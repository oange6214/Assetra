<UserControl
    x:Class="Assetra.WPF.Controls.DateRangePicker"
    xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
    xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
    xmlns:d="http://schemas.microsoft.com/expression/blend/2008"
    xmlns:local="clr-namespace:Assetra.WPF.Controls"
    xmlns:mc="http://schemas.openxmlformats.org/markup-compatibility/2006"
    xmlns:ui="http://schemas.lepo.co/wpfui/2022/xaml"
    x:Name="Root"
    mc:Ignorable="d">

    <UserControl.Resources>
        <!--  Day cell 基底 Style — 依據 DayCell 狀態切換色彩  -->
        <Style x:Key="DayCellButton" TargetType="Button">
            <Setter Property="Width" Value="30" />
            <Setter Property="Height" Value="26" />
            <Setter Property="Margin" Value="1" />
            <Setter Property="Background" Value="Transparent" />
            <Setter Property="BorderThickness" Value="0" />
            <Setter Property="Foreground" Value="{DynamicResource AppTextPrimary}" />
            <Setter Property="FontSize" Value="12" />
            <Setter Property="Cursor" Value="Hand" />
            <Setter Property="FocusVisualStyle" Value="{StaticResource FocusVisual}" />
            <Setter Property="Template">
                <Setter.Value>
                    <ControlTemplate TargetType="Button">
                        <Border
                            x:Name="Bd"
                            Background="{TemplateBinding Background}"
                            CornerRadius="4">
                            <ContentPresenter HorizontalAlignment="Center" VerticalAlignment="Center" />
                        </Border>
                        <ControlTemplate.Triggers>
                            <Trigger Property="IsMouseOver" Value="True">
                                <Setter TargetName="Bd" Property="Background" Value="{DynamicResource AppHover}" />
                            </Trigger>
                        </ControlTemplate.Triggers>
                    </ControlTemplate>
                </Setter.Value>
            </Setter>
            <Style.Triggers>
                <DataTrigger Binding="{Binding IsCurrentMonth}" Value="False">
                    <Setter Property="Foreground" Value="{DynamicResource AppTextMuted}" />
                    <Setter Property="Opacity" Value="0.45" />
                </DataTrigger>
                <!--  範圍內（start 跟 end 之間）：用 subtle 版本的 accent（跟主題一致）  -->
                <DataTrigger Binding="{Binding IsInRange}" Value="True">
                    <Setter Property="Background" Value="{DynamicResource AppAccentSubtle}" />
                </DataTrigger>
                <!--  起始 / 結束：實色 accent + 對比文字  -->
                <DataTrigger Binding="{Binding IsRangeStart}" Value="True">
                    <Setter Property="Background" Value="{DynamicResource AppAccent}" />
                    <Setter Property="Foreground" Value="{DynamicResource AppTextOnAccent}" />
                    <Setter Property="FontWeight" Value="SemiBold" />
                </DataTrigger>
                <DataTrigger Binding="{Binding IsRangeEnd}" Value="True">
                    <Setter Property="Background" Value="{DynamicResource AppAccent}" />
                    <Setter Property="Foreground" Value="{DynamicResource AppTextOnAccent}" />
                    <Setter Property="FontWeight" Value="SemiBold" />
                </DataTrigger>
            </Style.Triggers>
        </Style>

        <!--  Weekday header Style  -->
        <Style x:Key="WeekdayHeader" TargetType="TextBlock">
            <Setter Property="Width" Value="30" />
            <Setter Property="Margin" Value="1,4,1,6" />
            <Setter Property="HorizontalAlignment" Value="Center" />
            <Setter Property="TextAlignment" Value="Center" />
            <Setter Property="FontSize" Value="11" />
            <Setter Property="Foreground" Value="{DynamicResource AppTextMuted}" />
        </Style>
    </UserControl.Resources>

    <!--
        DataContext 指向 UserControl 自己，讓內部 bindings 能連到 DP（DisplayText、
        LeftDays 等）。外部從 Root 的 public DP 綁（StartDate/EndDate）不受影響，
        因為 DP 值是直接 set 到 UserControl 上。
    -->
    <Grid DataContext="{Binding ElementName=Root}">
        <!--  整個 Border 區域都是 popup 觸發器（用 ToggleButton + 自訂 template）  -->
        <ToggleButton
            x:Name="DisplayContainer"
            Height="30"
            HorizontalAlignment="Stretch"
            VerticalAlignment="Center"
            Cursor="Hand"
            FocusVisualStyle="{StaticResource FocusVisual}"
            IsChecked="{Binding IsPopupOpen, Mode=TwoWay}">
            <ToggleButton.Template>
                <ControlTemplate TargetType="ToggleButton">
                    <Border
                        Background="{DynamicResource AppBackground}"
                        BorderBrush="{DynamicResource AppBorder}"
                        BorderThickness="1"
                        CornerRadius="{StaticResource RadiusSm}">
                        <Grid>
                            <Grid.ColumnDefinitions>
                                <ColumnDefinition Width="Auto" />
                                <ColumnDefinition Width="*" />
                                <ColumnDefinition Width="Auto" />
                            </Grid.ColumnDefinitions>

                            <!--  左：行事曆圖示（Material Design 的 CalendarBlank）  -->
                            <ui:SymbolIcon
                                Grid.Column="0"
                                Width="14"
                                Height="14"
                                Margin="10,0,6,0"
                                VerticalAlignment="Center"
                                FontSize="14"
                                Foreground="{DynamicResource AppTextMuted}"
                                Symbol="CalendarLtr24" />

                            <!--  中：顯示文字  -->
                            <TextBlock
                                Grid.Column="1"
                                Margin="0,0,4,0"
                                VerticalAlignment="Center"
                                FontSize="{StaticResource FontSizeSm}"
                                Foreground="{DynamicResource AppTextPrimary}"
                                Text="{Binding DisplayText}"
                                TextTrimming="CharacterEllipsis" />

                            <!--  右：清除 X  overlay 位置（實際 Button 在模板外疊一層）  -->
                            <Border
                                Grid.Column="2"
                                Width="28"
                                Background="Transparent" />
                        </Grid>
                    </Border>
                </ControlTemplate>
            </ToggleButton.Template>
        </ToggleButton>

        <!--  清除 X — 疊在 ToggleButton 之上、右側；獨立 Button 以不觸發外層 toggle  -->
        <Button
            Width="22"
            Height="22"
            Margin="0,0,6,0"
            HorizontalAlignment="Right"
            VerticalAlignment="Center"
            Background="Transparent"
            BorderThickness="0"
            Click="ClearButton_Click"
            Cursor="Hand"
            FocusVisualStyle="{StaticResource FocusVisual}"
            Visibility="{Binding HasValue, Converter={StaticResource BooleanToVisibilityConverter}}">
            <ui:SymbolIcon
                Width="10"
                Height="10"
                FontSize="10"
                Foreground="{DynamicResource AppTextMuted}"
                Symbol="Dismiss24" />
        </Button>

        <!--  Popup：兩個月份行事曆  -->
        <Popup
            AllowsTransparency="True"
            IsOpen="{Binding IsPopupOpen, Mode=TwoWay}"
            Placement="Bottom"
            PlacementTarget="{Binding ElementName=DisplayContainer}"
            StaysOpen="False">
            <Border
                Margin="0,4,0,0"
                Padding="12"
                Background="{DynamicResource AppSurface}"
                BorderBrush="{DynamicResource AppBorder}"
                BorderThickness="1"
                CornerRadius="{StaticResource RadiusSm}">
                <StackPanel>
                    <!--  起迄輸入 + 重設  -->
                    <Grid Margin="0,0,0,12">
                        <Grid.ColumnDefinitions>
                            <ColumnDefinition Width="*" />
                            <ColumnDefinition Width="*" />
                            <ColumnDefinition Width="Auto" />
                        </Grid.ColumnDefinitions>
                        <TextBox
                            Grid.Column="0"
                            Height="30"
                            Margin="0,0,6,0"
                            Padding="8,0"
                            VerticalContentAlignment="Center"
                            Background="{DynamicResource AppBackground}"
                            BorderBrush="{DynamicResource AppBorder}"
                            BorderThickness="1"
                            FontFamily="{StaticResource FontBase}" Typography.NumeralAlignment="Tabular"
                            FontSize="{StaticResource FontSizeSm}"
                            Foreground="{DynamicResource AppTextPrimary}"
                            Text="{Binding StartDateText, UpdateSourceTrigger=LostFocus}" />
                        <TextBox
                            Grid.Column="1"
                            Height="30"
                            Margin="0,0,8,0"
                            Padding="8,0"
                            VerticalContentAlignment="Center"
                            Background="{DynamicResource AppBackground}"
                            BorderBrush="{DynamicResource AppBorder}"
                            BorderThickness="1"
                            FontFamily="{StaticResource FontBase}" Typography.NumeralAlignment="Tabular"
                            FontSize="{StaticResource FontSizeSm}"
                            Foreground="{DynamicResource AppTextPrimary}"
                            Text="{Binding EndDateText, UpdateSourceTrigger=LostFocus}" />
                        <ui:Button
                            Grid.Column="2"
                            Height="30"
                            Padding="12,0"
                            Click="Reset_Click"
                            Content="{DynamicResource DateRangePicker.Reset}"
                            FontSize="{StaticResource FontSizeSm}"
                            Appearance="Secondary" />
                    </Grid>

                    <!--  兩月並排  -->
                    <Grid>
                        <Grid.ColumnDefinitions>
                            <ColumnDefinition Width="Auto" />
                            <ColumnDefinition Width="12" />
                            <ColumnDefinition Width="Auto" />
                        </Grid.ColumnDefinitions>

                        <!--  左月  -->
                        <StackPanel Grid.Column="0">
                            <Grid Margin="0,0,0,6">
                                <Grid.ColumnDefinitions>
                                    <ColumnDefinition Width="Auto" />
                                    <ColumnDefinition Width="*" />
                                    <ColumnDefinition Width="Auto" />
                                </Grid.ColumnDefinitions>
                                <Button
                                    Grid.Column="0"
                                    Width="24"
                                    Height="24"
                                    Padding="0"
                                    Background="Transparent"
                                    BorderThickness="0"
                                    Click="PrevMonth_Click"
                                    Cursor="Hand"
                                    FocusVisualStyle="{StaticResource FocusVisual}">
                                    <ui:SymbolIcon
                                        Width="12"
                                        Height="12"
                                        FontSize="12"
                                        Foreground="{DynamicResource AppTextSecondary}"
                                        Symbol="ChevronLeft24" />
                                </Button>
                                <TextBlock
                                    Grid.Column="1"
                                    HorizontalAlignment="Center"
                                    VerticalAlignment="Center"
                                    FontSize="{StaticResource FontSizeBase}"
                                    FontWeight="SemiBold"
                                    Foreground="{DynamicResource AppTextPrimary}"
                                    Text="{Binding LeftMonthLabel}" />
                            </Grid>
                            <!--  Weekday headers  -->
                            <StackPanel Orientation="Horizontal">
                                <TextBlock Style="{StaticResource WeekdayHeader}" Text="Su" />
                                <TextBlock Style="{StaticResource WeekdayHeader}" Text="Mo" />
                                <TextBlock Style="{StaticResource WeekdayHeader}" Text="Tu" />
                                <TextBlock Style="{StaticResource WeekdayHeader}" Text="We" />
                                <TextBlock Style="{StaticResource WeekdayHeader}" Text="Th" />
                                <TextBlock Style="{StaticResource WeekdayHeader}" Text="Fr" />
                                <TextBlock Style="{StaticResource WeekdayHeader}" Text="Sa" />
                            </StackPanel>
                            <!--  Day cells (6 rows × 7 cols)  -->
                            <ItemsControl ItemsSource="{Binding LeftDays}">
                                <ItemsControl.ItemsPanel>
                                    <ItemsPanelTemplate>
                                        <UniformGrid Columns="7" Rows="6" />
                                    </ItemsPanelTemplate>
                                </ItemsControl.ItemsPanel>
                                <ItemsControl.ItemTemplate>
                                    <DataTemplate>
                                        <Button
                                            Click="DayCell_Click"
                                            Content="{Binding Day}"
                                            Style="{StaticResource DayCellButton}" />
                                    </DataTemplate>
                                </ItemsControl.ItemTemplate>
                            </ItemsControl>
                        </StackPanel>

                        <!--  右月  -->
                        <StackPanel Grid.Column="2">
                            <Grid Margin="0,0,0,6">
                                <Grid.ColumnDefinitions>
                                    <ColumnDefinition Width="Auto" />
                                    <ColumnDefinition Width="*" />
                                    <ColumnDefinition Width="Auto" />
                                </Grid.ColumnDefinitions>
                                <TextBlock
                                    Grid.Column="1"
                                    HorizontalAlignment="Center"
                                    VerticalAlignment="Center"
                                    FontSize="{StaticResource FontSizeBase}"
                                    FontWeight="SemiBold"
                                    Foreground="{DynamicResource AppTextPrimary}"
                                    Text="{Binding RightMonthLabel}" />
                                <Button
                                    Grid.Column="2"
                                    Width="24"
                                    Height="24"
                                    Padding="0"
                                    Background="Transparent"
                                    BorderThickness="0"
                                    Click="NextMonth_Click"
                                    Cursor="Hand"
                                    FocusVisualStyle="{StaticResource FocusVisual}">
                                    <ui:SymbolIcon
                                        Width="12"
                                        Height="12"
                                        FontSize="12"
                                        Foreground="{DynamicResource AppTextSecondary}"
                                        Symbol="ChevronRight24" />
                                </Button>
                            </Grid>
                            <StackPanel Orientation="Horizontal">
                                <TextBlock Style="{StaticResource WeekdayHeader}" Text="Su" />
                                <TextBlock Style="{StaticResource WeekdayHeader}" Text="Mo" />
                                <TextBlock Style="{StaticResource WeekdayHeader}" Text="Tu" />
                                <TextBlock Style="{StaticResource WeekdayHeader}" Text="We" />
                                <TextBlock Style="{StaticResource WeekdayHeader}" Text="Th" />
                                <TextBlock Style="{StaticResource WeekdayHeader}" Text="Fr" />
                                <TextBlock Style="{StaticResource WeekdayHeader}" Text="Sa" />
                            </StackPanel>
                            <ItemsControl ItemsSource="{Binding RightDays}">
                                <ItemsControl.ItemsPanel>
                                    <ItemsPanelTemplate>
                                        <UniformGrid Columns="7" Rows="6" />
                                    </ItemsPanelTemplate>
                                </ItemsControl.ItemsPanel>
                                <ItemsControl.ItemTemplate>
                                    <DataTemplate>
                                        <Button
                                            Click="DayCell_Click"
                                            Content="{Binding Day}"
                                            Style="{StaticResource DayCellButton}" />
                                    </DataTemplate>
                                </ItemsControl.ItemTemplate>
                            </ItemsControl>
                        </StackPanel>
                    </Grid>
                </StackPanel>
            </Border>
        </Popup>
    </Grid>
</UserControl>
