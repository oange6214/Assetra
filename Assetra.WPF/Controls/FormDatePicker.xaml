<UserControl
    x:Class="Assetra.WPF.Controls.FormDatePicker"
    xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
    xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
    xmlns:local="clr-namespace:Assetra.WPF.Controls"
    x:Name="Root">

    <Border
        x:Name="OuterBorder"
        Padding="4,5"
        Background="{DynamicResource AppBackground}"
        BorderBrush="{DynamicResource AppBorder}"
        BorderThickness="1"
        CornerRadius="4">

        <Grid>
            <Grid.ColumnDefinitions>
                <ColumnDefinition Width="*" />
                <ColumnDefinition Width="26" />
            </Grid.ColumnDefinitions>

            <!--  日期時間文字框（yyyy-MM-dd HH:mm）  -->
            <TextBox
                x:Name="DateTextBox"
                Grid.Column="0"
                Padding="4,5"
                VerticalContentAlignment="Center"
                Background="Transparent"
                BorderThickness="0"
                CaretBrush="{DynamicResource AppTextPrimary}"
                FocusVisualStyle="{x:Null}"
                FontFamily="{DynamicResource FontTabular}"
                FontSize="{StaticResource FontSizeSm}"
                Foreground="{DynamicResource AppTextPrimary}"
                KeyDown="DateTextBox_KeyDown"
                LostFocus="DateTextBox_LostFocus"
                SelectionBrush="{DynamicResource AppAccent}" />

            <!--  日曆圖示按鈕  -->
            <Button
                x:Name="ToggleButton"
                Grid.Column="1"
                Background="Transparent"
                BorderThickness="0"
                Click="ToggleButton_Click"
                Cursor="Hand"
                FocusVisualStyle="{x:Null}"
                Focusable="False">
                <Button.Template>
                    <ControlTemplate TargetType="Button">
                        <Border
                            x:Name="Bd"
                            Background="Transparent"
                            CornerRadius="4">
                            <Path
                                x:Name="Icon"
                                HorizontalAlignment="Center"
                                VerticalAlignment="Center"
                                Data="M4,2 L4,4 M10,2 L10,4 M1,6 L13,6 M1,3.5 C1,2.7 1.7,2 2.5,2 L11.5,2 C12.3,2 13,2.7 13,3.5 L13,12.5 C13,13.3 12.3,14 11.5,14 L2.5,14 C1.7,14 1,13.3 1,12.5 Z M3,8.5 L5,8.5 M6.5,8.5 L8.5,8.5 M10,8.5 L12,8.5 M3,11 L5,11 M6.5,11 L8.5,11"
                                Stretch="Uniform"
                                Stroke="{DynamicResource AppTextMuted}"
                                StrokeEndLineCap="Round"
                                StrokeLineJoin="Round"
                                StrokeStartLineCap="Round"
                                StrokeThickness="1.1" />
                        </Border>
                        <ControlTemplate.Triggers>
                            <Trigger Property="IsMouseOver" Value="True">
                                <Setter TargetName="Bd" Property="Background" Value="{DynamicResource AppHover}" />
                                <Setter TargetName="Icon" Property="Stroke" Value="{DynamicResource AppTextPrimary}" />
                            </Trigger>
                            <Trigger Property="IsPressed" Value="True">
                                <Setter TargetName="Bd" Property="Background" Value="{DynamicResource AppAccent}" />
                                <Setter TargetName="Icon" Property="Stroke" Value="White" />
                            </Trigger>
                        </ControlTemplate.Triggers>
                    </ControlTemplate>
                </Button.Template>
            </Button>

            <!--  Popup：自製 CalendarPanel，完全不依賴 WPF 內建 Calendar  -->
            <Popup
                x:Name="CalendarPopup"
                Grid.ColumnSpan="2"
                AllowsTransparency="True"
                Closed="CalendarPopup_Closed"
                Opened="CalendarPopup_Opened"
                Placement="Bottom"
                PlacementTarget="{Binding ElementName=OuterBorder}"
                StaysOpen="False">
                <Border
                    x:Name="PopupContent"
                    Padding="6"
                    Background="{DynamicResource AppSurface}"
                    BorderBrush="{DynamicResource AppBorder}"
                    BorderThickness="1"
                    CornerRadius="8"
                    RenderTransformOrigin="0.5,0">
                    <Border.RenderTransform>
                        <TranslateTransform x:Name="PopupSlide" />
                    </Border.RenderTransform>
                    <!--  Grid 讓兩欄共用同一列高度，TimePanel 由 CalendarPanel 高度決定  -->
                    <Grid>
                        <Grid.ColumnDefinitions>
                            <ColumnDefinition Width="Auto" />
                            <ColumnDefinition Width="Auto" />
                        </Grid.ColumnDefinitions>

                        <local:CalendarPanel
                            x:Name="InnerCalendar"
                            Grid.Column="0"
                            DatePicked="InnerCalendar_DatePicked" />

                        <!--
                            時間面板（ShowTime=True 時由 code-behind 設為 Visible）
                            MaxHeight 綁定 CalendarPanel 的實際高度，防止無限延展
                        -->
                        <Border
                            x:Name="TimePanelBorder"
                            Grid.Column="1"
                            MaxHeight="{Binding ActualHeight, ElementName=InnerCalendar}"
                            Margin="6,0,0,0"
                            Padding="6,0,0,0"
                            BorderBrush="{DynamicResource AppBorder}"
                            BorderThickness="1,0,0,0"
                            Visibility="Collapsed">
                            <local:TimePanel x:Name="InnerTime" TimePicked="InnerTime_TimePicked" />
                        </Border>
                    </Grid>
                </Border>
            </Popup>
        </Grid>
    </Border>
</UserControl>
