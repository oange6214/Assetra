<UserControl
    x:Class="Assetra.WPF.Controls.HexColorPicker"
    xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
    xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
    xmlns:d="http://schemas.microsoft.com/expression/blend/2008"
    xmlns:mc="http://schemas.openxmlformats.org/markup-compatibility/2006"
    xmlns:ui="http://schemas.lepo.co/wpfui/2022/xaml"
    x:Name="Root"
    mc:Ignorable="d">

    <Grid>
        <ui:Button
            x:Name="OpenButton"
            MinHeight="{Binding MinHeight, RelativeSource={RelativeSource AncestorType=UserControl}}"
            Padding="6,4"
            Appearance="Secondary"
            HorizontalContentAlignment="Stretch"
            Click="OpenButton_OnClick"
            Cursor="Hand">
            <DockPanel>
                <ui:SymbolIcon
                    Margin="6,0,0,0"
                    VerticalAlignment="Center"
                    DockPanel.Dock="Right"
                    FontSize="{StaticResource FontSizeXs}"
                    Foreground="{DynamicResource AppTextMuted}"
                    Symbol="ChevronDown24" />
                <Border
                    Width="22"
                    Height="22"
                    Background="{Binding SelectedColorHex, RelativeSource={RelativeSource AncestorType=UserControl}, Converter={StaticResource HexToBrushConverter}}"
                    BorderBrush="#33000000"
                    BorderThickness="1"
                    CornerRadius="{StaticResource RadiusSm}"
                    DockPanel.Dock="Left" />
                <TextBlock
                    Margin="8,0,0,0"
                    VerticalAlignment="Center"
                    FontFamily="{StaticResource FontBase}"
                    FontSize="{StaticResource FontSizeSm}"
                    Foreground="{DynamicResource AppTextPrimary}"
                    Text="{Binding SelectedColorHex, RelativeSource={RelativeSource AncestorType=UserControl}}"
                    Typography.NumeralAlignment="Tabular" />
            </DockPanel>
        </ui:Button>

        <Popup
            x:Name="PickerPopup"
            AllowsTransparency="True"
            Placement="Bottom"
            PlacementTarget="{Binding ElementName=OpenButton}"
            PopupAnimation="Fade"
            StaysOpen="False">
            <Border
                Margin="0,4,0,0"
                Padding="14"
                Background="{DynamicResource AppSurface}"
                BorderBrush="{DynamicResource AppBorder}"
                BorderThickness="1"
                CornerRadius="{StaticResource RadiusMd}">
                <Border.Effect>
                    <DropShadowEffect
                        BlurRadius="16"
                        Opacity="0.18"
                        ShadowDepth="2" />
                </Border.Effect>

                <StackPanel MinWidth="220">
                    <TextBlock
                        Margin="0,0,0,8"
                        FontSize="{StaticResource FontSizeXs}"
                        FontWeight="SemiBold"
                        Foreground="{DynamicResource AppTextMuted}"
                        Text="{DynamicResource HexColorPicker.Presets}" />
                    <ItemsControl x:Name="PresetsItemsControl">
                        <ItemsControl.ItemsPanel>
                            <ItemsPanelTemplate>
                                <WrapPanel />
                            </ItemsPanelTemplate>
                        </ItemsControl.ItemsPanel>
                        <ItemsControl.ItemTemplate>
                            <DataTemplate>
                                <ui:Button
                                    Width="26"
                                    Height="26"
                                    Margin="0,0,6,6"
                                    Click="Swatch_OnClick"
                                    Cursor="Hand"
                                    Tag="{Binding}">
                                    <ui:Button.Template>
                                        <ControlTemplate TargetType="ui:Button">
                                            <Border
                                                Background="{Binding Converter={StaticResource HexToBrushConverter}}"
                                                BorderBrush="#33000000"
                                                BorderThickness="1"
                                                CornerRadius="{StaticResource RadiusSm}">
                                                <ContentPresenter />
                                            </Border>
                                        </ControlTemplate>
                                    </ui:Button.Template>
                                </ui:Button>
                            </DataTemplate>
                        </ItemsControl.ItemTemplate>
                    </ItemsControl>

                    <TextBlock
                        Margin="0,8,0,4"
                        FontSize="{StaticResource FontSizeXs}"
                        FontWeight="SemiBold"
                        Foreground="{DynamicResource AppTextMuted}"
                        Text="HEX" />
                    <Grid>
                        <Grid.ColumnDefinitions>
                            <ColumnDefinition Width="*" />
                            <ColumnDefinition Width="6" />
                            <ColumnDefinition Width="Auto" />
                        </Grid.ColumnDefinitions>
                        <ui:TextBox
                            x:Name="HexInput"
                            Grid.Column="0"
                            MinHeight="32"
                            FontFamily="{StaticResource FontBase}"
                            KeyDown="HexInput_OnKeyDown"
                            MaxLength="7"
                            PlaceholderText="#RRGGBB"
                            Typography.NumeralAlignment="Tabular" />
                        <ui:Button
                            Grid.Column="2"
                            MinWidth="56"
                            MinHeight="32"
                            Padding="10,0"
                            Appearance="Primary"
                            Click="ApplyHex_OnClick">
                            <TextBlock Foreground="{Binding Foreground, RelativeSource={RelativeSource AncestorType=Button}}" Text="{DynamicResource HexColorPicker.Apply}" />
                        </ui:Button>
                    </Grid>

                    <TextBlock
                        x:Name="HexError"
                        Margin="0,4,0,0"
                        FontSize="{StaticResource FontSizeXs}"
                        Foreground="{DynamicResource AppDown}"
                        Text="{DynamicResource HexColorPicker.HexInvalid}"
                        Visibility="Collapsed" />
                </StackPanel>
            </Border>
        </Popup>
    </Grid>
</UserControl>
