<UserControl
    x:Class="Assetra.WPF.Controls.CalendarPanel"
    xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
    xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
    x:Name="Root"
    Width="280">

    <UserControl.Resources>

        <!--  Day cell button: circle indicator + scale animation on hover/press  -->
        <Style x:Key="DayCellBtn" TargetType="Button">
            <Setter Property="Background" Value="Transparent" />
            <Setter Property="BorderThickness" Value="0" />
            <Setter Property="Cursor" Value="Hand" />
            <Setter Property="FocusVisualStyle" Value="{x:Null}" />
            <Setter Property="HorizontalAlignment" Value="Stretch" />
            <Setter Property="VerticalAlignment" Value="Stretch" />
            <Setter Property="Template">
                <Setter.Value>
                    <ControlTemplate TargetType="Button">
                        <!--  Outer grid fills the UniformGrid cell  -->
                        <Grid RenderTransformOrigin="0.5,0.5">
                            <Grid.RenderTransform>
                                <ScaleTransform x:Name="CellScale" />
                            </Grid.RenderTransform>

                            <!--  Hover circle (underneath, fades in on hover)  -->
                            <Border
                                x:Name="HoverBd"
                                Width="32"
                                Height="32"
                                HorizontalAlignment="Center"
                                VerticalAlignment="Center"
                                Background="{DynamicResource AppHover}"
                                CornerRadius="16"
                                Opacity="0" />

                            <!--  Selection fill (AppAccent when selected, Transparent otherwise)  -->
                            <Border
                                x:Name="SelBd"
                                Width="32"
                                Height="32"
                                HorizontalAlignment="Center"
                                VerticalAlignment="Center"
                                Background="{TemplateBinding Background}"
                                CornerRadius="16" />

                            <!--  Day number + today dot  -->
                            <ContentPresenter HorizontalAlignment="Center" VerticalAlignment="Center" />
                        </Grid>

                        <ControlTemplate.Triggers>

                            <!--  Hover: fade in hover circle + scale up  -->
                            <EventTrigger RoutedEvent="MouseEnter">
                                <BeginStoryboard>
                                    <Storyboard>
                                        <DoubleAnimation
                                            Storyboard.TargetName="HoverBd"
                                            Storyboard.TargetProperty="Opacity"
                                            To="1"
                                            Duration="0:0:0.12" />
                                        <DoubleAnimation
                                            Storyboard.TargetName="CellScale"
                                            Storyboard.TargetProperty="ScaleX"
                                            To="1.12"
                                            Duration="0:0:0.14">
                                            <DoubleAnimation.EasingFunction>
                                                <CubicEase EasingMode="EaseOut" />
                                            </DoubleAnimation.EasingFunction>
                                        </DoubleAnimation>
                                        <DoubleAnimation
                                            Storyboard.TargetName="CellScale"
                                            Storyboard.TargetProperty="ScaleY"
                                            To="1.12"
                                            Duration="0:0:0.14">
                                            <DoubleAnimation.EasingFunction>
                                                <CubicEase EasingMode="EaseOut" />
                                            </DoubleAnimation.EasingFunction>
                                        </DoubleAnimation>
                                    </Storyboard>
                                </BeginStoryboard>
                            </EventTrigger>

                            <!--  Mouse leave: restore  -->
                            <EventTrigger RoutedEvent="MouseLeave">
                                <BeginStoryboard>
                                    <Storyboard>
                                        <DoubleAnimation
                                            Storyboard.TargetName="HoverBd"
                                            Storyboard.TargetProperty="Opacity"
                                            To="0"
                                            Duration="0:0:0.10" />
                                        <DoubleAnimation
                                            Storyboard.TargetName="CellScale"
                                            Storyboard.TargetProperty="ScaleX"
                                            To="1"
                                            Duration="0:0:0.10" />
                                        <DoubleAnimation
                                            Storyboard.TargetName="CellScale"
                                            Storyboard.TargetProperty="ScaleY"
                                            To="1"
                                            Duration="0:0:0.10" />
                                    </Storyboard>
                                </BeginStoryboard>
                            </EventTrigger>

                            <!--  Press: squeeze  -->
                            <EventTrigger RoutedEvent="PreviewMouseLeftButtonDown">
                                <BeginStoryboard>
                                    <Storyboard>
                                        <DoubleAnimation
                                            Storyboard.TargetName="CellScale"
                                            Storyboard.TargetProperty="ScaleX"
                                            To="0.88"
                                            Duration="0:0:0.07" />
                                        <DoubleAnimation
                                            Storyboard.TargetName="CellScale"
                                            Storyboard.TargetProperty="ScaleY"
                                            To="0.88"
                                            Duration="0:0:0.07" />
                                    </Storyboard>
                                </BeginStoryboard>
                            </EventTrigger>

                            <!--  Release: spring back  -->
                            <EventTrigger RoutedEvent="PreviewMouseLeftButtonUp">
                                <BeginStoryboard>
                                    <Storyboard>
                                        <DoubleAnimation
                                            Storyboard.TargetName="CellScale"
                                            Storyboard.TargetProperty="ScaleX"
                                            To="1"
                                            Duration="0:0:0.18">
                                            <DoubleAnimation.EasingFunction>
                                                <ElasticEase EasingMode="EaseOut" Oscillations="1" Springiness="8" />
                                            </DoubleAnimation.EasingFunction>
                                        </DoubleAnimation>
                                        <DoubleAnimation
                                            Storyboard.TargetName="CellScale"
                                            Storyboard.TargetProperty="ScaleY"
                                            To="1"
                                            Duration="0:0:0.18">
                                            <DoubleAnimation.EasingFunction>
                                                <ElasticEase EasingMode="EaseOut" Oscillations="1" Springiness="8" />
                                            </DoubleAnimation.EasingFunction>
                                        </DoubleAnimation>
                                    </Storyboard>
                                </BeginStoryboard>
                            </EventTrigger>

                            <!--  Disabled  -->
                            <Trigger Property="IsEnabled" Value="False">
                                <Setter Property="Opacity" Value="0.3" />
                            </Trigger>

                        </ControlTemplate.Triggers>
                    </ControlTemplate>
                </Setter.Value>
            </Setter>
        </Style>

        <!--  Month navigation arrow button  -->
        <Style x:Key="NavBtn" TargetType="Button">
            <Setter Property="Background" Value="Transparent" />
            <Setter Property="BorderThickness" Value="0" />
            <Setter Property="Width" Value="28" />
            <Setter Property="Height" Value="28" />
            <Setter Property="Cursor" Value="Hand" />
            <Setter Property="FocusVisualStyle" Value="{x:Null}" />
            <Setter Property="Template">
                <Setter.Value>
                    <ControlTemplate TargetType="Button">
                        <Border
                            x:Name="Bd"
                            Background="Transparent"
                            CornerRadius="14"
                            RenderTransformOrigin="0.5,0.5">
                            <Border.RenderTransform>
                                <ScaleTransform x:Name="NavScale" />
                            </Border.RenderTransform>
                            <ContentPresenter HorizontalAlignment="Center" VerticalAlignment="Center" />
                        </Border>
                        <ControlTemplate.Triggers>
                            <Trigger Property="IsMouseOver" Value="True">
                                <Setter TargetName="Bd" Property="Background" Value="{DynamicResource AppHover}" />
                            </Trigger>
                            <EventTrigger RoutedEvent="PreviewMouseLeftButtonDown">
                                <BeginStoryboard>
                                    <Storyboard>
                                        <DoubleAnimation
                                            Storyboard.TargetName="NavScale"
                                            Storyboard.TargetProperty="ScaleX"
                                            To="0.85"
                                            Duration="0:0:0.07" />
                                        <DoubleAnimation
                                            Storyboard.TargetName="NavScale"
                                            Storyboard.TargetProperty="ScaleY"
                                            To="0.85"
                                            Duration="0:0:0.07" />
                                    </Storyboard>
                                </BeginStoryboard>
                            </EventTrigger>
                            <EventTrigger RoutedEvent="PreviewMouseLeftButtonUp">
                                <BeginStoryboard>
                                    <Storyboard>
                                        <DoubleAnimation
                                            Storyboard.TargetName="NavScale"
                                            Storyboard.TargetProperty="ScaleX"
                                            To="1"
                                            Duration="0:0:0.15">
                                            <DoubleAnimation.EasingFunction>
                                                <CubicEase EasingMode="EaseOut" />
                                            </DoubleAnimation.EasingFunction>
                                        </DoubleAnimation>
                                        <DoubleAnimation
                                            Storyboard.TargetName="NavScale"
                                            Storyboard.TargetProperty="ScaleY"
                                            To="1"
                                            Duration="0:0:0.15">
                                            <DoubleAnimation.EasingFunction>
                                                <CubicEase EasingMode="EaseOut" />
                                            </DoubleAnimation.EasingFunction>
                                        </DoubleAnimation>
                                    </Storyboard>
                                </BeginStoryboard>
                            </EventTrigger>
                        </ControlTemplate.Triggers>
                    </ControlTemplate>
                </Setter.Value>
            </Setter>
        </Style>

        <!--  Today pill button  -->
        <Style x:Key="TodayBtn" TargetType="Button">
            <Setter Property="Background" Value="Transparent" />
            <Setter Property="BorderBrush" Value="{DynamicResource AppBorder}" />
            <Setter Property="BorderThickness" Value="1" />
            <Setter Property="Cursor" Value="Hand" />
            <Setter Property="FocusVisualStyle" Value="{x:Null}" />
            <Setter Property="Padding" Value="14,4" />
            <Setter Property="Template">
                <Setter.Value>
                    <ControlTemplate TargetType="Button">
                        <Border
                            x:Name="Bd"
                            Padding="{TemplateBinding Padding}"
                            Background="{TemplateBinding Background}"
                            BorderBrush="{TemplateBinding BorderBrush}"
                            BorderThickness="{TemplateBinding BorderThickness}"
                            CornerRadius="12"
                            RenderTransformOrigin="0.5,0.5">
                            <Border.RenderTransform>
                                <ScaleTransform x:Name="TodayScale" />
                            </Border.RenderTransform>
                            <ContentPresenter HorizontalAlignment="Center" VerticalAlignment="Center" />
                        </Border>
                        <ControlTemplate.Triggers>
                            <Trigger Property="IsMouseOver" Value="True">
                                <Setter TargetName="Bd" Property="Background" Value="{DynamicResource AppAccentSubtle}" />
                                <Setter TargetName="Bd" Property="BorderBrush" Value="{DynamicResource AppAccent}" />
                            </Trigger>
                            <EventTrigger RoutedEvent="PreviewMouseLeftButtonDown">
                                <BeginStoryboard>
                                    <Storyboard>
                                        <DoubleAnimation
                                            Storyboard.TargetName="TodayScale"
                                            Storyboard.TargetProperty="ScaleX"
                                            To="0.93"
                                            Duration="0:0:0.07" />
                                        <DoubleAnimation
                                            Storyboard.TargetName="TodayScale"
                                            Storyboard.TargetProperty="ScaleY"
                                            To="0.93"
                                            Duration="0:0:0.07" />
                                    </Storyboard>
                                </BeginStoryboard>
                            </EventTrigger>
                            <EventTrigger RoutedEvent="PreviewMouseLeftButtonUp">
                                <BeginStoryboard>
                                    <Storyboard>
                                        <DoubleAnimation
                                            Storyboard.TargetName="TodayScale"
                                            Storyboard.TargetProperty="ScaleX"
                                            To="1"
                                            Duration="0:0:0.15">
                                            <DoubleAnimation.EasingFunction>
                                                <CubicEase EasingMode="EaseOut" />
                                            </DoubleAnimation.EasingFunction>
                                        </DoubleAnimation>
                                        <DoubleAnimation
                                            Storyboard.TargetName="TodayScale"
                                            Storyboard.TargetProperty="ScaleY"
                                            To="1"
                                            Duration="0:0:0.15">
                                            <DoubleAnimation.EasingFunction>
                                                <CubicEase EasingMode="EaseOut" />
                                            </DoubleAnimation.EasingFunction>
                                        </DoubleAnimation>
                                    </Storyboard>
                                </BeginStoryboard>
                            </EventTrigger>
                        </ControlTemplate.Triggers>
                    </ControlTemplate>
                </Setter.Value>
            </Setter>
        </Style>

    </UserControl.Resources>

    <Grid>
        <Grid.RowDefinitions>
            <RowDefinition Height="36" />
            <RowDefinition Height="Auto" />
            <RowDefinition Height="Auto" />
        </Grid.RowDefinitions>

        <!--  Month navigation row  -->
        <Grid Grid.Row="0" Margin="4,0">
            <Grid.ColumnDefinitions>
                <ColumnDefinition Width="28" />
                <ColumnDefinition Width="*" />
                <ColumnDefinition Width="28" />
            </Grid.ColumnDefinitions>

            <Button Grid.Column="0" Click="PrevMonth_Click" Style="{StaticResource NavBtn}">
                <Path
                    HorizontalAlignment="Center"
                    VerticalAlignment="Center"
                    Data="M8,2 L2,8 L8,14"
                    Stretch="None"
                    Stroke="{DynamicResource AppTextSecondary}"
                    StrokeEndLineCap="Round"
                    StrokeLineJoin="Round"
                    StrokeStartLineCap="Round"
                    StrokeThickness="1.6" />
            </Button>

            <TextBlock
                x:Name="HeaderText"
                Grid.Column="1"
                HorizontalAlignment="Center"
                VerticalAlignment="Center"
                FontFamily="{DynamicResource FontBase}"
                FontSize="{StaticResource FontSizeBase}"
                FontWeight="SemiBold"
                Foreground="{DynamicResource AppTextPrimary}" />

            <Button Grid.Column="2" Click="NextMonth_Click" Style="{StaticResource NavBtn}">
                <Path
                    HorizontalAlignment="Center"
                    VerticalAlignment="Center"
                    Data="M2,2 L8,8 L2,14"
                    Stretch="None"
                    Stroke="{DynamicResource AppTextSecondary}"
                    StrokeEndLineCap="Round"
                    StrokeLineJoin="Round"
                    StrokeStartLineCap="Round"
                    StrokeThickness="1.6" />
            </Button>
        </Grid>

        <!--  Day grid (7 cols × 7 rows: weekday header + 6 weeks)  -->
        <UniformGrid
            x:Name="DayGrid"
            Grid.Row="1"
            Columns="7"
            Rows="7"
            Margin="4,0,4,4" />

        <!--  Today quick-jump  -->
        <Button
            x:Name="TodayBtn"
            Grid.Row="2"
            Margin="0,0,0,6"
            HorizontalAlignment="Center"
            Click="Today_Click"
            Style="{StaticResource TodayBtn}">
            <TextBlock
                FontFamily="{DynamicResource FontBase}"
                FontSize="{StaticResource FontSizeSm}"
                FontWeight="Medium"
                Foreground="{DynamicResource AppAccent}"
                Text="{DynamicResource Calendar.Today}" />
        </Button>

    </Grid>
</UserControl>
