<UserControl
    x:Class="Assetra.WPF.Controls.SearchBox"
    xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
    xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
    xmlns:d="http://schemas.microsoft.com/expression/blend/2008"
    xmlns:ds="clr-namespace:Assetra.WPF.DesignSystem.Controls"
    xmlns:mc="http://schemas.openxmlformats.org/markup-compatibility/2006"
    mc:Ignorable="d">

    <UserControl.Resources>
        <Style x:Key="SearchBoxClearButton" TargetType="Button">
            <Setter Property="Width" Value="26" />
            <Setter Property="Height" Value="26" />
            <Setter Property="Padding" Value="6" />
            <Setter Property="Background" Value="Transparent" />
            <Setter Property="BorderBrush" Value="Transparent" />
            <Setter Property="BorderThickness" Value="0" />
            <Setter Property="Cursor" Value="Hand" />
            <Setter Property="FocusVisualStyle" Value="{StaticResource FocusVisual}" />
            <Setter Property="Template">
                <Setter.Value>
                    <ControlTemplate TargetType="Button">
                        <Border
                            x:Name="Chrome"
                            Padding="{TemplateBinding Padding}"
                            Background="{TemplateBinding Background}"
                            CornerRadius="{StaticResource Radius.Sm}">
                            <ContentPresenter HorizontalAlignment="Center" VerticalAlignment="Center" />
                        </Border>
                        <ControlTemplate.Triggers>
                            <Trigger Property="IsMouseOver" Value="True">
                                <Setter TargetName="Chrome" Property="Background" Value="{DynamicResource AppHover}" />
                            </Trigger>
                            <Trigger Property="IsEnabled" Value="False">
                                <Setter Property="Opacity" Value="0.45" />
                                <Setter Property="Cursor" Value="Arrow" />
                            </Trigger>
                        </ControlTemplate.Triggers>
                    </ControlTemplate>
                </Setter.Value>
            </Setter>
        </Style>
    </UserControl.Resources>

    <!--
        Outer filter bar — 獨立模式時有 AppSurface 背景 + 底線分隔；
        IsInline=True 時移除這些額外 chrome，只留核心輸入樣式，方便嵌進既有工具列。
    -->
    <Border>
        <Border.Style>
            <Style TargetType="Border">
                <Setter Property="Padding" Value="12,6" />
                <Setter Property="Background" Value="{DynamicResource AppSurface}" />
                <Setter Property="BorderBrush" Value="{DynamicResource AppBorder}" />
                <Setter Property="BorderThickness" Value="0,0,0,1" />
                <Style.Triggers>
                    <DataTrigger Binding="{Binding IsInline, RelativeSource={RelativeSource AncestorType=UserControl}}" Value="True">
                        <Setter Property="Padding" Value="0" />
                        <Setter Property="Background" Value="Transparent" />
                        <Setter Property="BorderThickness" Value="0" />
                    </DataTrigger>
                </Style.Triggers>
            </Style>
        </Border.Style>
        <DockPanel>
            <!--
                Optional right-side slot (e.g. "＋ 新增現金" button). Sits flush with the search
                input's right edge via DockPanel.Dock="Right" + left margin for breathing room.
            -->
            <ContentPresenter
                Margin="8,0,0,0"
                VerticalAlignment="Center"
                Content="{Binding RightContent, RelativeSource={RelativeSource AncestorType=UserControl}}"
                DockPanel.Dock="Right" />

            <Border
                MinHeight="34"
                Background="{DynamicResource AppBackground}"
                BorderBrush="{DynamicResource AppBorder}"
                BorderThickness="1"
                CornerRadius="{StaticResource Radius.Sm}">
                <Grid>
                    <Grid.ColumnDefinitions>
                        <ColumnDefinition Width="32" />
                        <ColumnDefinition Width="*" />
                        <ColumnDefinition Width="30" />
                    </Grid.ColumnDefinitions>

                    <ds:AppIcon
                        Grid.Column="0"
                        Width="14"
                        Height="14"
                        HorizontalAlignment="Center"
                        VerticalAlignment="Center"
                        FontSize="14"
                        Foreground="{DynamicResource AppTextMuted}"
                        IsHitTestVisible="False"
                        Symbol="Search24" />

                    <TextBox
                        x:Name="InputBox"
                        Grid.Column="1"
                        MinHeight="0"
                        Padding="0"
                        VerticalContentAlignment="Center"
                        Background="Transparent"
                        BorderThickness="0"
                        FontFamily="{StaticResource Font.Family.Base}"
                        FontSize="{StaticResource Font.Size.Sm}"
                        Foreground="{DynamicResource AppTextPrimary}"
                        Text="{Binding Text, RelativeSource={RelativeSource AncestorType=UserControl}, UpdateSourceTrigger=PropertyChanged}" />

                    <TextBlock
                        Grid.Column="1"
                        Margin="0,0,4,0"
                        VerticalAlignment="Center"
                        FontFamily="{StaticResource Font.Family.Base}"
                        FontSize="{StaticResource Font.Size.Sm}"
                        Foreground="{DynamicResource AppTextMuted}"
                        IsHitTestVisible="False"
                        Text="{Binding Placeholder, RelativeSource={RelativeSource AncestorType=UserControl}}">
                        <TextBlock.Style>
                            <Style TargetType="TextBlock">
                                <Setter Property="Visibility" Value="Collapsed" />
                                <Style.Triggers>
                                    <DataTrigger Binding="{Binding Text, ElementName=InputBox}" Value="">
                                        <Setter Property="Visibility" Value="Visible" />
                                    </DataTrigger>
                                </Style.Triggers>
                            </Style>
                        </TextBlock.Style>
                    </TextBlock>

                    <Button
                        Grid.Column="2"
                        HorizontalAlignment="Center"
                        VerticalAlignment="Center"
                        Click="ClearButton_Click">
                        <Button.Style>
                            <Style BasedOn="{StaticResource SearchBoxClearButton}" TargetType="Button">
                                <Setter Property="Visibility" Value="Visible" />
                                <Style.Triggers>
                                    <DataTrigger Binding="{Binding Text, ElementName=InputBox}" Value="">
                                        <Setter Property="Visibility" Value="Collapsed" />
                                    </DataTrigger>
                                </Style.Triggers>
                            </Style>
                        </Button.Style>
                        <ds:AppIcon
                            Width="10"
                            Height="10"
                            FontSize="10"
                            Foreground="{DynamicResource AppTextMuted}"
                            Symbol="Dismiss24" />
                    </Button>
                </Grid>
            </Border>
        </DockPanel>
    </Border>
</UserControl>
