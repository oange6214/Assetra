<ResourceDictionary
    xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
    xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
    xmlns:sys="clr-namespace:System;assembly=mscorlib">

    <!--
        ════════════════════════════════════════════════════════════════
        Assetra Design Tokens — single source of truth
        ════════════════════════════════════════════════════════════════
        Mirrors the design system delivered in
        asset-management-uxui-guideline.docx (v1.0).

        Layer 1 — primitive values (theme-independent).
        Layer 2 — Light/Dark palette mappings live in their respective
                  theme dictionaries (Themes/Light.xaml, Themes/Dark.xaml)
                  and consume these primitives through DynamicResource so
                  swapping the theme dictionary at runtime carries through.
        Layer 3 — Wpf.Ui control-key overrides (AccentButton*, etc.) also
                  live in the theme dictionaries and reference Layer 2.
    -->

    <!--  ══ Brand primitives ══  -->
    <Color x:Key="Brand.Primary">#142F55</Color>
    <Color x:Key="Brand.Primary.Dark">#3B82F6</Color>
    <Color x:Key="Brand.Accent">#C8A25A</Color>
    <Color x:Key="Brand.Accent.Dark">#E6C27A</Color>
    <Color x:Key="Brand.Ink">#0F172A</Color>

    <!--  ══ Slate neutrals (Tailwind slate scale) ══  -->
    <Color x:Key="Slate.50">#F8FAFC</Color>
    <Color x:Key="Slate.100">#F1F5F9</Color>
    <Color x:Key="Slate.200">#E2E8F0</Color>
    <Color x:Key="Slate.300">#CBD5E1</Color>
    <Color x:Key="Slate.400">#94A3B8</Color>
    <Color x:Key="Slate.500">#64748B</Color>
    <Color x:Key="Slate.600">#475569</Color>
    <Color x:Key="Slate.700">#334155</Color>
    <Color x:Key="Slate.800">#1E293B</Color>
    <Color x:Key="Slate.900">#0F172A</Color>

    <!--  ══ Semantic status ══  -->
    <Color x:Key="Semantic.Success">#16A34A</Color>
    <Color x:Key="Semantic.Warning">#F59E0B</Color>
    <Color x:Key="Semantic.Error">#DC2626</Color>
    <Color x:Key="Semantic.Info">#3B82F6</Color>

    <SolidColorBrush x:Key="Brush.Brand.Primary" Color="{StaticResource Brand.Primary}" />
    <SolidColorBrush x:Key="Brush.Brand.Accent" Color="{StaticResource Brand.Accent}" />
    <SolidColorBrush x:Key="Brush.Semantic.Success" Color="{StaticResource Semantic.Success}" />
    <SolidColorBrush x:Key="Brush.Semantic.Warning" Color="{StaticResource Semantic.Warning}" />
    <SolidColorBrush x:Key="Brush.Semantic.Error" Color="{StaticResource Semantic.Error}" />
    <SolidColorBrush x:Key="Brush.Semantic.Info" Color="{StaticResource Semantic.Info}" />

    <!--  ══ Spacing scale (double + Thickness) ══  -->
    <sys:Double x:Key="Space.Xs">4</sys:Double>
    <sys:Double x:Key="Space.Sm">8</sys:Double>
    <sys:Double x:Key="Space.Md">16</sys:Double>
    <sys:Double x:Key="Space.Lg">24</sys:Double>
    <sys:Double x:Key="Space.Xl">32</sys:Double>
    <sys:Double x:Key="Space.2xl">48</sys:Double>

    <Thickness x:Key="Thickness.Xs">4</Thickness>
    <Thickness x:Key="Thickness.Sm">8</Thickness>
    <Thickness x:Key="Thickness.Md">16</Thickness>
    <Thickness x:Key="Thickness.Lg">24</Thickness>
    <Thickness x:Key="Thickness.Xl">32</Thickness>

    <!--
        ══ Radius / Typography ══
        Radius and font-size scales live in Themes/GlobalStyles.xaml as
        RadiusSm/Md/Lg (4/6/8) and FontSizeXs/Sm/Base/Md/Lg/Xl/2xl/3xl
        (12/14/16/18/20/24/32/48). DesignTokens stays the source of
        palette, semantic, spacing, sizing, and motion primitives.
    -->

    <!--  ══ Component sizes ══  -->
    <sys:Double x:Key="Size.Button.Height">40</sys:Double>
    <sys:Double x:Key="Size.Input.Height">40</sys:Double>
    <sys:Double x:Key="Size.Table.RowHeight">44</sys:Double>
    <sys:Double x:Key="Size.Table.RowHeight.Compact">36</sys:Double>
    <sys:Double x:Key="Size.Sidebar.Width">240</sys:Double>
    <sys:Double x:Key="Size.Topbar.Height">64</sys:Double>

    <!--  ══ Card defaults ══  -->
    <Thickness x:Key="Card.Padding">24</Thickness>
    <Thickness x:Key="Card.Padding.Compact">16</Thickness>
    <CornerRadius x:Key="Card.Radius">16</CornerRadius>

    <!--  ══ Motion (durations in ms; consumed by Storyboard via Duration converters) ══  -->
    <sys:Double x:Key="Motion.Duration.Fast">150</sys:Double>
    <sys:Double x:Key="Motion.Duration.Normal">240</sys:Double>

</ResourceDictionary>
