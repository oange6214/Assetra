<ResourceDictionary xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation" xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml">

    <!--
        ══════════════════════════════════════════════════════
        Light Theme — Windows 11 Mica / WinUI 3 palette
        ══════════════════════════════════════════════════════

        Layer hierarchy (matches WinUI 3 / Fluent Design):
          AppBackground  — outermost page canvas       #F3F3F3
          AppSurface     — cards, panels, sidebars     #FFFFFF
          AppHover       — hover / pressed state       #E8E8E8

        Borders follow Windows "Control Stroke":
          AppBorder      — visible dividers            #D9D9D9
          AppBorderLight — subtle separator            #EBEBEB

        Text follows Windows layered opacity model:
          Primary   100 %  #1A1A1A
          Secondary  60 %  #616161
          Muted      37 %  #919191

        Accent: Windows default system accent blue     #0078D4
    -->

    <!--  Backgrounds  -->
    <SolidColorBrush x:Key="AppBackground" Color="#F3F3F3" />
    <SolidColorBrush x:Key="AppSurface"    Color="#FFFFFF" />
    <SolidColorBrush x:Key="AppSurfaceAlt" Color="#F9F9F9" />
    <SolidColorBrush x:Key="AppCardBackground" Color="#FFFFFF" />
    <SolidColorBrush x:Key="AppHover"      Color="#E8E8E8" />

    <!--  Borders  -->
    <SolidColorBrush x:Key="AppBorder"      Color="#D9D9D9" />
    <SolidColorBrush x:Key="AppBorderLight" Color="#EBEBEB" />

    <!--  Text  -->
    <SolidColorBrush x:Key="AppTextPrimary"   Color="#1A1A1A" />
    <SolidColorBrush x:Key="AppTextSecondary" Color="#616161" />
    <!--  #6B6B6B gives 4.72:1 on AppBackground (#F3F3F3) and 5.2:1 on AppSurface (#FFFFFF) — passes WCAG AA  -->
    <!--  (was #919191: only 2.68:1 / 2.96:1 — failed for all text uses)  -->
    <SolidColorBrush x:Key="AppTextMuted"     Color="#6B6B6B" />
    <SolidColorBrush x:Key="AppTextOnAccent"  Color="#FFFFFF" />

    <!--  Semantic — price direction  -->
    <SolidColorBrush x:Key="AppUp"   Color="#0D7A5B" />
    <SolidColorBrush x:Key="AppDown" Color="#C42B1C" />
    <SolidColorBrush x:Key="AppFlat" Color="#616161" />

    <!--  Semantic — destructive action (always red, independent of price-direction convention)  -->
    <SolidColorBrush x:Key="AppDanger" Color="#C42B1C" />

    <!--  Accent — Windows system accent blue  -->
    <SolidColorBrush x:Key="AppAccent"       Color="#0078D4" />
    <SolidColorBrush x:Key="AppAccentHover"  Color="#006CBE" />
    <SolidColorBrush x:Key="AppAccentSubtle" Color="#D6EAFA" />
    <SolidColorBrush x:Key="AppAccentSoft"   Color="#D6EAFA" />
    <SolidColorBrush x:Key="AppAccentText"   Color="#005A9E" />

    <!--
        ════════════════════════════════════════════════════════════════
        Wpf.Ui accent overrides — pin Wpf.Ui controls to AppAccent
        ════════════════════════════════════════════════════════════════
        These keys are read by Wpf.Ui's Primary button, NavigationView
        active indicator, ToggleSwitch, focus rings, etc. By default
        they are populated by ApplicationAccentColorManager.Apply() from
        the Windows colorization color, which (1) ignores AppAccent,
        and (2) derives different shades per theme so the accent visibly
        shifts on Light↔Dark toggle.

        Defining the brushes here (merged AFTER Wpf.Ui's theme dict)
        gives a single source of truth that stays consistent across
        themes. AppThemeService skips ApplicationAccentColorManager.Apply
        so these overrides are not overwritten on Application.Resources.
    -->
    <SolidColorBrush x:Key="SystemAccentColorPrimaryBrush"   Color="#0078D4" />
    <SolidColorBrush x:Key="SystemAccentColorSecondaryBrush" Color="#006CBE" />
    <SolidColorBrush x:Key="SystemAccentColorTertiaryBrush"  Color="#005A9E" />

    <SolidColorBrush x:Key="AccentFillColorDefaultBrush"   Color="#0078D4" />
    <SolidColorBrush x:Key="AccentFillColorSecondaryBrush" Color="#006CBE" />
    <SolidColorBrush x:Key="AccentFillColorTertiaryBrush"  Color="#005A9E" />
    <SolidColorBrush x:Key="AccentFillColorDisabledBrush"  Color="#A6C8E0" />

    <SolidColorBrush x:Key="AccentTextFillColorPrimaryBrush"   Color="#005A9E" />
    <SolidColorBrush x:Key="AccentTextFillColorSecondaryBrush" Color="#004C84" />
    <SolidColorBrush x:Key="AccentTextFillColorTertiaryBrush"  Color="#003D6B" />
    <SolidColorBrush x:Key="AccentTextFillColorDisabledBrush"  Color="#88B5DD" />

    <SolidColorBrush x:Key="TextOnAccentFillColorPrimaryBrush"      Color="#FFFFFF" />
    <SolidColorBrush x:Key="TextOnAccentFillColorSecondaryBrush"    Color="#E6FFFFFF" />
    <SolidColorBrush x:Key="TextOnAccentFillColorDisabledBrush"     Color="#88FFFFFF" />
    <SolidColorBrush x:Key="TextOnAccentFillColorSelectedTextBrush" Color="#FFFFFF" />

    <!--  DataGrid  -->
    <SolidColorBrush x:Key="AppSelectedRow" Color="#C0DEFA" />
    <SolidColorBrush x:Key="AppGridLines"   Color="#EBEBEB" />

    <!--  Error banner  -->
    <SolidColorBrush x:Key="AppErrorBg"     Color="#FDF3F2" />
    <SolidColorBrush x:Key="AppErrorBorder" Color="#C42B1C" />

    <!--  Modal overlay scrim  -->
    <SolidColorBrush x:Key="AppModalOverlay" Color="#33000000" />

    <!--  Legacy aliases  -->
    <SolidColorBrush x:Key="AppTextHint" Color="#6B6B6B" />

</ResourceDictionary>
