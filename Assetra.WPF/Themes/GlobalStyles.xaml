<ResourceDictionary
    xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
    xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
    xmlns:models="clr-namespace:Assetra.Core.Models;assembly=Assetra.Core">

    <!--  ── App Logo (DrawingImage — resolution-independent, usable as ui:ImageIcon.Source) ──  -->
    <DrawingImage x:Key="AssetraLogo">
        <DrawingImage.Drawing>
            <DrawingGroup>
                <GeometryDrawing Brush="#142F55">
                    <GeometryDrawing.Geometry>
                        <PathGeometry Figures="M 34,72 L 52,28 64,28 46,72 Z" />
                    </GeometryDrawing.Geometry>
                </GeometryDrawing>
                <GeometryDrawing Brush="#C8A25A">
                    <GeometryDrawing.Geometry>
                        <PathGeometry Figures="M 60,72 L 72,52 82,72 Z" />
                    </GeometryDrawing.Geometry>
                </GeometryDrawing>
            </DrawingGroup>
        </DrawingImage.Drawing>
    </DrawingImage>

    <Style x:Key="StockSuggestionListBoxItemStyle" TargetType="ListBoxItem">
        <Setter Property="Padding" Value="10,7" />
        <Setter Property="Background" Value="Transparent" />
        <Setter Property="BorderThickness" Value="0" />
        <Setter Property="HorizontalContentAlignment" Value="Stretch" />
        <Setter Property="FocusVisualStyle" Value="{x:Null}" />
        <Style.Triggers>
            <Trigger Property="IsMouseOver" Value="True">
                <Setter Property="Background" Value="{DynamicResource AppHover}" />
            </Trigger>
        </Style.Triggers>
    </Style>

    <DataTemplate x:Key="StockSuggestionItemTemplate" DataType="{x:Type models:StockSearchResult}">
        <Grid>
            <Grid.ColumnDefinitions>
                <ColumnDefinition Width="64" />
                <ColumnDefinition Width="40" />
                <ColumnDefinition Width="*" />
            </Grid.ColumnDefinitions>

            <TextBlock
                Grid.Column="0"
                VerticalAlignment="Center"
                FontFamily="{DynamicResource FontTabular}"
                FontSize="{DynamicResource FontSizeSm}"
                FontWeight="SemiBold"
                Foreground="{DynamicResource AppTextPrimary}"
                Text="{Binding Symbol}" />

            <Border
                Grid.Column="1"
                Width="28"
                Height="20"
                Margin="0,0,8,0"
                HorizontalAlignment="Left"
                VerticalAlignment="Center"
                Background="{DynamicResource AppAccent}"
                CornerRadius="5">
                <TextBlock
                    HorizontalAlignment="Center"
                    VerticalAlignment="Center"
                    FontSize="{DynamicResource FontSizeXs}"
                    FontWeight="SemiBold"
                    Foreground="White"
                    Text="股">
                    <TextBlock.Style>
                        <Style TargetType="TextBlock">
                            <Setter Property="Text" Value="股" />
                            <Style.Triggers>
                                <DataTrigger Binding="{Binding IsEtf}" Value="True">
                                    <Setter Property="Text" Value="ETF" />
                                </DataTrigger>
                            </Style.Triggers>
                        </Style>
                    </TextBlock.Style>
                </TextBlock>
            </Border>

            <StackPanel Grid.Column="2">
                <TextBlock
                    FontSize="{DynamicResource FontSizeSm}"
                    Foreground="{DynamicResource AppTextPrimary}"
                    Text="{Binding Name}"
                    TextTrimming="CharacterEllipsis" />
                <TextBlock
                    Margin="0,2,0,0"
                    FontSize="{DynamicResource FontSizeXs}"
                    Foreground="{DynamicResource AppTextMuted}"
                    Text="{Binding Exchange}"
                    TextTrimming="CharacterEllipsis" />
            </StackPanel>
        </Grid>
    </DataTemplate>

    <Style x:Key="PortfolioBadgeBase" TargetType="Border">
        <Setter Property="Height" Value="20" />
        <Setter Property="MinWidth" Value="38" />
        <Setter Property="Padding" Value="8,0" />
        <Setter Property="HorizontalAlignment" Value="Left" />
        <Setter Property="VerticalAlignment" Value="Center" />
        <Setter Property="CornerRadius" Value="{DynamicResource RadiusSm}" />
    </Style>

    <Style x:Key="PortfolioBadgeText" TargetType="TextBlock">
        <Setter Property="HorizontalAlignment" Value="Center" />
        <Setter Property="VerticalAlignment" Value="Center" />
        <Setter Property="FontSize" Value="{DynamicResource FontSizeXs}" />
        <Setter Property="FontWeight" Value="SemiBold" />
        <Setter Property="Foreground" Value="{DynamicResource AppTextOnAccent}" />
    </Style>

    <Style
        x:Key="PortfolioAssetTypeBadge"
        BasedOn="{StaticResource PortfolioBadgeBase}"
        TargetType="Border">
        <Setter Property="Background" Value="#0062AD" />
        <Setter Property="MinWidth" Value="34" />
        <Style.Triggers>
            <DataTrigger Binding="{Binding AssetType}" Value="{x:Static models:AssetType.Fund}">
                <Setter Property="Background" Value="#0A7A55" />
            </DataTrigger>
            <DataTrigger Binding="{Binding AssetType}" Value="{x:Static models:AssetType.PreciousMetal}">
                <Setter Property="Background" Value="#966300" />
            </DataTrigger>
            <DataTrigger Binding="{Binding AssetType}" Value="{x:Static models:AssetType.Bond}">
                <Setter Property="Background" Value="#374151" />
            </DataTrigger>
            <DataTrigger Binding="{Binding AssetType}" Value="{x:Static models:AssetType.Crypto}">
                <Setter Property="Background" Value="#5B21B6" />
            </DataTrigger>
        </Style.Triggers>
    </Style>

    <Style
        x:Key="PortfolioDefaultBadge"
        BasedOn="{StaticResource PortfolioBadgeBase}"
        TargetType="Border">
        <Setter Property="Background" Value="{DynamicResource AppAccent}" />
    </Style>

    <Style
        x:Key="PortfolioLiabilityBadge"
        BasedOn="{StaticResource PortfolioBadgeBase}"
        TargetType="Border">
        <Setter Property="Background" Value="#374151" />
        <Setter Property="MinWidth" Value="42" />
        <Style.Triggers>
            <DataTrigger Binding="{Binding IsCreditCard}" Value="True">
                <Setter Property="Background" Value="#8A6A1F" />
            </DataTrigger>
        </Style.Triggers>
    </Style>

    <!--
        ══════════════════════════════════════════
        Global Design Tokens & Base Styles
        Font: Segoe UI Variable (Win11) / Segoe UI fallback
        Numbers: Consolas (tabular, monospaced)
        ══════════════════════════════════════════
    -->

    <!--  ── Typography Scale ──  -->
    <FontFamily x:Key="FontBase">Segoe UI Variable Display, Segoe UI, Microsoft JhengHei UI, Microsoft YaHei UI, sans-serif</FontFamily>
    <FontFamily x:Key="FontTabular">Consolas, Courier New, monospace</FontFamily>

    <System:Double xmlns:System="clr-namespace:System;assembly=mscorlib" x:Key="FontSizeXs">12</System:Double>
    <System:Double xmlns:System="clr-namespace:System;assembly=mscorlib" x:Key="FontSizeSm">14</System:Double>
    <System:Double xmlns:System="clr-namespace:System;assembly=mscorlib" x:Key="FontSizeBase">16</System:Double>
    <System:Double xmlns:System="clr-namespace:System;assembly=mscorlib" x:Key="FontSizeMd">18</System:Double>
    <System:Double xmlns:System="clr-namespace:System;assembly=mscorlib" x:Key="FontSizeLg">20</System:Double>
    <System:Double xmlns:System="clr-namespace:System;assembly=mscorlib" x:Key="FontSizeXl">24</System:Double>
    <System:Double xmlns:System="clr-namespace:System;assembly=mscorlib" x:Key="FontSize2xl">32</System:Double>
    <System:Double xmlns:System="clr-namespace:System;assembly=mscorlib" x:Key="FontSize3xl">48</System:Double>

    <!--  ── Layout Sizing Tokens ──  -->
    <System:Double xmlns:System="clr-namespace:System;assembly=mscorlib" x:Key="DataGridRowHeight">52</System:Double>
    <System:Double xmlns:System="clr-namespace:System;assembly=mscorlib" x:Key="DataGridHeaderHeight">40</System:Double>
    <System:Double xmlns:System="clr-namespace:System;assembly=mscorlib" x:Key="DialogWidth">440</System:Double>
    <System:Double xmlns:System="clr-namespace:System;assembly=mscorlib" x:Key="DialogMaxHeight">720</System:Double>
    <System:Double xmlns:System="clr-namespace:System;assembly=mscorlib" x:Key="ChartHeight">220</System:Double>
    <System:Double xmlns:System="clr-namespace:System;assembly=mscorlib" x:Key="FilterComboWidth">120</System:Double>
    <System:Double xmlns:System="clr-namespace:System;assembly=mscorlib" x:Key="DatePickerWidth">120</System:Double>
    <System:Double xmlns:System="clr-namespace:System;assembly=mscorlib" x:Key="LegendDotSize">8</System:Double>
    <Thickness x:Key="CardMarginLeft">0,0,4,0</Thickness>
    <Thickness x:Key="CardMarginCenter">2,0</Thickness>
    <Thickness x:Key="CardMarginRight">4,0,0,0</Thickness>

    <!--  ── Spacing Tokens (vertical gaps, set via Margin) ──  -->
    <Thickness x:Key="SpacingXs">0,0,0,4</Thickness>
    <Thickness x:Key="SpacingSm">0,0,0,6</Thickness>
    <Thickness x:Key="SpacingMd">0,0,0,8</Thickness>
    <Thickness x:Key="SpacingLg">0,0,0,12</Thickness>
    <Thickness x:Key="SpacingXl">0,0,0,16</Thickness>

    <!--  ── Inline Gap Tokens (horizontal spacing between siblings) ──  -->
    <Thickness x:Key="InlineGapSmRight">0,0,6,0</Thickness>
    <Thickness x:Key="InlineGapMdRight">0,0,8,0</Thickness>
    <Thickness x:Key="InlineGapLgRight">0,0,12,0</Thickness>
    <Thickness x:Key="InlineGapSmLeft">6,0,0,0</Thickness>
    <Thickness x:Key="InlineGapMdLeft">8,0,0,0</Thickness>

    <!--  ── Padding Tokens ──  -->
    <Thickness x:Key="CardPaddingCompact">12,10</Thickness>
    <Thickness x:Key="CardPaddingStandard">14,12</Thickness>
    <Thickness x:Key="CardPaddingComfortable">16,12</Thickness>
    <Thickness x:Key="RowPaddingH">12,0</Thickness>
    <Thickness x:Key="RowPaddingHLg">14,0</Thickness>

    <!--  ── Corner Radius ──  -->
    <CornerRadius x:Key="RadiusSm">4</CornerRadius>
    <CornerRadius x:Key="RadiusMd">6</CornerRadius>
    <CornerRadius x:Key="RadiusLg">8</CornerRadius>

    <!--  ── Keyboard Focus Visual (WCAG 2.4.7 Focus Visible) ──  -->
    <!--
        Applied to all interactive button-like controls.
        A 1.5 px dashed accent-coloured rectangle sits 3 px outside the control
        bounds, visible against any background in both dark and light themes.
    -->
    <Style x:Key="FocusVisual">
        <Setter Property="Control.Template">
            <Setter.Value>
                <ControlTemplate>
                    <Rectangle
                        Margin="-3"
                        RadiusX="6"
                        RadiusY="6"
                        SnapsToDevicePixels="True"
                        Stroke="{DynamicResource AppAccent}"
                        StrokeDashArray="1 2"
                        StrokeThickness="1.5" />
                </ControlTemplate>
            </Setter.Value>
        </Setter>
    </Style>

    <!--  ── Global TextBlock ──  -->
    <Style TargetType="TextBlock">
        <Setter Property="FontFamily" Value="{StaticResource FontBase}" />
        <Setter Property="FontSize" Value="{StaticResource FontSizeBase}" />
        <Setter Property="Foreground" Value="{DynamicResource AppTextPrimary}" />
        <Setter Property="TextOptions.TextFormattingMode" Value="Display" />
        <Setter Property="TextOptions.TextRenderingMode" Value="ClearType" />
    </Style>

    <!--  ── Global ToolTip ──  -->
    <!--  Tooltip is a separate Popup window and does not inherit FontFamily from the visual tree.  -->
    <!--  Explicitly set CJK-capable fonts so Chinese characters render correctly.  -->
    <Style TargetType="ToolTip">
        <Setter Property="FontFamily" Value="{StaticResource FontBase}" />
        <Setter Property="FontSize" Value="{StaticResource FontSizeSm}" />
        <Setter Property="Background" Value="{DynamicResource AppSurface}" />
        <Setter Property="Foreground" Value="{DynamicResource AppTextPrimary}" />
        <Setter Property="BorderBrush" Value="{DynamicResource AppBorder}" />
        <Setter Property="BorderThickness" Value="1" />
        <Setter Property="Padding" Value="8,4" />
    </Style>

    <!--  ── Global TextBox ──  -->
    <!--  CaretBrush must be set explicitly; it never inherits Foreground in WPF.  -->
    <Style TargetType="TextBox">
        <Setter Property="CaretBrush" Value="{DynamicResource AppTextPrimary}" />
    </Style>

    <!--  ── Primary Button ──  -->
    <Style x:Key="BtnPrimary" TargetType="Button">
        <Setter Property="Background" Value="{DynamicResource AppAccent}" />
        <Setter Property="Foreground" Value="#FFFFFF" />
        <Setter Property="BorderThickness" Value="0" />
        <Setter Property="Padding" Value="14,6" />
        <Setter Property="FontFamily" Value="{StaticResource FontBase}" />
        <Setter Property="FontSize" Value="{StaticResource FontSizeBase}" />
        <Setter Property="FontWeight" Value="SemiBold" />
        <Setter Property="Cursor" Value="Hand" />
        <Setter Property="Template">
            <Setter.Value>
                <ControlTemplate TargetType="Button">
                    <ControlTemplate.Resources>
                        <!--  Override implicit TextBlock style so string content uses the button's Foreground  -->
                        <Style TargetType="TextBlock">
                            <Setter Property="Foreground" Value="{Binding Foreground, RelativeSource={RelativeSource AncestorType={x:Type Button}}}" />
                        </Style>
                    </ControlTemplate.Resources>
                    <Border
                        Padding="{TemplateBinding Padding}"
                        Background="{TemplateBinding Background}"
                        CornerRadius="{StaticResource RadiusSm}"
                        TextElement.Foreground="{TemplateBinding Foreground}">
                        <ContentPresenter HorizontalAlignment="Center" VerticalAlignment="Center" />
                    </Border>
                    <ControlTemplate.Triggers>
                        <Trigger Property="IsMouseOver" Value="True">
                            <Setter Property="Background" Value="{DynamicResource AppAccentHover}" />
                        </Trigger>
                        <Trigger Property="IsPressed" Value="True">
                            <Setter Property="Opacity" Value="0.85" />
                        </Trigger>
                        <Trigger Property="IsEnabled" Value="False">
                            <Setter Property="Opacity" Value="0.4" />
                        </Trigger>
                    </ControlTemplate.Triggers>
                </ControlTemplate>
            </Setter.Value>
        </Setter>
    </Style>

    <!--  ── Ghost Button (border only) ──  -->
    <Style x:Key="BtnGhost" TargetType="Button">
        <Setter Property="Background" Value="Transparent" />
        <Setter Property="Foreground" Value="{DynamicResource AppTextSecondary}" />
        <Setter Property="BorderBrush" Value="{DynamicResource AppBorder}" />
        <Setter Property="BorderThickness" Value="1" />
        <Setter Property="Padding" Value="12,5" />
        <Setter Property="FontFamily" Value="{StaticResource FontBase}" />
        <Setter Property="FontSize" Value="{StaticResource FontSizeBase}" />
        <Setter Property="Cursor" Value="Hand" />
        <Setter Property="Template">
            <Setter.Value>
                <ControlTemplate TargetType="Button">
                    <Border
                        Padding="{TemplateBinding Padding}"
                        Background="{TemplateBinding Background}"
                        BorderBrush="{TemplateBinding BorderBrush}"
                        BorderThickness="{TemplateBinding BorderThickness}"
                        CornerRadius="{StaticResource RadiusSm}"
                        TextElement.Foreground="{TemplateBinding Foreground}">
                        <Border.Resources>
                            <Style TargetType="TextBlock">
                                <Setter Property="Foreground" Value="{Binding Foreground, RelativeSource={RelativeSource AncestorType={x:Type Button}}}" />
                            </Style>
                        </Border.Resources>
                        <ContentPresenter HorizontalAlignment="Center" VerticalAlignment="Center" />
                    </Border>
                    <ControlTemplate.Triggers>
                        <Trigger Property="IsMouseOver" Value="True">
                            <Setter Property="Background" Value="{DynamicResource AppHover}" />
                            <Setter Property="Foreground" Value="{DynamicResource AppTextPrimary}" />
                        </Trigger>
                        <Trigger Property="IsPressed" Value="True">
                            <Setter Property="Opacity" Value="0.8" />
                        </Trigger>
                    </ControlTemplate.Triggers>
                </ControlTemplate>
            </Setter.Value>
        </Setter>
    </Style>

    <!--  ── Link Button (text-only, accent colour, no border) ──  -->
    <Style x:Key="BtnLink" TargetType="Button">
        <Setter Property="Background" Value="Transparent" />
        <Setter Property="Foreground" Value="{DynamicResource AppAccent}" />
        <Setter Property="BorderThickness" Value="0" />
        <Setter Property="Padding" Value="0" />
        <Setter Property="FontFamily" Value="{StaticResource FontBase}" />
        <Setter Property="FontSize" Value="{StaticResource FontSizeSm}" />
        <Setter Property="Cursor" Value="Hand" />
        <Setter Property="FocusVisualStyle" Value="{StaticResource FocusVisual}" />
        <Setter Property="Template">
            <Setter.Value>
                <ControlTemplate TargetType="Button">
                    <ContentPresenter
                        HorizontalAlignment="Center"
                        VerticalAlignment="Center"
                        TextElement.Foreground="{TemplateBinding Foreground}" />
                    <ControlTemplate.Triggers>
                        <Trigger Property="IsMouseOver" Value="True">
                            <Setter Property="Opacity" Value="0.75" />
                        </Trigger>
                        <Trigger Property="IsPressed" Value="True">
                            <Setter Property="Opacity" Value="0.5" />
                        </Trigger>
                        <Trigger Property="IsEnabled" Value="False">
                            <Setter Property="Opacity" Value="0.4" />
                        </Trigger>
                    </ControlTemplate.Triggers>
                </ControlTemplate>
            </Setter.Value>
        </Setter>
    </Style>

    <!--  ── Period Selector Button (small, highlights when active via DataTrigger) ──  -->
    <Style x:Key="BtnPeriod" TargetType="Button">
        <Setter Property="Background" Value="Transparent" />
        <Setter Property="Foreground" Value="{DynamicResource AppTextSecondary}" />
        <Setter Property="BorderBrush" Value="{DynamicResource AppBorder}" />
        <Setter Property="BorderThickness" Value="1" />
        <Setter Property="Padding" Value="8,3" />
        <Setter Property="FontFamily" Value="{StaticResource FontBase}" />
        <Setter Property="FontSize" Value="{StaticResource FontSizeXs}" />
        <Setter Property="Cursor" Value="Hand" />
        <Setter Property="Template">
            <Setter.Value>
                <ControlTemplate TargetType="Button">
                    <Border
                        Padding="{TemplateBinding Padding}"
                        Background="{TemplateBinding Background}"
                        BorderBrush="{TemplateBinding BorderBrush}"
                        BorderThickness="{TemplateBinding BorderThickness}"
                        CornerRadius="{StaticResource RadiusSm}"
                        TextElement.Foreground="{TemplateBinding Foreground}">
                        <ContentPresenter HorizontalAlignment="Center" VerticalAlignment="Center" />
                    </Border>
                    <ControlTemplate.Triggers>
                        <Trigger Property="IsMouseOver" Value="True">
                            <Setter Property="Background" Value="{DynamicResource AppHover}" />
                            <Setter Property="Foreground" Value="{DynamicResource AppTextPrimary}" />
                        </Trigger>
                        <Trigger Property="IsPressed" Value="True">
                            <Setter Property="Opacity" Value="0.8" />
                        </Trigger>
                    </ControlTemplate.Triggers>
                </ControlTemplate>
            </Setter.Value>
        </Setter>
    </Style>

    <!--  ── Danger Button — solid red background, white text ──  -->
    <Style x:Key="BtnDanger" TargetType="Button">
        <Setter Property="Background" Value="{DynamicResource AppDanger}" />
        <Setter Property="Foreground" Value="#FFFFFF" />
        <Setter Property="BorderThickness" Value="0" />
        <Setter Property="Padding" Value="14,6" />
        <Setter Property="FontFamily" Value="{StaticResource FontBase}" />
        <Setter Property="FontSize" Value="{StaticResource FontSizeBase}" />
        <Setter Property="FontWeight" Value="SemiBold" />
        <Setter Property="Cursor" Value="Hand" />
        <Setter Property="Template">
            <Setter.Value>
                <ControlTemplate TargetType="Button">
                    <ControlTemplate.Resources>
                        <Style TargetType="TextBlock">
                            <Setter Property="Foreground" Value="{Binding Foreground, RelativeSource={RelativeSource AncestorType={x:Type Button}}}" />
                        </Style>
                    </ControlTemplate.Resources>
                    <Border
                        Padding="{TemplateBinding Padding}"
                        Background="{TemplateBinding Background}"
                        CornerRadius="{StaticResource RadiusSm}"
                        TextElement.Foreground="{TemplateBinding Foreground}">
                        <ContentPresenter HorizontalAlignment="Center" VerticalAlignment="Center" />
                    </Border>
                    <ControlTemplate.Triggers>
                        <Trigger Property="IsMouseOver" Value="True">
                            <Setter Property="Opacity" Value="0.85" />
                        </Trigger>
                        <Trigger Property="IsPressed" Value="True">
                            <Setter Property="Opacity" Value="0.7" />
                        </Trigger>
                        <Trigger Property="IsEnabled" Value="False">
                            <Setter Property="Opacity" Value="0.4" />
                        </Trigger>
                    </ControlTemplate.Triggers>
                </ControlTemplate>
            </Setter.Value>
        </Setter>
    </Style>

    <!--  ── Icon Button (no border, just icon) ──  -->
    <Style x:Key="BtnIcon" TargetType="Button">
        <Setter Property="Background" Value="Transparent" />
        <Setter Property="BorderThickness" Value="0" />
        <Setter Property="Padding" Value="6" />
        <Setter Property="Cursor" Value="Hand" />
        <Setter Property="FocusVisualStyle" Value="{StaticResource FocusVisual}" />
        <Setter Property="Template">
            <Setter.Value>
                <ControlTemplate TargetType="Button">
                    <!--
                        BorderThickness is always "1" to avoid layout shift on hover.
                        Default BorderBrush=Transparent so no ring is shown at rest.
                        Hover: AppAccent ring (#0078D4) + AppAccentSubtle fill — the blue ring
                        is visible against any background in both dark and light themes,
                        even inside a hovered DataGrid row (AppHover #333333 / #E8E8E8).
                    -->
                    <Border
                        x:Name="Bd"
                        Padding="{TemplateBinding Padding}"
                        Background="{TemplateBinding Background}"
                        BorderBrush="Transparent"
                        BorderThickness="1"
                        CornerRadius="{StaticResource RadiusSm}">
                        <ContentPresenter
                            x:Name="Icon"
                            HorizontalAlignment="Center"
                            VerticalAlignment="Center" />
                    </Border>
                    <ControlTemplate.Triggers>
                        <Trigger Property="IsMouseOver" Value="True">
                            <Setter TargetName="Bd" Property="BorderBrush" Value="{DynamicResource AppAccent}" />
                            <Setter TargetName="Bd" Property="Background" Value="{DynamicResource AppAccentSubtle}" />
                        </Trigger>
                        <Trigger Property="IsPressed" Value="True">
                            <Setter TargetName="Bd" Property="BorderBrush" Value="{DynamicResource AppAccentHover}" />
                            <Setter TargetName="Bd" Property="Background" Value="{DynamicResource AppAccentSubtle}" />
                            <Setter TargetName="Icon" Property="Opacity" Value="0.6" />
                        </Trigger>
                    </ControlTemplate.Triggers>
                </ControlTemplate>
            </Setter.Value>
        </Setter>
    </Style>

    <!--  ── Icon Toggle Button (ToggleButton variant of BtnIcon)  ──  -->
    <Style x:Key="BtnIconToggle" TargetType="ToggleButton">
        <Setter Property="Background" Value="Transparent" />
        <Setter Property="BorderThickness" Value="0" />
        <Setter Property="Padding" Value="6" />
        <Setter Property="Cursor" Value="Hand" />
        <Setter Property="FocusVisualStyle" Value="{StaticResource FocusVisual}" />
        <Setter Property="Template">
            <Setter.Value>
                <ControlTemplate TargetType="ToggleButton">
                    <Border
                        x:Name="Bd"
                        Padding="{TemplateBinding Padding}"
                        Background="{TemplateBinding Background}"
                        BorderBrush="Transparent"
                        BorderThickness="1"
                        CornerRadius="{StaticResource RadiusSm}">
                        <ContentPresenter
                            x:Name="Icon"
                            HorizontalAlignment="Center"
                            VerticalAlignment="Center" />
                    </Border>
                    <ControlTemplate.Triggers>
                        <!--  Checked: accent fill with accent ring  -->
                        <Trigger Property="IsChecked" Value="True">
                            <Setter TargetName="Bd" Property="Background" Value="{DynamicResource AppAccentSubtle}" />
                            <Setter TargetName="Bd" Property="BorderBrush" Value="{DynamicResource AppAccent}" />
                        </Trigger>
                        <!--  Hover: same accent ring visual as BtnIcon  -->
                        <Trigger Property="IsMouseOver" Value="True">
                            <Setter TargetName="Bd" Property="BorderBrush" Value="{DynamicResource AppAccent}" />
                            <Setter TargetName="Bd" Property="Background" Value="{DynamicResource AppAccentSubtle}" />
                        </Trigger>
                        <Trigger Property="IsPressed" Value="True">
                            <Setter TargetName="Bd" Property="BorderBrush" Value="{DynamicResource AppAccentHover}" />
                            <Setter TargetName="Bd" Property="Background" Value="{DynamicResource AppAccentSubtle}" />
                            <Setter TargetName="Icon" Property="Opacity" Value="0.6" />
                        </Trigger>
                    </ControlTemplate.Triggers>
                </ControlTemplate>
            </Setter.Value>
        </Setter>
    </Style>

    <!--  ── DataGrid row-level delete button (chrome-free, hover → danger)  -->
    <Style x:Key="DataGridDeleteBtn" TargetType="Button">
        <Setter Property="Width" Value="20" />
        <Setter Property="Height" Value="20" />
        <Setter Property="Padding" Value="0" />
        <!--  AppTextSecondary is more readable than AppTextMuted on AppHover row background  -->
        <Setter Property="Foreground" Value="{DynamicResource AppTextSecondary}" />
        <Setter Property="Background" Value="Transparent" />
        <Setter Property="BorderThickness" Value="0" />
        <Setter Property="Cursor" Value="Hand" />
        <Setter Property="FocusVisualStyle" Value="{StaticResource FocusVisual}" />
        <Setter Property="Template">
            <Setter.Value>
                <ControlTemplate TargetType="Button">
                    <!--
                        BorderThickness always "1" (Transparent at rest) to avoid layout shift.
                        Hover: AppDown red ring + red icon — danger signal visible in any theme/context.
                        Pressed: deeper red ring + icon dims to confirm click.
                    -->
                    <Border
                        x:Name="Bd"
                        Background="{TemplateBinding Background}"
                        BorderBrush="Transparent"
                        BorderThickness="1"
                        CornerRadius="{StaticResource RadiusSm}">
                        <ContentPresenter
                            x:Name="Icon"
                            HorizontalAlignment="Center"
                            VerticalAlignment="Center"
                            TextBlock.Foreground="{TemplateBinding Foreground}" />
                    </Border>
                    <ControlTemplate.Triggers>
                        <Trigger Property="IsMouseOver" Value="True">
                            <Setter Property="Foreground" Value="{DynamicResource AppDanger}" />
                            <Setter TargetName="Bd" Property="BorderBrush" Value="{DynamicResource AppDanger}" />
                        </Trigger>
                        <Trigger Property="IsPressed" Value="True">
                            <Setter Property="Foreground" Value="{DynamicResource AppDanger}" />
                            <Setter TargetName="Bd" Property="BorderBrush" Value="{DynamicResource AppDanger}" />
                            <Setter TargetName="Icon" Property="Opacity" Value="0.6" />
                        </Trigger>
                    </ControlTemplate.Triggers>
                </ControlTemplate>
            </Setter.Value>
        </Setter>
    </Style>

    <!--  ── Panel Header (標題列) ──  -->
    <Style x:Key="PanelHeader" TargetType="Border">
        <Setter Property="Background" Value="{DynamicResource AppSurface}" />
        <Setter Property="BorderBrush" Value="{DynamicResource AppBorder}" />
        <Setter Property="BorderThickness" Value="0,0,0,1" />
        <Setter Property="Padding" Value="16,0" />
        <Setter Property="Height" Value="40" />
    </Style>

    <!--  ── Panel Header Text ──  -->
    <Style x:Key="PanelHeaderText" TargetType="TextBlock">
        <Setter Property="FontFamily" Value="{StaticResource FontBase}" />
        <Setter Property="FontSize" Value="{StaticResource FontSizeBase}" />
        <Setter Property="FontWeight" Value="SemiBold" />
        <Setter Property="Foreground" Value="{DynamicResource AppTextPrimary}" />
        <Setter Property="VerticalAlignment" Value="Center" />
        <Setter Property="TextOptions.TextFormattingMode" Value="Display" />
    </Style>

    <!--  ── Metric Label (欄位標籤 xs) ──  -->
    <Style x:Key="MetricLabel" TargetType="TextBlock">
        <Setter Property="FontFamily" Value="{StaticResource FontBase}" />
        <Setter Property="FontSize" Value="{StaticResource FontSizeXs}" />
        <Setter Property="Foreground" Value="{DynamicResource AppTextSecondary}" />
        <Setter Property="TextOptions.TextFormattingMode" Value="Display" />
    </Style>

    <!--  ── Card Border ──  -->
    <Style x:Key="Card" TargetType="Border">
        <Setter Property="Background" Value="{DynamicResource AppSurface}" />
        <Setter Property="BorderBrush" Value="{DynamicResource AppBorder}" />
        <Setter Property="BorderThickness" Value="1" />
        <Setter Property="CornerRadius" Value="{StaticResource RadiusMd}" />
        <Setter Property="Padding" Value="12" />
    </Style>

    <!--  ── Top Navigation Tab Button (TradingView-style) ──  -->
    <Style x:Key="NavTabBtn" TargetType="RadioButton">
        <Setter Property="Background" Value="Transparent" />
        <Setter Property="Foreground" Value="{DynamicResource AppTextSecondary}" />
        <Setter Property="BorderThickness" Value="0" />
        <Setter Property="Padding" Value="14,0" />
        <Setter Property="Height" Value="36" />
        <Setter Property="FontFamily" Value="{StaticResource FontBase}" />
        <Setter Property="FontSize" Value="{StaticResource FontSizeSm}" />
        <Setter Property="Cursor" Value="Hand" />
        <Setter Property="FocusVisualStyle" Value="{StaticResource FocusVisual}" />
        <Setter Property="Template">
            <Setter.Value>
                <ControlTemplate TargetType="RadioButton">
                    <Border
                        x:Name="Bg"
                        Padding="{TemplateBinding Padding}"
                        Background="{TemplateBinding Background}">
                        <Grid>
                            <ContentPresenter
                                x:Name="Label"
                                HorizontalAlignment="Center"
                                VerticalAlignment="Center"
                                TextElement.Foreground="{TemplateBinding Foreground}" />
                            <!--  Bottom indicator line  -->
                            <Border
                                x:Name="Indicator"
                                Height="2"
                                VerticalAlignment="Bottom"
                                Background="{DynamicResource AppAccent}"
                                Visibility="Collapsed" />
                        </Grid>
                    </Border>
                    <ControlTemplate.Triggers>
                        <Trigger Property="IsChecked" Value="True">
                            <Setter TargetName="Indicator" Property="Visibility" Value="Visible" />
                            <Setter Property="Foreground" Value="{DynamicResource AppTextPrimary}" />
                            <Setter Property="FontWeight" Value="SemiBold" />
                        </Trigger>
                        <MultiTrigger>
                            <MultiTrigger.Conditions>
                                <Condition Property="IsMouseOver" Value="True" />
                                <Condition Property="IsChecked" Value="False" />
                            </MultiTrigger.Conditions>
                            <Setter Property="Foreground" Value="{DynamicResource AppTextPrimary}" />
                            <Setter TargetName="Bg" Property="Background" Value="{DynamicResource AppHover}" />
                        </MultiTrigger>
                    </ControlTemplate.Triggers>
                </ControlTemplate>
            </Setter.Value>
        </Setter>
    </Style>

    <!--  ── Panel Toggle Strip Button (side panel collapse) ──  -->
    <Style x:Key="PanelToggleBtn" TargetType="Button">
        <Setter Property="Background" Value="Transparent" />
        <Setter Property="BorderThickness" Value="0" />
        <Setter Property="HorizontalAlignment" Value="Stretch" />
        <Setter Property="VerticalAlignment" Value="Stretch" />
        <Setter Property="Cursor" Value="Hand" />
        <Setter Property="FocusVisualStyle" Value="{StaticResource FocusVisual}" />
        <Setter Property="Template">
            <Setter.Value>
                <ControlTemplate TargetType="Button">
                    <Border x:Name="Bg" Background="{TemplateBinding Background}">
                        <TextBlock
                            HorizontalAlignment="Center"
                            VerticalAlignment="Center"
                            FontFamily="Segoe MDL2 Assets"
                            FontSize="9"
                            Foreground="{DynamicResource AppTextMuted}"
                            Text="{TemplateBinding Content}" />
                    </Border>
                    <ControlTemplate.Triggers>
                        <Trigger Property="IsMouseOver" Value="True">
                            <Setter TargetName="Bg" Property="Background" Value="{DynamicResource AppHover}" />
                        </Trigger>
                        <Trigger Property="IsPressed" Value="True">
                            <Setter TargetName="Bg" Property="Background" Value="{DynamicResource AppAccentSubtle}" />
                        </Trigger>
                    </ControlTemplate.Triggers>
                </ControlTemplate>
            </Setter.Value>
        </Setter>
    </Style>

    <!--  ── Navigation Rail Button ──  -->
    <!--  Windows 11 / Fluent pattern: rounded-square indicator on icon area.  -->
    <!--
        NavRailToolTip — floating label with left caret.
        Uses Grid overlay: body Border (with shadow) is offset right 5 px,
        Polygon caret is drawn ON TOP to seamlessly cover the body's left border.
        Works in both dark and light themes via DynamicResource.
    -->
    <!--  NavRailToolTip — clean rounded label, no caret  -->
    <Style x:Key="NavRailToolTip" TargetType="ToolTip">
        <Setter Property="Background" Value="{DynamicResource AppSurface}" />
        <Setter Property="Foreground" Value="{DynamicResource AppTextPrimary}" />
        <Setter Property="FontFamily" Value="{StaticResource FontBase}" />
        <Setter Property="FontSize" Value="{StaticResource FontSizeSm}" />
        <Setter Property="FontWeight" Value="Medium" />
        <Setter Property="HasDropShadow" Value="False" />
        <Setter Property="Template">
            <Setter.Value>
                <ControlTemplate TargetType="ToolTip">
                    <Border
                        Padding="10,5"
                        Background="{TemplateBinding Background}"
                        BorderBrush="{DynamicResource AppBorder}"
                        BorderThickness="1"
                        CornerRadius="6">
                        <Border.Effect>
                            <DropShadowEffect
                                BlurRadius="12"
                                Opacity="0.20"
                                ShadowDepth="2"
                                Color="#000000" />
                        </Border.Effect>
                        <ContentPresenter />
                    </Border>
                </ControlTemplate>
            </Setter.Value>
        </Setter>
    </Style>

    <!--  NavRailBtn — icon-only with larger footprint for scaled UI  -->
    <Style x:Key="NavRailBtn" TargetType="RadioButton">
        <Setter Property="Background" Value="Transparent" />
        <Setter Property="Foreground" Value="{DynamicResource AppTextSecondary}" />
        <Setter Property="BorderThickness" Value="0" />
        <Setter Property="Width" Value="52" />
        <Setter Property="Height" Value="52" />
        <Setter Property="HorizontalAlignment" Value="Center" />
        <Setter Property="Cursor" Value="Hand" />
        <Setter Property="FocusVisualStyle" Value="{StaticResource FocusVisual}" />
        <Setter Property="ToolTipService.InitialShowDelay" Value="0" />
        <Setter Property="ToolTipService.BetweenShowDelay" Value="0" />
        <Setter Property="ToolTipService.Placement" Value="Right" />
        <Setter Property="ToolTipService.VerticalOffset" Value="10" />
        <Setter Property="ToolTipService.HorizontalOffset" Value="0" />
        <Setter Property="Template">
            <Setter.Value>
                <ControlTemplate TargetType="RadioButton">
                    <Border
                        x:Name="IconPill"
                        Width="40"
                        Height="40"
                        HorizontalAlignment="Center"
                        VerticalAlignment="Center"
                        Background="Transparent"
                        CornerRadius="{StaticResource RadiusLg}">
                        <TextBlock
                            x:Name="IconGlyph"
                            HorizontalAlignment="Center"
                            VerticalAlignment="Center"
                            FontFamily="Segoe MDL2 Assets"
                            FontSize="{StaticResource FontSizeMd}"
                            Foreground="{TemplateBinding Foreground}"
                            Text="{TemplateBinding Tag}"
                            TextOptions.TextFormattingMode="Ideal" />
                    </Border>
                    <ControlTemplate.Triggers>
                        <Trigger Property="IsChecked" Value="True">
                            <Setter TargetName="IconPill" Property="Background" Value="{DynamicResource AppAccentSubtle}" />
                            <Setter TargetName="IconGlyph" Property="Foreground" Value="{DynamicResource AppAccent}" />
                        </Trigger>
                        <MultiTrigger>
                            <MultiTrigger.Conditions>
                                <Condition Property="IsMouseOver" Value="True" />
                                <Condition Property="IsChecked" Value="False" />
                            </MultiTrigger.Conditions>
                            <Setter TargetName="IconPill" Property="Background" Value="{DynamicResource AppHover}" />
                            <Setter TargetName="IconGlyph" Property="Foreground" Value="{DynamicResource AppTextPrimary}" />
                        </MultiTrigger>
                        <!--  Pressed: subtle scale-down feedback  -->
                        <Trigger Property="IsPressed" Value="True">
                            <Setter TargetName="IconPill" Property="RenderTransformOrigin" Value="0.5,0.5" />
                            <Setter TargetName="IconPill" Property="RenderTransform">
                                <Setter.Value>
                                    <ScaleTransform ScaleX="0.9" ScaleY="0.9" />
                                </Setter.Value>
                            </Setter>
                        </Trigger>
                        <Trigger Property="IsEnabled" Value="False">
                            <Setter Property="Opacity" Value="0.3" />
                            <Setter Property="Cursor" Value="Arrow" />
                        </Trigger>
                    </ControlTemplate.Triggers>
                </ControlTemplate>
            </Setter.Value>
        </Setter>
    </Style>

    <!--  NavRailAiBtn — ToggleButton variant with same accent bar treatment  -->
    <Style x:Key="NavRailAiBtn" TargetType="ToggleButton">
        <Setter Property="Background" Value="Transparent" />
        <Setter Property="Foreground" Value="{DynamicResource AppTextSecondary}" />
        <Setter Property="BorderThickness" Value="0" />
        <Setter Property="Width" Value="52" />
        <Setter Property="Height" Value="52" />
        <Setter Property="HorizontalAlignment" Value="Center" />
        <Setter Property="Cursor" Value="Hand" />
        <Setter Property="FocusVisualStyle" Value="{StaticResource FocusVisual}" />
        <Setter Property="ToolTipService.InitialShowDelay" Value="0" />
        <Setter Property="ToolTipService.BetweenShowDelay" Value="0" />
        <Setter Property="ToolTipService.Placement" Value="Right" />
        <Setter Property="ToolTipService.VerticalOffset" Value="10" />
        <Setter Property="ToolTipService.HorizontalOffset" Value="0" />
        <Setter Property="Template">
            <Setter.Value>
                <ControlTemplate TargetType="ToggleButton">
                    <Grid>
                        <Border
                            x:Name="AccentBar"
                            Width="3"
                            HorizontalAlignment="Left"
                            Background="Transparent"
                            CornerRadius="0,2,2,0" />
                        <Border
                            x:Name="IconPill"
                            Width="40"
                            Height="40"
                            HorizontalAlignment="Center"
                            VerticalAlignment="Center"
                            Background="Transparent"
                            CornerRadius="{StaticResource RadiusLg}">
                            <TextBlock
                                x:Name="IconGlyph"
                                HorizontalAlignment="Center"
                                VerticalAlignment="Center"
                                FontFamily="Segoe MDL2 Assets"
                                FontSize="{StaticResource FontSizeMd}"
                                Foreground="{TemplateBinding Foreground}"
                                Text="{TemplateBinding Tag}"
                                TextOptions.TextFormattingMode="Ideal" />
                        </Border>
                    </Grid>
                    <ControlTemplate.Triggers>
                        <Trigger Property="IsChecked" Value="True">
                            <Setter TargetName="AccentBar" Property="Background" Value="{DynamicResource AppAccent}" />
                            <Setter TargetName="IconGlyph" Property="Foreground" Value="{DynamicResource AppAccent}" />
                        </Trigger>
                        <MultiTrigger>
                            <MultiTrigger.Conditions>
                                <Condition Property="IsMouseOver" Value="True" />
                                <Condition Property="IsChecked" Value="False" />
                            </MultiTrigger.Conditions>
                            <Setter TargetName="IconPill" Property="Background" Value="{DynamicResource AppHover}" />
                            <Setter TargetName="IconGlyph" Property="Foreground" Value="{DynamicResource AppTextPrimary}" />
                        </MultiTrigger>
                        <!--  Pressed: subtle scale-down feedback  -->
                        <Trigger Property="IsPressed" Value="True">
                            <Setter TargetName="IconPill" Property="RenderTransformOrigin" Value="0.5,0.5" />
                            <Setter TargetName="IconPill" Property="RenderTransform">
                                <Setter.Value>
                                    <ScaleTransform ScaleX="0.9" ScaleY="0.9" />
                                </Setter.Value>
                            </Setter>
                        </Trigger>
                        <Trigger Property="IsEnabled" Value="False">
                            <Setter Property="Opacity" Value="0.3" />
                            <Setter Property="Cursor" Value="Arrow" />
                        </Trigger>
                    </ControlTemplate.Triggers>
                </ControlTemplate>
            </Setter.Value>
        </Setter>
    </Style>

    <!--  ── Settings Radio Button (visible round indicator) ──  -->
    <Style x:Key="SettingsRadioBtn" TargetType="RadioButton">
        <Setter Property="Background" Value="Transparent" />
        <Setter Property="Foreground" Value="{DynamicResource AppTextPrimary}" />
        <Setter Property="BorderThickness" Value="0" />
        <Setter Property="Padding" Value="8,4" />
        <Setter Property="FontFamily" Value="{StaticResource FontBase}" />
        <Setter Property="FontSize" Value="{StaticResource FontSizeSm}" />
        <Setter Property="Cursor" Value="Hand" />
        <Setter Property="VerticalContentAlignment" Value="Center" />
        <Setter Property="Template">
            <Setter.Value>
                <ControlTemplate TargetType="RadioButton">
                    <StackPanel VerticalAlignment="Center" Orientation="Horizontal">
                        <!--  Outer ring  -->
                        <Grid
                            Width="16"
                            Height="16"
                            Margin="0,0,8,0"
                            VerticalAlignment="Center">
                            <Ellipse
                                x:Name="OuterRing"
                                Width="16"
                                Height="16"
                                Fill="Transparent"
                                Stroke="{DynamicResource AppBorder}"
                                StrokeThickness="1.5" />
                            <!--  Inner fill — visible when checked  -->
                            <Ellipse
                                x:Name="InnerDot"
                                Width="8"
                                Height="8"
                                Fill="{DynamicResource AppAccent}"
                                Visibility="Collapsed" />
                        </Grid>
                        <ContentPresenter VerticalAlignment="Center" />
                    </StackPanel>
                    <ControlTemplate.Triggers>
                        <Trigger Property="IsChecked" Value="True">
                            <Setter TargetName="OuterRing" Property="Stroke" Value="{DynamicResource AppAccent}" />
                            <Setter TargetName="InnerDot" Property="Visibility" Value="Visible" />
                        </Trigger>
                        <Trigger Property="IsMouseOver" Value="True">
                            <Setter TargetName="OuterRing" Property="Stroke" Value="{DynamicResource AppAccent}" />
                        </Trigger>
                    </ControlTemplate.Triggers>
                </ControlTemplate>
            </Setter.Value>
        </Setter>
    </Style>

    <!--
        ══════════════════════════════════════════
        Shared DataGrid Styles
        AppDataGridColHeader  — column header
        AppDataGridCell       — cell (no border, centred)
        AppDataGridRow        — row (hover only)
        AppDataGridRowSelectable — row with accent-left selection
        ══════════════════════════════════════════
    -->

    <Style x:Key="AppDataGridColHeader" TargetType="DataGridColumnHeader">
        <Setter Property="Background" Value="{DynamicResource AppSurface}" />
        <Setter Property="Foreground" Value="{DynamicResource AppTextSecondary}" />
        <Setter Property="FontFamily" Value="{StaticResource FontBase}" />
        <Setter Property="FontSize" Value="{StaticResource FontSizeXs}" />
        <Setter Property="FontWeight" Value="SemiBold" />
        <Setter Property="Padding" Value="8,6" />
        <Setter Property="BorderBrush" Value="{DynamicResource AppBorder}" />
        <Setter Property="BorderThickness" Value="0,0,0,1" />
        <Setter Property="HorizontalContentAlignment" Value="Left" />
        <Setter Property="Cursor" Value="Hand" />
        <Setter Property="Template">
            <Setter.Value>
                <ControlTemplate TargetType="DataGridColumnHeader">
                    <Border
                        Padding="{TemplateBinding Padding}"
                        Background="{TemplateBinding Background}"
                        BorderBrush="{TemplateBinding BorderBrush}"
                        BorderThickness="{TemplateBinding BorderThickness}">
                        <Grid Height="28">
                            <Grid.ColumnDefinitions>
                                <ColumnDefinition Width="*" />
                                <ColumnDefinition Width="14" />
                            </Grid.ColumnDefinitions>
                            <ContentPresenter
                                Grid.Column="0"
                                HorizontalAlignment="{TemplateBinding HorizontalContentAlignment}"
                                VerticalAlignment="Center" />
                            <TextBlock
                                x:Name="SortArrow"
                                Grid.Column="1"
                                HorizontalAlignment="Center"
                                VerticalAlignment="Center"
                                FontFamily="Segoe MDL2 Assets"
                                FontSize="9"
                                Foreground="{DynamicResource AppTextMuted}"
                                IsHitTestVisible="False"
                                Text="&#xE70D;"
                                Visibility="Collapsed" />
                        </Grid>
                    </Border>
                    <ControlTemplate.Triggers>
                        <Trigger Property="SortDirection" Value="Ascending">
                            <Setter TargetName="SortArrow" Property="Visibility" Value="Visible" />
                            <Setter TargetName="SortArrow" Property="Text" Value="&#xE70E;" />
                        </Trigger>
                        <Trigger Property="SortDirection" Value="Descending">
                            <Setter TargetName="SortArrow" Property="Visibility" Value="Visible" />
                            <Setter TargetName="SortArrow" Property="Text" Value="&#xE70D;" />
                        </Trigger>
                        <Trigger Property="IsMouseOver" Value="True">
                            <Setter Property="Foreground" Value="{DynamicResource AppTextPrimary}" />
                        </Trigger>
                    </ControlTemplate.Triggers>
                </ControlTemplate>
            </Setter.Value>
        </Setter>
    </Style>

    <!--
        AppDataGridCell — WPF's default DataGridCell ControlTemplate does not
        expose a Padding binding, so horizontal inset is handled per-column via
        Margin on each DataTemplate / ElementStyle rather than here.
    -->
    <Style x:Key="AppDataGridCell" TargetType="DataGridCell">
        <Setter Property="BorderThickness" Value="0" />
        <Setter Property="VerticalAlignment" Value="Stretch" />
        <Setter Property="VerticalContentAlignment" Value="Center" />
        <Setter Property="FocusVisualStyle" Value="{x:Null}" />
        <!--
            必須設 Transparent（非 null）：WPF 的 null 背景不參與 hit testing，
            點擊 TextBlock 之間的空白區域事件會穿透，DataGridRow 選取不觸發。
            Transparent 有渲染層，事件由 DataGridCell 捕捉後冒泡至 Row，
            Row 的 IsSelected / IsMouseOver 才能正常運作。
        -->
        <Setter Property="Background" Value="Transparent" />
        <Setter Property="Template">
            <Setter.Value>
                <ControlTemplate TargetType="DataGridCell">
                    <Border
                        Padding="8,0"
                        Background="{TemplateBinding Background}"
                        BorderBrush="{TemplateBinding BorderBrush}"
                        BorderThickness="{TemplateBinding BorderThickness}">
                        <ContentPresenter VerticalAlignment="Center" />
                    </Border>
                </ControlTemplate>
            </Setter.Value>
        </Setter>
        <Style.Triggers>
            <Trigger Property="IsSelected" Value="True">
                <Setter Property="Background" Value="Transparent" />
                <Setter Property="Foreground" Value="{DynamicResource AppTextPrimary}" />
            </Trigger>
        </Style.Triggers>
    </Style>

    <!--
        Row — alternating background + hover highlight (read-only grids)
        Set DataGrid.AlternationCount="2" to enable alternating rows.
    -->
    <Style x:Key="AppDataGridRow" TargetType="DataGridRow">
        <Setter Property="Background" Value="Transparent" />
        <Setter Property="BorderBrush" Value="Transparent" />
        <Setter Property="BorderThickness" Value="0" />
        <Style.Triggers>
            <!--  Alternating row background  -->
            <Trigger Property="AlternationIndex" Value="1">
                <Setter Property="Background" Value="{DynamicResource AppSurfaceAlt}" />
            </Trigger>
            <Trigger Property="IsMouseOver" Value="True">
                <Setter Property="Background" Value="{DynamicResource AppHover}" />
            </Trigger>
            <!--  Suppress the default WPF selection border/underline  -->
            <Trigger Property="IsSelected" Value="True">
                <Setter Property="Background" Value="Transparent" />
                <Setter Property="BorderBrush" Value="Transparent" />
                <Setter Property="BorderThickness" Value="0" />
            </Trigger>
        </Style.Triggers>
    </Style>

    <!--  Row — hover + accent-left selection (selectable grids)  -->
    <Style
        x:Key="AppDataGridRowSelectable"
        BasedOn="{StaticResource AppDataGridRow}"
        TargetType="DataGridRow">
        <Style.Triggers>
            <Trigger Property="IsSelected" Value="True">
                <Setter Property="Background" Value="{DynamicResource AppSelectedRow}" />
                <Setter Property="BorderBrush" Value="{DynamicResource AppAccent}" />
                <Setter Property="BorderThickness" Value="2,0,0,0" />
            </Trigger>
            <MultiTrigger>
                <MultiTrigger.Conditions>
                    <Condition Property="IsMouseOver" Value="True" />
                    <Condition Property="IsSelected" Value="False" />
                </MultiTrigger.Conditions>
                <Setter Property="Background" Value="{DynamicResource AppHover}" />
            </MultiTrigger>
        </Style.Triggers>
    </Style>

    <!--  ── Feature Page Toolbar Border ──  -->
    <!--
        MinHeight="48" guarantees a consistent toolbar height across all feature
        pages regardless of whether the content is just a title or includes
        buttons and input controls.
    -->
    <Style x:Key="ToolbarBorder" TargetType="Border">
        <Setter Property="MinHeight" Value="48" />
        <Setter Property="Padding" Value="16,10" />
        <Setter Property="Background" Value="{DynamicResource AppSurface}" />
        <Setter Property="BorderBrush" Value="{DynamicResource AppBorder}" />
        <Setter Property="BorderThickness" Value="0,0,0,1" />
    </Style>

    <!--  ── Form Input TextBox ──  -->
    <!--  Rounded border + accent focus ring. Width / Margin / Text stay per-instance.  -->
    <Style
        x:Key="FormTextBox"
        BasedOn="{StaticResource {x:Type TextBox}}"
        TargetType="TextBox">
        <Setter Property="Padding" Value="4,5" />
        <Setter Property="Background" Value="{DynamicResource AppBackground}" />
        <Setter Property="BorderBrush" Value="{DynamicResource AppBorder}" />
        <Setter Property="BorderThickness" Value="1" />
        <Setter Property="FontFamily" Value="{StaticResource FontTabular}" />
        <Setter Property="FontSize" Value="{StaticResource FontSizeSm}" />
        <Setter Property="Foreground" Value="{DynamicResource AppTextPrimary}" />
        <Setter Property="FocusVisualStyle" Value="{x:Null}" />
        <Setter Property="Template">
            <Setter.Value>
                <ControlTemplate TargetType="TextBox">
                    <Border
                        x:Name="Bd"
                        Padding="{TemplateBinding Padding}"
                        Background="{TemplateBinding Background}"
                        BorderBrush="{TemplateBinding BorderBrush}"
                        BorderThickness="{TemplateBinding BorderThickness}"
                        CornerRadius="{StaticResource RadiusSm}">
                        <ScrollViewer x:Name="PART_ContentHost" VerticalContentAlignment="Center" />
                    </Border>
                    <ControlTemplate.Triggers>
                        <Trigger Property="IsFocused" Value="True">
                            <Setter TargetName="Bd" Property="BorderBrush" Value="{DynamicResource AppAccent}" />
                        </Trigger>
                        <Trigger Property="IsEnabled" Value="False">
                            <Setter Property="Opacity" Value="0.5" />
                        </Trigger>
                    </ControlTemplate.Triggers>
                </ControlTemplate>
            </Setter.Value>
        </Setter>
    </Style>

    <!--  ── Form Field Validation Error ──  -->
    <Style x:Key="FormFieldError" TargetType="TextBlock">
        <Setter Property="FontSize" Value="{StaticResource FontSizeXs}" />
        <Setter Property="Foreground" Value="{DynamicResource AppDanger}" />
        <Setter Property="Margin" Value="0,2,0,0" />
        <Setter Property="TextWrapping" Value="Wrap" />
    </Style>

    <!--
        ── FormDatePicker ─────────────────────────────────────────────
        自製 UserControl（Controls/FormDatePicker.xaml + CalendarPanel.xaml）
        完全不使用 WPF 內建 Calendar / DatePicker / CalendarItem。
        日曆面板以純 UniformGrid + Button 實現，無 WPF.UI 衝突。
        ───────────────────────────────────────────────────────────────
    -->

    <!--  ── Form Input PasswordBox ──  -->
    <!--  Matches FormTextBox visually (rounded border + focus ring).  -->
    <Style x:Key="FormPasswordBox" TargetType="PasswordBox">
        <Setter Property="Padding" Value="8,5" />
        <Setter Property="Background" Value="{DynamicResource AppBackground}" />
        <Setter Property="BorderBrush" Value="{DynamicResource AppBorder}" />
        <Setter Property="BorderThickness" Value="1" />
        <Setter Property="FontFamily" Value="{StaticResource FontTabular}" />
        <Setter Property="FontSize" Value="{StaticResource FontSizeSm}" />
        <Setter Property="Foreground" Value="{DynamicResource AppTextPrimary}" />
        <Setter Property="CaretBrush" Value="{DynamicResource AppTextPrimary}" />
        <Setter Property="FocusVisualStyle" Value="{x:Null}" />
        <Setter Property="Template">
            <Setter.Value>
                <ControlTemplate TargetType="PasswordBox">
                    <Border
                        x:Name="Bd"
                        Padding="{TemplateBinding Padding}"
                        Background="{TemplateBinding Background}"
                        BorderBrush="{TemplateBinding BorderBrush}"
                        BorderThickness="{TemplateBinding BorderThickness}"
                        CornerRadius="{StaticResource RadiusSm}">
                        <ScrollViewer x:Name="PART_ContentHost" VerticalContentAlignment="Center" />
                    </Border>
                    <ControlTemplate.Triggers>
                        <Trigger Property="IsFocused" Value="True">
                            <Setter TargetName="Bd" Property="BorderBrush" Value="{DynamicResource AppAccent}" />
                        </Trigger>
                        <Trigger Property="IsEnabled" Value="False">
                            <Setter Property="Opacity" Value="0.5" />
                        </Trigger>
                    </ControlTemplate.Triggers>
                </ControlTemplate>
            </Setter.Value>
        </Setter>
    </Style>

    <!--  ── Form Input ComboBox ──  -->

    <!--  Item inside dropdown  -->
    <Style x:Key="FormComboBoxItem" TargetType="ComboBoxItem">
        <Setter Property="Background" Value="Transparent" />
        <Setter Property="Foreground" Value="{DynamicResource AppTextPrimary}" />
        <Setter Property="Padding" Value="10,6" />
        <Setter Property="FontFamily" Value="{StaticResource FontBase}" />
        <Setter Property="FontSize" Value="{StaticResource FontSizeSm}" />
        <Setter Property="FocusVisualStyle" Value="{x:Null}" />
        <Setter Property="Template">
            <Setter.Value>
                <ControlTemplate TargetType="ComboBoxItem">
                    <Border
                        x:Name="Bd"
                        Padding="{TemplateBinding Padding}"
                        Background="{TemplateBinding Background}">
                        <ContentPresenter />
                    </Border>
                    <ControlTemplate.Triggers>
                        <Trigger Property="IsMouseOver" Value="True">
                            <Setter TargetName="Bd" Property="Background" Value="{DynamicResource AppHover}" />
                        </Trigger>
                        <Trigger Property="IsSelected" Value="True">
                            <Setter TargetName="Bd" Property="Background" Value="{DynamicResource AppAccentSubtle}" />
                            <Setter Property="Foreground" Value="{DynamicResource AppAccent}" />
                        </Trigger>
                        <MultiTrigger>
                            <MultiTrigger.Conditions>
                                <Condition Property="IsSelected" Value="True" />
                                <Condition Property="IsMouseOver" Value="True" />
                            </MultiTrigger.Conditions>
                            <Setter TargetName="Bd" Property="Background" Value="{DynamicResource AppAccentSubtle}" />
                        </MultiTrigger>
                    </ControlTemplate.Triggers>
                </ControlTemplate>
            </Setter.Value>
        </Setter>
    </Style>

    <!--  ComboBox shell + dropdown  -->
    <Style x:Key="FormComboBox" TargetType="ComboBox">
        <Setter Property="MinHeight" Value="32" />
        <Setter Property="VerticalContentAlignment" Value="Center" />
        <Setter Property="Background" Value="{DynamicResource AppBackground}" />
        <Setter Property="Foreground" Value="{DynamicResource AppTextPrimary}" />
        <Setter Property="FontFamily" Value="{StaticResource FontBase}" />
        <Setter Property="FontSize" Value="{StaticResource FontSizeSm}" />
        <Setter Property="FocusVisualStyle" Value="{x:Null}" />
        <Setter Property="ItemContainerStyle" Value="{StaticResource FormComboBoxItem}" />
        <Setter Property="ScrollViewer.HorizontalScrollBarVisibility" Value="Disabled" />
        <Setter Property="Template">
            <Setter.Value>
                <ControlTemplate TargetType="ComboBox">
                    <Grid x:Name="Root">

                        <!--
                            ToggleButton provides the styled border + click-to-open.
                            Content display is lifted to the root Grid so PART_EditableTextBox
                            (required by WPF for IsEditable=True) can live at the same level.
                        -->
                        <ToggleButton
                            x:Name="ToggleButton"
                            HorizontalAlignment="Stretch"
                            VerticalAlignment="Stretch"
                            ClickMode="Press"
                            Focusable="False"
                            IsChecked="{Binding IsDropDownOpen, Mode=TwoWay, RelativeSource={RelativeSource TemplatedParent}}">
                            <ToggleButton.Template>
                                <ControlTemplate TargetType="ToggleButton">
                                    <Border
                                        x:Name="Bd"
                                        Background="{DynamicResource AppBackground}"
                                        BorderBrush="{DynamicResource AppBorder}"
                                        BorderThickness="1"
                                        CornerRadius="{StaticResource RadiusSm}">
                                        <Grid>
                                            <Grid.ColumnDefinitions>
                                                <ColumnDefinition Width="*" />
                                                <ColumnDefinition Width="24" />
                                            </Grid.ColumnDefinitions>
                                            <!--  Transparent spacer — actual content rendered above at root level  -->
                                            <Rectangle Grid.Column="0" Fill="Transparent" />
                                            <!--  Chevron  -->
                                            <TextBlock
                                                Grid.Column="1"
                                                HorizontalAlignment="Center"
                                                VerticalAlignment="Center"
                                                FontFamily="Segoe MDL2 Assets"
                                                FontSize="10"
                                                Foreground="{DynamicResource AppTextMuted}"
                                                IsHitTestVisible="False"
                                                Text="&#xE70D;" />
                                        </Grid>
                                    </Border>
                                    <ControlTemplate.Triggers>
                                        <!--  Dropdown open  -->
                                        <Trigger Property="IsChecked" Value="True">
                                            <Setter TargetName="Bd" Property="BorderBrush" Value="{DynamicResource AppAccent}" />
                                        </Trigger>
                                        <!--  Keyboard focus  -->
                                        <DataTrigger Binding="{Binding IsKeyboardFocusWithin, RelativeSource={RelativeSource AncestorType=ComboBox}}" Value="True">
                                            <Setter TargetName="Bd" Property="BorderBrush" Value="{DynamicResource AppAccent}" />
                                        </DataTrigger>
                                        <!--  Disabled  -->
                                        <DataTrigger Binding="{Binding IsEnabled, RelativeSource={RelativeSource AncestorType=ComboBox}}" Value="False">
                                            <Setter TargetName="Bd" Property="Opacity" Value="0.5" />
                                        </DataTrigger>
                                    </ControlTemplate.Triggers>
                                </ControlTemplate>
                            </ToggleButton.Template>
                        </ToggleButton>

                        <!--  Non-editable: display selected item text  -->
                        <ContentPresenter
                            x:Name="ContentPresenter"
                            Margin="8,0,24,0"
                            HorizontalAlignment="Left"
                            VerticalAlignment="Center"
                            Content="{TemplateBinding SelectionBoxItem}"
                            ContentTemplate="{TemplateBinding SelectionBoxItemTemplate}"
                            IsHitTestVisible="False" />

                        <!--
                            Editable text box — WPF requires this named part to exist when
                            IsEditable="True".  Hidden by default; shown via IsEditable trigger.
                        -->
                        <TextBox
                            x:Name="PART_EditableTextBox"
                            Margin="6,0,24,0"
                            Padding="0"
                            VerticalAlignment="Center"
                            Background="Transparent"
                            BorderThickness="0"
                            CaretBrush="{DynamicResource AppTextPrimary}"
                            FontFamily="{TemplateBinding FontFamily}"
                            FontSize="{TemplateBinding FontSize}"
                            Foreground="{TemplateBinding Foreground}"
                            IsReadOnly="{Binding IsReadOnly, RelativeSource={RelativeSource TemplatedParent}}"
                            Visibility="Collapsed" />

                        <!--  Dropdown popup  -->
                        <Popup
                            x:Name="PART_Popup"
                            AllowsTransparency="True"
                            IsOpen="{TemplateBinding IsDropDownOpen}"
                            Placement="Bottom">
                            <Border
                                MinWidth="{Binding ActualWidth, ElementName=Root}"
                                MaxHeight="{TemplateBinding MaxDropDownHeight}"
                                Margin="0,2,0,0"
                                Background="{DynamicResource AppSurface}"
                                BorderBrush="{DynamicResource AppBorder}"
                                BorderThickness="1"
                                CornerRadius="{StaticResource RadiusSm}">
                                <ScrollViewer Focusable="False">
                                    <ItemsPresenter />
                                </ScrollViewer>
                            </Border>
                        </Popup>
                    </Grid>
                    <ControlTemplate.Triggers>
                        <!--  Switch to editable text box when IsEditable=True  -->
                        <Trigger Property="IsEditable" Value="True">
                            <Setter TargetName="PART_EditableTextBox" Property="Visibility" Value="Visible" />
                            <Setter TargetName="ContentPresenter" Property="Visibility" Value="Collapsed" />
                        </Trigger>
                    </ControlTemplate.Triggers>
                </ControlTemplate>
            </Setter.Value>
        </Setter>
    </Style>

    <!--  ── Feature Page Toolbar Title ──  -->
    <!--
        More prominent than PanelHeaderText — used for main content
        page toolbar headings (選股, 持股組合, etc.), not side-panel headers.
    -->
    <Style x:Key="PanelToolbarText" TargetType="TextBlock">
        <Setter Property="FontFamily" Value="{StaticResource FontBase}" />
        <Setter Property="FontSize" Value="{StaticResource FontSizeMd}" />
        <Setter Property="FontWeight" Value="SemiBold" />
        <Setter Property="Foreground" Value="{DynamicResource AppTextPrimary}" />
        <Setter Property="VerticalAlignment" Value="Center" />
        <Setter Property="TextOptions.TextFormattingMode" Value="Display" />
    </Style>

    <!--  ── Indicator Toggle Button (ToggleButton, chart indicators) ──  -->
    <Style x:Key="IndicatorToggleBtn" TargetType="ToggleButton">
        <Setter Property="Background" Value="Transparent" />
        <Setter Property="Foreground" Value="{DynamicResource AppTextSecondary}" />
        <Setter Property="BorderThickness" Value="0" />
        <Setter Property="Padding" Value="8,4" />
        <Setter Property="FontFamily" Value="{StaticResource FontBase}" />
        <Setter Property="FontSize" Value="{StaticResource FontSizeSm}" />
        <Setter Property="Cursor" Value="Hand" />
        <Setter Property="Template">
            <Setter.Value>
                <ControlTemplate TargetType="ToggleButton">
                    <Border
                        x:Name="Bd"
                        Padding="{TemplateBinding Padding}"
                        Background="{TemplateBinding Background}"
                        BorderBrush="Transparent"
                        BorderThickness="1"
                        CornerRadius="{StaticResource RadiusSm}">
                        <ContentPresenter HorizontalAlignment="Center" VerticalAlignment="Center" />
                    </Border>
                    <ControlTemplate.Triggers>
                        <Trigger Property="IsChecked" Value="True">
                            <Setter Property="Background" Value="{DynamicResource AppAccentSubtle}" />
                            <Setter Property="Foreground" Value="{DynamicResource AppAccent}" />
                            <Setter Property="FontWeight" Value="SemiBold" />
                        </Trigger>
                        <Trigger Property="IsMouseOver" Value="True">
                            <Setter Property="Background" Value="{DynamicResource AppHover}" />
                            <Setter Property="Foreground" Value="{DynamicResource AppTextPrimary}" />
                        </Trigger>
                        <Trigger Property="IsFocused" Value="True">
                            <Setter TargetName="Bd" Property="BorderBrush" Value="{DynamicResource AppAccent}" />
                        </Trigger>
                    </ControlTemplate.Triggers>
                </ControlTemplate>
            </Setter.Value>
        </Setter>
    </Style>

    <!--  ── Segmented Control Button (Radio-style) ──  -->
    <Style x:Key="SegmentBtn" TargetType="RadioButton">
        <Setter Property="Background" Value="Transparent" />
        <Setter Property="Foreground" Value="{DynamicResource AppTextSecondary}" />
        <Setter Property="BorderThickness" Value="0" />
        <Setter Property="Padding" Value="12,5" />
        <Setter Property="FontFamily" Value="{StaticResource FontBase}" />
        <Setter Property="FontSize" Value="{StaticResource FontSizeSm}" />
        <Setter Property="Cursor" Value="Hand" />
        <Setter Property="Template">
            <Setter.Value>
                <ControlTemplate TargetType="RadioButton">
                    <Border
                        x:Name="Bd"
                        Padding="{TemplateBinding Padding}"
                        Background="{TemplateBinding Background}"
                        BorderBrush="Transparent"
                        BorderThickness="1"
                        CornerRadius="{StaticResource RadiusSm}">
                        <TextBlock
                            HorizontalAlignment="Center"
                            VerticalAlignment="Center"
                            FontFamily="{TemplateBinding FontFamily}"
                            FontSize="{TemplateBinding FontSize}"
                            FontWeight="{TemplateBinding FontWeight}"
                            Foreground="{TemplateBinding Foreground}"
                            Text="{TemplateBinding Content}" />
                    </Border>
                    <ControlTemplate.Triggers>
                        <Trigger Property="IsChecked" Value="True">
                            <Setter TargetName="Bd" Property="Background" Value="{DynamicResource AppAccent}" />
                            <Setter Property="Foreground" Value="{DynamicResource AppTextOnAccent}" />
                            <Setter TargetName="Bd" Property="BorderBrush" Value="{DynamicResource AppAccent}" />
                        </Trigger>
                        <Trigger Property="IsMouseOver" Value="True">
                            <Setter TargetName="Bd" Property="Background" Value="{DynamicResource AppHover}" />
                            <Setter Property="Foreground" Value="{DynamicResource AppTextPrimary}" />
                        </Trigger>
                        <MultiTrigger>
                            <MultiTrigger.Conditions>
                                <Condition Property="IsChecked" Value="True" />
                                <Condition Property="IsMouseOver" Value="True" />
                            </MultiTrigger.Conditions>
                            <Setter TargetName="Bd" Property="Background" Value="{DynamicResource AppAccent}" />
                            <Setter Property="Foreground" Value="{DynamicResource AppTextOnAccent}" />
                            <Setter TargetName="Bd" Property="BorderBrush" Value="{DynamicResource AppAccent}" />
                        </MultiTrigger>
                        <!--  Keyboard focus ring  -->
                        <Trigger Property="IsFocused" Value="True">
                            <Setter TargetName="Bd" Property="BorderBrush" Value="{DynamicResource AppAccent}" />
                        </Trigger>
                    </ControlTemplate.Triggers>
                </ControlTemplate>
            </Setter.Value>
        </Setter>
    </Style>


</ResourceDictionary>
