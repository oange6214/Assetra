<ResourceDictionary
    xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
    xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
    xmlns:models="clr-namespace:Assetra.Core.Models;assembly=Assetra.Core">

    <!--
        ════════════════════════════════════════════════════════════════
        App-specific resources (NOT design system)
        ════════════════════════════════════════════════════════════════
        Generic design-system primitives now live under DesignSystem/:

          DesignSystem/Tokens/Typography.xaml   Font + size scale
          DesignSystem/Tokens/Sizes.xaml        Layout sizing tokens
          DesignSystem/Tokens/Radius.xaml       Corner radius scale
          DesignSystem/Styles/Buttons.xaml      Wpf.Ui Button trigger fix
          DesignSystem/Styles/Focus.xaml        Keyboard focus visual
          DesignSystem/Styles/Inputs.xaml       TextBlock/TextBox/ToolTip/ComboBox
          DesignSystem/Styles/Tabs.xaml         NavTabBtn/SegmentBtn/TabControl/TabItem
          DesignSystem/Styles/DataGrid.xaml     DataGrid header/cell/row
          DesignSystem/Styles/Cards.xaml        FormCard/FormSectionTitle

        This file keeps only resources that depend on Assetra.Core
        domain types (StockSearchResult, AssetType) or contain product
        branding — they don't belong in a generic design layer.
    -->

    <!--  ── App Logo (DrawingImage — resolution-independent) ──  -->
    <DrawingImage x:Key="AssetraLogo">
        <DrawingImage.Drawing>
            <DrawingGroup>
                <GeometryDrawing Brush="#142F55">
                    <GeometryDrawing.Geometry>
                        <PathGeometry Figures="M 34,72 L 52,28 64,28 46,72 Z" />
                    </GeometryDrawing.Geometry>
                </GeometryDrawing>
                <GeometryDrawing Brush="#C8A25A">
                    <GeometryDrawing.Geometry>
                        <PathGeometry Figures="M 60,72 L 72,52 82,72 Z" />
                    </GeometryDrawing.Geometry>
                </GeometryDrawing>
            </DrawingGroup>
        </DrawingImage.Drawing>
    </DrawingImage>

    <!--  ── Stock-symbol search dropdown ──  -->
    <Style x:Key="StockSuggestionListBoxItemStyle" TargetType="ListBoxItem">
        <Setter Property="Padding" Value="10,7" />
        <Setter Property="Background" Value="Transparent" />
        <Setter Property="BorderThickness" Value="0" />
        <Setter Property="HorizontalContentAlignment" Value="Stretch" />
        <Setter Property="FocusVisualStyle" Value="{x:Null}" />
        <Style.Triggers>
            <Trigger Property="IsMouseOver" Value="True">
                <Setter Property="Background" Value="{DynamicResource AppHover}" />
            </Trigger>
        </Style.Triggers>
    </Style>

    <DataTemplate x:Key="StockSuggestionItemTemplate" DataType="{x:Type models:StockSearchResult}">
        <Grid>
            <Grid.ColumnDefinitions>
                <ColumnDefinition Width="64" />
                <ColumnDefinition Width="40" />
                <ColumnDefinition Width="*" />
            </Grid.ColumnDefinitions>

            <TextBlock
                Grid.Column="0"
                VerticalAlignment="Center"
                FontFamily="{DynamicResource FontTabular}"
                FontSize="{DynamicResource FontSizeSm}"
                FontWeight="SemiBold"
                Foreground="{DynamicResource AppTextPrimary}"
                Text="{Binding Symbol}" />

            <Border
                Grid.Column="1"
                Width="28"
                Height="20"
                Margin="0,0,8,0"
                HorizontalAlignment="Left"
                VerticalAlignment="Center"
                Background="{DynamicResource AppAccent}"
                CornerRadius="5">
                <TextBlock
                    HorizontalAlignment="Center"
                    VerticalAlignment="Center"
                    FontSize="{DynamicResource FontSizeXs}"
                    FontWeight="SemiBold"
                    Foreground="White"
                    Text="股">
                    <TextBlock.Style>
                        <Style TargetType="TextBlock">
                            <Setter Property="Text" Value="股" />
                            <Style.Triggers>
                                <DataTrigger Binding="{Binding IsEtf}" Value="True">
                                    <Setter Property="Text" Value="ETF" />
                                </DataTrigger>
                            </Style.Triggers>
                        </Style>
                    </TextBlock.Style>
                </TextBlock>
            </Border>

            <StackPanel Grid.Column="2">
                <TextBlock
                    FontSize="{DynamicResource FontSizeSm}"
                    Foreground="{DynamicResource AppTextPrimary}"
                    Text="{Binding Name}"
                    TextTrimming="CharacterEllipsis" />
                <TextBlock
                    Margin="0,2,0,0"
                    FontSize="{DynamicResource FontSizeXs}"
                    Foreground="{DynamicResource AppTextMuted}"
                    Text="{Binding Exchange}"
                    TextTrimming="CharacterEllipsis" />
            </StackPanel>
        </Grid>
    </DataTemplate>

    <!--  ── Portfolio status badges (asset-type / default / liability) ──  -->
    <Style x:Key="PortfolioBadgeText" TargetType="TextBlock">
        <Setter Property="HorizontalAlignment" Value="Center" />
        <Setter Property="VerticalAlignment" Value="Center" />
        <Setter Property="FontSize" Value="{DynamicResource FontSizeXs}" />
        <Setter Property="FontWeight" Value="SemiBold" />
        <Setter Property="Foreground" Value="{DynamicResource AppTextOnAccent}" />
    </Style>

    <!--
        Base for portfolio status badges. Derived styles override
        Background + MinWidth for asset-type categorical colours.
    -->
    <Style x:Key="PortfolioBadgeBase" TargetType="Border">
        <Setter Property="Height" Value="20" />
        <Setter Property="MinWidth" Value="38" />
        <Setter Property="Padding" Value="8,0" />
        <Setter Property="HorizontalAlignment" Value="Left" />
        <Setter Property="VerticalAlignment" Value="Center" />
        <Setter Property="CornerRadius" Value="{DynamicResource RadiusSm}" />
    </Style>

    <Style
        x:Key="PortfolioAssetTypeBadge"
        BasedOn="{StaticResource PortfolioBadgeBase}"
        TargetType="Border">
        <Setter Property="Background" Value="#0062AD" />
        <Setter Property="MinWidth" Value="34" />
        <Style.Triggers>
            <DataTrigger Binding="{Binding AssetType}" Value="{x:Static models:AssetType.Fund}">
                <Setter Property="Background" Value="#0A7A55" />
            </DataTrigger>
            <DataTrigger Binding="{Binding AssetType}" Value="{x:Static models:AssetType.PreciousMetal}">
                <Setter Property="Background" Value="#966300" />
            </DataTrigger>
            <DataTrigger Binding="{Binding AssetType}" Value="{x:Static models:AssetType.Bond}">
                <Setter Property="Background" Value="#374151" />
            </DataTrigger>
            <DataTrigger Binding="{Binding AssetType}" Value="{x:Static models:AssetType.Crypto}">
                <Setter Property="Background" Value="#5B21B6" />
            </DataTrigger>
        </Style.Triggers>
    </Style>

    <Style
        x:Key="PortfolioDefaultBadge"
        BasedOn="{StaticResource PortfolioBadgeBase}"
        TargetType="Border">
        <Setter Property="Background" Value="{DynamicResource AppAccent}" />
    </Style>

    <Style
        x:Key="PortfolioLiabilityBadge"
        BasedOn="{StaticResource PortfolioBadgeBase}"
        TargetType="Border">
        <Setter Property="Background" Value="#374151" />
        <Setter Property="MinWidth" Value="42" />
        <Style.Triggers>
            <DataTrigger Binding="{Binding IsCreditCard}" Value="True">
                <Setter Property="Background" Value="#8A6A1F" />
            </DataTrigger>
        </Style.Triggers>
    </Style>

</ResourceDictionary>
