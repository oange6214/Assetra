<Application
    x:Class="Assetra.WPF.App"
    xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
    xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
    xmlns:converters="clr-namespace:Assetra.WPF.Infrastructure.Converters">
    <Application.Resources>
        <ResourceDictionary>
            <BooleanToVisibilityConverter x:Key="BooleanToVisibilityConverter" />
            <BooleanToVisibilityConverter x:Key="BoolToVisibilityConverter" />
            <converters:InverseBooleanToVisibilityConverter x:Key="InverseBooleanToVisibilityConverter" />
            <converters:NullToVisibilityConverter x:Key="NullToVisibilityConverter" />
            <converters:BooleanToBrushConverter x:Key="BooleanToBrushConverter" />
            <converters:StringToVisibilityConverter x:Key="StringToVisibilityConverter" />
            <converters:EnumToBoolConverter x:Key="EnumToBoolConverter" />
            <converters:HexToBrushConverter x:Key="HexToBrushConverter" />
            <converters:StringEqualityConverter x:Key="EqualityConverter" />
            <converters:StatusTagToBrushConverter x:Key="StatusTagToBrushConverter" />
            <converters:PercentToWidthConverter x:Key="PercentToWidthConverter" />
            <converters:CurrencyConverter x:Key="CurrencyConverter" />
            <converters:DateDisplayConverter x:Key="DateDisplayConverter" />
            <converters:TradeTypeConverter x:Key="TradeTypeConverter" />
            <converters:ResourceKeyToStringConverter x:Key="ResourceKeyToStringConverter" />
            <converters:ZeroToVisibleConverter x:Key="ZeroToVisibleConverter" />
            <converters:WidthScaleThresholdToBooleanConverter x:Key="WidthScaleThresholdToBooleanConverter" />
            <converters:WidthScaleThresholdToVisibilityConverter x:Key="WidthScaleThresholdToVisibilityConverter" />
            <converters:InverseWidthScaleThresholdToVisibilityConverter x:Key="InverseWidthScaleThresholdToVisibilityConverter" />
            <converters:AdaptivePanelWidthConverter x:Key="AdaptivePanelWidthConverter" />

            <ResourceDictionary.MergedDictionaries>
                <!--  ── Design-system primitives (required by theme + styles) ──  -->
                <ResourceDictionary Source="pack://application:,,,/Assetra.WPF;component/DesignSystem/Tokens.xaml" />

                <!--  ── Theme palette (swappable Light ↔ Dark) ──  -->
                <ResourceDictionary Source="pack://application:,,,/Assetra.WPF;component/DesignSystem/Themes/Dark.xaml" />

                <!--  ── Focus visual must be top-level for local control dictionaries using StaticResource ──  -->
                <ResourceDictionary Source="pack://application:,,,/Assetra.WPF;component/DesignSystem/Styles/Focus.xaml" />

                <!--  ── Central style/resource indexes ──  -->
                <ResourceDictionary Source="pack://application:,,,/Assetra.WPF;component/DesignSystem/Styles.xaml" />
                <ResourceDictionary Source="pack://application:,,,/Assetra.WPF;component/Resources/AppResources.xaml" />

                <!--  Default language — overridden at startup by WpfLocalizationService based on saved AppSettings.Language  -->
                <ResourceDictionary Source="pack://application:,,,/Assetra.WPF;component/Languages/zh-TW.xaml" />
            </ResourceDictionary.MergedDictionaries>
        </ResourceDictionary>
    </Application.Resources>
</Application>
