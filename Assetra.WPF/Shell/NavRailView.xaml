<UserControl
    x:Class="Assetra.WPF.Shell.NavRailView"
    xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
    xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
    xmlns:alerts="clr-namespace:Assetra.WPF.Features.Alerts"
    xmlns:assistant="clr-namespace:Assetra.WPF.Features.Assistant"
    xmlns:auditlog="clr-namespace:Assetra.WPF.Features.AuditLog"
    xmlns:cashaccts="clr-namespace:Assetra.WPF.Features.CashAccounts"
    xmlns:categories="clr-namespace:Assetra.WPF.Features.Categories"
    xmlns:d="http://schemas.microsoft.com/expression/blend/2008"
    xmlns:ds="clr-namespace:Assetra.WPF.DesignSystem.Controls"
    xmlns:financialoverview="clr-namespace:Assetra.WPF.Features.FinancialOverview"
    xmlns:cal="clr-namespace:Assetra.WPF.Features.FinancialOverview.Calendar"
    xmlns:fire="clr-namespace:Assetra.WPF.Features.Fire"
    xmlns:goals="clr-namespace:Assetra.WPF.Features.Goals"
    xmlns:portfoliogroups="clr-namespace:Assetra.WPF.Features.PortfolioGroups"
    xmlns:import="clr-namespace:Assetra.WPF.Features.Import"
    xmlns:insurance="clr-namespace:Assetra.WPF.Features.Insurance"
    xmlns:liabs="clr-namespace:Assetra.WPF.Features.Liabilities"
    xmlns:mc="http://schemas.openxmlformats.org/markup-compatibility/2006"
    xmlns:montecarlo="clr-namespace:Assetra.WPF.Features.MonteCarlo"
    xmlns:physicalasset="clr-namespace:Assetra.WPF.Features.PhysicalAsset"
    xmlns:portfolio="clr-namespace:Assetra.WPF.Features.Portfolio"
    xmlns:pcontrols="clr-namespace:Assetra.WPF.Features.Portfolio.Controls"
    xmlns:realestate="clr-namespace:Assetra.WPF.Features.RealEstate"
    xmlns:reconciliation="clr-namespace:Assetra.WPF.Features.Reconciliation"
    xmlns:recurring="clr-namespace:Assetra.WPF.Features.Recurring"
    xmlns:reports="clr-namespace:Assetra.WPF.Features.Reports"
    xmlns:retirement="clr-namespace:Assetra.WPF.Features.Retirement"
    xmlns:settings="clr-namespace:Assetra.WPF.Features.Settings"
    xmlns:shell="clr-namespace:Assetra.WPF.Shell"
    xmlns:trends="clr-namespace:Assetra.WPF.Features.Trends"
    xmlns:txlog="clr-namespace:Assetra.WPF.Features.TransactionLog"
    d:DataContext="{d:DesignInstance Type={x:Type shell:MainViewModel},
                                     IsDesignTimeCreatable=False}"
    mc:Ignorable="d">

    <UserControl.Resources>

        <!--
            ── Leaf-button visual style (shared by expanded list, popup, bottom items) ──
            P2.16 — Height 40 → 44 (audit recommends 44-48 for premium financial nav；
            原 40 跟一般 list item 太接近)。Margin 3,1 vertical keeps inter-item
            breathing 不變。
        -->
        <Style x:Key="NavRailItemButton" TargetType="{x:Type ToggleButton}">
            <Setter Property="Height" Value="44" />
            <Setter Property="Margin" Value="3,1" />
            <Setter Property="Padding" Value="0" />
            <Setter Property="Background" Value="Transparent" />
            <Setter Property="BorderBrush" Value="Transparent" />
            <Setter Property="BorderThickness" Value="0" />
            <Setter Property="Cursor" Value="Hand" />
            <Setter Property="Focusable" Value="True" />
            <Setter Property="HorizontalContentAlignment" Value="Stretch" />
            <Setter Property="VerticalContentAlignment" Value="Center" />
            <Setter Property="Template">
                <Setter.Value>
                    <ControlTemplate TargetType="{x:Type ToggleButton}">
                        <Border
                            x:Name="Chrome"
                            Background="{TemplateBinding Background}"
                            CornerRadius="{StaticResource Radius.Sm}">
                            <Grid>
                                <Grid.ColumnDefinitions>
                                    <ColumnDefinition Width="4" />
                                    <ColumnDefinition Width="*" />
                                </Grid.ColumnDefinitions>
                                <Border
                                    x:Name="Indicator"
                                    Grid.Column="0"
                                    Width="3"
                                    Height="18"
                                    HorizontalAlignment="Left"
                                    VerticalAlignment="Center"
                                    Background="{DynamicResource AppAccent}"
                                    CornerRadius="0,2,2,0"
                                    Visibility="Collapsed" />
                                <ContentPresenter
                                    Grid.Column="1"
                                    Margin="10,0,8,0"
                                    HorizontalAlignment="{TemplateBinding HorizontalContentAlignment}"
                                    VerticalAlignment="{TemplateBinding VerticalContentAlignment}" />
                            </Grid>
                        </Border>
                        <ControlTemplate.Triggers>
                            <Trigger Property="IsMouseOver" Value="True">
                                <Setter TargetName="Chrome" Property="Background" Value="{DynamicResource AppHover}" />
                            </Trigger>
                            <Trigger Property="IsKeyboardFocused" Value="True">
                                <Setter TargetName="Chrome" Property="BorderBrush" Value="{DynamicResource AppAccent}" />
                            </Trigger>
                            <Trigger Property="IsChecked" Value="True">
                                <Setter TargetName="Chrome" Property="Background" Value="{DynamicResource AppHover}" />
                                <Setter TargetName="Indicator" Property="Visibility" Value="Visible" />
                            </Trigger>
                            <Trigger Property="IsEnabled" Value="False">
                                <Setter Property="Opacity" Value="0.45" />
                            </Trigger>
                        </ControlTemplate.Triggers>
                    </ControlTemplate>
                </Setter.Value>
            </Setter>
        </Style>

        <!--  Group-header style (expanded mode): chevron + title.  -->
        <Style x:Key="NavRailGroupHeader" TargetType="{x:Type ToggleButton}">
            <Setter Property="Height" Value="32" />
            <Setter Property="Margin" Value="3,8,3,2" />
            <Setter Property="Padding" Value="0" />
            <Setter Property="Background" Value="Transparent" />
            <Setter Property="BorderBrush" Value="Transparent" />
            <Setter Property="BorderThickness" Value="0" />
            <Setter Property="Cursor" Value="Hand" />
            <Setter Property="HorizontalContentAlignment" Value="Stretch" />
            <Setter Property="VerticalContentAlignment" Value="Center" />
            <Setter Property="Template">
                <Setter.Value>
                    <ControlTemplate TargetType="{x:Type ToggleButton}">
                        <Border
                            x:Name="Chrome"
                            Background="{TemplateBinding Background}"
                            CornerRadius="{StaticResource Radius.Sm}">
                            <ContentPresenter
                                Margin="14,0,8,0"
                                HorizontalAlignment="{TemplateBinding HorizontalContentAlignment}"
                                VerticalAlignment="{TemplateBinding VerticalContentAlignment}" />
                        </Border>
                        <ControlTemplate.Triggers>
                            <Trigger Property="IsMouseOver" Value="True">
                                <Setter TargetName="Chrome" Property="Background" Value="{DynamicResource AppHover}" />
                            </Trigger>
                            <Trigger Property="IsKeyboardFocused" Value="True">
                                <Setter TargetName="Chrome" Property="BorderBrush" Value="{DynamicResource AppAccent}" />
                            </Trigger>
                        </ControlTemplate.Triggers>
                    </ControlTemplate>
                </Setter.Value>
            </Setter>
        </Style>

        <!--  Group icon (collapsed mode): like a leaf button but uses the group icon and opens a flyout.  -->
        <Style x:Key="NavRailGroupIconButton" TargetType="{x:Type ToggleButton}" BasedOn="{StaticResource NavRailItemButton}">
            <!--  The base style already paints a hover/focus chrome; isChecked here means "flyout open".  -->
        </Style>

        <Style x:Key="NavRailItemText" TargetType="{x:Type TextBlock}">
            <Setter Property="Margin" Value="10,0,0,0" />
            <Setter Property="VerticalAlignment" Value="Center" />
            <Setter Property="FontSize" Value="{StaticResource Font.Size.Sm}" />
            <Setter Property="Foreground" Value="{DynamicResource AppTextPrimary}" />
            <Setter Property="TextTrimming" Value="CharacterEllipsis" />
        </Style>

        <!--
            P2.11 — section title 細化：原 12px SemiBold AppTextMuted 看起來跟 nav item label
            (14px Sm) 太接近，視覺競爭。降成 11px Medium + uppercase + 字級拉開：使用者掃 nav
            時 group label 退到背景、actual items 凸顯。Uppercase 是 WPF 沒有 native letter-spacing
            的折衷實現分組質感（en/zh-CN-friendly：中文沒大小寫變化、英文有；至少英文 nav 立刻有
            金融工具列的「ANALYTICS / ASSETS」 quality）。
        -->
        <Style x:Key="NavRailGroupTitle" TargetType="{x:Type TextBlock}">
            <Setter Property="VerticalAlignment" Value="Center" />
            <Setter Property="FontSize" Value="{StaticResource Font.Size.2Xs}" />
            <Setter Property="FontWeight" Value="{StaticResource Font.Weight.Medium}" />
            <Setter Property="Foreground" Value="{DynamicResource AppTextMuted}" />
            <Setter Property="TextTrimming" Value="CharacterEllipsis" />
            <Setter Property="Opacity" Value="0.72" />
        </Style>

        <Style x:Key="NavRailBadge" TargetType="{x:Type Border}">
            <Setter Property="MinWidth" Value="18" />
            <Setter Property="Height" Value="18" />
            <Setter Property="Margin" Value="8,0,0,0" />
            <Setter Property="Padding" Value="5,0" />
            <Setter Property="VerticalAlignment" Value="Center" />
            <Setter Property="Background" Value="{DynamicResource AppDanger}" />
            <Setter Property="CornerRadius" Value="9" />
        </Style>

        <!--
            Leaf badge content control — switches template based on the leaf's
            BadgeKind tag and binds to the appropriate VM at the UserControl
            level. Using a ContentControl + DataTrigger keeps the per-leaf
            template free of badge-specific bindings.
        -->
        <DataTemplate x:Key="NavLeafBadgeRecurringTemplate">
            <Border
                Style="{StaticResource NavRailBadge}"
                Visibility="{Binding DataContext.Recurring.HasPending, RelativeSource={RelativeSource AncestorType=UserControl}, Converter={StaticResource BooleanToVisibilityConverter}}">
                <TextBlock
                    HorizontalAlignment="Center"
                    VerticalAlignment="Center"
                    FontSize="{StaticResource Font.Size.Xs}"
                    Foreground="{DynamicResource AppTextOnAccent}"
                    Text="{Binding DataContext.Recurring.PendingCount, RelativeSource={RelativeSource AncestorType=UserControl}}" />
            </Border>
        </DataTemplate>

        <DataTemplate x:Key="NavLeafBadgeAlertsTemplate">
            <Border
                Style="{StaticResource NavRailBadge}"
                Visibility="{Binding DataContext.Alerts.HasTriggeredAlerts, RelativeSource={RelativeSource AncestorType=UserControl}, Converter={StaticResource BooleanToVisibilityConverter}}">
                <TextBlock
                    HorizontalAlignment="Center"
                    VerticalAlignment="Center"
                    FontSize="{StaticResource Font.Size.Xs}"
                    Foreground="{DynamicResource AppTextOnAccent}"
                    Text="{Binding DataContext.Alerts.TriggeredCount, RelativeSource={RelativeSource AncestorType=UserControl}}" />
            </Border>
        </DataTemplate>

        <!--  ── Leaf DataTemplate: full row with icon + label + optional badge.  ──  -->
        <DataTemplate x:Key="NavLeafRowTemplate" DataType="{x:Type shell:NavLeafVm}">
            <ToggleButton
                Click="NavLeaf_Click"
                IsChecked="{Binding IsActive, Mode=OneWay}"
                Style="{StaticResource NavRailItemButton}"
                Tag="{Binding}"
                ToolTip="{Binding LocalizedToolTip}">
                <Grid>
                    <Grid.ColumnDefinitions>
                        <ColumnDefinition Width="24" />
                        <ColumnDefinition Width="*" />
                        <ColumnDefinition Width="Auto" />
                    </Grid.ColumnDefinitions>
                    <ds:AppIcon Symbol="{Binding IconSymbol}" />
                    <TextBlock
                        Grid.Column="1"
                        Style="{StaticResource NavRailItemText}"
                        Text="{Binding LocalizedLabel}" />
                    <ContentControl Grid.Column="2">
                        <ContentControl.Style>
                            <Style TargetType="{x:Type ContentControl}">
                                <Setter Property="Visibility" Value="Collapsed" />
                                <Style.Triggers>
                                    <DataTrigger Binding="{Binding BadgeKind}" Value="Recurring">
                                        <Setter Property="Visibility" Value="Visible" />
                                        <Setter Property="ContentTemplate" Value="{StaticResource NavLeafBadgeRecurringTemplate}" />
                                    </DataTrigger>
                                    <DataTrigger Binding="{Binding BadgeKind}" Value="Alerts">
                                        <Setter Property="Visibility" Value="Visible" />
                                        <Setter Property="ContentTemplate" Value="{StaticResource NavLeafBadgeAlertsTemplate}" />
                                    </DataTrigger>
                                </Style.Triggers>
                            </Style>
                        </ContentControl.Style>
                    </ContentControl>
                </Grid>
            </ToggleButton>
        </DataTemplate>

        <!--  ── Group DataTemplate (expanded mode): collapsible header + child list.  ──  -->
        <DataTemplate x:Key="NavGroupExpandedTemplate" DataType="{x:Type shell:NavGroupVm}">
            <StackPanel>
                <ToggleButton
                    HorizontalContentAlignment="Stretch"
                    IsChecked="{Binding IsExpanded, Mode=TwoWay}"
                    Style="{StaticResource NavRailGroupHeader}"
                    ToolTip="{Binding LocalizedTitle}">
                    <Grid>
                        <Grid.ColumnDefinitions>
                            <ColumnDefinition Width="*" />
                            <ColumnDefinition Width="Auto" />
                        </Grid.ColumnDefinitions>
                        <TextBlock Style="{StaticResource NavRailGroupTitle}" Text="{Binding LocalizedTitle}" />
                        <ds:AppIcon
                            x:Name="Chevron"
                            Grid.Column="1"
                            Margin="0,0,4,0"
                            FontSize="12"
                            Foreground="{DynamicResource AppTextMuted}"
                            Symbol="ChevronDown24">
                            <ds:AppIcon.RenderTransform>
                                <RotateTransform x:Name="ChevronRotate" Angle="0" CenterX="6" CenterY="6" />
                            </ds:AppIcon.RenderTransform>
                        </ds:AppIcon>
                    </Grid>
                </ToggleButton>
                <ItemsControl
                    ItemTemplate="{StaticResource NavLeafRowTemplate}"
                    ItemsSource="{Binding Items}"
                    Visibility="{Binding IsExpanded, Converter={StaticResource BooleanToVisibilityConverter}}" />
            </StackPanel>
            <DataTemplate.Triggers>
                <DataTrigger Binding="{Binding IsExpanded}" Value="False">
                    <DataTrigger.EnterActions>
                        <BeginStoryboard>
                            <Storyboard>
                                <DoubleAnimation
                                    Storyboard.TargetName="ChevronRotate"
                                    Storyboard.TargetProperty="Angle"
                                    To="-90"
                                    Duration="0:0:0.12" />
                            </Storyboard>
                        </BeginStoryboard>
                    </DataTrigger.EnterActions>
                    <DataTrigger.ExitActions>
                        <BeginStoryboard>
                            <Storyboard>
                                <DoubleAnimation
                                    Storyboard.TargetName="ChevronRotate"
                                    Storyboard.TargetProperty="Angle"
                                    To="0"
                                    Duration="0:0:0.12" />
                            </Storyboard>
                        </BeginStoryboard>
                    </DataTrigger.ExitActions>
                </DataTrigger>
            </DataTemplate.Triggers>
        </DataTemplate>

        <!--
            Group DataTemplate (collapsed mode): icon button that opens a Popup
            flyout with the group's children. Same VS Code activity-bar pattern.
        -->
        <DataTemplate x:Key="NavGroupCollapsedTemplate" DataType="{x:Type shell:NavGroupVm}">
            <Grid>
                <ToggleButton
                    x:Name="GroupIconBtn"
                    Click="NavGroupIcon_Click"
                    IsChecked="{Binding HasActiveChild, Mode=OneWay}"
                    Style="{StaticResource NavRailGroupIconButton}"
                    Tag="{Binding}"
                    ToolTip="{Binding LocalizedTitle}">
                    <Grid>
                        <Grid.ColumnDefinitions>
                            <ColumnDefinition Width="24" />
                            <ColumnDefinition Width="*" />
                        </Grid.ColumnDefinitions>
                        <ds:AppIcon Symbol="{Binding GroupIconSymbol}" />
                    </Grid>
                </ToggleButton>
                <Popup
                    AllowsTransparency="True"
                    HorizontalOffset="4"
                    IsOpen="{Binding IsFlyoutOpen, Mode=TwoWay}"
                    Placement="Right"
                    PlacementTarget="{Binding ElementName=GroupIconBtn}"
                    PopupAnimation="Fade"
                    StaysOpen="False">
                    <Border
                        MinWidth="220"
                        Margin="0,4"
                        Padding="6,8"
                        Background="{DynamicResource AppSurface}"
                        BorderBrush="{DynamicResource AppBorderLight}"
                        BorderThickness="1"
                        CornerRadius="{StaticResource Radius.Md}"
                        SnapsToDevicePixels="True">
                        <Border.Effect>
                            <DropShadowEffect
                                BlurRadius="16"
                                Direction="270"
                                Opacity="0.18"
                                ShadowDepth="2"
                                Color="Black" />
                        </Border.Effect>
                        <StackPanel>
                            <TextBlock
                                Margin="14,4,0,8"
                                Style="{StaticResource NavRailGroupTitle}"
                                Text="{Binding LocalizedTitle}" />
                            <ItemsControl ItemTemplate="{StaticResource NavLeafRowTemplate}" ItemsSource="{Binding Items}" />
                        </StackPanel>
                    </Border>
                </Popup>
            </Grid>
        </DataTemplate>

        <!--  ── Bottom items DataTemplate (Import / Settings) — no group, just a leaf row.  ──  -->
        <DataTemplate x:Key="NavBottomLeafTemplate" DataType="{x:Type shell:NavLeafVm}">
            <ToggleButton
                Click="NavLeaf_Click"
                IsChecked="{Binding IsActive, Mode=OneWay}"
                Style="{StaticResource NavRailItemButton}"
                Tag="{Binding}"
                ToolTip="{Binding LocalizedToolTip}">
                <Grid>
                    <Grid.ColumnDefinitions>
                        <ColumnDefinition Width="24" />
                        <ColumnDefinition Width="*" />
                    </Grid.ColumnDefinitions>
                    <ds:AppIcon Symbol="{Binding IconSymbol}" />
                    <TextBlock
                        Grid.Column="1"
                        Style="{StaticResource NavRailItemText}"
                        Text="{Binding LocalizedLabel}"
                        Visibility="{Binding ElementName=PaneToggle, Path=IsChecked, Converter={StaticResource BooleanToVisibilityConverter}}" />
                </Grid>
            </ToggleButton>
        </DataTemplate>

        <!--  ─────────── Section view templates (resolved by ContentControl DataTrigger) ───────────  -->
        <DataTemplate x:Key="PortfolioContentTemplate">
            <portfolio:PortfolioView DataContext="{Binding Portfolio}" />
        </DataTemplate>

        <!--
            Stage 2 (Dashboard consolidation): 4-tab 財務儀表板。每個 TabItem
            的 DataContext 直接指向對應的 sub-VM，避免單一 FinancialOverviewVM
            背負所有 tab 的責任。SelectedValue 透過 FinancialOverview.SelectedDashboardTab
            雙向同步，方便 deep link（例：NavSection.Trends 點擊跳到 Trends tab）。
        -->
        <DataTemplate x:Key="FinancialOverviewContentTemplate">
            <TabControl
                HorizontalAlignment="Stretch"
                VerticalAlignment="Stretch"
                HorizontalContentAlignment="Stretch"
                VerticalContentAlignment="Stretch"
                Background="Transparent"
                BorderThickness="0"
                SelectedValue="{Binding FinancialOverview.SelectedDashboardTab, Mode=TwoWay}"
                SelectedValuePath="Tag">
                <TabControl.ItemContainerStyle>
                    <Style BasedOn="{StaticResource {x:Type TabItem}}" TargetType="{x:Type TabItem}">
                        <Setter Property="HorizontalContentAlignment" Value="Stretch" />
                        <Setter Property="VerticalContentAlignment" Value="Stretch" />
                    </Style>
                </TabControl.ItemContainerStyle>
                <!--  總覽：原 FinancialOverviewView（KPI bar + accordion + Stage 2.5 widget）  -->
                <TabItem Header="{DynamicResource Dashboard.Tab.Overview}"
                         Tag="{x:Static financialoverview:DashboardTab.Overview}">
                    <financialoverview:FinancialOverviewView DataContext="{Binding FinancialOverview}" />
                </TabItem>
                <!--  資產趨勢：原 Trends 頁，bind 到 Portfolio.History  -->
                <TabItem Header="{DynamicResource Dashboard.Tab.Trends}"
                         Tag="{x:Static financialoverview:DashboardTab.Trends}">
                    <trends:TrendsView DataContext="{Binding Portfolio.History}" />
                </TabItem>
                <!--  報酬日曆：Stage 4 — bind 到 PortfolioHistory 子 VM  -->
                <TabItem Header="{DynamicResource Dashboard.Tab.Calendar}"
                         Tag="{x:Static financialoverview:DashboardTab.Calendar}">
                    <cal:ReturnCalendarView DataContext="{Binding Portfolio.History.ReturnCalendar}" />
                </TabItem>
                <!--  配置：從 Portfolio 內 tab 搬入  -->
                <TabItem Header="{DynamicResource Dashboard.Tab.Allocation}"
                         Tag="{x:Static financialoverview:DashboardTab.Allocation}">
                    <pcontrols:AllocationView DataContext="{Binding Portfolio.AllocationAnalysis}" />
                </TabItem>
            </TabControl>
        </DataTemplate>

        <DataTemplate x:Key="CategoriesContentTemplate">
            <categories:CategoriesView DataContext="{Binding Categories}" />
        </DataTemplate>

        <DataTemplate x:Key="RecurringContentTemplate">
            <recurring:RecurringView DataContext="{Binding Recurring}" />
        </DataTemplate>

        <DataTemplate x:Key="GoalsContentTemplate">
            <goals:GoalsView DataContext="{Binding Goals}" />
        </DataTemplate>

        <DataTemplate x:Key="PortfolioGroupsContentTemplate">
            <portfoliogroups:PortfolioGroupsView DataContext="{Binding PortfolioGroups}" />
        </DataTemplate>

        <DataTemplate x:Key="TrendsContentTemplate">
            <trends:TrendsView DataContext="{Binding Portfolio.History}" />
        </DataTemplate>

        <DataTemplate x:Key="ReportsContentTemplate">
            <reports:ReportsView DataContext="{Binding Reports}" />
        </DataTemplate>

        <DataTemplate x:Key="AlertsContentTemplate">
            <alerts:AlertsView DataContext="{Binding Alerts}" />
        </DataTemplate>

        <DataTemplate x:Key="AssistantContentTemplate">
            <assistant:AssistantView DataContext="{Binding Assistant}" />
        </DataTemplate>

        <DataTemplate x:Key="AuditLogContentTemplate">
            <auditlog:AuditLogView DataContext="{Binding AuditLog}" />
        </DataTemplate>

        <DataTemplate x:Key="ImportContentTemplate">
            <TabControl
                HorizontalAlignment="Stretch"
                VerticalAlignment="Stretch"
                HorizontalContentAlignment="Stretch"
                VerticalContentAlignment="Stretch"
                Background="Transparent"
                BorderThickness="0">
                <TabControl.ItemContainerStyle>
                    <Style BasedOn="{StaticResource {x:Type TabItem}}" TargetType="{x:Type TabItem}">
                        <Setter Property="HorizontalContentAlignment" Value="Stretch" />
                        <Setter Property="VerticalContentAlignment" Value="Stretch" />
                    </Style>
                </TabControl.ItemContainerStyle>
                <TabItem Header="{DynamicResource Import.Tab.Import}">
                    <import:ImportView DataContext="{Binding Import}" />
                </TabItem>
                <TabItem Header="{DynamicResource Reconciliation.Tab}">
                    <reconciliation:ReconciliationView DataContext="{Binding Reconciliation}" />
                </TabItem>
            </TabControl>
        </DataTemplate>

        <DataTemplate x:Key="RealEstateContentTemplate">
            <realestate:RealEstateView DataContext="{Binding RealEstate}" />
        </DataTemplate>

        <DataTemplate x:Key="InsuranceContentTemplate">
            <insurance:InsurancePolicyView DataContext="{Binding Insurance}" />
        </DataTemplate>

        <DataTemplate x:Key="RetirementContentTemplate">
            <retirement:RetirementView DataContext="{Binding Retirement}" />
        </DataTemplate>

        <DataTemplate x:Key="PhysicalAssetContentTemplate">
            <physicalasset:PhysicalAssetView DataContext="{Binding PhysicalAsset}" />
        </DataTemplate>

        <DataTemplate x:Key="FireContentTemplate">
            <fire:FireView DataContext="{Binding Fire}" />
        </DataTemplate>

        <DataTemplate x:Key="MonteCarloContentTemplate">
            <montecarlo:MonteCarloView DataContext="{Binding MonteCarlo}" />
        </DataTemplate>

        <DataTemplate x:Key="SettingsContentTemplate">
            <settings:SettingsView DataContext="{Binding Settings}" />
        </DataTemplate>

        <!--
            Top-level entries promoted from inside the Portfolio tab strip.
            All three reuse the existing Portfolio sub-panels with PortfolioViewModel as DataContext.
        -->
        <DataTemplate x:Key="TransactionLogContentTemplate">
            <txlog:TransactionLogView DataContext="{Binding Portfolio}" />
        </DataTemplate>

        <DataTemplate x:Key="CashAccountsContentTemplate">
            <cashaccts:CashAccountsView DataContext="{Binding Portfolio}" />
        </DataTemplate>

        <DataTemplate x:Key="LiabilitiesContentTemplate">
            <liabs:LiabilitiesView DataContext="{Binding Portfolio}" />
        </DataTemplate>
    </UserControl.Resources>

    <Grid Background="{DynamicResource AppBackground}">
        <Grid.ColumnDefinitions>
            <ColumnDefinition Width="Auto" />
            <ColumnDefinition Width="*" />
        </Grid.ColumnDefinitions>

        <!--
            P2.16 — Background 從 AppSurface (#FFFFFF) 改 AppNavRailBackground (#FBFCFD)，
            建立 app bg #F5F7FA → NavRail #FBFCFD → 內容 cards #FFFFFF 的三層 hierarchy，
            audit「精準對比」原則：層級各有色階位置不是全部都灰白堆疊。
        -->
        <Border
            x:Name="NavPane"
            Grid.Column="0"
            Background="{DynamicResource AppNavRailBackground}"
            BorderBrush="{DynamicResource AppBorderLight}"
            BorderThickness="0,0,1,0">
            <Border.Style>
                <Style TargetType="{x:Type Border}">
                    <Setter Property="Width" Value="{StaticResource Size.Sidebar.Width}" />
                    <Style.Triggers>
                        <!--
                            NavRail collapse/expand uses Motion.Fast (120ms) and
                            Motion.Easing.Standard per the Fluent + Carbon plan.
                            Storyboards run with FillBehavior=HoldEnd so the
                            animated Width persists after the transition ends.
                        -->
                        <DataTrigger Binding="{Binding ElementName=PaneToggle, Path=IsChecked}" Value="False">
                            <DataTrigger.EnterActions>
                                <BeginStoryboard>
                                    <Storyboard>
                                        <DoubleAnimation
                                            EasingFunction="{StaticResource Motion.Easing.Standard}"
                                            FillBehavior="HoldEnd"
                                            Storyboard.TargetProperty="Width"
                                            To="56"
                                            Duration="0:0:0.12" />
                                    </Storyboard>
                                </BeginStoryboard>
                            </DataTrigger.EnterActions>
                            <DataTrigger.ExitActions>
                                <BeginStoryboard>
                                    <Storyboard>
                                        <DoubleAnimation
                                            EasingFunction="{StaticResource Motion.Easing.Standard}"
                                            FillBehavior="HoldEnd"
                                            Storyboard.TargetProperty="Width"
                                            To="{StaticResource Size.Sidebar.Width}"
                                            Duration="0:0:0.12" />
                                    </Storyboard>
                                </BeginStoryboard>
                            </DataTrigger.ExitActions>
                        </DataTrigger>
                    </Style.Triggers>
                </Style>
            </Border.Style>

            <Grid>
                <Grid.RowDefinitions>
                    <RowDefinition Height="Auto" />
                    <RowDefinition Height="*" />
                    <RowDefinition Height="Auto" />
                </Grid.RowDefinitions>

                <!--
                    Hamburger toggle. Expanded state：17px left padding 對齊下方
                    nav item 的 icon 位置。Collapsed state：rail 變窄，固定 padding 把
                    icon 推到偏左不置中 — 改用 Style.Triggers 在 IsChecked=False 時
                    Padding=0 + HorizontalContentAlignment=Center 把 icon 居中。
                -->
                <ToggleButton
                    x:Name="PaneToggle"
                    Grid.Row="0"
                    Height="40"
                    Margin="0,8,0,8"
                    HorizontalAlignment="Stretch"
                    Background="Transparent"
                    BorderThickness="0"
                    Cursor="Hand"
                    IsChecked="True"
                    ToolTip="{DynamicResource Nav.Toggle}">
                    <ToggleButton.Style>
                        <Style TargetType="ToggleButton">
                            <Setter Property="Padding" Value="17,0,0,0" />
                            <Setter Property="HorizontalContentAlignment" Value="Left" />
                            <Style.Triggers>
                                <Trigger Property="IsChecked" Value="False">
                                    <Setter Property="Padding" Value="0" />
                                    <Setter Property="HorizontalContentAlignment" Value="Center" />
                                </Trigger>
                            </Style.Triggers>
                        </Style>
                    </ToggleButton.Style>
                    <ToggleButton.Template>
                        <ControlTemplate TargetType="{x:Type ToggleButton}">
                            <Border
                                x:Name="Chrome"
                                Padding="{TemplateBinding Padding}"
                                Background="Transparent"
                                SnapsToDevicePixels="True">
                                <ContentPresenter HorizontalAlignment="{TemplateBinding HorizontalContentAlignment}" VerticalAlignment="Center" />
                            </Border>
                            <ControlTemplate.Triggers>
                                <Trigger Property="IsMouseOver" Value="True">
                                    <Setter TargetName="Chrome" Property="Background" Value="{DynamicResource AppHover}" />
                                </Trigger>
                            </ControlTemplate.Triggers>
                        </ControlTemplate>
                    </ToggleButton.Template>
                    <!--
                        AppIcon HorizontalAlignment=Left 維持原值 — 收合時的居中由
                        外層 ToggleButton 的 HorizontalContentAlignment trigger 帶動
                        ContentPresenter 對齊，AppIcon 在 ContentPresenter 內貼左
                        但因 ContentPresenter 自己被 center，整體視覺仍然居中。
                        (上一版用 AppIcon.Style 覆寫導致預設 implicit style 沒繼承，
                        icon glyph render 不出來。)
                    -->
                    <ds:AppIcon
                        HorizontalAlignment="Left"
                        VerticalAlignment="Center"
                        FontSize="{StaticResource Font.Size.Md}"
                        Foreground="{DynamicResource AppTextMuted}"
                        Symbol="Navigation24" />
                </ToggleButton>

                <!--
                    Middle scroll region — switches between expanded and
                    collapsed renderings via PaneToggle.IsChecked. Both
                    bind to the same NavRail.Groups source.
                -->
                <ScrollViewer
                    Grid.Row="1"
                    HorizontalScrollBarVisibility="Disabled"
                    VerticalScrollBarVisibility="Auto">
                    <Grid>
                        <!--  Expanded mode  -->
                        <ItemsControl
                            ItemTemplate="{StaticResource NavGroupExpandedTemplate}"
                            ItemsSource="{Binding NavRail.Groups}"
                            Visibility="{Binding ElementName=PaneToggle, Path=IsChecked, Converter={StaticResource BooleanToVisibilityConverter}}" />

                        <!--  Collapsed mode (4 group icons, no scroll)  -->
                        <ItemsControl
                            ItemTemplate="{StaticResource NavGroupCollapsedTemplate}"
                            ItemsSource="{Binding NavRail.Groups}"
                            Visibility="{Binding ElementName=PaneToggle, Path=IsChecked, Converter={StaticResource InverseBooleanToVisibilityConverter}}" />
                    </Grid>
                </ScrollViewer>

                <!--  Bottom items (Import / Settings).  -->
                <StackPanel Grid.Row="2" Margin="0,8,0,8">
                    <Border
                        Height="1"
                        Margin="0,0,0,8"
                        Background="{DynamicResource AppBorderLight}" />
                    <ItemsControl ItemTemplate="{StaticResource NavBottomLeafTemplate}" ItemsSource="{Binding NavRail.BottomItems}" />
                </StackPanel>
            </Grid>
        </Border>

        <ContentControl
            Grid.Column="1"
            HorizontalAlignment="Stretch"
            VerticalAlignment="Stretch"
            HorizontalContentAlignment="Stretch"
            VerticalContentAlignment="Stretch"
            Content="{Binding}">
            <ContentControl.Style>
                <Style TargetType="{x:Type ContentControl}">
                    <Setter Property="ContentTemplate" Value="{StaticResource PortfolioContentTemplate}" />
                    <Style.Triggers>
                        <DataTrigger Binding="{Binding NavRail.ActiveSection}" Value="{x:Static shell:NavSection.Portfolio}">
                            <Setter Property="ContentTemplate" Value="{StaticResource PortfolioContentTemplate}" />
                        </DataTrigger>
                        <DataTrigger Binding="{Binding NavRail.ActiveSection}" Value="{x:Static shell:NavSection.FinancialOverview}">
                            <Setter Property="ContentTemplate" Value="{StaticResource FinancialOverviewContentTemplate}" />
                        </DataTrigger>
                        <DataTrigger Binding="{Binding NavRail.ActiveSection}" Value="{x:Static shell:NavSection.Categories}">
                            <Setter Property="ContentTemplate" Value="{StaticResource CategoriesContentTemplate}" />
                        </DataTrigger>
                        <DataTrigger Binding="{Binding NavRail.ActiveSection}" Value="{x:Static shell:NavSection.Recurring}">
                            <Setter Property="ContentTemplate" Value="{StaticResource RecurringContentTemplate}" />
                        </DataTrigger>
                        <DataTrigger Binding="{Binding NavRail.ActiveSection}" Value="{x:Static shell:NavSection.Goals}">
                            <Setter Property="ContentTemplate" Value="{StaticResource GoalsContentTemplate}" />
                        </DataTrigger>
                        <DataTrigger Binding="{Binding NavRail.ActiveSection}" Value="{x:Static shell:NavSection.PortfolioGroups}">
                            <Setter Property="ContentTemplate" Value="{StaticResource PortfolioGroupsContentTemplate}" />
                        </DataTrigger>
                        <DataTrigger Binding="{Binding NavRail.ActiveSection}" Value="{x:Static shell:NavSection.Trends}">
                            <Setter Property="ContentTemplate" Value="{StaticResource TrendsContentTemplate}" />
                        </DataTrigger>
                        <DataTrigger Binding="{Binding NavRail.ActiveSection}" Value="{x:Static shell:NavSection.Reports}">
                            <Setter Property="ContentTemplate" Value="{StaticResource ReportsContentTemplate}" />
                        </DataTrigger>
                        <DataTrigger Binding="{Binding NavRail.ActiveSection}" Value="{x:Static shell:NavSection.Assistant}">
                            <Setter Property="ContentTemplate" Value="{StaticResource AssistantContentTemplate}" />
                        </DataTrigger>
                        <DataTrigger Binding="{Binding NavRail.ActiveSection}" Value="{x:Static shell:NavSection.AuditLog}">
                            <Setter Property="ContentTemplate" Value="{StaticResource AuditLogContentTemplate}" />
                        </DataTrigger>
                        <DataTrigger Binding="{Binding NavRail.ActiveSection}" Value="{x:Static shell:NavSection.Alerts}">
                            <Setter Property="ContentTemplate" Value="{StaticResource AlertsContentTemplate}" />
                        </DataTrigger>
                        <DataTrigger Binding="{Binding NavRail.ActiveSection}" Value="{x:Static shell:NavSection.Import}">
                            <Setter Property="ContentTemplate" Value="{StaticResource ImportContentTemplate}" />
                        </DataTrigger>
                        <DataTrigger Binding="{Binding NavRail.ActiveSection}" Value="{x:Static shell:NavSection.RealEstate}">
                            <Setter Property="ContentTemplate" Value="{StaticResource RealEstateContentTemplate}" />
                        </DataTrigger>
                        <DataTrigger Binding="{Binding NavRail.ActiveSection}" Value="{x:Static shell:NavSection.Insurance}">
                            <Setter Property="ContentTemplate" Value="{StaticResource InsuranceContentTemplate}" />
                        </DataTrigger>
                        <DataTrigger Binding="{Binding NavRail.ActiveSection}" Value="{x:Static shell:NavSection.Retirement}">
                            <Setter Property="ContentTemplate" Value="{StaticResource RetirementContentTemplate}" />
                        </DataTrigger>
                        <DataTrigger Binding="{Binding NavRail.ActiveSection}" Value="{x:Static shell:NavSection.PhysicalAsset}">
                            <Setter Property="ContentTemplate" Value="{StaticResource PhysicalAssetContentTemplate}" />
                        </DataTrigger>
                        <DataTrigger Binding="{Binding NavRail.ActiveSection}" Value="{x:Static shell:NavSection.Fire}">
                            <Setter Property="ContentTemplate" Value="{StaticResource FireContentTemplate}" />
                        </DataTrigger>
                        <DataTrigger Binding="{Binding NavRail.ActiveSection}" Value="{x:Static shell:NavSection.MonteCarlo}">
                            <Setter Property="ContentTemplate" Value="{StaticResource MonteCarloContentTemplate}" />
                        </DataTrigger>
                        <DataTrigger Binding="{Binding NavRail.ActiveSection}" Value="{x:Static shell:NavSection.Settings}">
                            <Setter Property="ContentTemplate" Value="{StaticResource SettingsContentTemplate}" />
                        </DataTrigger>
                        <DataTrigger Binding="{Binding NavRail.ActiveSection}" Value="{x:Static shell:NavSection.TransactionLog}">
                            <Setter Property="ContentTemplate" Value="{StaticResource TransactionLogContentTemplate}" />
                        </DataTrigger>
                        <DataTrigger Binding="{Binding NavRail.ActiveSection}" Value="{x:Static shell:NavSection.CashAccounts}">
                            <Setter Property="ContentTemplate" Value="{StaticResource CashAccountsContentTemplate}" />
                        </DataTrigger>
                        <DataTrigger Binding="{Binding NavRail.ActiveSection}" Value="{x:Static shell:NavSection.Liabilities}">
                            <Setter Property="ContentTemplate" Value="{StaticResource LiabilitiesContentTemplate}" />
                        </DataTrigger>
                    </Style.Triggers>
                </Style>
            </ContentControl.Style>
        </ContentControl>
    </Grid>
</UserControl>
