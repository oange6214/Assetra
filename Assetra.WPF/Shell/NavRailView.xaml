<UserControl
    x:Class="Assetra.WPF.Shell.NavRailView"
    xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
    xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
    xmlns:ui="http://schemas.lepo.co/wpfui/2022/xaml"
    xmlns:conv="clr-namespace:Assetra.WPF.Infrastructure.Converters"
    xmlns:d="http://schemas.microsoft.com/expression/blend/2008"
    xmlns:mc="http://schemas.openxmlformats.org/markup-compatibility/2006"
    xmlns:vm="clr-namespace:Assetra.WPF.Shell"
    d:DataContext="{d:DesignInstance Type={x:Type vm:MainViewModel},
                                     IsDesignTimeCreatable=False}"
    mc:Ignorable="d">

    <!--
        NavRailView — collapsible rail (56px ↔ 220px) with hamburger toggle.
        Top: hamburger + 6 navigation entries grouped by purpose.
        Bottom (pinned): Import + Settings.
        Labels appear inline when expanded; tooltips suppressed when expanded.
    -->
    <Border
        x:Name="NavRailBorder"
        Background="{DynamicResource AppSurface}"
        BorderBrush="{DynamicResource AppBorder}"
        BorderThickness="0,0,1,0">
        <Border.Style>
            <Style TargetType="Border">
                <Setter Property="Width" Value="56" />
                <Style.Triggers>
                    <DataTrigger Binding="{Binding NavRail.IsExpanded}" Value="True">
                        <Setter Property="Width" Value="220" />
                    </DataTrigger>
                </Style.Triggers>
            </Style>
        </Border.Style>

        <DockPanel ClipToBounds="True" LastChildFill="True">

            <!--  ── Hamburger toggle (top) ──  -->
            <Button
                Width="56"
                Height="48"
                Margin="0,4,0,4"
                HorizontalAlignment="Left"
                Background="Transparent"
                BorderThickness="0"
                Command="{Binding NavRail.ToggleExpandCommand}"
                Cursor="Hand"
                DockPanel.Dock="Top"
                ToolTipService.InitialShowDelay="0"
                ToolTipService.Placement="Right">
                <Button.ToolTip>
                    <ToolTip Content="{DynamicResource Nav.Toggle}" Style="{DynamicResource NavRailToolTip}" />
                </Button.ToolTip>
                <ui:SymbolIcon Symbol="LineHorizontal320" HorizontalAlignment="Center" VerticalAlignment="Center" FontSize="{StaticResource FontSizeMd}" Foreground="{DynamicResource AppTextSecondary}" />
            </Button>

            <!--  ── Pinned bottom: Import + Settings ──  -->
            <StackPanel DockPanel.Dock="Bottom" Margin="0,8,0,8">
                <Border
                    Height="1"
                    Margin="8,0,8,8"
                    Background="{DynamicResource AppBorderLight}" />

                <RadioButton
                    Content="{DynamicResource Nav.Import}"
                    GroupName="NavSections"
                    IsChecked="{Binding NavRail.SelectedRailSection, Converter={StaticResource EnumToBoolConverter}, ConverterParameter=Import}"
                    Style="{StaticResource NavRailBtn}"
                    Tag="{x:Static ui:SymbolRegular.DocumentArrowDown24}">
                    <RadioButton.ToolTip>
                        <ToolTip Content="{DynamicResource Nav.Import}" Style="{DynamicResource NavRailToolTip}" />
                    </RadioButton.ToolTip>
                </RadioButton>

                <RadioButton
                    Content="{DynamicResource Nav.Settings}"
                    GroupName="NavSections"
                    IsChecked="{Binding NavRail.SelectedRailSection, Converter={StaticResource EnumToBoolConverter}, ConverterParameter=Settings}"
                    Style="{StaticResource NavRailBtn}"
                    Tag="{x:Static ui:SymbolRegular.Settings24}">
                    <RadioButton.ToolTip>
                        <ToolTip Content="{DynamicResource Nav.Settings}" Style="{DynamicResource NavRailToolTip}" />
                    </RadioButton.ToolTip>
                </RadioButton>
            </StackPanel>

            <!--  ── Scrollable section groups ──  -->
            <ScrollViewer
                HorizontalScrollBarVisibility="Disabled"
                VerticalScrollBarVisibility="Auto">
            <StackPanel>
                <!--  Group 1: 核心 — Portfolio + FinancialOverview  -->
                <RadioButton
                    Content="{DynamicResource Nav.Portfolio}"
                    GroupName="NavSections"
                    IsChecked="{Binding NavRail.SelectedRailSection, Converter={StaticResource EnumToBoolConverter}, ConverterParameter=Portfolio}"
                    Style="{StaticResource NavRailBtn}"
                    Tag="{x:Static ui:SymbolRegular.Briefcase24}">
                    <RadioButton.ToolTip>
                        <ToolTip Content="{DynamicResource Nav.Portfolio}" Style="{DynamicResource NavRailToolTip}" />
                    </RadioButton.ToolTip>
                </RadioButton>

                <RadioButton
                    Content="{DynamicResource FinancialOverview.Nav.Label}"
                    GroupName="NavSections"
                    IsChecked="{Binding NavRail.SelectedRailSection, Converter={StaticResource EnumToBoolConverter}, ConverterParameter=FinancialOverview}"
                    Style="{StaticResource NavRailBtn}"
                    Tag="{x:Static ui:SymbolRegular.DataPie24}">
                    <RadioButton.ToolTip>
                        <ToolTip Content="{DynamicResource FinancialOverview.Nav.Label}" Style="{DynamicResource NavRailToolTip}" />
                    </RadioButton.ToolTip>
                </RadioButton>

                <!--  Group 2: 收支 (Hub: Categories + Recurring) with pending badge  -->
                <Grid Margin="0,12,0,0">
                    <RadioButton
                        Content="{DynamicResource Nav.Cashflow}"
                        GroupName="NavSections"
                        IsChecked="{Binding NavRail.SelectedRailSection, Converter={StaticResource EnumToBoolConverter}, ConverterParameter=Cashflow}"
                        Style="{StaticResource NavRailBtn}"
                        Tag="{x:Static ui:SymbolRegular.Wallet24}">
                        <RadioButton.ToolTip>
                            <ToolTip Content="{DynamicResource Nav.Cashflow}" Style="{DynamicResource NavRailToolTip}" />
                        </RadioButton.ToolTip>
                    </RadioButton>
                    <Border
                        Width="18"
                        Height="18"
                        Margin="0,4,18,0"
                        HorizontalAlignment="Left"
                        VerticalAlignment="Top"
                        Background="{DynamicResource AppAccent}"
                        CornerRadius="8"
                        IsHitTestVisible="False"
                        Visibility="{Binding Recurring.HasPending, Converter={StaticResource BooleanToVisibilityConverter}}">
                        <Border.RenderTransform>
                            <TranslateTransform X="34" />
                        </Border.RenderTransform>
                        <TextBlock
                            HorizontalAlignment="Center"
                            VerticalAlignment="Center"
                            FontFamily="{StaticResource FontBase}" Typography.NumeralAlignment="Tabular"
                            FontSize="{StaticResource FontSizeXs}"
                            FontWeight="Bold"
                            Foreground="{DynamicResource AppTextOnAccent}"
                            Text="{Binding Recurring.PendingBadge}" />
                    </Border>
                </Grid>

                <!--  Group 3: 分析報表 (Hub: Goals + Trends + Reports + FIRE + MonteCarlo)  -->
                <RadioButton
                    Content="{DynamicResource Nav.Insights}"
                    GroupName="NavSections"
                    IsChecked="{Binding NavRail.SelectedRailSection, Converter={StaticResource EnumToBoolConverter}, ConverterParameter=Insights}"
                    Style="{StaticResource NavRailBtn}"
                    Tag="{x:Static ui:SymbolRegular.Pulse24}">
                    <RadioButton.ToolTip>
                        <ToolTip Content="{DynamicResource Nav.Insights}" Style="{DynamicResource NavRailToolTip}" />
                    </RadioButton.ToolTip>
                </RadioButton>

                <!--  Group 4: 多元資產 (Hub: RealEstate + Insurance + Retirement + PhysicalAsset)  -->
                <RadioButton
                    Margin="0,12,0,0"
                    Content="{DynamicResource Nav.MultiAsset}"
                    GroupName="NavSections"
                    IsChecked="{Binding NavRail.SelectedRailSection, Converter={StaticResource EnumToBoolConverter}, ConverterParameter=MultiAsset}"
                    Style="{StaticResource NavRailBtn}"
                    Tag="{x:Static ui:SymbolRegular.Home24}">
                    <RadioButton.ToolTip>
                        <ToolTip Content="{DynamicResource Nav.MultiAsset}" Style="{DynamicResource NavRailToolTip}" />
                    </RadioButton.ToolTip>
                </RadioButton>

                <!--  Group 5: 警示  -->
                <Grid Margin="0,12,0,0">
                    <RadioButton
                        Content="{DynamicResource Nav.Alerts}"
                        GroupName="NavSections"
                        IsChecked="{Binding NavRail.SelectedRailSection, Converter={StaticResource EnumToBoolConverter}, ConverterParameter=Alerts}"
                        Style="{StaticResource NavRailBtn}"
                        Tag="{x:Static ui:SymbolRegular.Alert24}">
                        <RadioButton.ToolTip>
                            <ToolTip Content="{DynamicResource Nav.Alerts.Tooltip}" Style="{DynamicResource NavRailToolTip}" />
                        </RadioButton.ToolTip>
                    </RadioButton>
                    <Border
                        Width="18"
                        Height="18"
                        Margin="0,4,18,0"
                        HorizontalAlignment="Left"
                        VerticalAlignment="Top"
                        Background="{DynamicResource AppDown}"
                        CornerRadius="8"
                        IsHitTestVisible="False"
                        Visibility="{Binding Alerts.HasTriggeredAlerts, Converter={StaticResource BooleanToVisibilityConverter}}">
                        <Border.RenderTransform>
                            <TranslateTransform X="34" />
                        </Border.RenderTransform>
                        <TextBlock
                            HorizontalAlignment="Center"
                            VerticalAlignment="Center"
                            FontFamily="{StaticResource FontBase}" Typography.NumeralAlignment="Tabular"
                            FontSize="{StaticResource FontSizeXs}"
                            FontWeight="Bold"
                            Foreground="{DynamicResource AppTextOnAccent}"
                            Text="{Binding Alerts.TriggeredBadge}" />
                    </Border>
                </Grid>

            </StackPanel>
            </ScrollViewer>

        </DockPanel>
    </Border>
</UserControl>
