<UserControl
    x:Class="Assetra.WPF.Shell.NavRailView"
    xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
    xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
    xmlns:conv="clr-namespace:Assetra.WPF.Infrastructure.Converters"
    xmlns:d="http://schemas.microsoft.com/expression/blend/2008"
    xmlns:mc="http://schemas.openxmlformats.org/markup-compatibility/2006"
    xmlns:vm="clr-namespace:Assetra.WPF.Shell"
    d:DataContext="{d:DesignInstance Type={x:Type vm:MainViewModel},
                                     IsDesignTimeCreatable=False}"
    mc:Ignorable="d">

    <!--
        NavRailView — icon-only navigation rail.
        DataContext = MainViewModel (set by MainWindow).
    -->
    <Border
        x:Name="NavRailBorder"
        Width="56"
        Background="{DynamicResource AppSurface}"
        BorderBrush="{DynamicResource AppBorder}"
        BorderThickness="0,0,1,0">
        <DockPanel ClipToBounds="True">

            <!--  ── Top spacer ──  -->
            <Border Height="6" DockPanel.Dock="Top" />

            <!--  ── Main section buttons ──  -->
            <ScrollViewer
                HorizontalScrollBarVisibility="Disabled"
                VerticalScrollBarVisibility="Auto">
            <StackPanel>
                <!--  Portfolio  -->
                <RadioButton
                    Content="{DynamicResource Nav.Portfolio}"
                    GroupName="NavSections"
                    IsChecked="{Binding NavRail.ActiveSection, Converter={StaticResource EnumToBoolConverter}, ConverterParameter=Portfolio}"
                    Style="{StaticResource NavRailBtn}"
                    Tag="&#xE8D7;">
                    <RadioButton.ToolTip>
                        <ToolTip Content="{DynamicResource Nav.Portfolio}" Style="{DynamicResource NavRailToolTip}" />
                    </RadioButton.ToolTip>
                </RadioButton>

                <!--  FinancialOverview (Allocation Treemap + 再平衡 + 財務總覽)  -->
                <RadioButton
                    Content="{DynamicResource FinancialOverview.Nav.Label}"
                    GroupName="NavSections"
                    IsChecked="{Binding NavRail.ActiveSection, Converter={StaticResource EnumToBoolConverter}, ConverterParameter=FinancialOverview}"
                    Style="{StaticResource NavRailBtn}"
                    Tag="&#xE81E;">
                    <RadioButton.ToolTip>
                        <ToolTip Content="{DynamicResource FinancialOverview.Nav.Label}" Style="{DynamicResource NavRailToolTip}" />
                    </RadioButton.ToolTip>
                </RadioButton>

                <!--  Categories (收支分類)  -->
                <RadioButton
                    Content="{DynamicResource Nav.Categories}"
                    GroupName="NavSections"
                    IsChecked="{Binding NavRail.ActiveSection, Converter={StaticResource EnumToBoolConverter}, ConverterParameter=Categories}"
                    Style="{StaticResource NavRailBtn}"
                    Tag="&#xE8FD;">
                    <RadioButton.ToolTip>
                        <ToolTip Content="{DynamicResource Nav.Categories}" Style="{DynamicResource NavRailToolTip}" />
                    </RadioButton.ToolTip>
                </RadioButton>

                <!--  Recurring (訂閱與待確認) with pending count badge  -->
                <Grid>
                    <RadioButton
                        Content="{DynamicResource Nav.Recurring}"
                        GroupName="NavSections"
                        IsChecked="{Binding NavRail.ActiveSection, Converter={StaticResource EnumToBoolConverter}, ConverterParameter=Recurring}"
                        Style="{StaticResource NavRailBtn}"
                        Tag="&#xE823;">
                        <RadioButton.ToolTip>
                            <ToolTip Content="{DynamicResource Nav.Recurring}" Style="{DynamicResource NavRailToolTip}" />
                        </RadioButton.ToolTip>
                    </RadioButton>
                    <Border
                        Width="18"
                        Height="18"
                        Margin="18,4,0,0"
                        HorizontalAlignment="Center"
                        VerticalAlignment="Top"
                        Background="{DynamicResource AppAccent}"
                        CornerRadius="8"
                        IsHitTestVisible="False"
                        Visibility="{Binding Recurring.HasPending, Converter={StaticResource BooleanToVisibilityConverter}}">
                        <TextBlock
                            HorizontalAlignment="Center"
                            VerticalAlignment="Center"
                            FontFamily="{StaticResource FontTabular}"
                            FontSize="{StaticResource FontSizeXs}"
                            FontWeight="Bold"
                            Foreground="{DynamicResource AppTextOnAccent}"
                            Text="{Binding Recurring.PendingBadge}" />
                    </Border>
                </Grid>

                <!--  Goals (財務目標)  -->
                <RadioButton
                    Content="{DynamicResource Nav.Goals}"
                    GroupName="NavSections"
                    IsChecked="{Binding NavRail.ActiveSection, Converter={StaticResource EnumToBoolConverter}, ConverterParameter=Goals}"
                    Style="{StaticResource NavRailBtn}"
                    Tag="&#xE945;">
                    <RadioButton.ToolTip>
                        <ToolTip Content="{DynamicResource Nav.Goals}" Style="{DynamicResource NavRailToolTip}" />
                    </RadioButton.ToolTip>
                </RadioButton>

                <!--  Trends (淨資產趨勢)  -->
                <RadioButton
                    Content="{DynamicResource Nav.Trends}"
                    GroupName="NavSections"
                    IsChecked="{Binding NavRail.ActiveSection, Converter={StaticResource EnumToBoolConverter}, ConverterParameter=Trends}"
                    Style="{StaticResource NavRailBtn}"
                    Tag="&#xE9D9;">
                    <RadioButton.ToolTip>
                        <ToolTip Content="{DynamicResource Nav.Trends}" Style="{DynamicResource NavRailToolTip}" />
                    </RadioButton.ToolTip>
                </RadioButton>

                <!--  Reports (月結報告)  -->
                <RadioButton
                    Content="{DynamicResource Nav.Reports}"
                    GroupName="NavSections"
                    IsChecked="{Binding NavRail.ActiveSection, Converter={StaticResource EnumToBoolConverter}, ConverterParameter=Reports}"
                    Style="{StaticResource NavRailBtn}"
                    Tag="&#xE9F9;">
                    <RadioButton.ToolTip>
                        <ToolTip Content="{DynamicResource Nav.Reports}" Style="{DynamicResource NavRailToolTip}" />
                    </RadioButton.ToolTip>
                </RadioButton>

                <!--  Import (匯入)  -->
                <RadioButton
                    Content="{DynamicResource Nav.Import}"
                    GroupName="NavSections"
                    IsChecked="{Binding NavRail.ActiveSection, Converter={StaticResource EnumToBoolConverter}, ConverterParameter=Import}"
                    Style="{StaticResource NavRailBtn}"
                    Tag="&#xE8B5;">
                    <RadioButton.ToolTip>
                        <ToolTip Content="{DynamicResource Nav.Import}" Style="{DynamicResource NavRailToolTip}" />
                    </RadioButton.ToolTip>
                </RadioButton>

                <!--  Real estate  -->
                <RadioButton
                    Content="{DynamicResource RealEstate.Title}"
                    GroupName="NavSections"
                    IsChecked="{Binding NavRail.ActiveSection, Converter={StaticResource EnumToBoolConverter}, ConverterParameter=RealEstate}"
                    Style="{StaticResource NavRailBtn}"
                    Tag="&#xE80F;">
                    <RadioButton.ToolTip>
                        <ToolTip Content="{DynamicResource RealEstate.Title}" Style="{DynamicResource NavRailToolTip}" />
                    </RadioButton.ToolTip>
                </RadioButton>

                <!--  Insurance  -->
                <RadioButton
                    Content="{DynamicResource Insurance.Title}"
                    GroupName="NavSections"
                    IsChecked="{Binding NavRail.ActiveSection, Converter={StaticResource EnumToBoolConverter}, ConverterParameter=Insurance}"
                    Style="{StaticResource NavRailBtn}"
                    Tag="&#xE8BA;">
                    <RadioButton.ToolTip>
                        <ToolTip Content="{DynamicResource Insurance.Title}" Style="{DynamicResource NavRailToolTip}" />
                    </RadioButton.ToolTip>
                </RadioButton>

                <!--  Retirement  -->
                <RadioButton
                    Content="{DynamicResource Retirement.Title}"
                    GroupName="NavSections"
                    IsChecked="{Binding NavRail.ActiveSection, Converter={StaticResource EnumToBoolConverter}, ConverterParameter=Retirement}"
                    Style="{StaticResource NavRailBtn}"
                    Tag="&#xE825;">
                    <RadioButton.ToolTip>
                        <ToolTip Content="{DynamicResource Retirement.Title}" Style="{DynamicResource NavRailToolTip}" />
                    </RadioButton.ToolTip>
                </RadioButton>

                <!--  Physical assets  -->
                <RadioButton
                    Content="{DynamicResource PhysicalAsset.Title}"
                    GroupName="NavSections"
                    IsChecked="{Binding NavRail.ActiveSection, Converter={StaticResource EnumToBoolConverter}, ConverterParameter=PhysicalAsset}"
                    Style="{StaticResource NavRailBtn}"
                    Tag="&#xE8B7;">
                    <RadioButton.ToolTip>
                        <ToolTip Content="{DynamicResource PhysicalAsset.Title}" Style="{DynamicResource NavRailToolTip}" />
                    </RadioButton.ToolTip>
                </RadioButton>

                <!--  FIRE calculator  -->
                <RadioButton
                    Content="{DynamicResource Fire.Title}"
                    GroupName="NavSections"
                    IsChecked="{Binding NavRail.ActiveSection, Converter={StaticResource EnumToBoolConverter}, ConverterParameter=Fire}"
                    Style="{StaticResource NavRailBtn}"
                    Tag="&#xE7C1;">
                    <RadioButton.ToolTip>
                        <ToolTip Content="{DynamicResource Fire.Title}" Style="{DynamicResource NavRailToolTip}" />
                    </RadioButton.ToolTip>
                </RadioButton>

                <!--  Monte Carlo simulation  -->
                <RadioButton
                    Content="{DynamicResource MonteCarlo.Title}"
                    GroupName="NavSections"
                    IsChecked="{Binding NavRail.ActiveSection, Converter={StaticResource EnumToBoolConverter}, ConverterParameter=MonteCarlo}"
                    Style="{StaticResource NavRailBtn}"
                    Tag="&#xE9D2;">
                    <RadioButton.ToolTip>
                        <ToolTip Content="{DynamicResource MonteCarlo.Title}" Style="{DynamicResource NavRailToolTip}" />
                    </RadioButton.ToolTip>
                </RadioButton>

                <!--  警示 with triggered-count badge  -->
                <Grid>
                    <RadioButton
                        Content="{DynamicResource Nav.Alerts}"
                        GroupName="NavSections"
                        IsChecked="{Binding NavRail.ActiveSection, Converter={StaticResource EnumToBoolConverter}, ConverterParameter=Alerts}"
                        Style="{StaticResource NavRailBtn}"
                        Tag="&#xEA8F;">
                        <RadioButton.ToolTip>
                            <ToolTip Content="{DynamicResource Nav.Alerts.Tooltip}" Style="{DynamicResource NavRailToolTip}" />
                        </RadioButton.ToolTip>
                    </RadioButton>
                    <Border
                        Width="18"
                        Height="18"
                        Margin="18,4,0,0"
                        HorizontalAlignment="Center"
                        VerticalAlignment="Top"
                        Background="{DynamicResource AppDown}"
                        CornerRadius="8"
                        IsHitTestVisible="False"
                        Visibility="{Binding Alerts.HasTriggeredAlerts, Converter={StaticResource BooleanToVisibilityConverter}}">
                        <TextBlock
                            HorizontalAlignment="Center"
                            VerticalAlignment="Center"
                            FontFamily="{StaticResource FontTabular}"
                            FontSize="{StaticResource FontSizeXs}"
                            FontWeight="Bold"
                            Foreground="{DynamicResource AppTextOnAccent}"
                            Text="{Binding Alerts.TriggeredBadge}" />
                    </Border>
                </Grid>

                <!--  Settings  -->
                <RadioButton
                    Content="{DynamicResource Nav.Settings}"
                    GroupName="NavSections"
                    IsChecked="{Binding NavRail.ActiveSection, Converter={StaticResource EnumToBoolConverter}, ConverterParameter=Settings}"
                    Style="{StaticResource NavRailBtn}"
                    Tag="&#xE713;">
                    <RadioButton.ToolTip>
                        <ToolTip Content="{DynamicResource Nav.Settings}" Style="{DynamicResource NavRailToolTip}" />
                    </RadioButton.ToolTip>
                </RadioButton>

            </StackPanel>
            </ScrollViewer>

        </DockPanel>
    </Border>
</UserControl>
