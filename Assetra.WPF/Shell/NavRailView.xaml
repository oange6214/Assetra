<UserControl
    x:Class="Assetra.WPF.Shell.NavRailView"
    xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
    xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
    xmlns:d="http://schemas.microsoft.com/expression/blend/2008"
    xmlns:mc="http://schemas.openxmlformats.org/markup-compatibility/2006"
    xmlns:shell="clr-namespace:Assetra.WPF.Shell"
    xmlns:ui="http://schemas.lepo.co/wpfui/2022/xaml"
    d:DataContext="{d:DesignInstance Type={x:Type shell:MainViewModel},
                                     IsDesignTimeCreatable=False}"
    mc:Ignorable="d">

    <!--
        ui:NavigationView — Wpf.Ui Fluent navigation with Frame-backed Page navigation.
        Each NavigationViewItem.TargetPageType points at a singleton Page registered
        in DI (see ServiceCollectionExtensions.AddAssetraShell). Wpf.Ui resolves
        instances through SetServiceProvider, wired up in NavRailView.xaml.cs.

        Collapsed (56 px) shows icons only; toggling the hamburger expands to 220 px
        with labels. InfoBadges surface pending recurring entries and triggered alerts.
        ActiveSection ↔ pane selection is bridged in code-behind via SelectionChanged.
    -->
    <ui:NavigationView
        x:Name="RootNavView"
        CompactPaneLength="56"
        IsBackButtonVisible="Collapsed"
        IsPaneOpen="False"
        IsPaneToggleVisible="True"
        OpenPaneLength="220"
        PaneDisplayMode="Left"
        SelectionChanged="RootNavView_SelectionChanged">

        <ui:NavigationView.MenuItems>

            <ui:NavigationViewItem
                x:Name="NavPortfolio"
                Content="{DynamicResource Nav.Portfolio}"
                TargetPageType="{x:Type shell:PortfolioPage}"
                ToolTip="{DynamicResource Nav.Portfolio}">
                <ui:NavigationViewItem.Icon>
                    <ui:SymbolIcon Symbol="Briefcase24" />
                </ui:NavigationViewItem.Icon>
            </ui:NavigationViewItem>

            <ui:NavigationViewItem
                x:Name="NavFinancialOverview"
                Content="{DynamicResource FinancialOverview.Nav.Label}"
                TargetPageType="{x:Type shell:FinancialOverviewPage}"
                ToolTip="{DynamicResource FinancialOverview.Nav.Label}">
                <ui:NavigationViewItem.Icon>
                    <ui:SymbolIcon Symbol="DataPie24" />
                </ui:NavigationViewItem.Icon>
            </ui:NavigationViewItem>

            <ui:NavigationViewItem
                x:Name="NavCashflow"
                Content="{DynamicResource Nav.Cashflow}"
                TargetPageType="{x:Type shell:CashflowHubPage}"
                ToolTip="{DynamicResource Nav.Cashflow}">
                <ui:NavigationViewItem.Icon>
                    <ui:SymbolIcon Symbol="Wallet24" />
                </ui:NavigationViewItem.Icon>
                <ui:NavigationViewItem.InfoBadge>
                    <ui:InfoBadge
                        Severity="Attention"
                        Value="{Binding Recurring.PendingCount}"
                        Visibility="{Binding Recurring.HasPending, Converter={StaticResource BooleanToVisibilityConverter}}" />
                </ui:NavigationViewItem.InfoBadge>
            </ui:NavigationViewItem>

            <ui:NavigationViewItem
                x:Name="NavInsights"
                Content="{DynamicResource Nav.Insights}"
                TargetPageType="{x:Type shell:InsightsHubPage}"
                ToolTip="{DynamicResource Nav.Insights}">
                <ui:NavigationViewItem.Icon>
                    <ui:SymbolIcon Symbol="Pulse24" />
                </ui:NavigationViewItem.Icon>
            </ui:NavigationViewItem>

            <ui:NavigationViewItem
                x:Name="NavMultiAsset"
                Content="{DynamicResource Nav.MultiAsset}"
                TargetPageType="{x:Type shell:MultiAssetHubPage}"
                ToolTip="{DynamicResource Nav.MultiAsset}">
                <ui:NavigationViewItem.Icon>
                    <ui:SymbolIcon Symbol="Home24" />
                </ui:NavigationViewItem.Icon>
            </ui:NavigationViewItem>

            <ui:NavigationViewItem
                x:Name="NavAlerts"
                Content="{DynamicResource Nav.Alerts}"
                TargetPageType="{x:Type shell:AlertsPage}"
                ToolTip="{DynamicResource Nav.Alerts.Tooltip}">
                <ui:NavigationViewItem.Icon>
                    <ui:SymbolIcon Symbol="Alert24" />
                </ui:NavigationViewItem.Icon>
                <ui:NavigationViewItem.InfoBadge>
                    <ui:InfoBadge
                        Severity="Critical"
                        Value="{Binding Alerts.TriggeredCount}"
                        Visibility="{Binding Alerts.HasTriggeredAlerts, Converter={StaticResource BooleanToVisibilityConverter}}" />
                </ui:NavigationViewItem.InfoBadge>
            </ui:NavigationViewItem>

        </ui:NavigationView.MenuItems>

        <ui:NavigationView.FooterMenuItems>

            <ui:NavigationViewItem
                x:Name="NavImport"
                Content="{DynamicResource Nav.Import}"
                TargetPageType="{x:Type shell:ImportPage}"
                ToolTip="{DynamicResource Nav.Import}">
                <ui:NavigationViewItem.Icon>
                    <ui:SymbolIcon Symbol="DocumentArrowDown24" />
                </ui:NavigationViewItem.Icon>
            </ui:NavigationViewItem>

            <ui:NavigationViewItem
                x:Name="NavSettings"
                Content="{DynamicResource Nav.Settings}"
                TargetPageType="{x:Type shell:SettingsPage}"
                ToolTip="{DynamicResource Nav.Settings}">
                <ui:NavigationViewItem.Icon>
                    <ui:SymbolIcon Symbol="Settings24" />
                </ui:NavigationViewItem.Icon>
            </ui:NavigationViewItem>

        </ui:NavigationView.FooterMenuItems>

    </ui:NavigationView>
</UserControl>
