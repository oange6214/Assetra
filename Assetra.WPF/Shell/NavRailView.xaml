<UserControl
    x:Class="Assetra.WPF.Shell.NavRailView"
    xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
    xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
    xmlns:alerts="clr-namespace:Assetra.WPF.Features.Alerts"
    xmlns:categories="clr-namespace:Assetra.WPF.Features.Categories"
    xmlns:d="http://schemas.microsoft.com/expression/blend/2008"
    xmlns:financialoverview="clr-namespace:Assetra.WPF.Features.FinancialOverview"
    xmlns:fire="clr-namespace:Assetra.WPF.Features.Fire"
    xmlns:goals="clr-namespace:Assetra.WPF.Features.Goals"
    xmlns:import="clr-namespace:Assetra.WPF.Features.Import"
    xmlns:insurance="clr-namespace:Assetra.WPF.Features.Insurance"
    xmlns:mc="http://schemas.openxmlformats.org/markup-compatibility/2006"
    xmlns:montecarlo="clr-namespace:Assetra.WPF.Features.MonteCarlo"
    xmlns:physicalasset="clr-namespace:Assetra.WPF.Features.PhysicalAsset"
    xmlns:portfolio="clr-namespace:Assetra.WPF.Features.Portfolio"
    xmlns:realestate="clr-namespace:Assetra.WPF.Features.RealEstate"
    xmlns:reconciliation="clr-namespace:Assetra.WPF.Features.Reconciliation"
    xmlns:recurring="clr-namespace:Assetra.WPF.Features.Recurring"
    xmlns:reports="clr-namespace:Assetra.WPF.Features.Reports"
    xmlns:retirement="clr-namespace:Assetra.WPF.Features.Retirement"
    xmlns:settings="clr-namespace:Assetra.WPF.Features.Settings"
    xmlns:shell="clr-namespace:Assetra.WPF.Shell"
    xmlns:trends="clr-namespace:Assetra.WPF.Features.Trends"
    xmlns:txlog="clr-namespace:Assetra.WPF.Features.TransactionLog"
    xmlns:cashaccts="clr-namespace:Assetra.WPF.Features.CashAccounts"
    xmlns:liabs="clr-namespace:Assetra.WPF.Features.Liabilities"
    xmlns:ds="clr-namespace:Assetra.WPF.DesignSystem.Controls"
    d:DataContext="{d:DesignInstance Type={x:Type shell:MainViewModel},
                                     IsDesignTimeCreatable=False}"
    mc:Ignorable="d">

    <UserControl.Resources>

        <Style x:Key="NavRailItemButton" TargetType="{x:Type ToggleButton}">
            <Setter Property="Height" Value="40" />
            <Setter Property="Margin" Value="3,1" />
            <Setter Property="Padding" Value="0" />
            <Setter Property="Background" Value="Transparent" />
            <Setter Property="BorderBrush" Value="Transparent" />
            <Setter Property="BorderThickness" Value="0" />
            <Setter Property="Cursor" Value="Hand" />
            <Setter Property="Focusable" Value="True" />
            <Setter Property="HorizontalContentAlignment" Value="Stretch" />
            <Setter Property="VerticalContentAlignment" Value="Center" />
            <Setter Property="Template">
                <Setter.Value>
                    <ControlTemplate TargetType="{x:Type ToggleButton}">
                        <Border
                            x:Name="Chrome"
                            Background="{TemplateBinding Background}"
                            CornerRadius="{StaticResource Radius.Sm}">
                            <Grid>
                                <Grid.ColumnDefinitions>
                                    <ColumnDefinition Width="4" />
                                    <ColumnDefinition Width="*" />
                                </Grid.ColumnDefinitions>
                                <Border
                                    x:Name="Indicator"
                                    Grid.Column="0"
                                    Width="3"
                                    Height="18"
                                    HorizontalAlignment="Left"
                                    VerticalAlignment="Center"
                                    Background="{DynamicResource AppAccent}"
                                    CornerRadius="0,2,2,0"
                                    Visibility="Collapsed" />
                                <ContentPresenter
                                    Grid.Column="1"
                                    Margin="10,0,8,0"
                                    HorizontalAlignment="{TemplateBinding HorizontalContentAlignment}"
                                    VerticalAlignment="{TemplateBinding VerticalContentAlignment}" />
                            </Grid>
                        </Border>
                        <ControlTemplate.Triggers>
                            <Trigger Property="IsMouseOver" Value="True">
                                <Setter TargetName="Chrome" Property="Background" Value="{DynamicResource AppHover}" />
                            </Trigger>
                            <Trigger Property="IsKeyboardFocused" Value="True">
                                <Setter TargetName="Chrome" Property="BorderBrush" Value="{DynamicResource AppAccent}" />
                            </Trigger>
                            <Trigger Property="IsChecked" Value="True">
                                <Setter TargetName="Chrome" Property="Background" Value="{DynamicResource AppHover}" />
                                <Setter TargetName="Indicator" Property="Visibility" Value="Visible" />
                            </Trigger>
                            <Trigger Property="IsEnabled" Value="False">
                                <Setter Property="Opacity" Value="0.45" />
                            </Trigger>
                        </ControlTemplate.Triggers>
                    </ControlTemplate>
                </Setter.Value>
            </Setter>
        </Style>

        <Style x:Key="NavRailItemText" TargetType="{x:Type TextBlock}">
            <Setter Property="Margin" Value="10,0,0,0" />
            <Setter Property="VerticalAlignment" Value="Center" />
            <Setter Property="FontSize" Value="{StaticResource Font.Size.Sm}" />
            <Setter Property="Foreground" Value="{DynamicResource AppTextPrimary}" />
            <Setter Property="TextTrimming" Value="CharacterEllipsis" />
            <Style.Triggers>
                <DataTrigger Binding="{Binding ElementName=PaneToggle, Path=IsChecked}" Value="False">
                    <Setter Property="Visibility" Value="Collapsed" />
                </DataTrigger>
            </Style.Triggers>
        </Style>

        <Style x:Key="NavRailHeaderText" TargetType="{x:Type TextBlock}">
            <Setter Property="Margin" Value="16,16,12,6" />
            <Setter Property="FontSize" Value="{StaticResource Font.Size.Xs}" />
            <Setter Property="FontWeight" Value="SemiBold" />
            <Setter Property="Foreground" Value="{DynamicResource AppTextMuted}" />
            <Style.Triggers>
                <DataTrigger Binding="{Binding ElementName=PaneToggle, Path=IsChecked}" Value="False">
                    <Setter Property="Visibility" Value="Collapsed" />
                </DataTrigger>
            </Style.Triggers>
        </Style>

        <Style x:Key="NavRailBadge" TargetType="{x:Type Border}">
            <Setter Property="MinWidth" Value="18" />
            <Setter Property="Height" Value="18" />
            <Setter Property="Margin" Value="8,0,0,0" />
            <Setter Property="Padding" Value="5,0" />
            <Setter Property="VerticalAlignment" Value="Center" />
            <Setter Property="Background" Value="{DynamicResource AppDanger}" />
            <Setter Property="CornerRadius" Value="9" />
        </Style>

        <!--
            Group divider — only visible when the rail is collapsed. Provides
            the visual section break that text headers (NavRailHeaderText)
            give in expanded mode but disappear in collapsed mode.
        -->
        <Style x:Key="NavRailGroupDivider" TargetType="{x:Type Border}">
            <Setter Property="Height" Value="1" />
            <Setter Property="Margin" Value="12,12,12,8" />
            <Setter Property="Background" Value="{DynamicResource AppBorderLight}" />
            <Setter Property="Visibility" Value="Collapsed" />
            <Style.Triggers>
                <DataTrigger Binding="{Binding ElementName=PaneToggle, Path=IsChecked}" Value="False">
                    <Setter Property="Visibility" Value="Visible" />
                </DataTrigger>
            </Style.Triggers>
        </Style>

        <!--  ── Section view templates (resolved by ContentControl DataTrigger) ──  -->
        <DataTemplate x:Key="PortfolioContentTemplate">
            <portfolio:PortfolioView DataContext="{Binding Portfolio}" />
        </DataTemplate>

        <DataTemplate x:Key="FinancialOverviewContentTemplate">
            <financialoverview:FinancialOverviewView DataContext="{Binding FinancialOverview}" />
        </DataTemplate>

        <DataTemplate x:Key="CategoriesContentTemplate">
            <categories:CategoriesView DataContext="{Binding Categories}" />
        </DataTemplate>

        <DataTemplate x:Key="RecurringContentTemplate">
            <recurring:RecurringView DataContext="{Binding Recurring}" />
        </DataTemplate>

        <DataTemplate x:Key="GoalsContentTemplate">
            <goals:GoalsView DataContext="{Binding Goals}" />
        </DataTemplate>

        <DataTemplate x:Key="TrendsContentTemplate">
            <trends:TrendsView DataContext="{Binding Portfolio.History}" />
        </DataTemplate>

        <DataTemplate x:Key="ReportsContentTemplate">
            <reports:ReportsView DataContext="{Binding Reports}" />
        </DataTemplate>

        <DataTemplate x:Key="AlertsContentTemplate">
            <alerts:AlertsView DataContext="{Binding Alerts}" />
        </DataTemplate>

        <DataTemplate x:Key="ImportContentTemplate">
            <TabControl
                HorizontalAlignment="Stretch"
                VerticalAlignment="Stretch"
                HorizontalContentAlignment="Stretch"
                VerticalContentAlignment="Stretch"
                Background="Transparent"
                BorderThickness="0">
                <TabControl.ItemContainerStyle>
                    <Style BasedOn="{StaticResource {x:Type TabItem}}" TargetType="{x:Type TabItem}">
                        <Setter Property="HorizontalContentAlignment" Value="Stretch" />
                        <Setter Property="VerticalContentAlignment" Value="Stretch" />
                    </Style>
                </TabControl.ItemContainerStyle>
                <TabItem Header="{DynamicResource Import.Tab.Import}">
                    <import:ImportView DataContext="{Binding Import}" />
                </TabItem>
                <TabItem Header="{DynamicResource Reconciliation.Tab}">
                    <reconciliation:ReconciliationView DataContext="{Binding Reconciliation}" />
                </TabItem>
            </TabControl>
        </DataTemplate>

        <DataTemplate x:Key="RealEstateContentTemplate">
            <realestate:RealEstateView DataContext="{Binding RealEstate}" />
        </DataTemplate>

        <DataTemplate x:Key="InsuranceContentTemplate">
            <insurance:InsurancePolicyView DataContext="{Binding Insurance}" />
        </DataTemplate>

        <DataTemplate x:Key="RetirementContentTemplate">
            <retirement:RetirementView DataContext="{Binding Retirement}" />
        </DataTemplate>

        <DataTemplate x:Key="PhysicalAssetContentTemplate">
            <physicalasset:PhysicalAssetView DataContext="{Binding PhysicalAsset}" />
        </DataTemplate>

        <DataTemplate x:Key="FireContentTemplate">
            <fire:FireView DataContext="{Binding Fire}" />
        </DataTemplate>

        <DataTemplate x:Key="MonteCarloContentTemplate">
            <montecarlo:MonteCarloView DataContext="{Binding MonteCarlo}" />
        </DataTemplate>

        <DataTemplate x:Key="SettingsContentTemplate">
            <settings:SettingsView DataContext="{Binding Settings}" />
        </DataTemplate>

        <!--
            Top-level entries promoted from inside the Portfolio tab strip
            (Option B + Portfolio-tabs refactor). All three reuse the
            existing Portfolio sub-panels with PortfolioViewModel as
            DataContext so the legacy bindings (Trades, Account.*, Liability.*)
            keep working without a sub-VM extraction.
        -->
        <DataTemplate x:Key="TransactionLogContentTemplate">
            <txlog:TransactionLogView DataContext="{Binding Portfolio}" />
        </DataTemplate>

        <DataTemplate x:Key="CashAccountsContentTemplate">
            <cashaccts:CashAccountsView DataContext="{Binding Portfolio}" />
        </DataTemplate>

        <DataTemplate x:Key="LiabilitiesContentTemplate">
            <liabs:LiabilitiesView DataContext="{Binding Portfolio}" />
        </DataTemplate>
    </UserControl.Resources>

    <Grid Background="{DynamicResource AppBackground}">
        <Grid.ColumnDefinitions>
            <ColumnDefinition Width="Auto" />
            <ColumnDefinition Width="*" />
        </Grid.ColumnDefinitions>

        <Border
            x:Name="NavPane"
            Grid.Column="0"
            Background="{DynamicResource AppSurface}"
            BorderBrush="{DynamicResource AppBorderLight}"
            BorderThickness="0,0,1,0">
            <Border.Style>
                <Style TargetType="{x:Type Border}">
                    <Setter Property="Width" Value="{StaticResource Size.Sidebar.Width}" />
                    <Style.Triggers>
                        <!--
                            NavRail collapse/expand uses Motion.Fast (120ms) and
                            Motion.Easing.Standard per the Fluent + Carbon plan.
                            Storyboards run with FillBehavior=HoldEnd so the
                            animated Width persists after the transition ends.
                        -->
                        <DataTrigger Binding="{Binding ElementName=PaneToggle, Path=IsChecked}" Value="False">
                            <DataTrigger.EnterActions>
                                <BeginStoryboard>
                                    <Storyboard>
                                        <DoubleAnimation
                                            Storyboard.TargetProperty="Width"
                                            To="56"
                                            Duration="0:0:0.12"
                                            EasingFunction="{StaticResource Motion.Easing.Standard}"
                                            FillBehavior="HoldEnd" />
                                    </Storyboard>
                                </BeginStoryboard>
                            </DataTrigger.EnterActions>
                            <DataTrigger.ExitActions>
                                <BeginStoryboard>
                                    <Storyboard>
                                        <DoubleAnimation
                                            Storyboard.TargetProperty="Width"
                                            To="{StaticResource Size.Sidebar.Width}"
                                            Duration="0:0:0.12"
                                            EasingFunction="{StaticResource Motion.Easing.Standard}"
                                            FillBehavior="HoldEnd" />
                                    </Storyboard>
                                </BeginStoryboard>
                            </DataTrigger.ExitActions>
                        </DataTrigger>
                    </Style.Triggers>
                </Style>
            </Border.Style>

            <Grid>
                <Grid.RowDefinitions>
                    <RowDefinition Height="Auto" />
                    <RowDefinition Height="*" />
                    <RowDefinition Height="Auto" />
                </Grid.RowDefinitions>

                <!--
                    Hamburger toggle:
                    * Stretches full rail width and uses Padding 17,0,0,0 so
                      the 18px icon (FontSize Md) sits with its center at
                      x=26, matching the nav-item icon column (4px indicator
                      + 10px content margin + 12px half of 24-wide icon column)
                      in both expanded (200px) and collapsed (56px) modes.
                    * Symbol swaps between ChevronLeft (expanded → click to
                      collapse) and ChevronRight (collapsed → click to expand)
                      so the affordance reflects state.
                    * AppIcon style uses BasedOn so the default Viewbox+Path
                      template is preserved.
                    * Custom Template removes the default ToggleButton chrome
                      so IsChecked state does not paint a blue rectangle.
                -->
                <ToggleButton
                    x:Name="PaneToggle"
                    Grid.Row="0"
                    Height="40"
                    Margin="0,8,0,8"
                    HorizontalAlignment="Stretch"
                    HorizontalContentAlignment="Left"
                    Padding="17,0,0,0"
                    Background="Transparent"
                    BorderThickness="0"
                    Cursor="Hand"
                    IsChecked="True"
                    ToolTip="{DynamicResource Nav.Toggle}">
                    <ToggleButton.Template>
                        <ControlTemplate TargetType="{x:Type ToggleButton}">
                            <Border
                                x:Name="Chrome"
                                Padding="{TemplateBinding Padding}"
                                Background="Transparent"
                                SnapsToDevicePixels="True">
                                <ContentPresenter
                                    HorizontalAlignment="{TemplateBinding HorizontalContentAlignment}"
                                    VerticalAlignment="Center" />
                            </Border>
                            <ControlTemplate.Triggers>
                                <Trigger Property="IsMouseOver" Value="True">
                                    <Setter TargetName="Chrome" Property="Background" Value="{DynamicResource AppHover}" />
                                </Trigger>
                            </ControlTemplate.Triggers>
                        </ControlTemplate>
                    </ToggleButton.Template>
                    <ds:AppIcon
                        HorizontalAlignment="Left"
                        VerticalAlignment="Center"
                        FontSize="{StaticResource Font.Size.Md}"
                        Foreground="{DynamicResource AppTextMuted}">
                        <ds:AppIcon.Style>
                            <Style BasedOn="{StaticResource AppIcon}" TargetType="{x:Type ds:AppIcon}">
                                <!--  Hamburger toggles the pane regardless of state — single recognisable affordance.  -->
                                <Setter Property="Symbol" Value="Navigation24" />
                                <Style.Triggers>
                                    <DataTrigger Binding="{Binding ElementName=PaneToggle, Path=IsChecked}" Value="False">
                                        <Setter Property="Symbol" Value="Navigation24" />
                                    </DataTrigger>
                                </Style.Triggers>
                            </Style>
                        </ds:AppIcon.Style>
                    </ds:AppIcon>
                </ToggleButton>

                <ScrollViewer
                    Grid.Row="1"
                    HorizontalScrollBarVisibility="Disabled"
                    VerticalScrollBarVisibility="Auto">
                    <StackPanel>
                        <!--  ─── Overview group ───  -->
                        <TextBlock Style="{StaticResource NavRailHeaderText}" Text="{DynamicResource Nav.Overview}" />

                        <ToggleButton
                            x:Name="NavFinancialOverview"
                            Click="NavItem_Click"
                            IsChecked="{Binding NavRail.ActiveSection, Converter={StaticResource EnumToBoolConverter}, ConverterParameter=FinancialOverview, Mode=OneWay}"
                            Style="{StaticResource NavRailItemButton}"
                            Tag="{x:Static shell:NavSection.FinancialOverview}"
                            ToolTip="{DynamicResource FinancialOverview.Nav.Label}">
                            <Grid>
                                <Grid.ColumnDefinitions>
                                    <ColumnDefinition Width="24" />
                                    <ColumnDefinition Width="*" />
                                </Grid.ColumnDefinitions>
                                <ds:AppIcon Symbol="DataPie24" />
                                <TextBlock Grid.Column="1" Style="{StaticResource NavRailItemText}" Text="{DynamicResource FinancialOverview.Nav.Label}" />
                            </Grid>
                        </ToggleButton>

                        <ToggleButton
                            x:Name="NavTrends"
                            Click="NavItem_Click"
                            IsChecked="{Binding NavRail.ActiveSection, Converter={StaticResource EnumToBoolConverter}, ConverterParameter=Trends, Mode=OneWay}"
                            Style="{StaticResource NavRailItemButton}"
                            Tag="{x:Static shell:NavSection.Trends}"
                            ToolTip="{DynamicResource Nav.Trends}">
                            <Grid>
                                <Grid.ColumnDefinitions>
                                    <ColumnDefinition Width="24" />
                                    <ColumnDefinition Width="*" />
                                </Grid.ColumnDefinitions>
                                <ds:AppIcon Symbol="DataTrending24" />
                                <TextBlock Grid.Column="1" Style="{StaticResource NavRailItemText}" Text="{DynamicResource Nav.Trends}" />
                            </Grid>
                        </ToggleButton>

                        <ToggleButton
                            x:Name="NavReports"
                            Click="NavItem_Click"
                            IsChecked="{Binding NavRail.ActiveSection, Converter={StaticResource EnumToBoolConverter}, ConverterParameter=Reports, Mode=OneWay}"
                            Style="{StaticResource NavRailItemButton}"
                            Tag="{x:Static shell:NavSection.Reports}"
                            ToolTip="{DynamicResource Nav.Reports}">
                            <Grid>
                                <Grid.ColumnDefinitions>
                                    <ColumnDefinition Width="24" />
                                    <ColumnDefinition Width="*" />
                                </Grid.ColumnDefinitions>
                                <ds:AppIcon Symbol="DocumentBulletList24" />
                                <TextBlock Grid.Column="1" Style="{StaticResource NavRailItemText}" Text="{DynamicResource Nav.Reports}" />
                            </Grid>
                        </ToggleButton>

                        <!--  ─── Assets group (was MultiAsset; now also hosts Portfolio) ───  -->
                        <Border Style="{StaticResource NavRailGroupDivider}" />
                        <TextBlock Style="{StaticResource NavRailHeaderText}" Text="{DynamicResource Nav.Assets}" />

                        <ToggleButton
                            x:Name="NavPortfolio"
                            Click="NavItem_Click"
                            IsChecked="{Binding NavRail.ActiveSection, Converter={StaticResource EnumToBoolConverter}, ConverterParameter=Portfolio, Mode=OneWay}"
                            Style="{StaticResource NavRailItemButton}"
                            Tag="{x:Static shell:NavSection.Portfolio}"
                            ToolTip="{DynamicResource Nav.Portfolio}">
                            <Grid>
                                <Grid.ColumnDefinitions>
                                    <ColumnDefinition Width="24" />
                                    <ColumnDefinition Width="*" />
                                </Grid.ColumnDefinitions>
                                <ds:AppIcon Symbol="Briefcase24" />
                                <TextBlock Grid.Column="1" Style="{StaticResource NavRailItemText}" Text="{DynamicResource Nav.Portfolio}" />
                            </Grid>
                        </ToggleButton>

                        <ToggleButton
                            x:Name="NavCashAccounts"
                            Click="NavItem_Click"
                            IsChecked="{Binding NavRail.ActiveSection, Converter={StaticResource EnumToBoolConverter}, ConverterParameter=CashAccounts, Mode=OneWay}"
                            Style="{StaticResource NavRailItemButton}"
                            Tag="{x:Static shell:NavSection.CashAccounts}"
                            ToolTip="{DynamicResource Nav.CashAccounts}">
                            <Grid>
                                <Grid.ColumnDefinitions>
                                    <ColumnDefinition Width="24" />
                                    <ColumnDefinition Width="*" />
                                </Grid.ColumnDefinitions>
                                <ds:AppIcon Symbol="Money24" />
                                <TextBlock Grid.Column="1" Style="{StaticResource NavRailItemText}" Text="{DynamicResource Nav.CashAccounts}" />
                            </Grid>
                        </ToggleButton>

                        <ToggleButton
                            x:Name="NavLiabilities"
                            Click="NavItem_Click"
                            IsChecked="{Binding NavRail.ActiveSection, Converter={StaticResource EnumToBoolConverter}, ConverterParameter=Liabilities, Mode=OneWay}"
                            Style="{StaticResource NavRailItemButton}"
                            Tag="{x:Static shell:NavSection.Liabilities}"
                            ToolTip="{DynamicResource Nav.Liabilities}">
                            <Grid>
                                <Grid.ColumnDefinitions>
                                    <ColumnDefinition Width="24" />
                                    <ColumnDefinition Width="*" />
                                </Grid.ColumnDefinitions>
                                <ds:AppIcon Symbol="Cut24" />
                                <TextBlock Grid.Column="1" Style="{StaticResource NavRailItemText}" Text="{DynamicResource Nav.Liabilities}" />
                            </Grid>
                        </ToggleButton>

                        <ToggleButton
                            x:Name="NavRealEstate"
                            Click="NavItem_Click"
                            IsChecked="{Binding NavRail.ActiveSection, Converter={StaticResource EnumToBoolConverter}, ConverterParameter=RealEstate, Mode=OneWay}"
                            Style="{StaticResource NavRailItemButton}"
                            Tag="{x:Static shell:NavSection.RealEstate}"
                            ToolTip="{DynamicResource RealEstate.Title}">
                            <Grid>
                                <Grid.ColumnDefinitions>
                                    <ColumnDefinition Width="24" />
                                    <ColumnDefinition Width="*" />
                                </Grid.ColumnDefinitions>
                                <ds:AppIcon Symbol="Home24" />
                                <TextBlock Grid.Column="1" Style="{StaticResource NavRailItemText}" Text="{DynamicResource RealEstate.Title}" />
                            </Grid>
                        </ToggleButton>

                        <ToggleButton
                            x:Name="NavInsurance"
                            Click="NavItem_Click"
                            IsChecked="{Binding NavRail.ActiveSection, Converter={StaticResource EnumToBoolConverter}, ConverterParameter=Insurance, Mode=OneWay}"
                            Style="{StaticResource NavRailItemButton}"
                            Tag="{x:Static shell:NavSection.Insurance}"
                            ToolTip="{DynamicResource Insurance.Title}">
                            <Grid>
                                <Grid.ColumnDefinitions>
                                    <ColumnDefinition Width="24" />
                                    <ColumnDefinition Width="*" />
                                </Grid.ColumnDefinitions>
                                <ds:AppIcon Symbol="Shield24" />
                                <TextBlock Grid.Column="1" Style="{StaticResource NavRailItemText}" Text="{DynamicResource Insurance.Title}" />
                            </Grid>
                        </ToggleButton>

                        <ToggleButton
                            x:Name="NavRetirement"
                            Click="NavItem_Click"
                            IsChecked="{Binding NavRail.ActiveSection, Converter={StaticResource EnumToBoolConverter}, ConverterParameter=Retirement, Mode=OneWay}"
                            Style="{StaticResource NavRailItemButton}"
                            Tag="{x:Static shell:NavSection.Retirement}"
                            ToolTip="{DynamicResource Retirement.Title}">
                            <Grid>
                                <Grid.ColumnDefinitions>
                                    <ColumnDefinition Width="24" />
                                    <ColumnDefinition Width="*" />
                                </Grid.ColumnDefinitions>
                                <ds:AppIcon Symbol="PersonClock24" />
                                <TextBlock Grid.Column="1" Style="{StaticResource NavRailItemText}" Text="{DynamicResource Retirement.Title}" />
                            </Grid>
                        </ToggleButton>

                        <ToggleButton
                            x:Name="NavPhysicalAsset"
                            Click="NavItem_Click"
                            IsChecked="{Binding NavRail.ActiveSection, Converter={StaticResource EnumToBoolConverter}, ConverterParameter=PhysicalAsset, Mode=OneWay}"
                            Style="{StaticResource NavRailItemButton}"
                            Tag="{x:Static shell:NavSection.PhysicalAsset}"
                            ToolTip="{DynamicResource PhysicalAsset.Title}">
                            <Grid>
                                <Grid.ColumnDefinitions>
                                    <ColumnDefinition Width="24" />
                                    <ColumnDefinition Width="*" />
                                </Grid.ColumnDefinitions>
                                <ds:AppIcon Symbol="Box24" />
                                <TextBlock Grid.Column="1" Style="{StaticResource NavRailItemText}" Text="{DynamicResource PhysicalAsset.Title}" />
                            </Grid>
                        </ToggleButton>

                        <Border Style="{StaticResource NavRailGroupDivider}" />
                        <TextBlock Style="{StaticResource NavRailHeaderText}" Text="{DynamicResource Nav.Cashflow}" />

                        <ToggleButton
                            x:Name="NavCategories"
                            Click="NavItem_Click"
                            IsChecked="{Binding NavRail.ActiveSection, Converter={StaticResource EnumToBoolConverter}, ConverterParameter=Categories, Mode=OneWay}"
                            Style="{StaticResource NavRailItemButton}"
                            Tag="{x:Static shell:NavSection.Categories}"
                            ToolTip="{DynamicResource Nav.Categories}">
                            <Grid>
                                <Grid.ColumnDefinitions>
                                    <ColumnDefinition Width="24" />
                                    <ColumnDefinition Width="*" />
                                </Grid.ColumnDefinitions>
                                <ds:AppIcon Symbol="Tag24" />
                                <TextBlock Grid.Column="1" Style="{StaticResource NavRailItemText}" Text="{DynamicResource Nav.Categories}" />
                            </Grid>
                        </ToggleButton>

                        <ToggleButton
                            x:Name="NavRecurring"
                            Click="NavItem_Click"
                            IsChecked="{Binding NavRail.ActiveSection, Converter={StaticResource EnumToBoolConverter}, ConverterParameter=Recurring, Mode=OneWay}"
                            Style="{StaticResource NavRailItemButton}"
                            Tag="{x:Static shell:NavSection.Recurring}"
                            ToolTip="{DynamicResource Nav.Recurring}">
                            <Grid>
                                <Grid.ColumnDefinitions>
                                    <ColumnDefinition Width="24" />
                                    <ColumnDefinition Width="*" />
                                    <ColumnDefinition Width="Auto" />
                                </Grid.ColumnDefinitions>
                                <!--  CalendarLtr maps cleanly to "subscription / recurring schedule" — matches the 訂閱排程 label and avoids the swap-arrow misread of ArrowRepeatAll.  -->
                                <ds:AppIcon Symbol="CalendarLtr24" />
                                <TextBlock Grid.Column="1" Style="{StaticResource NavRailItemText}" Text="{DynamicResource Nav.Recurring}" />
                                <Border Grid.Column="2" Style="{StaticResource NavRailBadge}" Visibility="{Binding Recurring.HasPending, Converter={StaticResource BooleanToVisibilityConverter}}">
                                    <TextBlock
                                        HorizontalAlignment="Center"
                                        VerticalAlignment="Center"
                                        FontSize="{StaticResource Font.Size.Xs}"
                                        Foreground="{DynamicResource AppTextOnAccent}"
                                        Text="{Binding Recurring.PendingCount}" />
                                </Border>
                            </Grid>
                        </ToggleButton>

                        <ToggleButton
                            x:Name="NavTransactionLog"
                            Click="NavItem_Click"
                            IsChecked="{Binding NavRail.ActiveSection, Converter={StaticResource EnumToBoolConverter}, ConverterParameter=TransactionLog, Mode=OneWay}"
                            Style="{StaticResource NavRailItemButton}"
                            Tag="{x:Static shell:NavSection.TransactionLog}"
                            ToolTip="{DynamicResource Nav.TransactionLog}">
                            <Grid>
                                <Grid.ColumnDefinitions>
                                    <ColumnDefinition Width="24" />
                                    <ColumnDefinition Width="*" />
                                </Grid.ColumnDefinitions>
                                <ds:AppIcon Symbol="DocumentBulletList24" />
                                <TextBlock Grid.Column="1" Style="{StaticResource NavRailItemText}" Text="{DynamicResource Nav.TransactionLog}" />
                            </Grid>
                        </ToggleButton>

                        <ToggleButton
                            x:Name="NavAlerts"
                            Click="NavItem_Click"
                            IsChecked="{Binding NavRail.ActiveSection, Converter={StaticResource EnumToBoolConverter}, ConverterParameter=Alerts, Mode=OneWay}"
                            Style="{StaticResource NavRailItemButton}"
                            Tag="{x:Static shell:NavSection.Alerts}"
                            ToolTip="{DynamicResource Nav.Alerts.Tooltip}">
                            <Grid>
                                <Grid.ColumnDefinitions>
                                    <ColumnDefinition Width="24" />
                                    <ColumnDefinition Width="*" />
                                    <ColumnDefinition Width="Auto" />
                                </Grid.ColumnDefinitions>
                                <ds:AppIcon Symbol="Alert24" />
                                <TextBlock Grid.Column="1" Style="{StaticResource NavRailItemText}" Text="{DynamicResource Nav.Alerts}" />
                                <Border Grid.Column="2" Style="{StaticResource NavRailBadge}" Visibility="{Binding Alerts.HasTriggeredAlerts, Converter={StaticResource BooleanToVisibilityConverter}}">
                                    <TextBlock
                                        HorizontalAlignment="Center"
                                        VerticalAlignment="Center"
                                        FontSize="{StaticResource Font.Size.Xs}"
                                        Foreground="{DynamicResource AppTextOnAccent}"
                                        Text="{Binding Alerts.TriggeredCount}" />
                                </Border>
                            </Grid>
                        </ToggleButton>

                        <Border Style="{StaticResource NavRailGroupDivider}" />
                        <TextBlock Style="{StaticResource NavRailHeaderText}" Text="{DynamicResource Nav.Planning}" />

                        <ToggleButton
                            x:Name="NavGoals"
                            Click="NavItem_Click"
                            IsChecked="{Binding NavRail.ActiveSection, Converter={StaticResource EnumToBoolConverter}, ConverterParameter=Goals, Mode=OneWay}"
                            Style="{StaticResource NavRailItemButton}"
                            Tag="{x:Static shell:NavSection.Goals}"
                            ToolTip="{DynamicResource Nav.Goals}">
                            <Grid>
                                <Grid.ColumnDefinitions>
                                    <ColumnDefinition Width="24" />
                                    <ColumnDefinition Width="*" />
                                </Grid.ColumnDefinitions>
                                <ds:AppIcon Symbol="Target24" />
                                <TextBlock Grid.Column="1" Style="{StaticResource NavRailItemText}" Text="{DynamicResource Nav.Goals}" />
                            </Grid>
                        </ToggleButton>

                        <ToggleButton
                            x:Name="NavFire"
                            Click="NavItem_Click"
                            IsChecked="{Binding NavRail.ActiveSection, Converter={StaticResource EnumToBoolConverter}, ConverterParameter=Fire, Mode=OneWay}"
                            Style="{StaticResource NavRailItemButton}"
                            Tag="{x:Static shell:NavSection.Fire}"
                            ToolTip="{DynamicResource Fire.Title}">
                            <Grid>
                                <Grid.ColumnDefinitions>
                                    <ColumnDefinition Width="24" />
                                    <ColumnDefinition Width="*" />
                                </Grid.ColumnDefinitions>
                                <ds:AppIcon Symbol="Flash24" />
                                <TextBlock Grid.Column="1" Style="{StaticResource NavRailItemText}" Text="{DynamicResource Fire.Title}" />
                            </Grid>
                        </ToggleButton>

                        <ToggleButton
                            x:Name="NavMonteCarlo"
                            Click="NavItem_Click"
                            IsChecked="{Binding NavRail.ActiveSection, Converter={StaticResource EnumToBoolConverter}, ConverterParameter=MonteCarlo, Mode=OneWay}"
                            Style="{StaticResource NavRailItemButton}"
                            Tag="{x:Static shell:NavSection.MonteCarlo}"
                            ToolTip="{DynamicResource MonteCarlo.Title}">
                            <Grid>
                                <Grid.ColumnDefinitions>
                                    <ColumnDefinition Width="24" />
                                    <ColumnDefinition Width="*" />
                                </Grid.ColumnDefinitions>
                                <!--  Calculator differentiates Monte Carlo from the pie/line chart icons of FinancialOverview / Trends; conveys "simulation / computation" semantics.  -->
                                <ds:AppIcon Symbol="Calculator24" />
                                <TextBlock Grid.Column="1" Style="{StaticResource NavRailItemText}" Text="{DynamicResource MonteCarlo.Title}" />
                            </Grid>
                        </ToggleButton>
                    </StackPanel>
                </ScrollViewer>

                <StackPanel Grid.Row="2" Margin="0,8,0,8">
                    <Border Height="1" Margin="0,0,0,8" Background="{DynamicResource AppBorderLight}" />

                    <ToggleButton
                        x:Name="NavImport"
                        Click="NavItem_Click"
                        IsChecked="{Binding NavRail.ActiveSection, Converter={StaticResource EnumToBoolConverter}, ConverterParameter=Import, Mode=OneWay}"
                        Style="{StaticResource NavRailItemButton}"
                        Tag="{x:Static shell:NavSection.Import}"
                        ToolTip="{DynamicResource Nav.Import}">
                        <Grid>
                            <Grid.ColumnDefinitions>
                                <ColumnDefinition Width="24" />
                                <ColumnDefinition Width="*" />
                            </Grid.ColumnDefinitions>
                            <ds:AppIcon Symbol="DocumentArrowDown24" />
                            <TextBlock Grid.Column="1" Style="{StaticResource NavRailItemText}" Text="{DynamicResource Nav.Import}" />
                        </Grid>
                    </ToggleButton>

                    <ToggleButton
                        x:Name="NavSettings"
                        Click="NavItem_Click"
                        IsChecked="{Binding NavRail.ActiveSection, Converter={StaticResource EnumToBoolConverter}, ConverterParameter=Settings, Mode=OneWay}"
                        Style="{StaticResource NavRailItemButton}"
                        Tag="{x:Static shell:NavSection.Settings}"
                        ToolTip="{DynamicResource Nav.Settings}">
                        <Grid>
                            <Grid.ColumnDefinitions>
                                <ColumnDefinition Width="24" />
                                <ColumnDefinition Width="*" />
                            </Grid.ColumnDefinitions>
                            <ds:AppIcon Symbol="Settings24" />
                            <TextBlock Grid.Column="1" Style="{StaticResource NavRailItemText}" Text="{DynamicResource Nav.Settings}" />
                        </Grid>
                    </ToggleButton>
                </StackPanel>
            </Grid>
        </Border>

        <ContentControl
            Grid.Column="1"
            HorizontalAlignment="Stretch"
            VerticalAlignment="Stretch"
            HorizontalContentAlignment="Stretch"
            VerticalContentAlignment="Stretch"
            Content="{Binding}">
            <ContentControl.Style>
                <Style TargetType="{x:Type ContentControl}">
                    <Setter Property="ContentTemplate" Value="{StaticResource PortfolioContentTemplate}" />
                    <Style.Triggers>
                        <DataTrigger Binding="{Binding NavRail.ActiveSection}" Value="{x:Static shell:NavSection.Portfolio}">
                            <Setter Property="ContentTemplate" Value="{StaticResource PortfolioContentTemplate}" />
                        </DataTrigger>
                        <DataTrigger Binding="{Binding NavRail.ActiveSection}" Value="{x:Static shell:NavSection.FinancialOverview}">
                            <Setter Property="ContentTemplate" Value="{StaticResource FinancialOverviewContentTemplate}" />
                        </DataTrigger>
                        <DataTrigger Binding="{Binding NavRail.ActiveSection}" Value="{x:Static shell:NavSection.Categories}">
                            <Setter Property="ContentTemplate" Value="{StaticResource CategoriesContentTemplate}" />
                        </DataTrigger>
                        <DataTrigger Binding="{Binding NavRail.ActiveSection}" Value="{x:Static shell:NavSection.Recurring}">
                            <Setter Property="ContentTemplate" Value="{StaticResource RecurringContentTemplate}" />
                        </DataTrigger>
                        <DataTrigger Binding="{Binding NavRail.ActiveSection}" Value="{x:Static shell:NavSection.Goals}">
                            <Setter Property="ContentTemplate" Value="{StaticResource GoalsContentTemplate}" />
                        </DataTrigger>
                        <DataTrigger Binding="{Binding NavRail.ActiveSection}" Value="{x:Static shell:NavSection.Trends}">
                            <Setter Property="ContentTemplate" Value="{StaticResource TrendsContentTemplate}" />
                        </DataTrigger>
                        <DataTrigger Binding="{Binding NavRail.ActiveSection}" Value="{x:Static shell:NavSection.Reports}">
                            <Setter Property="ContentTemplate" Value="{StaticResource ReportsContentTemplate}" />
                        </DataTrigger>
                        <DataTrigger Binding="{Binding NavRail.ActiveSection}" Value="{x:Static shell:NavSection.Alerts}">
                            <Setter Property="ContentTemplate" Value="{StaticResource AlertsContentTemplate}" />
                        </DataTrigger>
                        <DataTrigger Binding="{Binding NavRail.ActiveSection}" Value="{x:Static shell:NavSection.Import}">
                            <Setter Property="ContentTemplate" Value="{StaticResource ImportContentTemplate}" />
                        </DataTrigger>
                        <DataTrigger Binding="{Binding NavRail.ActiveSection}" Value="{x:Static shell:NavSection.RealEstate}">
                            <Setter Property="ContentTemplate" Value="{StaticResource RealEstateContentTemplate}" />
                        </DataTrigger>
                        <DataTrigger Binding="{Binding NavRail.ActiveSection}" Value="{x:Static shell:NavSection.Insurance}">
                            <Setter Property="ContentTemplate" Value="{StaticResource InsuranceContentTemplate}" />
                        </DataTrigger>
                        <DataTrigger Binding="{Binding NavRail.ActiveSection}" Value="{x:Static shell:NavSection.Retirement}">
                            <Setter Property="ContentTemplate" Value="{StaticResource RetirementContentTemplate}" />
                        </DataTrigger>
                        <DataTrigger Binding="{Binding NavRail.ActiveSection}" Value="{x:Static shell:NavSection.PhysicalAsset}">
                            <Setter Property="ContentTemplate" Value="{StaticResource PhysicalAssetContentTemplate}" />
                        </DataTrigger>
                        <DataTrigger Binding="{Binding NavRail.ActiveSection}" Value="{x:Static shell:NavSection.Fire}">
                            <Setter Property="ContentTemplate" Value="{StaticResource FireContentTemplate}" />
                        </DataTrigger>
                        <DataTrigger Binding="{Binding NavRail.ActiveSection}" Value="{x:Static shell:NavSection.MonteCarlo}">
                            <Setter Property="ContentTemplate" Value="{StaticResource MonteCarloContentTemplate}" />
                        </DataTrigger>
                        <DataTrigger Binding="{Binding NavRail.ActiveSection}" Value="{x:Static shell:NavSection.Settings}">
                            <Setter Property="ContentTemplate" Value="{StaticResource SettingsContentTemplate}" />
                        </DataTrigger>
                        <DataTrigger Binding="{Binding NavRail.ActiveSection}" Value="{x:Static shell:NavSection.TransactionLog}">
                            <Setter Property="ContentTemplate" Value="{StaticResource TransactionLogContentTemplate}" />
                        </DataTrigger>
                        <DataTrigger Binding="{Binding NavRail.ActiveSection}" Value="{x:Static shell:NavSection.CashAccounts}">
                            <Setter Property="ContentTemplate" Value="{StaticResource CashAccountsContentTemplate}" />
                        </DataTrigger>
                        <DataTrigger Binding="{Binding NavRail.ActiveSection}" Value="{x:Static shell:NavSection.Liabilities}">
                            <Setter Property="ContentTemplate" Value="{StaticResource LiabilitiesContentTemplate}" />
                        </DataTrigger>
                    </Style.Triggers>
                </Style>
            </ContentControl.Style>
        </ContentControl>
    </Grid>
</UserControl>
