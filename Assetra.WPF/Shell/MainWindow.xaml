<ui:FluentWindow
    x:Class="Assetra.WPF.Shell.MainWindow"
    xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
    xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
    xmlns:alerts="clr-namespace:Assetra.WPF.Features.Alerts"
    xmlns:categories="clr-namespace:Assetra.WPF.Features.Categories"
    xmlns:financialoverview="clr-namespace:Assetra.WPF.Features.FinancialOverview"
    xmlns:fire="clr-namespace:Assetra.WPF.Features.Fire"
    xmlns:d="http://schemas.microsoft.com/expression/blend/2008"
    xmlns:insurance="clr-namespace:Assetra.WPF.Features.Insurance"
    xmlns:mc="http://schemas.openxmlformats.org/markup-compatibility/2006"
    xmlns:montecarlo="clr-namespace:Assetra.WPF.Features.MonteCarlo"
    xmlns:physicalasset="clr-namespace:Assetra.WPF.Features.PhysicalAsset"
    xmlns:portfolio="clr-namespace:Assetra.WPF.Features.Portfolio"
    xmlns:realestate="clr-namespace:Assetra.WPF.Features.RealEstate"
    xmlns:recurring="clr-namespace:Assetra.WPF.Features.Recurring"
    xmlns:reports="clr-namespace:Assetra.WPF.Features.Reports"
    xmlns:retirement="clr-namespace:Assetra.WPF.Features.Retirement"
    xmlns:trends="clr-namespace:Assetra.WPF.Features.Trends"
    xmlns:goals="clr-namespace:Assetra.WPF.Features.Goals"
    xmlns:hubs="clr-namespace:Assetra.WPF.Features.Hubs"
    xmlns:import="clr-namespace:Assetra.WPF.Features.Import"
    xmlns:reconciliation="clr-namespace:Assetra.WPF.Features.Reconciliation"
    xmlns:settings="clr-namespace:Assetra.WPF.Features.Settings"
    xmlns:shell="clr-namespace:Assetra.WPF.Shell"
    xmlns:snackbar="clr-namespace:Assetra.WPF.Features.Snackbar"
    xmlns:statusbar="clr-namespace:Assetra.WPF.Features.StatusBar"
    xmlns:ui="http://schemas.lepo.co/wpfui/2022/xaml"
    x:Name="MainShell"
    Title="{DynamicResource App.Title}"
    Width="1440"
    Height="840"
    MinWidth="900"
    MinHeight="600"
    Background="{DynamicResource AppBackground}"
    Icon="pack://application:,,,/Assetra.WPF;component/Assets/windows/assetra-app.ico"
    WindowStartupLocation="CenterScreen"
    mc:Ignorable="d">

    <ui:FluentWindow.Resources>
        <DataTemplate x:Key="PortfolioContentTemplate">
            <portfolio:PortfolioView DataContext="{Binding Portfolio}" />
        </DataTemplate>

        <DataTemplate x:Key="FinancialOverviewContentTemplate">
            <financialoverview:FinancialOverviewView DataContext="{Binding FinancialOverview}" />
        </DataTemplate>

        <DataTemplate x:Key="CategoriesContentTemplate">
            <categories:CategoriesView DataContext="{Binding Categories}" />
        </DataTemplate>

        <DataTemplate x:Key="RecurringContentTemplate">
            <recurring:RecurringView DataContext="{Binding Recurring}" />
        </DataTemplate>

        <DataTemplate x:Key="GoalsContentTemplate">
            <goals:GoalsView DataContext="{Binding Goals}" />
        </DataTemplate>

        <DataTemplate x:Key="TrendsContentTemplate">
            <trends:TrendsView DataContext="{Binding Portfolio.History}" />
        </DataTemplate>

        <DataTemplate x:Key="ReportsContentTemplate">
            <reports:ReportsView DataContext="{Binding Reports}" />
        </DataTemplate>

        <DataTemplate x:Key="AlertsContentTemplate">
            <alerts:AlertsView DataContext="{Binding Alerts}" />
        </DataTemplate>

        <DataTemplate x:Key="ImportContentTemplate">
            <TabControl Background="Transparent" BorderThickness="0">
                <TabItem Header="{DynamicResource Import.Tab.Import}">
                    <import:ImportView DataContext="{Binding Import}" />
                </TabItem>
                <TabItem Header="{DynamicResource Reconciliation.Tab}">
                    <reconciliation:ReconciliationView DataContext="{Binding Reconciliation}" />
                </TabItem>
            </TabControl>
        </DataTemplate>

        <DataTemplate x:Key="RealEstateContentTemplate">
            <realestate:RealEstateView DataContext="{Binding RealEstate}" />
        </DataTemplate>

        <DataTemplate x:Key="InsuranceContentTemplate">
            <insurance:InsurancePolicyView DataContext="{Binding Insurance}" />
        </DataTemplate>

        <DataTemplate x:Key="RetirementContentTemplate">
            <retirement:RetirementView DataContext="{Binding Retirement}" />
        </DataTemplate>

        <DataTemplate x:Key="PhysicalAssetContentTemplate">
            <physicalasset:PhysicalAssetView DataContext="{Binding PhysicalAsset}" />
        </DataTemplate>

        <DataTemplate x:Key="FireContentTemplate">
            <fire:FireView DataContext="{Binding Fire}" />
        </DataTemplate>

        <DataTemplate x:Key="MonteCarloContentTemplate">
            <montecarlo:MonteCarloView DataContext="{Binding MonteCarlo}" />
        </DataTemplate>

        <DataTemplate x:Key="SettingsContentTemplate">
            <settings:SettingsView DataContext="{Binding Settings}" />
        </DataTemplate>

        <!--  ── Hub views (Phase 2 IA consolidation) ──  -->
        <DataTemplate x:Key="CashflowHubContentTemplate">
            <hubs:CashflowHubView />
        </DataTemplate>

        <DataTemplate x:Key="InsightsHubContentTemplate">
            <hubs:InsightsHubView />
        </DataTemplate>

        <DataTemplate x:Key="MultiAssetHubContentTemplate">
            <hubs:MultiAssetHubView />
        </DataTemplate>
    </ui:FluentWindow.Resources>

    <!--  Keyboard shortcuts  -->
    <ui:FluentWindow.InputBindings>
        <KeyBinding
            Key="K"
            Command="{Binding ToggleSearchCommand}"
            Modifiers="Ctrl" />
        <KeyBinding
            Key="Left"
            Command="{Binding NavRail.GoBackCommand}"
            Modifiers="Alt" />
        <KeyBinding
            Key="Right"
            Command="{Binding NavRail.GoForwardCommand}"
            Modifiers="Alt" />
    </ui:FluentWindow.InputBindings>

    <Grid>
        <Grid.LayoutTransform>
            <ScaleTransform ScaleX="{Binding Settings.UiScale}" ScaleY="{Binding Settings.UiScale}" />
        </Grid.LayoutTransform>
        <Grid.RowDefinitions>
            <RowDefinition Height="Auto" />
            <!--  TitleBar  -->
            <RowDefinition Height="*" />
            <!--  NavRail + Content  -->
            <RowDefinition Height="Auto" />
            <!--  Status bar  -->
        </Grid.RowDefinitions>

        <!--  ── Title Bar ──  -->
        <Border
            Grid.Row="0"
            Background="{DynamicResource AppSurface}"
            BorderBrush="{DynamicResource AppBorderLight}"
            BorderThickness="0,0,0,1">
            <ui:TitleBar
                x:Name="AppTitleBar"
                Title="{DynamicResource App.Title}"
                Background="Transparent"
                Foreground="{DynamicResource AppTextPrimary}">

                <ui:TitleBar.Icon>
                    <ui:ImageIcon Source="{StaticResource AssetraLogo}" />
                </ui:TitleBar.Icon>

                <ui:TitleBar.Header>
                    <!--
                        Grid (Auto | * | Auto) prevents DockPanel clipping when the
                        WPF-UI header region is narrower than expected.  The centre
                        column absorbs all slack; neither side ever gets clipped.
                    -->
                    <Grid VerticalAlignment="Center">
                        <Grid.ColumnDefinitions>
                            <ColumnDefinition Width="Auto" />
                            <ColumnDefinition Width="*" />
                            <ColumnDefinition Width="Auto" />
                        </Grid.ColumnDefinitions>

                        <!--  Left: Back / Forward / Search  -->
                        <StackPanel
                            Grid.Column="0"
                            Margin="-4,0,0,0"
                            Orientation="Horizontal">
                            <ui:Button
                                Margin="4,0,0,0"
                                Appearance="Transparent"
                                Command="{Binding NavRail.GoBackCommand}"
                                ToolTip="{DynamicResource Nav.GoBack}">
                                <ui:SymbolIcon Symbol="ChevronRight24" FontSize="{StaticResource FontSizeBase}" Foreground="{DynamicResource AppTextMuted}" />
                            </ui:Button>
                            <ui:Button
                                Margin="2,0,0,0"
                                Appearance="Transparent"
                                Command="{Binding NavRail.GoForwardCommand}"
                                ToolTip="{DynamicResource Nav.GoForward}">
                                <ui:SymbolIcon Symbol="ChevronLeft24" FontSize="{StaticResource FontSizeBase}" Foreground="{DynamicResource AppTextMuted}" />
                            </ui:Button>
                            <ui:Button
                                x:Name="SearchIconBtn"
                                Margin="8,0,0,0"
                                Appearance="Transparent"
                                Command="{Binding ToggleSearchCommand}"
                                ToolTip="Ctrl+K">
                                <ui:SymbolIcon Symbol="Search24" FontSize="{StaticResource FontSizeMd}" Foreground="{DynamicResource AppTextMuted}" />
                            </ui:Button>
                        </StackPanel>

                        <!--  Center: Current page title (dynamic per ActiveSection)  -->
                        <TextBlock
                            Grid.Column="1"
                            Margin="16,0,12,0"
                            VerticalAlignment="Center"
                            FontSize="{StaticResource FontSizeMd}"
                            FontWeight="SemiBold"
                            Foreground="{DynamicResource AppTextPrimary}"
                            TextTrimming="CharacterEllipsis">
                            <TextBlock.Style>
                                <Style TargetType="TextBlock">
                                    <Setter Property="Text" Value="{DynamicResource Nav.Portfolio}" />
                                    <Style.Triggers>
                                        <DataTrigger Binding="{Binding NavRail.ActiveSection}" Value="{x:Static shell:NavSection.Portfolio}">
                                            <Setter Property="Text" Value="{DynamicResource Nav.Portfolio}" />
                                        </DataTrigger>
                                        <DataTrigger Binding="{Binding NavRail.ActiveSection}" Value="{x:Static shell:NavSection.FinancialOverview}">
                                            <Setter Property="Text" Value="{DynamicResource FinancialOverview.Nav.Label}" />
                                        </DataTrigger>
                                        <DataTrigger Binding="{Binding NavRail.ActiveSection}" Value="{x:Static shell:NavSection.Categories}">
                                            <Setter Property="Text" Value="{DynamicResource Nav.Categories}" />
                                        </DataTrigger>
                                        <DataTrigger Binding="{Binding NavRail.ActiveSection}" Value="{x:Static shell:NavSection.Recurring}">
                                            <Setter Property="Text" Value="{DynamicResource Nav.Recurring}" />
                                        </DataTrigger>
                                        <DataTrigger Binding="{Binding NavRail.ActiveSection}" Value="{x:Static shell:NavSection.Goals}">
                                            <Setter Property="Text" Value="{DynamicResource Nav.Goals}" />
                                        </DataTrigger>
                                        <DataTrigger Binding="{Binding NavRail.ActiveSection}" Value="{x:Static shell:NavSection.Trends}">
                                            <Setter Property="Text" Value="{DynamicResource Nav.Trends}" />
                                        </DataTrigger>
                                        <DataTrigger Binding="{Binding NavRail.ActiveSection}" Value="{x:Static shell:NavSection.Reports}">
                                            <Setter Property="Text" Value="{DynamicResource Nav.Reports}" />
                                        </DataTrigger>
                                        <DataTrigger Binding="{Binding NavRail.ActiveSection}" Value="{x:Static shell:NavSection.RealEstate}">
                                            <Setter Property="Text" Value="{DynamicResource RealEstate.Title}" />
                                        </DataTrigger>
                                        <DataTrigger Binding="{Binding NavRail.ActiveSection}" Value="{x:Static shell:NavSection.Insurance}">
                                            <Setter Property="Text" Value="{DynamicResource Insurance.Title}" />
                                        </DataTrigger>
                                        <DataTrigger Binding="{Binding NavRail.ActiveSection}" Value="{x:Static shell:NavSection.Retirement}">
                                            <Setter Property="Text" Value="{DynamicResource Retirement.Title}" />
                                        </DataTrigger>
                                        <DataTrigger Binding="{Binding NavRail.ActiveSection}" Value="{x:Static shell:NavSection.PhysicalAsset}">
                                            <Setter Property="Text" Value="{DynamicResource PhysicalAsset.Title}" />
                                        </DataTrigger>
                                        <DataTrigger Binding="{Binding NavRail.ActiveSection}" Value="{x:Static shell:NavSection.Fire}">
                                            <Setter Property="Text" Value="{DynamicResource Fire.Title}" />
                                        </DataTrigger>
                                        <DataTrigger Binding="{Binding NavRail.ActiveSection}" Value="{x:Static shell:NavSection.MonteCarlo}">
                                            <Setter Property="Text" Value="{DynamicResource MonteCarlo.Title}" />
                                        </DataTrigger>
                                        <DataTrigger Binding="{Binding NavRail.ActiveSection}" Value="{x:Static shell:NavSection.Alerts}">
                                            <Setter Property="Text" Value="{DynamicResource Nav.Alerts}" />
                                        </DataTrigger>
                                        <DataTrigger Binding="{Binding NavRail.ActiveSection}" Value="{x:Static shell:NavSection.Import}">
                                            <Setter Property="Text" Value="{DynamicResource Nav.Import}" />
                                        </DataTrigger>
                                        <DataTrigger Binding="{Binding NavRail.ActiveSection}" Value="{x:Static shell:NavSection.Settings}">
                                            <Setter Property="Text" Value="{DynamicResource Nav.Settings}" />
                                        </DataTrigger>
                                        <DataTrigger Binding="{Binding NavRail.ActiveSection}" Value="{x:Static shell:NavSection.Cashflow}">
                                            <Setter Property="Text" Value="{DynamicResource Nav.Cashflow}" />
                                        </DataTrigger>
                                        <DataTrigger Binding="{Binding NavRail.ActiveSection}" Value="{x:Static shell:NavSection.Insights}">
                                            <Setter Property="Text" Value="{DynamicResource Nav.Insights}" />
                                        </DataTrigger>
                                        <DataTrigger Binding="{Binding NavRail.ActiveSection}" Value="{x:Static shell:NavSection.MultiAsset}">
                                            <Setter Property="Text" Value="{DynamicResource Nav.MultiAsset}" />
                                        </DataTrigger>
                                    </Style.Triggers>
                                </Style>
                            </TextBlock.Style>
                        </TextBlock>

                        <!--  Right: Theme toggle (Settings moved to NavRail bottom)  -->
                        <StackPanel
                            Grid.Column="2"
                            Margin="0,0,8,0"
                            Orientation="Horizontal">
                            <ui:Button
                                Appearance="Transparent"
                                Command="{Binding ToggleThemeCommand}"
                                ToolTip="{Binding ThemeToggleLabel}">
                                <ui:SymbolIcon FontSize="{StaticResource FontSizeMd}" Foreground="{DynamicResource AppTextMuted}">
                                    <ui:SymbolIcon.Style>
                                        <Style TargetType="ui:SymbolIcon">
                                            <Setter Property="Symbol" Value="WeatherSunny24" />
                                            <Style.Triggers>
                                                <DataTrigger Binding="{Binding CurrentTheme}" Value="Dark">
                                                    <Setter Property="Symbol" Value="WeatherMoon24" />
                                                </DataTrigger>
                                            </Style.Triggers>
                                        </Style>
                                    </ui:SymbolIcon.Style>
                                </ui:SymbolIcon>
                            </ui:Button>
                        </StackPanel>

                    </Grid>
                </ui:TitleBar.Header>
            </ui:TitleBar>
        </Border>

        <!--  ── Row 1: NavigationView (pane + content) ──  -->
        <ui:NavigationView
            x:Name="RootNavView"
            Grid.Row="1"
            CompactPaneLength="56"
            IsBackButtonVisible="Collapsed"
            IsPaneToggleVisible="True"
            OpenPaneLength="220"
            PaneDisplayMode="LeftMinimal"
            SelectionChanged="RootNavView_SelectionChanged">

            <ui:NavigationView.MenuItems>

                <ui:NavigationViewItem
                    x:Name="NavPortfolio"
                    Content="{DynamicResource Nav.Portfolio}"
                    TargetPageTag="Portfolio">
                    <ui:NavigationViewItem.Icon>
                        <ui:SymbolIcon Symbol="Briefcase24" />
                    </ui:NavigationViewItem.Icon>
                </ui:NavigationViewItem>

                <ui:NavigationViewItem
                    x:Name="NavFinancialOverview"
                    Content="{DynamicResource FinancialOverview.Nav.Label}"
                    TargetPageTag="FinancialOverview">
                    <ui:NavigationViewItem.Icon>
                        <ui:SymbolIcon Symbol="DataPie24" />
                    </ui:NavigationViewItem.Icon>
                </ui:NavigationViewItem>

                <ui:NavigationViewItem
                    x:Name="NavCashflow"
                    Content="{DynamicResource Nav.Cashflow}"
                    TargetPageTag="Cashflow">
                    <ui:NavigationViewItem.Icon>
                        <ui:SymbolIcon Symbol="Wallet24" />
                    </ui:NavigationViewItem.Icon>
                    <ui:NavigationViewItem.InfoBadge>
                        <ui:InfoBadge
                            Severity="Attention"
                            Value="{Binding Recurring.PendingCount}"
                            Visibility="{Binding Recurring.HasPending, Converter={StaticResource BooleanToVisibilityConverter}}" />
                    </ui:NavigationViewItem.InfoBadge>
                </ui:NavigationViewItem>

                <ui:NavigationViewItem
                    x:Name="NavInsights"
                    Content="{DynamicResource Nav.Insights}"
                    TargetPageTag="Insights">
                    <ui:NavigationViewItem.Icon>
                        <ui:SymbolIcon Symbol="Pulse24" />
                    </ui:NavigationViewItem.Icon>
                </ui:NavigationViewItem>

                <ui:NavigationViewItem
                    x:Name="NavMultiAsset"
                    Content="{DynamicResource Nav.MultiAsset}"
                    TargetPageTag="MultiAsset">
                    <ui:NavigationViewItem.Icon>
                        <ui:SymbolIcon Symbol="Home24" />
                    </ui:NavigationViewItem.Icon>
                </ui:NavigationViewItem>

                <ui:NavigationViewItem
                    x:Name="NavAlerts"
                    Content="{DynamicResource Nav.Alerts}"
                    TargetPageTag="Alerts">
                    <ui:NavigationViewItem.Icon>
                        <ui:SymbolIcon Symbol="Alert24" />
                    </ui:NavigationViewItem.Icon>
                    <ui:NavigationViewItem.InfoBadge>
                        <ui:InfoBadge
                            Severity="Critical"
                            Value="{Binding Alerts.TriggeredCount}"
                            Visibility="{Binding Alerts.HasTriggeredAlerts, Converter={StaticResource BooleanToVisibilityConverter}}" />
                    </ui:NavigationViewItem.InfoBadge>
                </ui:NavigationViewItem>

            </ui:NavigationView.MenuItems>

            <ui:NavigationView.FooterMenuItems>

                <ui:NavigationViewItem
                    x:Name="NavImport"
                    Content="{DynamicResource Nav.Import}"
                    TargetPageTag="Import">
                    <ui:NavigationViewItem.Icon>
                        <ui:SymbolIcon Symbol="DocumentArrowDown24" />
                    </ui:NavigationViewItem.Icon>
                </ui:NavigationViewItem>

                <ui:NavigationViewItem
                    x:Name="NavSettings"
                    Content="{DynamicResource Nav.Settings}"
                    TargetPageTag="Settings">
                    <ui:NavigationViewItem.Icon>
                        <ui:SymbolIcon Symbol="Settings24" />
                    </ui:NavigationViewItem.Icon>
                </ui:NavigationViewItem>

            </ui:NavigationView.FooterMenuItems>

            <!--  ── Content area (active feature view) — overlays NavigationView frame ──  -->
            <ui:NavigationView.ContentOverlay>
                <ContentControl Content="{Binding}">
                    <ContentControl.Style>
                        <Style TargetType="{x:Type ContentControl}">
                            <Setter Property="ContentTemplate" Value="{StaticResource PortfolioContentTemplate}" />
                            <Style.Triggers>
                                <DataTrigger Binding="{Binding NavRail.ActiveSection}" Value="{x:Static shell:NavSection.Portfolio}">
                                    <Setter Property="ContentTemplate" Value="{StaticResource PortfolioContentTemplate}" />
                                </DataTrigger>
                                <DataTrigger Binding="{Binding NavRail.ActiveSection}" Value="{x:Static shell:NavSection.FinancialOverview}">
                                    <Setter Property="ContentTemplate" Value="{StaticResource FinancialOverviewContentTemplate}" />
                                </DataTrigger>
                                <DataTrigger Binding="{Binding NavRail.ActiveSection}" Value="{x:Static shell:NavSection.Categories}">
                                    <Setter Property="ContentTemplate" Value="{StaticResource CategoriesContentTemplate}" />
                                </DataTrigger>
                                <DataTrigger Binding="{Binding NavRail.ActiveSection}" Value="{x:Static shell:NavSection.Recurring}">
                                    <Setter Property="ContentTemplate" Value="{StaticResource RecurringContentTemplate}" />
                                </DataTrigger>
                                <DataTrigger Binding="{Binding NavRail.ActiveSection}" Value="{x:Static shell:NavSection.Goals}">
                                    <Setter Property="ContentTemplate" Value="{StaticResource GoalsContentTemplate}" />
                                </DataTrigger>
                                <DataTrigger Binding="{Binding NavRail.ActiveSection}" Value="{x:Static shell:NavSection.Trends}">
                                    <Setter Property="ContentTemplate" Value="{StaticResource TrendsContentTemplate}" />
                                </DataTrigger>
                                <DataTrigger Binding="{Binding NavRail.ActiveSection}" Value="{x:Static shell:NavSection.Reports}">
                                    <Setter Property="ContentTemplate" Value="{StaticResource ReportsContentTemplate}" />
                                </DataTrigger>
                                <DataTrigger Binding="{Binding NavRail.ActiveSection}" Value="{x:Static shell:NavSection.Alerts}">
                                    <Setter Property="ContentTemplate" Value="{StaticResource AlertsContentTemplate}" />
                                </DataTrigger>
                                <DataTrigger Binding="{Binding NavRail.ActiveSection}" Value="{x:Static shell:NavSection.Import}">
                                    <Setter Property="ContentTemplate" Value="{StaticResource ImportContentTemplate}" />
                                </DataTrigger>
                                <DataTrigger Binding="{Binding NavRail.ActiveSection}" Value="{x:Static shell:NavSection.RealEstate}">
                                    <Setter Property="ContentTemplate" Value="{StaticResource RealEstateContentTemplate}" />
                                </DataTrigger>
                                <DataTrigger Binding="{Binding NavRail.ActiveSection}" Value="{x:Static shell:NavSection.Insurance}">
                                    <Setter Property="ContentTemplate" Value="{StaticResource InsuranceContentTemplate}" />
                                </DataTrigger>
                                <DataTrigger Binding="{Binding NavRail.ActiveSection}" Value="{x:Static shell:NavSection.Retirement}">
                                    <Setter Property="ContentTemplate" Value="{StaticResource RetirementContentTemplate}" />
                                </DataTrigger>
                                <DataTrigger Binding="{Binding NavRail.ActiveSection}" Value="{x:Static shell:NavSection.PhysicalAsset}">
                                    <Setter Property="ContentTemplate" Value="{StaticResource PhysicalAssetContentTemplate}" />
                                </DataTrigger>
                                <DataTrigger Binding="{Binding NavRail.ActiveSection}" Value="{x:Static shell:NavSection.Fire}">
                                    <Setter Property="ContentTemplate" Value="{StaticResource FireContentTemplate}" />
                                </DataTrigger>
                                <DataTrigger Binding="{Binding NavRail.ActiveSection}" Value="{x:Static shell:NavSection.MonteCarlo}">
                                    <Setter Property="ContentTemplate" Value="{StaticResource MonteCarloContentTemplate}" />
                                </DataTrigger>
                                <DataTrigger Binding="{Binding NavRail.ActiveSection}" Value="{x:Static shell:NavSection.Settings}">
                                    <Setter Property="ContentTemplate" Value="{StaticResource SettingsContentTemplate}" />
                                </DataTrigger>
                                <DataTrigger Binding="{Binding NavRail.ActiveSection}" Value="{x:Static shell:NavSection.Cashflow}">
                                    <Setter Property="ContentTemplate" Value="{StaticResource CashflowHubContentTemplate}" />
                                </DataTrigger>
                                <DataTrigger Binding="{Binding NavRail.ActiveSection}" Value="{x:Static shell:NavSection.Insights}">
                                    <Setter Property="ContentTemplate" Value="{StaticResource InsightsHubContentTemplate}" />
                                </DataTrigger>
                                <DataTrigger Binding="{Binding NavRail.ActiveSection}" Value="{x:Static shell:NavSection.MultiAsset}">
                                    <Setter Property="ContentTemplate" Value="{StaticResource MultiAssetHubContentTemplate}" />
                                </DataTrigger>
                            </Style.Triggers>
                        </Style>
                    </ContentControl.Style>
                </ContentControl>
            </ui:NavigationView.ContentOverlay>

        </ui:NavigationView>

        <!--  Search backdrop — sits above content, behind the popup HWnd  -->
        <Border
            x:Name="SearchBackdrop"
            Grid.Row="0"
            Grid.RowSpan="3"
            Panel.ZIndex="8"
            Background="Black"
            MouseDown="SearchBackdrop_MouseDown"
            Opacity="0.35"
            Visibility="{Binding IsSearchOpen, Converter={StaticResource BooleanToVisibilityConverter}}" />

        <!--  ── Search / Command Palette Popup (centered at top; dismiss on outside click) ──  -->
        <Popup
            x:Name="SearchPopup"
            AllowsTransparency="True"
            IsOpen="{Binding IsSearchOpen, Mode=TwoWay}"
            Placement="Custom"
            PlacementTarget="{Binding ElementName=MainShell}"
            PopupAnimation="Fade"
            StaysOpen="False">
            <Border
                Margin="12"
                MaxHeight="440"
                Background="{DynamicResource AppSurface}"
                BorderBrush="{DynamicResource AppBorder}"
                BorderThickness="1"
                CornerRadius="{StaticResource RadiusLg}">
                <Border.Width>
                    <MultiBinding Converter="{StaticResource AdaptivePanelWidthConverter}" ConverterParameter="0.52|360|620">
                        <Binding ElementName="MainShell" Path="ActualWidth" />
                        <Binding Path="Settings.UiScale" />
                    </MultiBinding>
                </Border.Width>
                <Grid>
                    <Grid.RowDefinitions>
                        <RowDefinition Height="Auto" />
                        <RowDefinition Height="*" />
                    </Grid.RowDefinitions>

                    <!--  Search input row  -->
                    <Border
                        Grid.Row="0"
                        Padding="16,12"
                        BorderBrush="{DynamicResource AppBorder}"
                        BorderThickness="0,0,0,1">
                        <DockPanel>
                            <ui:SymbolIcon Symbol="Search24" Margin="0,0,10,0" VerticalAlignment="Center" DockPanel.Dock="Left" FontSize="{StaticResource FontSizeLg}" Foreground="{DynamicResource AppTextMuted}" IsHitTestVisible="False" />
                            <ui:TextBox
                                x:Name="SearchPaletteInput"
                                VerticalContentAlignment="Center"
                                Background="Transparent"
                                BorderThickness="0"
                                FocusVisualStyle="{x:Null}"
                                FontFamily="{StaticResource FontBase}"
                                FontSize="{StaticResource FontSizeMd}"
                                Foreground="{DynamicResource AppTextPrimary}"
                                Text="{Binding SearchText, UpdateSourceTrigger=PropertyChanged}">
                                <TextBox.Style>
                                    <Style BasedOn="{StaticResource {x:Type TextBox}}" TargetType="TextBox">
                                        <Style.Triggers>
                                            <Trigger Property="Text" Value="">
                                                <Setter Property="Background">
                                                    <Setter.Value>
                                                        <VisualBrush
                                                            AlignmentX="Left"
                                                            AlignmentY="Center"
                                                            Stretch="None">
                                                            <VisualBrush.Visual>
                                                                <TextBlock
                                                                    FontFamily="{StaticResource FontBase}"
                                                                    FontSize="{StaticResource FontSizeMd}"
                                                                    Foreground="{DynamicResource AppTextMuted}"
                                                                    Text="{DynamicResource TitleBar.Search.Placeholder}" />
                                                            </VisualBrush.Visual>
                                                        </VisualBrush>
                                                    </Setter.Value>
                                                </Setter>
                                            </Trigger>
                                        </Style.Triggers>
                                    </Style>
                                </TextBox.Style>
                            </ui:TextBox>
                        </DockPanel>
                    </Border>

                    <!--  Results / hint  -->
                    <Grid Grid.Row="1">
                        <!--  Empty hint — shown when no results  -->
                        <TextBlock
                            Margin="16,16"
                            FontFamily="{StaticResource FontBase}"
                            FontSize="{StaticResource FontSizeSm}"
                            Foreground="{DynamicResource AppTextMuted}"
                            Text="{DynamicResource TitleBar.Search.Hint}"
                            Visibility="{Binding SearchResults.Count, Converter={StaticResource ZeroToVisibleConverter}}" />

                        <!--  Results list  -->
                        <ScrollViewer MaxHeight="360" VerticalScrollBarVisibility="Auto">
                            <ItemsControl Focusable="False" ItemsSource="{Binding SearchResults}">
                                <ItemsControl.ItemTemplate>
                                    <DataTemplate>
                                        <Border
                                            Padding="16,10"
                                            Background="Transparent"
                                            BorderBrush="{DynamicResource AppBorderLight}"
                                            BorderThickness="0,0,0,1"
                                            Cursor="Hand">
                                            <Grid>
                                                <Grid.ColumnDefinitions>
                                                    <ColumnDefinition Width="Auto" />
                                                    <ColumnDefinition Width="*" />
                                                    <ColumnDefinition Width="Auto" />
                                                </Grid.ColumnDefinitions>
                                                <TextBlock
                                                    Grid.Column="0"
                                                    MinWidth="60"
                                                    FontFamily="{StaticResource FontBase}"
                                                    FontSize="{StaticResource FontSizeBase}"
                                                    FontWeight="SemiBold"
                                                    Foreground="{DynamicResource AppTextPrimary}"
                                                    Text="{Binding Symbol}" />
                                                <TextBlock
                                                    Grid.Column="1"
                                                    Margin="12,0,0,0"
                                                    VerticalAlignment="Center"
                                                    FontFamily="{StaticResource FontBase}"
                                                    FontSize="{StaticResource FontSizeSm}"
                                                    Foreground="{DynamicResource AppTextSecondary}"
                                                    Text="{Binding Name}"
                                                    TextTrimming="CharacterEllipsis" />
                                                <TextBlock
                                                    Grid.Column="2"
                                                    Margin="8,0,0,0"
                                                    VerticalAlignment="Center"
                                                    FontFamily="{StaticResource FontBase}"
                                                    FontSize="{StaticResource FontSizeXs}"
                                                    Foreground="{DynamicResource AppTextMuted}"
                                                    Text="{Binding Exchange}" />
                                            </Grid>
                                        </Border>
                                    </DataTemplate>
                                </ItemsControl.ItemTemplate>
                            </ItemsControl>
                        </ScrollViewer>
                    </Grid>
                </Grid>
            </Border>
        </Popup>

        <!--  ── In-App Snackbar (ZIndex=15, bottom-center) ──  -->
        <snackbar:SnackbarView
            Grid.Row="1"
            Margin="0,0,0,16"
            HorizontalAlignment="Center"
            VerticalAlignment="Bottom"
            Panel.ZIndex="15"
            DataContext="{Binding Snackbar}" />

        <!--  ── Status Bar ──  -->
        <statusbar:StatusBarView Grid.Row="2" DataContext="{Binding StatusBar}" />

    </Grid>
</ui:FluentWindow>
