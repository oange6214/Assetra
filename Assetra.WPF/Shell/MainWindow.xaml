                        Grid.Row="1"
                        Style="{StaticResource AppDialogSubtitle}">
                        <Run Text="{DynamicResource Common.DeleteConfirmPrefix}" />
                        <Run Text="{Binding DeleteTargetName}" />
                        <Run Text="{DynamicResource Common.DeleteConfirmSuffix}" />
                    </TextBlock>

                    <StackPanel Grid.Row="2" Style="{StaticResource AppDialogFooter}">
                        <Button
                            Margin="0,0,8,0"
                            Command="{Binding CancelDeleteCommand}"
                            Content="{DynamicResource Common.Cancel}"
                            Style="{StaticResource AppSecondaryButton}" />
                        <Button
                            Command="{Binding ConfirmDeleteCommand}"
                            Content="{DynamicResource Common.Delete}"
                            Style="{StaticResource AppDangerButton}" />
                    </StackPanel>
                </Grid>
            </Border>
        </Grid>

        <!--  實物資產 (PhysicalAsset) — 新增 / 編輯表單  -->
        <Grid
            Grid.Row="0"
            Grid.RowSpan="3"
            Panel.ZIndex="186"
            DataContext="{Binding PhysicalAsset}"
            Style="{StaticResource AppDialogOverlay}"
            Visibility="{Binding IsFormOpen, Converter={StaticResource BooleanToVisibilityConverter}}">
            <Border
                Width="920"
                MaxHeight="680"
                HorizontalAlignment="Center"
                VerticalAlignment="Center"
                beh:EscapeKeyCommandBehavior.Command="{Binding CancelEditCommand}"
                Style="{StaticResource AppDialogShell}">
                <Grid>
                    <Grid.RowDefinitions>
                        <RowDefinition Height="Auto" />
                        <RowDefinition Height="Auto" />
                        <RowDefinition Height="Auto" />
                        <RowDefinition Height="Auto" />
                    </Grid.RowDefinitions>

                    <Grid Grid.Row="0" Margin="0,0,0,16">
                        <TextBlock
                            Margin="0,4,40,0"
                            VerticalAlignment="Center"
                            Style="{StaticResource FormSectionTitle}"
                            Text="{DynamicResource PhysicalAsset.Form.Title}" />
                        <Button
                            Width="32"
                            Height="32"
                            Margin="0,-4,-4,0"
                            Padding="0"
                            HorizontalAlignment="Right"
                            VerticalAlignment="Top"
                            Command="{Binding CancelEditCommand}"
                            Style="{StaticResource AppIconButton}"
                            ToolTip="{DynamicResource Common.Close}">
                            <ds:AppIcon FontSize="13" Symbol="Dismiss24" />
                        </Button>
                    </Grid>

                    <UniformGrid Grid.Row="1" Columns="2" Rows="5">
                        <StackPanel Margin="0,0,12,12">
                            <TextBlock Foreground="{DynamicResource AppTextSecondary}" Text="{DynamicResource PhysicalAsset.Form.Name}" />
                            <TextBox Style="{StaticResource AppTextBox}" Text="{Binding FormName, UpdateSourceTrigger=PropertyChanged}" />
                        </StackPanel>
                        <StackPanel Margin="0,0,0,12">
                            <TextBlock Foreground="{DynamicResource AppTextSecondary}" Text="{DynamicResource PhysicalAsset.Form.Category}" />
                            <ComboBox
                                DisplayMemberPath="DisplayName"
                                ItemsSource="{Binding CategoryOptions}"
                                SelectedValue="{Binding FormCategory, Mode=TwoWay}"
                                SelectedValuePath="Value"
                                Style="{StaticResource AppComboBox}" />
                        </StackPanel>
                        <StackPanel Margin="0,0,12,12">
                            <TextBlock Foreground="{DynamicResource AppTextSecondary}" Text="{DynamicResource PhysicalAsset.Form.Description}" />
                            <TextBox Style="{StaticResource AppTextBox}" Text="{Binding FormDescription, UpdateSourceTrigger=PropertyChanged}" />
                        </StackPanel>
                        <StackPanel Margin="0,0,0,12">
                            <TextBlock Foreground="{DynamicResource AppTextSecondary}" Text="{DynamicResource PhysicalAsset.Form.Cost}" />
                            <TextBox Style="{StaticResource AppTextBox}"
                                beh:ThousandSeparatorBehavior.IsEnabled="True"
                                Text="{Binding FormAcquisitionCost, UpdateSourceTrigger=PropertyChanged}" />
                        </StackPanel>
                        <StackPanel Margin="0,0,12,12">
                            <TextBlock Foreground="{DynamicResource AppTextSecondary}" Text="{DynamicResource PhysicalAsset.Form.AcquisitionDate}" />
                            <DatePicker
                                MinWidth="132"
                                HorizontalContentAlignment="Left"
                                SelectedDate="{Binding FormAcquisitionDate, Mode=TwoWay}"
                                Style="{StaticResource AppDatePicker}" />
                        </StackPanel>
                        <StackPanel Margin="0,0,0,12">
                            <TextBlock Foreground="{DynamicResource AppTextSecondary}" Text="{DynamicResource PhysicalAsset.Form.CurrentValue}" />
                            <TextBox Style="{StaticResource AppTextBox}"
                                beh:ThousandSeparatorBehavior.IsEnabled="True"
                                Text="{Binding FormCurrentValue, UpdateSourceTrigger=PropertyChanged}" />
                        </StackPanel>
                        <StackPanel Margin="0,0,12,12">
                            <TextBlock Foreground="{DynamicResource AppTextSecondary}" Text="{DynamicResource PhysicalAsset.Form.ValuationMethod}" />
                            <TextBox Style="{StaticResource AppTextBox}" Text="{Binding FormValuationMethod, UpdateSourceTrigger=PropertyChanged}" />
                        </StackPanel>
                        <StackPanel Margin="0,0,0,12">
                            <TextBlock Foreground="{DynamicResource AppTextSecondary}" Text="{DynamicResource PhysicalAsset.Form.Currency}" />
                            <TextBox Style="{StaticResource AppTextBox}" Text="{Binding FormCurrency, UpdateSourceTrigger=PropertyChanged}" />
                        </StackPanel>
                        <StackPanel Margin="0,0,12,0">
                            <TextBlock Foreground="{DynamicResource AppTextSecondary}" Text="{DynamicResource PhysicalAsset.Form.Notes}" />
                            <TextBox Style="{StaticResource AppTextBox}" Text="{Binding FormNotes, UpdateSourceTrigger=PropertyChanged}" />
                        </StackPanel>
                    </UniformGrid>

                    <TextBlock
                        Grid.Row="2"
                        Margin="0,8,0,0"
                        Foreground="{DynamicResource AppDanger}"
                        Text="{Binding FormError}"
                        Visibility="{Binding FormError, Converter={StaticResource NullToVisibilityConverter}}" />

                    <StackPanel
                        Grid.Row="3"
                        Margin="0,16,0,0"
                        HorizontalAlignment="Right"
                        Orientation="Horizontal">
                        <Button
                            Margin="0,0,8,0"
                            Command="{Binding CancelEditCommand}"
                            Content="{DynamicResource Common.Cancel}"
                            Style="{StaticResource AppSecondaryButton}" />
                        <Button Command="{Binding SaveCommand}" Style="{StaticResource AppPrimaryButton}">
                            <TextBlock
                                Foreground="{Binding Foreground, RelativeSource={RelativeSource AncestorType=Button}}"
                                Text="{DynamicResource Common.Save}" />
                        </Button>
                    </StackPanel>
                </Grid>
            </Border>
        </Grid>

        <!--  實物資產 — 刪除確認  -->
        <Grid
            Grid.Row="0"
            Grid.RowSpan="3"
            Panel.ZIndex="187"
            DataContext="{Binding PhysicalAsset}"
            Style="{StaticResource AppDialogOverlay}"
            Visibility="{Binding IsDeleteConfirmOpen, Converter={StaticResource BooleanToVisibilityConverter}}">
            <Border
                HorizontalAlignment="Center"
                VerticalAlignment="Center"
                beh:EscapeKeyCommandBehavior.Command="{Binding CancelDeleteCommand}"
                Style="{StaticResource AppDestructiveDialogShell}">
                <Grid>
                    <Grid.RowDefinitions>
                        <RowDefinition Height="Auto" />
                        <RowDefinition Height="Auto" />
                        <RowDefinition Height="Auto" />
                    </Grid.RowDefinitions>

                    <TextBlock Style="{StaticResource AppDialogTitle}" Text="{DynamicResource Common.DeleteConfirmTitle}" />
                    <TextBlock
                        Grid.Row="1"
                        Style="{StaticResource AppDialogSubtitle}">
                        <Run Text="{DynamicResource Common.DeleteConfirmPrefix}" />
                        <Run Text="{Binding DeleteTargetName}" />
                        <Run Text="{DynamicResource Common.DeleteConfirmSuffix}" />
                    </TextBlock>

                    <StackPanel Grid.Row="2" Style="{StaticResource AppDialogFooter}">
                        <Button
                            Margin="0,0,8,0"
                            Command="{Binding CancelDeleteCommand}"
                            Content="{DynamicResource Common.Cancel}"
                            Style="{StaticResource AppSecondaryButton}" />
                        <Button
                            Command="{Binding ConfirmDeleteCommand}"
                            Content="{DynamicResource Common.Delete}"
                            Style="{StaticResource AppDangerButton}" />
                    </StackPanel>
                </Grid>
            </Border>
        </Grid>

        <!--
            警示 (Alerts) — 新增 / 刪除 dialogs。模組性較高的頁面把所有 modal
            打包進獨立 UserControl，避免 MainWindow.xaml 過度膨脹（vs. 上面
            4 個 asset view 直接 inline 的作法）。
        -->
        <alerts:AlertsDialogsHost
            Grid.Row="0"
            Grid.RowSpan="3"
            Panel.ZIndex="188"
            DataContext="{Binding Alerts}" />

        <!--  訂閱排程 (Recurring) — 新增 / 刪除 dialogs  -->
        <recurring:RecurringDialogsHost
            Grid.Row="0"
            Grid.RowSpan="3"
            Panel.ZIndex="189"
            DataContext="{Binding Recurring}" />

        <!--  收支分類 (Categories) — 新增分類 / 規則 / 預算 + 刪除確認 dialogs  -->
        <categories:CategoriesDialogsHost
            Grid.Row="0"
            Grid.RowSpan="3"
            Panel.ZIndex="190"
            DataContext="{Binding Categories}" />

        <!--  財務目標 (Goals) — 新增 / 編輯 + 刪除確認 dialogs  -->
        <goals:GoalsDialogsHost
            Grid.Row="0"
            Grid.RowSpan="3"
            Panel.ZIndex="191"
            DataContext="{Binding Goals}" />

        <!--
            對帳 (Reconciliation) — 只有刪除確認一個 modal，直接 inline
            而不另開 host UserControl。
        -->
        <Grid
            Grid.Row="0"
            Grid.RowSpan="3"
            Panel.ZIndex="192"
            DataContext="{Binding Reconciliation}"
            Style="{StaticResource AppDialogOverlay}"
            Visibility="{Binding IsDeleteConfirmOpen, Converter={StaticResource BooleanToVisibilityConverter}}">
            <Border
                HorizontalAlignment="Center"
                VerticalAlignment="Center"
                beh:EscapeKeyCommandBehavior.Command="{Binding CancelDeleteCommand}"
                Style="{StaticResource AppDestructiveDialogShell}">
                <Grid>
                    <Grid.RowDefinitions>
                        <RowDefinition Height="Auto" />
                        <RowDefinition Height="Auto" />
                        <RowDefinition Height="Auto" />
                    </Grid.RowDefinitions>

                    <TextBlock Style="{StaticResource AppDialogTitle}" Text="{DynamicResource Common.DeleteConfirmTitle}" />
                    <TextBlock
                        Grid.Row="1"
                        Style="{StaticResource AppDialogSubtitle}">
                        <Run Text="{DynamicResource Common.DeleteConfirmPrefix}" />
                        <Run Text="{Binding DeleteTargetName}" />
                        <Run Text="{DynamicResource Common.DeleteConfirmSuffix}" />
                    </TextBlock>

                    <StackPanel Grid.Row="2" Style="{StaticResource AppDialogFooter}">
                        <Button
                            Margin="0,0,8,0"
                            Command="{Binding CancelDeleteCommand}"
                            Content="{DynamicResource Common.Cancel}"
                            Style="{StaticResource AppSecondaryButton}" />
                        <Button
                            Command="{Binding ConfirmDeleteCommand}"
                            Content="{DynamicResource Common.Delete}"
                            Style="{StaticResource AppDangerButton}" />
                    </StackPanel>
                </Grid>
            </Border>
        </Grid>

        <!--
            設定 — 兩個 help dialog (Fugle / TwelveData API)。Dialogs 本身已是
            UserControl，這裡只是把它們的掛載點從 SettingsView 內部移到 MainWindow，
            讓 backdrop 蓋住整個視窗。DataContext = SettingsViewModel。
        -->
        <settingsCtrls:FugleHelpDialog
            Grid.Row="0"
            Grid.RowSpan="3"
            Panel.ZIndex="193"
            DataContext="{Binding Settings}" />
        <settingsCtrls:TwelveDataHelpDialog
            Grid.Row="0"
            Grid.RowSpan="3"
            Panel.ZIndex="194"
            DataContext="{Binding Settings}" />

        <!--
            Allocation 編輯目標 overlay — 同樣已是 UserControl，外提以讓 backdrop 蓋全視窗。
        -->
        <pcontrols:EditTargetsOverlay
            Grid.Row="0"
            Grid.RowSpan="3"
            Panel.ZIndex="195"
            DataContext="{Binding Allocation}" />

        <!--  不動產 — 刪除確認  -->
        <Grid
            Grid.Row="0"
            Grid.RowSpan="3"
            Panel.ZIndex="181"
            DataContext="{Binding RealEstate}"
            Style="{StaticResource AppDialogOverlay}"
            Visibility="{Binding IsDeleteConfirmOpen, Converter={StaticResource BooleanToVisibilityConverter}}">
            <Border
                HorizontalAlignment="Center"
                VerticalAlignment="Center"
                beh:EscapeKeyCommandBehavior.Command="{Binding CancelDeleteCommand}"
                Style="{StaticResource AppDestructiveDialogShell}">
                <Grid>
                    <Grid.RowDefinitions>
                        <RowDefinition Height="Auto" />
                        <RowDefinition Height="Auto" />
                        <RowDefinition Height="Auto" />
                    </Grid.RowDefinitions>

                    <TextBlock Style="{StaticResource AppDialogTitle}" Text="{DynamicResource Common.DeleteConfirmTitle}" />
                    <TextBlock
                        Grid.Row="1"
                        Style="{StaticResource AppDialogSubtitle}">
                        <Run Text="{DynamicResource Common.DeleteConfirmPrefix}" />
                        <Run Text="{Binding DeleteTargetName}" />
                        <Run Text="{DynamicResource Common.DeleteConfirmSuffix}" />
                    </TextBlock>

                    <StackPanel Grid.Row="2" Style="{StaticResource AppDialogFooter}">
                        <Button
                            Margin="0,0,8,0"
                            Command="{Binding CancelDeleteCommand}"
                            Content="{DynamicResource Common.Cancel}"
                            Style="{StaticResource AppSecondaryButton}" />
                        <Button
                            Command="{Binding ConfirmDeleteCommand}"
                            Content="{DynamicResource Common.Delete}"
                            Style="{StaticResource AppDangerButton}" />
                    </StackPanel>
                </Grid>
            </Border>
        </Grid>

    </Grid>
</Window>
