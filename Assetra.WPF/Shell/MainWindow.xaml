<Window
    x:Class="Assetra.WPF.Shell.MainWindow"
    xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
    xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
    xmlns:beh="clr-namespace:Assetra.WPF.Infrastructure.Behaviors"
    xmlns:chrome="clr-namespace:System.Windows.Shell;assembly=PresentationFramework"
    xmlns:d="http://schemas.microsoft.com/expression/blend/2008"
    xmlns:ds="clr-namespace:Assetra.WPF.DesignSystem.Controls"
    xmlns:mc="http://schemas.openxmlformats.org/markup-compatibility/2006"
    xmlns:alerts="clr-namespace:Assetra.WPF.Features.Alerts"
    xmlns:categories="clr-namespace:Assetra.WPF.Features.Categories"
    xmlns:goals="clr-namespace:Assetra.WPF.Features.Goals"
    xmlns:pcontrols="clr-namespace:Assetra.WPF.Features.Portfolio.Controls"
    xmlns:recurring="clr-namespace:Assetra.WPF.Features.Recurring"
    xmlns:settingsCtrls="clr-namespace:Assetra.WPF.Features.Settings.Controls"
    xmlns:shell="clr-namespace:Assetra.WPF.Shell"
    xmlns:snackbar="clr-namespace:Assetra.WPF.Features.Snackbar"
    xmlns:statusbar="clr-namespace:Assetra.WPF.Features.StatusBar"
    x:Name="MainShell"
    Title="{DynamicResource App.Title}"
    Width="1600"
    Height="1000"
    MinWidth="900"
    MinHeight="800"
    Background="{DynamicResource AppBackground}"
    Icon="pack://application:,,,/Assetra.WPF;component/Assets/windows/assetra-app.ico"
    ResizeMode="CanResize"
    WindowStartupLocation="CenterScreen"
    WindowStyle="None"
    mc:Ignorable="d">

    <chrome:WindowChrome.WindowChrome>
        <chrome:WindowChrome
            CaptionHeight="48"
            CornerRadius="0"
            GlassFrameThickness="0"
            ResizeBorderThickness="6"
            UseAeroCaptionButtons="False" />
    </chrome:WindowChrome.WindowChrome>

    <!--  Keyboard shortcuts  -->
    <Window.InputBindings>
        <KeyBinding
            Key="K"
            Command="{Binding ToggleSearchCommand}"
            Modifiers="Ctrl" />
        <!--
            P2.12 — Ctrl+Shift+K = Command Palette (navigate / quick actions).
            Ctrl+K stays as global stock search (existing convention)，因為兩者
            mental model 不同：stock 搜尋是查 asset，command palette 是執行動作。
        -->
        <KeyBinding
            Key="K"
            Command="{Binding ToggleCommandPaletteCommand}"
            Modifiers="Ctrl+Shift" />
        <!--  P2.17 T04 — Ctrl+/ = Keyboard shortcuts help (VS Code 慣例)。  -->
        <KeyBinding
            Key="OemQuestion"
            Command="{Binding ToggleShortcutsHelpCommand}"
            Modifiers="Ctrl" />
        <KeyBinding
            Key="Left"
            Command="{Binding NavRail.GoBackCommand}"
            Modifiers="Alt" />
        <KeyBinding
            Key="Right"
            Command="{Binding NavRail.GoForwardCommand}"
            Modifiers="Alt" />
        <!--  Ctrl+N: quick add transaction. The title-bar button itself opens the broader add menu.  -->
        <KeyBinding
            Key="N"
            Command="{Binding Portfolio.AddRecordCommand}"
            Modifiers="Ctrl" />
        <!--  Ctrl+1..6: 跳到主要分頁（高頻使用率排序）  -->
        <KeyBinding
            Key="D1"
            Command="{Binding NavRail.NavigateToByNameCommand}"
            CommandParameter="FinancialOverview"
            Modifiers="Ctrl" />
        <KeyBinding
            Key="D2"
            Command="{Binding NavRail.NavigateToByNameCommand}"
            CommandParameter="Portfolio"
            Modifiers="Ctrl" />
        <KeyBinding
            Key="D3"
            Command="{Binding NavRail.NavigateToByNameCommand}"
            CommandParameter="TransactionLog"
            Modifiers="Ctrl" />
        <KeyBinding
            Key="D4"
            Command="{Binding NavRail.NavigateToByNameCommand}"
            CommandParameter="Reports"
            Modifiers="Ctrl" />
        <KeyBinding
            Key="D5"
            Command="{Binding NavRail.NavigateToByNameCommand}"
            CommandParameter="Categories"
            Modifiers="Ctrl" />
        <KeyBinding
            Key="D6"
            Command="{Binding NavRail.NavigateToByNameCommand}"
            CommandParameter="Assistant"
            Modifiers="Ctrl" />
    </Window.InputBindings>

    <Grid Background="{DynamicResource AppBackground}">
        <Grid.LayoutTransform>
            <ScaleTransform ScaleX="{Binding Settings.UiScale}" ScaleY="{Binding Settings.UiScale}" />
        </Grid.LayoutTransform>
        <Grid.RowDefinitions>
            <RowDefinition Height="Auto" />
            <!--  TitleBar  -->
            <RowDefinition Height="*" />
            <!--  NavRail + Content  -->
            <RowDefinition Height="Auto" />
            <!--  Status bar  -->
        </Grid.RowDefinitions>

        <!--  ── Title Bar ──  -->
        <Border
            Grid.Row="0"
            Background="{DynamicResource AppSurface}"
            BorderBrush="{DynamicResource AppBorderLight}"
            BorderThickness="0,0,0,1">
            <Grid Height="48" VerticalAlignment="Center">
                <Grid.ColumnDefinitions>
                    <ColumnDefinition Width="Auto" />
                    <ColumnDefinition Width="Auto" />
                    <ColumnDefinition Width="*" />
                    <ColumnDefinition Width="Auto" />
                    <ColumnDefinition Width="Auto" />
                </Grid.ColumnDefinitions>

                <!--
                    P2.11 — Brand block：Logo + 「Assetra」 文字組成一個視覺整體。原本 Logo
                    在最左、App.Title 飄在 column 2 中段，視覺上沒有連結 (audit 文件指出像
                    placeholder)。合併到同一個 StackPanel + Display font + slightly tracked
                    spacing → 完整 brand presence。Cursor 預設 (drag region 仍走 WindowChrome)，
                    不額外加 hover/click。
                -->
                <StackPanel
                    Grid.Column="0"
                    Margin="14,0,12,0"
                    VerticalAlignment="Center"
                    Orientation="Horizontal">
                    <Image
                        Width="22"
                        Height="22"
                        VerticalAlignment="Center"
                        Source="{StaticResource AssetraLogo}" />
                    <TextBlock
                        Margin="8,0,0,0"
                        VerticalAlignment="Center"
                        FontFamily="{StaticResource Font.Family.Display}"
                        FontSize="{StaticResource Font.Size.Base}"
                        FontWeight="SemiBold"
                        Foreground="{DynamicResource AppTextPrimary}"
                        Text="{DynamicResource App.Title}" />
                </StackPanel>

                <!--  Left: Back / Forward / Search  -->
                <StackPanel
                    Grid.Column="1"
                    VerticalAlignment="Center"
                    chrome:WindowChrome.IsHitTestVisibleInChrome="True"
                    Orientation="Horizontal">
                    <Button
                        Width="32"
                        Height="32"
                        Margin="0,0,0,0"
                        Padding="0"
                        Command="{Binding NavRail.GoBackCommand}"
                        IsEnabled="{Binding NavRail.CanGoBack}"
                        Style="{StaticResource AppIconButton}"
                        ToolTip="{DynamicResource Nav.GoBack}"
                        ToolTipService.ShowOnDisabled="True">
                        <ds:AppIcon
                            FontSize="{StaticResource Font.Size.Base}"
                            Foreground="{DynamicResource AppTextMuted}"
                            Symbol="ChevronLeft24" />
                    </Button>
                    <Button
                        Width="32"
                        Height="32"
                        Margin="2,0,0,0"
                        Padding="0"
                        Command="{Binding NavRail.GoForwardCommand}"
                        IsEnabled="{Binding NavRail.CanGoForward}"
                        Style="{StaticResource AppIconButton}"
                        ToolTip="{DynamicResource Nav.GoForward}"
                        ToolTipService.ShowOnDisabled="True">
                        <ds:AppIcon
                            FontSize="{StaticResource Font.Size.Base}"
                            Foreground="{DynamicResource AppTextMuted}"
                            Symbol="ChevronRight24" />
                    </Button>
                    <Button
                        x:Name="SearchIconBtn"
                        Width="32"
                        Height="32"
                        Margin="8,0,0,0"
                        Padding="0"
                        Command="{Binding ToggleSearchCommand}"
                        Style="{StaticResource AppIconButton}"
                        ToolTip="Ctrl+K">
                        <ds:AppIcon
                            FontSize="{StaticResource Font.Size.Md}"
                            Foreground="{DynamicResource AppTextMuted}"
                            Symbol="Search24" />
                    </Button>
                </StackPanel>

                <!--
                    Column 2 stretch — empty drag region (window chrome handles dragging).
                    原本這欄有重複的 App.Title TextBlock；brand block 已移到 column 0
                    跟 Logo 合併，這裡留空當作 drag handle 即可。
                -->
                <Grid Grid.Column="2" />

                <!--  Right: global app actions. Native window commands live in the final column so they never get clipped first.  -->
                <StackPanel
                    Grid.Column="3"
                    Margin="0,0,8,0"
                    VerticalAlignment="Center"
                    chrome:WindowChrome.IsHitTestVisibleInChrome="True"
                    Orientation="Horizontal">
                    <!--
                        Global "Add" menu — high-frequency creation actions are reachable
                        from every section. Ctrl+N remains a direct shortcut for adding a
                        transaction; the button opens the broader menu.
                    -->
                    <!--
                        v0.28+ UX：title-bar「+ 新增」dropdown，列出常見新增動作。
                        每個 menu item 切到對應頁面並開啟正確的 dialog，解決使用者
                        「新增的資料去哪了」的困惑。
                        實作：Button.Click 程式化開啟 ContextMenu。
                        
                        UI refresh：原本是填色（AppPrimaryButton），跟旁邊的小巧
                        icon button（主題切換 / 最小化 / 關閉）視覺重量不一致 —
                        title bar 是 shell 區域，不該被一顆深色 CTA 主導。改用
                        icon-only style（Add24 + 小 chevron 提示有 dropdown），與
                        旁邊一致。tooltip 顯示完整意圖，發現性靠 hover 即可。
                    -->
                    <Button
                        x:Name="AddMenuButton"
                        Width="44"
                        Height="32"
                        Margin="0,0,4,0"
                        Padding="0"
                        Click="AddMenuButton_Click"
                        Style="{StaticResource AppIconButton}"
                        ToolTip="{DynamicResource Portfolio.AddRecord.Tooltip}">
                        <StackPanel
                            HorizontalAlignment="Center"
                            VerticalAlignment="Center"
                            Orientation="Horizontal">
                            <ds:AppIcon
                                FontSize="{StaticResource Font.Size.Md}"
                                Foreground="{DynamicResource AppTextMuted}"
                                Symbol="Add24" />
                            <ds:AppIcon
                                Margin="2,0,0,0"
                                FontSize="9"
                                Foreground="{DynamicResource AppTextMuted}"
                                Symbol="ChevronDown24" />
                        </StackPanel>
                        <Button.ContextMenu>
                            <ContextMenu DataContext="{Binding PlacementTarget.DataContext, RelativeSource={RelativeSource Self}}" Placement="Bottom">
                                <MenuItem Command="{Binding AddTransactionFromMenuCommand}">
                                    <MenuItem.Header>
                                        <StackPanel>
                                            <TextBlock FontWeight="SemiBold" Text="{DynamicResource Portfolio.AddRecord.Menu.Transaction}" />
                                            <TextBlock
                                                FontSize="{StaticResource Font.Size.Xs}"
                                                Foreground="{DynamicResource AppTextMuted}"
                                                Text="{DynamicResource Portfolio.AddRecord.Menu.Transaction.Hint}" />
                                        </StackPanel>
                                    </MenuItem.Header>
                                </MenuItem>
                                <!--
                                    「新增買入交易」已移除 — 「新增交易」已涵蓋（dialog 內可選交易類型）。
                                    對應的 AddBuyTransactionFromMenuCommand + 兩個 lang key 一併拿掉。
                                -->
                                <Separator />
                                <MenuItem Command="{Binding AddAccountFromMenuCommand}">
                                    <MenuItem.Header>
                                        <StackPanel>
                                            <TextBlock FontWeight="SemiBold" Text="{DynamicResource Portfolio.AddRecord.Menu.Account}" />
                                            <TextBlock
                                                FontSize="{StaticResource Font.Size.Xs}"
                                                Foreground="{DynamicResource AppTextMuted}"
                                                Text="{DynamicResource Portfolio.AddRecord.Menu.Account.Hint}" />
                                        </StackPanel>
                                    </MenuItem.Header>
                                </MenuItem>
                                <MenuItem Command="{Binding AddLiabilityFromMenuCommand}">
                                    <MenuItem.Header>
                                        <StackPanel>
                                            <TextBlock FontWeight="SemiBold" Text="{DynamicResource Portfolio.AddRecord.Menu.Liability}" />
                                            <TextBlock
                                                FontSize="{StaticResource Font.Size.Xs}"
                                                Foreground="{DynamicResource AppTextMuted}"
                                                Text="{DynamicResource Portfolio.AddRecord.Menu.Liability.Hint}" />
                                        </StackPanel>
                                    </MenuItem.Header>
                                </MenuItem>
                                <!--
                                    其他四類資產（不動產 / 保險 / 退休 / 實物）— 與 NavRail 一致，
                                    讓 quick-add menu 對齊側邊欄資產分類，避免要回首頁才能找入口。
                                -->
                                <MenuItem Command="{Binding AddRealEstateFromMenuCommand}">
                                    <MenuItem.Header>
                                        <StackPanel>
                                            <TextBlock FontWeight="SemiBold" Text="{DynamicResource Portfolio.AddRecord.Menu.RealEstate}" />
                                            <TextBlock
                                                FontSize="{StaticResource Font.Size.Xs}"
                                                Foreground="{DynamicResource AppTextMuted}"
                                                Text="{DynamicResource Portfolio.AddRecord.Menu.RealEstate.Hint}" />
                                        </StackPanel>
                                    </MenuItem.Header>
                                </MenuItem>
                                <MenuItem Command="{Binding AddInsuranceFromMenuCommand}">
                                    <MenuItem.Header>
                                        <StackPanel>
                                            <TextBlock FontWeight="SemiBold" Text="{DynamicResource Portfolio.AddRecord.Menu.Insurance}" />
                                            <TextBlock
                                                FontSize="{StaticResource Font.Size.Xs}"
                                                Foreground="{DynamicResource AppTextMuted}"
                                                Text="{DynamicResource Portfolio.AddRecord.Menu.Insurance.Hint}" />
                                        </StackPanel>
                                    </MenuItem.Header>
                                </MenuItem>
                                <MenuItem Command="{Binding AddRetirementFromMenuCommand}">
                                    <MenuItem.Header>
                                        <StackPanel>
                                            <TextBlock FontWeight="SemiBold" Text="{DynamicResource Portfolio.AddRecord.Menu.Retirement}" />
                                            <TextBlock
                                                FontSize="{StaticResource Font.Size.Xs}"
                                                Foreground="{DynamicResource AppTextMuted}"
                                                Text="{DynamicResource Portfolio.AddRecord.Menu.Retirement.Hint}" />
                                        </StackPanel>
                                    </MenuItem.Header>
                                </MenuItem>
                                <MenuItem Command="{Binding AddPhysicalAssetFromMenuCommand}">
                                    <MenuItem.Header>
                                        <StackPanel>
                                            <TextBlock FontWeight="SemiBold" Text="{DynamicResource Portfolio.AddRecord.Menu.PhysicalAsset}" />
                                            <TextBlock
                                                FontSize="{StaticResource Font.Size.Xs}"
                                                Foreground="{DynamicResource AppTextMuted}"
                                                Text="{DynamicResource Portfolio.AddRecord.Menu.PhysicalAsset.Hint}" />
                                        </StackPanel>
                                    </MenuItem.Header>
                                </MenuItem>
                                <MenuItem Command="{Binding AddCategoryFromMenuCommand}">
                                    <MenuItem.Header>
                                        <StackPanel>
                                            <TextBlock FontWeight="SemiBold" Text="{DynamicResource Portfolio.AddRecord.Menu.Category}" />
                                            <TextBlock
                                                FontSize="{StaticResource Font.Size.Xs}"
                                                Foreground="{DynamicResource AppTextMuted}"
                                                Text="{DynamicResource Portfolio.AddRecord.Menu.Category.Hint}" />
                                        </StackPanel>
                                    </MenuItem.Header>
                                </MenuItem>
                                <Separator />
                                <MenuItem Command="{Binding AddRecurringFromMenuCommand}">
                                    <MenuItem.Header>
                                        <StackPanel>
                                            <TextBlock FontWeight="SemiBold" Text="{DynamicResource Portfolio.AddRecord.Menu.Recurring}" />
                                            <TextBlock
                                                FontSize="{StaticResource Font.Size.Xs}"
                                                Foreground="{DynamicResource AppTextMuted}"
                                                Text="{DynamicResource Portfolio.AddRecord.Menu.Recurring.Hint}" />
                                        </StackPanel>
                                    </MenuItem.Header>
                                </MenuItem>
                                <MenuItem Command="{Binding AddAlertFromMenuCommand}">
                                    <MenuItem.Header>
                                        <StackPanel>
                                            <TextBlock FontWeight="SemiBold" Text="{DynamicResource Portfolio.AddRecord.Menu.Alert}" />
                                            <TextBlock
                                                FontSize="{StaticResource Font.Size.Xs}"
                                                Foreground="{DynamicResource AppTextMuted}"
                                                Text="{DynamicResource Portfolio.AddRecord.Menu.Alert.Hint}" />
                                        </StackPanel>
                                    </MenuItem.Header>
                                </MenuItem>
                                <MenuItem Command="{Binding AddGoalFromMenuCommand}">
                                    <MenuItem.Header>
                                        <StackPanel>
                                            <TextBlock FontWeight="SemiBold" Text="{DynamicResource Portfolio.AddRecord.Menu.Goal}" />
                                            <TextBlock
                                                FontSize="{StaticResource Font.Size.Xs}"
                                                Foreground="{DynamicResource AppTextMuted}"
                                                Text="{DynamicResource Portfolio.AddRecord.Menu.Goal.Hint}" />
                                        </StackPanel>
                                    </MenuItem.Header>
                                </MenuItem>
                            </ContextMenu>
                        </Button.ContextMenu>
                    </Button>
                    <Button
                        Width="32"
                        Height="32"
                        Padding="0"
                        Command="{Binding ToggleThemeCommand}"
                        Style="{StaticResource AppIconButton}"
                        ToolTip="{Binding ThemeToggleLabel}">
                        <ds:AppIcon FontSize="{StaticResource Font.Size.Md}" Foreground="{DynamicResource AppTextMuted}">
                            <ds:AppIcon.Style>
                                <Style BasedOn="{StaticResource AppIcon}" TargetType="{x:Type ds:AppIcon}">
                                    <Setter Property="Symbol" Value="WeatherSunny24" />
                                    <Style.Triggers>
                                        <DataTrigger Binding="{Binding CurrentTheme}" Value="Dark">
                                            <Setter Property="Symbol" Value="WeatherMoon24" />
                                        </DataTrigger>
                                    </Style.Triggers>
                                </Style>
                            </ds:AppIcon.Style>
                        </ds:AppIcon>
                    </Button>
                </StackPanel>

                <!--  Native window commands: highest priority on narrow widths.  -->
                <StackPanel
                    Grid.Column="4"
                    Margin="0,0,8,0"
                    VerticalAlignment="Center"
                    chrome:WindowChrome.IsHitTestVisibleInChrome="True"
                    Orientation="Horizontal">
                    <Button
                        Width="40"
                        Height="32"
                        Margin="0"
                        Padding="0"
                        Click="MinimizeButton_Click"
                        Style="{StaticResource AppIconButton}"
                        ToolTip="Minimize">
                        <ds:AppIcon
                            FontSize="{StaticResource Font.Size.Sm}"
                            Foreground="{DynamicResource AppTextMuted}"
                            Symbol="Subtract24" />
                    </Button>
                    <Button
                        Width="40"
                        Height="32"
                        Margin="2,0,0,0"
                        Padding="0"
                        Click="MaximizeRestoreButton_Click"
                        Style="{StaticResource AppIconButton}"
                        ToolTip="Maximize">
                        <ds:AppIcon FontSize="{StaticResource Font.Size.Sm}" Foreground="{DynamicResource AppTextMuted}">
                            <ds:AppIcon.Style>
                                <Style BasedOn="{StaticResource AppIcon}" TargetType="{x:Type ds:AppIcon}">
                                    <Setter Property="Symbol" Value="Square24" />
                                    <Style.Triggers>
                                        <DataTrigger Binding="{Binding WindowState, ElementName=MainShell}" Value="Maximized">
                                            <!--
                                                Two overlapping squares = restore-down (Win 11 standard).
                                                Use SquareMultiple — the FluentSystemIcons enum has
                                                no "WindowMultiple", which previously fell through to
                                                the empty-glyph branch and rendered nothing.
                                            -->
                                            <Setter Property="Symbol" Value="SquareMultiple24" />
                                        </DataTrigger>
                                    </Style.Triggers>
                                </Style>
                            </ds:AppIcon.Style>
                        </ds:AppIcon>
                    </Button>
                    <Button
                        Width="40"
                        Height="32"
                        Margin="2,0,0,0"
                        Padding="0"
                        Click="CloseButton_Click"
                        Style="{StaticResource AppWindowCloseButton}"
                        ToolTip="Close">
                        <!--
                            Icon Foreground 綁 parent Button.Foreground → 跟著 style trigger
                            走 (idle=AppTextMuted、hover=White)。預設不能 hard-code 顏色
                            否則 hover 紅底配灰 icon 不協調。
                        -->
                        <ds:AppIcon
                            FontSize="{StaticResource Font.Size.Sm}"
                            Foreground="{Binding Foreground, RelativeSource={RelativeSource AncestorType=Button}}"
                            Symbol="Dismiss24" />
                    </Button>
                </StackPanel>
            </Grid>
        </Border>

        <!--  ── Row 1: NavRailView pane + section content ──  -->
        <shell:NavRailView Grid.Row="1" />

        <!--  Search backdrop — sits above content, behind the popup HWnd  -->
        <Border
            x:Name="SearchBackdrop"
            Grid.Row="0"
            Grid.RowSpan="3"
            Panel.ZIndex="8"
            Background="Black"
            MouseDown="SearchBackdrop_MouseDown"
            Opacity="0.35"
            Visibility="{Binding IsSearchOpen, Converter={StaticResource BooleanToVisibilityConverter}}" />

        <!--  ── Search / Command Palette Popup (centered at top; dismiss on outside click) ──  -->
        <Popup
            x:Name="SearchPopup"
            AllowsTransparency="True"
            IsOpen="{Binding IsSearchOpen, Mode=TwoWay}"
            Placement="Custom"
            PlacementTarget="{Binding ElementName=MainShell}"
            PopupAnimation="Fade"
            StaysOpen="False">
            <!--
                P2.17 T13 — Search popup border lightened (AppBorder → AppBorderLight)
                跟 Command Palette popup 一致；兩個 popup 共用同一個視覺語言 (modal
                overlay shape + light edges + same backdrop opacity)。
            -->
            <Border
                MaxHeight="440"
                Margin="12"
                Background="{DynamicResource AppSurface}"
                BorderBrush="{DynamicResource AppBorderLight}"
                BorderThickness="1"
                CornerRadius="{StaticResource Radius.Lg}">
                <Border.Width>
                    <MultiBinding Converter="{StaticResource AdaptivePanelWidthConverter}" ConverterParameter="0.52|360|620">
                        <Binding ElementName="MainShell" Path="ActualWidth" />
                        <Binding Path="Settings.UiScale" />
                    </MultiBinding>
                </Border.Width>
                <Grid>
                    <Grid.RowDefinitions>
                        <RowDefinition Height="Auto" />
                        <RowDefinition Height="*" />
                    </Grid.RowDefinitions>

                    <!--  Search input row  -->
                    <Border
                        Grid.Row="0"
                        Padding="16,12"
                        BorderBrush="{DynamicResource AppBorderLight}"
                        BorderThickness="0,0,0,1">
                        <DockPanel>
                            <ds:AppIcon
                                Margin="0,0,10,0"
                                VerticalAlignment="Center"
                                DockPanel.Dock="Left"
                                FontSize="{StaticResource Font.Size.Lg}"
                                Foreground="{DynamicResource AppTextMuted}"
                                IsHitTestVisible="False"
                                Symbol="Search24" />
                            <TextBox
                                x:Name="SearchPaletteInput"
                                VerticalContentAlignment="Center"
                                Background="Transparent"
                                BorderThickness="0"
                                FocusVisualStyle="{x:Null}"
                                FontFamily="{StaticResource Font.Family.Base}"
                                FontSize="{StaticResource Font.Size.Md}"
                                Foreground="{DynamicResource AppTextPrimary}"
                                Text="{Binding SearchText, UpdateSourceTrigger=PropertyChanged}">
                                <TextBox.Style>
                                    <Style BasedOn="{StaticResource {x:Type TextBox}}" TargetType="TextBox">
                                        <Style.Triggers>
                                            <Trigger Property="Text" Value="">
                                                <Setter Property="Background">
                                                    <Setter.Value>
                                                        <VisualBrush
                                                            AlignmentX="Left"
                                                            AlignmentY="Center"
                                                            Stretch="None">
                                                            <VisualBrush.Visual>
                                                                <TextBlock
                                                                    FontFamily="{StaticResource Font.Family.Base}"
                                                                    FontSize="{StaticResource Font.Size.Md}"
                                                                    Foreground="{DynamicResource AppTextMuted}"
                                                                    Text="{DynamicResource TitleBar.Search.Placeholder}" />
                                                            </VisualBrush.Visual>
                                                        </VisualBrush>
                                                    </Setter.Value>
                                                </Setter>
                                            </Trigger>
                                        </Style.Triggers>
                                    </Style>
                                </TextBox.Style>
                            </TextBox>
                        </DockPanel>
                    </Border>

                    <!--  Results / hint  -->
                    <Grid Grid.Row="1">
                        <!--  Empty hint — shown when no results  -->
                        <TextBlock
                            Margin="16,16"
                            FontFamily="{StaticResource Font.Family.Base}"
                            FontSize="{StaticResource Font.Size.Sm}"
                            Foreground="{DynamicResource AppTextMuted}"
                            Text="{DynamicResource TitleBar.Search.Hint}"
                            Visibility="{Binding SearchResults.Count, Converter={StaticResource ZeroToVisibleConverter}}" />

                        <!--  Results list  -->
                        <ScrollViewer MaxHeight="360" VerticalScrollBarVisibility="Auto">
                            <ItemsControl Focusable="False" ItemsSource="{Binding SearchResults}">
                                <ItemsControl.ItemTemplate>
                                    <DataTemplate>
                                        <Border
                                            Padding="16,10"
                                            Background="Transparent"
                                            BorderBrush="{DynamicResource AppBorderLight}"
                                            BorderThickness="0,0,0,1"
                                            Cursor="Hand">
                                            <Grid>
                                                <Grid.ColumnDefinitions>
                                                    <ColumnDefinition Width="Auto" />
                                                    <ColumnDefinition Width="*" />
                                                    <ColumnDefinition Width="Auto" />
                                                </Grid.ColumnDefinitions>
                                                <TextBlock
                                                    Grid.Column="0"
                                                    MinWidth="60"
                                                    FontFamily="{StaticResource Font.Family.Base}"
                                                    FontSize="{StaticResource Font.Size.Base}"
                                                    FontWeight="SemiBold"
                                                    Foreground="{DynamicResource AppTextPrimary}"
                                                    Text="{Binding Symbol}" />
                                                <TextBlock
                                                    Grid.Column="1"
                                                    Margin="12,0,0,0"
                                                    VerticalAlignment="Center"
                                                    FontFamily="{StaticResource Font.Family.Base}"
                                                    FontSize="{StaticResource Font.Size.Sm}"
                                                    Foreground="{DynamicResource AppTextSecondary}"
                                                    Text="{Binding Name}"
                                                    TextTrimming="CharacterEllipsis" />
                                                <TextBlock
                                                    Grid.Column="2"
                                                    Margin="8,0,0,0"
                                                    VerticalAlignment="Center"
                                                    FontFamily="{StaticResource Font.Family.Base}"
                                                    FontSize="{StaticResource Font.Size.Xs}"
                                                    Foreground="{DynamicResource AppTextMuted}"
                                                    Text="{Binding Exchange}" />
                                            </Grid>
                                        </Border>
                                    </DataTemplate>
                                </ItemsControl.ItemTemplate>
                            </ItemsControl>
                        </ScrollViewer>
                    </Grid>
                </Grid>
            </Border>
        </Popup>

        <!--
            ═══ Command Palette popup (Ctrl+Shift+K) ═══
            P2.12 — 簡化版 command palette。Backdrop 灰幕 + 中上 popup（沿用 search
            popup 的視覺語言）。Item 列表是 i18n key 走 ResourceKeyToStringConverter
            渲染當下語系字串。MouseLeftButtonUp 觸發 ExecuteCommandPaletteEntry 接力。
        -->
        <Border
            x:Name="CommandPaletteBackdrop"
            Grid.Row="0"
            Grid.RowSpan="3"
            Panel.ZIndex="9"
            Background="Black"
            MouseDown="CommandPaletteBackdrop_MouseDown"
            Opacity="0.35"
            Visibility="{Binding IsCommandPaletteOpen, Converter={StaticResource BooleanToVisibilityConverter}}" />

        <Popup
            x:Name="CommandPalettePopup"
            AllowsTransparency="True"
            IsOpen="{Binding IsCommandPaletteOpen, Mode=TwoWay}"
            Opened="CommandPalettePopup_Opened"
            Placement="Custom"
            PlacementTarget="{Binding ElementName=MainShell}"
            PopupAnimation="Fade"
            StaysOpen="False">
            <!--  P2.17 T13 — Command Palette border lightened, matches Search popup.  -->
            <Border
                MaxHeight="440"
                Margin="12"
                Background="{DynamicResource AppSurface}"
                BorderBrush="{DynamicResource AppBorderLight}"
                BorderThickness="1"
                CornerRadius="{StaticResource Radius.Lg}">
                <Border.Width>
                    <MultiBinding Converter="{StaticResource AdaptivePanelWidthConverter}" ConverterParameter="0.52|360|620">
                        <Binding ElementName="MainShell" Path="ActualWidth" />
                        <Binding Path="Settings.UiScale" />
                    </MultiBinding>
                </Border.Width>
                <Grid>
                    <Grid.RowDefinitions>
                        <RowDefinition Height="Auto" />
                        <RowDefinition Height="*" />
                    </Grid.RowDefinitions>

                    <Border
                        Grid.Row="0"
                        Padding="16,12"
                        BorderBrush="{DynamicResource AppBorderLight}"
                        BorderThickness="0,0,0,1">
                        <DockPanel>
                            <ds:AppIcon
                                Margin="0,0,10,0"
                                VerticalAlignment="Center"
                                DockPanel.Dock="Left"
                                FontSize="{StaticResource Font.Size.Lg}"
                                Foreground="{DynamicResource AppTextMuted}"
                                IsHitTestVisible="False"
                                Symbol="ChevronRight24" />
                            <TextBox
                                x:Name="CommandPaletteInput"
                                VerticalContentAlignment="Center"
                                Background="Transparent"
                                BorderThickness="0"
                                FocusVisualStyle="{x:Null}"
                                FontFamily="{StaticResource Font.Family.Base}"
                                FontSize="{StaticResource Font.Size.Md}"
                                Foreground="{DynamicResource AppTextPrimary}"
                                PreviewKeyDown="CommandPaletteInput_PreviewKeyDown"
                                Tag="{DynamicResource CommandPalette.Placeholder}"
                                Text="{Binding CommandPaletteText, UpdateSourceTrigger=PropertyChanged}" />
                        </DockPanel>
                    </Border>

                    <!--
                        P2.13 — ListBox (was ItemsControl) 走 grouped view 顯示 「導覽 / 動作」
                        section header。SelectedItem 給 Up/Down 鍵盤導覽用，Border 樣式只是
                        wrapper，實際 hover/selected 視覺由 ListBoxItem ContainerStyle 接管。
                    -->
                    <ListBox
                        x:Name="CommandPaletteResultsList"
                        Grid.Row="1"
                        MaxHeight="360"
                        Background="Transparent"
                        BorderThickness="0"
                        ItemsSource="{Binding CommandPaletteResultsView}"
                        ScrollViewer.HorizontalScrollBarVisibility="Disabled"
                        ScrollViewer.VerticalScrollBarVisibility="Auto">
                        <ListBox.ItemContainerStyle>
                            <Style TargetType="ListBoxItem">
                                <Setter Property="Padding" Value="0" />
                                <Setter Property="BorderThickness" Value="0" />
                                <Setter Property="FocusVisualStyle" Value="{x:Null}" />
                                <Setter Property="HorizontalContentAlignment" Value="Stretch" />
                                <Setter Property="Template">
                                    <Setter.Value>
                                        <ControlTemplate TargetType="ListBoxItem">
                                            <Border
                                                x:Name="Bd"
                                                Padding="16,10"
                                                Background="Transparent"
                                                BorderBrush="{DynamicResource AppBorderLight}"
                                                BorderThickness="0,0,0,1">
                                                <ContentPresenter />
                                            </Border>
                                            <ControlTemplate.Triggers>
                                                <Trigger Property="IsMouseOver" Value="True">
                                                    <Setter TargetName="Bd" Property="Background" Value="{DynamicResource AppHover}" />
                                                </Trigger>
                                                <Trigger Property="IsSelected" Value="True">
                                                    <Setter TargetName="Bd" Property="Background" Value="{DynamicResource AppAccentSubtle}" />
                                                </Trigger>
                                            </ControlTemplate.Triggers>
                                        </ControlTemplate>
                                    </Setter.Value>
                                </Setter>
                            </Style>
                        </ListBox.ItemContainerStyle>
                        <ListBox.ItemTemplate>
                            <DataTemplate>
                                <TextBlock
                                    FontFamily="{StaticResource Font.Family.Base}"
                                    FontSize="{StaticResource Font.Size.Sm}"
                                    Foreground="{DynamicResource AppTextPrimary}"
                                    Text="{Binding TitleKey, Converter={StaticResource ResourceKeyToStringConverter}}" />
                            </DataTemplate>
                        </ListBox.ItemTemplate>
                        <ListBox.GroupStyle>
                            <GroupStyle>
                                <GroupStyle.HeaderTemplate>
                                    <DataTemplate>
                                        <Border
                                            Padding="16,8,16,4"
                                            Background="{DynamicResource AppSurfaceAlt}"
                                            BorderBrush="{DynamicResource AppBorderLight}"
                                            BorderThickness="0,0,0,1">
                                            <TextBlock
                                                FontFamily="{StaticResource Font.Family.UI}"
                                                FontSize="{StaticResource Font.Size.2Xs}"
                                                FontWeight="{StaticResource Font.Weight.Medium}"
                                                Foreground="{DynamicResource AppTextMuted}"
                                                Opacity="0.72"
                                                Text="{Binding Name, Converter={StaticResource ResourceKeyToStringConverter}}" />
                                        </Border>
                                    </DataTemplate>
                                </GroupStyle.HeaderTemplate>
                            </GroupStyle>
                        </ListBox.GroupStyle>
                    </ListBox>
                </Grid>
            </Border>
        </Popup>

        <!--
            ═══ Keyboard Shortcuts Help popup (Ctrl+/) ═══
            P2.17 T04 — 列出所有 keyboard shortcut 給 user 探索。Modal-like 體驗
            (backdrop + center popup)。Esc 由 EscapeKeyCommandBehavior 在 Border
            上處理。
        -->
        <Border
            x:Name="ShortcutsBackdrop"
            Grid.Row="0"
            Grid.RowSpan="3"
            Panel.ZIndex="10"
            Background="Black"
            MouseDown="ShortcutsBackdrop_MouseDown"
            Opacity="0.4"
            Visibility="{Binding IsShortcutsHelpOpen, Converter={StaticResource BooleanToVisibilityConverter}}" />

        <Border
            Grid.Row="0"
            Grid.RowSpan="3"
            Width="520"
            MaxHeight="560"
            Padding="0"
            HorizontalAlignment="Center"
            VerticalAlignment="Center"
            Panel.ZIndex="11"
            beh:EscapeKeyCommandBehavior.Command="{Binding ToggleShortcutsHelpCommand}"
            Style="{StaticResource AppDialogShell}"
            Visibility="{Binding IsShortcutsHelpOpen, Converter={StaticResource BooleanToVisibilityConverter}}">
            <Grid>
                <Grid.RowDefinitions>
                    <RowDefinition Height="Auto" />
                    <RowDefinition Height="*" />
                </Grid.RowDefinitions>

                <!--  Header  -->
                <Border Grid.Row="0"
                        Padding="20,14"
                        BorderBrush="{DynamicResource AppBorderLight}"
                        BorderThickness="0,0,0,1">
                    <DockPanel>
                        <Button Width="28" Height="28" Padding="0"
                                Command="{Binding ToggleShortcutsHelpCommand}"
                                DockPanel.Dock="Right"
                                Style="{StaticResource AppIconButton}">
                            <ds:AppIcon FontSize="12"
                                        Foreground="{DynamicResource AppTextMuted}"
                                        Symbol="Dismiss24" />
                        </Button>
                        <StackPanel>
                            <TextBlock FontSize="{StaticResource Font.Size.Sm}"
                                       FontWeight="SemiBold"
                                       Foreground="{DynamicResource AppTextPrimary}"
                                       Text="{DynamicResource Shortcuts.Title}" />
                            <TextBlock Margin="0,2,0,0"
                                       FontSize="{StaticResource Font.Size.Xs}"
                                       Foreground="{DynamicResource AppTextMuted}"
                                       Text="{DynamicResource Shortcuts.Subtitle}" />
                        </StackPanel>
                    </DockPanel>
                </Border>

                <!--  Shortcut list  -->
                <ScrollViewer Grid.Row="1" Padding="20,12" VerticalScrollBarVisibility="Auto">
                    <StackPanel>
                        <!--  Group: Navigation  -->
                        <TextBlock Margin="0,0,0,8"
                                   FontFamily="{StaticResource Font.Family.UI}"
                                   FontSize="{StaticResource Font.Size.2Xs}"
                                   FontWeight="{StaticResource Font.Weight.Medium}"
                                   Foreground="{DynamicResource AppTextMuted}"
                                   Opacity="0.72"
                                   Text="{DynamicResource Shortcuts.Group.Navigation}" />

                        <!--
                            Row template:  DockPanel  [chip chip] (right-docked)  |  description (fill)
                            Ctrl chip + key chip 之間沒 + sign，視覺貼近實體鍵盤的「按下兩鍵」感。
                        -->
                        <Grid Margin="0,0,0,8">
                            <Grid.ColumnDefinitions>
                                <ColumnDefinition Width="*" />
                                <ColumnDefinition Width="Auto" />
                            </Grid.ColumnDefinitions>
                            <TextBlock VerticalAlignment="Center" FontSize="{StaticResource Font.Size.Sm}" Foreground="{DynamicResource AppTextPrimary}" Text="{DynamicResource Shortcuts.NavFinancial}" />
                            <StackPanel Grid.Column="1" Orientation="Horizontal">
                                <Border Style="{StaticResource AppKbdChip}"><TextBlock Style="{StaticResource AppKbdChipText}" Text="Ctrl" /></Border>
                                <Border Style="{StaticResource AppKbdChip}"><TextBlock Style="{StaticResource AppKbdChipText}" Text="1" /></Border>
                            </StackPanel>
                        </Grid>
                        <Grid Margin="0,0,0,8">
                            <Grid.ColumnDefinitions><ColumnDefinition Width="*" /><ColumnDefinition Width="Auto" /></Grid.ColumnDefinitions>
                            <TextBlock VerticalAlignment="Center" FontSize="{StaticResource Font.Size.Sm}" Foreground="{DynamicResource AppTextPrimary}" Text="{DynamicResource Shortcuts.NavPortfolio}" />
                            <StackPanel Grid.Column="1" Orientation="Horizontal">
                                <Border Style="{StaticResource AppKbdChip}"><TextBlock Style="{StaticResource AppKbdChipText}" Text="Ctrl" /></Border>
                                <Border Style="{StaticResource AppKbdChip}"><TextBlock Style="{StaticResource AppKbdChipText}" Text="2" /></Border>
                            </StackPanel>
                        </Grid>
                        <Grid Margin="0,0,0,8">
                            <Grid.ColumnDefinitions><ColumnDefinition Width="*" /><ColumnDefinition Width="Auto" /></Grid.ColumnDefinitions>
                            <TextBlock VerticalAlignment="Center" FontSize="{StaticResource Font.Size.Sm}" Foreground="{DynamicResource AppTextPrimary}" Text="{DynamicResource Shortcuts.NavTransactions}" />
                            <StackPanel Grid.Column="1" Orientation="Horizontal">
                                <Border Style="{StaticResource AppKbdChip}"><TextBlock Style="{StaticResource AppKbdChipText}" Text="Ctrl" /></Border>
                                <Border Style="{StaticResource AppKbdChip}"><TextBlock Style="{StaticResource AppKbdChipText}" Text="3" /></Border>
                            </StackPanel>
                        </Grid>
                        <Grid Margin="0,0,0,8">
                            <Grid.ColumnDefinitions><ColumnDefinition Width="*" /><ColumnDefinition Width="Auto" /></Grid.ColumnDefinitions>
                            <TextBlock VerticalAlignment="Center" FontSize="{StaticResource Font.Size.Sm}" Foreground="{DynamicResource AppTextPrimary}" Text="{DynamicResource Shortcuts.NavReports}" />
                            <StackPanel Grid.Column="1" Orientation="Horizontal">
                                <Border Style="{StaticResource AppKbdChip}"><TextBlock Style="{StaticResource AppKbdChipText}" Text="Ctrl" /></Border>
                                <Border Style="{StaticResource AppKbdChip}"><TextBlock Style="{StaticResource AppKbdChipText}" Text="4" /></Border>
                            </StackPanel>
                        </Grid>
                        <Grid Margin="0,0,0,8">
                            <Grid.ColumnDefinitions><ColumnDefinition Width="*" /><ColumnDefinition Width="Auto" /></Grid.ColumnDefinitions>
                            <TextBlock VerticalAlignment="Center" FontSize="{StaticResource Font.Size.Sm}" Foreground="{DynamicResource AppTextPrimary}" Text="{DynamicResource Shortcuts.NavCategories}" />
                            <StackPanel Grid.Column="1" Orientation="Horizontal">
                                <Border Style="{StaticResource AppKbdChip}"><TextBlock Style="{StaticResource AppKbdChipText}" Text="Ctrl" /></Border>
                                <Border Style="{StaticResource AppKbdChip}"><TextBlock Style="{StaticResource AppKbdChipText}" Text="5" /></Border>
                            </StackPanel>
                        </Grid>
                        <Grid Margin="0,0,0,8">
                            <Grid.ColumnDefinitions><ColumnDefinition Width="*" /><ColumnDefinition Width="Auto" /></Grid.ColumnDefinitions>
                            <TextBlock VerticalAlignment="Center" FontSize="{StaticResource Font.Size.Sm}" Foreground="{DynamicResource AppTextPrimary}" Text="{DynamicResource Shortcuts.NavAssistant}" />
                            <StackPanel Grid.Column="1" Orientation="Horizontal">
                                <Border Style="{StaticResource AppKbdChip}"><TextBlock Style="{StaticResource AppKbdChipText}" Text="Ctrl" /></Border>
                                <Border Style="{StaticResource AppKbdChip}"><TextBlock Style="{StaticResource AppKbdChipText}" Text="6" /></Border>
                            </StackPanel>
                        </Grid>
                        <Grid Margin="0,0,0,8">
                            <Grid.ColumnDefinitions><ColumnDefinition Width="*" /><ColumnDefinition Width="Auto" /></Grid.ColumnDefinitions>
                            <TextBlock VerticalAlignment="Center" FontSize="{StaticResource Font.Size.Sm}" Foreground="{DynamicResource AppTextPrimary}" Text="{DynamicResource Shortcuts.GoBack}" />
                            <StackPanel Grid.Column="1" Orientation="Horizontal">
                                <Border Style="{StaticResource AppKbdChip}"><TextBlock Style="{StaticResource AppKbdChipText}" Text="Alt" /></Border>
                                <Border Style="{StaticResource AppKbdChip}"><TextBlock Style="{StaticResource AppKbdChipText}" Text="←" /></Border>
                            </StackPanel>
                        </Grid>
                        <Grid Margin="0,0,0,16">
                            <Grid.ColumnDefinitions><ColumnDefinition Width="*" /><ColumnDefinition Width="Auto" /></Grid.ColumnDefinitions>
                            <TextBlock VerticalAlignment="Center" FontSize="{StaticResource Font.Size.Sm}" Foreground="{DynamicResource AppTextPrimary}" Text="{DynamicResource Shortcuts.GoForward}" />
                            <StackPanel Grid.Column="1" Orientation="Horizontal">
                                <Border Style="{StaticResource AppKbdChip}"><TextBlock Style="{StaticResource AppKbdChipText}" Text="Alt" /></Border>
                                <Border Style="{StaticResource AppKbdChip}"><TextBlock Style="{StaticResource AppKbdChipText}" Text="→" /></Border>
                            </StackPanel>
                        </Grid>

                        <!--  Group: Action  -->
                        <TextBlock Margin="0,0,0,8"
                                   FontFamily="{StaticResource Font.Family.UI}"
                                   FontSize="{StaticResource Font.Size.2Xs}"
                                   FontWeight="{StaticResource Font.Weight.Medium}"
                                   Foreground="{DynamicResource AppTextMuted}"
                                   Opacity="0.72"
                                   Text="{DynamicResource Shortcuts.Group.Action}" />
                        <Grid Margin="0,0,0,8">
                            <Grid.ColumnDefinitions><ColumnDefinition Width="*" /><ColumnDefinition Width="Auto" /></Grid.ColumnDefinitions>
                            <TextBlock VerticalAlignment="Center" FontSize="{StaticResource Font.Size.Sm}" Foreground="{DynamicResource AppTextPrimary}" Text="{DynamicResource Shortcuts.GlobalSearch}" />
                            <StackPanel Grid.Column="1" Orientation="Horizontal">
                                <Border Style="{StaticResource AppKbdChip}"><TextBlock Style="{StaticResource AppKbdChipText}" Text="Ctrl" /></Border>
                                <Border Style="{StaticResource AppKbdChip}"><TextBlock Style="{StaticResource AppKbdChipText}" Text="K" /></Border>
                            </StackPanel>
                        </Grid>
                        <Grid Margin="0,0,0,8">
                            <Grid.ColumnDefinitions><ColumnDefinition Width="*" /><ColumnDefinition Width="Auto" /></Grid.ColumnDefinitions>
                            <TextBlock VerticalAlignment="Center" FontSize="{StaticResource Font.Size.Sm}" Foreground="{DynamicResource AppTextPrimary}" Text="{DynamicResource Shortcuts.CommandPalette}" />
                            <StackPanel Grid.Column="1" Orientation="Horizontal">
                                <Border Style="{StaticResource AppKbdChip}"><TextBlock Style="{StaticResource AppKbdChipText}" Text="Ctrl" /></Border>
                                <Border Style="{StaticResource AppKbdChip}"><TextBlock Style="{StaticResource AppKbdChipText}" Text="Shift" /></Border>
                                <Border Style="{StaticResource AppKbdChip}"><TextBlock Style="{StaticResource AppKbdChipText}" Text="K" /></Border>
                            </StackPanel>
                        </Grid>
                        <Grid Margin="0,0,0,8">
                            <Grid.ColumnDefinitions><ColumnDefinition Width="*" /><ColumnDefinition Width="Auto" /></Grid.ColumnDefinitions>
                            <TextBlock VerticalAlignment="Center" FontSize="{StaticResource Font.Size.Sm}" Foreground="{DynamicResource AppTextPrimary}" Text="{DynamicResource Shortcuts.AddTransaction}" />
                            <StackPanel Grid.Column="1" Orientation="Horizontal">
                                <Border Style="{StaticResource AppKbdChip}"><TextBlock Style="{StaticResource AppKbdChipText}" Text="Ctrl" /></Border>
                                <Border Style="{StaticResource AppKbdChip}"><TextBlock Style="{StaticResource AppKbdChipText}" Text="N" /></Border>
                            </StackPanel>
                        </Grid>
                        <Grid Margin="0,0,0,8">
                            <Grid.ColumnDefinitions><ColumnDefinition Width="*" /><ColumnDefinition Width="Auto" /></Grid.ColumnDefinitions>
                            <TextBlock VerticalAlignment="Center" FontSize="{StaticResource Font.Size.Sm}" Foreground="{DynamicResource AppTextPrimary}" Text="{DynamicResource Shortcuts.ToggleHelp}" />
                            <StackPanel Grid.Column="1" Orientation="Horizontal">
                                <Border Style="{StaticResource AppKbdChip}"><TextBlock Style="{StaticResource AppKbdChipText}" Text="Ctrl" /></Border>
                                <Border Style="{StaticResource AppKbdChip}"><TextBlock Style="{StaticResource AppKbdChipText}" Text="/" /></Border>
                            </StackPanel>
                        </Grid>
                    </StackPanel>
                </ScrollViewer>
            </Grid>
        </Border>

        <!--  ── In-App Snackbar (ZIndex=15, bottom-center) ──  -->
        <snackbar:SnackbarView
            Grid.Row="1"
            Margin="0,0,0,16"
            HorizontalAlignment="Center"
            VerticalAlignment="Bottom"
            Panel.ZIndex="15"
            DataContext="{Binding Snackbar}" />

        <!--  ── Status Bar ──  -->
        <statusbar:StatusBarView Grid.Row="2" DataContext="{Binding StatusBar}" />


        <!--
            Shell-level Cash detail overlay. Promoted from PortfolioView so
            clicking a Cash row from any page (Portfolio, CashAccounts, ...) shows
            the side panel. Wrapper Grid sets DataContext to PortfolioViewModel
            so existing bindings (HasSelectedCashRow, SelectedCashRow.*,
            Account.*) keep working without rewrites. Grid.Row=1 means the
            backdrop covers the content area but leaves the title bar and
            status bar reachable.
        -->
        <Grid Grid.Row="1" DataContext="{Binding Portfolio}">
            <!--  ── Cash / Liability detail overlays (floating side panel with backdrop) ──  -->
            <Grid Panel.ZIndex="180" Visibility="{Binding HasSelectedCashRow, Converter={StaticResource BooleanToVisibilityConverter}}">
                <!--  Click-to-close backdrop  -->
                <Border beh:BackdropClickToCloseBehavior.Command="{Binding CloseCashDetailCommand}" Style="{StaticResource AppDialogOverlayBorder}" />

                <!--  Floating panel anchored right  -->
                <Border
                    HorizontalAlignment="Right"
                    Background="{DynamicResource AppSurface}"
                    BorderBrush="{DynamicResource AppBorder}"
                    BorderThickness="1,0,0,0">
                    <Border.Width>
                        <!--  P4.9 — Position / Cash / Liability detail panel 統一寬度 `0.55/520/820`  -->
                        <MultiBinding Converter="{StaticResource AdaptivePanelWidthConverter}" ConverterParameter="0.55|520|820">
                            <Binding Path="ActualWidth" RelativeSource="{RelativeSource AncestorType=Window}" />
                            <Binding Path="DataContext.Settings.UiScale" RelativeSource="{RelativeSource AncestorType=Window}" />
                        </MultiBinding>
                    </Border.Width>
                    <Grid>
                        <Grid.RowDefinitions>
                            <RowDefinition Height="Auto" />
                            <RowDefinition Height="Auto" />
                            <RowDefinition Height="*" />
                            <RowDefinition Height="Auto" />
                        </Grid.RowDefinitions>

                        <!--  Header  -->
                        <Border
                            Grid.Row="0"
                            Padding="16,14"
                            BorderBrush="{DynamicResource AppBorder}"
                            BorderThickness="0,0,0,1">
                            <StackPanel>
                            <DockPanel LastChildFill="True">
                                <!--  Close  -->
                                <Button
                                    Width="30"
                                    Height="36"
                                    Margin="6,0,0,0"
                                    Padding="0"
                                    VerticalAlignment="Center"
                                    Command="{Binding CloseCashDetailCommand}"
                                    DockPanel.Dock="Right"
                                    Style="{StaticResource AppIconButton}"
                                    ToolTip="{DynamicResource Common.Close}">
                                    <ds:AppIcon
                                        FontSize="11"
                                        Foreground="{DynamicResource AppTextSecondary}"
                                        Symbol="Dismiss24" />
                                </Button>
                                <!--  Edit pencil → opens shared EditAssetDialog  -->
                                <Button
                                    Width="30"
                                    Height="36"
                                    Padding="0"
                                    VerticalAlignment="Center"
                                    Command="{Binding Account.OpenEditCashCommand}"
                                    CommandParameter="{Binding SelectedCashRow}"
                                    DockPanel.Dock="Right"
                                    Style="{StaticResource AppIconButton}"
                                    ToolTip="{DynamicResource Common.Edit}">
                                    <ds:AppIcon
                                        FontSize="12"
                                        Foreground="{DynamicResource AppTextPrimary}"
                                        Symbol="Edit24" />
                                </Button>
                                <!--  設為預設 / 取消預設 toggle  -->
                                <Button
                                    Width="30"
                                    Height="36"
                                    Margin="0,0,4,0"
                                    VerticalAlignment="Center"
                                    Command="{Binding Account.ToggleDefaultCashAccountCommand}"
                                    CommandParameter="{Binding SelectedCashRow}"
                                    DockPanel.Dock="Right">
                                    <Button.Style>
                                        <Style BasedOn="{StaticResource AppIconButton}" TargetType="{x:Type Button}">
                                            <Setter Property="ToolTip" Value="{DynamicResource Portfolio.Cash.SetDefault}" />
                                            <Style.Triggers>
                                                <DataTrigger Binding="{Binding SelectedCashRow.IsDefault}" Value="True">
                                                    <Setter Property="ToolTip" Value="{DynamicResource Portfolio.Cash.UnsetDefault}" />
                                                </DataTrigger>
                                            </Style.Triggers>
                                        </Style>
                                    </Button.Style>
                                    <ds:AppIcon FontSize="12" Symbol="Star24">
                                        <ds:AppIcon.Style>
                                            <Style BasedOn="{StaticResource AppIcon}" TargetType="{x:Type ds:AppIcon}">
                                                <Setter Property="Foreground" Value="{DynamicResource AppTextSecondary}" />
                                                <Setter Property="Filled" Value="False" />
                                                <Style.Triggers>
                                                    <DataTrigger Binding="{Binding SelectedCashRow.IsDefault}" Value="True">
                                                        <Setter Property="Filled" Value="True" />
                                                        <Setter Property="Foreground" Value="{DynamicResource AppAccent}" />
                                                    </DataTrigger>
                                                </Style.Triggers>
                                            </Style>
                                        </ds:AppIcon.Style>
                                    </ds:AppIcon>
                                </Button>
                                <!--  封存 / 取消封存 toggle (依 IsActive 切標籤與圖示)  -->
                                <Button
                                    Width="30"
                                    Height="36"
                                    Margin="0,0,4,0"
                                    VerticalAlignment="Center"
                                    Command="{Binding Account.ToggleArchiveCommand}"
                                    CommandParameter="{Binding SelectedCashRow}"
                                    DockPanel.Dock="Right">
                                    <Button.Style>
                                        <Style BasedOn="{StaticResource AppIconButton}" TargetType="{x:Type Button}">
                                            <Setter Property="ToolTip" Value="{DynamicResource Portfolio.Account.Archive}" />
                                            <Style.Triggers>
                                                <DataTrigger Binding="{Binding SelectedCashRow.IsActive}" Value="False">
                                                    <Setter Property="ToolTip" Value="{DynamicResource Portfolio.Account.Unarchive}" />
                                                </DataTrigger>
                                            </Style.Triggers>
                                        </Style>
                                    </Button.Style>
                                    <ds:AppIcon
                                        FontSize="12"
                                        Foreground="{DynamicResource AppTextSecondary}"
                                        Symbol="Archive24">
                                        <ds:AppIcon.Style>
                                            <Style BasedOn="{StaticResource AppIcon}" TargetType="{x:Type ds:AppIcon}">
                                                <Setter Property="Symbol" Value="Archive24" />
                                                <Style.Triggers>
                                                    <DataTrigger Binding="{Binding SelectedCashRow.IsActive}" Value="False">
                                                        <Setter Property="Symbol" Value="ArchiveArrowBack24" />
                                                        <Setter Property="Foreground" Value="{DynamicResource AppAccent}" />
                                                    </DataTrigger>
                                                </Style.Triggers>
                                            </Style>
                                        </ds:AppIcon.Style>
                                    </ds:AppIcon>
                                </Button>
                                <TextBlock
                                    VerticalAlignment="Center"
                                    FontSize="{StaticResource Font.Size.Lg}"
                                    FontWeight="SemiBold"
                                    Foreground="{DynamicResource AppTextPrimary}"
                                    Text="{Binding SelectedCashRow.Name, FallbackValue=''}"
                                    TextTrimming="CharacterEllipsis" />
                            </DockPanel>
                            <!--  P4.9e — subtitle + currency chip 對齊 Position header  -->
                            <StackPanel>
                                <TextBlock
                                    Margin="0,8,0,8"
                                    FontSize="{StaticResource Font.Size.Xs}"
                                    Foreground="{DynamicResource AppTextMuted}"
                                    Text="{DynamicResource Portfolio.Detail.Cash.Subtitle}" />
                                <StackPanel Orientation="Horizontal">
                                    <Border Padding="8,2" CornerRadius="{StaticResource Radius.Sm}">
                                        <Border.Style>
                                            <Style TargetType="Border">
                                                <Setter Property="Background" Value="{DynamicResource Brush.Neutral}" />
                                                <Style.Triggers>
                                                    <DataTrigger Binding="{Binding SelectedCashRow.Currency, FallbackValue=''}" Value="USD">
                                                        <Setter Property="Background" Value="{DynamicResource Brush.Special}" />
                                                    </DataTrigger>
                                                </Style.Triggers>
                                            </Style>
                                        </Border.Style>
                                        <TextBlock
                                            FontSize="{StaticResource Font.Size.Xs}"
                                            FontWeight="SemiBold"
                                            Foreground="{DynamicResource AppTextOnAccent}"
                                            Text="{Binding SelectedCashRow.Currency, FallbackValue='TWD'}" />
                                    </Border>
                                </StackPanel>
                            </StackPanel>
                            </StackPanel>
                        </Border>

                        <!--  Tab bar — P4.9e DockPanel + pill tab + primary CTA  -->
                        <Border
                            Grid.Row="1"
                            Padding="14,8"
                            BorderBrush="{DynamicResource AppBorder}"
                            BorderThickness="0,0,0,1">
                            <DockPanel LastChildFill="True">
                                <Button
                                    Height="32"
                                    MinWidth="120"
                                    Padding="14,0"
                                    Click="AddMenuButton_Click"
                                    DockPanel.Dock="Right"
                                    Style="{StaticResource AppPrimaryButton}"
                                    TextElement.Foreground="{DynamicResource Brush.Text.OnAccent}">
                                    <StackPanel Orientation="Horizontal" TextElement.Foreground="{DynamicResource Brush.Text.OnAccent}">
                                        <ds:AppIcon
                                            Margin="0,0,6,0"
                                            VerticalAlignment="Center"
                                            FontSize="10"
                                            Foreground="{DynamicResource Brush.Text.OnAccent}"
                                            Symbol="Add24" />
                                        <TextBlock
                                            VerticalAlignment="Center"
                                            FontSize="{StaticResource Font.Size.Sm}"
                                            Foreground="{DynamicResource Brush.Text.OnAccent}"
                                            Text="{DynamicResource Portfolio.Detail.AddRecord}" />
                                    </StackPanel>
                                    <Button.ContextMenu>
                                        <ContextMenu>
                                            <MenuItem
                                                Command="{Binding BeginTxForSelectedCashCommand}"
                                                CommandParameter="income"
                                                Header="{DynamicResource Portfolio.Detail.Cash.Action.Income}" />
                                            <MenuItem
                                                Command="{Binding BeginTxForSelectedCashCommand}"
                                                CommandParameter="deposit"
                                                Header="{DynamicResource Portfolio.Detail.Cash.Action.Deposit}" />
                                            <MenuItem
                                                Command="{Binding BeginTxForSelectedCashCommand}"
                                                CommandParameter="withdrawal"
                                                Header="{DynamicResource Portfolio.Detail.Cash.Action.Withdrawal}" />
                                            <MenuItem
                                                Command="{Binding BeginTxForSelectedCashCommand}"
                                                CommandParameter="transfer"
                                                Header="{DynamicResource Portfolio.Detail.Cash.Action.Transfer}" />
                                        </ContextMenu>
                                    </Button.ContextMenu>
                                </Button>
                                <StackPanel Orientation="Horizontal">
                                    <RadioButton
                                        Command="{Binding SwitchDetailTabCommand}"
                                        CommandParameter="overview"
                                        Content="{DynamicResource Portfolio.Detail.Overview}"
                                        GroupName="CashDetailTab"
                                        IsChecked="{Binding IsDetailOverviewTab, Mode=OneWay}"
                                        Style="{StaticResource AppPillTab}" />
                                    <RadioButton
                                        Command="{Binding SwitchDetailTabCommand}"
                                        CommandParameter="trades"
                                        Content="{DynamicResource Portfolio.Detail.Trades}"
                                        GroupName="CashDetailTab"
                                        IsChecked="{Binding IsDetailTradesTab, Mode=OneWay}"
                                        Style="{StaticResource AppPillTab}" />
                                </StackPanel>
                            </DockPanel>
                        </Border>

                        <!--  Tab content  -->
                        <ScrollViewer Grid.Row="2" VerticalScrollBarVisibility="Auto">
                            <Grid>
                                <StackPanel Margin="16,16,16,12" Visibility="{Binding IsDetailOverviewTab, Converter={StaticResource BooleanToVisibilityConverter}}">
                                    <StackPanel>
                                        <TextBlock
                                            FontSize="{StaticResource Font.Size.Xs}"
                                            Foreground="{DynamicResource AppTextSecondary}"
                                            Text="{DynamicResource Portfolio.Cash.Amount}" />
                                        <TextBlock
                                            Margin="0,2,0,14"
                                            FontFamily="{StaticResource Font.Family.Base}"
                                            FontSize="{StaticResource Font.Size.2xl}"
                                            FontWeight="SemiBold"
                                            Foreground="{DynamicResource AppTextPrimary}"
                                            Text="{Binding SelectedCashRow.Balance, Converter={StaticResource CurrencyConverter}, ConverterParameter=amount, FallbackValue=''}"
                                            Typography.NumeralAlignment="Tabular" />
                                        <DockPanel Margin="0,0,0,14">
                                            <TextBlock
                                                DockPanel.Dock="Left"
                                                FontSize="{StaticResource Font.Size.Xs}"
                                                Foreground="{DynamicResource AppTextSecondary}"
                                                Text="{DynamicResource Common.CreatedDate}" />
                                            <TextBlock
                                                HorizontalAlignment="Right"
                                                DockPanel.Dock="Right"
                                                FontFamily="{StaticResource Font.Family.Base}"
                                                FontSize="{StaticResource Font.Size.Xs}"
                                                Foreground="{DynamicResource AppTextPrimary}"
                                                Text="{Binding SelectedCashRow.CreatedDate, StringFormat=yyyy/MM/dd, FallbackValue=''}"
                                                Typography.NumeralAlignment="Tabular" />
                                        </DockPanel>
                                        <Grid>
                                            <Grid.ColumnDefinitions>
                                                <ColumnDefinition Width="*" />
                                                <ColumnDefinition Width="10" />
                                                <ColumnDefinition Width="*" />
                                            </Grid.ColumnDefinitions>
                                            <Border
                                                Grid.Column="0"
                                                Padding="12,10"
                                                Background="{DynamicResource AppBackground}"
                                                BorderBrush="{DynamicResource AppBorder}"
                                                BorderThickness="1"
                                                CornerRadius="{StaticResource Radius.Sm}">
                                                <StackPanel>
                                                    <TextBlock
                                                        FontSize="{StaticResource Font.Size.Xs}"
                                                        Foreground="{DynamicResource AppTextSecondary}"
                                                        Text="{DynamicResource Portfolio.Detail.TotalDeposits}" />
                                                    <TextBlock
                                                        Margin="0,4,0,0"
                                                        FontFamily="{StaticResource Font.Family.Base}"
                                                        FontSize="{StaticResource Font.Size.Sm}"
                                                        FontWeight="SemiBold"
                                                        Foreground="{DynamicResource AppUp}"
                                                        Text="{Binding SelectedCashTotalDeposits, Converter={StaticResource CurrencyConverter}, ConverterParameter=amount}"
                                                        Typography.NumeralAlignment="Tabular" />
                                                </StackPanel>
                                            </Border>
                                            <Border
                                                Grid.Column="2"
                                                Padding="12,10"
                                                Background="{DynamicResource AppBackground}"
                                                BorderBrush="{DynamicResource AppBorder}"
                                                BorderThickness="1"
                                                CornerRadius="{StaticResource Radius.Sm}">
                                                <StackPanel>
                                                    <TextBlock
                                                        FontSize="{StaticResource Font.Size.Xs}"
                                                        Foreground="{DynamicResource AppTextSecondary}"
                                                        Text="{DynamicResource Portfolio.Detail.TotalWithdrawals}" />
                                                    <TextBlock
                                                        Margin="0,4,0,0"
                                                        FontFamily="{StaticResource Font.Family.Base}"
                                                        FontSize="{StaticResource Font.Size.Sm}"
                                                        FontWeight="SemiBold"
                                                        Foreground="{DynamicResource AppDown}"
                                                        Text="{Binding SelectedCashTotalWithdrawals, Converter={StaticResource CurrencyConverter}, ConverterParameter=amount}"
                                                        Typography.NumeralAlignment="Tabular" />
                                                </StackPanel>
                                            </Border>
                                        </Grid>
                                    </StackPanel>
                                </StackPanel>

                                <!--
                                    Cash trades tab — P4.9b 對齊 Position panel table-style：4 欄
                                    (日期 / 類型 / 價值 / Edit)。Cash trade 沒有 Qty / Price 欄。
                                    Note 不為空時當 row ToolTip。
                                -->
                                <Grid Margin="16,12" Visibility="{Binding IsDetailTradesTab, Converter={StaticResource BooleanToVisibilityConverter}}">
                                    <Grid.RowDefinitions>
                                        <RowDefinition Height="Auto" />
                                        <RowDefinition Height="*" />
                                    </Grid.RowDefinitions>

                                    <!--  Column header — P4.9c Note 欄移除  -->
                                    <Border
                                        Grid.Row="0"
                                        Padding="0,0,0,8"
                                        BorderBrush="{DynamicResource AppBorder}"
                                        BorderThickness="0,0,0,1">
                                        <Grid>
                                            <Grid.ColumnDefinitions>
                                                <ColumnDefinition Width="92" />
                                                <ColumnDefinition Width="80" />
                                                <ColumnDefinition Width="*" />
                                            </Grid.ColumnDefinitions>
                                            <TextBlock
                                                Grid.Column="0"
                                                FontSize="{StaticResource Font.Size.Xs}"
                                                Foreground="{DynamicResource AppTextSecondary}"
                                                Text="{DynamicResource Portfolio.TradeHistory.Date}" />
                                            <TextBlock
                                                Grid.Column="1"
                                                FontSize="{StaticResource Font.Size.Xs}"
                                                Foreground="{DynamicResource AppTextSecondary}"
                                                Text="{DynamicResource Portfolio.TradeHistory.Type}" />
                                            <TextBlock
                                                Grid.Column="2"
                                                HorizontalAlignment="Right"
                                                FontSize="{StaticResource Font.Size.Xs}"
                                                Foreground="{DynamicResource AppTextSecondary}"
                                                Text="{DynamicResource Portfolio.TradeHistory.GrossAmount}" />
                                        </Grid>
                                    </Border>

                                    <TextBlock
                                        Grid.Row="1"
                                        Margin="0,24,0,0"
                                        HorizontalAlignment="Center"
                                        VerticalAlignment="Top"
                                        FontSize="{StaticResource Font.Size.Sm}"
                                        Foreground="{DynamicResource AppTextMuted}"
                                        Text="{DynamicResource Portfolio.Detail.NoTrades}">
                                        <TextBlock.Style>
                                            <Style TargetType="TextBlock">
                                                <Setter Property="Visibility" Value="Collapsed" />
                                                <Style.Triggers>
                                                    <DataTrigger Binding="{Binding SelectedCashTrades.Count, FallbackValue=0}" Value="0">
                                                        <Setter Property="Visibility" Value="Visible" />
                                                    </DataTrigger>
                                                </Style.Triggers>
                                            </Style>
                                        </TextBlock.Style>
                                    </TextBlock>

                                    <ItemsControl Grid.Row="1" ItemsSource="{Binding SelectedCashTrades}">
                                        <ItemsControl.ItemTemplate>
                                            <DataTemplate>
                                                <Border
                                                    Padding="6,10"
                                                    BorderThickness="0,0,0,1"
                                                    Cursor="Hand"
                                                    ToolTip="{Binding Note}">
                                                    <Border.Style>
                                                        <Style TargetType="Border">
                                                            <Setter Property="BorderBrush" Value="{DynamicResource AppBorderLight}" />
                                                            <Setter Property="Background" Value="Transparent" />
                                                            <Style.Triggers>
                                                                <Trigger Property="IsMouseOver" Value="True">
                                                                    <Setter Property="Background" Value="{DynamicResource AppHover}" />
                                                                </Trigger>
                                                            </Style.Triggers>
                                                        </Style>
                                                    </Border.Style>
                                                    <Border.InputBindings>
                                                        <MouseBinding
                                                            Command="{Binding DataContext.Transaction.EditTradeCommand, RelativeSource={RelativeSource AncestorType=ItemsControl}}"
                                                            CommandParameter="{Binding}"
                                                            MouseAction="LeftClick" />
                                                    </Border.InputBindings>
                                                    <Grid>
                                                        <Grid.ColumnDefinitions>
                                                            <ColumnDefinition Width="92" />
                                                            <ColumnDefinition Width="80" />
                                                            <ColumnDefinition Width="*" />
                                                        </Grid.ColumnDefinitions>
                                                        <!--  日期  -->
                                                        <TextBlock
                                                            Grid.Column="0"
                                                            VerticalAlignment="Center"
                                                            FontFamily="{StaticResource Font.Family.Base}"
                                                            FontSize="{StaticResource Font.Size.Sm}"
                                                            Foreground="{DynamicResource AppTextPrimary}"
                                                            Text="{Binding TradeDateLocal, StringFormat=yyyy-MM-dd}"
                                                            Typography.NumeralAlignment="Tabular" />
                                                        <!--  類型 badge  -->
                                                        <Border
                                                            Grid.Column="1"
                                                            Padding="6,2"
                                                            HorizontalAlignment="Left"
                                                            VerticalAlignment="Center"
                                                            Background="{Binding TypeBadgeColor, Converter={StaticResource HexToBrushConverter}}"
                                                            CornerRadius="{StaticResource Radius.Sm}">
                                                            <TextBlock
                                                                FontSize="{StaticResource Font.Size.Xs}"
                                                                FontWeight="SemiBold"
                                                                Foreground="{DynamicResource AppTextOnAccent}"
                                                                Text="{Binding Type, Converter={StaticResource TradeTypeConverter}}" />
                                                        </Border>
                                                        <!--  價值 (TotalAmount 已含 sign)  -->
                                                        <TextBlock
                                                            Grid.Column="2"
                                                            HorizontalAlignment="Right"
                                                            VerticalAlignment="Center"
                                                            FontFamily="{StaticResource Font.Family.Base}"
                                                            FontSize="{StaticResource Font.Size.Sm}"
                                                            FontWeight="SemiBold"
                                                            Text="{Binding TotalAmount, Converter={StaticResource CurrencyConverter}, ConverterParameter=signed-dash}"
                                                            Typography.NumeralAlignment="Tabular">
                                                            <TextBlock.Style>
                                                                <Style BasedOn="{StaticResource {x:Type TextBlock}}" TargetType="TextBlock">
                                                                    <Setter Property="Foreground" Value="{DynamicResource AppDown}" />
                                                                    <Style.Triggers>
                                                                        <DataTrigger Binding="{Binding IsAmountPositive}" Value="True">
                                                                            <Setter Property="Foreground" Value="{DynamicResource AppUp}" />
                                                                        </DataTrigger>
                                                                        <DataTrigger Binding="{Binding TotalAmount}" Value="0">
                                                                            <Setter Property="Foreground" Value="{DynamicResource AppTextSecondary}" />
                                                                        </DataTrigger>
                                                                    </Style.Triggers>
                                                                </Style>
                                                            </TextBlock.Style>
                                                        </TextBlock>
                                                    </Grid>
                                                </Border>
                                            </DataTemplate>
                                        </ItemsControl.ItemTemplate>
                                    </ItemsControl>
                                </Grid>
                            </Grid>
                        </ScrollViewer>

                        <!--  Danger zone  -->
                        <Border
                            Grid.Row="3"
                            Margin="16,0,16,16"
                            Padding="14,12"
                            Background="{DynamicResource AppBackground}"
                            BorderBrush="{DynamicResource AppDanger}"
                            BorderThickness="1"
                            CornerRadius="{StaticResource Radius.Sm}">
                            <Grid>
                                <Grid.ColumnDefinitions>
                                    <ColumnDefinition Width="*" />
                                    <ColumnDefinition Width="Auto" />
                                </Grid.ColumnDefinitions>
                                <StackPanel Grid.Column="0" VerticalAlignment="Center">
                                    <StackPanel Margin="0,0,0,2" Orientation="Horizontal">
                                        <ds:AppIcon
                                            Margin="0,0,6,0"
                                            VerticalAlignment="Center"
                                            FontSize="11"
                                            Foreground="{DynamicResource AppDanger}"
                                            Symbol="Delete24" />
                                        <TextBlock
                                            FontSize="{StaticResource Font.Size.Xs}"
                                            FontWeight="SemiBold"
                                            Foreground="{DynamicResource AppDanger}"
                                            Text="{DynamicResource Portfolio.Detail.DeleteAccount}" />
                                    </StackPanel>
                                    <TextBlock
                                        FontSize="{StaticResource Font.Size.Xs}"
                                        Foreground="{DynamicResource AppTextSecondary}"
                                        Text="{DynamicResource Portfolio.Detail.DeleteWarning}"
                                        TextWrapping="Wrap" />
                                </StackPanel>
                                <Button
                                    Grid.Column="1"
                                    Height="32"
                                    Margin="12,0,0,0"
                                    Padding="14,0"
                                    VerticalAlignment="Center"
                                    Command="{Binding Account.RemoveCashAccountCommand}"
                                    CommandParameter="{Binding SelectedCashRow}"
                                    Style="{StaticResource AppDangerButton}">
                                    <TextBlock
                                        FontSize="{StaticResource Font.Size.Xs}"
                                        Foreground="{Binding Foreground, RelativeSource={RelativeSource AncestorType=Button}}"
                                        Text="{DynamicResource Portfolio.Detail.DeleteAccount}" />
                                </Button>
                            </Grid>
                        </Border>
                    </Grid>
                </Border>
            </Grid>
        </Grid>

        <!--
            Shell-level Liability detail overlay. Same shell-promotion as
            Cash overlay above so a Liability row click on any page
            (Portfolio, Liabilities, ...) opens the side panel.
        -->
        <Grid Grid.Row="1" DataContext="{Binding Portfolio}">
            <!--  Liability detail overlay  -->
            <Grid Panel.ZIndex="180" Visibility="{Binding HasSelectedLiabilityRow, Converter={StaticResource BooleanToVisibilityConverter}}">
                <Border beh:BackdropClickToCloseBehavior.Command="{Binding CloseLiabilityDetailCommand}" Style="{StaticResource AppDialogOverlayBorder}" />
                <Border
                    HorizontalAlignment="Right"
                    Background="{DynamicResource AppSurface}"
                    BorderBrush="{DynamicResource AppBorder}"
                    BorderThickness="1,0,0,0">
                    <Border.Width>
                        <!--  P4.9 — Position / Cash / Liability detail panel 統一寬度 `0.55/520/820`  -->
                        <MultiBinding Converter="{StaticResource AdaptivePanelWidthConverter}" ConverterParameter="0.55|520|820">
                            <Binding Path="ActualWidth" RelativeSource="{RelativeSource AncestorType=Window}" />
                            <Binding Path="DataContext.Settings.UiScale" RelativeSource="{RelativeSource AncestorType=Window}" />
                        </MultiBinding>
                    </Border.Width>
                    <Grid>
                        <Grid.RowDefinitions>
                            <RowDefinition Height="Auto" />
                            <RowDefinition Height="Auto" />
                            <RowDefinition Height="*" />
                            <RowDefinition Height="Auto" />
                        </Grid.RowDefinitions>

                        <Border
                            Grid.Row="0"
                            Padding="16,14"
                            BorderBrush="{DynamicResource AppBorder}"
                            BorderThickness="0,0,0,1">
                            <StackPanel>
                            <DockPanel LastChildFill="True">
                                <!--  Close  -->
                                <Button
                                    Width="30"
                                    Height="36"
                                    Margin="6,0,0,0"
                                    Padding="0"
                                    VerticalAlignment="Center"
                                    Command="{Binding CloseLiabilityDetailCommand}"
                                    DockPanel.Dock="Right"
                                    Style="{StaticResource AppIconButton}"
                                    ToolTip="{DynamicResource Common.Close}">
                                    <ds:AppIcon
                                        FontSize="11"
                                        Foreground="{DynamicResource AppTextSecondary}"
                                        Symbol="Dismiss24" />
                                </Button>
                                <!--
                                    Edit pencil — same icon-only pattern as
                                    Cash / Position panels for visual parity.
                                    Hidden for legacy label-only liabilities
                                    (AssetId == null) since they have no
                                    AssetItem to edit.
                                -->
                                <Button
                                    Width="30"
                                    Height="36"
                                    Padding="0"
                                    VerticalAlignment="Center"
                                    Command="{Binding OpenEditLiabilityCommand}"
                                    CommandParameter="{Binding SelectedLiabilityRow}"
                                    DockPanel.Dock="Right"
                                    Style="{StaticResource AppIconButton}"
                                    ToolTip="{DynamicResource Common.Edit}"
                                    Visibility="{Binding SelectedLiabilityRow.AssetId, Converter={StaticResource NullToVisibilityConverter}, FallbackValue=Collapsed}">
                                    <ds:AppIcon
                                        FontSize="12"
                                        Foreground="{DynamicResource AppTextPrimary}"
                                        Symbol="Edit24" />
                                </Button>
                                <TextBlock
                                    VerticalAlignment="Center"
                                    FontSize="{StaticResource Font.Size.Lg}"
                                    FontWeight="SemiBold"
                                    Foreground="{DynamicResource AppTextPrimary}"
                                    Text="{Binding SelectedLiabilityRow.Name, FallbackValue=''}"
                                    TextTrimming="CharacterEllipsis" />
                            </DockPanel>
                            <!--  P4.9e — subtitle + currency chip 對齊 Position / Cash header  -->
                            <StackPanel>
                                <TextBlock
                                    Margin="0,8,0,8"
                                    FontSize="{StaticResource Font.Size.Xs}"
                                    Foreground="{DynamicResource AppTextMuted}"
                                    Text="{DynamicResource Portfolio.Detail.Liability.Subtitle}" />
                                <StackPanel Orientation="Horizontal">
                                    <Border Padding="8,2" CornerRadius="{StaticResource Radius.Sm}">
                                        <Border.Style>
                                            <Style TargetType="Border">
                                                <Setter Property="Background" Value="{DynamicResource Brush.Neutral}" />
                                                <Style.Triggers>
                                                    <DataTrigger Binding="{Binding SelectedLiabilityRow.Currency, FallbackValue=''}" Value="USD">
                                                        <Setter Property="Background" Value="{DynamicResource Brush.Special}" />
                                                    </DataTrigger>
                                                </Style.Triggers>
                                            </Style>
                                        </Border.Style>
                                        <TextBlock
                                            FontSize="{StaticResource Font.Size.Xs}"
                                            FontWeight="SemiBold"
                                            Foreground="{DynamicResource AppTextOnAccent}"
                                            Text="{Binding SelectedLiabilityRow.Currency, FallbackValue='TWD'}" />
                                    </Border>
                                </StackPanel>
                            </StackPanel>
                            </StackPanel>
                        </Border>

                        <!--  Tab bar — P4.9e DockPanel + pill tab + primary CTA  -->
                        <Border
                            Grid.Row="1"
                            Padding="14,8"
                            BorderBrush="{DynamicResource AppBorder}"
                            BorderThickness="0,0,0,1">
                            <DockPanel LastChildFill="True">
                                <Button
                                    Height="32"
                                    MinWidth="120"
                                    Padding="14,0"
                                    Click="AddMenuButton_Click"
                                    DockPanel.Dock="Right"
                                    Style="{StaticResource AppPrimaryButton}"
                                    TextElement.Foreground="{DynamicResource Brush.Text.OnAccent}">
                                    <StackPanel Orientation="Horizontal" TextElement.Foreground="{DynamicResource Brush.Text.OnAccent}">
                                        <ds:AppIcon
                                            Margin="0,0,6,0"
                                            VerticalAlignment="Center"
                                            FontSize="10"
                                            Foreground="{DynamicResource Brush.Text.OnAccent}"
                                            Symbol="Add24" />
                                        <TextBlock
                                            VerticalAlignment="Center"
                                            FontSize="{StaticResource Font.Size.Sm}"
                                            Foreground="{DynamicResource Brush.Text.OnAccent}"
                                            Text="{DynamicResource Portfolio.Detail.AddRecord}" />
                                    </StackPanel>
                                    <Button.ContextMenu>
                                        <ContextMenu>
                                            <!--  Loan：借款 / 還款  -->
                                            <MenuItem
                                                Command="{Binding BeginTxForSelectedLiabilityCommand}"
                                                CommandParameter="loanBorrow"
                                                Header="{DynamicResource Portfolio.Detail.Liability.Action.LoanBorrow}"
                                                Visibility="{Binding SelectedLiabilityRow.IsLoan, Converter={StaticResource BooleanToVisibilityConverter}, FallbackValue=Collapsed}" />
                                            <MenuItem
                                                Command="{Binding BeginTxForSelectedLiabilityCommand}"
                                                CommandParameter="loanRepay"
                                                Header="{DynamicResource Portfolio.Detail.Liability.Action.LoanRepay}"
                                                Visibility="{Binding SelectedLiabilityRow.IsLoan, Converter={StaticResource BooleanToVisibilityConverter}, FallbackValue=Collapsed}" />
                                            <!--  CreditCard：消費 / 繳款  -->
                                            <MenuItem
                                                Command="{Binding BeginTxForSelectedLiabilityCommand}"
                                                CommandParameter="creditCardCharge"
                                                Header="{DynamicResource Portfolio.Detail.Liability.Action.CreditCardCharge}"
                                                Visibility="{Binding SelectedLiabilityRow.IsCreditCard, Converter={StaticResource BooleanToVisibilityConverter}, FallbackValue=Collapsed}" />
                                            <MenuItem
                                                Command="{Binding BeginTxForSelectedLiabilityCommand}"
                                                CommandParameter="creditCardPayment"
                                                Header="{DynamicResource Portfolio.Detail.Liability.Action.CreditCardPayment}"
                                                Visibility="{Binding SelectedLiabilityRow.IsCreditCard, Converter={StaticResource BooleanToVisibilityConverter}, FallbackValue=Collapsed}" />
                                        </ContextMenu>
                                    </Button.ContextMenu>
                                </Button>
                                <StackPanel Orientation="Horizontal">
                                    <RadioButton
                                        Command="{Binding SwitchDetailTabCommand}"
                                        CommandParameter="overview"
                                        Content="{DynamicResource Portfolio.Detail.Overview}"
                                        GroupName="LiabilityDetailTab"
                                        IsChecked="{Binding IsDetailOverviewTab, Mode=OneWay}"
                                        Style="{StaticResource AppPillTab}" />
                                    <RadioButton
                                        Command="{Binding SwitchDetailTabCommand}"
                                        CommandParameter="trades"
                                        Content="{DynamicResource Portfolio.Detail.Trades}"
                                        GroupName="LiabilityDetailTab"
                                        IsChecked="{Binding IsDetailTradesTab, Mode=OneWay}"
                                        Style="{StaticResource AppPillTab}" />
                                    <RadioButton
                                        Command="{Binding SwitchDetailTabCommand}"
                                        CommandParameter="schedule"
                                        Content="{DynamicResource Portfolio.Loan.Schedule}"
                                        GroupName="LiabilityDetailTab"
                                        IsChecked="{Binding IsDetailScheduleTab, Mode=OneWay}"
                                        Style="{StaticResource AppPillTab}"
                                        Visibility="{Binding SelectedLiabilityRow.IsLoan, Converter={StaticResource BooleanToVisibilityConverter}, FallbackValue=Collapsed}" />
                                </StackPanel>
                            </DockPanel>
                        </Border>

                        <ScrollViewer Grid.Row="2" VerticalScrollBarVisibility="Auto">
                            <Grid>
                                <StackPanel Margin="16,16,16,12" Visibility="{Binding IsDetailOverviewTab, Converter={StaticResource BooleanToVisibilityConverter}}">
                                    <StackPanel>
                                        <!--  Two stat cards: 總借款 + 剩餘債務 (with paid progress)  -->
                                        <Grid>
                                            <Grid.ColumnDefinitions>
                                                <ColumnDefinition Width="*" />
                                                <ColumnDefinition Width="10" />
                                                <ColumnDefinition Width="*" />
                                            </Grid.ColumnDefinitions>

                                            <!--  Left: 總借款 (sum of LoanBorrow trades — what was actually borrowed)  -->
                                            <Border
                                                Grid.Column="0"
                                                Padding="14,12"
                                                Background="{DynamicResource AppBackground}"
                                                BorderBrush="{DynamicResource AppBorder}"
                                                BorderThickness="1"
                                                CornerRadius="{StaticResource Radius.Sm}">
                                                <StackPanel>
                                                    <TextBlock
                                                        FontSize="{StaticResource Font.Size.Xs}"
                                                        Foreground="{DynamicResource AppTextSecondary}"
                                                        Text="{DynamicResource Portfolio.Detail.TotalBorrows}" />
                                                    <TextBlock
                                                        Margin="0,6,0,0"
                                                        FontFamily="{StaticResource Font.Family.Base}"
                                                        FontSize="{StaticResource Font.Size.Xl}"
                                                        FontWeight="SemiBold"
                                                        Foreground="{DynamicResource AppTextPrimary}"
                                                        Text="{Binding SelectedLiabilityTotalBorrows, Converter={StaticResource CurrencyConverter}, ConverterParameter=amount}"
                                                        Typography.NumeralAlignment="Tabular" />
                                                </StackPanel>
                                            </Border>

                                            <!--  Right: 剩餘債務 (current outstanding balance + paid progress bar)  -->
                                            <Border
                                                Grid.Column="2"
                                                Padding="14,12"
                                                Background="{DynamicResource AppBackground}"
                                                BorderBrush="{DynamicResource AppBorder}"
                                                BorderThickness="1"
                                                CornerRadius="{StaticResource Radius.Sm}">
                                                <StackPanel>
                                                    <TextBlock
                                                        FontSize="{StaticResource Font.Size.Xs}"
                                                        Foreground="{DynamicResource AppTextSecondary}"
                                                        Text="{DynamicResource Portfolio.Detail.RemainingDebt}" />
                                                    <TextBlock
                                                        Margin="0,6,0,10"
                                                        FontFamily="{StaticResource Font.Family.Base}"
                                                        FontSize="{StaticResource Font.Size.Xl}"
                                                        FontWeight="SemiBold"
                                                        Foreground="{DynamicResource AppDown}"
                                                        Text="{Binding SelectedLiabilityRow.Balance, Converter={StaticResource CurrencyConverter}, ConverterParameter=amount, FallbackValue=''}"
                                                        Typography.NumeralAlignment="Tabular" />
                                                    <Grid Margin="0,0,0,4">
                                                        <Border
                                                            Height="6"
                                                            Background="{DynamicResource AppBorder}"
                                                            CornerRadius="{StaticResource Radius.Sm}" />
                                                        <Border
                                                            Height="6"
                                                            HorizontalAlignment="Left"
                                                            Background="{DynamicResource AppUp}"
                                                            CornerRadius="{StaticResource Radius.Sm}">
                                                            <Border.Width>
                                                                <MultiBinding Converter="{StaticResource PercentToWidthConverter}">
                                                                    <Binding FallbackValue="0" Path="SelectedLiabilityRow.PaidPercent" />
                                                                    <Binding Path="ActualWidth" RelativeSource="{RelativeSource AncestorType=Grid}" />
                                                                </MultiBinding>
                                                            </Border.Width>
                                                        </Border>
                                                    </Grid>
                                                    <TextBlock
                                                        HorizontalAlignment="Right"
                                                        FontFamily="{StaticResource Font.Family.Base}"
                                                        FontSize="{StaticResource Font.Size.Xs}"
                                                        Foreground="{DynamicResource AppTextMuted}"
                                                        Text="{Binding SelectedLiabilityRow.PaidPercentDisplay, FallbackValue=''}"
                                                        Typography.NumeralAlignment="Tabular" />
                                                </StackPanel>
                                            </Border>
                                        </Grid>
                                    </StackPanel>
                                </StackPanel>

                                <!--
                                    Liability trades tab — P4.9b 對齊 Position / Cash table-style：
                                    4 欄 (日期 / 類型 / 價值 / Edit)。沿用 CashAmount + signed-dash
                                    保留既有顯示語意（不換成 TotalAmount，避免 sign 變動需逐筆驗證）。
                                -->
                                <Grid Margin="16,12" Visibility="{Binding IsDetailTradesTab, Converter={StaticResource BooleanToVisibilityConverter}}">
                                    <Grid.RowDefinitions>
                                        <RowDefinition Height="Auto" />
                                        <RowDefinition Height="*" />
                                    </Grid.RowDefinitions>

                                    <!--  Column header — P4.9c Note 欄移除  -->
                                    <Border
                                        Grid.Row="0"
                                        Padding="0,0,0,8"
                                        BorderBrush="{DynamicResource AppBorder}"
                                        BorderThickness="0,0,0,1">
                                        <Grid>
                                            <Grid.ColumnDefinitions>
                                                <ColumnDefinition Width="92" />
                                                <ColumnDefinition Width="80" />
                                                <ColumnDefinition Width="*" />
                                            </Grid.ColumnDefinitions>
                                            <TextBlock
                                                Grid.Column="0"
                                                FontSize="{StaticResource Font.Size.Xs}"
                                                Foreground="{DynamicResource AppTextSecondary}"
                                                Text="{DynamicResource Portfolio.TradeHistory.Date}" />
                                            <TextBlock
                                                Grid.Column="1"
                                                FontSize="{StaticResource Font.Size.Xs}"
                                                Foreground="{DynamicResource AppTextSecondary}"
                                                Text="{DynamicResource Portfolio.TradeHistory.Type}" />
                                            <TextBlock
                                                Grid.Column="2"
                                                HorizontalAlignment="Right"
                                                FontSize="{StaticResource Font.Size.Xs}"
                                                Foreground="{DynamicResource AppTextSecondary}"
                                                Text="{DynamicResource Portfolio.TradeHistory.GrossAmount}" />
                                        </Grid>
                                    </Border>

                                    <TextBlock
                                        Grid.Row="1"
                                        Margin="0,24,0,0"
                                        HorizontalAlignment="Center"
                                        VerticalAlignment="Top"
                                        FontSize="{StaticResource Font.Size.Sm}"
                                        Foreground="{DynamicResource AppTextMuted}"
                                        Text="{DynamicResource Portfolio.Detail.NoTrades}">
                                        <TextBlock.Style>
                                            <Style TargetType="TextBlock">
                                                <Setter Property="Visibility" Value="Collapsed" />
                                                <Style.Triggers>
                                                    <DataTrigger Binding="{Binding SelectedLiabilityTrades.Count, FallbackValue=0}" Value="0">
                                                        <Setter Property="Visibility" Value="Visible" />
                                                    </DataTrigger>
                                                </Style.Triggers>
                                            </Style>
                                        </TextBlock.Style>
                                    </TextBlock>

                                    <ItemsControl Grid.Row="1" ItemsSource="{Binding SelectedLiabilityTrades}">
                                        <ItemsControl.ItemTemplate>
                                            <DataTemplate>
                                                <Border
                                                    Padding="6,10"
                                                    BorderThickness="0,0,0,1"
                                                    Cursor="Hand"
                                                    ToolTip="{Binding Note}">
                                                    <Border.Style>
                                                        <Style TargetType="Border">
                                                            <Setter Property="BorderBrush" Value="{DynamicResource AppBorderLight}" />
                                                            <Setter Property="Background" Value="Transparent" />
                                                            <Style.Triggers>
                                                                <Trigger Property="IsMouseOver" Value="True">
                                                                    <Setter Property="Background" Value="{DynamicResource AppHover}" />
                                                                </Trigger>
                                                            </Style.Triggers>
                                                        </Style>
                                                    </Border.Style>
                                                    <Border.InputBindings>
                                                        <MouseBinding
                                                            Command="{Binding DataContext.Transaction.EditTradeCommand, RelativeSource={RelativeSource AncestorType=ItemsControl}}"
                                                            CommandParameter="{Binding}"
                                                            MouseAction="LeftClick" />
                                                    </Border.InputBindings>
                                                    <Grid>
                                                        <Grid.ColumnDefinitions>
                                                            <ColumnDefinition Width="92" />
                                                            <ColumnDefinition Width="80" />
                                                            <ColumnDefinition Width="*" />
                                                        </Grid.ColumnDefinitions>
                                                        <!--  日期  -->
                                                        <TextBlock
                                                            Grid.Column="0"
                                                            VerticalAlignment="Center"
                                                            FontFamily="{StaticResource Font.Family.Base}"
                                                            FontSize="{StaticResource Font.Size.Sm}"
                                                            Foreground="{DynamicResource AppTextPrimary}"
                                                            Text="{Binding TradeDateLocal, StringFormat=yyyy-MM-dd}"
                                                            Typography.NumeralAlignment="Tabular" />
                                                        <!--  類型 badge  -->
                                                        <Border
                                                            Grid.Column="1"
                                                            Padding="6,2"
                                                            HorizontalAlignment="Left"
                                                            VerticalAlignment="Center"
                                                            Background="{Binding TypeBadgeColor, Converter={StaticResource HexToBrushConverter}}"
                                                            CornerRadius="{StaticResource Radius.Sm}">
                                                            <TextBlock
                                                                FontSize="{StaticResource Font.Size.Xs}"
                                                                FontWeight="SemiBold"
                                                                Foreground="{DynamicResource AppTextOnAccent}"
                                                                Text="{Binding Type, Converter={StaticResource TradeTypeConverter}}" />
                                                        </Border>
                                                        <!--  價值 (沿用 CashAmount + signed-dash 既有語意)  -->
                                                        <TextBlock
                                                            Grid.Column="2"
                                                            HorizontalAlignment="Right"
                                                            VerticalAlignment="Center"
                                                            FontFamily="{StaticResource Font.Family.Base}"
                                                            FontSize="{StaticResource Font.Size.Sm}"
                                                            FontWeight="SemiBold"
                                                            Foreground="{DynamicResource AppTextPrimary}"
                                                            Text="{Binding CashAmount, Converter={StaticResource CurrencyConverter}, ConverterParameter=signed-dash}"
                                                            Typography.NumeralAlignment="Tabular" />
                                                    </Grid>
                                                </Border>
                                            </DataTemplate>
                                        </ItemsControl.ItemTemplate>
                                    </ItemsControl>
                                </Grid>

                                <!--  ── 攤還表 tab ──  -->
                                <StackPanel Margin="16,12,16,16" Visibility="{Binding IsDetailScheduleTab, Converter={StaticResource BooleanToVisibilityConverter}}">

                                    <!--  Loan metadata  -->
                                    <DockPanel Margin="0,0,0,8">
                                        <TextBlock
                                            VerticalAlignment="Center"
                                            FontSize="{StaticResource Font.Size.Xs}"
                                            Foreground="{DynamicResource AppTextMuted}">
                                            <Run Text="{DynamicResource Portfolio.Loan.Rate}" />
                                            <Run Text=":" />
                                            <Run
                                                FontFamily="{StaticResource Font.Family.Base}"
                                                Text="{Binding SelectedLiabilityRow.RateDisplay, FallbackValue='—', Mode=OneWay}"
                                                Typography.NumeralAlignment="Tabular" />
                                            <Run Text="  " />
                                            <Run Text="{DynamicResource Portfolio.Loan.Term}" />
                                            <Run Text=":" />
                                            <Run
                                                FontFamily="{StaticResource Font.Family.Base}"
                                                Text="{Binding SelectedLiabilityRow.TermDisplay, FallbackValue='—', Mode=OneWay}"
                                                Typography.NumeralAlignment="Tabular" />
                                        </TextBlock>
                                    </DockPanel>

                                    <!--  3 summary cards  -->
                                    <WrapPanel Margin="0,0,0,14" ItemWidth="152">
                                        <Border
                                            Margin="0,0,12,12"
                                            Padding="12,10"
                                            Background="{DynamicResource AppBackground}"
                                            BorderBrush="{DynamicResource AppBorder}"
                                            BorderThickness="1"
                                            CornerRadius="{StaticResource Radius.Sm}">
                                            <StackPanel>
                                                <TextBlock
                                                    FontSize="{StaticResource Font.Size.Xs}"
                                                    Foreground="{DynamicResource AppTextSecondary}"
                                                    Text="{DynamicResource Portfolio.Loan.PaidPrincipal}" />
                                                <TextBlock
                                                    Margin="0,4,0,0"
                                                    FontFamily="{StaticResource Font.Family.Base}"
                                                    FontSize="{StaticResource Font.Size.Sm}"
                                                    FontWeight="SemiBold"
                                                    Foreground="{DynamicResource AppUp}"
                                                    Text="{Binding SelectedLiabilityRow.PaidPrincipal, Converter={StaticResource CurrencyConverter}, ConverterParameter=amount, FallbackValue='—'}"
                                                    Typography.NumeralAlignment="Tabular" />
                                            </StackPanel>
                                        </Border>
                                        <Border
                                            Margin="0,0,12,12"
                                            Padding="12,10"
                                            Background="{DynamicResource AppBackground}"
                                            BorderBrush="{DynamicResource AppBorder}"
                                            BorderThickness="1"
                                            CornerRadius="{StaticResource Radius.Sm}">
                                            <StackPanel>
                                                <TextBlock
                                                    FontSize="{StaticResource Font.Size.Xs}"
                                                    Foreground="{DynamicResource AppTextSecondary}"
                                                    Text="{DynamicResource Portfolio.Loan.PaidInterest}" />
                                                <TextBlock
                                                    Margin="0,4,0,0"
                                                    FontFamily="{StaticResource Font.Family.Base}"
                                                    FontSize="{StaticResource Font.Size.Sm}"
                                                    FontWeight="SemiBold"
                                                    Foreground="{DynamicResource AppTextPrimary}"
                                                    Text="{Binding SelectedLiabilityRow.PaidInterest, Converter={StaticResource CurrencyConverter}, ConverterParameter=amount, FallbackValue='—'}"
                                                    Typography.NumeralAlignment="Tabular" />
                                            </StackPanel>
                                        </Border>
                                        <Border
                                            Margin="0,0,12,12"
                                            Padding="12,10"
                                            Background="{DynamicResource AppBackground}"
                                            BorderBrush="{DynamicResource AppBorder}"
                                            BorderThickness="1"
                                            CornerRadius="{StaticResource Radius.Sm}">
                                            <StackPanel>
                                                <TextBlock
                                                    FontSize="{StaticResource Font.Size.Xs}"
                                                    Foreground="{DynamicResource AppTextSecondary}"
                                                    Text="{DynamicResource Portfolio.Loan.RemainingBalance}" />
                                                <TextBlock
                                                    Margin="0,4,0,0"
                                                    FontFamily="{StaticResource Font.Family.Base}"
                                                    FontSize="{StaticResource Font.Size.Sm}"
                                                    FontWeight="SemiBold"
                                                    Foreground="{DynamicResource AppDown}"
                                                    Text="{Binding SelectedLiabilityRow.RemainingFromSchedule, Converter={StaticResource CurrencyConverter}, ConverterParameter=amount, FallbackValue='—'}"
                                                    Typography.NumeralAlignment="Tabular" />
                                            </StackPanel>
                                        </Border>
                                    </WrapPanel>

                                    <!--  Empty state  -->
                                    <TextBlock
                                        Margin="0,16,0,0"
                                        HorizontalAlignment="Center"
                                        FontSize="{StaticResource Font.Size.Sm}"
                                        Foreground="{DynamicResource AppTextMuted}"
                                        Text="{DynamicResource Portfolio.Loan.NoSchedule}">
                                        <TextBlock.Style>
                                            <Style TargetType="TextBlock">
                                                <Setter Property="Visibility" Value="Collapsed" />
                                                <Style.Triggers>
                                                    <DataTrigger Binding="{Binding SelectedLiabilityRow.HasSchedule, FallbackValue=False}" Value="False">
                                                        <Setter Property="Visibility" Value="Visible" />
                                                    </DataTrigger>
                                                </Style.Triggers>
                                            </Style>
                                        </TextBlock.Style>
                                    </TextBlock>

                                    <ItemsControl ItemsSource="{Binding SelectedLiabilityRow.ScheduleEntries}" Visibility="{Binding SelectedLiabilityRow.HasSchedule, Converter={StaticResource BooleanToVisibilityConverter}, FallbackValue=Collapsed}">
                                        <ItemsControl.ItemTemplate>
                                            <DataTemplate>
                                                <Border Margin="0,0,0,10" Padding="12">
                                                    <Border.Style>
                                                        <Style BasedOn="{StaticResource FormCard}" TargetType="{x:Type Border}">
                                                            <Setter Property="Opacity" Value="1" />
                                                            <Style.Triggers>
                                                                <DataTrigger Binding="{Binding IsPaid}" Value="True">
                                                                    <Setter Property="Opacity" Value="0.55" />
                                                                </DataTrigger>
                                                            </Style.Triggers>
                                                        </Style>
                                                    </Border.Style>
                                                    <StackPanel>
                                                        <DockPanel LastChildFill="True">
                                                            <Border
                                                                Margin="0,0,10,0"
                                                                Padding="8,3"
                                                                Background="{DynamicResource AppBackground}"
                                                                BorderBrush="{DynamicResource AppBorder}"
                                                                BorderThickness="1"
                                                                CornerRadius="{StaticResource Radius.Sm}"
                                                                DockPanel.Dock="Left">
                                                                <TextBlock
                                                                    FontFamily="{StaticResource Font.Family.Base}"
                                                                    FontSize="{StaticResource Font.Size.Xs}"
                                                                    FontWeight="SemiBold"
                                                                    Foreground="{DynamicResource AppTextPrimary}"
                                                                    Text="{Binding Period, StringFormat={}{0:00}}"
                                                                    Typography.NumeralAlignment="Tabular" />
                                                            </Border>
                                                            <TextBlock
                                                                DockPanel.Dock="Right"
                                                                FontFamily="{StaticResource Font.Family.Base}"
                                                                FontSize="{StaticResource Font.Size.Xs}"
                                                                Foreground="{DynamicResource AppTextMuted}"
                                                                Text="{Binding DueDateDisplay}"
                                                                Typography.NumeralAlignment="Tabular" />
                                                            <TextBlock
                                                                FontSize="{StaticResource Font.Size.Sm}"
                                                                FontWeight="SemiBold"
                                                                Foreground="{DynamicResource AppTextPrimary}">
                                                                <TextBlock.Style>
                                                                    <Style TargetType="TextBlock">
                                                                        <Setter Property="Text" Value="{DynamicResource Portfolio.Loan.PaymentPending}" />
                                                                        <Style.Triggers>
                                                                            <DataTrigger Binding="{Binding IsPaid}" Value="True">
                                                                                <Setter Property="Text" Value="{DynamicResource Portfolio.Loan.PaymentConfirmed}" />
                                                                            </DataTrigger>
                                                                        </Style.Triggers>
                                                                    </Style>
                                                                </TextBlock.Style>
                                                            </TextBlock>
                                                        </DockPanel>

                                                        <WrapPanel Margin="0,8,0,0">
                                                            <StackPanel Margin="0,0,20,4">
                                                                <TextBlock
                                                                    FontSize="{StaticResource Font.Size.Xs}"
                                                                    Foreground="{DynamicResource AppTextSecondary}"
                                                                    Text="{DynamicResource Portfolio.Loan.Principal}" />
                                                                <TextBlock
                                                                    Margin="0,2,0,0"
                                                                    FontFamily="{StaticResource Font.Family.Base}"
                                                                    FontSize="{StaticResource Font.Size.Sm}"
                                                                    FontWeight="SemiBold"
                                                                    Foreground="{DynamicResource AppTextPrimary}"
                                                                    Text="{Binding PrincipalAmount, Converter={StaticResource CurrencyConverter}, ConverterParameter=amount}"
                                                                    Typography.NumeralAlignment="Tabular" />
                                                            </StackPanel>
                                                            <StackPanel Margin="0,0,20,4">
                                                                <TextBlock
                                                                    FontSize="{StaticResource Font.Size.Xs}"
                                                                    Foreground="{DynamicResource AppTextSecondary}"
                                                                    Text="{DynamicResource Portfolio.Loan.Interest}" />
                                                                <TextBlock
                                                                    Margin="0,2,0,0"
                                                                    FontFamily="{StaticResource Font.Family.Base}"
                                                                    FontSize="{StaticResource Font.Size.Sm}"
                                                                    FontWeight="SemiBold"
                                                                    Foreground="{DynamicResource AppTextPrimary}"
                                                                    Text="{Binding InterestAmount, Converter={StaticResource CurrencyConverter}, ConverterParameter=amount}"
                                                                    Typography.NumeralAlignment="Tabular" />
                                                            </StackPanel>
                                                            <StackPanel Margin="0,0,20,4">
                                                                <TextBlock
                                                                    FontSize="{StaticResource Font.Size.Xs}"
                                                                    Foreground="{DynamicResource AppTextSecondary}"
                                                                    Text="{DynamicResource Portfolio.TradeHistory.GrossAmount}" />
                                                                <TextBlock
                                                                    Margin="0,2,0,0"
                                                                    FontFamily="{StaticResource Font.Family.Base}"
                                                                    FontSize="{StaticResource Font.Size.Sm}"
                                                                    FontWeight="SemiBold"
                                                                    Foreground="{DynamicResource AppTextPrimary}"
                                                                    Text="{Binding TotalAmount, Converter={StaticResource CurrencyConverter}, ConverterParameter=amount}"
                                                                    Typography.NumeralAlignment="Tabular" />
                                                            </StackPanel>
                                                        </WrapPanel>

                                                        <Button
                                                            Height="28"
                                                            Margin="0,2,0,0"
                                                            Padding="10,0"
                                                            HorizontalAlignment="Left"
                                                            Command="{Binding DataContext.Loan.ConfirmLoanPaymentCommand, RelativeSource={RelativeSource AncestorType=ItemsControl}}"
                                                            CommandParameter="{Binding}">
                                                            <Button.Style>
                                                                <Style BasedOn="{StaticResource AppPrimaryButton}" TargetType="{x:Type Button}">
                                                                    <Setter Property="Visibility" Value="Visible" />
                                                                    <Style.Triggers>
                                                                        <DataTrigger Binding="{Binding IsPaid}" Value="True">
                                                                            <Setter Property="Visibility" Value="Collapsed" />
                                                                        </DataTrigger>
                                                                    </Style.Triggers>
                                                                </Style>
                                                            </Button.Style>
                                                            <TextBlock
                                                                FontSize="{StaticResource Font.Size.Xs}"
                                                                Foreground="{Binding Foreground, RelativeSource={RelativeSource AncestorType=Button}}"
                                                                Text="{DynamicResource Portfolio.Loan.ConfirmPayment}" />
                                                        </Button>
                                                    </StackPanel>
                                                </Border>
                                            </DataTemplate>
                                        </ItemsControl.ItemTemplate>
                                    </ItemsControl>
                                </StackPanel>

                            </Grid>
                        </ScrollViewer>

                        <!--  Danger zone  -->
                        <Border
                            Grid.Row="3"
                            Margin="16,0,16,16"
                            Padding="14,12"
                            Background="{DynamicResource AppBackground}"
                            BorderBrush="{DynamicResource AppDanger}"
                            BorderThickness="1"
                            CornerRadius="{StaticResource Radius.Sm}">
                            <Grid>
                                <Grid.ColumnDefinitions>
                                    <ColumnDefinition Width="*" />
                                    <ColumnDefinition Width="Auto" />
                                </Grid.ColumnDefinitions>
                                <StackPanel Grid.Column="0" VerticalAlignment="Center">
                                    <StackPanel Margin="0,0,0,2" Orientation="Horizontal">
                                        <ds:AppIcon
                                            Margin="0,0,6,0"
                                            VerticalAlignment="Center"
                                            FontSize="11"
                                            Foreground="{DynamicResource AppDanger}"
                                            Symbol="Delete24" />
                                        <TextBlock
                                            FontSize="{StaticResource Font.Size.Xs}"
                                            FontWeight="SemiBold"
                                            Foreground="{DynamicResource AppDanger}"
                                            Text="{DynamicResource Portfolio.Detail.DeleteLiability}" />
                                    </StackPanel>
                                    <TextBlock
                                        FontSize="{StaticResource Font.Size.Xs}"
                                        Foreground="{DynamicResource AppTextSecondary}"
                                        Text="{DynamicResource Portfolio.Detail.DeleteWarning}"
                                        TextWrapping="Wrap" />
                                </StackPanel>
                                <Button
                                    Grid.Column="1"
                                    Height="32"
                                    Margin="12,0,0,0"
                                    Padding="14,0"
                                    VerticalAlignment="Center"
                                    Command="{Binding RemoveLiabilityCommand}"
                                    CommandParameter="{Binding SelectedLiabilityRow}"
                                    Style="{StaticResource AppDangerButton}">
                                    <TextBlock
                                        FontSize="{StaticResource Font.Size.Xs}"
                                        Foreground="{Binding Foreground, RelativeSource={RelativeSource AncestorType=Button}}"
                                        Text="{DynamicResource Portfolio.Detail.DeleteLiability}" />
                                </Button>
                            </Grid>
                        </Border>

                    </Grid>
                </Border>
            </Grid>
        </Grid>


        <!--
            Shell-level AddRecord dialog overlay. Promoted from PortfolioView so
            the dialog can render regardless of which section is active. The
            global Ctrl+N + title-bar button can fire from any page (Cash,
            Liabilities, TransactionLog, FinancialOverview, …) and the user
            sees the dialog without a forced navigation back to Portfolio.
        -->
        <pcontrols:AddRecordDialog
            Grid.Row="0"
            Grid.RowSpan="3"
            Panel.ZIndex="210"
            DataContext="{Binding Portfolio.Transaction}" />

        <!--
            AddAssetDialog (新增帳戶 / 新增負債) — promoted from PortfolioView so
            users on CashAccounts / Liabilities top-level pages can also create.
        -->
        <pcontrols:AddAssetDialog
            Grid.Row="0"
            Grid.RowSpan="3"
            Panel.ZIndex="200"
            DataContext="{Binding Portfolio}" />

        <!--
            新增投資 (前身為「加入觀察標的」watchlist) dialog — hoisted to MainWindow
            so the backdrop dims NavRail + title bar like other top-level dialogs.
            DataContext = PortfolioViewModel (IsAddWatchlistOpen / Confirm 等都在那)。
        -->
        <Grid
            Grid.Row="0"
            Grid.RowSpan="3"
            Panel.ZIndex="190"
            beh:EscapeKeyCommandBehavior.Command="{Binding CloseAddWatchlistDialogCommand}"
            DataContext="{Binding Portfolio}"
            Visibility="{Binding IsAddWatchlistOpen, Converter={StaticResource BooleanToVisibilityConverter}}">
            <Border Background="#80000000">
                <Border.InputBindings>
                    <MouseBinding MouseAction="LeftClick" Command="{Binding CloseAddWatchlistDialogCommand}" />
                </Border.InputBindings>
            </Border>
            <Border Width="420" Padding="24,20,24,20"
                    HorizontalAlignment="Center" VerticalAlignment="Center"
                    Background="{DynamicResource AppCardBackground}"
                    BorderBrush="{DynamicResource AppBorder}"
                    BorderThickness="1"
                    CornerRadius="{StaticResource Radius.Md}">
                <!--
                    Grid 而不是 StackPanel — 把 close 按鈕用 absolute positioning
                    釘在卡片右上角；表單內容仍放在中央 StackPanel。
                -->
                <Grid>
                    <!-- Top-right close button. Negative margin 讓它「貼齊」卡片邊緣，
                         保留 32x32 hit area 但視覺上看起來是邊角的浮動 icon。 -->
                    <Button HorizontalAlignment="Right" VerticalAlignment="Top"
                            Margin="0,-4,-8,0"
                            Width="32" Height="32" Padding="0"
                            Panel.ZIndex="5"
                            Command="{Binding CloseAddWatchlistDialogCommand}"
                            Style="{StaticResource AppIconButton}"
                            ToolTip="{DynamicResource Common.Close}">
                        <ds:AppIcon FontSize="13" Foreground="{DynamicResource AppTextMuted}" Symbol="Dismiss24" />
                    </Button>

                    <StackPanel Margin="0,0,32,0">
                        <!-- 標題 + 描述 -->
                        <TextBlock Margin="0,0,0,6"
                                   FontSize="{StaticResource Font.Size.Lg}"
                                   FontWeight="SemiBold"
                                   Foreground="{DynamicResource AppTextPrimary}"
                                   Text="{DynamicResource Portfolio.Watchlist.AddTitle}" />
                        <TextBlock Margin="0,0,0,18"
                                   FontSize="{StaticResource Font.Size.Xs}"
                                   Foreground="{DynamicResource AppTextMuted}"
                                   Text="{DynamicResource Portfolio.Watchlist.AddHint}"
                                   TextWrapping="Wrap" />

                        <!-- 類型 -->
                        <TextBlock Margin="0,0,0,4"
                                   FontSize="{StaticResource Font.Size.Xs}"
                                   FontWeight="SemiBold"
                                   Foreground="{DynamicResource AppTextSecondary}"
                                   Text="{DynamicResource Portfolio.Watchlist.AssetType}" />
                        <ComboBox Margin="0,0,0,12"
                                  ItemsSource="{Binding WatchlistAssetTypeOptions}"
                                  SelectedItem="{Binding WatchlistAssetType, Mode=TwoWay}"
                                  Style="{StaticResource FormComboBox}">
                            <ComboBox.ItemTemplate>
                                <DataTemplate>
                                    <TextBlock Text="{Binding Converter={StaticResource AssetTypeToLocalizedNameConverter}}" />
                                </DataTemplate>
                            </ComboBox.ItemTemplate>
                        </ComboBox>

                        <!-- 代號 -->
                        <TextBlock Margin="0,0,0,4"
                                   FontSize="{StaticResource Font.Size.Xs}"
                                   FontWeight="SemiBold"
                                   Foreground="{DynamicResource AppTextSecondary}"
                                   Text="{DynamicResource Portfolio.Watchlist.Symbol}" />
                        <TextBox Margin="0,0,0,12"
                                 FontFamily="{StaticResource Font.Family.Base}"
                                 Style="{StaticResource AppTextBox}"
                                 Text="{Binding WatchlistSymbol, UpdateSourceTrigger=PropertyChanged}" />

                        <!-- 名稱 -->
                        <TextBlock Margin="0,0,0,4"
                                   FontSize="{StaticResource Font.Size.Xs}"
                                   FontWeight="SemiBold"
                                   Foreground="{DynamicResource AppTextSecondary}"
                                   Text="{DynamicResource Portfolio.Watchlist.Name}" />
                        <TextBox Margin="0,0,0,12"
                                 Style="{StaticResource AppTextBox}"
                                 Text="{Binding WatchlistName, UpdateSourceTrigger=PropertyChanged}" />

                        <!-- 幣別 -->
                        <TextBlock Margin="0,0,0,4"
                                   FontSize="{StaticResource Font.Size.Xs}"
                                   FontWeight="SemiBold"
                                   Foreground="{DynamicResource AppTextSecondary}"
                                   Text="{DynamicResource Portfolio.Watchlist.Currency}" />
                        <ComboBox Margin="0,0,0,4"
                                  ItemsSource="{Binding WatchlistCurrencyOptions}"
                                  SelectedItem="{Binding WatchlistCurrency, Mode=TwoWay}"
                                  Style="{StaticResource FormComboBox}" />

                        <TextBlock Margin="0,10,0,0"
                                   FontSize="{StaticResource Font.Size.Xs}"
                                   Foreground="{DynamicResource AppDown}"
                                   Text="{Binding WatchlistError}"
                                   Visibility="{Binding WatchlistError, Converter={StaticResource StringToVisibilityConverter}}" />

                        <!-- 動作列：拉高到 36，間距加大，更現代 -->
                        <StackPanel Margin="0,22,0,0" HorizontalAlignment="Right" Orientation="Horizontal">
                            <Button Height="36" MinWidth="84" Margin="0,0,10,0" Padding="16,0"
                                    Command="{Binding CloseAddWatchlistDialogCommand}"
                                    Content="{DynamicResource Portfolio.Cancel}"
                                    Style="{StaticResource AppSecondaryButton}" />
                            <Button Height="36" MinWidth="84" Padding="16,0"
                                    Command="{Binding ConfirmAddWatchlistCommand}"
                                    Content="{DynamicResource Portfolio.Watchlist.AddButton}"
                                    Style="{StaticResource AppPrimaryButton}" />
                        </StackPanel>
                    </StackPanel>
                </Grid>
            </Border>
        </Grid>

        <!--  EditAssetDialog (編輯現有資產) — same shell promotion as above.  -->
        <pcontrols:EditAssetDialog
            Grid.Row="0"
            Grid.RowSpan="3"
            Panel.ZIndex="205"
            DataContext="{Binding Portfolio.Account}" />

        <!--
            EditLiabilityDialog (編輯既有負債 — Loan / CreditCard metadata)
            B 方案：含可選的 Loan 攤還表重算。已付期保留原樣，未付期重新生成。
            DataContext = PortfolioViewModel.EditLiabilityDialog (sub-VM)。
        -->
        <Grid
            Grid.Row="0"
            Grid.RowSpan="3"
            Panel.ZIndex="208"
            DataContext="{Binding Portfolio.EditLiabilityDialog}"
            Style="{StaticResource AppDialogOverlay}"
            Visibility="{Binding IsOpen, Converter={StaticResource BooleanToVisibilityConverter}}">
            <Border
                Width="480"
                MaxHeight="640"
                HorizontalAlignment="Center"
                VerticalAlignment="Center"
                beh:EscapeKeyCommandBehavior.Command="{Binding CancelCommand}"
                Style="{StaticResource AppDialogShell}">
                <Grid>
                    <Grid.RowDefinitions>
                        <RowDefinition Height="Auto" />
                        <RowDefinition Height="*" />
                        <RowDefinition Height="Auto" />
                    </Grid.RowDefinitions>

                    <!--  Header  -->
                    <Border
                        Grid.Row="0"
                        Padding="20,16"
                        BorderBrush="{DynamicResource AppBorder}"
                        BorderThickness="0,0,0,1">
                        <TextBlock
                            FontSize="{StaticResource Font.Size.Lg}"
                            FontWeight="SemiBold"
                            Foreground="{DynamicResource AppTextPrimary}"
                            Text="{DynamicResource Portfolio.EditLiability.Title}" />
                    </Border>

                    <!--  Body  -->
                    <ScrollViewer
                        Grid.Row="1"
                        Padding="20,16"
                        HorizontalScrollBarVisibility="Disabled"
                        VerticalScrollBarVisibility="Auto">
                        <StackPanel>

                            <!--  Common: Name  -->
                            <TextBlock
                                Margin="0,0,0,4"
                                FontSize="{StaticResource Font.Size.Xs}"
                                Foreground="{DynamicResource AppTextSecondary}"
                                Text="{DynamicResource Portfolio.EditLiability.Name}" />
                            <TextBox
                                Margin="0,0,0,12"
                                Padding="8,6"
                                Style="{StaticResource AppTextBox}"
                                Text="{Binding Name, UpdateSourceTrigger=PropertyChanged}" />

                            <!--  Issuer (both)  -->
                            <TextBlock
                                Margin="0,0,0,4"
                                FontSize="{StaticResource Font.Size.Xs}"
                                Foreground="{DynamicResource AppTextSecondary}"
                                Text="{DynamicResource Portfolio.EditLiability.Issuer}" />
                            <TextBox
                                Margin="0,0,0,12"
                                Padding="8,6"
                                Style="{StaticResource AppTextBox}"
                                Text="{Binding IssuerName, UpdateSourceTrigger=PropertyChanged}" />

                            <!--  Loan-only fields  -->
                            <StackPanel Visibility="{Binding IsLoanEdit, Converter={StaticResource BooleanToVisibilityConverter}}">
                                <Border
                                    Height="1"
                                    Margin="0,4,0,12"
                                    Background="{DynamicResource AppBorderLight}" />
                                <TextBlock
                                    Margin="0,0,0,8"
                                    FontSize="{StaticResource Font.Size.Sm}"
                                    FontWeight="SemiBold"
                                    Foreground="{DynamicResource AppTextPrimary}"
                                    Text="{DynamicResource Portfolio.EditLiability.LoanSection}" />

                                <Grid Margin="0,0,0,12">
                                    <Grid.ColumnDefinitions>
                                        <ColumnDefinition Width="*" />
                                        <ColumnDefinition Width="12" />
