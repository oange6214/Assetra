<Window
    x:Class="Assetra.WPF.Shell.SplashScreen"
    xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
    xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
    Title="Assetra"
    Width="320"
    Height="260"
    AllowsTransparency="True"
    Background="Transparent"
    ResizeMode="NoResize"
    WindowStartupLocation="CenterScreen"
    WindowStyle="None">

    <Border
        Background="{DynamicResource AppBackground}"
        BorderBrush="{DynamicResource AppBorder}"
        BorderThickness="1"
        CornerRadius="12">
        <StackPanel
            HorizontalAlignment="Center"
            VerticalAlignment="Center">

            <!--  Vector logo — crisp at any DPI  -->
            <Viewbox Width="72" Height="72" HorizontalAlignment="Center">
                <Canvas Width="100" Height="100">
                    <Rectangle Width="100" Height="100" RadiusX="17" RadiusY="17" Fill="#16A34A" />
                    <Rectangle Canvas.Left="14" Canvas.Top="58" Width="19" Height="27" RadiusX="3" RadiusY="3" Fill="#FFFFFFBF" />
                    <Rectangle Canvas.Left="41" Canvas.Top="42" Width="19" Height="43" RadiusX="3" RadiusY="3" Fill="#FFFFFFDF" />
                    <Rectangle Canvas.Left="68" Canvas.Top="23" Width="19" Height="62" RadiusX="3" RadiusY="3" Fill="White" />
                    <Polyline
                        Points="23,58 50,42 77,23"
                        Opacity="0.9"
                        Stroke="White"
                        StrokeEndLineCap="Round"
                        StrokeLineJoin="Round"
                        StrokeStartLineCap="Round"
                        StrokeThickness="5" />
                    <Ellipse Canvas.Left="18" Canvas.Top="53" Width="10" Height="10" Fill="White" />
                    <Ellipse Canvas.Left="45" Canvas.Top="37" Width="10" Height="10" Fill="White" />
                    <Ellipse Canvas.Left="72" Canvas.Top="18" Width="10" Height="10" Fill="White" />
                </Canvas>
            </Viewbox>

            <!--  App name  -->
            <TextBlock
                Margin="0,14,0,0"
                HorizontalAlignment="Center"
                FontFamily="{StaticResource FontBase}"
                FontSize="{StaticResource FontSizeXl}"
                FontWeight="Bold"
                Foreground="{DynamicResource AppTextPrimary}"
                Text="Assetra" />

            <!--  Tagline  -->
            <TextBlock
                Margin="0,4,0,0"
                HorizontalAlignment="Center"
                FontFamily="{StaticResource FontBase}"
                FontSize="{StaticResource FontSizeSm}"
                Foreground="{DynamicResource AppTextMuted}"
                Text="{DynamicResource About.Description}" />

            <!--  Progress bar  -->
            <ProgressBar
                x:Name="LoadingBar"
                Width="200"
                Height="4"
                Margin="0,18,0,0"
                HorizontalAlignment="Center"
                Maximum="100"
                Minimum="0"
                Value="0" />

            <!--  Status text  -->
            <TextBlock
                x:Name="StatusText"
                Margin="0,8,0,0"
                HorizontalAlignment="Center"
                FontFamily="{StaticResource FontBase}"
                FontSize="{StaticResource FontSizeXs}"
                Foreground="{DynamicResource AppTextMuted}" />
        </StackPanel>
    </Border>
</Window>
