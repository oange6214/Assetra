<ResourceDictionary xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation" xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml">

    <!--
        ════════════════════════════════════════════════════════════
        Form / card surface helpers
        ════════════════════════════════════════════════════════════
        FormCard         : Border ready-to-use as a form container —
        16 px padding, AppSurface bg, 1 px AppBorder,
        Radius.Lg (8) corners.
        FormSectionTitle : 20 px SemiBold AppTextPrimary heading with
        12 px bottom margin, for section labels
        inside a form.
    -->

    <!--
        P3.6 — FormCard 對齊 P3.1 baseline。原本 BorderBrush=AppBorder + Radius.Lg
        + 無 shadow，跟新的 AppCardSummary (BorderLight + Radius.2Xl) 並排時邊框
        粗細不齊、圓角大小不一造成「card 不一致」視覺破綻。
        現在 FormCard 跟 AppCardSummary 視覺完全等價 — 70+ 使用點自動同步升級。

        P3.7 — Shadow.Card 拿掉。CSS `box-shadow: 0 14px 36px` 在 mockup HTML
        是 spread+falloff 自然浮起感，但 WPF DropShadowEffect 在 14px ShadowDepth
        會渲染成 card 下方一條明顯「色塊」帶狀 — 視覺很詭異。
        改用 border-only 區隔卡片即可（mockup「calm + minimal」設計感本來就靠
        border + bg contrast 而非 shadow）。
    -->
    <Style x:Key="FormCard" TargetType="Border">
        <Setter Property="Padding" Value="20" />
        <Setter Property="Background" Value="{DynamicResource AppCardBackground}" />
        <Setter Property="BorderBrush" Value="{DynamicResource AppBorderLight}" />
        <Setter Property="BorderThickness" Value="1" />
        <Setter Property="CornerRadius" Value="{StaticResource Radius.2Xl}" />
    </Style>

    <Style x:Key="FormSectionTitle" TargetType="TextBlock">
        <Setter Property="Margin" Value="0,0,0,12" />
        <Setter Property="FontFamily" Value="{StaticResource Font.Family.Display}" />
        <Setter Property="FontSize" Value="{StaticResource Font.Size.Lg}" />
        <Setter Property="FontWeight" Value="SemiBold" />
        <Setter Property="Foreground" Value="{DynamicResource AppTextPrimary}" />
    </Style>

    <!--
        ════════════════════════════════════════════════════════════
        P2.13 — Dashboard card system
        ════════════════════════════════════════════════════════════
        AppCard*：dashboard / overview 區域用的卡片組件。跟 FormCard
        差異：
          - 圓角用 Radius.Md (不是 Lg) — dashboard 卡片密集，過大圓
            角會破壞視覺對齊
          - Border 用 AppBorderLight (Layer2) — 跟 Hero/Summary tier
            lightening 一致
        AppCardHero    : 高 emphasis card (e.g. 淨資產 hero) — accent
                         邊框，padding 較大
        AppCardSummary : 中 emphasis (公式列, KPI rows) — 標準 padding
                         + light border
        AppCardSubtle  : 低 emphasis (analytics widgets) — light border
                         + 16,14 padding
        Hero / Summary / Subtle 視覺差用 padding + border 顏色拉開，
        而不是塞滿色塊（過工業）。
    -->

    <!--
        P3.1 — 三層 AppCard* 全部對齊 mockup HTML 的 "Wealth Platform"
        baseline：radius=18 (Radius.2Xl) + 統一 padding 20。Hero / Summary /
        Subtle 差異現在只在 Padding + Margin（hierarchy 用 padding 大小 + margin
        區隔），其餘視覺一致 — 所有頁面看起來像同家公司做的核心 token。

        P3.7 — Shadow.Card 拿掉（CSS box-shadow → WPF DropShadowEffect
        渲染成下方「色塊」帶狀很詭異）。Calm + Minimal 設計感靠 border + bg
        contrast 區分卡片就足夠，符合 mockup「Wealth Platform」 sophisticated 風格。
    -->
    <Style x:Key="AppCardHero" TargetType="Border">
        <Setter Property="Padding" Value="20" />
        <Setter Property="Background" Value="{DynamicResource AppCardBackground}" />
        <Setter Property="BorderBrush" Value="{DynamicResource AppBorderLight}" />
        <Setter Property="BorderThickness" Value="1" />
        <Setter Property="CornerRadius" Value="{StaticResource Radius.2Xl}" />
        <Setter Property="Margin" Value="0,0,0,16" />
    </Style>

    <Style x:Key="AppCardSummary" TargetType="Border">
        <Setter Property="Padding" Value="20" />
        <Setter Property="Background" Value="{DynamicResource AppCardBackground}" />
        <Setter Property="BorderBrush" Value="{DynamicResource AppBorderLight}" />
        <Setter Property="BorderThickness" Value="1" />
        <Setter Property="CornerRadius" Value="{StaticResource Radius.2Xl}" />
    </Style>

    <Style x:Key="AppCardSubtle" TargetType="Border">
        <Setter Property="Padding" Value="20" />
        <Setter Property="Background" Value="{DynamicResource AppCardBackground}" />
        <Setter Property="BorderBrush" Value="{DynamicResource AppBorderLight}" />
        <Setter Property="BorderThickness" Value="1" />
        <Setter Property="CornerRadius" Value="{StaticResource Radius.2Xl}" />
        <Setter Property="Margin" Value="0,0,0,16" />
    </Style>

    <Style x:Key="AppCardHeader" TargetType="TextBlock">
        <Setter Property="FontFamily" Value="{StaticResource Font.Family.UI}" />
        <Setter Property="FontSize" Value="{StaticResource Font.Size.Sm}" />
        <Setter Property="FontWeight" Value="SemiBold" />
        <Setter Property="Foreground" Value="{DynamicResource AppTextSecondary}" />
        <Setter Property="Margin" Value="0,0,0,10" />
    </Style>

    <Style x:Key="AppCardCaption" TargetType="TextBlock">
        <Setter Property="FontFamily" Value="{StaticResource Font.Family.UI}" />
        <Setter Property="FontSize" Value="{StaticResource Font.Size.Xs}" />
        <Setter Property="Foreground" Value="{DynamicResource AppTextMuted}" />
    </Style>

    <!--
        P2.17 T04 — Keyboard shortcut chip (kbd-style)。Border + padding 模擬
        實體鍵盤按鍵外觀，給 shortcuts help dialog / inline 顯示。
    -->
    <Style x:Key="AppKbdChip" TargetType="Border">
        <Setter Property="Background" Value="{DynamicResource AppSurfaceAlt}" />
        <Setter Property="BorderBrush" Value="{DynamicResource AppBorderLight}" />
        <Setter Property="BorderThickness" Value="1" />
        <Setter Property="CornerRadius" Value="4" />
        <Setter Property="Padding" Value="6,2" />
        <Setter Property="MinWidth" Value="24" />
        <Setter Property="Margin" Value="0,0,4,0" />
    </Style>

    <Style x:Key="AppKbdChipText" TargetType="TextBlock">
        <Setter Property="FontFamily" Value="{StaticResource Font.Family.UI}" />
        <Setter Property="FontSize" Value="{StaticResource Font.Size.Xs}" />
        <Setter Property="FontWeight" Value="{StaticResource Font.Weight.Medium}" />
        <Setter Property="Foreground" Value="{DynamicResource AppTextSecondary}" />
        <Setter Property="HorizontalAlignment" Value="Center" />
    </Style>

</ResourceDictionary>
