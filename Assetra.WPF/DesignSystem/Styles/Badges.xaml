<ResourceDictionary xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation" xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml">

    <!--
        ══════════════════════════════════════════════════════════
        StatusBadge — pill labels for state metadata
        ══════════════════════════════════════════════════════════
        Use to label state on rows, cards, and toolbars: active /
        archived / pending / healthy / warning / danger / info /
        special. Variants set Background and Foreground only;
        layout is shared via StatusBadge.Container + StatusBadge.Text.

        Composition pattern:
            <Border Style="{StaticResource StatusBadge.Success}">
                <TextBlock Style="{StaticResource StatusBadge.Text}" Text="Active" />
            </Border>

        Variants do NOT use the AppDanger/AppWarning brushes directly —
        those are full-saturation foreground colors. Badges use the
        subtle/soft brand tints where available, falling back to the
        full brush at reduced opacity via solid theme brushes.
    -->

    <!--  Shared text style inside any badge variant  -->
    <Style x:Key="StatusBadge.Text" TargetType="TextBlock">
        <Setter Property="HorizontalAlignment" Value="Center" />
        <Setter Property="VerticalAlignment" Value="Center" />
        <Setter Property="FontFamily" Value="{StaticResource Font.Family.UI}" />
        <Setter Property="FontSize" Value="{StaticResource Font.Size.Xs}" />
        <Setter Property="FontWeight" Value="{StaticResource Font.Weight.Medium}" />
    </Style>

    <!--  Shared container layout  -->
    <Style x:Key="StatusBadge.Container" TargetType="Border">
        <Setter Property="Height" Value="20" />
        <Setter Property="MinWidth" Value="40" />
        <Setter Property="Padding" Value="8,0" />
        <Setter Property="HorizontalAlignment" Value="Left" />
        <Setter Property="VerticalAlignment" Value="Center" />
        <Setter Property="CornerRadius" Value="{DynamicResource Radius.Full}" />
    </Style>

    <!--
        Variants — Background drives the visible color of the badge.
        Foreground for text is set on the contained TextBlock via
        StatusBadge.Text + a per-variant override where needed.
    -->

    <!--  Neutral — generic / unlabeled status  -->
    <Style
        x:Key="StatusBadge.Neutral"
        BasedOn="{StaticResource StatusBadge.Container}"
        TargetType="Border">
        <Setter Property="Background" Value="{DynamicResource Brush.SurfaceRaised}" />
        <Setter Property="TextElement.Foreground" Value="{DynamicResource Brush.Text.Secondary}" />
    </Style>

    <!--  Success / Active / Healthy  -->
    <Style
        x:Key="StatusBadge.Success"
        BasedOn="{StaticResource StatusBadge.Container}"
        TargetType="Border">
        <Setter Property="Background" Value="{DynamicResource Brush.Success}" />
        <Setter Property="TextElement.Foreground" Value="{DynamicResource Brush.Text.OnAccent}" />
    </Style>

    <!--  Warning / Risk / Pending  -->
    <Style
        x:Key="StatusBadge.Warning"
        BasedOn="{StaticResource StatusBadge.Container}"
        TargetType="Border">
        <Setter Property="Background" Value="{DynamicResource Brush.Warning}" />
        <Setter Property="TextElement.Foreground" Value="{DynamicResource Brush.Text.OnAccent}" />
    </Style>

    <!--  Danger / Destructive  -->
    <Style
        x:Key="StatusBadge.Danger"
        BasedOn="{StaticResource StatusBadge.Container}"
        TargetType="Border">
        <Setter Property="Background" Value="{DynamicResource Brush.Danger}" />
        <Setter Property="TextElement.Foreground" Value="{DynamicResource Brush.Text.OnAccent}" />
    </Style>

    <!--  Info  -->
    <Style
        x:Key="StatusBadge.Info"
        BasedOn="{StaticResource StatusBadge.Container}"
        TargetType="Border">
        <Setter Property="Background" Value="{DynamicResource Brush.Info}" />
        <Setter Property="TextElement.Foreground" Value="{DynamicResource Brush.Text.OnAccent}" />
    </Style>

    <!--  Special — promotional / categorical highlight  -->
    <Style
        x:Key="StatusBadge.Special"
        BasedOn="{StaticResource StatusBadge.Container}"
        TargetType="Border">
        <Setter Property="Background" Value="{DynamicResource Brush.Special}" />
        <Setter Property="TextElement.Foreground" Value="{DynamicResource Brush.Text.OnAccent}" />
    </Style>

    <!--  Accent — selected / current  -->
    <Style
        x:Key="StatusBadge.Accent"
        BasedOn="{StaticResource StatusBadge.Container}"
        TargetType="Border">
        <Setter Property="Background" Value="{DynamicResource Brush.Accent}" />
        <Setter Property="TextElement.Foreground" Value="{DynamicResource Brush.Text.OnAccent}" />
    </Style>

    <!--  Muted — archived / inactive  -->
    <Style
        x:Key="StatusBadge.Muted"
        BasedOn="{StaticResource StatusBadge.Container}"
        TargetType="Border">
        <Setter Property="Background" Value="{DynamicResource Brush.SurfaceRaised}" />
        <Setter Property="TextElement.Foreground" Value="{DynamicResource Brush.Text.Muted}" />
    </Style>

</ResourceDictionary>
