<ResourceDictionary xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation" xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml">

    <!--
        ════════════════════════════════════════════════════════════
        Tab-style controls
        ════════════════════════════════════════════════════════════
        NavTabBtn      : RadioButton-based tab (TradingView-style),
        underline indicator + AppHover bg on hover.
        Used for sub-tabs (Allocation 配置概覽/再平衡,
        Trends period filter).
        SegmentBtn     : RadioButton-based pill segment, filled bg
        when checked. Used for compact segmented
        controls.
        TabControl /   : Implicit (no x:Key) modern fintech tab strip
        TabItem          with 3 px AppAccent underline indicator
        flush to bottom edge. Used by main feature
        views (PortfolioView, CategoriesView, etc).
    -->

    <!--  ── NavTabBtn — RadioButton-based tab with bottom indicator ──  -->
    <Style x:Key="NavTabBtn" TargetType="RadioButton">
        <Setter Property="Background" Value="Transparent" />
        <Setter Property="Foreground" Value="{DynamicResource AppTextSecondary}" />
        <Setter Property="BorderThickness" Value="0" />
        <Setter Property="Padding" Value="14,0" />
        <Setter Property="Height" Value="36" />
        <Setter Property="FontFamily" Value="{StaticResource Font.Family.UI}" />
        <Setter Property="FontSize" Value="{StaticResource Font.Size.Sm}" />
        <Setter Property="Cursor" Value="Hand" />
        <Setter Property="FocusVisualStyle" Value="{StaticResource FocusVisual}" />
        <Setter Property="Template">
            <Setter.Value>
                <ControlTemplate TargetType="RadioButton">
                    <Border
                        x:Name="Bg"
                        Padding="{TemplateBinding Padding}"
                        Background="{TemplateBinding Background}">
                        <Grid>
                            <ContentPresenter
                                x:Name="Label"
                                HorizontalAlignment="Center"
                                VerticalAlignment="Center"
                                TextElement.Foreground="{TemplateBinding Foreground}" />
                            <Border
                                x:Name="Indicator"
                                Height="2"
                                VerticalAlignment="Bottom"
                                Background="{DynamicResource AppAccent}"
                                Visibility="Collapsed" />
                        </Grid>
                    </Border>
                    <ControlTemplate.Triggers>
                        <Trigger Property="IsChecked" Value="True">
                            <Setter TargetName="Indicator" Property="Visibility" Value="Visible" />
                            <Setter Property="Foreground" Value="{DynamicResource AppTextPrimary}" />
                            <Setter Property="FontWeight" Value="SemiBold" />
                        </Trigger>
                        <MultiTrigger>
                            <MultiTrigger.Conditions>
                                <Condition Property="IsMouseOver" Value="True" />
                                <Condition Property="IsChecked" Value="False" />
                            </MultiTrigger.Conditions>
                            <Setter Property="Foreground" Value="{DynamicResource AppTextPrimary}" />
                            <Setter TargetName="Bg" Property="Background" Value="{DynamicResource AppHover}" />
                        </MultiTrigger>
                    </ControlTemplate.Triggers>
                </ControlTemplate>
            </Setter.Value>
        </Setter>
    </Style>

    <Style
        x:Key="AppTopTab"
        BasedOn="{StaticResource NavTabBtn}"
        TargetType="{x:Type RadioButton}" />
    <Style
        x:Key="AppSubTab"
        BasedOn="{StaticResource NavTabBtn}"
        TargetType="{x:Type RadioButton}" />

    <!--  ── SegmentBtn — RadioButton-based pill segment ──  -->
    <!--
        P2.15 — 加 explicit Height (不只 MinHeight) = Control.Height.Md (40) 鎖死高度。
        RadioButton 的 measure 行為偶爾會超 MinHeight 幾 px (native 計算 indicator
        空間 + content padding 加起來 > 40)，造成跟相鄰 TextBox 視覺上「高一截」。
        Padding 從 12,5 縮成 12,4 讓 natural height 更落在 40 之內，配合 Height 鎖
        確保跟 TextBox / ComboBox / DatePicker 精準同高 (都是 40)。
    -->
    <Style x:Key="SegmentBtn" TargetType="RadioButton">
        <Setter Property="Background" Value="Transparent" />
        <Setter Property="Foreground" Value="{DynamicResource AppTextSecondary}" />
        <Setter Property="BorderThickness" Value="0" />
        <Setter Property="Padding" Value="12,4" />
        <Setter Property="MinHeight" Value="{StaticResource Control.Height.Md}" />
        <Setter Property="Height" Value="{StaticResource Control.Height.Md}" />
        <Setter Property="FontFamily" Value="{StaticResource Font.Family.UI}" />
        <Setter Property="FontSize" Value="{StaticResource Font.Size.Sm}" />
        <Setter Property="Cursor" Value="Hand" />
        <Setter Property="Template">
            <Setter.Value>
                <ControlTemplate TargetType="RadioButton">
                    <Border
                        x:Name="Bd"
                        Padding="{TemplateBinding Padding}"
                        Background="{TemplateBinding Background}"
                        BorderBrush="Transparent"
                        BorderThickness="1"
                        CornerRadius="{StaticResource Radius.Sm}">
                        <TextBlock
                            HorizontalAlignment="Center"
                            VerticalAlignment="Center"
                            FontFamily="{TemplateBinding FontFamily}"
                            FontSize="{TemplateBinding FontSize}"
                            FontWeight="{TemplateBinding FontWeight}"
                            Foreground="{TemplateBinding Foreground}"
                            Text="{TemplateBinding Content}" />
                    </Border>
                    <ControlTemplate.Triggers>
                        <Trigger Property="IsChecked" Value="True">
                            <Setter TargetName="Bd" Property="Background" Value="{DynamicResource AppAccent}" />
                            <Setter Property="Foreground" Value="{DynamicResource AppTextOnAccent}" />
                            <Setter TargetName="Bd" Property="BorderBrush" Value="{DynamicResource AppAccent}" />
                        </Trigger>
                        <Trigger Property="IsMouseOver" Value="True">
                            <Setter TargetName="Bd" Property="Background" Value="{DynamicResource AppHover}" />
                            <Setter Property="Foreground" Value="{DynamicResource AppTextPrimary}" />
                        </Trigger>
                        <MultiTrigger>
                            <MultiTrigger.Conditions>
                                <Condition Property="IsChecked" Value="True" />
                                <Condition Property="IsMouseOver" Value="True" />
                            </MultiTrigger.Conditions>
                            <Setter TargetName="Bd" Property="Background" Value="{DynamicResource AppAccent}" />
                            <Setter Property="Foreground" Value="{DynamicResource AppTextOnAccent}" />
                            <Setter TargetName="Bd" Property="BorderBrush" Value="{DynamicResource AppAccent}" />
                        </MultiTrigger>
                        <Trigger Property="IsFocused" Value="True">
                            <Setter TargetName="Bd" Property="BorderBrush" Value="{DynamicResource AppAccent}" />
                        </Trigger>
                    </ControlTemplate.Triggers>
                </ControlTemplate>
            </Setter.Value>
        </Setter>
    </Style>

    <Style
        x:Key="AppSegmentButton"
        BasedOn="{StaticResource SegmentBtn}"
        TargetType="{x:Type RadioButton}" />

    <!--
        ── AppPillTab — RadioButton tab in pill style (filled bg when checked) ──
        P4.3 #8 — 給 side panel 內部 tab bar 用（detail panel 的 概覽 / 交易記錄）。
        Active = AppAccent 填底 + 白字；Inactive = 透明底 + 次要字。視覺更現代，
        跟 NavTabBtn 的 underline 風格區隔開（後者用於主導航 / 子分頁）。
        Height 32 比 SegmentBtn (40) 矮一階，符合 panel 內密度需求。
    -->
    <Style x:Key="AppPillTab" TargetType="RadioButton">
        <Setter Property="Background" Value="Transparent" />
        <Setter Property="Foreground" Value="{DynamicResource AppTextSecondary}" />
        <Setter Property="BorderThickness" Value="0" />
        <Setter Property="Padding" Value="14,4" />
        <Setter Property="Height" Value="32" />
        <Setter Property="Margin" Value="0,0,6,0" />
        <Setter Property="FontFamily" Value="{StaticResource Font.Family.UI}" />
        <Setter Property="FontSize" Value="{StaticResource Font.Size.Sm}" />
        <Setter Property="Cursor" Value="Hand" />
        <Setter Property="FocusVisualStyle" Value="{StaticResource FocusVisual}" />
        <Setter Property="Template">
            <Setter.Value>
                <ControlTemplate TargetType="RadioButton">
                    <Border
                        x:Name="Bd"
                        Padding="{TemplateBinding Padding}"
                        Background="{TemplateBinding Background}"
                        CornerRadius="{StaticResource Radius.Lg}">
                        <TextBlock
                            HorizontalAlignment="Center"
                            VerticalAlignment="Center"
                            FontFamily="{TemplateBinding FontFamily}"
                            FontSize="{TemplateBinding FontSize}"
                            FontWeight="{TemplateBinding FontWeight}"
                            Foreground="{TemplateBinding Foreground}"
                            Text="{TemplateBinding Content}" />
                    </Border>
                    <ControlTemplate.Triggers>
                        <Trigger Property="IsChecked" Value="True">
                            <Setter TargetName="Bd" Property="Background" Value="{DynamicResource AppAccent}" />
                            <Setter Property="Foreground" Value="{DynamicResource AppTextOnAccent}" />
                            <Setter Property="FontWeight" Value="SemiBold" />
                        </Trigger>
                        <MultiTrigger>
                            <MultiTrigger.Conditions>
                                <Condition Property="IsMouseOver" Value="True" />
                                <Condition Property="IsChecked" Value="False" />
                            </MultiTrigger.Conditions>
                            <Setter TargetName="Bd" Property="Background" Value="{DynamicResource AppHover}" />
                            <Setter Property="Foreground" Value="{DynamicResource AppTextPrimary}" />
                        </MultiTrigger>
                    </ControlTemplate.Triggers>
                </ControlTemplate>
            </Setter.Value>
        </Setter>
    </Style>

    <!--  ── TabControl (implicit) ──  -->
    <Style TargetType="{x:Type TabControl}">
        <Setter Property="Background" Value="Transparent" />
        <Setter Property="BorderThickness" Value="0" />
        <Setter Property="Padding" Value="0" />
        <Setter Property="Foreground" Value="{DynamicResource AppTextPrimary}" />
        <Setter Property="Template">
            <Setter.Value>
                <ControlTemplate TargetType="{x:Type TabControl}">
                    <Grid SnapsToDevicePixels="True">
                        <Grid.RowDefinitions>
                            <RowDefinition Height="Auto" />
                            <RowDefinition Height="*" />
                        </Grid.RowDefinitions>
                        <Border
                            Grid.Row="0"
                            BorderBrush="{DynamicResource AppBorderLight}"
                            BorderThickness="0,0,0,1">
                            <TabPanel
                                x:Name="HeaderPanel"
                                Margin="0"
                                Panel.ZIndex="1"
                                IsItemsHost="True"
                                KeyboardNavigation.TabIndex="1" />
                        </Border>
                        <ContentPresenter
                            x:Name="PART_SelectedContentHost"
                            Grid.Row="1"
                            HorizontalAlignment="Stretch"
                            VerticalAlignment="Stretch"
                            ContentSource="SelectedContent"
                            SnapsToDevicePixels="{TemplateBinding SnapsToDevicePixels}" />
                    </Grid>
                </ControlTemplate>
            </Setter.Value>
        </Setter>
    </Style>

    <!--  ── TabItem (implicit) ──  -->
    <Style TargetType="{x:Type TabItem}">
        <Setter Property="Background" Value="Transparent" />
        <Setter Property="Foreground" Value="{DynamicResource AppTextSecondary}" />
        <Setter Property="BorderThickness" Value="0" />
        <Setter Property="Padding" Value="16,10" />
        <Setter Property="Margin" Value="0,0,4,0" />
        <Setter Property="MinWidth" Value="0" />
        <Setter Property="FontFamily" Value="{StaticResource Font.Family.UI}" />
        <Setter Property="FontSize" Value="{StaticResource Font.Size.Sm}" />
        <Setter Property="FontWeight" Value="Normal" />
        <!--
            ⚠ 不可在這加 Cursor="Hand" — WPF Cursor 屬性透過 logical tree 繼承，
            TabItem.Content 是 logical child，會把 Hand 漂到整個 TabItem 所顯示的
            頁面上，所有 widget body 都會變 Hand cursor。改在 ControlTemplate 內
            的 Bg Border 設 Cursor，只作用在 header 視覺上。
        -->
        <!--
            These alignment values are also used by TabControl for the
            selected content. Keep them Stretch so tab pages fill the available
            workspace; the header template centers its label explicitly below.
        -->
        <Setter Property="HorizontalContentAlignment" Value="Stretch" />
        <Setter Property="VerticalContentAlignment" Value="Stretch" />
        <Setter Property="FocusVisualStyle" Value="{StaticResource FocusVisual}" />
        <Setter Property="Template">
            <Setter.Value>
                <ControlTemplate TargetType="{x:Type TabItem}">
                    <Grid SnapsToDevicePixels="True">
                        <Border
                            x:Name="Bg"
                            Padding="{TemplateBinding Padding}"
                            Background="{TemplateBinding Background}"
                            Cursor="Hand">
                            <ContentPresenter
                                x:Name="Content"
                                HorizontalAlignment="Center"
                                VerticalAlignment="Center"
                                ContentSource="Header"
                                RecognizesAccessKey="True"
                                TextElement.FontWeight="{TemplateBinding FontWeight}"
                                TextElement.Foreground="{TemplateBinding Foreground}" />
                        </Border>
                        <Border
                            x:Name="Indicator"
                            Height="3"
                            Margin="8,0"
                            VerticalAlignment="Bottom"
                            Background="{DynamicResource AppAccent}"
                            CornerRadius="1.5,1.5,0,0"
                            Visibility="Hidden" />
                    </Grid>
                    <ControlTemplate.Triggers>
                        <Trigger Property="IsMouseOver" Value="True">
                            <Setter Property="Foreground" Value="{DynamicResource AppTextPrimary}" />
                            <Setter TargetName="Bg" Property="Background" Value="{DynamicResource AppHover}" />
                        </Trigger>
                        <Trigger Property="IsSelected" Value="True">
                            <Setter Property="Foreground" Value="{DynamicResource AppAccent}" />
                            <Setter Property="FontWeight" Value="SemiBold" />
                            <Setter TargetName="Indicator" Property="Visibility" Value="Visible" />
                        </Trigger>
                        <MultiTrigger>
                            <MultiTrigger.Conditions>
                                <Condition Property="IsSelected" Value="True" />
                                <Condition Property="IsMouseOver" Value="True" />
                            </MultiTrigger.Conditions>
                            <Setter Property="Foreground" Value="{DynamicResource AppAccent}" />
                            <Setter TargetName="Bg" Property="Background" Value="Transparent" />
                        </MultiTrigger>
                        <Trigger Property="IsEnabled" Value="False">
                            <Setter Property="Foreground" Value="{DynamicResource AppTextMuted}" />
                            <Setter Property="Cursor" Value="Arrow" />
                        </Trigger>
                    </ControlTemplate.Triggers>
                </ControlTemplate>
            </Setter.Value>
        </Setter>
    </Style>

</ResourceDictionary>
