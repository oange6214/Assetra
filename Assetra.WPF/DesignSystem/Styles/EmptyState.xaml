<ResourceDictionary
    xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
    xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml">

    <!--
        EmptyStateIcon lives in DesignSystem/Controls/Icon.xaml so its
        BasedOn lookup of AppIcon stays inside one ResourceDictionary
        (cross-file BasedOn StaticResource is forbidden — see
        DesignSystem/README.md). This file owns the layout / panel /
        text styles only.
    -->


    <Style x:Key="EmptyStatePanel" TargetType="StackPanel">
        <Setter Property="Width" Value="420" />
        <Setter Property="MaxWidth" Value="520" />
        <Setter Property="HorizontalAlignment" Value="Center" />
        <Setter Property="VerticalAlignment" Value="Center" />
    </Style>

    <Style x:Key="EmptyStateTitle" TargetType="TextBlock">
        <Setter Property="Margin" Value="0,12,0,0" />
        <Setter Property="HorizontalAlignment" Value="Center" />
        <Setter Property="FontSize" Value="{StaticResource Font.Size.Md}" />
        <Setter Property="FontWeight" Value="SemiBold" />
        <Setter Property="Foreground" Value="{DynamicResource AppTextPrimary}" />
        <Setter Property="TextAlignment" Value="Center" />
        <Setter Property="TextWrapping" Value="Wrap" />
    </Style>

    <Style x:Key="EmptyStateHint" TargetType="TextBlock">
        <!--
            Title -> description gap: 8 px (Gap.Sm) for comfortable
            two-line readability. Was 6 px which felt cramped against
            the SemiBold title.
        -->
        <Setter Property="Margin" Value="0,8,0,0" />
        <Setter Property="HorizontalAlignment" Value="Center" />
        <Setter Property="Foreground" Value="{DynamicResource AppTextSecondary}" />
        <Setter Property="TextAlignment" Value="Center" />
        <Setter Property="TextWrapping" Value="Wrap" />
    </Style>

    <Style x:Key="AppEmptyState" BasedOn="{StaticResource EmptyStatePanel}" TargetType="{x:Type StackPanel}" />
    <Style x:Key="AppEmptyStateTitle" BasedOn="{StaticResource EmptyStateTitle}" TargetType="{x:Type TextBlock}" />
    <Style x:Key="AppEmptyStateDescription" BasedOn="{StaticResource EmptyStateHint}" TargetType="{x:Type TextBlock}" />

    <Style x:Key="AppEmptyStateActionBar" TargetType="{x:Type StackPanel}">
        <!--
            Description -> action gap: 24 px (Gap.Xl). Per the Fluent +
            Carbon plan's form rhythm, the gap before a primary CTA is
            larger than inter-text gaps so the action feels deliberate
            rather than crammed under the body copy. Was 16 px.
        -->
        <Setter Property="Margin" Value="0,24,0,0" />
        <Setter Property="HorizontalAlignment" Value="Center" />
        <Setter Property="Orientation" Value="Horizontal" />
    </Style>

</ResourceDictionary>
