<ResourceDictionary xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation" xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml">

    <!--
        ══════════════════════════════════════════════════════════
        Pagination — composed via styles, not a custom control
        ══════════════════════════════════════════════════════════
        Drop these styles onto a DockPanel + buttons + indicator
        TextBlock. The consumer controls binding for command
        availability / current page text.

        Reference layout:

            <DockPanel Style="{StaticResource Pagination.Container}">
                <Button DockPanel.Dock="Left"
                        Style="{StaticResource PaginationNavButton}"
                        Command="{Binding PreviousPageCommand}"
                        Content="‹" />
                <Button DockPanel.Dock="Right"
                        Style="{StaticResource PaginationNavButton}"
                        Command="{Binding NextPageCommand}"
                        Content="›" />
                <TextBlock Style="{StaticResource Pagination.Indicator}"
                           Text="{Binding PageDisplay}" />
            </DockPanel>

        PaginationNavButton lives in DesignSystem/Controls/Button.xaml
        next to the other button variants.

        Disabled prev/next buttons should rely on Command.CanExecute,
        not a separate visual state.
    -->

    <Style x:Key="Pagination.Container" TargetType="DockPanel">
        <Setter Property="HorizontalAlignment" Value="Right" />
        <Setter Property="VerticalAlignment" Value="Center" />
        <Setter Property="LastChildFill" Value="True" />
        <Setter Property="Margin" Value="0,12,0,0" />
    </Style>

    <Style x:Key="Pagination.Indicator" TargetType="TextBlock">
        <Setter Property="HorizontalAlignment" Value="Center" />
        <Setter Property="VerticalAlignment" Value="Center" />
        <Setter Property="Margin" Value="12,0" />
        <Setter Property="FontFamily" Value="{StaticResource Font.Family.UI}" />
        <Setter Property="FontSize" Value="{StaticResource Font.Size.Sm}" />
        <Setter Property="FontWeight" Value="{StaticResource Font.Weight.Regular}" />
        <Setter Property="Foreground" Value="{DynamicResource Brush.Text.Secondary}" />
        <Setter Property="Typography.NumeralAlignment" Value="Tabular" />
    </Style>

    <Style x:Key="Pagination.PageSizeLabel" TargetType="TextBlock">
        <Setter Property="VerticalAlignment" Value="Center" />
        <Setter Property="Margin" Value="0,0,8,0" />
        <Setter Property="FontFamily" Value="{StaticResource Font.Family.UI}" />
        <Setter Property="FontSize" Value="{StaticResource Font.Size.Xs}" />
        <Setter Property="FontWeight" Value="{StaticResource Font.Weight.Regular}" />
        <Setter Property="Foreground" Value="{DynamicResource Brush.Text.Muted}" />
    </Style>

</ResourceDictionary>
