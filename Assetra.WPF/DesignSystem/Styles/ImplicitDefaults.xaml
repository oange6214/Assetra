<ResourceDictionary
    xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
    xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml">

    <!--
        ════════════════════════════════════════════════════════════
        Implicit-default style overrides
        ════════════════════════════════════════════════════════════
        Every "bare" instance of these controls in the codebase picks
        up the design-system look automatically. Pages can still opt
        into a different keyed variant via Style="{StaticResource ...}".

        Implicit defaults are ONLY listed here when the control's keyed
        style file does not already declare its own implicit default —
        TextBox / Tooltip / TextBlock / CheckBox / RadioButton /
        PasswordBox / ScrollBar / ProgressBar / ToolTip / TabControl /
        TabItem / CalendarDayButton already register their own.
    -->

    <!--
        Button → AppButtonBase (template-only, no MinWidth lock).
        AppButtonBase carries the chrome / typography / focus visual but
        does not enforce a MinWidth, so dense UIs (icon-sized actions,
        toolbar +/- adjusters, etc.) keep their compact sizing.
        Pages opt into AppSecondaryButton / AppPrimaryButton / AppDangerButton
        explicitly when they need a sized form action.
    -->
    <Style BasedOn="{StaticResource AppButtonBase}" TargetType="{x:Type Button}" />

    <!--  ComboBox → AppComboBox (Fluent chevron + AppHover dropdown).  -->
    <Style BasedOn="{StaticResource AppComboBox}" TargetType="{x:Type ComboBox}" />

    <!--  Expander → AppExpander (rounded card + animated chevron).  -->
    <Style BasedOn="{StaticResource AppExpander}" TargetType="{x:Type Expander}" />

</ResourceDictionary>
