<ResourceDictionary xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation" xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml">

    <!--
        ══════════════════════════════════════════════════════════
        Form Text — label, helper, and validation error text
        ══════════════════════════════════════════════════════════
        Implements the Form Vertical Rhythm rules from the Fluent
        + Carbon plan:

            label    → input  : Gap.Sm (8 px) — set on input Margin
            input    → helper : Gap.Xs (4 px) — set on helper Margin (top)
            input    → error  : Gap.Xs (4 px) — set on error Margin (top)
            field    → field  : Gap.Sm (8 px)
            group    → group  : Gap.Xl (24 px)

        Reference layout for a single field:

            <StackPanel>
                <TextBlock Style="{StaticResource Form.FieldLabel}" Text="Amount" />
                <TextBox  Style="{StaticResource AppMoneyTextBox}" .../>
                <TextBlock Style="{StaticResource Form.HelperText}"
                           Text="In TWD." />
                <TextBlock Style="{StaticResource Form.ErrorText}"
                           Text="{Binding AmountError}"
                           Visibility="{Binding HasAmountError, Converter={StaticResource BooleanToVisibilityConverter}}" />
            </StackPanel>

        Form.SectionHeader marks group boundaries. Consumers should
        space between groups with Margin top = Gap.Xl on the next
        section, or rely on PageFormGrid's row gap.
    -->

    <Style x:Key="Form.FieldLabel" TargetType="TextBlock">
        <Setter Property="FontFamily" Value="{StaticResource Font.Family.Base}" />
        <Setter Property="FontSize" Value="{StaticResource Font.Size.Sm}" />
        <Setter Property="FontWeight" Value="{StaticResource Font.Weight.Medium}" />
        <Setter Property="Foreground" Value="{DynamicResource Brush.Text.Primary}" />
        <Setter Property="Margin" Value="0,0,0,8" />
    </Style>

    <Style x:Key="Form.HelperText" TargetType="TextBlock">
        <Setter Property="FontFamily" Value="{StaticResource Font.Family.Base}" />
        <Setter Property="FontSize" Value="{StaticResource Font.Size.Xs}" />
        <Setter Property="FontWeight" Value="{StaticResource Font.Weight.Regular}" />
        <Setter Property="Foreground" Value="{DynamicResource Brush.Text.Muted}" />
        <Setter Property="Margin" Value="0,4,0,0" />
        <Setter Property="TextWrapping" Value="Wrap" />
    </Style>

    <Style x:Key="Form.ErrorText" TargetType="TextBlock">
        <Setter Property="FontFamily" Value="{StaticResource Font.Family.Base}" />
        <Setter Property="FontSize" Value="{StaticResource Font.Size.Xs}" />
        <Setter Property="FontWeight" Value="{StaticResource Font.Weight.Regular}" />
        <Setter Property="Foreground" Value="{DynamicResource Brush.Danger}" />
        <Setter Property="Margin" Value="0,4,0,0" />
        <Setter Property="TextWrapping" Value="Wrap" />
    </Style>

    <Style x:Key="Form.SectionHeader" TargetType="TextBlock">
        <Setter Property="FontFamily" Value="{StaticResource Font.Family.Base}" />
        <Setter Property="FontSize" Value="{StaticResource Font.Size.Base}" />
        <Setter Property="FontWeight" Value="{StaticResource Font.Weight.Semibold}" />
        <Setter Property="Foreground" Value="{DynamicResource Brush.Text.Primary}" />
        <Setter Property="Margin" Value="0,0,0,12" />
    </Style>

    <!--
        Form.SectionGap — empty Border element used as a vertical
        spacer between form groups. 24 px = Gap.Xl. Useful when the
        next section header should not carry a top margin itself.
    -->
    <Style x:Key="Form.SectionGap" TargetType="Border">
        <Setter Property="Height" Value="24" />
    </Style>

</ResourceDictionary>
