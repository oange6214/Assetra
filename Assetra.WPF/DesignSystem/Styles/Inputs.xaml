<ResourceDictionary
    xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
    xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
    xmlns:behaviors="clr-namespace:Assetra.WPF.Infrastructure.Behaviors"
    xmlns:converters="clr-namespace:Assetra.WPF.Infrastructure.Converters"
    xmlns:ds="clr-namespace:Assetra.WPF.DesignSystem.Controls"
    xmlns:primitives="clr-namespace:System.Windows.Controls.Primitives;assembly=PresentationFramework">

    <converters:DisplayOptionTextConverter x:Key="DisplayOptionTextConverter" />

    <DataTemplate x:Key="AppComboBoxDisplayTemplate">
        <TextBlock Text="{Binding Converter={StaticResource DisplayOptionTextConverter}}" TextTrimming="CharacterEllipsis" />
    </DataTemplate>

    <!--
        ════════════════════════════════════════════════════════════
        Input + text controls
        ════════════════════════════════════════════════════════════
        TextBlock (implicit)   : default font / colour / rendering.
        ToolTip   (implicit)   : CJK-capable popup (no inheritance).
        TextBox   (implicit)   : explicit caret colour.
        FormFieldError         : 12 px AppDanger error label below
        inputs.
        FormComboBoxItem +     : Custom dropdown chrome matching the
        FormComboBox             rest of the design (border + chevron
        + AppHover/AppAccentSubtle states).
    -->

    <!--  ── Global TextBlock ──  -->
    <Style TargetType="TextBlock">
        <Setter Property="FontFamily" Value="{StaticResource Font.Family.UI}" />
        <Setter Property="FontSize" Value="{StaticResource Font.Size.Base}" />
        <Setter Property="Foreground" Value="{DynamicResource AppTextPrimary}" />
        <Setter Property="TextOptions.TextFormattingMode" Value="Display" />
        <Setter Property="TextOptions.TextRenderingMode" Value="ClearType" />
    </Style>

    <!--
        ── Global ToolTip ──
        Tooltip is a separate Popup window and does not inherit
        FontFamily from the visual tree. Explicitly set CJK-capable
        fonts so Chinese characters render correctly.
    -->
    <!--
        P2.17 T05 — Tooltip refresh：
        FontSize Sm → Xs (12px) 縮小不搶 main content
        BorderBrush AppBorder → AppBorderLight 跟 card lightening convention 對齊
        Padding 8,4 → 8,5 略寬一點呼吸
        Template 加 CornerRadius=Radius.Sm 跟其他卡片一致
        MaxWidth=320 避免長文 tooltip 拉成單行
    -->
    <Style TargetType="ToolTip">
        <Setter Property="FontFamily" Value="{StaticResource Font.Family.UI}" />
        <Setter Property="FontSize" Value="{StaticResource Font.Size.Xs}" />
        <Setter Property="Background" Value="{DynamicResource AppSurface}" />
        <Setter Property="Foreground" Value="{DynamicResource AppTextPrimary}" />
        <Setter Property="BorderBrush" Value="{DynamicResource AppBorderLight}" />
        <Setter Property="BorderThickness" Value="1" />
        <Setter Property="Padding" Value="8,5" />
        <Setter Property="MaxWidth" Value="320" />
        <Setter Property="Template">
            <Setter.Value>
                <ControlTemplate TargetType="ToolTip">
                    <Border
                        Padding="{TemplateBinding Padding}"
                        Background="{TemplateBinding Background}"
                        BorderBrush="{TemplateBinding BorderBrush}"
                        BorderThickness="{TemplateBinding BorderThickness}"
                        CornerRadius="{StaticResource Radius.Sm}"
                        SnapsToDevicePixels="True">
                        <ContentPresenter />
                    </Border>
                </ControlTemplate>
            </Setter.Value>
        </Setter>
    </Style>

    <!--  ── TextBox shell + variants ──  -->
    <Style x:Key="AppTextBox" TargetType="{x:Type TextBox}">
        <Setter Property="MinHeight" Value="{StaticResource Control.Height.Md}" />
        <Setter Property="Padding" Value="10,6" />
        <Setter Property="FontFamily" Value="{StaticResource Font.Family.UI}" />
        <Setter Property="FontSize" Value="{StaticResource Font.Size.Sm}" />
        <Setter Property="Foreground" Value="{DynamicResource Brush.Text.Primary}" />
        <Setter Property="Background" Value="{DynamicResource Brush.Surface}" />
        <Setter Property="BorderBrush" Value="{DynamicResource Brush.Border}" />
        <Setter Property="BorderThickness" Value="{StaticResource Border.Input}" />
        <Setter Property="CaretBrush" Value="{DynamicResource AppTextPrimary}" />
        <Setter Property="VerticalContentAlignment" Value="Center" />
        <Setter Property="Template">
            <Setter.Value>
                <ControlTemplate TargetType="{x:Type TextBox}">
                    <Border
                        x:Name="Chrome"
                        Background="{TemplateBinding Background}"
                        BorderBrush="{TemplateBinding BorderBrush}"
                        BorderThickness="{TemplateBinding BorderThickness}"
                        CornerRadius="{StaticResource Radius.Sm}"
                        SnapsToDevicePixels="True">
                        <!--
                            Placeholder support — set TextBox.Tag="0.00" (or any hint string) and a
                            muted overlay TextBlock 顯示在沒輸入時。隨使用者打字後 Text!="" 觸發 trigger
                            把 placeholder Visibility 設成 Collapsed。Tag 為 null/空字串時 TextBlock
                            渲染空白，沒有視覺干擾。HorizontalAlignment / VerticalAlignment 跟著
                            HorizontalContentAlignment / VerticalContentAlignment — 這樣：
                            - right-aligned 數字 textbox placeholder 靠右
                            - multiline 備註 (VerticalContentAlignment=Top) placeholder 也靠頂，
                            跟使用者點擊後的 cursor 位置一致，避免「placeholder 在中間、cursor
                            跳到上方」的詭異斷層。
                        -->
                        <Grid>
                            <TextBlock
                                x:Name="Placeholder"
                                Margin="{TemplateBinding Padding}"
                                HorizontalAlignment="{TemplateBinding HorizontalContentAlignment}"
                                VerticalAlignment="{TemplateBinding VerticalContentAlignment}"
                                FontFamily="{TemplateBinding FontFamily}"
                                FontSize="{TemplateBinding FontSize}"
                                Foreground="{DynamicResource Brush.Text.Muted}"
                                IsHitTestVisible="False"
                                Opacity="0.7"
                                Text="{TemplateBinding Tag}"
                                Visibility="Collapsed" />
                            <ScrollViewer
                                x:Name="PART_ContentHost"
                                Margin="{TemplateBinding Padding}"
                                Focusable="False"
                                HorizontalScrollBarVisibility="Hidden"
                                VerticalScrollBarVisibility="Hidden" />
                        </Grid>
                    </Border>
                    <ControlTemplate.Triggers>
                        <!--
                            P4.9d — placeholder 預設 Collapsed，僅在「Text 為空 AND 沒 focus」
                            時才出現。原本只看 Text=="" 觸發，造成 user 點進 textbox 時
                            placeholder 跟 caret 同位置疊在一起、視覺上 caret 跟 placeholder
                            重疊「奇怪位置」。改成 multi-trigger 後：
                            - 未 focus + 空：顯示 placeholder 提示
                            - 一點進去 (focus)：placeholder 立刻消失，caret 獨立可見
                            - 有 text 任何狀態：placeholder 永遠隱藏
                        -->
                        <MultiTrigger>
                            <MultiTrigger.Conditions>
                                <Condition Property="Text" Value="" />
                                <Condition Property="IsKeyboardFocused" Value="False" />
                            </MultiTrigger.Conditions>
                            <Setter TargetName="Placeholder" Property="Visibility" Value="Visible" />
                        </MultiTrigger>
                        <Trigger Property="IsMouseOver" Value="True">
                            <Setter TargetName="Chrome" Property="BorderBrush" Value="{DynamicResource Brush.BorderStrong}" />
                        </Trigger>
                        <Trigger Property="IsKeyboardFocused" Value="True">
                            <Setter TargetName="Chrome" Property="BorderBrush" Value="{DynamicResource Brush.FocusRing}" />
                        </Trigger>
                        <Trigger Property="Validation.HasError" Value="True">
                            <Setter TargetName="Chrome" Property="BorderBrush" Value="{DynamicResource Brush.Danger}" />
                        </Trigger>
                        <Trigger Property="IsReadOnly" Value="True">
                            <Setter Property="Background" Value="{DynamicResource Brush.SurfaceRaised}" />
                            <Setter Property="Foreground" Value="{DynamicResource Brush.Text.Secondary}" />
                        </Trigger>
                        <Trigger Property="IsEnabled" Value="False">
                            <Setter Property="Opacity" Value="0.45" />
                        </Trigger>
                    </ControlTemplate.Triggers>
                </ControlTemplate>
            </Setter.Value>
        </Setter>
    </Style>

    <Style BasedOn="{StaticResource AppTextBox}" TargetType="{x:Type TextBox}" />

    <Style
        x:Key="AppNumberTextBox"
        BasedOn="{StaticResource AppTextBox}"
        TargetType="{x:Type TextBox}">
        <Setter Property="HorizontalContentAlignment" Value="Right" />
        <!--  P4.9d — TextAlignment 才是 text + caret 的真實對齊；只設 HorizontalContentAlignment 只會搬 placeholder。  -->
        <Setter Property="TextAlignment" Value="Right" />
    </Style>

    <Style
        x:Key="AppMoneyTextBox"
        BasedOn="{StaticResource AppNumberTextBox}"
        TargetType="{x:Type TextBox}">
        <Setter Property="behaviors:ThousandSeparatorBehavior.IsEnabled" Value="True" />
    </Style>

    <Style
        x:Key="AppRateTextBox"
        BasedOn="{StaticResource AppNumberTextBox}"
        TargetType="{x:Type TextBox}">
        <Setter Property="MinWidth" Value="96" />
        <Setter Property="ToolTip" Value="Use decimal form, for example 0.05 for 5%." />
    </Style>

    <Style
        x:Key="AppPercentTextBox"
        BasedOn="{StaticResource AppNumberTextBox}"
        TargetType="{x:Type TextBox}">
        <Setter Property="MinWidth" Value="96" />
        <Setter Property="ToolTip" Value="Use percent form, for example 5 for 5%." />
    </Style>

    <Style TargetType="{x:Type primitives:CalendarDayButton}">
        <Setter Property="MinWidth" Value="34" />
        <Setter Property="MinHeight" Value="34" />
        <Setter Property="Margin" Value="1" />
        <Setter Property="Padding" Value="0" />
        <Setter Property="Background" Value="Transparent" />
        <Setter Property="BorderBrush" Value="Transparent" />
        <Setter Property="BorderThickness" Value="1" />
        <Setter Property="Foreground" Value="{DynamicResource AppTextPrimary}" />
        <Setter Property="FontFamily" Value="{StaticResource Font.Family.UI}" />
        <Setter Property="FontSize" Value="{StaticResource Font.Size.Sm}" />
        <Setter Property="FocusVisualStyle" Value="{x:Null}" />
        <Setter Property="Template">
            <Setter.Value>
                <ControlTemplate TargetType="{x:Type primitives:CalendarDayButton}">
                    <Border
                        x:Name="Chrome"
                        Width="34"
                        Height="34"
                        Background="{TemplateBinding Background}"
                        BorderBrush="{TemplateBinding BorderBrush}"
                        BorderThickness="{TemplateBinding BorderThickness}"
                        CornerRadius="17">
                        <ContentPresenter
                            HorizontalAlignment="Center"
                            VerticalAlignment="Center"
                            TextElement.Foreground="{TemplateBinding Foreground}" />
                    </Border>
                    <ControlTemplate.Triggers>
                        <Trigger Property="IsMouseOver" Value="True">
                            <Setter TargetName="Chrome" Property="Background" Value="{DynamicResource AppHover}" />
                        </Trigger>
                        <Trigger Property="IsToday" Value="True">
                            <Setter TargetName="Chrome" Property="BorderBrush" Value="{DynamicResource AppAccent}" />
                            <Setter Property="Foreground" Value="{DynamicResource AppAccent}" />
                            <Setter Property="FontWeight" Value="SemiBold" />
                        </Trigger>
                        <Trigger Property="IsSelected" Value="True">
                            <Setter TargetName="Chrome" Property="Background" Value="{DynamicResource AppAccent}" />
                            <Setter TargetName="Chrome" Property="BorderBrush" Value="{DynamicResource AppAccent}" />
                            <Setter Property="Foreground" Value="{DynamicResource AppTextOnAccent}" />
                            <Setter Property="FontWeight" Value="SemiBold" />
                        </Trigger>
                        <MultiTrigger>
                            <MultiTrigger.Conditions>
                                <Condition Property="IsSelected" Value="True" />
                                <Condition Property="IsMouseOver" Value="True" />
                            </MultiTrigger.Conditions>
                            <Setter TargetName="Chrome" Property="Background" Value="{DynamicResource AppAccentHover}" />
                            <Setter TargetName="Chrome" Property="BorderBrush" Value="{DynamicResource AppAccentHover}" />
                        </MultiTrigger>
                        <Trigger Property="IsInactive" Value="True">
                            <Setter Property="Foreground" Value="{DynamicResource AppTextMuted}" />
                            <Setter Property="Opacity" Value="0.58" />
                        </Trigger>
                        <Trigger Property="IsBlackedOut" Value="True">
                            <Setter Property="Foreground" Value="{DynamicResource AppTextMuted}" />
                            <Setter Property="Opacity" Value="0.32" />
                        </Trigger>
                        <Trigger Property="IsEnabled" Value="False">
                            <Setter Property="Foreground" Value="{DynamicResource AppTextMuted}" />
                            <Setter Property="Opacity" Value="0.45" />
                        </Trigger>
                    </ControlTemplate.Triggers>
                </ControlTemplate>
            </Setter.Value>
        </Setter>
    </Style>

    <!--  ── Form Field Validation Error ──  -->
    <Style x:Key="FormFieldError" TargetType="TextBlock">
        <Setter Property="FontSize" Value="{StaticResource Font.Size.Xs}" />
        <Setter Property="Foreground" Value="{DynamicResource AppDanger}" />
        <Setter Property="Margin" Value="0,2,0,0" />
        <Setter Property="TextWrapping" Value="Wrap" />
    </Style>

    <!--  ── Form ComboBox dropdown item ──  -->
    <Style x:Key="FormComboBoxItem" TargetType="ComboBoxItem">
        <Setter Property="Background" Value="Transparent" />
        <Setter Property="Foreground" Value="{DynamicResource AppTextPrimary}" />
        <Setter Property="Padding" Value="10,6" />
        <Setter Property="FontFamily" Value="{StaticResource Font.Family.UI}" />
        <Setter Property="FontSize" Value="{StaticResource Font.Size.Sm}" />
        <Setter Property="FocusVisualStyle" Value="{x:Null}" />
        <Setter Property="Template">
            <Setter.Value>
                <ControlTemplate TargetType="ComboBoxItem">
                    <Border
                        x:Name="Bd"
                        Padding="{TemplateBinding Padding}"
                        Background="{TemplateBinding Background}">
                        <ContentPresenter />
                    </Border>
                    <ControlTemplate.Triggers>
                        <Trigger Property="IsMouseOver" Value="True">
                            <Setter TargetName="Bd" Property="Background" Value="{DynamicResource AppHover}" />
                        </Trigger>
                        <Trigger Property="IsSelected" Value="True">
                            <Setter TargetName="Bd" Property="Background" Value="{DynamicResource AppAccentSubtle}" />
                            <Setter Property="Foreground" Value="{DynamicResource AppAccent}" />
                        </Trigger>
                        <MultiTrigger>
                            <MultiTrigger.Conditions>
                                <Condition Property="IsSelected" Value="True" />
                                <Condition Property="IsMouseOver" Value="True" />
                            </MultiTrigger.Conditions>
                            <Setter TargetName="Bd" Property="Background" Value="{DynamicResource AppAccentSubtle}" />
                        </MultiTrigger>
                    </ControlTemplate.Triggers>
                </ControlTemplate>
            </Setter.Value>
        </Setter>
    </Style>

    <!--  ── Form ComboBox shell + dropdown ──  -->
    <!--
        MinHeight 從硬碼 32 改成 Control.Height.Md (40) 對齊 AppTextBox / SegmentBtn /
        AppDatePicker — 之前 ComboBox 比相鄰 TextBox 矮 8px 是視覺上「為什麼控件不齊」的
        主因之一。
    -->
    <Style x:Key="FormComboBox" TargetType="ComboBox">
        <Setter Property="MinHeight" Value="{StaticResource Control.Height.Md}" />
        <Setter Property="VerticalContentAlignment" Value="Center" />
        <Setter Property="Background" Value="{DynamicResource AppBackground}" />
        <Setter Property="Foreground" Value="{DynamicResource AppTextPrimary}" />
        <Setter Property="FontFamily" Value="{StaticResource Font.Family.UI}" />
        <Setter Property="FontSize" Value="{StaticResource Font.Size.Sm}" />
        <Setter Property="FocusVisualStyle" Value="{x:Null}" />
        <Setter Property="ItemContainerStyle" Value="{StaticResource FormComboBoxItem}" />
        <Setter Property="ScrollViewer.HorizontalScrollBarVisibility" Value="Disabled" />
        <Setter Property="Template">
            <Setter.Value>
                <ControlTemplate TargetType="ComboBox">
                    <Grid x:Name="Root">
                        <ToggleButton
                            x:Name="ToggleButton"
                            HorizontalAlignment="Stretch"
                            VerticalAlignment="Stretch"
                            ClickMode="Press"
                            Focusable="False"
                            IsChecked="{Binding IsDropDownOpen, Mode=TwoWay, RelativeSource={RelativeSource TemplatedParent}}">
                            <ToggleButton.Template>
                                <ControlTemplate TargetType="ToggleButton">
                                    <Border
                                        x:Name="Bd"
                                        Background="{DynamicResource AppBackground}"
                                        BorderBrush="{DynamicResource AppBorder}"
                                        BorderThickness="1"
                                        CornerRadius="{StaticResource Radius.Sm}">
                                        <Grid>
                                            <Grid.ColumnDefinitions>
                                                <ColumnDefinition Width="*" />
                                                <ColumnDefinition Width="24" />
                                            </Grid.ColumnDefinitions>
                                            <Rectangle Grid.Column="0" Fill="Transparent" />
                                            <ds:AppIcon
                                                Grid.Column="1"
                                                HorizontalAlignment="Center"
                                                VerticalAlignment="Center"
                                                FontSize="10"
                                                Foreground="{DynamicResource AppTextMuted}"
                                                IsHitTestVisible="False"
                                                Symbol="ChevronDown24" />
                                        </Grid>
                                    </Border>
                                    <ControlTemplate.Triggers>
                                        <Trigger Property="IsChecked" Value="True">
                                            <Setter TargetName="Bd" Property="BorderBrush" Value="{DynamicResource AppAccent}" />
                                        </Trigger>
                                        <DataTrigger Binding="{Binding IsKeyboardFocusWithin, RelativeSource={RelativeSource AncestorType=ComboBox}}" Value="True">
                                            <Setter TargetName="Bd" Property="BorderBrush" Value="{DynamicResource AppAccent}" />
                                        </DataTrigger>
                                        <DataTrigger Binding="{Binding IsEnabled, RelativeSource={RelativeSource AncestorType=ComboBox}}" Value="False">
                                            <Setter TargetName="Bd" Property="Opacity" Value="0.5" />
                                        </DataTrigger>
                                    </ControlTemplate.Triggers>
                                </ControlTemplate>
                            </ToggleButton.Template>
                        </ToggleButton>

                        <ContentPresenter
                            x:Name="ContentPresenter"
                            Margin="8,0,24,0"
                            HorizontalAlignment="Left"
                            VerticalAlignment="Center"
                            Content="{TemplateBinding SelectionBoxItem}"
                            ContentTemplate="{TemplateBinding SelectionBoxItemTemplate}"
                            IsHitTestVisible="False" />
                        <!--
                            ⚠ 用 SelectionBoxItemTemplate（不是 ItemTemplate）：
                            - 顯式 ItemTemplate → SelectionBoxItemTemplate 同 ItemTemplate
                            - 只用 DisplayMemberPath → SelectionBoxItemTemplate 是 WPF 自動生的
                            那個顯示 Display property 的 inline template，且 ContentTemplateSelector 不會被 set
                            原本綁 ItemTemplate 在 DisplayMemberPath 場景下：
                            - ItemTemplate=null → ContentTemplate=null
                            - WPF 在 SelectionBoxItem 也另設了 ContentTemplateSelector
                            - 雙設 → throw warning「ContentTemplateSelector will be ignored」
                            改綁 SelectionBoxItemTemplate 一次解決兩種使用方式。
                        -->

                        <!--
                            Placeholder overlay — ComboBox.Tag = 提示字串，SelectedItem=null 時顯示。
                            ⚠ FormComboBoxWithSearch 把 Tag 拿去當 search-text bridge，所以那個 variant
                            override 整個 Template 不繼承這個 placeholder。
                        -->
                        <TextBlock
                            x:Name="PlaceholderText"
                            Margin="8,0,24,0"
                            VerticalAlignment="Center"
                            FontFamily="{TemplateBinding FontFamily}"
                            FontSize="{TemplateBinding FontSize}"
                            Foreground="{DynamicResource Brush.Text.Muted}"
                            IsHitTestVisible="False"
                            Opacity="0.7"
                            Text="{TemplateBinding Tag}"
                            Visibility="Collapsed" />

                        <TextBox
                            x:Name="PART_EditableTextBox"
                            Margin="6,0,24,0"
                            Padding="0"
                            VerticalAlignment="Center"
                            Background="Transparent"
                            BorderThickness="0"
                            CaretBrush="{DynamicResource AppTextPrimary}"
                            FontFamily="{TemplateBinding FontFamily}"
                            FontSize="{TemplateBinding FontSize}"
                            Foreground="{TemplateBinding Foreground}"
                            IsReadOnly="{Binding IsReadOnly, RelativeSource={RelativeSource TemplatedParent}}"
                            Visibility="Collapsed" />

                        <Popup
                            x:Name="PART_Popup"
                            AllowsTransparency="True"
                            IsOpen="{TemplateBinding IsDropDownOpen}"
                            Placement="Bottom">
                            <Border
                                MinWidth="{Binding ActualWidth, ElementName=Root}"
                                MaxHeight="{TemplateBinding MaxDropDownHeight}"
                                Margin="0,2,0,0"
                                Background="{DynamicResource AppSurface}"
                                BorderBrush="{DynamicResource AppBorder}"
                                BorderThickness="1"
                                CornerRadius="{StaticResource Radius.Sm}">
                                <ScrollViewer Focusable="False">
                                    <ItemsPresenter />
                                </ScrollViewer>
                            </Border>
                        </Popup>
                    </Grid>
                    <ControlTemplate.Triggers>
                        <Trigger Property="IsEditable" Value="True">
                            <Setter TargetName="PART_EditableTextBox" Property="Visibility" Value="Visible" />
                            <Setter TargetName="ContentPresenter" Property="Visibility" Value="Collapsed" />
                        </Trigger>
                        <!--
                            SelectedItem=null 時露出 placeholder（Tag 內容）。SelectedItem 一被選
                            ContentPresenter 蓋過 placeholder → 自動切回隱藏。
                            P2.13 — 改成 MultiTrigger 確保 IsEditable=True 時不顯示 placeholder
                            (避免跟可見的 PART_EditableTextBox 重疊)。Editable mode 下使用者
                            打字本身就是「placeholder」的替代品。
                        -->
                        <MultiTrigger>
                            <MultiTrigger.Conditions>
                                <Condition Property="SelectedItem" Value="{x:Null}" />
                                <Condition Property="IsEditable" Value="False" />
                            </MultiTrigger.Conditions>
                            <Setter TargetName="PlaceholderText" Property="Visibility" Value="Visible" />
                        </MultiTrigger>
                    </ControlTemplate.Triggers>
                </ControlTemplate>
            </Setter.Value>
        </Setter>
    </Style>

    <Style
        x:Key="AppComboBox"
        BasedOn="{StaticResource FormComboBox}"
        TargetType="{x:Type ComboBox}">
        <Setter Property="MinHeight" Value="{StaticResource Control.Height.Md}" />
        <Setter Property="FontSize" Value="{StaticResource Font.Size.Sm}" />
        <Setter Property="ItemTemplate" Value="{StaticResource AppComboBoxDisplayTemplate}" />
    </Style>

    <!--
        FormComboBox with a search/filter TextBox docked at the popup top.
        Bridge: caller binds VM filter text into ComboBox.Tag (TwoWay), the template
        TextBox bind its Text to that Tag — VM gets keystroke updates without code-behind.
        Caller is responsible for IsTextSearchEnabled="False" so WPF's built-in type-ahead
        doesn't fight the VM filter. Drop-down item list is whatever ItemsSource provides
        (typically an ICollectionView whose Filter predicate honors the same VM property).
    -->
    <Style
        x:Key="FormComboBoxWithSearch"
        BasedOn="{StaticResource FormComboBox}"
        TargetType="ComboBox">
        <Setter Property="StaysOpenOnEdit" Value="True" />
        <Setter Property="Template">
            <Setter.Value>
                <ControlTemplate TargetType="ComboBox">
                    <Grid x:Name="Root">
                        <ToggleButton
                            x:Name="ToggleButton"
                            HorizontalAlignment="Stretch"
                            VerticalAlignment="Stretch"
                            ClickMode="Press"
                            Focusable="False"
                            IsChecked="{Binding IsDropDownOpen, Mode=TwoWay, RelativeSource={RelativeSource TemplatedParent}}">
                            <ToggleButton.Template>
                                <ControlTemplate TargetType="ToggleButton">
                                    <Border
                                        x:Name="Bd"
                                        Background="{DynamicResource AppBackground}"
                                        BorderBrush="{DynamicResource AppBorder}"
                                        BorderThickness="1"
                                        CornerRadius="{StaticResource Radius.Sm}">
                                        <Grid>
                                            <Grid.ColumnDefinitions>
                                                <ColumnDefinition Width="*" />
                                                <ColumnDefinition Width="24" />
                                            </Grid.ColumnDefinitions>
                                            <Rectangle Grid.Column="0" Fill="Transparent" />
                                            <ds:AppIcon
                                                Grid.Column="1"
                                                HorizontalAlignment="Center"
                                                VerticalAlignment="Center"
                                                FontSize="10"
                                                Foreground="{DynamicResource AppTextMuted}"
                                                IsHitTestVisible="False"
                                                Symbol="ChevronDown24" />
                                        </Grid>
                                    </Border>
                                    <ControlTemplate.Triggers>
                                        <Trigger Property="IsChecked" Value="True">
                                            <Setter TargetName="Bd" Property="BorderBrush" Value="{DynamicResource AppAccent}" />
                                        </Trigger>
                                        <DataTrigger Binding="{Binding IsKeyboardFocusWithin, RelativeSource={RelativeSource AncestorType=ComboBox}}" Value="True">
                                            <Setter TargetName="Bd" Property="BorderBrush" Value="{DynamicResource AppAccent}" />
                                        </DataTrigger>
                                        <DataTrigger Binding="{Binding IsEnabled, RelativeSource={RelativeSource AncestorType=ComboBox}}" Value="False">
                                            <Setter TargetName="Bd" Property="Opacity" Value="0.5" />
                                        </DataTrigger>
                                    </ControlTemplate.Triggers>
                                </ControlTemplate>
                            </ToggleButton.Template>
                        </ToggleButton>

                        <ContentPresenter
                            x:Name="ContentPresenter"
                            Margin="8,0,24,0"
                            HorizontalAlignment="Left"
                            VerticalAlignment="Center"
                            Content="{TemplateBinding SelectionBoxItem}"
                            ContentTemplate="{TemplateBinding SelectionBoxItemTemplate}"
                            IsHitTestVisible="False" />

                        <Popup
                            x:Name="PART_Popup"
                            AllowsTransparency="True"
                            IsOpen="{TemplateBinding IsDropDownOpen}"
                            Placement="Bottom">
                            <Border
                                MinWidth="{Binding ActualWidth, ElementName=Root}"
                                MaxHeight="{TemplateBinding MaxDropDownHeight}"
                                Margin="0,2,0,0"
                                Background="{DynamicResource AppSurface}"
                                BorderBrush="{DynamicResource AppBorder}"
                                BorderThickness="1"
                                CornerRadius="{StaticResource Radius.Sm}">
                                <Grid>
                                    <Grid.RowDefinitions>
                                        <RowDefinition Height="Auto" />
                                        <RowDefinition Height="*" />
                                    </Grid.RowDefinitions>
                                    <Border
                                        Grid.Row="0"
                                        Padding="8,6"
                                        Background="{DynamicResource AppSurface}"
                                        BorderBrush="{DynamicResource AppBorder}"
                                        BorderThickness="0,0,0,1">
                                        <Grid>
                                            <TextBox
                                                x:Name="PART_SearchBox"
                                                Padding="6,3"
                                                Background="{DynamicResource AppBackground}"
                                                BorderBrush="{DynamicResource AppBorder}"
                                                BorderThickness="1"
                                                FontFamily="{StaticResource Font.Family.UI}"
                                                FontSize="{StaticResource Font.Size.Sm}"
                                                Foreground="{DynamicResource AppTextPrimary}"
                                                Text="{Binding Tag, RelativeSource={RelativeSource TemplatedParent}, Mode=TwoWay, UpdateSourceTrigger=PropertyChanged}" />
                                            <TextBlock
                                                Margin="14,0,8,0"
                                                VerticalAlignment="Center"
                                                FontFamily="{StaticResource Font.Family.UI}"
                                                FontSize="{StaticResource Font.Size.Sm}"
                                                Foreground="{DynamicResource AppTextMuted}"
                                                IsHitTestVisible="False"
                                                Text="{DynamicResource Common.Search.Placeholder}">
                                                <TextBlock.Style>
                                                    <Style TargetType="TextBlock">
                                                        <Setter Property="Visibility" Value="Collapsed" />
                                                        <Style.Triggers>
                                                            <DataTrigger Binding="{Binding Text, ElementName=PART_SearchBox}" Value="">
                                                                <Setter Property="Visibility" Value="Visible" />
                                                            </DataTrigger>
                                                        </Style.Triggers>
                                                    </Style>
                                                </TextBlock.Style>
                                            </TextBlock>
                                        </Grid>
                                    </Border>
                                    <ScrollViewer Grid.Row="1" Focusable="False">
                                        <ItemsPresenter />
                                    </ScrollViewer>
                                </Grid>
                            </Border>
                        </Popup>
                    </Grid>
                </ControlTemplate>
            </Setter.Value>
        </Setter>
    </Style>

    <!--  Implicit default for bare <ComboBox/>.  -->
    <Style BasedOn="{StaticResource AppComboBox}" TargetType="{x:Type ComboBox}" />

</ResourceDictionary>
