<ResourceDictionary
    xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
    xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml">

    <!--
        ════════════════════════════════════════════════════════════
        P2.15 E — Loading skeleton primitives
        ════════════════════════════════════════════════════════════
        Skeleton 是 async data fetch 還沒到位前的 placeholder shape，比空白
        (spinner / 突然出現的數字) 更接近現代 financial UI 的「資料一定會到、
        正在路上」的視覺承諾。

        三個 primitive：
          AppSkeletonRect  : 通用矩形佔位 (e.g. Hero 金額) — 由 caller 指定
                             Width / Height
          AppSkeletonLine  : 單行文字佔位 (e.g. body line) — Height 固定 12
          AppSkeletonCard  : Card 形狀佔位 (e.g. summary metric) — Height 固定 56

        所有 primitive 都有 EventTrigger Loaded → Storyboard 跑 Opacity
        1.0 → 0.4 → 1.0 (1.2 sec) infinite，呈現 subtle pulse。
        AutoReverse + IndefiniteRepeat 讓 shimmer 一直 loop。

        Theme：背景用 AppHover (Layer3 dark / NavySubtle light) — 比 page
        background 稍微亮但不到 surface，傳遞「這裡有東西、還沒到」的視覺
        重量。
    -->

    <Style x:Key="AppSkeletonBase" TargetType="Border">
        <Setter Property="Background" Value="{DynamicResource AppHover}" />
        <Setter Property="CornerRadius" Value="{StaticResource Radius.Sm}" />
        <Setter Property="SnapsToDevicePixels" Value="True" />
        <Style.Triggers>
            <EventTrigger RoutedEvent="Loaded">
                <BeginStoryboard>
                    <Storyboard RepeatBehavior="Forever" AutoReverse="True">
                        <DoubleAnimation
                            Storyboard.TargetProperty="Opacity"
                            From="1.0"
                            To="0.45"
                            Duration="0:0:0.9" />
                    </Storyboard>
                </BeginStoryboard>
            </EventTrigger>
        </Style.Triggers>
    </Style>

    <Style
        x:Key="AppSkeletonRect"
        BasedOn="{StaticResource AppSkeletonBase}"
        TargetType="Border" />

    <Style
        x:Key="AppSkeletonLine"
        BasedOn="{StaticResource AppSkeletonBase}"
        TargetType="Border">
        <Setter Property="Height" Value="12" />
        <Setter Property="HorizontalAlignment" Value="Stretch" />
    </Style>

    <Style
        x:Key="AppSkeletonCard"
        BasedOn="{StaticResource AppSkeletonBase}"
        TargetType="Border">
        <Setter Property="Height" Value="56" />
        <Setter Property="CornerRadius" Value="{StaticResource Radius.Md}" />
    </Style>

</ResourceDictionary>
