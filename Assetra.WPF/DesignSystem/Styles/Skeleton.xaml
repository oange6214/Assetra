<ResourceDictionary
    xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
    xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
    xmlns:sys="clr-namespace:System;assembly=mscorlib">

    <!--
        ════════════════════════════════════════════════════════════
        P2.15 E — Loading skeleton primitives
        ════════════════════════════════════════════════════════════
        Skeleton 是 async data fetch 還沒到位前的 placeholder shape，比空白
        (spinner / 突然出現的數字) 更接近現代 financial UI 的「資料一定會到、
        正在路上」的視覺承諾。

        三個 primitive：
          AppSkeletonRect  : 通用矩形佔位 (e.g. Hero 金額) — 由 caller 指定
                             Width / Height
          AppSkeletonLine  : 單行文字佔位 (e.g. body line) — Height 固定 12
          AppSkeletonCard  : Card 形狀佔位 (e.g. summary metric) — Height 固定 56

        所有 primitive 都有 EventTrigger Loaded → Storyboard 跑 Opacity
        1.0 → 0.45 → 1.0 (0.9 sec) infinite，呈現 subtle pulse。

        Theme：背景用 AppHover (Layer3 dark / NavySubtle light) — 比 page
        background 稍微亮但不到 surface，傳遞「這裡有東西、還沒到」的視覺
        重量。

        ── P2.17 T08 — Reduced-motion ──
        Motion.SkeletonPulseDuration 是 Duration token，預設 0:0:0.9s。
        App.xaml.cs 在 startup 時若偵測到 SystemParameters.MenuAnimation=False
        (Windows 系統偏好「減少動畫」開啟)，會 override 此 resource 成 0:0:0
        讓 pulse 變成不動 (但 background 顏色仍存在，視覺上是 static
        placeholder)，respect 使用者的無障礙設定。
    -->
    <Duration x:Key="Motion.SkeletonPulseDuration">0:0:0.9</Duration>

    <Style x:Key="AppSkeletonBase" TargetType="Border">
        <Setter Property="Background" Value="{DynamicResource AppHover}" />
        <Setter Property="CornerRadius" Value="{StaticResource Radius.Sm}" />
        <Setter Property="SnapsToDevicePixels" Value="True" />
        <Style.Triggers>
            <EventTrigger RoutedEvent="Loaded">
                <BeginStoryboard>
                    <Storyboard RepeatBehavior="Forever" AutoReverse="True">
                        <DoubleAnimation
                            Storyboard.TargetProperty="Opacity"
                            From="1.0"
                            To="0.45"
                            Duration="{StaticResource Motion.SkeletonPulseDuration}" />
                    </Storyboard>
                </BeginStoryboard>
            </EventTrigger>
        </Style.Triggers>
    </Style>

    <Style
        x:Key="AppSkeletonRect"
        BasedOn="{StaticResource AppSkeletonBase}"
        TargetType="Border" />

    <Style
        x:Key="AppSkeletonLine"
        BasedOn="{StaticResource AppSkeletonBase}"
        TargetType="Border">
        <Setter Property="Height" Value="12" />
        <Setter Property="HorizontalAlignment" Value="Stretch" />
    </Style>

    <Style
        x:Key="AppSkeletonCard"
        BasedOn="{StaticResource AppSkeletonBase}"
        TargetType="Border">
        <Setter Property="Height" Value="56" />
        <Setter Property="CornerRadius" Value="{StaticResource Radius.Md}" />
    </Style>

</ResourceDictionary>
