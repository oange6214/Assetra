<ResourceDictionary xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation" xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml">

    <!--
        ══════════════════════════════════════════════════════
        Light Theme — Windows 11 Mica / WinUI 3 palette
        ══════════════════════════════════════════════════════
        All Color= attributes reference primitives from
        DesignSystem/Tokens/Colors.xaml — no hex values here.
        Preserved for ColorSchemeService Taiwan/Intl swap.
    -->

    <!--  Backgrounds — Asset Management CIS light theme  -->
    <SolidColorBrush x:Key="AppBackground"        Color="{StaticResource Color.Cis.Light.Background}" />
    <SolidColorBrush x:Key="AppSurface"           Color="{StaticResource Color.Cis.Light.Surface}" />
    <SolidColorBrush x:Key="AppSurfaceAlt"        Color="{StaticResource Color.Brand.SoftWhite}" />
    <SolidColorBrush x:Key="AppCardBackground"    Color="{StaticResource Color.Cis.Light.Surface}" />
    <SolidColorBrush x:Key="AppNavRailBackground" Color="{StaticResource Color.Cis.Light.NavRail}" />
    <SolidColorBrush x:Key="AppHover"             Color="{StaticResource Color.Brand.NavySubtle}" />

    <!--  Borders  -->
    <SolidColorBrush x:Key="AppBorder"      Color="{StaticResource Color.Cis.Light.Border}" />
    <SolidColorBrush x:Key="AppBorderLight" Color="{StaticResource Color.Brand.SoftWhite}" />

    <!--  Text — Slate ramp  -->
    <SolidColorBrush x:Key="AppTextPrimary"   Color="{StaticResource Color.Cis.Light.TextPrimary}" />
    <SolidColorBrush x:Key="AppTextSecondary" Color="{StaticResource Color.Cis.Light.TextSecondary}" />
    <SolidColorBrush x:Key="AppTextMuted"     Color="{StaticResource Color.Slate.500}" />
    <SolidColorBrush x:Key="AppTextOnAccent"  Color="{StaticResource Color.White}" />

    <!--
        Semantic — price direction.
        AppUp = green-700 (~5.5:1 on white, passes WCAG AA at small sizes).
        Preserved for ColorSchemeService Taiwan/Intl swap.
    -->
    <SolidColorBrush x:Key="AppUp"      Color="{StaticResource Color.Green.700}" />
    <SolidColorBrush x:Key="AppDown"    Color="{StaticResource Color.Red.600}" />
    <SolidColorBrush x:Key="AppNeutral" Color="{StaticResource Color.Slate.600}" />

    <!--  Semantic — status  -->
    <SolidColorBrush x:Key="AppWarning"        Color="{StaticResource Color.Amber.500}" />
    <SolidColorBrush x:Key="AppWarningSubtle"  Color="#FFF8EB" />
    <SolidColorBrush x:Key="AppInfoSubtle"     Color="#EFF6FF" />
    <SolidColorBrush x:Key="AppSuccess"   Color="{StaticResource Color.Green.700}" />
    <SolidColorBrush x:Key="AppFocusRing" Color="{StaticResource Color.Brand.Navy}" />

    <!--  Semantic — destructive  -->
    <SolidColorBrush x:Key="AppDanger" Color="{StaticResource Color.Red.600}" />
    <!--  P5.7 — soft red wash for "required for sub-brokerage" badges & danger-tinted backgrounds  -->
    <SolidColorBrush x:Key="AppDangerSubtle" Color="{StaticResource Color.Red.50}" />

    <!--  Brand primary — Navy  -->
    <SolidColorBrush x:Key="AppAccent"       Color="{StaticResource Color.Brand.Navy}" />
    <SolidColorBrush x:Key="AppAccentHover"  Color="{StaticResource Color.Brand.NavyHover}" />
    <SolidColorBrush x:Key="AppAccentSubtle" Color="{StaticResource Color.Brand.NavySubtle}" />
    <SolidColorBrush x:Key="AppAccentSoft"   Color="{StaticResource Color.Brand.NavySubtle}" />
    <SolidColorBrush x:Key="AppAccentText"   Color="{StaticResource Color.Brand.Navy}" />

    <!--  Canonical semantic DesignSystem brushes  -->
    <SolidColorBrush x:Key="Brush.Background"     Color="{StaticResource Color.Cis.Light.Background}" />
    <SolidColorBrush x:Key="Brush.Surface"        Color="{StaticResource Color.Cis.Light.Surface}" />
    <SolidColorBrush x:Key="Brush.SurfaceRaised"  Color="{StaticResource Color.Brand.SoftWhite}" />
    <SolidColorBrush x:Key="Brush.Text.Primary"   Color="{StaticResource Color.Cis.Light.TextPrimary}" />
    <SolidColorBrush x:Key="Brush.Text.Secondary" Color="{StaticResource Color.Cis.Light.TextSecondary}" />
    <SolidColorBrush x:Key="Brush.Text.Muted"     Color="{StaticResource Color.Slate.500}" />
    <SolidColorBrush x:Key="Brush.Text.OnAccent"  Color="{StaticResource Color.White}" />
    <SolidColorBrush x:Key="Brush.Border"         Color="{StaticResource Color.Cis.Light.Border}" />
    <SolidColorBrush x:Key="Brush.BorderStrong"   Color="{StaticResource Color.Slate.300}" />
    <SolidColorBrush x:Key="Brush.Accent"         Color="{StaticResource Color.Brand.Navy}" />
    <SolidColorBrush x:Key="Brush.AccentHover"    Color="{StaticResource Color.Brand.NavyHover}" />
    <SolidColorBrush x:Key="Brush.AccentSubtle"   Color="{StaticResource Color.Brand.NavySubtle}" />
    <SolidColorBrush x:Key="Brush.Danger"         Color="{StaticResource Color.Red.600}" />
    <SolidColorBrush x:Key="Brush.Warning"        Color="{StaticResource Color.Amber.500}" />
    <SolidColorBrush x:Key="Brush.Success"        Color="{StaticResource Color.Green.700}" />
    <SolidColorBrush x:Key="Brush.FocusRing"      Color="{StaticResource Color.Brand.Navy}" />
    <SolidColorBrush x:Key="Brush.Up"             Color="{StaticResource Color.Green.700}" />
    <SolidColorBrush x:Key="Brush.Down"           Color="{StaticResource Color.Red.600}" />
    <SolidColorBrush x:Key="Brush.Neutral"        Color="{StaticResource Color.Slate.600}" />
    <SolidColorBrush x:Key="Brush.Info"           Color="{StaticResource Color.Cyan.600}" />
    <SolidColorBrush x:Key="Brush.Special"        Color="{StaticResource Color.Violet.800}" />
    <SolidColorBrush x:Key="Brush.Risk"           Color="{StaticResource Color.Amber.500}" />
    <SolidColorBrush x:Key="Brush.Budget"         Color="{StaticResource Color.Brand.Gold}" />

    <!--  Brand accent — Gold  -->
    <SolidColorBrush x:Key="AppGold"       Color="{StaticResource Color.Brand.Gold}" />
    <SolidColorBrush x:Key="AppGoldHover"  Color="{StaticResource Color.Brand.GoldHover}" />
    <SolidColorBrush x:Key="AppGoldSubtle" Color="{StaticResource Color.Brand.GoldSubtle}" />

    <!--  DataGrid  -->
    <SolidColorBrush x:Key="AppSelectedRow" Color="{StaticResource Color.Brand.NavySubtle}" />
    <SolidColorBrush x:Key="AppGridLines"   Color="{StaticResource Color.Cis.Light.Border}" />

    <!--  Error banner  -->
    <SolidColorBrush x:Key="AppErrorBg"     Color="{StaticResource Color.Red.50}" />
    <SolidColorBrush x:Key="AppErrorBorder" Color="{StaticResource Color.Red.600}" />

    <!--  Modal overlay scrim  -->
    <SolidColorBrush x:Key="AppModalOverlay"    Color="#66000000" />
    <SolidColorBrush x:Key="Brush.ModalOverlay" Color="#66000000" />

    <!--  Legacy aliases  -->
    <SolidColorBrush x:Key="AppTextHint" Color="#6B6B6B" />

</ResourceDictionary>
