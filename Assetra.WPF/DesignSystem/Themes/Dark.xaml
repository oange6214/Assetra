<ResourceDictionary xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation" xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml">

    <!--
        ══════════════════════════════════════════════════════
        Dark Theme — Asset Management CIS
        ══════════════════════════════════════════════════════
        All Color= attributes reference primitives from
        DesignSystem/Tokens/Colors.xaml — no hex values here.
        Institutional graphite surfaces, quiet navy structure, and gold
        accents align the app with the asset management identity system.
    -->

    <!--  Backgrounds — Asset Management CIS dark theme  -->
    <SolidColorBrush x:Key="AppBackground" Color="{StaticResource Color.Cis.Dark.Background}" />
    <SolidColorBrush x:Key="AppSurface" Color="{StaticResource Color.Cis.Dark.Layer1}" />
    <SolidColorBrush x:Key="AppSurfaceAlt" Color="{StaticResource Color.Cis.Dark.Layer2}" />
    <SolidColorBrush x:Key="AppCardBackground" Color="{StaticResource Color.Cis.Dark.Layer1}" />
    <SolidColorBrush x:Key="AppNavRailBackground" Color="{StaticResource Color.Cis.Dark.NavRail}" />
    <SolidColorBrush x:Key="AppHover" Color="{StaticResource Color.Cis.Dark.Layer3}" />

    <!--  Borders  -->
    <SolidColorBrush x:Key="AppBorder" Color="{StaticResource Color.Cis.Dark.Layer3}" />
    <SolidColorBrush x:Key="AppBorderLight" Color="{StaticResource Color.Cis.Dark.Layer2}" />

    <!--  Text — Slate ramp (dark)  -->
    <SolidColorBrush x:Key="AppTextPrimary" Color="{StaticResource Color.Cis.Dark.TextPrimary}" />
    <SolidColorBrush x:Key="AppTextSecondary" Color="{StaticResource Color.Cis.Dark.TextSecondary}" />
    <SolidColorBrush x:Key="AppTextMuted" Color="{StaticResource Color.Slate.400}" />
    <SolidColorBrush x:Key="AppTextOnAccent" Color="{StaticResource Color.White}" />

    <!--  Semantic — price direction (brightened for dark surfaces)  -->
    <SolidColorBrush x:Key="AppUp" Color="{StaticResource Color.Green.500}" />
    <SolidColorBrush x:Key="AppDown" Color="{StaticResource Color.Red.500}" />
    <SolidColorBrush x:Key="AppNeutral" Color="{StaticResource Color.Slate.400}" />

    <!--  Semantic — status  -->
    <SolidColorBrush x:Key="AppWarning" Color="{StaticResource Color.Amber.400}" />
    <SolidColorBrush x:Key="AppWarningSubtle" Color="#3E2C0F" />
    <SolidColorBrush x:Key="AppInfoSubtle" Color="#0F2848" />
    <SolidColorBrush x:Key="AppSuccess" Color="{StaticResource Color.Green.500}" />
    <SolidColorBrush x:Key="AppFocusRing" Color="{StaticResource Color.Blue.400}" />

    <!--  Semantic — destructive  -->
    <SolidColorBrush x:Key="AppDanger" Color="{StaticResource Color.Red.500}" />
    <!--  P5.7 — soft red wash for "required for sub-brokerage" badges & danger-tinted backgrounds. Dark mode uses Red.500 with low opacity via direct color.  -->
    <SolidColorBrush x:Key="AppDangerSubtle" Color="#33EF4444" />

    <!--  Brand primary — Dark variant  -->
    <SolidColorBrush x:Key="AppAccent" Color="{StaticResource Color.Brand.Gold}" />
    <SolidColorBrush x:Key="AppAccentHover" Color="{StaticResource Color.Brand.GoldHover.Dark}" />
    <SolidColorBrush x:Key="AppAccentSubtle" Color="{StaticResource Color.Brand.NavySubtle.Dark}" />
    <SolidColorBrush x:Key="AppAccentSoft" Color="{StaticResource Color.Brand.NavySubtle.Dark}" />
    <SolidColorBrush x:Key="AppAccentText" Color="{StaticResource Color.Brand.GoldDark}" />

    <!--  Canonical semantic DesignSystem brushes  -->
    <SolidColorBrush x:Key="Brush.Background" Color="{StaticResource Color.Cis.Dark.Background}" />
    <SolidColorBrush x:Key="Brush.Surface" Color="{StaticResource Color.Cis.Dark.Layer1}" />
    <SolidColorBrush x:Key="Brush.SurfaceRaised" Color="{StaticResource Color.Cis.Dark.Layer2}" />
    <SolidColorBrush x:Key="Brush.Text.Primary" Color="{StaticResource Color.Cis.Dark.TextPrimary}" />
    <SolidColorBrush x:Key="Brush.Text.Secondary" Color="{StaticResource Color.Cis.Dark.TextSecondary}" />
    <SolidColorBrush x:Key="Brush.Text.Muted" Color="{StaticResource Color.Slate.400}" />
    <SolidColorBrush x:Key="Brush.Text.OnAccent" Color="{StaticResource Color.White}" />
    <SolidColorBrush x:Key="Brush.Border" Color="{StaticResource Color.Cis.Dark.Layer3}" />
    <SolidColorBrush x:Key="Brush.BorderStrong" Color="{StaticResource Color.Slate.600}" />
    <SolidColorBrush x:Key="Brush.Accent" Color="{StaticResource Color.Brand.Gold}" />
    <SolidColorBrush x:Key="Brush.AccentHover" Color="{StaticResource Color.Brand.GoldHover.Dark}" />
    <SolidColorBrush x:Key="Brush.AccentSubtle" Color="{StaticResource Color.Brand.NavySubtle.Dark}" />
    <SolidColorBrush x:Key="Brush.Danger" Color="{StaticResource Color.Red.500}" />
    <SolidColorBrush x:Key="Brush.Warning" Color="{StaticResource Color.Amber.400}" />
    <SolidColorBrush x:Key="Brush.Success" Color="{StaticResource Color.Green.500}" />
    <SolidColorBrush x:Key="Brush.FocusRing" Color="{StaticResource Color.Blue.400}" />
    <SolidColorBrush x:Key="Brush.Up" Color="{StaticResource Color.Green.500}" />
    <SolidColorBrush x:Key="Brush.Down" Color="{StaticResource Color.Red.500}" />
    <SolidColorBrush x:Key="Brush.Neutral" Color="{StaticResource Color.Slate.400}" />
    <SolidColorBrush x:Key="Brush.Info" Color="{StaticResource Color.Cyan.400}" />
    <SolidColorBrush x:Key="Brush.Special" Color="{StaticResource Color.Violet.400}" />
    <SolidColorBrush x:Key="Brush.Risk" Color="{StaticResource Color.Amber.400}" />
    <SolidColorBrush x:Key="Brush.Budget" Color="{StaticResource Color.Brand.GoldDark}" />

    <!--  Brand accent — Gold (dark variant)  -->
    <SolidColorBrush x:Key="AppGold" Color="{StaticResource Color.Brand.GoldDark}" />
    <SolidColorBrush x:Key="AppGoldHover" Color="{StaticResource Color.Brand.GoldHover.Dark}" />
    <SolidColorBrush x:Key="AppGoldSubtle" Color="{StaticResource Color.Brand.GoldSubtle.Dark}" />

    <!--  DataGrid  -->
    <SolidColorBrush x:Key="AppSelectedRow" Color="{StaticResource Color.Brand.NavySubtle.Dark}" />
    <SolidColorBrush x:Key="AppGridLines" Color="{StaticResource Color.Slate.700}" />

    <!--  Modal overlay  -->
    <SolidColorBrush x:Key="AppModalOverlay" Color="#99000000" />
    <SolidColorBrush x:Key="Brush.ModalOverlay" Color="#99000000" />

    <!--  Error banner  -->
    <SolidColorBrush x:Key="AppErrorBg" Color="#3B1F1F" />
    <SolidColorBrush x:Key="AppErrorBorder" Color="{StaticResource Color.Red.500}" />

    <!--  Legacy aliases  -->
    <SolidColorBrush x:Key="AppTextHint" Color="#8C8C8C" />

</ResourceDictionary>
