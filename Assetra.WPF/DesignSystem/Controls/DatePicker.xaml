<ResourceDictionary
    xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
    xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
    xmlns:primitives="clr-namespace:System.Windows.Controls.Primitives;assembly=PresentationFramework"
    xmlns:behaviors="clr-namespace:Assetra.WPF.Infrastructure.Behaviors"
    xmlns:ds="clr-namespace:Assetra.WPF.DesignSystem.Controls">

    <Style x:Key="AppDatePickerTextBox" TargetType="{x:Type primitives:DatePickerTextBox}">
        <Setter Property="MinHeight" Value="{StaticResource Control.Height.Md}" />
        <Setter Property="Padding" Value="10,6" />
        <Setter Property="FontFamily" Value="{StaticResource Font.Family.Base}" />
        <Setter Property="FontSize" Value="{StaticResource Font.Size.Sm}" />
        <Setter Property="Foreground" Value="{DynamicResource Brush.Text.Primary}" />
        <Setter Property="Background" Value="{DynamicResource Brush.Surface}" />
        <Setter Property="BorderBrush" Value="{DynamicResource Brush.Border}" />
        <Setter Property="BorderThickness" Value="{StaticResource Border.Input}" />
        <Setter Property="CaretBrush" Value="{DynamicResource Brush.Text.Primary}" />
        <Setter Property="VerticalContentAlignment" Value="Center" />
        <Setter Property="Focusable" Value="True" />
        <Setter Property="HorizontalContentAlignment" Value="Left" />
        <Setter Property="Template">
            <Setter.Value>
                <ControlTemplate TargetType="{x:Type primitives:DatePickerTextBox}">
                    <Border
                        x:Name="Chrome"
                        Background="{TemplateBinding Background}"
                        BorderBrush="{TemplateBinding BorderBrush}"
                        BorderThickness="{TemplateBinding BorderThickness}"
                        CornerRadius="{StaticResource Radius.Sm}"
                        SnapsToDevicePixels="True">
                        <ScrollViewer
                            x:Name="PART_ContentHost"
                            Margin="{TemplateBinding Padding}"
                            Focusable="False"
                            HorizontalScrollBarVisibility="Hidden"
                            VerticalScrollBarVisibility="Hidden" />
                    </Border>
                    <ControlTemplate.Triggers>
                        <Trigger Property="IsKeyboardFocused" Value="True">
                            <Setter TargetName="Chrome" Property="BorderBrush" Value="{DynamicResource Brush.FocusRing}" />
                        </Trigger>
                        <Trigger Property="Validation.HasError" Value="True">
                            <Setter TargetName="Chrome" Property="BorderBrush" Value="{DynamicResource Brush.Danger}" />
                        </Trigger>
                        <Trigger Property="IsEnabled" Value="False">
                            <Setter Property="Opacity" Value="0.45" />
                        </Trigger>
                    </ControlTemplate.Triggers>
                </ControlTemplate>
            </Setter.Value>
        </Setter>
    </Style>

    <Style BasedOn="{StaticResource AppDatePickerTextBox}" TargetType="{x:Type primitives:DatePickerTextBox}" />

    <!--
        ════════════════════════════════════════════════════════════
        AppCalendarButton — month / year header nav buttons
        ════════════════════════════════════════════════════════════
        Drives:
        * PART_HeaderButton (the centered "May 2026" text button)
        * PART_PreviousButton / PART_NextButton (◀ ▶ chevrons)
        * Year/decade view month-cell buttons
    -->
    <Style x:Key="AppCalendarButton" TargetType="{x:Type primitives:CalendarButton}">
        <Setter Property="Background" Value="Transparent" />
        <Setter Property="BorderBrush" Value="Transparent" />
        <Setter Property="BorderThickness" Value="0" />
        <Setter Property="Foreground" Value="{DynamicResource AppTextPrimary}" />
        <Setter Property="FontFamily" Value="{StaticResource Font.Family.Base}" />
        <Setter Property="FontSize" Value="{StaticResource Font.Size.Sm}" />
        <Setter Property="FontWeight" Value="SemiBold" />
        <Setter Property="MinWidth" Value="40" />
        <Setter Property="MinHeight" Value="32" />
        <Setter Property="Padding" Value="6,4" />
        <Setter Property="HorizontalContentAlignment" Value="Center" />
        <Setter Property="VerticalContentAlignment" Value="Center" />
        <Setter Property="Cursor" Value="Hand" />
        <Setter Property="FocusVisualStyle" Value="{x:Null}" />
        <Setter Property="Template">
            <Setter.Value>
                <ControlTemplate TargetType="{x:Type primitives:CalendarButton}">
                    <Border
                        x:Name="Chrome"
                        Background="{TemplateBinding Background}"
                        BorderBrush="{TemplateBinding BorderBrush}"
                        BorderThickness="{TemplateBinding BorderThickness}"
                        CornerRadius="{StaticResource Radius.Sm}"
                        SnapsToDevicePixels="True">
                        <ContentPresenter
                            Margin="{TemplateBinding Padding}"
                            HorizontalAlignment="{TemplateBinding HorizontalContentAlignment}"
                            VerticalAlignment="{TemplateBinding VerticalContentAlignment}"
                            TextElement.Foreground="{TemplateBinding Foreground}" />
                    </Border>
                    <ControlTemplate.Triggers>
                        <!--
                            CalendarButton properties: IsInactive, HasSelectedDays,
                            IsFocused (no IsSelected — that's on CalendarDayButton).
                            "Currently displayed" cells use HasSelectedDays for the
                            ring; mouse hover paints the fill.
                        -->
                        <Trigger Property="IsMouseOver" Value="True">
                            <Setter TargetName="Chrome" Property="Background" Value="{DynamicResource AppHover}" />
                        </Trigger>
                        <Trigger Property="HasSelectedDays" Value="True">
                            <Setter TargetName="Chrome" Property="Background" Value="{DynamicResource AppAccentSubtle}" />
                            <Setter TargetName="Chrome" Property="BorderBrush" Value="{DynamicResource AppAccent}" />
                            <Setter TargetName="Chrome" Property="BorderThickness" Value="1" />
                            <Setter Property="Foreground" Value="{DynamicResource AppAccent}" />
                        </Trigger>
                        <Trigger Property="IsInactive" Value="True">
                            <Setter Property="Opacity" Value="0.45" />
                        </Trigger>
                        <Trigger Property="IsEnabled" Value="False">
                            <Setter Property="Opacity" Value="0.45" />
                            <Setter Property="Cursor" Value="Arrow" />
                        </Trigger>
                    </ControlTemplate.Triggers>
                </ControlTemplate>
            </Setter.Value>
        </Setter>
    </Style>

    <Style BasedOn="{StaticResource AppCalendarButton}" TargetType="{x:Type primitives:CalendarButton}" />

    <!--
        ════════════════════════════════════════════════════════════
        Chevron-button style for previous/next nav (◀ ▶)
        ════════════════════════════════════════════════════════════
        Used inside the CalendarItem template; bare 28×28 circular
        hover affordance. Path data is the standard left/right chevron.
    -->
    <Style x:Key="AppCalendarNavButton" TargetType="{x:Type Button}">
        <Setter Property="Width" Value="28" />
        <Setter Property="Height" Value="28" />
        <Setter Property="Padding" Value="0" />
        <Setter Property="Background" Value="Transparent" />
        <Setter Property="BorderThickness" Value="0" />
        <Setter Property="Cursor" Value="Hand" />
        <Setter Property="Foreground" Value="{DynamicResource AppTextSecondary}" />
        <Setter Property="FocusVisualStyle" Value="{x:Null}" />
        <Setter Property="Template">
            <Setter.Value>
                <ControlTemplate TargetType="{x:Type Button}">
                    <Border
                        x:Name="Chrome"
                        Background="{TemplateBinding Background}"
                        CornerRadius="{StaticResource Radius.Full}"
                        SnapsToDevicePixels="True">
                        <ContentPresenter
                            HorizontalAlignment="Center"
                            VerticalAlignment="Center"
                            TextElement.Foreground="{TemplateBinding Foreground}" />
                    </Border>
                    <ControlTemplate.Triggers>
                        <Trigger Property="IsMouseOver" Value="True">
                            <Setter TargetName="Chrome" Property="Background" Value="{DynamicResource AppHover}" />
                            <Setter Property="Foreground" Value="{DynamicResource AppTextPrimary}" />
                        </Trigger>
                        <Trigger Property="IsEnabled" Value="False">
                            <Setter Property="Opacity" Value="0.45" />
                            <Setter Property="Cursor" Value="Arrow" />
                        </Trigger>
                    </ControlTemplate.Triggers>
                </ControlTemplate>
            </Setter.Value>
        </Setter>
    </Style>

    <!--
        ════════════════════════════════════════════════════════════
        AppCalendarItem — the popup body of a Calendar
        ════════════════════════════════════════════════════════════
        Full template that:
        * Wraps the calendar in an AppSurface card with rounded corners
        * Centers "May 2026" header (PART_HeaderButton) flanked by ◀ ▶
        * Renders day-of-week strip + Month/Year/Decade views
        * Drops the default WPF white-with-grey-border chrome that
          previously leaked through the popup
    -->
    <Style x:Key="AppCalendarItem" TargetType="{x:Type primitives:CalendarItem}">
        <Setter Property="Margin" Value="0" />
        <Setter Property="Background" Value="{DynamicResource AppSurface}" />
        <Setter Property="Foreground" Value="{DynamicResource AppTextPrimary}" />
        <Setter Property="BorderBrush" Value="{DynamicResource AppBorder}" />
        <Setter Property="BorderThickness" Value="1" />
        <Setter Property="Template">
            <Setter.Value>
                <ControlTemplate TargetType="{x:Type primitives:CalendarItem}">
                    <ControlTemplate.Resources>
                        <DataTemplate x:Key="{x:Static CalendarItem.DayTitleTemplateResourceKey}">
                            <TextBlock
                                Margin="0,0,0,4"
                                HorizontalAlignment="Center"
                                VerticalAlignment="Center"
                                FontFamily="{StaticResource Font.Family.Base}"
                                FontSize="{StaticResource Font.Size.Xs}"
                                FontWeight="SemiBold"
                                Foreground="{DynamicResource AppTextMuted}"
                                Text="{Binding}" />
                        </DataTemplate>
                    </ControlTemplate.Resources>
                    <Border
                        Padding="10,10,10,8"
                        Background="{TemplateBinding Background}"
                        BorderBrush="{TemplateBinding BorderBrush}"
                        BorderThickness="{TemplateBinding BorderThickness}"
                        CornerRadius="{StaticResource Radius.Md}"
                        SnapsToDevicePixels="True">
                        <Grid>
                            <Grid.RowDefinitions>
                                <RowDefinition Height="Auto" />
                                <RowDefinition Height="*" />
                            </Grid.RowDefinitions>

                            <!--  Header row : ◀  May 2026  ▶  -->
                            <Grid Grid.Row="0" Margin="0,0,0,6">
                                <Grid.ColumnDefinitions>
                                    <ColumnDefinition Width="Auto" />
                                    <ColumnDefinition Width="*" />
                                    <ColumnDefinition Width="Auto" />
                                </Grid.ColumnDefinitions>
                                <Button
                                    x:Name="PART_PreviousButton"
                                    Grid.Column="0"
                                    Focusable="False"
                                    Style="{StaticResource AppCalendarNavButton}">
                                    <Path
                                        Width="6"
                                        Height="10"
                                        Data="M 6 0 L 0 5 L 6 10"
                                        Stroke="{Binding Foreground, RelativeSource={RelativeSource AncestorType=Button}}"
                                        StrokeEndLineCap="Round"
                                        StrokeStartLineCap="Round"
                                        StrokeThickness="1.6" />
                                </Button>
                                <Button
                                    x:Name="PART_HeaderButton"
                                    Grid.Column="1"
                                    Margin="6,0"
                                    Padding="6,4"
                                    HorizontalAlignment="Stretch"
                                    HorizontalContentAlignment="Center"
                                    Background="Transparent"
                                    BorderThickness="0"
                                    Cursor="Hand"
                                    FocusVisualStyle="{x:Null}"
                                    FontFamily="{StaticResource Font.Family.Base}"
                                    FontSize="{StaticResource Font.Size.Sm}"
                                    FontWeight="SemiBold"
                                    Foreground="{DynamicResource AppTextPrimary}">
                                    <Button.Template>
                                        <ControlTemplate TargetType="{x:Type Button}">
                                            <Border
                                                x:Name="Chrome"
                                                Padding="{TemplateBinding Padding}"
                                                Background="{TemplateBinding Background}"
                                                CornerRadius="{StaticResource Radius.Sm}">
                                                <ContentPresenter
                                                    HorizontalAlignment="Center"
                                                    VerticalAlignment="Center" />
                                            </Border>
                                            <ControlTemplate.Triggers>
                                                <Trigger Property="IsMouseOver" Value="True">
                                                    <Setter TargetName="Chrome" Property="Background" Value="{DynamicResource AppHover}" />
                                                </Trigger>
                                            </ControlTemplate.Triggers>
                                        </ControlTemplate>
                                    </Button.Template>
                                </Button>
                                <Button
                                    x:Name="PART_NextButton"
                                    Grid.Column="2"
                                    Focusable="False"
                                    Style="{StaticResource AppCalendarNavButton}">
                                    <Path
                                        Width="6"
                                        Height="10"
                                        Data="M 0 0 L 6 5 L 0 10"
                                        Stroke="{Binding Foreground, RelativeSource={RelativeSource AncestorType=Button}}"
                                        StrokeEndLineCap="Round"
                                        StrokeStartLineCap="Round"
                                        StrokeThickness="1.6" />
                                </Button>
                            </Grid>

                            <!--
                                Body : Month / Year / Decade views, stacked in
                                a single body cell. Calendar.UpdateAppearance()
                                toggles Visibility on PART_MonthView /
                                PART_YearView based on DisplayMode.

                                Wrapped in an unnamed Grid (NOT just Grid.Row
                                siblings) — flat sibling layout caused stale
                                _monthView refs after first mode swap and the
                                Decade view stacked over the Month grid.

                                Each PART starts with collapsed Visibility so
                                only the one Calendar makes Visible renders;
                                without this initial state both render at
                                first Measure and the user sees stacked grids
                                until the first mode swap.
                            -->
                            <Grid Grid.Row="1">
                                <Grid x:Name="PART_MonthView" Visibility="Collapsed">
                                    <Grid.ColumnDefinitions>
                                        <ColumnDefinition Width="*" />
                                        <ColumnDefinition Width="*" />
                                        <ColumnDefinition Width="*" />
                                        <ColumnDefinition Width="*" />
                                        <ColumnDefinition Width="*" />
                                        <ColumnDefinition Width="*" />
                                        <ColumnDefinition Width="*" />
                                    </Grid.ColumnDefinitions>
                                    <Grid.RowDefinitions>
                                        <RowDefinition Height="Auto" />
                                        <RowDefinition Height="*" />
                                        <RowDefinition Height="*" />
                                        <RowDefinition Height="*" />
                                        <RowDefinition Height="*" />
                                        <RowDefinition Height="*" />
                                        <RowDefinition Height="*" />
                                    </Grid.RowDefinitions>
                                </Grid>
                                <Grid x:Name="PART_YearView" Visibility="Collapsed">
                                    <Grid.ColumnDefinitions>
                                        <ColumnDefinition Width="*" />
                                        <ColumnDefinition Width="*" />
                                        <ColumnDefinition Width="*" />
                                        <ColumnDefinition Width="*" />
                                    </Grid.ColumnDefinitions>
                                    <Grid.RowDefinitions>
                                        <RowDefinition Height="*" />
                                        <RowDefinition Height="*" />
                                        <RowDefinition Height="*" />
                                    </Grid.RowDefinitions>
                                </Grid>
                            </Grid>
                        </Grid>
                    </Border>
                    <!--
                        Visibility of PART_MonthView / PART_YearView is driven
                        internally by Calendar based on its DisplayMode (Month /
                        Year / Decade) — CalendarItem does not expose DisplayMode
                        as a TemplatedParent property, so triggers here would fail
                        to compile. WPF will toggle each PART's Visibility for us
                        as long as the named parts exist in the template.
                    -->
                </ControlTemplate>
            </Setter.Value>
        </Setter>
    </Style>

    <Style BasedOn="{StaticResource AppCalendarItem}" TargetType="{x:Type primitives:CalendarItem}" />

    <Style x:Key="AppCalendar" TargetType="{x:Type Calendar}">
        <Setter Property="Background" Value="{DynamicResource AppSurface}" />
        <Setter Property="Foreground" Value="{DynamicResource AppTextPrimary}" />
        <Setter Property="BorderBrush" Value="{DynamicResource AppBorder}" />
        <Setter Property="BorderThickness" Value="0" />
        <Setter Property="FontFamily" Value="{StaticResource Font.Family.Base}" />
        <Setter Property="FontSize" Value="{StaticResource Font.Size.Sm}" />
        <!--
            Explicitly bind sub-part styles so Calendar uses our themed
            templates. Without these, the implicit CalendarDayButton /
            CalendarButton / CalendarItem fallbacks may be skipped — Calendar
            internally instantiates these via FrameworkElement.Style which
            doesn't always honour ambient implicit styles when nested in
            a popup. The CalendarItemStyle in particular is required for the
            ◀ ▶ chevron paths and rounded popup chrome to appear.
        -->
        <Setter Property="CalendarDayButtonStyle" Value="{StaticResource AppCalendarDayButton}" />
        <Setter Property="CalendarButtonStyle" Value="{StaticResource AppCalendarButton}" />
        <Setter Property="CalendarItemStyle" Value="{StaticResource AppCalendarItem}" />
    </Style>

    <Style BasedOn="{StaticResource AppCalendar}" TargetType="{x:Type Calendar}" />

    <Style x:Key="AppCalendarDayButton" TargetType="{x:Type primitives:CalendarDayButton}">
        <Setter Property="MinWidth" Value="34" />
        <Setter Property="MinHeight" Value="34" />
        <Setter Property="Margin" Value="1" />
        <Setter Property="Padding" Value="0" />
        <Setter Property="Background" Value="Transparent" />
        <Setter Property="BorderBrush" Value="Transparent" />
        <Setter Property="BorderThickness" Value="1" />
        <Setter Property="Foreground" Value="{DynamicResource Brush.Text.Primary}" />
        <Setter Property="FontFamily" Value="{StaticResource Font.Family.Base}" />
        <Setter Property="FontSize" Value="{StaticResource Font.Size.Sm}" />
        <Setter Property="FontWeight" Value="{StaticResource Font.Weight.Medium}" />
        <Setter Property="HorizontalContentAlignment" Value="Center" />
        <Setter Property="VerticalContentAlignment" Value="Center" />
        <Setter Property="Template">
            <Setter.Value>
                <ControlTemplate TargetType="{x:Type primitives:CalendarDayButton}">
                    <Border
                        x:Name="Chrome"
                        Background="{TemplateBinding Background}"
                        BorderBrush="{TemplateBinding BorderBrush}"
                        BorderThickness="{TemplateBinding BorderThickness}"
                        CornerRadius="{StaticResource Radius.Full}"
                        SnapsToDevicePixels="True">
                        <ContentPresenter
                            HorizontalAlignment="{TemplateBinding HorizontalContentAlignment}"
                            VerticalAlignment="{TemplateBinding VerticalContentAlignment}"
                            RecognizesAccessKey="True"
                            TextElement.Foreground="{TemplateBinding Foreground}" />
                    </Border>
                    <ControlTemplate.Triggers>
                        <Trigger Property="IsMouseOver" Value="True">
                            <Setter TargetName="Chrome" Property="Background" Value="{DynamicResource Brush.SurfaceRaised}" />
                            <Setter TargetName="Chrome" Property="BorderBrush" Value="{DynamicResource Brush.BorderStrong}" />
                        </Trigger>
                        <Trigger Property="IsToday" Value="True">
                            <Setter TargetName="Chrome" Property="BorderBrush" Value="{DynamicResource Brush.Accent}" />
                            <Setter Property="Foreground" Value="{DynamicResource Brush.Accent}" />
                        </Trigger>
                        <Trigger Property="IsSelected" Value="True">
                            <Setter TargetName="Chrome" Property="Background" Value="{DynamicResource Brush.Accent}" />
                            <Setter TargetName="Chrome" Property="BorderBrush" Value="{DynamicResource Brush.Accent}" />
                            <Setter Property="Foreground" Value="{DynamicResource Brush.Text.OnAccent}" />
                        </Trigger>
                        <MultiTrigger>
                            <MultiTrigger.Conditions>
                                <Condition Property="IsSelected" Value="True" />
                                <Condition Property="IsToday" Value="True" />
                            </MultiTrigger.Conditions>
                            <Setter TargetName="Chrome" Property="BorderBrush" Value="{DynamicResource Brush.FocusRing}" />
                        </MultiTrigger>
                        <Trigger Property="IsInactive" Value="True">
                            <Setter Property="Opacity" Value="0.45" />
                        </Trigger>
                        <Trigger Property="IsBlackedOut" Value="True">
                            <Setter Property="Opacity" Value="0.28" />
                            <Setter Property="Foreground" Value="{DynamicResource AppTextMuted}" />
                        </Trigger>
                    </ControlTemplate.Triggers>
                </ControlTemplate>
            </Setter.Value>
        </Setter>
    </Style>

    <Style BasedOn="{StaticResource AppCalendarDayButton}" TargetType="{x:Type primitives:CalendarDayButton}" />

    <!--
        Drop-down trigger button — replaces the OS default "15"-on-calendar
        glyph with a Fluent CalendarLtr icon. Embedded inside the DatePicker
        template below; not exposed as a public key.
    -->
    <Style x:Key="DatePickerDropDownButton" TargetType="{x:Type Button}">
        <Setter Property="Width" Value="32" />
        <Setter Property="Height" Value="{StaticResource Control.Height.Md}" />
        <Setter Property="MinHeight" Value="{StaticResource Control.Height.Md}" />
        <Setter Property="Padding" Value="0" />
        <Setter Property="Background" Value="Transparent" />
        <Setter Property="BorderThickness" Value="0" />
        <Setter Property="Foreground" Value="{DynamicResource AppTextSecondary}" />
        <Setter Property="Cursor" Value="Hand" />
        <Setter Property="FocusVisualStyle" Value="{x:Null}" />
        <Setter Property="HorizontalAlignment" Value="Center" />
        <Setter Property="VerticalAlignment" Value="Stretch" />
        <Setter Property="Template">
            <Setter.Value>
                <ControlTemplate TargetType="{x:Type Button}">
                    <Border
                        x:Name="Chrome"
                        Background="{TemplateBinding Background}"
                        CornerRadius="0,3,3,0"
                        SnapsToDevicePixels="True">
                        <!--
                            Symbol "Calendar24" 是 FluentSystemIcons 在所有版本中都
                            存在的基本月曆圖示。CalendarLtr24 在某些 FluentIcons.Wpf
                            版本上會解析失敗，AppIcon 會 fallback 成 Info（驚嘆號），
                            產生「ⓘ」誤導使用者。
                        -->
                        <ds:AppIcon
                            HorizontalAlignment="Center"
                            VerticalAlignment="Center"
                            FontSize="14"
                            Foreground="{TemplateBinding Foreground}"
                            Symbol="Calendar24" />
                    </Border>
                    <ControlTemplate.Triggers>
                        <Trigger Property="IsMouseOver" Value="True">
                            <Setter TargetName="Chrome" Property="Background" Value="{DynamicResource AppHover}" />
                            <Setter Property="Foreground" Value="{DynamicResource AppTextPrimary}" />
                        </Trigger>
                        <Trigger Property="IsEnabled" Value="False">
                            <Setter Property="Opacity" Value="0.45" />
                            <Setter Property="Cursor" Value="Arrow" />
                        </Trigger>
                    </ControlTemplate.Triggers>
                </ControlTemplate>
            </Setter.Value>
        </Setter>
    </Style>

    <!--
        AppDatePicker — full template overrides the DatePicker root so the
        drop-down button uses our Fluent calendar glyph (CalendarLtr) instead
        of the WPF default "15"-on-frame XAML path.
        Required PARTs (per WPF DatePicker contract):
          PART_Root      Grid container
          PART_TextBox   DatePickerTextBox for display + edit
          PART_Button    Drop-down trigger
          PART_Popup     Hosts the auto-generated Calendar control
          PART_DisabledVisual  Mask shown when IsEnabled=False
    -->
    <Style x:Key="AppDatePicker" TargetType="{x:Type DatePicker}">
        <Setter Property="MinHeight" Value="{StaticResource Control.Height.Md}" />
        <Setter Property="FontFamily" Value="{StaticResource Font.Family.Base}" />
        <Setter Property="FontSize" Value="{StaticResource Font.Size.Sm}" />
        <Setter Property="Foreground" Value="{DynamicResource Brush.Text.Primary}" />
        <Setter Property="Background" Value="{DynamicResource Brush.Surface}" />
        <Setter Property="BorderBrush" Value="{DynamicResource Brush.Border}" />
        <Setter Property="BorderThickness" Value="{StaticResource Border.Input}" />
        <Setter Property="FocusVisualStyle" Value="{StaticResource FocusVisual}" />
        <Setter Property="CalendarStyle" Value="{StaticResource AppCalendar}" />
        <Setter Property="SelectedDateFormat" Value="Short" />
        <Setter Property="behaviors:DatePickerDateOnlyBehavior.IsEnabled" Value="True" />
        <Setter Property="behaviors:DatePickerDateOnlyBehavior.Constraint" Value="None" />
        <Setter Property="Template">
            <Setter.Value>
                <ControlTemplate TargetType="{x:Type DatePicker}">
                    <Border
                        x:Name="Chrome"
                        Background="{TemplateBinding Background}"
                        BorderBrush="{TemplateBinding BorderBrush}"
                        BorderThickness="{TemplateBinding BorderThickness}"
                        CornerRadius="{StaticResource Radius.Sm}"
                        SnapsToDevicePixels="True">
                        <Grid x:Name="PART_Root">
                            <Grid.ColumnDefinitions>
                                <ColumnDefinition Width="*" />
                                <ColumnDefinition Width="Auto" />
                            </Grid.ColumnDefinitions>

                            <!--  Inner text box. Border 0 because chrome is on the outer Border.  -->
                            <primitives:DatePickerTextBox
                                x:Name="PART_TextBox"
                                Grid.Column="0"
                                BorderThickness="0"
                                Foreground="{TemplateBinding Foreground}"
                                Focusable="{TemplateBinding Focusable}" />

                            <!--  Drop-down button: Fluent CalendarLtr icon.  -->
                            <Button
                                x:Name="PART_Button"
                                Grid.Column="1"
                                Focusable="False"
                                Foreground="{DynamicResource AppTextSecondary}"
                                Style="{StaticResource DatePickerDropDownButton}" />

                            <!--  Popup: hosts the Calendar created by DatePicker code.  -->
                            <Popup
                                x:Name="PART_Popup"
                                AllowsTransparency="True"
                                Placement="Bottom"
                                PlacementTarget="{Binding ElementName=PART_TextBox}"
                                StaysOpen="False" />

                            <!--  Disabled-state overlay — used when IsEnabled=False.  -->
                            <ContentControl
                                x:Name="PART_DisabledVisual"
                                Grid.ColumnSpan="2"
                                Background="Transparent"
                                Focusable="False"
                                IsHitTestVisible="False"
                                IsTabStop="False"
                                Visibility="Collapsed" />
                        </Grid>
                    </Border>
                    <ControlTemplate.Triggers>
                        <Trigger Property="IsMouseOver" Value="True">
                            <Setter TargetName="Chrome" Property="BorderBrush" Value="{DynamicResource AppTextSecondary}" />
                        </Trigger>
                        <Trigger Property="IsKeyboardFocusWithin" Value="True">
                            <Setter TargetName="Chrome" Property="BorderBrush" Value="{DynamicResource AppAccent}" />
                        </Trigger>
                        <Trigger Property="IsEnabled" Value="False">
                            <Setter TargetName="PART_DisabledVisual" Property="Visibility" Value="Visible" />
                            <Setter Property="Opacity" Value="0.45" />
                        </Trigger>
                    </ControlTemplate.Triggers>
                </ControlTemplate>
            </Setter.Value>
        </Setter>
    </Style>

    <Style BasedOn="{StaticResource AppDatePicker}" TargetType="{x:Type DatePicker}" />

</ResourceDictionary>
