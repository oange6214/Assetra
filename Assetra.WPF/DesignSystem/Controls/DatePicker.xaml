<ResourceDictionary
    xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
    xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
    xmlns:primitives="clr-namespace:System.Windows.Controls.Primitives;assembly=PresentationFramework"
    xmlns:behaviors="clr-namespace:Assetra.WPF.Infrastructure.Behaviors"
    xmlns:ds="clr-namespace:Assetra.WPF.DesignSystem.Controls">

    <!--
        ════════════════════════════════════════════════════════════
        DESIGN NOTE — Calendar / CalendarItem theming policy
        ════════════════════════════════════════════════════════════
        We attempted full Fluent re-templating of CalendarItem (the popup
        chrome + month/year/decade view container) but multiple iterations
        triggered hard-to-debug timing issues with WPF's internal
        OnApplyTemplate / GetTemplateChild / UpdateAppearance pipeline:

          * Custom wrapper Grid → _monthView ref came back null, view
            switching no-op'd.
          * Both PARTs Visibility=Collapsed → UpdateMonths() early-returned
            (Owner == null in some timing paths) and body stayed blank.
          * Both PARTs Visibility=Visible → click header swapped header
            text but old grid remained, views stacked.

        WPF Calendar has a tight coupling between CalendarItem template
        layout, view-population timing, and the Visibility toggle in
        UpdateAppearance. Maintaining a custom CalendarItem template
        without breaking that pipeline is high-risk for low visual gain.

        Compromise (this file): rely on the WPF default CalendarItem
        template (so view switching just works), and theme appearance
        only via:
          * CalendarDayButton template (full custom — single day cell
            shape + accent colors).
          * CalendarButton template (full custom — month/year cell shape).
          * Calendar background / border (themed via Calendar's own
            templated properties, no need to override CalendarItemStyle).

        Side effect: the popup chrome (◀ ▶ chevron arrows, "May 2026"
        header button) shows OS-default Aero2/Win11 styling rather than
        full Fluent. This is acceptable — those are minor surface details
        compared to the functional view-switching breakage.
    -->

    <Style x:Key="AppDatePickerTextBox" TargetType="{x:Type primitives:DatePickerTextBox}">
        <Setter Property="MinHeight" Value="{StaticResource Control.Height.Md}" />
        <Setter Property="Padding" Value="10,6" />
        <Setter Property="FontFamily" Value="{StaticResource Font.Family.Base}" />
        <Setter Property="FontSize" Value="{StaticResource Font.Size.Sm}" />
        <Setter Property="Foreground" Value="{DynamicResource Brush.Text.Primary}" />
        <Setter Property="Background" Value="{DynamicResource Brush.Surface}" />
        <Setter Property="BorderBrush" Value="{DynamicResource Brush.Border}" />
        <Setter Property="BorderThickness" Value="{StaticResource Border.Input}" />
        <Setter Property="CaretBrush" Value="{DynamicResource Brush.Text.Primary}" />
        <Setter Property="VerticalContentAlignment" Value="Center" />
        <Setter Property="Focusable" Value="True" />
        <Setter Property="HorizontalContentAlignment" Value="Left" />
        <Setter Property="Template">
            <Setter.Value>
                <ControlTemplate TargetType="{x:Type primitives:DatePickerTextBox}">
                    <Border
                        x:Name="Chrome"
                        Background="{TemplateBinding Background}"
                        BorderBrush="{TemplateBinding BorderBrush}"
                        BorderThickness="{TemplateBinding BorderThickness}"
                        CornerRadius="{StaticResource Radius.Sm}"
                        SnapsToDevicePixels="True">
                        <ScrollViewer
                            x:Name="PART_ContentHost"
                            Margin="{TemplateBinding Padding}"
                            Focusable="False"
                            HorizontalScrollBarVisibility="Hidden"
                            VerticalScrollBarVisibility="Hidden" />
                    </Border>
                    <ControlTemplate.Triggers>
                        <Trigger Property="IsKeyboardFocused" Value="True">
                            <Setter TargetName="Chrome" Property="BorderBrush" Value="{DynamicResource Brush.FocusRing}" />
                        </Trigger>
                        <Trigger Property="Validation.HasError" Value="True">
                            <Setter TargetName="Chrome" Property="BorderBrush" Value="{DynamicResource Brush.Danger}" />
                        </Trigger>
                        <Trigger Property="IsEnabled" Value="False">
                            <Setter Property="Opacity" Value="0.45" />
                        </Trigger>
                    </ControlTemplate.Triggers>
                </ControlTemplate>
            </Setter.Value>
        </Setter>
    </Style>

    <Style BasedOn="{StaticResource AppDatePickerTextBox}" TargetType="{x:Type primitives:DatePickerTextBox}" />

    <!--
        AppCalendarButton — month/year/decade cell button.
        Uses CalendarButton's actual properties: IsInactive (out-of-range
        cells), HasSelectedDays (the cell containing the selected date),
        IsFocused. There's NO IsSelected on CalendarButton (that's
        CalendarDayButton). Removing the IsSelected trigger from earlier
        broken iterations.
    -->
    <Style x:Key="AppCalendarButton" TargetType="{x:Type primitives:CalendarButton}">
        <Setter Property="Background" Value="Transparent" />
        <Setter Property="BorderBrush" Value="Transparent" />
        <Setter Property="BorderThickness" Value="0" />
        <Setter Property="Foreground" Value="{DynamicResource AppTextPrimary}" />
        <Setter Property="FontFamily" Value="{StaticResource Font.Family.Base}" />
        <Setter Property="FontSize" Value="{StaticResource Font.Size.Sm}" />
        <Setter Property="FontWeight" Value="SemiBold" />
        <Setter Property="MinWidth" Value="40" />
        <Setter Property="MinHeight" Value="32" />
        <Setter Property="Padding" Value="6,4" />
        <Setter Property="HorizontalContentAlignment" Value="Center" />
        <Setter Property="VerticalContentAlignment" Value="Center" />
        <Setter Property="Cursor" Value="Hand" />
        <Setter Property="FocusVisualStyle" Value="{x:Null}" />
        <Setter Property="Template">
            <Setter.Value>
                <ControlTemplate TargetType="{x:Type primitives:CalendarButton}">
                    <Border
                        x:Name="Chrome"
                        Margin="2"
                        Background="{TemplateBinding Background}"
                        BorderBrush="{TemplateBinding BorderBrush}"
                        BorderThickness="{TemplateBinding BorderThickness}"
                        CornerRadius="{StaticResource Radius.Sm}"
                        SnapsToDevicePixels="True">
                        <ContentPresenter
                            Margin="{TemplateBinding Padding}"
                            HorizontalAlignment="{TemplateBinding HorizontalContentAlignment}"
                            VerticalAlignment="{TemplateBinding VerticalContentAlignment}">
                            <!--  Same TextBlock-style override as CalendarDayButton — see comment there.  -->
                            <ContentPresenter.Resources>
                                <Style TargetType="TextBlock">
                                    <Setter Property="Foreground" Value="{Binding Foreground, RelativeSource={RelativeSource AncestorType={x:Type primitives:CalendarButton}}}" />
                                </Style>
                            </ContentPresenter.Resources>
                        </ContentPresenter>
                    </Border>
                    <ControlTemplate.Triggers>
                        <Trigger Property="IsMouseOver" Value="True">
                            <Setter TargetName="Chrome" Property="Background" Value="{DynamicResource AppHover}" />
                        </Trigger>
                        <Trigger Property="HasSelectedDays" Value="True">
                            <Setter TargetName="Chrome" Property="Background" Value="{DynamicResource AppAccentSubtle}" />
                            <Setter TargetName="Chrome" Property="BorderBrush" Value="{DynamicResource AppAccent}" />
                            <Setter TargetName="Chrome" Property="BorderThickness" Value="1" />
                            <Setter Property="Foreground" Value="{DynamicResource AppAccent}" />
                        </Trigger>
                        <Trigger Property="IsInactive" Value="True">
                            <Setter Property="Opacity" Value="0.45" />
                        </Trigger>
                        <Trigger Property="IsEnabled" Value="False">
                            <Setter Property="Opacity" Value="0.45" />
                            <Setter Property="Cursor" Value="Arrow" />
                        </Trigger>
                    </ControlTemplate.Triggers>
                </ControlTemplate>
            </Setter.Value>
        </Setter>
    </Style>

    <Style BasedOn="{StaticResource AppCalendarButton}" TargetType="{x:Type primitives:CalendarButton}" />

    <!--
        AppCalendarDayButton — single day cell.
        Full template: 34×34 circular chrome with hover / today / selected
        states. Selected → AppAccent fill + white text. Today → AppAccent
        ring + AppAccent text. IsBlackedOut / IsInactive fade.
    -->
    <Style x:Key="AppCalendarDayButton" TargetType="{x:Type primitives:CalendarDayButton}">
        <Setter Property="MinWidth" Value="34" />
        <Setter Property="MinHeight" Value="34" />
        <Setter Property="Margin" Value="1" />
        <Setter Property="Padding" Value="0" />
        <Setter Property="Background" Value="Transparent" />
        <Setter Property="BorderBrush" Value="Transparent" />
        <Setter Property="BorderThickness" Value="1" />
        <Setter Property="Foreground" Value="{DynamicResource AppTextPrimary}" />
        <Setter Property="FontFamily" Value="{StaticResource Font.Family.Base}" />
        <Setter Property="FontSize" Value="{StaticResource Font.Size.Sm}" />
        <Setter Property="FontWeight" Value="{StaticResource Font.Weight.Medium}" />
        <Setter Property="HorizontalContentAlignment" Value="Center" />
        <Setter Property="VerticalContentAlignment" Value="Center" />
        <Setter Property="FocusVisualStyle" Value="{x:Null}" />
        <Setter Property="Template">
            <Setter.Value>
                <ControlTemplate TargetType="{x:Type primitives:CalendarDayButton}">
                    <Border
                        x:Name="Chrome"
                        Background="{TemplateBinding Background}"
                        BorderBrush="{TemplateBinding BorderBrush}"
                        BorderThickness="{TemplateBinding BorderThickness}"
                        CornerRadius="{StaticResource Radius.Full}"
                        SnapsToDevicePixels="True">
                        <ContentPresenter
                            HorizontalAlignment="{TemplateBinding HorizontalContentAlignment}"
                            VerticalAlignment="{TemplateBinding VerticalContentAlignment}"
                            RecognizesAccessKey="True">
                            <!--
                                Local TextBlock style overrides the global
                                Inputs.xaml implicit TextBlock style. Without
                                this, the day-number TextBlock created by
                                ContentPresenter inherits Foreground=AppTextPrimary
                                from the global style — which has higher
                                precedence than the TemplateBinding inheritance,
                                so the IsToday / IsSelected trigger Foreground
                                changes wouldn't reach the rendered text.
                            -->
                            <ContentPresenter.Resources>
                                <Style TargetType="TextBlock">
                                    <Setter Property="Foreground" Value="{Binding Foreground, RelativeSource={RelativeSource AncestorType={x:Type primitives:CalendarDayButton}}}" />
                                </Style>
                            </ContentPresenter.Resources>
                        </ContentPresenter>
                    </Border>
                    <ControlTemplate.Triggers>
                        <Trigger Property="IsMouseOver" Value="True">
                            <Setter TargetName="Chrome" Property="Background" Value="{DynamicResource AppHover}" />
                        </Trigger>
                        <Trigger Property="IsToday" Value="True">
                            <Setter TargetName="Chrome" Property="BorderBrush" Value="{DynamicResource AppAccent}" />
                            <Setter Property="Foreground" Value="{DynamicResource AppAccent}" />
                        </Trigger>
                        <Trigger Property="IsSelected" Value="True">
                            <Setter TargetName="Chrome" Property="Background" Value="{DynamicResource AppAccent}" />
                            <Setter TargetName="Chrome" Property="BorderBrush" Value="{DynamicResource AppAccent}" />
                            <Setter Property="Foreground" Value="{DynamicResource AppTextOnAccent}" />
                        </Trigger>
                        <MultiTrigger>
                            <MultiTrigger.Conditions>
                                <Condition Property="IsSelected" Value="True" />
                                <Condition Property="IsToday" Value="True" />
                            </MultiTrigger.Conditions>
                            <Setter Property="Foreground" Value="{DynamicResource AppTextOnAccent}" />
                        </MultiTrigger>
                        <Trigger Property="IsInactive" Value="True">
                            <Setter Property="Opacity" Value="0.45" />
                        </Trigger>
                        <Trigger Property="IsBlackedOut" Value="True">
                            <Setter Property="Opacity" Value="0.28" />
                            <Setter Property="Foreground" Value="{DynamicResource AppTextMuted}" />
                        </Trigger>
                    </ControlTemplate.Triggers>
                </ControlTemplate>
            </Setter.Value>
        </Setter>
    </Style>

    <Style BasedOn="{StaticResource AppCalendarDayButton}" TargetType="{x:Type primitives:CalendarDayButton}" />

    <!--
        ════════════════════════════════════════════════════════════
        Calendar header buttons — circular chevron + flat header
        ════════════════════════════════════════════════════════════
        Three button styles that fit the WPF default CalendarItem
        template's PART_PreviousButton / PART_NextButton / PART_HeaderButton
        slots without changing layout assumptions.
    -->
    <Style x:Key="CalendarPreviousButton" TargetType="{x:Type Button}">
        <Setter Property="Width" Value="28" />
        <Setter Property="Height" Value="28" />
        <Setter Property="Margin" Value="4" />
        <Setter Property="Background" Value="Transparent" />
        <Setter Property="BorderThickness" Value="0" />
        <Setter Property="Foreground" Value="{DynamicResource AppTextSecondary}" />
        <Setter Property="Cursor" Value="Hand" />
        <Setter Property="FocusVisualStyle" Value="{x:Null}" />
        <Setter Property="Template">
            <Setter.Value>
                <ControlTemplate TargetType="{x:Type Button}">
                    <Border
                        x:Name="Chrome"
                        Background="{TemplateBinding Background}"
                        CornerRadius="{StaticResource Radius.Full}"
                        SnapsToDevicePixels="True">
                        <Path
                            Width="6"
                            Height="10"
                            HorizontalAlignment="Center"
                            VerticalAlignment="Center"
                            Data="M 6 0 L 0 5 L 6 10"
                            Stroke="{TemplateBinding Foreground}"
                            StrokeEndLineCap="Round"
                            StrokeStartLineCap="Round"
                            StrokeThickness="1.6" />
                    </Border>
                    <ControlTemplate.Triggers>
                        <Trigger Property="IsMouseOver" Value="True">
                            <Setter TargetName="Chrome" Property="Background" Value="{DynamicResource AppHover}" />
                            <Setter Property="Foreground" Value="{DynamicResource AppTextPrimary}" />
                        </Trigger>
                        <Trigger Property="IsEnabled" Value="False">
                            <Setter Property="Opacity" Value="0.45" />
                            <Setter Property="Cursor" Value="Arrow" />
                        </Trigger>
                    </ControlTemplate.Triggers>
                </ControlTemplate>
            </Setter.Value>
        </Setter>
    </Style>

    <Style x:Key="CalendarNextButton" BasedOn="{StaticResource CalendarPreviousButton}" TargetType="{x:Type Button}">
        <Setter Property="Template">
            <Setter.Value>
                <ControlTemplate TargetType="{x:Type Button}">
                    <Border
                        x:Name="Chrome"
                        Background="{TemplateBinding Background}"
                        CornerRadius="{StaticResource Radius.Full}"
                        SnapsToDevicePixels="True">
                        <Path
                            Width="6"
                            Height="10"
                            HorizontalAlignment="Center"
                            VerticalAlignment="Center"
                            Data="M 0 0 L 6 5 L 0 10"
                            Stroke="{TemplateBinding Foreground}"
                            StrokeEndLineCap="Round"
                            StrokeStartLineCap="Round"
                            StrokeThickness="1.6" />
                    </Border>
                    <ControlTemplate.Triggers>
                        <Trigger Property="IsMouseOver" Value="True">
                            <Setter TargetName="Chrome" Property="Background" Value="{DynamicResource AppHover}" />
                            <Setter Property="Foreground" Value="{DynamicResource AppTextPrimary}" />
                        </Trigger>
                        <Trigger Property="IsEnabled" Value="False">
                            <Setter Property="Opacity" Value="0.45" />
                            <Setter Property="Cursor" Value="Arrow" />
                        </Trigger>
                    </ControlTemplate.Triggers>
                </ControlTemplate>
            </Setter.Value>
        </Setter>
    </Style>

    <Style x:Key="CalendarHeaderButton" TargetType="{x:Type Button}">
        <Setter Property="MinHeight" Value="28" />
        <Setter Property="Padding" Value="10,4" />
        <Setter Property="Background" Value="Transparent" />
        <Setter Property="BorderThickness" Value="0" />
        <Setter Property="Foreground" Value="{DynamicResource AppTextPrimary}" />
        <Setter Property="FontFamily" Value="{StaticResource Font.Family.Base}" />
        <Setter Property="FontSize" Value="{StaticResource Font.Size.Sm}" />
        <Setter Property="FontWeight" Value="SemiBold" />
        <Setter Property="Cursor" Value="Hand" />
        <Setter Property="FocusVisualStyle" Value="{x:Null}" />
        <Setter Property="Template">
            <Setter.Value>
                <ControlTemplate TargetType="{x:Type Button}">
                    <Border
                        x:Name="Chrome"
                        Padding="{TemplateBinding Padding}"
                        Background="{TemplateBinding Background}"
                        CornerRadius="{StaticResource Radius.Sm}"
                        SnapsToDevicePixels="True">
                        <ContentPresenter
                            HorizontalAlignment="Center"
                            VerticalAlignment="Center"
                            TextElement.FontSize="{TemplateBinding FontSize}"
                            TextElement.FontWeight="{TemplateBinding FontWeight}"
                            TextElement.Foreground="{TemplateBinding Foreground}" />
                    </Border>
                    <ControlTemplate.Triggers>
                        <Trigger Property="IsMouseOver" Value="True">
                            <Setter TargetName="Chrome" Property="Background" Value="{DynamicResource AppHover}" />
                        </Trigger>
                    </ControlTemplate.Triggers>
                </ControlTemplate>
            </Setter.Value>
        </Setter>
    </Style>

    <!--
        ════════════════════════════════════════════════════════════
        AppCalendarItem — Fluent template
        ════════════════════════════════════════════════════════════
        Structure mirrors .NET reference source (PresentationFramework
        Aero2.NormalColor.xaml CalendarItem default template) EXACTLY:

          * Outer x:Name="PART_Root" Grid (3 columns × 2 rows)
          * Header row (Row 0):
              - PART_PreviousButton at Col 0, left-aligned
              - PART_HeaderButton spans all 3 columns, center-aligned
              - PART_NextButton at Col 2, right-aligned
          * Body row (Row 1):
              - PART_MonthView and PART_YearView both at Row 1, ColumnSpan 3
              - Initial Visibility="Visible" / "Hidden" (Calendar's
                UpdateAppearance toggles via SetValue at runtime)

        Only colors / borders / fonts differ from default — no layout
        changes — so OnApplyTemplate's GetTemplateChild lookups and
        UpdateAppearance's Visibility SetValue calls all hit the same
        elements they would in the default template.
    -->
    <DataTemplate x:Key="{x:Static primitives:CalendarItem.DayTitleTemplateResourceKey}">
        <TextBlock
            Margin="0,2,0,4"
            HorizontalAlignment="Center"
            VerticalAlignment="Center"
            FontFamily="{StaticResource Font.Family.Base}"
            FontSize="{StaticResource Font.Size.Xs}"
            FontWeight="SemiBold"
            Foreground="{DynamicResource AppTextMuted}"
            Text="{Binding}" />
    </DataTemplate>

    <Style x:Key="AppCalendarItem" TargetType="{x:Type primitives:CalendarItem}">
        <Setter Property="Margin" Value="0" />
        <Setter Property="Background" Value="{DynamicResource AppSurface}" />
        <Setter Property="Foreground" Value="{DynamicResource AppTextPrimary}" />
        <Setter Property="BorderBrush" Value="{DynamicResource AppBorder}" />
        <Setter Property="BorderThickness" Value="1" />
        <Setter Property="Template">
            <Setter.Value>
                <ControlTemplate TargetType="{x:Type primitives:CalendarItem}">
                    <Border
                        Padding="6,6,6,8"
                        Background="{TemplateBinding Background}"
                        BorderBrush="{TemplateBinding BorderBrush}"
                        BorderThickness="{TemplateBinding BorderThickness}"
                        CornerRadius="{StaticResource Radius.Md}"
                        SnapsToDevicePixels="True">
                        <Grid x:Name="PART_Root" HorizontalAlignment="Center">
                            <Grid.ColumnDefinitions>
                                <ColumnDefinition Width="Auto" />
                                <ColumnDefinition Width="*" />
                                <ColumnDefinition Width="Auto" />
                            </Grid.ColumnDefinitions>
                            <Grid.RowDefinitions>
                                <RowDefinition Height="Auto" />
                                <RowDefinition Height="*" />
                            </Grid.RowDefinitions>

                            <Button
                                x:Name="PART_PreviousButton"
                                Grid.Row="0"
                                Grid.Column="0"
                                Focusable="False"
                                HorizontalAlignment="Left"
                                Style="{StaticResource CalendarPreviousButton}" />

                            <Button
                                x:Name="PART_HeaderButton"
                                Grid.Row="0"
                                Grid.Column="0"
                                Grid.ColumnSpan="3"
                                HorizontalAlignment="Center"
                                VerticalAlignment="Center"
                                FocusVisualStyle="{x:Null}"
                                Focusable="False"
                                Style="{StaticResource CalendarHeaderButton}" />

                            <Button
                                x:Name="PART_NextButton"
                                Grid.Row="0"
                                Grid.Column="2"
                                Focusable="False"
                                HorizontalAlignment="Right"
                                Style="{StaticResource CalendarNextButton}" />

                            <Grid
                                x:Name="PART_MonthView"
                                Grid.Row="1"
                                Grid.ColumnSpan="3"
                                Margin="6,2,6,4"
                                HorizontalAlignment="Center"
                                Visibility="Visible">
                                <Grid.ColumnDefinitions>
                                    <ColumnDefinition Width="*" />
                                    <ColumnDefinition Width="*" />
                                    <ColumnDefinition Width="*" />
                                    <ColumnDefinition Width="*" />
                                    <ColumnDefinition Width="*" />
                                    <ColumnDefinition Width="*" />
                                    <ColumnDefinition Width="*" />
                                </Grid.ColumnDefinitions>
                                <Grid.RowDefinitions>
                                    <RowDefinition Height="Auto" />
                                    <RowDefinition Height="*" />
                                    <RowDefinition Height="*" />
                                    <RowDefinition Height="*" />
                                    <RowDefinition Height="*" />
                                    <RowDefinition Height="*" />
                                    <RowDefinition Height="*" />
                                </Grid.RowDefinitions>
                            </Grid>
                            <Grid
                                x:Name="PART_YearView"
                                Grid.Row="1"
                                Grid.ColumnSpan="3"
                                Margin="6,2,6,4"
                                HorizontalAlignment="Center"
                                Visibility="Hidden">
                                <Grid.ColumnDefinitions>
                                    <ColumnDefinition Width="*" />
                                    <ColumnDefinition Width="*" />
                                    <ColumnDefinition Width="*" />
                                    <ColumnDefinition Width="*" />
                                </Grid.ColumnDefinitions>
                                <Grid.RowDefinitions>
                                    <RowDefinition Height="*" />
                                    <RowDefinition Height="*" />
                                    <RowDefinition Height="*" />
                                </Grid.RowDefinitions>
                            </Grid>
                        </Grid>
                    </Border>
                </ControlTemplate>
            </Setter.Value>
        </Setter>
    </Style>

    <Style BasedOn="{StaticResource AppCalendarItem}" TargetType="{x:Type primitives:CalendarItem}" />

    <Style x:Key="AppCalendar" TargetType="{x:Type Calendar}">
        <Setter Property="Background" Value="{DynamicResource AppSurface}" />
        <Setter Property="Foreground" Value="{DynamicResource AppTextPrimary}" />
        <Setter Property="BorderBrush" Value="{DynamicResource AppBorder}" />
        <Setter Property="BorderThickness" Value="0" />
        <Setter Property="FontFamily" Value="{StaticResource Font.Family.Base}" />
        <Setter Property="FontSize" Value="{StaticResource Font.Size.Sm}" />
        <Setter Property="CalendarDayButtonStyle" Value="{StaticResource AppCalendarDayButton}" />
        <Setter Property="CalendarButtonStyle" Value="{StaticResource AppCalendarButton}" />
        <Setter Property="CalendarItemStyle" Value="{StaticResource AppCalendarItem}" />
    </Style>

    <Style BasedOn="{StaticResource AppCalendar}" TargetType="{x:Type Calendar}" />

    <!--
        Drop-down trigger button — Fluent CalendarLtr / Calendar glyph.
    -->
    <Style x:Key="DatePickerDropDownButton" TargetType="{x:Type Button}">
        <Setter Property="Width" Value="32" />
        <Setter Property="Height" Value="{StaticResource Control.Height.Md}" />
        <Setter Property="MinHeight" Value="{StaticResource Control.Height.Md}" />
        <Setter Property="Padding" Value="0" />
        <Setter Property="Background" Value="Transparent" />
        <Setter Property="BorderThickness" Value="0" />
        <Setter Property="Foreground" Value="{DynamicResource AppTextSecondary}" />
        <Setter Property="Cursor" Value="Hand" />
        <Setter Property="FocusVisualStyle" Value="{x:Null}" />
        <Setter Property="HorizontalAlignment" Value="Center" />
        <Setter Property="VerticalAlignment" Value="Stretch" />
        <Setter Property="Template">
            <Setter.Value>
                <ControlTemplate TargetType="{x:Type Button}">
                    <Border
                        x:Name="Chrome"
                        Background="{TemplateBinding Background}"
                        CornerRadius="0,3,3,0"
                        SnapsToDevicePixels="True">
                        <ds:AppIcon
                            HorizontalAlignment="Center"
                            VerticalAlignment="Center"
                            FontSize="14"
                            Foreground="{TemplateBinding Foreground}"
                            Symbol="Calendar24" />
                    </Border>
                    <ControlTemplate.Triggers>
                        <Trigger Property="IsMouseOver" Value="True">
                            <Setter TargetName="Chrome" Property="Background" Value="{DynamicResource AppHover}" />
                            <Setter Property="Foreground" Value="{DynamicResource AppTextPrimary}" />
                        </Trigger>
                        <Trigger Property="IsEnabled" Value="False">
                            <Setter Property="Opacity" Value="0.45" />
                            <Setter Property="Cursor" Value="Arrow" />
                        </Trigger>
                    </ControlTemplate.Triggers>
                </ControlTemplate>
            </Setter.Value>
        </Setter>
    </Style>

    <!--
        AppDatePicker — full template overrides only the OUTER DatePicker
        (textbox + drop-down button + popup placeholder). The popup hosts
        a Calendar that renders via WPF's default template, themed by
        AppCalendar's color/sub-style setters.
    -->
    <Style x:Key="AppDatePicker" TargetType="{x:Type DatePicker}">
        <Setter Property="MinHeight" Value="{StaticResource Control.Height.Md}" />
        <Setter Property="FontFamily" Value="{StaticResource Font.Family.Base}" />
        <Setter Property="FontSize" Value="{StaticResource Font.Size.Sm}" />
        <Setter Property="Foreground" Value="{DynamicResource Brush.Text.Primary}" />
        <Setter Property="Background" Value="{DynamicResource Brush.Surface}" />
        <Setter Property="BorderBrush" Value="{DynamicResource Brush.Border}" />
        <Setter Property="BorderThickness" Value="{StaticResource Border.Input}" />
        <Setter Property="FocusVisualStyle" Value="{StaticResource FocusVisual}" />
        <Setter Property="CalendarStyle" Value="{StaticResource AppCalendar}" />
        <Setter Property="SelectedDateFormat" Value="Short" />
        <Setter Property="behaviors:DatePickerDateOnlyBehavior.IsEnabled" Value="True" />
        <Setter Property="behaviors:DatePickerDateOnlyBehavior.Constraint" Value="None" />
        <Setter Property="Template">
            <Setter.Value>
                <ControlTemplate TargetType="{x:Type DatePicker}">
                    <Border
                        x:Name="Chrome"
                        Background="{TemplateBinding Background}"
                        BorderBrush="{TemplateBinding BorderBrush}"
                        BorderThickness="{TemplateBinding BorderThickness}"
                        CornerRadius="{StaticResource Radius.Sm}"
                        SnapsToDevicePixels="True">
                        <Grid x:Name="PART_Root">
                            <Grid.ColumnDefinitions>
                                <ColumnDefinition Width="*" />
                                <ColumnDefinition Width="Auto" />
                            </Grid.ColumnDefinitions>

                            <primitives:DatePickerTextBox
                                x:Name="PART_TextBox"
                                Grid.Column="0"
                                BorderThickness="0"
                                Foreground="{TemplateBinding Foreground}"
                                Focusable="{TemplateBinding Focusable}" />

                            <Button
                                x:Name="PART_Button"
                                Grid.Column="1"
                                Focusable="False"
                                Foreground="{DynamicResource AppTextSecondary}"
                                Style="{StaticResource DatePickerDropDownButton}" />

                            <Popup
                                x:Name="PART_Popup"
                                AllowsTransparency="True"
                                Placement="Bottom"
                                PlacementTarget="{Binding ElementName=PART_TextBox}"
                                StaysOpen="False" />

                            <ContentControl
                                x:Name="PART_DisabledVisual"
                                Grid.ColumnSpan="2"
                                Background="Transparent"
                                Focusable="False"
                                IsHitTestVisible="False"
                                IsTabStop="False"
                                Visibility="Collapsed" />
                        </Grid>
                    </Border>
                    <ControlTemplate.Triggers>
                        <Trigger Property="IsMouseOver" Value="True">
                            <Setter TargetName="Chrome" Property="BorderBrush" Value="{DynamicResource AppTextSecondary}" />
                        </Trigger>
                        <Trigger Property="IsKeyboardFocusWithin" Value="True">
                            <Setter TargetName="Chrome" Property="BorderBrush" Value="{DynamicResource AppAccent}" />
                        </Trigger>
                        <Trigger Property="IsEnabled" Value="False">
                            <Setter TargetName="PART_DisabledVisual" Property="Visibility" Value="Visible" />
                            <Setter Property="Opacity" Value="0.45" />
                        </Trigger>
                    </ControlTemplate.Triggers>
                </ControlTemplate>
            </Setter.Value>
        </Setter>
    </Style>

