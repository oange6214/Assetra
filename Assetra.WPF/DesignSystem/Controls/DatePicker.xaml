<ResourceDictionary
    xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
    xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
    xmlns:primitives="clr-namespace:System.Windows.Controls.Primitives;assembly=PresentationFramework"
    xmlns:behaviors="clr-namespace:Assetra.WPF.Infrastructure.Behaviors"
    xmlns:ds="clr-namespace:Assetra.WPF.DesignSystem.Controls">

    <!--
        ════════════════════════════════════════════════════════════
        DESIGN NOTE — Calendar / CalendarItem theming policy
        ════════════════════════════════════════════════════════════
        We attempted full Fluent re-templating of CalendarItem (the popup
        chrome + month/year/decade view container) but multiple iterations
        triggered hard-to-debug timing issues with WPF's internal
        OnApplyTemplate / GetTemplateChild / UpdateAppearance pipeline:

          * Custom wrapper Grid → _monthView ref came back null, view
            switching no-op'd.
          * Both PARTs Visibility=Collapsed → UpdateMonths() early-returned
            (Owner == null in some timing paths) and body stayed blank.
          * Both PARTs Visibility=Visible → click header swapped header
            text but old grid remained, views stacked.

        WPF Calendar has a tight coupling between CalendarItem template
        layout, view-population timing, and the Visibility toggle in
        UpdateAppearance. Maintaining a custom CalendarItem template
        without breaking that pipeline is high-risk for low visual gain.

        Compromise (this file): rely on the WPF default CalendarItem
        template (so view switching just works), and theme appearance
        only via:
          * CalendarDayButton template (full custom — single day cell
            shape + accent colors).
          * CalendarButton template (full custom — month/year cell shape).
          * Calendar background / border (themed via Calendar's own
            templated properties, no need to override CalendarItemStyle).

        Side effect: the popup chrome (◀ ▶ chevron arrows, "May 2026"
        header button) shows OS-default Aero2/Win11 styling rather than
        full Fluent. This is acceptable — those are minor surface details
        compared to the functional view-switching breakage.
    -->

    <Style x:Key="AppDatePickerTextBox" TargetType="{x:Type primitives:DatePickerTextBox}">
        <Setter Property="MinHeight" Value="{StaticResource Control.Height.Md}" />
        <Setter Property="Padding" Value="10,6" />
        <Setter Property="FontFamily" Value="{StaticResource Font.Family.Base}" />
        <Setter Property="FontSize" Value="{StaticResource Font.Size.Sm}" />
        <Setter Property="Foreground" Value="{DynamicResource AppTextPrimary}" />
        <Setter Property="Background" Value="{DynamicResource AppSurface}" />
        <Setter Property="BorderBrush" Value="{DynamicResource AppBorder}" />
        <Setter Property="BorderThickness" Value="{StaticResource Border.Input}" />
        <Setter Property="CaretBrush" Value="{DynamicResource AppTextPrimary}" />
        <Setter Property="VerticalContentAlignment" Value="Center" />
        <Setter Property="Focusable" Value="True" />
        <Setter Property="HorizontalContentAlignment" Value="Left" />
        <Setter Property="Template">
            <Setter.Value>
                <ControlTemplate TargetType="{x:Type primitives:DatePickerTextBox}">
                    <Border
                        x:Name="Chrome"
                        Background="{TemplateBinding Background}"
                        BorderBrush="{TemplateBinding BorderBrush}"
                        BorderThickness="{TemplateBinding BorderThickness}"
                        CornerRadius="{StaticResource Radius.Sm}"
                        SnapsToDevicePixels="True">
                        <ScrollViewer
                            x:Name="PART_ContentHost"
                            Margin="{TemplateBinding Padding}"
                            Focusable="False"
                            HorizontalScrollBarVisibility="Hidden"
                            VerticalScrollBarVisibility="Hidden" />
                    </Border>
                    <ControlTemplate.Triggers>
                        <Trigger Property="IsKeyboardFocused" Value="True">
                            <Setter TargetName="Chrome" Property="BorderBrush" Value="{DynamicResource AppFocusRing}" />
                        </Trigger>
                        <Trigger Property="Validation.HasError" Value="True">
                            <Setter TargetName="Chrome" Property="BorderBrush" Value="{DynamicResource AppDanger}" />
                        </Trigger>
                        <Trigger Property="IsEnabled" Value="False">
                            <Setter Property="Opacity" Value="0.45" />
                        </Trigger>
                    </ControlTemplate.Triggers>
                </ControlTemplate>
            </Setter.Value>
        </Setter>
    </Style>

    <Style BasedOn="{StaticResource AppDatePickerTextBox}" TargetType="{x:Type primitives:DatePickerTextBox}" />

    <!--
        AppCalendarButton — month/year/decade cell button.
        Uses CalendarButton's actual properties: IsInactive (out-of-range
        cells), HasSelectedDays (the cell containing the selected date),
        IsFocused. There's NO IsSelected on CalendarButton (that's
        CalendarDayButton). Removing the IsSelected trigger from earlier
        broken iterations.
    -->
    <Style x:Key="AppCalendarButton" TargetType="{x:Type primitives:CalendarButton}">
        <Setter Property="Background" Value="Transparent" />
        <Setter Property="BorderBrush" Value="Transparent" />
        <Setter Property="BorderThickness" Value="1" />
        <Setter Property="Foreground" Value="{DynamicResource AppTextPrimary}" />
        <Setter Property="FontFamily" Value="{StaticResource Font.Family.Base}" />
        <Setter Property="FontSize" Value="{StaticResource Font.Size.Sm}" />
        <Setter Property="FontWeight" Value="{StaticResource Font.Weight.Medium}" />
        <Setter Property="MinWidth" Value="46" />
        <Setter Property="MinHeight" Value="34" />
        <Setter Property="Padding" Value="6,5" />
        <Setter Property="HorizontalAlignment" Value="Stretch" />
        <Setter Property="VerticalAlignment" Value="Stretch" />
        <Setter Property="HorizontalContentAlignment" Value="Center" />
        <Setter Property="VerticalContentAlignment" Value="Center" />
        <Setter Property="Cursor" Value="Hand" />
        <Setter Property="FocusVisualStyle" Value="{x:Null}" />
        <Setter Property="Template">
            <Setter.Value>
                <ControlTemplate TargetType="{x:Type primitives:CalendarButton}">
                    <Border
                        x:Name="Chrome"
                        Margin="2,3"
                        Background="{TemplateBinding Background}"
                        BorderBrush="{TemplateBinding BorderBrush}"
                        BorderThickness="{TemplateBinding BorderThickness}"
                        CornerRadius="{StaticResource Radius.Md}"
                        SnapsToDevicePixels="True">
                        <ContentPresenter
                            Margin="{TemplateBinding Padding}"
                            HorizontalAlignment="{TemplateBinding HorizontalContentAlignment}"
                            VerticalAlignment="{TemplateBinding VerticalContentAlignment}">
                            <!--  Same TextBlock-style override as CalendarDayButton — see comment there.  -->
                            <ContentPresenter.Resources>
                                <Style TargetType="TextBlock">
                                    <Setter Property="Foreground" Value="{Binding Foreground, RelativeSource={RelativeSource AncestorType={x:Type primitives:CalendarButton}}}" />
                                </Style>
                            </ContentPresenter.Resources>
                        </ContentPresenter>
                    </Border>
                    <ControlTemplate.Triggers>
                        <Trigger Property="IsMouseOver" Value="True">
                            <Setter TargetName="Chrome" Property="Background" Value="{DynamicResource AppHover}" />
                            <Setter TargetName="Chrome" Property="BorderBrush" Value="{DynamicResource AppTextSecondary}" />
                        </Trigger>
                        <Trigger Property="HasSelectedDays" Value="True">
                            <Setter TargetName="Chrome" Property="Background" Value="{DynamicResource AppAccent}" />
                            <Setter TargetName="Chrome" Property="BorderBrush" Value="{DynamicResource AppAccent}" />
                            <Setter Property="Foreground" Value="{DynamicResource AppTextOnAccent}" />
                            <Setter Property="FontWeight" Value="SemiBold" />
                        </Trigger>
                        <MultiTrigger>
                            <MultiTrigger.Conditions>
                                <Condition Property="HasSelectedDays" Value="True" />
                                <Condition Property="IsMouseOver" Value="True" />
                            </MultiTrigger.Conditions>
                            <Setter TargetName="Chrome" Property="Background" Value="{DynamicResource AppAccentHover}" />
                            <Setter TargetName="Chrome" Property="BorderBrush" Value="{DynamicResource AppAccentHover}" />
                            <Setter Property="Foreground" Value="{DynamicResource AppTextOnAccent}" />
                        </MultiTrigger>
                        <Trigger Property="IsInactive" Value="True">
                            <Setter Property="Foreground" Value="{DynamicResource AppTextMuted}" />
                            <Setter Property="Opacity" Value="0.62" />
                        </Trigger>
                        <Trigger Property="IsEnabled" Value="False">
                            <Setter Property="Opacity" Value="0.45" />
                            <Setter Property="Cursor" Value="Arrow" />
                        </Trigger>
                    </ControlTemplate.Triggers>
                </ControlTemplate>
            </Setter.Value>
        </Setter>
    </Style>

    <Style BasedOn="{StaticResource AppCalendarButton}" TargetType="{x:Type primitives:CalendarButton}" />

    <!--
        AppCalendarDayButton — single day cell.
        Full template: 34×34 circular chrome with hover / today / selected
        states. Selected → AppAccent fill + white text. Today → AppAccent
        ring + AppAccent text. IsBlackedOut / IsInactive fade.
    -->
    <Style x:Key="AppCalendarDayButton" TargetType="{x:Type primitives:CalendarDayButton}">
        <Setter Property="MinWidth" Value="34" />
        <Setter Property="MinHeight" Value="34" />
        <Setter Property="Margin" Value="1" />
        <Setter Property="Padding" Value="0" />
        <Setter Property="Background" Value="Transparent" />
        <Setter Property="BorderBrush" Value="Transparent" />
        <Setter Property="BorderThickness" Value="1" />
        <Setter Property="Foreground" Value="{DynamicResource AppTextPrimary}" />
        <Setter Property="FontFamily" Value="{StaticResource Font.Family.Base}" />
        <Setter Property="FontSize" Value="{StaticResource Font.Size.Sm}" />
        <Setter Property="FontWeight" Value="{StaticResource Font.Weight.Medium}" />
        <Setter Property="HorizontalContentAlignment" Value="Center" />
        <Setter Property="VerticalContentAlignment" Value="Center" />
        <Setter Property="FocusVisualStyle" Value="{x:Null}" />
        <Setter Property="Template">
            <Setter.Value>
                <ControlTemplate TargetType="{x:Type primitives:CalendarDayButton}">
                    <Border
                        x:Name="Chrome"
                        Background="{TemplateBinding Background}"
                        BorderBrush="{TemplateBinding BorderBrush}"
                        BorderThickness="{TemplateBinding BorderThickness}"
                        CornerRadius="{StaticResource Radius.Full}"
                        SnapsToDevicePixels="True">
                        <ContentPresenter
                            HorizontalAlignment="{TemplateBinding HorizontalContentAlignment}"
                            VerticalAlignment="{TemplateBinding VerticalContentAlignment}"
                            RecognizesAccessKey="True">
                            <!--
                                Local TextBlock style overrides the global
                                Inputs.xaml implicit TextBlock style. Without
                                this, the day-number TextBlock created by
                                ContentPresenter inherits Foreground=AppTextPrimary
                                from the global style — which has higher
                                precedence than the TemplateBinding inheritance,
                                so the IsToday / IsSelected trigger Foreground
                                changes wouldn't reach the rendered text.
                            -->
                            <ContentPresenter.Resources>
                                <Style TargetType="TextBlock">
                                    <Setter Property="Foreground" Value="{Binding Foreground, RelativeSource={RelativeSource AncestorType={x:Type primitives:CalendarDayButton}}}" />
                                </Style>
                            </ContentPresenter.Resources>
                        </ContentPresenter>
                    </Border>
                    <ControlTemplate.Triggers>
                        <Trigger Property="IsMouseOver" Value="True">
                            <Setter TargetName="Chrome" Property="Background" Value="{DynamicResource AppHover}" />
                        </Trigger>
                        <Trigger Property="IsToday" Value="True">
                            <Setter TargetName="Chrome" Property="BorderBrush" Value="{DynamicResource AppAccent}" />
                            <Setter Property="Foreground" Value="{DynamicResource AppAccent}" />
                        </Trigger>
                        <Trigger Property="IsSelected" Value="True">
                            <Setter TargetName="Chrome" Property="Background" Value="{DynamicResource AppAccent}" />
                            <Setter TargetName="Chrome" Property="BorderBrush" Value="{DynamicResource AppAccent}" />
                            <Setter Property="Foreground" Value="{DynamicResource AppTextOnAccent}" />
                        </Trigger>
                        <MultiTrigger>
                            <MultiTrigger.Conditions>
                                <Condition Property="IsSelected" Value="True" />
                                <Condition Property="IsToday" Value="True" />
                            </MultiTrigger.Conditions>
                            <Setter Property="Foreground" Value="{DynamicResource AppTextOnAccent}" />
                        </MultiTrigger>
                        <Trigger Property="IsInactive" Value="True">
                            <Setter Property="Opacity" Value="0.45" />
                        </Trigger>
                        <Trigger Property="IsBlackedOut" Value="True">
                            <Setter Property="Opacity" Value="0.28" />
                            <Setter Property="Foreground" Value="{DynamicResource AppTextMuted}" />
                        </Trigger>
                    </ControlTemplate.Triggers>
                </ControlTemplate>
            </Setter.Value>
        </Setter>
    </Style>

    <Style BasedOn="{StaticResource AppCalendarDayButton}" TargetType="{x:Type primitives:CalendarDayButton}" />

    <!--
        ════════════════════════════════════════════════════════════
        DESIGN NOTE — why no AppCalendarItem template
        ════════════════════════════════════════════════════════════
        Custom CalendarItem template has been attempted FIVE times now,
        each iteration broke a different aspect of view-switching:

          v1  wrapper Grid                → _monthView ref null, no toggle
          v2  Collapsed initial            → UpdateMonths early-return, blank
          v3  no Visibility set            → both Visible, views stack
          v4  mirror default w/ Visible/Hidden → click header → header text
              changes but Decade/Year view still shows Month grid
          v5  逐字 mirror reference source → SAME as v4 (year view click
              shows day grid)

        Conclusion: WPF Calendar's OnApplyTemplate / GetTemplateChild /
        UpdateAppearance pipeline has internal coupling we cannot
        reproduce reliably from XAML alone. Cell-level theming
        (CalendarDayButton + CalendarButton) is sufficient for the
        actual content; popup chrome remains OS default but functional.

        Tradeoff accepted: the ◀ ▶ chevrons and "May 2026" header
        button keep WPF Aero2 styling, but view-switching works.
    -->
    <Style x:Key="AppCalendar" TargetType="{x:Type Calendar}">
        <Setter Property="Background" Value="{DynamicResource AppSurface}" />
        <Setter Property="Foreground" Value="{DynamicResource AppTextPrimary}" />
        <Setter Property="BorderBrush" Value="{DynamicResource AppBorder}" />
        <Setter Property="BorderThickness" Value="0" />
        <Setter Property="FontFamily" Value="{StaticResource Font.Family.Base}" />
        <Setter Property="FontSize" Value="{StaticResource Font.Size.Sm}" />
        <Setter Property="CalendarDayButtonStyle" Value="{StaticResource AppCalendarDayButton}" />
        <Setter Property="CalendarButtonStyle" Value="{StaticResource AppCalendarButton}" />
        <!--
            CalendarItemStyle deliberately NOT set — uses WPF default
            CalendarItem template so view-switching (Month → Year →
            Decade) works reliably. See "DESIGN NOTE — why no
            AppCalendarItem template" earlier in this file.
        -->
    </Style>

    <Style BasedOn="{StaticResource AppCalendar}" TargetType="{x:Type Calendar}" />

    <!--
        Drop-down trigger button — Fluent CalendarLtr / Calendar glyph.
    -->
    <Style x:Key="DatePickerDropDownButton" TargetType="{x:Type Button}">
        <Setter Property="Width" Value="32" />
        <Setter Property="Height" Value="{StaticResource Control.Height.Md}" />
        <Setter Property="MinHeight" Value="{StaticResource Control.Height.Md}" />
        <Setter Property="Padding" Value="0" />
        <Setter Property="Background" Value="Transparent" />
        <Setter Property="BorderThickness" Value="0" />
        <Setter Property="Foreground" Value="{DynamicResource AppTextSecondary}" />
        <Setter Property="Cursor" Value="Hand" />
        <Setter Property="FocusVisualStyle" Value="{x:Null}" />
        <Setter Property="HorizontalAlignment" Value="Center" />
        <Setter Property="VerticalAlignment" Value="Stretch" />
        <Setter Property="Template">
            <Setter.Value>
                <ControlTemplate TargetType="{x:Type Button}">
                    <Border
                        x:Name="Chrome"
                        Background="{TemplateBinding Background}"
                        CornerRadius="0,3,3,0"
                        SnapsToDevicePixels="True">
                        <ds:AppIcon
                            HorizontalAlignment="Center"
                            VerticalAlignment="Center"
                            FontSize="14"
                            Foreground="{TemplateBinding Foreground}"
                            Symbol="Calendar24" />
                    </Border>
                    <ControlTemplate.Triggers>
                        <Trigger Property="IsMouseOver" Value="True">
                            <Setter TargetName="Chrome" Property="Background" Value="{DynamicResource AppHover}" />
                            <Setter Property="Foreground" Value="{DynamicResource AppTextPrimary}" />
                        </Trigger>
                        <Trigger Property="IsEnabled" Value="False">
                            <Setter Property="Opacity" Value="0.45" />
                            <Setter Property="Cursor" Value="Arrow" />
                        </Trigger>
                    </ControlTemplate.Triggers>
                </ControlTemplate>
            </Setter.Value>
        </Setter>
    </Style>

    <!--
        AppDatePicker — full template overrides only the OUTER DatePicker
        (textbox + drop-down button + popup placeholder). The popup hosts
        a Calendar that renders via WPF's default template, themed by
        AppCalendar's color/sub-style setters.
    -->
    <Style x:Key="AppDatePicker" TargetType="{x:Type DatePicker}">
        <Setter Property="MinHeight" Value="{StaticResource Control.Height.Md}" />
        <Setter Property="FontFamily" Value="{StaticResource Font.Family.Base}" />
        <Setter Property="FontSize" Value="{StaticResource Font.Size.Sm}" />
        <Setter Property="Foreground" Value="{DynamicResource AppTextPrimary}" />
        <Setter Property="Background" Value="{DynamicResource AppSurface}" />
        <Setter Property="BorderBrush" Value="{DynamicResource AppBorder}" />
        <Setter Property="BorderThickness" Value="{StaticResource Border.Input}" />
        <Setter Property="FocusVisualStyle" Value="{StaticResource FocusVisual}" />
        <Setter Property="CalendarStyle" Value="{StaticResource AppCalendar}" />
        <Setter Property="SelectedDateFormat" Value="Short" />
        <Setter Property="behaviors:DatePickerDateOnlyBehavior.IsEnabled" Value="True" />
        <Setter Property="behaviors:DatePickerDateOnlyBehavior.Constraint" Value="None" />
        <Setter Property="Template">
            <Setter.Value>
                <ControlTemplate TargetType="{x:Type DatePicker}">
                    <Border
                        x:Name="Chrome"
                        Background="{TemplateBinding Background}"
                        BorderBrush="{TemplateBinding BorderBrush}"
                        BorderThickness="{TemplateBinding BorderThickness}"
                        CornerRadius="{StaticResource Radius.Sm}"
                        SnapsToDevicePixels="True">
                        <Grid x:Name="PART_Root">
                            <Grid.ColumnDefinitions>
                                <ColumnDefinition Width="*" />
                                <ColumnDefinition Width="Auto" />
                            </Grid.ColumnDefinitions>

                            <primitives:DatePickerTextBox
                                x:Name="PART_TextBox"
                                Grid.Column="0"
                                BorderThickness="0"
                                Foreground="{TemplateBinding Foreground}"
                                Focusable="{TemplateBinding Focusable}" />

                            <Button
                                x:Name="PART_Button"
                                Grid.Column="1"
                                Focusable="False"
                                Foreground="{DynamicResource AppTextSecondary}"
                                Style="{StaticResource DatePickerDropDownButton}" />

                            <Popup
                                x:Name="PART_Popup"
                                AllowsTransparency="True"
                                Placement="Bottom"
                                PlacementTarget="{Binding ElementName=PART_TextBox}"
                                StaysOpen="False" />

                            <ContentControl
                                x:Name="PART_DisabledVisual"
                                Grid.ColumnSpan="2"
                                Background="Transparent"
                                Focusable="False"
                                IsHitTestVisible="False"
                                IsTabStop="False"
                                Visibility="Collapsed" />
                        </Grid>
                    </Border>
                    <ControlTemplate.Triggers>
                        <Trigger Property="IsMouseOver" Value="True">
                            <Setter TargetName="Chrome" Property="BorderBrush" Value="{DynamicResource AppTextSecondary}" />
                        </Trigger>
                        <Trigger Property="IsKeyboardFocusWithin" Value="True">
                            <Setter TargetName="Chrome" Property="BorderBrush" Value="{DynamicResource AppAccent}" />
                        </Trigger>
                        <Trigger Property="IsEnabled" Value="False">
                            <Setter TargetName="PART_DisabledVisual" Property="Visibility" Value="Visible" />
                            <Setter Property="Opacity" Value="0.45" />
                        </Trigger>
                    </ControlTemplate.Triggers>
                </ControlTemplate>
            </Setter.Value>
        </Setter>
    </Style>

    <Style BasedOn="{StaticResource AppDatePicker}" TargetType="{x:Type DatePicker}" />

</ResourceDictionary>
