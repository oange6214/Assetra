<ResourceDictionary
    xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
    xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml">

    <Style x:Key="AppExpander" TargetType="{x:Type Expander}">
        <Setter Property="Background" Value="{DynamicResource AppSurface}" />
        <Setter Property="BorderBrush" Value="{DynamicResource AppBorder}" />
        <Setter Property="BorderThickness" Value="1" />
        <Setter Property="Foreground" Value="{DynamicResource AppTextPrimary}" />
        <Setter Property="Padding" Value="12,10" />
        <Setter Property="Template">
            <Setter.Value>
                <ControlTemplate TargetType="{x:Type Expander}">
                    <Border
                        Background="{TemplateBinding Background}"
                        BorderBrush="{TemplateBinding BorderBrush}"
                        BorderThickness="{TemplateBinding BorderThickness}"
                        CornerRadius="{StaticResource Radius.Lg}">
                        <DockPanel LastChildFill="True">
                            <ToggleButton
                                x:Name="HeaderSite"
                                DockPanel.Dock="Top"
                                Padding="{TemplateBinding Padding}"
                                HorizontalContentAlignment="Stretch"
                                Background="Transparent"
                                BorderThickness="0"
                                Cursor="Hand"
                                FocusVisualStyle="{StaticResource FocusVisual}"
                                IsChecked="{Binding IsExpanded, Mode=TwoWay, RelativeSource={RelativeSource TemplatedParent}}">
                                <ToggleButton.Template>
                                    <ControlTemplate TargetType="{x:Type ToggleButton}">
                                        <Border
                                            x:Name="HeaderChrome"
                                            Padding="{TemplateBinding Padding}"
                                            Background="{TemplateBinding Background}">
                                            <Grid>
                                                <Grid.ColumnDefinitions>
                                                    <ColumnDefinition Width="*" />
                                                    <ColumnDefinition Width="Auto" />
                                                </Grid.ColumnDefinitions>
                                                <ContentPresenter
                                                    Grid.Column="0"
                                                    VerticalAlignment="Center"
                                                    RecognizesAccessKey="True" />
                                                <Path
                                                    x:Name="Chevron"
                                                    Grid.Column="1"
                                                    Width="8"
                                                    Height="5"
                                                    Margin="12,0,0,0"
                                                    VerticalAlignment="Center"
                                                    Data="M 0 0 L 4 4 L 8 0"
                                                    Fill="{DynamicResource AppTextMuted}"
                                                    RenderTransformOrigin="0.5,0.5">
                                                    <Path.RenderTransform>
                                                        <RotateTransform Angle="0" />
                                                    </Path.RenderTransform>
                                                </Path>
                                            </Grid>
                                        </Border>
                                        <ControlTemplate.Triggers>
                                            <Trigger Property="IsMouseOver" Value="True">
                                                <Setter TargetName="HeaderChrome" Property="Background" Value="{DynamicResource AppSurfaceRaised}" />
                                            </Trigger>
                                            <Trigger Property="IsChecked" Value="True">
                                                <Setter TargetName="Chevron" Property="RenderTransform">
                                                    <Setter.Value>
                                                        <RotateTransform Angle="180" />
                                                    </Setter.Value>
                                                </Setter>
                                            </Trigger>
                                            <Trigger Property="IsEnabled" Value="False">
                                                <Setter Property="Opacity" Value="0.45" />
                                            </Trigger>
                                        </ControlTemplate.Triggers>
                                    </ControlTemplate>
                                </ToggleButton.Template>
                                <ContentPresenter
                                    ContentSource="Header"
                                    RecognizesAccessKey="True" />
                            </ToggleButton>

                            <ContentPresenter
                                x:Name="ExpandSite"
                                Margin="{TemplateBinding Padding}"
                                ContentSource="Content"
                                Visibility="Collapsed" />
                        </DockPanel>
                    </Border>
                    <ControlTemplate.Triggers>
                        <Trigger Property="IsExpanded" Value="True">
                            <Setter TargetName="ExpandSite" Property="Visibility" Value="Visible" />
                        </Trigger>
                    </ControlTemplate.Triggers>
                </ControlTemplate>
            </Setter.Value>
        </Setter>
    </Style>

    <!--  Implicit default for bare <Expander/>.  -->
    <Style BasedOn="{StaticResource AppExpander}" TargetType="{x:Type Expander}" />

</ResourceDictionary>
