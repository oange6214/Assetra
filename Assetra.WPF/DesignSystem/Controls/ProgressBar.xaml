<ResourceDictionary xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation" xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml">

    <!--
        AppProgressBar — Fluent thin (4 px) progress track.
        Indeterminate animation kept simple: gradient sweep across track.
    -->
    <Style x:Key="AppProgressBar" TargetType="{x:Type ProgressBar}">
        <Setter Property="Height" Value="4" />
        <Setter Property="MinHeight" Value="4" />
        <Setter Property="Background" Value="{DynamicResource AppBorderLight}" />
        <Setter Property="Foreground" Value="{DynamicResource AppAccent}" />
        <Setter Property="BorderThickness" Value="0" />
        <Setter Property="SnapsToDevicePixels" Value="True" />
        <Setter Property="Template">
            <Setter.Value>
                <ControlTemplate TargetType="{x:Type ProgressBar}">
                    <Grid>
                        <Border
                            x:Name="Track"
                            Background="{TemplateBinding Background}"
                            CornerRadius="2" />
                        <Border x:Name="PART_Track" Background="Transparent" />
                        <Border
                            x:Name="PART_Indicator"
                            HorizontalAlignment="Left"
                            Background="{TemplateBinding Foreground}"
                            CornerRadius="2" />
                    </Grid>
                    <ControlTemplate.Triggers>
                        <!--
                            Indeterminate: WPF auto-animates PART_Indicator
                            (clipped to Track) when IsIndeterminate=True. We
                            keep the simple solid-accent indicator — gradient
                            sweep dropped because Binding.Source cannot accept
                            DynamicResource and a hard-coded gradient would
                            break dark-theme support.
                        -->
                        <Trigger Property="IsIndeterminate" Value="True">
                            <Setter TargetName="PART_Indicator" Property="Width" Value="80" />
                            <Setter TargetName="PART_Indicator" Property="Opacity" Value="0.85" />
                        </Trigger>
                    </ControlTemplate.Triggers>
                </ControlTemplate>
            </Setter.Value>
        </Setter>
    </Style>

    <Style BasedOn="{StaticResource AppProgressBar}" TargetType="{x:Type ProgressBar}" />

</ResourceDictionary>
