<ResourceDictionary xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation" xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml">

    <Style x:Key="AppDialogOverlay" TargetType="{x:Type Grid}">
        <Setter Property="Background" Value="{DynamicResource Brush.ModalOverlay}" />
        <Setter Property="HorizontalAlignment" Value="Stretch" />
        <Setter Property="VerticalAlignment" Value="Stretch" />
    </Style>

    <Style x:Key="AppDialogOverlayBorder" TargetType="{x:Type Border}">
        <Setter Property="Background" Value="{DynamicResource Brush.ModalOverlay}" />
        <Setter Property="HorizontalAlignment" Value="Stretch" />
        <Setter Property="VerticalAlignment" Value="Stretch" />
    </Style>

    <!--
        P4.9f — Side panel backdrop（Position / Cash / Liability 共用）。
        跟 AppDialogOverlayBorder 一樣 stretch 全頁面當 click-to-close 區域，
        但 Background=Transparent 不蓋色 — 使用者可以同時看到下層 list
        作為對照參考（modern fintech master-detail pattern）。
        其他真實 modal dialog (AddAsset、確認對話框等) 仍用
        AppDialogOverlayBorder 帶 dim，視覺語意：dim = modal / 沒 dim = side panel。
    -->
    <Style x:Key="AppSidePanelBackdropBorder" TargetType="{x:Type Border}">
        <Setter Property="Background" Value="Transparent" />
        <Setter Property="HorizontalAlignment" Value="Stretch" />
        <Setter Property="VerticalAlignment" Value="Stretch" />
    </Style>

    <Style x:Key="AppDialogShell" TargetType="{x:Type Border}">
        <Setter Property="Width" Value="{StaticResource DialogWidth}" />
        <Setter Property="MaxHeight" Value="{StaticResource DialogMaxHeight}" />
        <Setter Property="Padding" Value="{StaticResource Padding.Dialog}" />
        <Setter Property="Background" Value="{DynamicResource Brush.Surface}" />
        <Setter Property="BorderBrush" Value="{DynamicResource Brush.Border}" />
        <Setter Property="BorderThickness" Value="{StaticResource Border.Dialog}" />
        <Setter Property="CornerRadius" Value="{StaticResource Radius.Xl}" />
        <Setter Property="Effect" Value="{StaticResource Shadow.Dialog}" />
    </Style>

    <Style
        x:Key="AppSidePanelDialogShell"
        BasedOn="{StaticResource AppDialogShell}"
        TargetType="{x:Type Border}">
        <Setter Property="Width" Value="520" />
        <Setter Property="MaxHeight" Value="{x:Null}" />
        <Setter Property="HorizontalAlignment" Value="Right" />
        <Setter Property="VerticalAlignment" Value="Stretch" />
        <Setter Property="Margin" Value="0" />
        <Setter Property="CornerRadius" Value="{StaticResource Radius.Lg}" />
    </Style>

    <Style
        x:Key="AppDestructiveDialogShell"
        BasedOn="{StaticResource AppDialogShell}"
        TargetType="{x:Type Border}">
        <Setter Property="Width" Value="420" />
    </Style>

    <Style x:Key="AppDialogHeader" TargetType="{x:Type StackPanel}">
        <Setter Property="Margin" Value="0,0,0,16" />
    </Style>

    <Style x:Key="AppDialogTitle" TargetType="{x:Type TextBlock}">
        <Setter Property="FontFamily" Value="{StaticResource Font.Family.Display}" />
        <Setter Property="FontSize" Value="{StaticResource Font.Size.Lg}" />
        <Setter Property="FontWeight" Value="{StaticResource Font.Weight.Semibold}" />
        <Setter Property="Foreground" Value="{DynamicResource Brush.Text.Primary}" />
        <Setter Property="TextWrapping" Value="Wrap" />
    </Style>

    <Style x:Key="AppDialogSubtitle" TargetType="{x:Type TextBlock}">
        <Setter Property="Margin" Value="0,6,0,0" />
        <Setter Property="FontSize" Value="{StaticResource Font.Size.Sm}" />
        <Setter Property="Foreground" Value="{DynamicResource Brush.Text.Secondary}" />
        <Setter Property="TextWrapping" Value="Wrap" />
    </Style>

    <Style x:Key="AppDialogBody" TargetType="{x:Type Grid}">
        <Setter Property="HorizontalAlignment" Value="Stretch" />
        <Setter Property="VerticalAlignment" Value="Stretch" />
    </Style>

    <Style x:Key="AppDialogFooter" TargetType="{x:Type StackPanel}">
        <Setter Property="Margin" Value="0,16,0,0" />
        <Setter Property="HorizontalAlignment" Value="Right" />
        <Setter Property="Orientation" Value="Horizontal" />
    </Style>

    <Style
        x:Key="AppFormDialogShell"
        BasedOn="{StaticResource AppDialogShell}"
        TargetType="{x:Type Border}" />
    <Style
        x:Key="AppEditDialogShell"
        BasedOn="{StaticResource AppDialogShell}"
        TargetType="{x:Type Border}" />
    <Style x:Key="AppDialogValidationText" TargetType="{x:Type TextBlock}">
        <Setter Property="Margin" Value="0,12,0,0" />
        <Setter Property="Foreground" Value="{DynamicResource Brush.Danger}" />
        <Setter Property="TextWrapping" Value="Wrap" />
    </Style>

</ResourceDictionary>
