<ResourceDictionary
    xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
    xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
    xmlns:controls="clr-namespace:Assetra.WPF.DesignSystem.Controls"
    xmlns:fi="clr-namespace:FluentIcons.Wpf;assembly=FluentIcons.Wpf">

    <Style x:Key="AppIcon" TargetType="{x:Type controls:AppIcon}">
        <Setter Property="Foreground" Value="{DynamicResource Brush.Text.Secondary}" />
        <Setter Property="IsHitTestVisible" Value="False" />
        <Setter Property="SnapsToDevicePixels" Value="True" />
        <Setter Property="Template">
            <Setter.Value>
                <ControlTemplate TargetType="{x:Type controls:AppIcon}">
                    <Viewbox
                        Width="{Binding FontSize, RelativeSource={RelativeSource TemplatedParent}}"
                        Height="{Binding FontSize, RelativeSource={RelativeSource TemplatedParent}}"
                        SnapsToDevicePixels="True"
                        Stretch="Uniform">
                        <fi:FluentIcon
                            FontSize="24"
                            Foreground="{TemplateBinding Foreground}"
                            Icon="{Binding IconElement, RelativeSource={RelativeSource TemplatedParent}}"
                            IconSize="Size24"
                            IconVariant="{Binding IconVariant, RelativeSource={RelativeSource TemplatedParent}}" />
                    </Viewbox>
                </ControlTemplate>
            </Setter.Value>
        </Setter>
    </Style>

    <Style TargetType="{x:Type controls:AppIcon}">
        <Setter Property="Foreground" Value="{DynamicResource Brush.Text.Secondary}" />
        <Setter Property="IsHitTestVisible" Value="False" />
        <Setter Property="SnapsToDevicePixels" Value="True" />
        <Setter Property="Template">
            <Setter.Value>
                <ControlTemplate TargetType="{x:Type controls:AppIcon}">
                    <Viewbox
                        Width="{Binding FontSize, RelativeSource={RelativeSource TemplatedParent}}"
                        Height="{Binding FontSize, RelativeSource={RelativeSource TemplatedParent}}"
                        SnapsToDevicePixels="True"
                        Stretch="Uniform">
                        <fi:FluentIcon
                            FontSize="24"
                            Foreground="{TemplateBinding Foreground}"
                            Icon="{Binding IconElement, RelativeSource={RelativeSource TemplatedParent}}"
                            IconSize="Size24"
                            IconVariant="{Binding IconVariant, RelativeSource={RelativeSource TemplatedParent}}" />
                    </Viewbox>
                </ControlTemplate>
            </Setter.Value>
        </Setter>
    </Style>

    <!--
        EmptyStateIcon lives here (not in Styles/EmptyState.xaml) so its
        BasedOn lookup of AppIcon stays inside one ResourceDictionary —
        cross-file BasedOn StaticResource is forbidden by the project
        convention (see DesignSystem/README.md "Migration Rules").
    -->
    <Style
        x:Key="EmptyStateIcon"
        BasedOn="{StaticResource AppIcon}"
        TargetType="{x:Type controls:AppIcon}">
        <Setter Property="HorizontalAlignment" Value="Center" />
        <Setter Property="FontSize" Value="44" />
        <Setter Property="Foreground" Value="{DynamicResource AppTextMuted}" />
    </Style>
</ResourceDictionary>
