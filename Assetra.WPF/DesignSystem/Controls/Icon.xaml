<ResourceDictionary
    xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
    xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
    xmlns:controls="clr-namespace:Assetra.WPF.DesignSystem.Controls">

    <Style x:Key="AppIcon" TargetType="{x:Type controls:AppIcon}">
        <Setter Property="Foreground" Value="{DynamicResource Brush.Text.Secondary}" />
        <Setter Property="IsHitTestVisible" Value="False" />
        <Setter Property="SnapsToDevicePixels" Value="True" />
        <Setter Property="Template">
            <Setter.Value>
                <ControlTemplate TargetType="{x:Type controls:AppIcon}">
                    <Viewbox
                        Width="{Binding FontSize, RelativeSource={RelativeSource TemplatedParent}}"
                        Height="{Binding FontSize, RelativeSource={RelativeSource TemplatedParent}}"
                        Stretch="Uniform"
                        SnapsToDevicePixels="True">
                        <Path
                            Width="24"
                            Height="24"
                            Data="{TemplateBinding Data}"
                            Fill="{TemplateBinding Foreground}"
                            Stretch="Uniform" />
                    </Viewbox>
                </ControlTemplate>
            </Setter.Value>
        </Setter>
    </Style>

    <Style TargetType="{x:Type controls:AppIcon}">
        <Setter Property="Foreground" Value="{DynamicResource Brush.Text.Secondary}" />
        <Setter Property="IsHitTestVisible" Value="False" />
        <Setter Property="SnapsToDevicePixels" Value="True" />
        <Setter Property="Template">
            <Setter.Value>
                <ControlTemplate TargetType="{x:Type controls:AppIcon}">
                    <Viewbox
                        Width="{Binding FontSize, RelativeSource={RelativeSource TemplatedParent}}"
                        Height="{Binding FontSize, RelativeSource={RelativeSource TemplatedParent}}"
                        Stretch="Uniform"
                        SnapsToDevicePixels="True">
                        <Path
                            Width="24"
                            Height="24"
                            Data="{TemplateBinding Data}"
                            Fill="{TemplateBinding Foreground}"
                            Stretch="Uniform" />
                    </Viewbox>
                </ControlTemplate>
            </Setter.Value>
        </Setter>
    </Style>
</ResourceDictionary>
