<UserControl
    x:Class="Assetra.WPF.DesignSystem.ControlGallery"
    xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
    xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
    xmlns:behaviors="clr-namespace:Assetra.WPF.Infrastructure.Behaviors"
    xmlns:ds="clr-namespace:Assetra.WPF.DesignSystem.Controls"
    xmlns:sys="clr-namespace:System;assembly=System.Runtime"
    Background="{DynamicResource AppBackground}">

    <ScrollViewer Style="{StaticResource ListContentHost}">
        <StackPanel Margin="24">
            <DockPanel Style="{StaticResource PageHeaderDock}">
                <StackPanel Style="{StaticResource PageTitleRow}">
                    <ds:AppIcon
                        Margin="0,0,8,0"
                        VerticalAlignment="Center"
                        Foreground="{DynamicResource AppTextMuted}"
                        Symbol="Settings24" />
                    <TextBlock Style="{StaticResource PageTitleText}" Text="Assetra DesignSystem Gallery" />
                </StackPanel>
            </DockPanel>

            <Border Style="{StaticResource FormSection}" Margin="0,0,0,16">
                <StackPanel>
                    <TextBlock Style="{StaticResource FormSectionHeader}" Text="Buttons" />
                    <StackPanel Orientation="Horizontal">
                        <Button Style="{StaticResource AppPrimaryButton}">
                            <StackPanel Style="{StaticResource AppButtonContent}">
                                <ds:AppIcon Style="{StaticResource AppButtonLeadingIcon}" Symbol="Add24" />
                                <TextBlock Style="{StaticResource AppButtonText}" Text="Primary" />
                            </StackPanel>
                        </Button>
                        <Button Margin="8,0,0,0" Content="Secondary" Style="{StaticResource AppSecondaryButton}" />
                        <Button Margin="8,0,0,0" Content="Ghost" Style="{StaticResource AppGhostButton}" />
                        <Button Margin="8,0,0,0" Content="Danger" Style="{StaticResource AppDangerButton}" />
                        <Button Margin="8,0,0,0" Style="{StaticResource AppIconButton}">
                            <ds:AppIcon Symbol="Search24" />
                        </Button>
                        <Button Margin="8,0,0,0" Style="{StaticResource AppToolbarButton}">
                            <ds:AppIcon Symbol="Settings24" />
                        </Button>
                        <Button Margin="8,0,0,0" IsEnabled="False" Content="Disabled" Style="{StaticResource AppPrimaryButton}" />
                    </StackPanel>
                </StackPanel>
            </Border>

            <Border Style="{StaticResource FormSection}" Margin="0,0,0,16">
                <StackPanel>
                    <TextBlock Style="{StaticResource FormSectionHeader}" Text="Inputs" />
                    <UniformGrid Columns="4" Rows="1">
                        <StackPanel Style="{StaticResource FormField}">
                            <TextBlock Style="{StaticResource FormFieldLabel}" Text="Text" />
                            <TextBox Style="{StaticResource AppTextBox}" Text="Assetra" />
                        </StackPanel>
                        <StackPanel Style="{StaticResource FormField}">
                            <TextBlock Style="{StaticResource FormFieldLabel}" Text="Money" />
                            <TextBox
                                behaviors:ThousandSeparatorBehavior.IsEnabled="True"
                                Style="{StaticResource AppMoneyTextBox}"
                                Text="1234567" />
                        </StackPanel>
                        <StackPanel Style="{StaticResource FormField}">
                            <TextBlock Style="{StaticResource FormFieldLabel}" Text="Rate" />
                            <TextBox Style="{StaticResource AppRateTextBox}" Text="0.05" />
                        </StackPanel>
                        <StackPanel Style="{StaticResource FormFieldLast}">
                            <TextBlock Style="{StaticResource FormFieldLabel}" Text="Percent" />
                            <TextBox Style="{StaticResource AppPercentTextBox}" Text="5" />
                        </StackPanel>
                    </UniformGrid>
                </StackPanel>
            </Border>

            <Border Style="{StaticResource FormSection}" Margin="0,0,0,16">
                <StackPanel>
                    <TextBlock Style="{StaticResource FormSectionHeader}" Text="Selection" />
                    <UniformGrid Columns="4" Rows="1">
                        <StackPanel Style="{StaticResource FormField}">
                            <TextBlock Style="{StaticResource FormFieldLabel}" Text="ComboBox" />
                            <ComboBox SelectedIndex="0" Style="{StaticResource AppComboBox}">
                                <ComboBox.ItemsSource>
                                    <x:Array Type="{x:Type sys:String}">
                                        <sys:String>收入</sys:String>
                                        <sys:String>支出</sys:String>
                                        <sys:String>轉帳</sys:String>
                                    </x:Array>
                                </ComboBox.ItemsSource>
                            </ComboBox>
                        </StackPanel>
                        <StackPanel Style="{StaticResource FormField}">
                            <TextBlock Style="{StaticResource FormFieldLabel}" Text="Date" />
                            <DatePicker Style="{StaticResource AppDatePicker}" SelectedDate="2026-05-06" />
                        </StackPanel>
                        <StackPanel Style="{StaticResource FormFieldLast}">
                            <TextBlock Style="{StaticResource FormFieldLabel}" Text="Past Only Date" />
                            <DatePicker
                                behaviors:DatePickerDateOnlyBehavior.Constraint="PastOnly"
                                Style="{StaticResource AppDatePicker}"
                                SelectedDate="2026-05-06" />
                        </StackPanel>
                        <StackPanel Style="{StaticResource FormFieldLast}">
                            <TextBlock Style="{StaticResource FormFieldLabel}" Text="Check / Radio / Switch" />
                            <CheckBox Content="Checked" IsChecked="True" Style="{StaticResource AppCheckBox}" />
                            <RadioButton Margin="0,8,0,0" Content="Selected" IsChecked="True" Style="{StaticResource AppRadioButton}" />
                            <CheckBox Margin="0,8,0,0" IsChecked="True" Style="{StaticResource AppSwitch}" />
                        </StackPanel>
                    </UniformGrid>
                </StackPanel>
            </Border>

            <Border Style="{StaticResource FormSection}" Margin="0,0,0,16">
                <StackPanel>
                    <TextBlock Style="{StaticResource FormSectionHeader}" Text="Tabs and Segments" />
                    <StackPanel Orientation="Horizontal">
                        <RadioButton Content="Top Tab" IsChecked="True" Style="{StaticResource AppTopTab}" />
                        <RadioButton Content="Sub Tab" Margin="8,0,0,0" Style="{StaticResource AppSubTab}" />
                        <RadioButton Content="Segment" Margin="24,0,0,0" IsChecked="True" Style="{StaticResource AppSegmentButton}" />
                        <RadioButton Content="Segment" Margin="8,0,0,0" Style="{StaticResource AppSegmentButton}" />
                    </StackPanel>
                </StackPanel>
            </Border>

            <Border Style="{StaticResource FormSection}" Margin="0,0,0,16">
                <StackPanel>
                    <TextBlock Style="{StaticResource FormSectionHeader}" Text="DataGrid" />
                    <DataGrid
                        Height="180"
                        Style="{StaticResource AppDataGrid}">
                        <DataGrid.ItemsSource>
                            <x:Array Type="{x:Type sys:String}">
                                <sys:String>Portfolio</sys:String>
                                <sys:String>Alerts</sys:String>
                                <sys:String>Reports</sys:String>
                            </x:Array>
                        </DataGrid.ItemsSource>
                        <DataGrid.Columns>
                            <DataGridTextColumn Binding="{Binding .}" Header="Name" />
                            <DataGridTextColumn Binding="{Binding Length}" Header="Score" />
                        </DataGrid.Columns>
                    </DataGrid>
                </StackPanel>
            </Border>

            <Border Style="{StaticResource FormSection}" Margin="0,0,0,16">
                <StackPanel>
                    <TextBlock Style="{StaticResource FormSectionHeader}" Text="Dialog Shell" />
                    <Border HorizontalAlignment="Left" Style="{StaticResource AppDialogShell}">
                        <StackPanel>
                            <StackPanel Style="{StaticResource AppDialogHeader}">
                                <TextBlock Style="{StaticResource AppDialogTitle}" Text="Dialog title" />
                                <TextBlock Style="{StaticResource AppDialogSubtitle}" Text="Dialog body uses shared spacing and footer buttons." />
                            </StackPanel>
                            <StackPanel Style="{StaticResource AppDialogFooter}">
                                <Button Content="Cancel" Style="{StaticResource AppSecondaryButton}" />
                                <Button Margin="8,0,0,0" Content="Confirm" Style="{StaticResource AppPrimaryButton}" />
                            </StackPanel>
                        </StackPanel>
                    </Border>
                </StackPanel>
            </Border>

            <Grid MinHeight="220">
                <StackPanel Style="{StaticResource AppEmptyState}">
                    <ds:AppIcon Style="{StaticResource EmptyStateIcon}" Symbol="Info24" />
                    <TextBlock Style="{StaticResource AppEmptyStateTitle}" Text="尚無資料" />
                    <TextBlock Style="{StaticResource AppEmptyStateDescription}" Text="這裡示範共用空狀態與主要操作。" />
                    <StackPanel Style="{StaticResource AppEmptyStateActionBar}">
                        <Button Style="{StaticResource AppEmptyStatePrimaryAction}">
                            <StackPanel Style="{StaticResource AppButtonContent}">
                                <ds:AppIcon Style="{StaticResource AppButtonLeadingIcon}" Symbol="Add24" />
                                <TextBlock Style="{StaticResource AppButtonText}" Text="新增項目" />
                            </StackPanel>
                        </Button>
                    </StackPanel>
                </StackPanel>
            </Grid>
        </StackPanel>
    </ScrollViewer>
</UserControl>
