<ResourceDictionary
    xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
    xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
    xmlns:sys="clr-namespace:System;assembly=mscorlib">

    <!--
        ══════════════════════════════════════════════════════════
        Layout sizing tokens
        ══════════════════════════════════════════════════════════
        Component-level fixed sizes used in templates / layouts:
        DataGrid row + header height, modal dialog width caps,
        filter combo box defaults, and the small Card-margin trio
        used inside flex / WrapPanel summary rows for first /
        middle / last positions.
    -->

    <sys:Double x:Key="DataGridRowHeight">52</sys:Double>
    <sys:Double x:Key="DataGridHeaderHeight">40</sys:Double>
    <sys:Double x:Key="DialogWidth">440</sys:Double>
    <sys:Double x:Key="DialogMaxHeight">720</sys:Double>
    <sys:Double x:Key="FilterComboWidth">120</sys:Double>
    <sys:Double x:Key="LegendDotSize">8</sys:Double>

    <Thickness x:Key="CardMarginLeft">0,0,4,0</Thickness>
    <Thickness x:Key="CardMarginCenter">2,0</Thickness>
    <Thickness x:Key="CardMarginRight">4,0,0,0</Thickness>

</ResourceDictionary>
