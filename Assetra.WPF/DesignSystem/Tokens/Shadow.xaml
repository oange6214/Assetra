<ResourceDictionary xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation" xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml">

    <!--  WPF-native elevation tokens. Keep shadows subtle for finance workflows.  -->
    <DropShadowEffect
        x:Key="Shadow.Sm"
        BlurRadius="8"
        Direction="270"
        Opacity="0.10"
        ShadowDepth="1"
        Color="#0F172A" />

    <DropShadowEffect
        x:Key="Shadow.Md"
        BlurRadius="18"
        Direction="270"
        Opacity="0.14"
        ShadowDepth="4"
        Color="#0F172A" />

    <!--
        P3.1 — Shadow.Card：對應 mockup HTML 的
        `box-shadow: 0 14px 36px rgba(15, 23, 42, 0.06)`。
        ShadowDepth=14 (Y offset)、BlurRadius=36、Opacity=0.06 = 非常 subtle。
        所有 page-level card (AppCardHero / AppCardSummary / AppCardSubtle)
        都 inherit 這層 elevation，建立「Wealth Platform」均一視覺重量。
    -->
    <DropShadowEffect
        x:Key="Shadow.Card"
        BlurRadius="36"
        Direction="270"
        Opacity="0.06"
        ShadowDepth="14"
        Color="#0F172A" />

    <DropShadowEffect
        x:Key="Shadow.Dialog"
        BlurRadius="28"
        Direction="270"
        Opacity="0.18"
        ShadowDepth="8"
        Color="#0F172A" />

</ResourceDictionary>
