<ResourceDictionary
    xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
    xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
    xmlns:sys="clr-namespace:System;assembly=mscorlib">

    <!--
        ══════════════════════════════════════════════════════════
        Typography tokens
        ══════════════════════════════════════════════════════════
        Font family + size scale used across the app.
        FontBase is the only family used; the platform fallback
        chain handles Win11 (Segoe UI Variable) -> Win10 / older
        (Segoe UI) -> CJK (微軟正黑體 / 雅黑體) -> generic sans.
    -->

    <FontFamily x:Key="FontBase">Segoe UI Variable Display, Segoe UI, Microsoft JhengHei UI, Microsoft YaHei UI, sans-serif</FontFamily>

    <sys:Double x:Key="FontSizeXs">12</sys:Double>
    <sys:Double x:Key="FontSizeSm">14</sys:Double>
    <sys:Double x:Key="FontSizeBase">16</sys:Double>
    <sys:Double x:Key="FontSizeMd">18</sys:Double>
    <sys:Double x:Key="FontSizeLg">20</sys:Double>
    <sys:Double x:Key="FontSizeXl">24</sys:Double>
    <sys:Double x:Key="FontSize2xl">32</sys:Double>
    <sys:Double x:Key="FontSize3xl">48</sys:Double>

</ResourceDictionary>
