<ResourceDictionary
    xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
    xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
    xmlns:sys="clr-namespace:System;assembly=mscorlib">

    <!--
        ══════════════════════════════════════════════════════════
        Typography tokens
        ══════════════════════════════════════════════════════════
        Font family + size scale used across the app.
        FontBase is the only family used; the platform fallback
        chain handles Win11 (Segoe UI Variable) -> Win10 / older
        (Segoe UI) -> CJK (微軟正黑體 / 雅黑體) -> generic sans.
    -->

    <FontFamily x:Key="Font.Family.Base">Segoe UI Variable Display, Segoe UI, Microsoft JhengHei UI, Microsoft YaHei UI, sans-serif</FontFamily>
    <sys:Double x:Key="Font.Size.Xs">12</sys:Double>
    <sys:Double x:Key="Font.Size.Sm">14</sys:Double>
    <sys:Double x:Key="Font.Size.Base">16</sys:Double>
    <sys:Double x:Key="Font.Size.Md">18</sys:Double>
    <sys:Double x:Key="Font.Size.Lg">20</sys:Double>
    <sys:Double x:Key="Font.Size.Xl">24</sys:Double>
    <sys:Double x:Key="Font.Size.2xl">32</sys:Double>
    <sys:Double x:Key="Font.Size.3xl">48</sys:Double>
    <FontWeight x:Key="Font.Weight.Regular">Regular</FontWeight>
    <FontWeight x:Key="Font.Weight.Medium">Medium</FontWeight>
    <FontWeight x:Key="Font.Weight.Semibold">SemiBold</FontWeight>

    <!--
        Line-height tokens — multiplied with font-size at consume time.
        Tight    : single-line dense displays (numerics, badges).
        Normal   : default body and most UI text.
        Relaxed  : long-form descriptive text (helper text, paragraphs).
    -->
    <sys:Double x:Key="LineHeight.Tight">1.0</sys:Double>
    <sys:Double x:Key="LineHeight.Normal">1.4</sys:Double>
    <sys:Double x:Key="LineHeight.Relaxed">1.6</sys:Double>

</ResourceDictionary>
