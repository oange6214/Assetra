<ResourceDictionary
    xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
    xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
    xmlns:sys="clr-namespace:System;assembly=mscorlib">

    <!--
        ══════════════════════════════════════════════════════════
        Typography tokens
        ══════════════════════════════════════════════════════════
        Font family + size scale used across the app.
        
        Assetra is a Windows-first, Traditional Chinese finance tool. Use
        Segoe UI Variable Text for dense controls and data-heavy views,
        Segoe UI Variable Display for headings, and keep numeric values on
        the UI family with tabular figures enabled by TextStyles.
    -->

    <FontFamily x:Key="Font.Family.UI">Segoe UI Variable Text, Segoe UI, Microsoft JhengHei UI, Noto Sans TC, Taipei Sans TC Beta, Microsoft YaHei UI, sans-serif</FontFamily>
    <FontFamily x:Key="Font.Family.Display">Segoe UI Variable Display, Segoe UI, Microsoft JhengHei UI, Noto Sans TC, Taipei Sans TC Beta, Microsoft YaHei UI, sans-serif</FontFamily>
    <FontFamily x:Key="Font.Family.Numeric">Segoe UI Variable Text, Segoe UI, Microsoft JhengHei UI, Noto Sans TC, Taipei Sans TC Beta, Microsoft YaHei UI, sans-serif</FontFamily>

    <!--  Back-compat alias for existing XAML. New styles should choose UI / Display / Numeric explicitly.  -->
    <FontFamily x:Key="Font.Family.Base">Segoe UI Variable Text, Segoe UI, Microsoft JhengHei UI, Noto Sans TC, Taipei Sans TC Beta, Microsoft YaHei UI, sans-serif</FontFamily>
    <sys:Double x:Key="Font.Size.2Xs">11</sys:Double>
    <sys:Double x:Key="Font.Size.Xs">12</sys:Double>
    <sys:Double x:Key="Font.Size.Sm">14</sys:Double>
    <sys:Double x:Key="Font.Size.Base">16</sys:Double>
    <sys:Double x:Key="Font.Size.Md">18</sys:Double>
    <sys:Double x:Key="Font.Size.Lg">20</sys:Double>
    <sys:Double x:Key="Font.Size.Xl">24</sys:Double>
    <sys:Double x:Key="Font.Size.2xl">32</sys:Double>
    <sys:Double x:Key="Font.Size.3xl">48</sys:Double>
    <FontWeight x:Key="Font.Weight.Regular">Regular</FontWeight>
    <FontWeight x:Key="Font.Weight.Medium">Medium</FontWeight>
    <FontWeight x:Key="Font.Weight.Semibold">SemiBold</FontWeight>

    <!--
        Line-height tokens — multiplied with font-size at consume time.
        Tight    : single-line dense displays (numerics, badges).
        Normal   : default body and most UI text.
        Relaxed  : long-form descriptive text (helper text, paragraphs).
    -->
    <sys:Double x:Key="LineHeight.Tight">1.0</sys:Double>
    <sys:Double x:Key="LineHeight.Normal">1.4</sys:Double>
    <sys:Double x:Key="LineHeight.Relaxed">1.6</sys:Double>

</ResourceDictionary>
