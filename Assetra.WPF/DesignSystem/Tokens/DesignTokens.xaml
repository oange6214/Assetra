<ResourceDictionary
    xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
    xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
    xmlns:sys="clr-namespace:System;assembly=mscorlib">

    <!--
        Assetra component-level design tokens.
        Primitive colour scale  → DesignSystem/Tokens/Colors.xaml  (loaded first)
        Runtime theme brushes  → DesignSystem/Themes/Light.xaml, Dark.xaml
    -->

    <!--  Component sizes  -->
    <sys:Double x:Key="Size.Button.Height">40</sys:Double>
    <sys:Double x:Key="Size.Input.Height">40</sys:Double>
    <sys:Double x:Key="Size.Table.RowHeight">44</sys:Double>
    <sys:Double x:Key="Size.Table.RowHeight.Compact">36</sys:Double>
    <sys:Double x:Key="Size.Sidebar.Width">200</sys:Double>
    <sys:Double x:Key="Size.Topbar.Height">64</sys:Double>

    <!--  Card defaults  -->
    <Thickness x:Key="Card.Padding">24</Thickness>
    <Thickness x:Key="Card.Padding.Compact">16</Thickness>
    <CornerRadius x:Key="Card.Radius">16</CornerRadius>

</ResourceDictionary>
