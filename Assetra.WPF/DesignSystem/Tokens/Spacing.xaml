<ResourceDictionary
    xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
    xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
    xmlns:sys="clr-namespace:System;assembly=mscorlib">

    <!--  Tailwind-inspired spacing scale. Values are device-independent pixels.  -->
    <sys:Double x:Key="Space.0">0</sys:Double>
    <sys:Double x:Key="Space.1">4</sys:Double>
    <sys:Double x:Key="Space.2">8</sys:Double>
    <sys:Double x:Key="Space.3">12</sys:Double>
    <sys:Double x:Key="Space.4">16</sys:Double>
    <sys:Double x:Key="Space.5">20</sys:Double>
    <sys:Double x:Key="Space.6">24</sys:Double>
    <sys:Double x:Key="Space.8">32</sys:Double>
    <sys:Double x:Key="Space.10">40</sys:Double>
    <sys:Double x:Key="Space.12">48</sys:Double>
    <sys:Double x:Key="Space.16">64</sys:Double>

    <Thickness x:Key="Padding.Button">14,0</Thickness>
    <Thickness x:Key="Padding.IconButton">0</Thickness>
    <Thickness x:Key="Padding.Card">16</Thickness>
    <Thickness x:Key="Padding.Page">24,20</Thickness>
    <Thickness x:Key="Padding.Dialog">24</Thickness>
    <Thickness x:Key="Margin.Section">0,16,0,0</Thickness>
    <Thickness x:Key="Gap.Form">12</Thickness>

    <!--
        Gap tokens — used for inter-element spacing in StackPanel children,
        Grid column/row gutters, and any place where a literal margin is
        otherwise hard-coded. Mirrors the form rhythm rules in the
        Fluent + Carbon plan.
    -->
    <sys:Double x:Key="Gap.Xs">4</sys:Double>
    <sys:Double x:Key="Gap.Sm">8</sys:Double>
    <sys:Double x:Key="Gap.Md">12</sys:Double>
    <sys:Double x:Key="Gap.Lg">16</sys:Double>
    <sys:Double x:Key="Gap.Xl">24</sys:Double>

</ResourceDictionary>
