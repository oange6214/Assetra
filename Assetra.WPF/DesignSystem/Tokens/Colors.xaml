<ResourceDictionary xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation" xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml">

    <!--
        Tailwind v4-inspired primitive colour scale.
        All values are sRGB hex equivalents of the Tailwind v4 palette.
        Theme-specific semantic brushes live in DesignSystem/Themes.
        Nothing outside this file should hard-code these hex values.
    -->

    <!--  Slate neutral scale (Tailwind v4, includes 950)  -->
    <Color x:Key="Color.Slate.50">#F8FAFC</Color>
    <Color x:Key="Color.Slate.100">#F1F5F9</Color>
    <Color x:Key="Color.Slate.200">#E2E8F0</Color>
    <Color x:Key="Color.Slate.300">#CBD5E1</Color>
    <Color x:Key="Color.Slate.400">#94A3B8</Color>
    <Color x:Key="Color.Slate.500">#64748B</Color>
    <Color x:Key="Color.Slate.600">#475569</Color>
    <Color x:Key="Color.Slate.700">#334155</Color>
    <Color x:Key="Color.Slate.800">#1E293B</Color>
    <Color x:Key="Color.Slate.900">#0F172A</Color>
    <Color x:Key="Color.Slate.950">#020617</Color>

    <!--  Green scale  -->
    <Color x:Key="Color.Green.500">#22C55E</Color>
    <Color x:Key="Color.Green.700">#15803D</Color>

    <!--  Red scale  -->
    <Color x:Key="Color.Red.50">#FEF2F2</Color>
    <Color x:Key="Color.Red.500">#EF4444</Color>
    <Color x:Key="Color.Red.600">#DC2626</Color>

    <!--  Amber scale  -->
    <Color x:Key="Color.Amber.400">#FBBF24</Color>
    <Color x:Key="Color.Amber.500">#F59E0B</Color>

    <!--  Blue scale  -->
    <Color x:Key="Color.Blue.300">#93C5FD</Color>
    <Color x:Key="Color.Blue.400">#60A5FA</Color>
    <Color x:Key="Color.Blue.500">#3B82F6</Color>

    <!--  Cyan scale  -->
    <Color x:Key="Color.Cyan.400">#22D3EE</Color>
    <Color x:Key="Color.Cyan.600">#0891B2</Color>

    <!--  Violet scale  -->
    <Color x:Key="Color.Violet.400">#A78BFA</Color>
    <Color x:Key="Color.Violet.800">#5B21B6</Color>

    <!--  Asset Management CIS brand palette  -->
    <Color x:Key="Color.Brand.Graphite">#0A0F1C</Color>
    <Color x:Key="Color.Brand.Navy">#14213D</Color>
    <Color x:Key="Color.Brand.NavyHover">#1B2E55</Color>
    <Color x:Key="Color.Brand.NavySubtle">#E6EAF2</Color>
    <Color x:Key="Color.Brand.NavySubtle.Dark">#1D2840</Color>
    <Color x:Key="Color.Brand.Gold">#C8A96B</Color>
    <Color x:Key="Color.Brand.GoldDark">#D7BB82</Color>
    <Color x:Key="Color.Brand.GoldHover">#B89654</Color>
    <Color x:Key="Color.Brand.GoldHover.Dark">#E6CB93</Color>
    <Color x:Key="Color.Brand.GoldSubtle">#F4EEE2</Color>
    <Color x:Key="Color.Brand.GoldSubtle.Dark">#3A3122</Color>
    <Color x:Key="Color.Brand.SurfaceGraphite">#1E2430</Color>
    <Color x:Key="Color.Brand.SoftWhite">#F7F8FA</Color>

    <!--  Asset Management CIS theme layers  -->
    <Color x:Key="Color.Cis.Dark.Background">#0A0F1C</Color>
    <Color x:Key="Color.Cis.Dark.Layer1">#121826</Color>
    <Color x:Key="Color.Cis.Dark.Layer2">#161B26</Color>
    <Color x:Key="Color.Cis.Dark.Layer3">#1D2433</Color>
    <Color x:Key="Color.Cis.Dark.TextPrimary">#F8FAFC</Color>
    <Color x:Key="Color.Cis.Dark.TextSecondary">#98A2B3</Color>
    <!--
        P2.16 — Light palette 微調對齊 UI redesign checklist：
          Background  F7F8FA → F5F7FA (audit 推薦，更冷一點)
          Border      E4E7EC → E2E5ED (rgba(15,23,42,0.08) ≈ #E2E5ED)
          NavRail     新加 #FBFCFD — 比 app bg 稍微亮一階、比 Surface 稍暗，
                      讓 NavRail / 主內容區 / 卡片三層 hierarchy 各有自己的
                      色階位置 (audit「精準對比」原則)
    -->
    <Color x:Key="Color.Cis.Light.Background">#F5F7FA</Color>
    <Color x:Key="Color.Cis.Light.Surface">#FFFFFF</Color>
    <Color x:Key="Color.Cis.Light.NavRail">#FBFCFD</Color>
    <Color x:Key="Color.Cis.Light.Border">#E2E5ED</Color>
    <Color x:Key="Color.Cis.Light.TextPrimary">#101828</Color>
    <Color x:Key="Color.Cis.Light.TextSecondary">#667085</Color>
    <!--
        Dark NavRail：跟 Background (Layer0) 稍微區分。Layer1 用於 Surface，
        NavRail 取兩者之間 — 視覺上 nav 區域既不跟 bg 融合也不跟 cards 一樣。
    -->
    <Color x:Key="Color.Cis.Dark.NavRail">#0E141F</Color>

    <!--  Utility  -->
    <Color x:Key="Color.White">#FFFFFF</Color>
    <Color x:Key="Color.Black">#000000</Color>

</ResourceDictionary>
