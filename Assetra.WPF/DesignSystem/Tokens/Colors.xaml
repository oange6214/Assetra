<ResourceDictionary
    xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
    xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml">

    <!--
        Tailwind v4-inspired primitive colour scale.
        All values are sRGB hex equivalents of the Tailwind v4 palette.
        Theme-specific semantic brushes live in DesignSystem/Themes.
        Nothing outside this file should hard-code these hex values.
    -->

    <!--  Slate neutral scale (Tailwind v4, includes 950)  -->
    <Color x:Key="Color.Slate.50">#F8FAFC</Color>
    <Color x:Key="Color.Slate.100">#F1F5F9</Color>
    <Color x:Key="Color.Slate.200">#E2E8F0</Color>
    <Color x:Key="Color.Slate.300">#CBD5E1</Color>
    <Color x:Key="Color.Slate.400">#94A3B8</Color>
    <Color x:Key="Color.Slate.500">#64748B</Color>
    <Color x:Key="Color.Slate.600">#475569</Color>
    <Color x:Key="Color.Slate.700">#334155</Color>
    <Color x:Key="Color.Slate.800">#1E293B</Color>
    <Color x:Key="Color.Slate.900">#0F172A</Color>
    <Color x:Key="Color.Slate.950">#020617</Color>

    <!--  Green scale  -->
    <Color x:Key="Color.Green.500">#22C55E</Color>
    <Color x:Key="Color.Green.700">#15803D</Color>

    <!--  Red scale  -->
    <Color x:Key="Color.Red.50">#FEF2F2</Color>
    <Color x:Key="Color.Red.500">#EF4444</Color>
    <Color x:Key="Color.Red.600">#DC2626</Color>

    <!--  Amber scale  -->
    <Color x:Key="Color.Amber.400">#FBBF24</Color>
    <Color x:Key="Color.Amber.500">#F59E0B</Color>

    <!--  Blue scale  -->
    <Color x:Key="Color.Blue.300">#93C5FD</Color>
    <Color x:Key="Color.Blue.400">#60A5FA</Color>
    <Color x:Key="Color.Blue.500">#3B82F6</Color>

    <!--  Cyan scale  -->
    <Color x:Key="Color.Cyan.400">#22D3EE</Color>
    <Color x:Key="Color.Cyan.600">#0891B2</Color>

    <!--  Violet scale  -->
    <Color x:Key="Color.Violet.400">#A78BFA</Color>
    <Color x:Key="Color.Violet.800">#5B21B6</Color>

    <!--  Brand palette  -->
    <Color x:Key="Color.Brand.Navy">#142F55</Color>
    <Color x:Key="Color.Brand.NavyHover">#1F4275</Color>
    <Color x:Key="Color.Brand.NavySubtle">#E5EAF1</Color>
    <Color x:Key="Color.Brand.NavySubtle.Dark">#1E3A5F</Color>
    <Color x:Key="Color.Brand.Gold">#C8A25A</Color>
    <Color x:Key="Color.Brand.GoldDark">#E6C27A</Color>
    <Color x:Key="Color.Brand.GoldHover">#B58D45</Color>
    <Color x:Key="Color.Brand.GoldHover.Dark">#F0D397</Color>
    <Color x:Key="Color.Brand.GoldSubtle">#F4ECDC</Color>
    <Color x:Key="Color.Brand.GoldSubtle.Dark">#3D3320</Color>

    <!--  Utility  -->
    <Color x:Key="Color.White">#FFFFFF</Color>
    <Color x:Key="Color.Black">#000000</Color>

</ResourceDictionary>
