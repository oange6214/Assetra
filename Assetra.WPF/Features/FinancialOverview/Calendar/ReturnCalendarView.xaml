<UserControl
    x:Class="Assetra.WPF.Features.FinancialOverview.Calendar.ReturnCalendarView"
    xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
    xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
    xmlns:cal="clr-namespace:Assetra.WPF.Features.FinancialOverview.Calendar"
    xmlns:d="http://schemas.microsoft.com/expression/blend/2008"
    xmlns:ds="clr-namespace:Assetra.WPF.DesignSystem.Controls"
    xmlns:lvc="clr-namespace:LiveChartsCore.SkiaSharpView.WPF;assembly=LiveChartsCore.SkiaSharpView.WPF"
    xmlns:mc="http://schemas.openxmlformats.org/markup-compatibility/2006"
    d:DataContext="{d:DesignInstance Type={x:Type cal:ReturnCalendarViewModel},
                                     IsDesignTimeCreatable=False}"
    Background="{DynamicResource AppBackground}"
    mc:Ignorable="d">

    <UserControl.Resources>
        <!--
            Stage 4：cell 視覺。Tone enum 決定背景色階；紅綠依台灣慣例
            （上漲紅、下跌綠）。非當月 / 無資料 cell 改用 muted。
        -->
        <Style x:Key="DayCellBorder" TargetType="Border">
            <Setter Property="Margin" Value="2" />
            <Setter Property="Padding" Value="6,4" />
            <Setter Property="BorderThickness" Value="1" />
            <Setter Property="BorderBrush" Value="{DynamicResource AppBorderLight}" />
            <Setter Property="CornerRadius" Value="{StaticResource Radius.Xs}" />
            <Setter Property="Background" Value="{DynamicResource AppCardBackground}" />
            <Style.Triggers>
                <DataTrigger Binding="{Binding IsCurrentMonth}" Value="False">
                    <Setter Property="Opacity" Value="0.35" />
                </DataTrigger>
                <DataTrigger Binding="{Binding Tone}" Value="UpWeak">
                    <Setter Property="Background" Value="#1AEF4444" />
                </DataTrigger>
                <DataTrigger Binding="{Binding Tone}" Value="UpMedium">
                    <Setter Property="Background" Value="#33EF4444" />
                </DataTrigger>
                <DataTrigger Binding="{Binding Tone}" Value="UpStrong">
                    <Setter Property="Background" Value="#66EF4444" />
                </DataTrigger>
                <DataTrigger Binding="{Binding Tone}" Value="UpStrongest">
                    <Setter Property="Background" Value="#99EF4444" />
                </DataTrigger>
                <DataTrigger Binding="{Binding Tone}" Value="DownWeak">
                    <Setter Property="Background" Value="#1A22C55E" />
                </DataTrigger>
                <DataTrigger Binding="{Binding Tone}" Value="DownMedium">
                    <Setter Property="Background" Value="#3322C55E" />
                </DataTrigger>
                <DataTrigger Binding="{Binding Tone}" Value="DownStrong">
                    <Setter Property="Background" Value="#6622C55E" />
                </DataTrigger>
                <DataTrigger Binding="{Binding Tone}" Value="DownStrongest">
                    <Setter Property="Background" Value="#9922C55E" />
                </DataTrigger>
            </Style.Triggers>
        </Style>

        <Style x:Key="WeekHeaderText" TargetType="TextBlock">
            <Setter Property="HorizontalAlignment" Value="Center" />
            <Setter Property="FontSize" Value="{StaticResource Font.Size.Xs}" />
            <Setter Property="Foreground" Value="{DynamicResource AppTextMuted}" />
            <Setter Property="FontWeight" Value="SemiBold" />
            <Setter Property="Margin" Value="0,0,0,6" />
        </Style>
    </UserControl.Resources>

    <Grid Margin="16">
        <Grid.RowDefinitions>
            <RowDefinition Height="Auto" />
            <!--  toolbar  -->
            <RowDefinition Height="Auto" />
            <!--  KPI line  -->
            <RowDefinition Height="Auto" />
            <!--  weekday header  -->
            <RowDefinition Height="*" MinHeight="280" />
            <!--  6x7 grid  -->
            <RowDefinition Height="Auto" />
            <!--  monthly bar chart  -->
        </Grid.RowDefinitions>

        <!--
            ── Toolbar：月份切換 ──
            ◄ ► 箭頭 + 月份下拉選單（保留兩種互動：快速翻頁與直接跳指定月份）。
        -->
        <DockPanel Grid.Row="0" Margin="0,0,0,8" LastChildFill="False">
            <Button DockPanel.Dock="Left"
                    Width="32" Height="32" Padding="0"
                    Command="{Binding GoPrevCommand}"
                    Style="{StaticResource AppIconButton}">
                <ds:AppIcon Symbol="ChevronLeft24" FontSize="{StaticResource Font.Size.Md}" />
            </Button>
            <!--  月份下拉：點開後直接選任一月份  -->
            <ComboBox DockPanel.Dock="Left"
                      Margin="8,0"
                      MinWidth="140"
                      Height="32"
                      ItemsSource="{Binding AvailableMonths}"
                      SelectedItem="{Binding CurrentMonth, Mode=TwoWay}">
                <ComboBox.ItemTemplate>
                    <DataTemplate>
                        <TextBlock Text="{Binding Year, StringFormat='0000'}">
                            <Run Text=" / " />
                            <Run Text="{Binding Month, StringFormat='00', Mode=OneWay}" />
                        </TextBlock>
                    </DataTemplate>
                </ComboBox.ItemTemplate>
            </ComboBox>
            <Button DockPanel.Dock="Left"
                    Width="32" Height="32" Padding="0"
                    Command="{Binding GoNextCommand}"
                    Style="{StaticResource AppIconButton}">
                <ds:AppIcon Symbol="ChevronRight24" FontSize="{StaticResource Font.Size.Md}" />
            </Button>
            <Button DockPanel.Dock="Right"
                    Padding="10,4"
                    Command="{Binding GoTodayCommand}"
                    Content="{DynamicResource Dashboard.Calendar.Today}"
                    Style="{StaticResource AppSecondaryButton}" />
        </DockPanel>

        <!--
            ── 月份 KPI line：當月 PnL + 報酬率 ──
            紅 / 綠依台灣慣例（漲紅跌綠），值為 0 時用 primary text。
            兩個 number TextBlock 用 Style + DataTrigger 切換 Foreground。
        -->
        <StackPanel Grid.Row="1" Margin="0,0,0,12" Orientation="Horizontal"
                    Visibility="{Binding HasData, Converter={StaticResource BooleanToVisibilityConverter}}">
            <TextBlock VerticalAlignment="Center"
                       FontSize="{StaticResource Font.Size.Xs}"
                       Foreground="{DynamicResource AppTextMuted}"
                       Text="{DynamicResource Dashboard.Calendar.MonthlyPnl}" />
            <TextBlock Margin="6,0,16,0"
                       VerticalAlignment="Center"
                       FontSize="{StaticResource Font.Size.Lg}"
                       FontWeight="SemiBold"
                       Text="{Binding MonthlyAbsolutePnl, StringFormat='+#\,##0;-#\,##0;0'}"
                       Typography.NumeralAlignment="Tabular">
                <TextBlock.Style>
                    <Style TargetType="TextBlock">
                        <Setter Property="Foreground" Value="{DynamicResource AppTextPrimary}" />
                        <Style.Triggers>
                            <DataTrigger Binding="{Binding IsMonthlyPnlPositive}" Value="True">
                                <Setter Property="Foreground" Value="{DynamicResource AppUp}" />
                            </DataTrigger>
                            <DataTrigger Binding="{Binding IsMonthlyPnlNegative}" Value="True">
                                <Setter Property="Foreground" Value="{DynamicResource AppDown}" />
                            </DataTrigger>
                        </Style.Triggers>
                    </Style>
                </TextBlock.Style>
            </TextBlock>
            <TextBlock VerticalAlignment="Center"
                       FontSize="{StaticResource Font.Size.Xs}"
                       Foreground="{DynamicResource AppTextMuted}"
                       Text="{DynamicResource Dashboard.Calendar.MonthlyReturn}" />
            <TextBlock Margin="6,0,0,0"
                       VerticalAlignment="Center"
                       FontSize="{StaticResource Font.Size.Lg}"
                       FontWeight="SemiBold"
                       Text="{Binding MonthlyReturnPct, StringFormat='+0.00%;-0.00%;0.00%'}"
                       Typography.NumeralAlignment="Tabular">
                <TextBlock.Style>
                    <Style TargetType="TextBlock">
                        <Setter Property="Foreground" Value="{DynamicResource AppTextPrimary}" />
                        <Style.Triggers>
                            <DataTrigger Binding="{Binding IsMonthlyPnlPositive}" Value="True">
                                <Setter Property="Foreground" Value="{DynamicResource AppUp}" />
                            </DataTrigger>
                            <DataTrigger Binding="{Binding IsMonthlyPnlNegative}" Value="True">
                                <Setter Property="Foreground" Value="{DynamicResource AppDown}" />
                            </DataTrigger>
                        </Style.Triggers>
                    </Style>
                </TextBlock.Style>
            </TextBlock>
        </StackPanel>

        <!--  ── Weekday header ── 7 天 + 1 個週合計欄  -->
        <Grid Grid.Row="2">
            <Grid.ColumnDefinitions>
                <ColumnDefinition Width="*" />
                <ColumnDefinition Width="*" />
                <ColumnDefinition Width="*" />
                <ColumnDefinition Width="*" />
                <ColumnDefinition Width="*" />
                <ColumnDefinition Width="*" />
                <ColumnDefinition Width="*" />
                <ColumnDefinition Width="80" />
                <!--  Weekly P&L column  -->
            </Grid.ColumnDefinitions>
            <TextBlock Grid.Column="0" Style="{StaticResource WeekHeaderText}" Text="{DynamicResource Dashboard.Calendar.Mon}" />
            <TextBlock Grid.Column="1" Style="{StaticResource WeekHeaderText}" Text="{DynamicResource Dashboard.Calendar.Tue}" />
            <TextBlock Grid.Column="2" Style="{StaticResource WeekHeaderText}" Text="{DynamicResource Dashboard.Calendar.Wed}" />
            <TextBlock Grid.Column="3" Style="{StaticResource WeekHeaderText}" Text="{DynamicResource Dashboard.Calendar.Thu}" />
            <TextBlock Grid.Column="4" Style="{StaticResource WeekHeaderText}" Text="{DynamicResource Dashboard.Calendar.Fri}" />
            <TextBlock Grid.Column="5" Style="{StaticResource WeekHeaderText}" Text="{DynamicResource Dashboard.Calendar.Sat}" />
            <TextBlock Grid.Column="6" Style="{StaticResource WeekHeaderText}" Text="{DynamicResource Dashboard.Calendar.Sun}" />
            <TextBlock Grid.Column="7" Style="{StaticResource WeekHeaderText}" Text="{DynamicResource Dashboard.Calendar.WeeklyPnl}" />
        </Grid>

        <!--
            ── 6 列 × (7 日 + 1 週合計) ──
            ItemsControl 跑 Weeks 集合；每列模板繪製 7 個日 cell + 1 個週合計。
            click cell → SelectCellCommand 開 popover；HasData=false 的 cell
            command 內部 return 不開啟。
        -->
        <ItemsControl Grid.Row="3" ItemsSource="{Binding Weeks}">
            <ItemsControl.ItemsPanel>
                <ItemsPanelTemplate>
                    <StackPanel />
                </ItemsPanelTemplate>
            </ItemsControl.ItemsPanel>
            <ItemsControl.ItemTemplate>
                <DataTemplate>
                    <Grid Height="46">
                        <Grid.ColumnDefinitions>
                            <ColumnDefinition Width="*" />
                            <ColumnDefinition Width="*" />
                            <ColumnDefinition Width="*" />
                            <ColumnDefinition Width="*" />
                            <ColumnDefinition Width="*" />
                            <ColumnDefinition Width="*" />
                            <ColumnDefinition Width="*" />
                            <ColumnDefinition Width="80" />
                        </Grid.ColumnDefinitions>
                        <!--  7 個日 cell  -->
                        <ItemsControl Grid.Column="0" Grid.ColumnSpan="7" ItemsSource="{Binding Days}">
                            <ItemsControl.ItemsPanel>
                                <ItemsPanelTemplate>
                                    <UniformGrid Columns="7" />
                                </ItemsPanelTemplate>
                            </ItemsControl.ItemsPanel>
                            <ItemsControl.ItemTemplate>
                                <DataTemplate>
                                    <Border Style="{StaticResource DayCellBorder}" Cursor="Hand">
                                        <Border.InputBindings>
                                            <MouseBinding MouseAction="LeftClick"
                                                          Command="{Binding DataContext.SelectCellCommand, RelativeSource={RelativeSource AncestorType=UserControl}}"
                                                          CommandParameter="{Binding}" />
                                        </Border.InputBindings>
                                        <StackPanel>
                                            <TextBlock FontSize="{StaticResource Font.Size.Sm}"
                                                       FontWeight="SemiBold"
                                                       Foreground="{DynamicResource AppTextPrimary}"
                                                       Text="{Binding Day}" />
                                            <TextBlock FontSize="{StaticResource Font.Size.Xs}"
                                                       Foreground="{DynamicResource AppTextSecondary}"
                                                       Text="{Binding DeltaDisplay}"
                                                       Typography.NumeralAlignment="Tabular"
                                                       Visibility="{Binding HasData, Converter={StaticResource BooleanToVisibilityConverter}}" />
                                        </StackPanel>
                                    </Border>
                                </DataTemplate>
                            </ItemsControl.ItemTemplate>
                        </ItemsControl>
                        <!--  週合計 cell  -->
                        <Border Grid.Column="7"
                                Margin="2"
                                Padding="6,4"
                                Background="{DynamicResource AppHover}"
                                BorderBrush="{DynamicResource AppBorderLight}"
                                BorderThickness="1"
                                CornerRadius="{StaticResource Radius.Xs}">
                            <TextBlock VerticalAlignment="Center"
                                       HorizontalAlignment="Right"
                                       FontFamily="{StaticResource Font.Family.Base}"
                                       FontSize="{StaticResource Font.Size.Xs}"
                                       FontWeight="SemiBold"
                                       Foreground="{DynamicResource AppTextPrimary}"
                                       Text="{Binding TotalDisplay}"
                                       Typography.NumeralAlignment="Tabular" />
                        </Border>
                    </Grid>
                </DataTemplate>
            </ItemsControl.ItemTemplate>
        </ItemsControl>

        <!--
            ── 月份迷你 bar chart ──
            每日 PnL 直方圖：紅柱為當日獲利，綠柱為當日虧損。視覺上補充
            熱度圖看不出的「分布感」— 月初密集還是月底密集？極端值在何處？
        -->
        <Border Grid.Row="4"
                Margin="0,12,0,0"
                Padding="0"
                Background="Transparent"
                Visibility="{Binding HasData, Converter={StaticResource BooleanToVisibilityConverter}}">
            <lvc:CartesianChart
                Height="100"
                Background="Transparent"
                Series="{Binding MonthlyBarSeries}"
                XAxes="{Binding BarXAxes}"
                YAxes="{Binding BarYAxes}"
                TooltipPosition="Top"
                TooltipTextSize="10" />
        </Border>

        <!--
            ── Cell popover ──
            點 cell 後彈出當日明細摘要 + 「跳到當日交易」link。整層蓋滿 Grid
            才能在四個 row 上方居中；click 背景關閉。
        -->
        <Grid Grid.RowSpan="5" Panel.ZIndex="180"
              Visibility="{Binding IsCellPopoverOpen, Converter={StaticResource BooleanToVisibilityConverter}}">
            <!--  半透明 backdrop  -->
            <Border Background="#80000000">
                <Border.InputBindings>
                    <MouseBinding MouseAction="LeftClick" Command="{Binding CloseCellPopoverCommand}" />
                </Border.InputBindings>
            </Border>
            <!--  popover content card  -->
            <Border HorizontalAlignment="Center" VerticalAlignment="Center"
                    Width="320" Padding="20,16"
                    Background="{DynamicResource AppCardBackground}"
                    BorderBrush="{DynamicResource AppBorder}"
                    BorderThickness="1"
                    CornerRadius="{StaticResource Radius.Md}">
                <StackPanel>
                    <DockPanel Margin="0,0,0,8" LastChildFill="False">
                        <TextBlock DockPanel.Dock="Left"
                                   FontSize="{StaticResource Font.Size.Md}"
                                   FontWeight="SemiBold"
                                   Foreground="{DynamicResource AppTextPrimary}">
                            <Run Text="{Binding SelectedCell.Date.Year, FallbackValue=''}" />
                            <Run Text="/" />
                            <Run Text="{Binding SelectedCell.Date.Month, StringFormat='00', FallbackValue='', Mode=OneWay}" />
                            <Run Text="/" />
                            <Run Text="{Binding SelectedCell.Date.Day, StringFormat='00', FallbackValue='', Mode=OneWay}" />
                        </TextBlock>
                        <Button DockPanel.Dock="Right" Width="28" Height="28" Padding="0"
                                Command="{Binding CloseCellPopoverCommand}"
                                Style="{StaticResource AppIconButton}">
                            <ds:AppIcon Symbol="Dismiss24" FontSize="14"
                                        Foreground="{DynamicResource AppTextMuted}" />
                        </Button>
                    </DockPanel>
                    <TextBlock FontSize="{StaticResource Font.Size.Xs}"
                               Foreground="{DynamicResource AppTextMuted}"
                               Text="{DynamicResource Dashboard.Calendar.Popover.DailyPnl}" />
                    <TextBlock Margin="0,4,0,12"
                               FontSize="{StaticResource Font.Size.Xl}"
                               FontWeight="SemiBold"
                               Text="{Binding SelectedCell.DeltaDisplay, FallbackValue='—'}"
                               Typography.NumeralAlignment="Tabular">
                        <TextBlock.Style>
                            <Style TargetType="TextBlock">
                                <Setter Property="Foreground" Value="{DynamicResource AppTextPrimary}" />
                            </Style>
                        </TextBlock.Style>
                    </TextBlock>
                    <Button Command="{Binding OpenDayTransactionsCommand}"
                            Content="{DynamicResource Dashboard.Calendar.Popover.OpenTransactions}"
                            HorizontalAlignment="Stretch"
                            Style="{StaticResource AppSecondaryButton}" />
                </StackPanel>
            </Border>
        </Grid>
    </Grid>
</UserControl>
