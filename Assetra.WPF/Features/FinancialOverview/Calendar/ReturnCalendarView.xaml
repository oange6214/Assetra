<UserControl
    x:Class="Assetra.WPF.Features.FinancialOverview.Calendar.ReturnCalendarView"
    xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
    xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
    xmlns:cal="clr-namespace:Assetra.WPF.Features.FinancialOverview.Calendar"
    xmlns:d="http://schemas.microsoft.com/expression/blend/2008"
    xmlns:ds="clr-namespace:Assetra.WPF.DesignSystem.Controls"
    xmlns:lvc="clr-namespace:LiveChartsCore.SkiaSharpView.WPF;assembly=LiveChartsCore.SkiaSharpView.WPF"
    xmlns:mc="http://schemas.openxmlformats.org/markup-compatibility/2006"
    d:DataContext="{d:DesignInstance Type={x:Type cal:ReturnCalendarViewModel},
                                     IsDesignTimeCreatable=False}"
    Background="{DynamicResource AppBackground}"
    mc:Ignorable="d">

    <UserControl.Resources>
        <!--
            P3.4 — DayCellBorder 從「整格實色」(GitHub heatmap 風) 改成
            「上半 subtle 漸層」(Wealth Behavior Journal 風)：
            每個 tone level 用 LinearGradientBrush 從頂端微透明色 fade 到
            底部 transparent (offset 0.68)，視覺上像「這天有事件、淡淡標記
            一下」而不是整格被色塊轟炸。Opacity 比之前少 ~30%（原 99→
            new top alpha 33 max），跟 mockup `linear-gradient(180deg,
            rgba(...,.09), transparent 68%)` 對齊風格。
        -->
        <Style x:Key="DayCellBorder" TargetType="Border">
            <Setter Property="Margin" Value="2" />
            <Setter Property="Padding" Value="6,4" />
            <Setter Property="BorderThickness" Value="1" />
            <Setter Property="BorderBrush" Value="{DynamicResource AppBorderLight}" />
            <Setter Property="CornerRadius" Value="{StaticResource Radius.Sm}" />
            <Setter Property="Background" Value="{DynamicResource AppCardBackground}" />
            <Style.Triggers>
                <DataTrigger Binding="{Binding IsCurrentMonth}" Value="False">
                    <Setter Property="Opacity" Value="0.35" />
                </DataTrigger>
                <DataTrigger Binding="{Binding Tone}" Value="UpWeak">
                    <Setter Property="Background">
                        <Setter.Value>
                            <LinearGradientBrush StartPoint="0,0" EndPoint="0,1">
                                <GradientStop Offset="0" Color="#14EF4444" />
                                <GradientStop Offset="0.68" Color="#00EF4444" />
                            </LinearGradientBrush>
                        </Setter.Value>
                    </Setter>
                </DataTrigger>
                <DataTrigger Binding="{Binding Tone}" Value="UpMedium">
                    <Setter Property="Background">
                        <Setter.Value>
                            <LinearGradientBrush StartPoint="0,0" EndPoint="0,1">
                                <GradientStop Offset="0" Color="#1FEF4444" />
                                <GradientStop Offset="0.68" Color="#00EF4444" />
                            </LinearGradientBrush>
                        </Setter.Value>
                    </Setter>
                </DataTrigger>
                <DataTrigger Binding="{Binding Tone}" Value="UpStrong">
                    <Setter Property="Background">
                        <Setter.Value>
                            <LinearGradientBrush StartPoint="0,0" EndPoint="0,1">
                                <GradientStop Offset="0" Color="#2EEF4444" />
                                <GradientStop Offset="0.68" Color="#00EF4444" />
                            </LinearGradientBrush>
                        </Setter.Value>
                    </Setter>
                </DataTrigger>
                <DataTrigger Binding="{Binding Tone}" Value="UpStrongest">
                    <Setter Property="Background">
                        <Setter.Value>
                            <LinearGradientBrush StartPoint="0,0" EndPoint="0,1">
                                <GradientStop Offset="0" Color="#3DEF4444" />
                                <GradientStop Offset="0.68" Color="#00EF4444" />
                            </LinearGradientBrush>
                        </Setter.Value>
                    </Setter>
                </DataTrigger>
                <DataTrigger Binding="{Binding Tone}" Value="DownWeak">
                    <Setter Property="Background">
                        <Setter.Value>
                            <LinearGradientBrush StartPoint="0,0" EndPoint="0,1">
                                <GradientStop Offset="0" Color="#1422C55E" />
                                <GradientStop Offset="0.68" Color="#0022C55E" />
                            </LinearGradientBrush>
                        </Setter.Value>
                    </Setter>
                </DataTrigger>
                <DataTrigger Binding="{Binding Tone}" Value="DownMedium">
                    <Setter Property="Background">
                        <Setter.Value>
                            <LinearGradientBrush StartPoint="0,0" EndPoint="0,1">
                                <GradientStop Offset="0" Color="#1F22C55E" />
                                <GradientStop Offset="0.68" Color="#0022C55E" />
                            </LinearGradientBrush>
                        </Setter.Value>
                    </Setter>
                </DataTrigger>
                <DataTrigger Binding="{Binding Tone}" Value="DownStrong">
                    <Setter Property="Background">
                        <Setter.Value>
                            <LinearGradientBrush StartPoint="0,0" EndPoint="0,1">
                                <GradientStop Offset="0" Color="#2E22C55E" />
                                <GradientStop Offset="0.68" Color="#0022C55E" />
                            </LinearGradientBrush>
                        </Setter.Value>
                    </Setter>
                </DataTrigger>
                <DataTrigger Binding="{Binding Tone}" Value="DownStrongest">
                    <Setter Property="Background">
                        <Setter.Value>
                            <LinearGradientBrush StartPoint="0,0" EndPoint="0,1">
                                <GradientStop Offset="0" Color="#3D22C55E" />
                                <GradientStop Offset="0.68" Color="#0022C55E" />
                            </LinearGradientBrush>
                        </Setter.Value>
                    </Setter>
                </DataTrigger>
            </Style.Triggers>
        </Style>

        <!--
            P3.4 — 「極端日」dot indicator (8px circle at bottom-left of day cell)。
            Strong / Strongest tone 時可見，顏色 = 漲跌色，讓使用者掃月曆能立刻
            看出「這幾天波動大」— mockup 提的 Wealth Behavior Journal 行為標記。
        -->
        <Style x:Key="DayExtremeDot" TargetType="Ellipse">
            <Setter Property="Width" Value="8" />
            <Setter Property="Height" Value="8" />
            <Setter Property="HorizontalAlignment" Value="Left" />
            <Setter Property="VerticalAlignment" Value="Bottom" />
            <Setter Property="Visibility" Value="Collapsed" />
            <Style.Triggers>
                <DataTrigger Binding="{Binding Tone}" Value="UpStrong">
                    <Setter Property="Visibility" Value="Visible" />
                    <Setter Property="Fill" Value="{DynamicResource AppUp}" />
                </DataTrigger>
                <DataTrigger Binding="{Binding Tone}" Value="UpStrongest">
                    <Setter Property="Visibility" Value="Visible" />
                    <Setter Property="Fill" Value="{DynamicResource AppUp}" />
                </DataTrigger>
                <DataTrigger Binding="{Binding Tone}" Value="DownStrong">
                    <Setter Property="Visibility" Value="Visible" />
                    <Setter Property="Fill" Value="{DynamicResource AppDown}" />
                </DataTrigger>
                <DataTrigger Binding="{Binding Tone}" Value="DownStrongest">
                    <Setter Property="Visibility" Value="Visible" />
                    <Setter Property="Fill" Value="{DynamicResource AppDown}" />
                </DataTrigger>
            </Style.Triggers>
        </Style>

        <Style x:Key="WeekHeaderText" TargetType="TextBlock">
            <Setter Property="HorizontalAlignment" Value="Center" />
            <Setter Property="FontSize" Value="{StaticResource Font.Size.Xs}" />
            <Setter Property="Foreground" Value="{DynamicResource AppTextMuted}" />
            <Setter Property="FontWeight" Value="SemiBold" />
            <Setter Property="Margin" Value="0,0,0,6" />
        </Style>
    </UserControl.Resources>

    <Grid Style="{StaticResource PageRootGrid}">
        <!--
            P3.6 — Calendar outer wrapper migrated to AppCardSummary baseline
            跟其他頁面 (Overview / Trend / Allocation) 同 design language。
        -->
        <Border Style="{StaticResource AppCardSummary}">
            <Grid>
                <Grid.RowDefinitions>
                    <RowDefinition Height="Auto" />
                    <!--  toolbar  -->
                    <RowDefinition Height="Auto" />
                    <!--  KPI line  -->
                    <RowDefinition Height="Auto" />
                    <!--  weekday header  -->
                    <RowDefinition Height="*" MinHeight="280" />
                    <!--  6 列 × 8 col grid（含週合計欄）— 拉伸填滿主要空間，使每列等高  -->
                    <RowDefinition Height="Auto" />
                    <!--  monthly bar chart：固定 100px 高，緊貼月曆下方  -->
                </Grid.RowDefinitions>

                <DockPanel
                    Grid.Row="0"
                    Margin="0,0,0,8"
                    LastChildFill="False">
                    <Button
                        Width="32"
                        Height="32"
                        Padding="0"
                        Command="{Binding GoPrevCommand}"
                        DockPanel.Dock="Left"
                        IsEnabled="{Binding CanGoPrev}"
                        Style="{StaticResource AppIconButton}">
                        <ds:AppIcon FontSize="{StaticResource Font.Size.Md}" Symbol="ChevronLeft24" />
                    </Button>

                    <ComboBox
                        Height="32"
                        MinWidth="140"
                        Margin="8,0"
                        DockPanel.Dock="Left"
                        ItemsSource="{Binding AvailableMonths}"
                        SelectedValue="{Binding CurrentMonth, Mode=TwoWay}"
                        SelectedValuePath="Value">
                        <ComboBox.ItemTemplate>
                            <DataTemplate>
                                <TextBlock Text="{Binding Display}" />
                            </DataTemplate>
                        </ComboBox.ItemTemplate>
                    </ComboBox>
                    <Button
                        Width="32"
                        Height="32"
                        Padding="0"
                        Command="{Binding GoNextCommand}"
                        DockPanel.Dock="Left"
                        IsEnabled="{Binding CanGoNext}"
                        Style="{StaticResource AppIconButton}">
                        <ds:AppIcon FontSize="{StaticResource Font.Size.Md}" Symbol="ChevronRight24" />
                    </Button>
                    <Button
                        Padding="10,4"
                        Command="{Binding GoTodayCommand}"
                        Content="{DynamicResource Dashboard.Calendar.Today}"
                        DockPanel.Dock="Right"
                        Style="{StaticResource AppSecondaryButton}" />
                    <!--  v2：絕對值 / 百分比 色階切換  -->
                    <CheckBox
                        Margin="0,0,12,0"
                        VerticalAlignment="Center"
                        DockPanel.Dock="Right"
                        IsChecked="{Binding UseAbsoluteForTone, Mode=TwoWay}"
                        ToolTip="{DynamicResource Dashboard.Calendar.UseAbsolute.Tooltip}">
                        <TextBlock
                            FontSize="{StaticResource Font.Size.Xs}"
                            Foreground="{DynamicResource AppTextSecondary}"
                            Text="{DynamicResource Dashboard.Calendar.UseAbsolute}" />
                    </CheckBox>
                    <!--  v2 #6d：年度熱度圖切換（GitHub contribution graph 風格）  -->
                    <CheckBox
                        Margin="0,0,12,0"
                        VerticalAlignment="Center"
                        DockPanel.Dock="Right"
                        IsChecked="{Binding IsYearView, Mode=TwoWay}">
                        <TextBlock
                            FontSize="{StaticResource Font.Size.Xs}"
                            Foreground="{DynamicResource AppTextSecondary}"
                            Text="{DynamicResource Dashboard.Calendar.YearView}" />
                    </CheckBox>
                </DockPanel>

                <!--
                    ── 月份 KPI line：當月 PnL + 報酬率 ──
                -->
                <StackPanel
                    Grid.Row="1"
                    Margin="0,0,0,12"
                    Orientation="Horizontal"
                    Visibility="{Binding HasData, Converter={StaticResource BooleanToVisibilityConverter}}">
                    <TextBlock
                        VerticalAlignment="Center"
                        FontSize="{StaticResource Font.Size.Xs}"
                        Foreground="{DynamicResource AppTextMuted}"
                        Text="{DynamicResource Dashboard.Calendar.MonthlyPnl}" />
                    <TextBlock
                        Margin="6,0,16,0"
                        VerticalAlignment="Center"
                        FontSize="{StaticResource Font.Size.Lg}"
                        FontWeight="SemiBold"
                        Text="{Binding MonthlyAbsolutePnl, StringFormat='+#\,##0;-#\,##0;0'}"
                        Typography.NumeralAlignment="Tabular">
                        <TextBlock.Style>
                            <Style TargetType="TextBlock">
                                <Setter Property="Foreground" Value="{DynamicResource AppTextPrimary}" />
                                <Style.Triggers>
                                    <DataTrigger Binding="{Binding IsMonthlyPnlPositive}" Value="True">
                                        <Setter Property="Foreground" Value="{DynamicResource AppUp}" />
                                    </DataTrigger>
                                    <DataTrigger Binding="{Binding IsMonthlyPnlNegative}" Value="True">
                                        <Setter Property="Foreground" Value="{DynamicResource AppDown}" />
                                    </DataTrigger>
                                </Style.Triggers>
                            </Style>
                        </TextBlock.Style>
                    </TextBlock>
                    <TextBlock
                        VerticalAlignment="Center"
                        FontSize="{StaticResource Font.Size.Xs}"
                        Foreground="{DynamicResource AppTextMuted}"
                        Text="{DynamicResource Dashboard.Calendar.MonthlyReturn}" />
                    <TextBlock
                        Margin="6,0,0,0"
                        VerticalAlignment="Center"
                        FontSize="{StaticResource Font.Size.Lg}"
                        FontWeight="SemiBold"
                        Text="{Binding MonthlyReturnPct, StringFormat='+0.00%;-0.00%;0.00%'}"
                        Typography.NumeralAlignment="Tabular">
                        <TextBlock.Style>
                            <Style TargetType="TextBlock">
                                <Setter Property="Foreground" Value="{DynamicResource AppTextPrimary}" />
                                <Style.Triggers>
                                    <DataTrigger Binding="{Binding IsMonthlyPnlPositive}" Value="True">
                                        <Setter Property="Foreground" Value="{DynamicResource AppUp}" />
                                    </DataTrigger>
                                    <DataTrigger Binding="{Binding IsMonthlyPnlNegative}" Value="True">
                                        <Setter Property="Foreground" Value="{DynamicResource AppDown}" />
                                    </DataTrigger>
                                </Style.Triggers>
                            </Style>
                        </TextBlock.Style>
                    </TextBlock>
                </StackPanel>

                <!--  ── Weekday header ── 7 天 + 1 個週合計欄 (年度檢視時隱藏)  -->
                <Grid Grid.Row="2" Visibility="{Binding IsYearView, Converter={StaticResource InverseBooleanToVisibilityConverter}}">
                    <Grid.ColumnDefinitions>
                        <ColumnDefinition Width="*" />
                        <ColumnDefinition Width="*" />
                        <ColumnDefinition Width="*" />
                        <ColumnDefinition Width="*" />
                        <ColumnDefinition Width="*" />
                        <ColumnDefinition Width="*" />
                        <ColumnDefinition Width="*" />
                        <ColumnDefinition Width="80" />
                        <!--  Weekly P&L column  -->
                    </Grid.ColumnDefinitions>
                    <TextBlock
                        Grid.Column="0"
                        Style="{StaticResource WeekHeaderText}"
                        Text="{DynamicResource Dashboard.Calendar.Mon}" />
                    <TextBlock
                        Grid.Column="1"
                        Style="{StaticResource WeekHeaderText}"
                        Text="{DynamicResource Dashboard.Calendar.Tue}" />
                    <TextBlock
                        Grid.Column="2"
                        Style="{StaticResource WeekHeaderText}"
                        Text="{DynamicResource Dashboard.Calendar.Wed}" />
                    <TextBlock
                        Grid.Column="3"
                        Style="{StaticResource WeekHeaderText}"
                        Text="{DynamicResource Dashboard.Calendar.Thu}" />
                    <TextBlock
                        Grid.Column="4"
                        Style="{StaticResource WeekHeaderText}"
                        Text="{DynamicResource Dashboard.Calendar.Fri}" />
                    <TextBlock
                        Grid.Column="5"
                        Style="{StaticResource WeekHeaderText}"
                        Text="{DynamicResource Dashboard.Calendar.Sat}" />
                    <TextBlock
                        Grid.Column="6"
                        Style="{StaticResource WeekHeaderText}"
                        Text="{DynamicResource Dashboard.Calendar.Sun}" />
                    <TextBlock
                        Grid.Column="7"
                        Style="{StaticResource WeekHeaderText}"
                        Text="{DynamicResource Dashboard.Calendar.WeeklyPnl}" />
                </Grid>

                <!--
                    ── 6 列 × (7 日 + 1 週合計) ──
                -->
                <ItemsControl
                    Grid.Row="3"
                    ItemsSource="{Binding Weeks}"
                    Visibility="{Binding IsYearView, Converter={StaticResource InverseBooleanToVisibilityConverter}}">
                    <ItemsControl.ItemsPanel>
                        <ItemsPanelTemplate>
                            <UniformGrid Rows="6" />
                        </ItemsPanelTemplate>
                    </ItemsControl.ItemsPanel>
                    <ItemsControl.ItemTemplate>
                        <DataTemplate>
                            <Grid MinHeight="42">
                                <Grid.ColumnDefinitions>
                                    <ColumnDefinition Width="*" />
                                    <ColumnDefinition Width="*" />
                                    <ColumnDefinition Width="*" />
                                    <ColumnDefinition Width="*" />
                                    <ColumnDefinition Width="*" />
                                    <ColumnDefinition Width="*" />
                                    <ColumnDefinition Width="*" />
                                    <ColumnDefinition Width="80" />
                                </Grid.ColumnDefinitions>
                                <!--  7 個日 cell  -->
                                <ItemsControl
                                    Grid.Column="0"
                                    Grid.ColumnSpan="7"
                                    ItemsSource="{Binding Days}">
                                    <ItemsControl.ItemsPanel>
                                        <ItemsPanelTemplate>
                                            <UniformGrid Columns="7" />
                                        </ItemsPanelTemplate>
                                    </ItemsControl.ItemsPanel>
                                    <ItemsControl.ItemTemplate>
                                        <DataTemplate>
                                            <Border Cursor="Hand" Style="{StaticResource DayCellBorder}">
                                                <Border.InputBindings>
                                                    <MouseBinding
                                                        Command="{Binding DataContext.SelectCellCommand, RelativeSource={RelativeSource AncestorType=UserControl}}"
                                                        CommandParameter="{Binding}"
                                                        MouseAction="LeftClick" />
                                                </Border.InputBindings>
                                                <Grid>
                                                    <StackPanel>
                                                        <TextBlock
                                                            FontSize="{StaticResource Font.Size.Sm}"
                                                            FontWeight="SemiBold"
                                                            Foreground="{DynamicResource AppTextPrimary}"
                                                            Text="{Binding Day}" />
                                                        <TextBlock
                                                            FontSize="{StaticResource Font.Size.Xs}"
                                                            Foreground="{DynamicResource AppTextSecondary}"
                                                            Text="{Binding DeltaDisplay}"
                                                            Typography.NumeralAlignment="Tabular"
                                                            Visibility="{Binding HasData, Converter={StaticResource BooleanToVisibilityConverter}}" />
                                                    </StackPanel>
                                                    <!--  P3.4 — 極端日 dot indicator (bottom-left)  -->
                                                    <Ellipse Style="{StaticResource DayExtremeDot}" />
                                                </Grid>
                                            </Border>
                                        </DataTemplate>
                                    </ItemsControl.ItemTemplate>
                                </ItemsControl>
                                <!--  週合計 cell  -->
                                <Border
                                    Grid.Column="7"
                                    Margin="2"
                                    Padding="6,4"
                                    Background="{DynamicResource AppHover}"
                                    BorderBrush="{DynamicResource AppBorderLight}"
                                    BorderThickness="1"
                                    CornerRadius="{StaticResource Radius.Xs}">
                                    <TextBlock
                                        HorizontalAlignment="Right"
                                        VerticalAlignment="Center"
                                        FontFamily="{StaticResource Font.Family.Base}"
                                        FontSize="{StaticResource Font.Size.Xs}"
                                        FontWeight="SemiBold"
                                        Foreground="{DynamicResource AppTextPrimary}"
                                        Text="{Binding TotalDisplay}"
                                        Typography.NumeralAlignment="Tabular" />
                                </Border>
                            </Grid>
                        </DataTemplate>
                    </ItemsControl.ItemTemplate>
                </ItemsControl>

                <!--
                    ── v2 #6d：年度熱度圖（IsYearView=true 時取代月份 grid）──
                    GitHub-style：嚴格 7-row × ~54-col grid（Mon..Sun 為 row）。
                    每 column = 一週；月份標籤在每月首週欄的 column 上方。
                -->
                <!--
                    Viewbox 包裹整個年度熱度圖讓固定尺寸 (10x10 cell, 12 column pitch)
                    自動延展填滿可用寬度；Stretch=Uniform 保持 7-row 比例不變形。
                    StretchDirection=UpOnly 避免小窗時把 cell 縮到不可辨識。
                -->
                <Viewbox
                    Grid.Row="3"
                    HorizontalAlignment="Stretch"
                    VerticalAlignment="Top"
                    Stretch="Uniform"
                    StretchDirection="UpOnly"
                    Visibility="{Binding IsYearView, Converter={StaticResource BooleanToVisibilityConverter}}">
                    <StackPanel>
                        <!--  Month labels row：每欄一個 label（多數空白，每月首週欄有月份字）  -->
                        <ItemsControl Margin="0,0,0,4" ItemsSource="{Binding YearViewWeekColumns}">
                            <ItemsControl.ItemsPanel>
                                <ItemsPanelTemplate>
                                    <StackPanel Orientation="Horizontal" />
                                </ItemsPanelTemplate>
                            </ItemsControl.ItemsPanel>
                            <ItemsControl.ItemTemplate>
                                <DataTemplate>
                                    <TextBlock
                                        Width="12"
                                        Margin="1,0"
                                        FontSize="{StaticResource Font.Size.Xs}"
                                        Foreground="{DynamicResource AppTextMuted}"
                                        Text="{Binding MonthLabel}" />
                                </DataTemplate>
                            </ItemsControl.ItemTemplate>
                        </ItemsControl>

                        <!--  7-row × N-col 熱度圖：每 column 是 7 個 day cell 的垂直 stack  -->
                        <ItemsControl ItemsSource="{Binding YearViewWeekColumns}">
                            <ItemsControl.ItemsPanel>
                                <ItemsPanelTemplate>
                                    <StackPanel Orientation="Horizontal" />
                                </ItemsPanelTemplate>
                            </ItemsControl.ItemsPanel>
                            <ItemsControl.ItemTemplate>
                                <DataTemplate>
                                    <ItemsControl ItemsSource="{Binding Days}">
                                        <ItemsControl.ItemsPanel>
                                            <ItemsPanelTemplate>
                                                <StackPanel Orientation="Vertical" />
                                            </ItemsPanelTemplate>
                                        </ItemsControl.ItemsPanel>
                                        <ItemsControl.ItemTemplate>
                                            <DataTemplate>
                                                <Border
                                                    Width="10"
                                                    Height="10"
                                                    Margin="1"
                                                    BorderBrush="{DynamicResource AppBorderLight}"
                                                    BorderThickness="0.5"
                                                    CornerRadius="2">
                                                    <Border.Style>
                                                        <Style TargetType="Border">
                                                            <Setter Property="Background" Value="{DynamicResource AppCardBackground}" />
                                                            <Style.Triggers>
                                                                <!--  null cell（跨年 placeholder）：透明  -->
                                                                <DataTrigger Binding="{Binding}" Value="{x:Null}">
                                                                    <Setter Property="Background" Value="Transparent" />
                                                                    <Setter Property="BorderBrush" Value="Transparent" />
                                                                </DataTrigger>
                                                                <DataTrigger Binding="{Binding Tone}" Value="UpWeak">
                                                                    <Setter Property="Background" Value="#1AEF4444" />
                                                                </DataTrigger>
                                                                <DataTrigger Binding="{Binding Tone}" Value="UpMedium">
                                                                    <Setter Property="Background" Value="#33EF4444" />
                                                                </DataTrigger>
                                                                <DataTrigger Binding="{Binding Tone}" Value="UpStrong">
                                                                    <Setter Property="Background" Value="#66EF4444" />
                                                                </DataTrigger>
                                                                <DataTrigger Binding="{Binding Tone}" Value="UpStrongest">
                                                                    <Setter Property="Background" Value="#99EF4444" />
                                                                </DataTrigger>
                                                                <DataTrigger Binding="{Binding Tone}" Value="DownWeak">
                                                                    <Setter Property="Background" Value="#1A22C55E" />
                                                                </DataTrigger>
                                                                <DataTrigger Binding="{Binding Tone}" Value="DownMedium">
                                                                    <Setter Property="Background" Value="#3322C55E" />
                                                                </DataTrigger>
                                                                <DataTrigger Binding="{Binding Tone}" Value="DownStrong">
                                                                    <Setter Property="Background" Value="#6622C55E" />
                                                                </DataTrigger>
                                                                <DataTrigger Binding="{Binding Tone}" Value="DownStrongest">
                                                                    <Setter Property="Background" Value="#9922C55E" />
                                                                </DataTrigger>
                                                            </Style.Triggers>
                                                        </Style>
                                                    </Border.Style>
                                                    <Border.ToolTip>
                                                        <TextBlock>
                                                            <Run Text="{Binding Date.Year, Mode=OneWay, StringFormat='0000'}" />
                                                            <Run Text="/" />
                                                            <Run Text="{Binding Date.Month, Mode=OneWay, StringFormat='00'}" />
                                                            <Run Text="/" />
                                                            <Run Text="{Binding Date.Day, Mode=OneWay, StringFormat='00'}" />
                                                            <Run Text=" " />
                                                            <Run Text="{Binding DeltaDisplay, Mode=OneWay}" />
                                                        </TextBlock>
                                                    </Border.ToolTip>
                                                </Border>
                                            </DataTemplate>
                                        </ItemsControl.ItemTemplate>
                                    </ItemsControl>
                                </DataTemplate>
                            </ItemsControl.ItemTemplate>
                        </ItemsControl>
                    </StackPanel>
                </Viewbox>

                <!--
                    ── 月份迷你 bar chart ──
                    每日 PnL 直方圖：紅柱為當日獲利，綠柱為當日虧損。視覺上補充
                    熱度圖看不出的「分布感」— 月初密集還是月底密集？極端值在何處？
                -->
                <Border
                    Grid.Row="4"
                    Margin="0,12,0,0"
                    Padding="0"
                    Background="Transparent"
                    Visibility="{Binding HasData, Converter={StaticResource BooleanToVisibilityConverter}}">
                    <lvc:CartesianChart
                        Height="100"
                        Background="Transparent"
                        Series="{Binding MonthlyBarSeries}"
                        TooltipPosition="Top"
                        TooltipTextSize="10"
                        XAxes="{Binding BarXAxes}"
                        YAxes="{Binding BarYAxes}" />
                </Border>

                <!--
                    ── Cell popover ──
                    點 cell 後彈出當日明細摘要 + 「跳到當日交易」link。整層蓋滿 Grid
                    才能在四個 row 上方居中；click 背景關閉。
                -->
                <Grid
                    Grid.RowSpan="5"
                    Panel.ZIndex="180"
                    Visibility="{Binding IsCellPopoverOpen, Converter={StaticResource BooleanToVisibilityConverter}}">
                    <!--  半透明 backdrop — P2.17 T09 hex→token (Brush.ModalOverlay)  -->
                    <Border Background="{DynamicResource Brush.ModalOverlay}">
                        <Border.InputBindings>
                            <MouseBinding Command="{Binding CloseCellPopoverCommand}" MouseAction="LeftClick" />
                        </Border.InputBindings>
                    </Border>
                    <!--  popover content card  -->
                    <Border
                        Width="320"
                        Padding="20,16"
                        HorizontalAlignment="Center"
                        VerticalAlignment="Center"
                        Background="{DynamicResource AppCardBackground}"
                        BorderBrush="{DynamicResource AppBorder}"
                        BorderThickness="1"
                        CornerRadius="{StaticResource Radius.Md}">
                        <StackPanel>
                            <DockPanel Margin="0,0,0,8" LastChildFill="False">
                                <TextBlock
                                    DockPanel.Dock="Left"
                                    FontSize="{StaticResource Font.Size.Md}"
                                    FontWeight="SemiBold"
                                    Foreground="{DynamicResource AppTextPrimary}">
                                    <!--
                                        bug fix：原本 Year 沒標 Mode=OneWay；DateOnly.Year/Month/Day
                                        全部 readonly get → WPF 預設 TwoWay binding 直接 throw
                                        InvalidOperationException 在 SelectCell 命令觸發時。
                                        三個 Run 全部標明 Mode=OneWay。
                                    -->
                                    <Run Text="{Binding SelectedCell.Date.Year, Mode=OneWay, FallbackValue=''}" />
                                    <Run Text="/" />
                                    <Run Text="{Binding SelectedCell.Date.Month, Mode=OneWay, StringFormat='00', FallbackValue=''}" />
                                    <Run Text="/" />
                                    <Run Text="{Binding SelectedCell.Date.Day, Mode=OneWay, StringFormat='00', FallbackValue=''}" />
                                </TextBlock>
                                <Button
                                    Width="28"
                                    Height="28"
                                    Padding="0"
                                    Command="{Binding CloseCellPopoverCommand}"
                                    DockPanel.Dock="Right"
                                    Style="{StaticResource AppIconButton}">
                                    <ds:AppIcon
                                        FontSize="14"
                                        Foreground="{DynamicResource AppTextMuted}"
                                        Symbol="Dismiss24" />
                                </Button>
                            </DockPanel>
                            <TextBlock
                                FontSize="{StaticResource Font.Size.Xs}"
                                Foreground="{DynamicResource AppTextMuted}"
                                Text="{DynamicResource Dashboard.Calendar.Popover.DailyPnl}" />
                            <TextBlock
                                Margin="0,4,0,12"
                                FontSize="{StaticResource Font.Size.Xl}"
                                FontWeight="SemiBold"
                                Text="{Binding SelectedCell.DeltaDisplay, FallbackValue='—'}"
                                Typography.NumeralAlignment="Tabular">
                                <TextBlock.Style>
                                    <Style TargetType="TextBlock">
                                        <Setter Property="Foreground" Value="{DynamicResource AppTextPrimary}" />
                                    </Style>
                                </TextBlock.Style>
                            </TextBlock>
                            <Button
                                HorizontalAlignment="Stretch"
                                Command="{Binding OpenDayTransactionsCommand}"
                                Content="{DynamicResource Dashboard.Calendar.Popover.OpenTransactions}"
                                Style="{StaticResource AppSecondaryButton}" />
                        </StackPanel>
                    </Border>
                </Grid>
            </Grid>
        </Border>
    </Grid>
</UserControl>
