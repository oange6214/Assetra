<UserControl
    x:Class="Assetra.WPF.Features.FinancialOverview.FinancialOverviewView"
    xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
    xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
    xmlns:d="http://schemas.microsoft.com/expression/blend/2008"
    xmlns:mc="http://schemas.openxmlformats.org/markup-compatibility/2006"
    xmlns:vm="clr-namespace:Assetra.WPF.Features.FinancialOverview"
    xmlns:behaviors="clr-namespace:Assetra.WPF.Infrastructure.Behaviors"
    xmlns:ds="clr-namespace:Assetra.WPF.DesignSystem.Controls"
    xmlns:lvc="clr-namespace:LiveChartsCore.SkiaSharpView.WPF;assembly=LiveChartsCore.SkiaSharpView.WPF"
    xmlns:widgets="clr-namespace:Assetra.WPF.Features.FinancialOverview.Widgets"
    d:DataContext="{d:DesignInstance Type={x:Type vm:FinancialOverviewViewModel}}"
    d:DesignHeight="800"
    d:DesignWidth="900"
    Background="{DynamicResource AppBackground}"
    mc:Ignorable="d">

    <Grid Style="{StaticResource PageRootGrid}">
        <Grid.RowDefinitions>
            <RowDefinition Height="Auto" />
            <RowDefinition Height="Auto" />
            <RowDefinition Height="*" />
        </Grid.RowDefinitions>

        <!--  Gear icon to open the KPI selector dialog  -->
        <Button
            Grid.Row="0"
            Width="32"
            Height="32"
            Margin="0,0,0,8"
            Padding="0"
            HorizontalAlignment="Right"
            Command="{Binding OpenKpiEditorCommand}"
            Style="{StaticResource AppIconButton}"
            ToolTip="{DynamicResource Settings.OverviewKpis.Title}">
            <ds:AppIcon Symbol="Settings24" FontSize="{StaticResource Font.Size.Md}" />
        </Button>

        <!--
            KPI Bar — driven by AppSettings.OverviewKpis. The user picks
            which 3-6 metrics to show in the Settings page; this view just
            renders whatever the ViewModel emits.
        -->
        <ItemsControl
            Grid.Row="1"
            Margin="0,0,0,16"
            ItemsSource="{Binding KpiCards}">
            <ItemsControl.ItemsPanel>
                <ItemsPanelTemplate>
                    <UniformGrid Rows="1" />
                </ItemsPanelTemplate>
            </ItemsControl.ItemsPanel>
            <ItemsControl.ItemTemplate>
                <DataTemplate>
                    <Border Margin="4,0" Style="{StaticResource FormCard}">
                        <StackPanel>
                            <TextBlock
                                FontSize="{StaticResource Font.Size.Xs}"
                                Foreground="{DynamicResource AppTextMuted}"
                                Text="{Binding LabelKey, Converter={StaticResource ResourceKeyToStringConverter}}" />
                            <TextBlock
                                Margin="0,8,0,0"
                                FontFamily="{StaticResource Font.Family.Base}"
                                FontSize="{StaticResource Font.Size.Lg}"
                                FontWeight="SemiBold"
                                Text="{Binding ValueDisplay}"
                                Typography.NumeralAlignment="Tabular">
                                <TextBlock.Style>
                                    <Style TargetType="TextBlock">
                                        <Setter Property="Foreground" Value="{DynamicResource AppTextPrimary}" />
                                        <Style.Triggers>
                                            <DataTrigger Binding="{Binding Tone}" Value="Up">
                                                <Setter Property="Foreground" Value="{DynamicResource AppUp}" />
                                            </DataTrigger>
                                            <DataTrigger Binding="{Binding Tone}" Value="Down">
                                                <Setter Property="Foreground" Value="{DynamicResource AppDown}" />
                                            </DataTrigger>
                                            <DataTrigger Binding="{Binding Tone}" Value="Accent">
                                                <Setter Property="Foreground" Value="{DynamicResource AppAccent}" />
                                            </DataTrigger>
                                        </Style.Triggers>
                                    </Style>
                                </TextBlock.Style>
                            </TextBlock>
                        </StackPanel>
                    </Border>
                </DataTemplate>
            </ItemsControl.ItemTemplate>
        </ItemsControl>

        <!--  ── Accordion  ───────────────────────────────────────────────────  -->
        <ScrollViewer
            Grid.Row="2"
            Margin="0"
            VerticalScrollBarVisibility="Auto">
            <StackPanel>

                <!--
                    30 天投資組合 sparkline — 給 KPI bar 一個「方向感」。
                    純線條無軸；資料源是 InvestmentFocusWidget.TenDaySeries（cutoff -29 天）。
                    註：理想是淨值（資產 + 投資 − 負債）每日 sparkline，但目前
                    PortfolioDailySnapshot 只記錄投資 MarketValue（CashValue /
                    LiabilityValue 兩欄存在但未持久化）。這版以投資組合趨勢為
                    proxy；完整淨值 sparkline 待 daily NW snapshot 基建完成。
                -->
                <Border Height="56" Margin="0,0,0,16"
                        Padding="12,8"
                        Background="{DynamicResource AppCardBackground}"
                        BorderBrush="{DynamicResource AppBorder}"
                        BorderThickness="1"
                        CornerRadius="{StaticResource Radius.Sm}"
                        Visibility="{Binding InvestmentFocusWidget, Converter={StaticResource NullToVisibilityConverter}}">
                    <Grid>
                        <Grid.ColumnDefinitions>
                            <ColumnDefinition Width="Auto" />
                            <ColumnDefinition Width="*" />
                        </Grid.ColumnDefinitions>
                        <TextBlock Grid.Column="0"
                                   VerticalAlignment="Center"
                                   FontSize="{StaticResource Font.Size.Xs}"
                                   Foreground="{DynamicResource AppTextMuted}"
                                   Text="{DynamicResource Dashboard.Overview.PortfolioTrend30d}" />
                        <lvc:CartesianChart Grid.Column="1"
                                            Margin="12,0,0,0"
                                            Background="Transparent"
                                            Series="{Binding InvestmentFocusWidget.TenDaySeries}"
                                            XAxes="{Binding InvestmentFocusWidget.SparklineXAxes}"
                                            YAxes="{Binding InvestmentFocusWidget.SparklineYAxes}"
                                            TooltipPosition="Hidden" />
                    </Grid>
                </Border>

                <!--
                    Stage 2.5 (Dashboard consolidation)：總覽 tab 上的 widget。
                    DataContext = FinancialOverviewViewModel；widget 內部用
                    GoalsWidget / FireWidget / AssistantWidget 屬性投影既有 VM。
                    每個 widget 在對應 VM 未注入時自動隱藏（NullToVisibilityConverter）。
                -->
                <widgets:AssistantWidget />
                <!--
                    Long-term refactor：投資焦點卡放在 Assistant 之後、Goals/FIRE 之前。
                    優先序：「我有多少 / 賺多少」(投資) → 「想達成什麼」(目標 / FIRE)。
                -->
                <widgets:InvestmentFocusWidget />
                <!--
                    Phase C：現金 / 負債 / 不動產三在一焦點卡。同模式可擴展到
                    crypto / 保險 / 退休 / 實物等其他資產類 — 加新項目時只要
                    擴 grid columns 即可，不會再回到「每資產類做 mini-dashboard」
                    的反模式。
                -->
                <widgets:AssetClassFocusWidget />
                <Grid Margin="0,0,0,4">
                    <Grid.ColumnDefinitions>
                        <ColumnDefinition Width="*" />
                        <ColumnDefinition Width="*" />
                    </Grid.ColumnDefinitions>
                    <widgets:GoalsWidget Grid.Column="0" Margin="0,0,6,0" />
                    <widgets:FireWidget Grid.Column="1" Margin="6,0,0,0" />
                </Grid>

                <!--  資產 Expander  -->
                <Expander
                    Margin="0,0,0,16"
                    IsExpanded="True"
                    Style="{StaticResource AppExpander}">
                    <Expander.Header>
                        <TextBlock
                            FontSize="{StaticResource Font.Size.Md}"
                            FontWeight="SemiBold"
                            Foreground="{DynamicResource AppUp}"
                            Text="{DynamicResource FinancialOverview.Section.Assets}" />
                    </Expander.Header>
                    <ItemsControl Margin="0,4,0,4" ItemsSource="{Binding AssetGroups}">
                        <ItemsControl.ItemTemplate>
                            <DataTemplate DataType="{x:Type vm:AssetGroupVm}">
                                <StackPanel Margin="8,4">
                                    <Grid Margin="0,2,0,4">
                                        <Grid.ColumnDefinitions>
                                            <ColumnDefinition Width="*" />
                                            <ColumnDefinition Width="Auto" />
                                        </Grid.ColumnDefinitions>
                                        <TextBlock
                                            Grid.Column="0"
                                            FontSize="{StaticResource Font.Size.Base}"
                                            FontWeight="SemiBold"
                                            Foreground="{DynamicResource AppTextMuted}"
                                            Text="{Binding Name}" />
                                        <TextBlock
                                            Grid.Column="1"
                                            FontSize="{StaticResource Font.Size.Base}"
                                            Foreground="{DynamicResource AppTextMuted}"
                                            Text="{Binding SubtotalDisplay}" />
                                    </Grid>
                                    <ItemsControl ItemsSource="{Binding Items}">
                                        <ItemsControl.ItemTemplate>
                                            <DataTemplate DataType="{x:Type vm:AssetItemVm}">
                                                <Grid Margin="12,2,0,2">
                                                    <Grid.ColumnDefinitions>
                                                        <ColumnDefinition Width="*" />
                                                        <ColumnDefinition Width="Auto" />
                                                    </Grid.ColumnDefinitions>
                                                    <TextBlock
                                                        Grid.Column="0"
                                                        FontSize="{StaticResource Font.Size.Base}"
                                                        Foreground="{DynamicResource AppTextPrimary}"
                                                        Text="{Binding Name}" />
                                                    <TextBlock
                                                        Grid.Column="1"
                                                        FontSize="{StaticResource Font.Size.Base}"
                                                        Foreground="{DynamicResource AppTextPrimary}"
                                                        Text="{Binding CurrentValueDisplay}" />
                                                </Grid>
                                            </DataTemplate>
                                        </ItemsControl.ItemTemplate>
                                    </ItemsControl>
                                </StackPanel>
                            </DataTemplate>
                        </ItemsControl.ItemTemplate>
                    </ItemsControl>
                </Expander>

                <!--  投資 Expander  -->
                <Expander
                    Margin="0,0,0,16"
                    IsExpanded="True"
                    Style="{StaticResource AppExpander}">
                    <Expander.Header>
                        <TextBlock
                            FontSize="{StaticResource Font.Size.Md}"
                            FontWeight="SemiBold"
                            Foreground="{DynamicResource AppAccent}"
                            Text="{DynamicResource FinancialOverview.Section.Investments}" />
                    </Expander.Header>
                    <ItemsControl Margin="0,4,0,4" ItemsSource="{Binding InvestGroups}">
                        <ItemsControl.ItemTemplate>
                            <DataTemplate DataType="{x:Type vm:AssetGroupVm}">
                                <StackPanel Margin="8,4">
                                    <Grid Margin="0,2,0,4">
                                        <Grid.ColumnDefinitions>
                                            <ColumnDefinition Width="*" />
                                            <ColumnDefinition Width="Auto" />
                                        </Grid.ColumnDefinitions>
                                        <TextBlock
                                            Grid.Column="0"
                                            FontSize="{StaticResource Font.Size.Base}"
                                            FontWeight="SemiBold"
                                            Foreground="{DynamicResource AppTextMuted}"
                                            Text="{Binding Name}" />
                                        <TextBlock
                                            Grid.Column="1"
                                            FontSize="{StaticResource Font.Size.Base}"
                                            Foreground="{DynamicResource AppTextMuted}"
                                            Text="{Binding SubtotalDisplay}" />
                                    </Grid>
                                    <ItemsControl ItemsSource="{Binding Items}">
                                        <ItemsControl.ItemTemplate>
                                            <DataTemplate DataType="{x:Type vm:AssetItemVm}">
                                                <Grid Margin="12,2,0,2">
                                                    <Grid.ColumnDefinitions>
                                                        <ColumnDefinition Width="*" />
                                                        <ColumnDefinition Width="Auto" />
                                                    </Grid.ColumnDefinitions>
                                                    <TextBlock
                                                        Grid.Column="0"
                                                        FontSize="{StaticResource Font.Size.Base}"
                                                        Foreground="{DynamicResource AppTextPrimary}"
                                                        Text="{Binding Name}" />
                                                    <TextBlock
                                                        Grid.Column="1"
                                                        FontSize="{StaticResource Font.Size.Base}"
                                                        Foreground="{DynamicResource AppTextPrimary}"
                                                        Text="{Binding CurrentValueDisplay}" />
                                                </Grid>
                                            </DataTemplate>
                                        </ItemsControl.ItemTemplate>
                                    </ItemsControl>
                                </StackPanel>
                            </DataTemplate>
                        </ItemsControl.ItemTemplate>
                    </ItemsControl>
                </Expander>

                <!--  負債 Expander  -->
                <Expander
                    Margin="0,0,0,16"
                    IsExpanded="True"
                    Style="{StaticResource AppExpander}">
                    <Expander.Header>
                        <TextBlock
                            FontSize="{StaticResource Font.Size.Md}"
                            FontWeight="SemiBold"
                            Foreground="{DynamicResource AppDown}"
                            Text="{DynamicResource FinancialOverview.Section.Liabilities}" />
                    </Expander.Header>
                    <ItemsControl Margin="0,4,0,4" ItemsSource="{Binding LiabGroups}">
                        <ItemsControl.ItemTemplate>
                            <DataTemplate DataType="{x:Type vm:AssetGroupVm}">
                                <StackPanel Margin="8,4">
                                    <Grid Margin="0,2,0,4">
                                        <Grid.ColumnDefinitions>
                                            <ColumnDefinition Width="*" />
                                            <ColumnDefinition Width="Auto" />
                                        </Grid.ColumnDefinitions>
                                        <TextBlock
                                            Grid.Column="0"
                                            FontSize="{StaticResource Font.Size.Base}"
                                            FontWeight="SemiBold"
                                            Foreground="{DynamicResource AppTextMuted}"
                                            Text="{Binding Name}" />
                                        <TextBlock
                                            Grid.Column="1"
                                            FontSize="{StaticResource Font.Size.Base}"
                                            Foreground="{DynamicResource AppTextMuted}"
                                            Text="{Binding SubtotalDisplay}" />
                                    </Grid>
                                    <ItemsControl ItemsSource="{Binding Items}">
                                        <ItemsControl.ItemTemplate>
                                            <DataTemplate DataType="{x:Type vm:AssetItemVm}">
                                                <Grid Margin="12,2,0,2">
                                                    <Grid.ColumnDefinitions>
                                                        <ColumnDefinition Width="*" />
                                                        <ColumnDefinition Width="Auto" />
                                                    </Grid.ColumnDefinitions>
                                                    <TextBlock
                                                        Grid.Column="0"
                                                        FontSize="{StaticResource Font.Size.Base}"
                                                        Foreground="{DynamicResource AppTextPrimary}"
                                                        Text="{Binding Name}" />
                                                    <TextBlock
                                                        Grid.Column="1"
                                                        FontSize="{StaticResource Font.Size.Base}"
                                                        Foreground="{DynamicResource AppDown}"
                                                        Text="{Binding CurrentValueDisplay}" />
                                                </Grid>
                                            </DataTemplate>
                                        </ItemsControl.ItemTemplate>
                                    </ItemsControl>
                                </StackPanel>
                            </DataTemplate>
                        </ItemsControl.ItemTemplate>
                    </ItemsControl>
                </Expander>

            </StackPanel>
        </ScrollViewer>

        <!--  ── KPI selector dialog ──────────────────────────────────────  -->
        <Grid
            Grid.Row="0"
            Grid.RowSpan="3"
            behaviors:EscapeKeyCommandBehavior.Command="{Binding CloseKpiEditorCommand}"
            Visibility="{Binding IsKpiEditorOpen, Converter={StaticResource BooleanToVisibilityConverter}}">
            <!--  Backdrop  -->
            <Border
                Background="{DynamicResource AppModalOverlay}"
                MouseDown="KpiEditorBackdrop_MouseDown" />
            <!--  Card  -->
            <Border
                MaxWidth="520"
                MaxHeight="640"
                Margin="24"
                HorizontalAlignment="Center"
                VerticalAlignment="Center"
                Style="{StaticResource AppDialogShell}">
                <Grid>
                    <Grid.RowDefinitions>
                        <RowDefinition Height="Auto" />
                        <RowDefinition Height="*" />
                        <RowDefinition Height="Auto" />
                    </Grid.RowDefinitions>

                    <!--  Header  -->
                    <StackPanel Grid.Row="0" Margin="0,0,0,16">
                        <TextBlock
                            FontSize="{StaticResource Font.Size.Lg}"
                            FontWeight="SemiBold"
                            Foreground="{DynamicResource AppTextPrimary}"
                            Text="{DynamicResource Settings.OverviewKpis.Title}" />
                        <TextBlock
                            Margin="0,4,0,0"
                            FontSize="{StaticResource Font.Size.Xs}"
                            Foreground="{DynamicResource AppTextMuted}"
                            Text="{DynamicResource Settings.OverviewKpis.Description}"
                            TextWrapping="Wrap" />
                    </StackPanel>

                    <!--  Checkbox list  -->
                    <ScrollViewer Grid.Row="1" VerticalScrollBarVisibility="Auto">
                        <ItemsControl ItemsSource="{Binding KpiEditorItems}">
                            <ItemsControl.ItemTemplate>
                                <DataTemplate>
                                    <Grid Margin="0,4">
                                        <Grid.ColumnDefinitions>
                                            <ColumnDefinition Width="*" />
                                            <ColumnDefinition Width="Auto" />
                                            <ColumnDefinition Width="Auto" />
                                        </Grid.ColumnDefinitions>
                                        <CheckBox Grid.Column="0"
                                                  IsChecked="{Binding IsSelected, Mode=TwoWay}">
                                            <StackPanel>
                                                <TextBlock
                                                    FontSize="{StaticResource Font.Size.Sm}"
                                                    FontWeight="Medium"
                                                    Foreground="{DynamicResource AppTextPrimary}"
                                                    Text="{Binding LabelKey, Converter={StaticResource ResourceKeyToStringConverter}}" />
                                                <TextBlock
                                                    Margin="0,2,0,0"
                                                    FontSize="{StaticResource Font.Size.Xs}"
                                                    Foreground="{DynamicResource AppTextMuted}"
                                                    Text="{Binding DescriptionKey, Converter={StaticResource ResourceKeyToStringConverter}}"
                                                    TextWrapping="Wrap" />
                                            </StackPanel>
                                        </CheckBox>
                                        <!--  v2：reorder（▲▼）— 按勾選順序排會混亂，用上下鈕較直覺。  -->
                                        <Button Grid.Column="1" Width="28" Height="28" Padding="0"
                                                Margin="0,0,4,0"
                                                Style="{StaticResource AppIconButton}"
                                                Command="{Binding DataContext.MoveKpiUpCommand, RelativeSource={RelativeSource AncestorType=UserControl}}"
                                                CommandParameter="{Binding}"
                                                ToolTip="{DynamicResource FinancialOverview.Kpi.MoveUp}">
                                            <ds:AppIcon Symbol="ChevronUp24" FontSize="14"
                                                        Foreground="{DynamicResource AppTextSecondary}" />
                                        </Button>
                                        <Button Grid.Column="2" Width="28" Height="28" Padding="0"
                                                Style="{StaticResource AppIconButton}"
                                                Command="{Binding DataContext.MoveKpiDownCommand, RelativeSource={RelativeSource AncestorType=UserControl}}"
                                                CommandParameter="{Binding}"
                                                ToolTip="{DynamicResource FinancialOverview.Kpi.MoveDown}">
                                            <ds:AppIcon Symbol="ChevronDown24" FontSize="14"
                                                        Foreground="{DynamicResource AppTextSecondary}" />
                                        </Button>
                                    </Grid>
                                </DataTemplate>
                            </ItemsControl.ItemTemplate>
                        </ItemsControl>
                    </ScrollViewer>

                    <!--  Footer  -->
                    <DockPanel Grid.Row="2" Margin="0,16,0,0" LastChildFill="False">
                        <TextBlock
                            DockPanel.Dock="Left"
                            VerticalAlignment="Center"
                            FontSize="{StaticResource Font.Size.Xs}"
                            Foreground="{DynamicResource AppTextMuted}">
                            <Run Text="{Binding KpiSelectedCount, Mode=OneWay}" />
                            <Run Text=" / " />
                            <Run Text="{Binding KpiMaxSelected, Mode=OneWay}" />
                            <Run Text=" (min " />
                            <Run Text="{Binding KpiMinSelected, Mode=OneWay}" />
                            <Run Text=")" />
                        </TextBlock>
                        <Button
                            Height="32"
                            MinHeight="32"
                            Margin="0,0,0,0"
                            Padding="14,0"
                            DockPanel.Dock="Right"
                            Command="{Binding SaveKpiSelectionCommand}"
                            Style="{StaticResource AppPrimaryButton}">
                            <TextBlock Style="{StaticResource AppButtonText}" Text="{DynamicResource Common.Save}" />
                        </Button>
                        <Button
                            Height="32"
                            MinHeight="32"
                            Margin="0,0,8,0"
                            Padding="14,0"
                            DockPanel.Dock="Right"
                            Command="{Binding CloseKpiEditorCommand}"
                            Style="{StaticResource AppSecondaryButton}">
                            <TextBlock Style="{StaticResource AppButtonText}" Text="{DynamicResource Common.Cancel}" />
                        </Button>
                    </DockPanel>
                </Grid>
            </Border>
        </Grid>

    </Grid>
</UserControl>
