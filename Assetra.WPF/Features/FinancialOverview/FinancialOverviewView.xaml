<UserControl
    x:Class="Assetra.WPF.Features.FinancialOverview.FinancialOverviewView"
    xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
    xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
    xmlns:behaviors="clr-namespace:Assetra.WPF.Infrastructure.Behaviors"
    xmlns:d="http://schemas.microsoft.com/expression/blend/2008"
    xmlns:ds="clr-namespace:Assetra.WPF.DesignSystem.Controls"
    xmlns:mc="http://schemas.openxmlformats.org/markup-compatibility/2006"
    xmlns:vm="clr-namespace:Assetra.WPF.Features.FinancialOverview"
    xmlns:widgets="clr-namespace:Assetra.WPF.Features.FinancialOverview.Widgets"
    d:DataContext="{d:DesignInstance Type={x:Type vm:FinancialOverviewViewModel}}"
    d:DesignHeight="800"
    d:DesignWidth="900"
    Background="{DynamicResource AppBackground}"
    mc:Ignorable="d">

    <!--
        Gear button + KPI bar 原本放在 ScrollViewer 外面（Row 0 / Row 1），導致 KPI 寬度
        跟 ScrollViewer 內容寬度不對齊：scrollbar 出現時 widgets 損失 17px 右側空間，KPI
        卻保留滿寬，右側差一條。整段搬進 ScrollViewer 內就所有橫向 padding / scrollbar
        gutter 一致。
    -->
    <Grid Style="{StaticResource PageRootGrid}">
        <ScrollViewer Margin="0" VerticalScrollBarVisibility="Auto">
            <!--
                IsEmpty=True（全新使用者、尚無任何資產/負債）時整段儀表板隱藏，
                改由下方「從這裡開始」onboarding hero 接手（見 root Grid 尾端）。
            -->
            <StackPanel Visibility="{Binding IsEmpty, Converter={StaticResource InverseBooleanToVisibilityConverter}}">

                <!--
                    ═══ ❶ HERO card (v2 redesign 2026-05-13) ═══
                    永久顯示 淨資產 + 目標進度 + 今日漲跌。
                    - 淨資產是 universal hero indicator，不該被 KPI dialog 砍掉
                    - 目標進度條：未設定目標時顯示 CTA「尚未設定目標 → 點此設定」
                    - 今日漲跌：HasHeroTodayDelta=false 時整段隱藏，避免「未開盤」期間佔位
                -->
                <!--
                    P2.14 — Migrated to AppCardHero design-system style (Cards.xaml).
                    Style 內已含 Padding=20,16 + Margin=0,0,0,12 + Radius.Md + BorderLight。
                    Hero 大字本身扛主視覺，邊框只是 card 邊界提示。
                -->
                <Border Style="{StaticResource AppCardHero}">
                    <Grid>
                        <Grid.ColumnDefinitions>
                            <ColumnDefinition Width="2*" />
                            <ColumnDefinition Width="*" />
                        </Grid.ColumnDefinitions>
                        <!--  Left: 淨資產大字 + 目標進度條  -->
                        <StackPanel Grid.Column="0">
                            <TextBlock
                                FontSize="{StaticResource Font.Size.Xs}"
                                Foreground="{DynamicResource AppTextMuted}"
                                Text="{DynamicResource FinancialOverview.Header.NetWorth}" />
                            <!--
                                Hero 大字綁 BalanceSheetNetWorthDisplay 而非 TotalNetWorthDisplay
                                — 後者 = (TotalAssets + TotalInvestments − TotalLiabilities) 漏掉
                                Physical/RealEstate/Retirement 等不在 IFinancialOverviewQueryService
                                的資產類別，會少算。BalanceSheet 系列直接從各 widget VM 加總，
                                跟「資產組成」view 的金額一致。
                            -->
                            <!--
                                P2.11 — 升級到 TextStyle.Numeric.Hero (3xl=48px Bold tabular)，
                                跟 KPI dialog / 公式列的 secondary 金額拉開視覺差，對應
                                Personal Wealth Terminal review 的 Dashboard Rhythm Hero 層級。
                                P2.15 E — IsLoading=True 時改顯示 AppSkeletonRect placeholder
                                取代直接 binding 突然出現的數字，pulse 動畫傳遞「資料正在路上」。
                            -->
                            <Grid Height="56" Margin="0,4,0,8">
                                <TextBlock
                                    VerticalAlignment="Center"
                                    Foreground="{DynamicResource AppTextPrimary}"
                                    Style="{StaticResource TextStyle.Numeric.Hero}"
                                    Text="{Binding BalanceSheetNetWorthDisplay}"
                                    Visibility="{Binding IsLoading, Converter={StaticResource InverseBooleanToVisibilityConverter}}" />
                                <Border
                                    Width="220"
                                    Height="40"
                                    HorizontalAlignment="Left"
                                    VerticalAlignment="Center"
                                    Style="{StaticResource AppSkeletonRect}"
                                    Visibility="{Binding IsLoading, Converter={StaticResource BooleanToVisibilityConverter}}" />
                            </Grid>

                            <!--  Goal progress bar — visible when HasGoalTarget  -->
                            <StackPanel Visibility="{Binding HasGoalTarget, Converter={StaticResource BooleanToVisibilityConverter}}">
                                <Grid Height="6" Margin="0,0,0,4">
                                    <Border Background="{DynamicResource AppBorder}" CornerRadius="3" />
                                    <Border
                                        HorizontalAlignment="Left"
                                        Background="{DynamicResource AppAccent}"
                                        CornerRadius="3">
                                        <Border.Width>
                                            <MultiBinding Converter="{StaticResource PercentToWidthConverter}">
                                                <Binding Path="HeroGoalProgressValue" />
                                                <Binding Path="ActualWidth" RelativeSource="{RelativeSource AncestorType=Grid}" />
                                            </MultiBinding>
                                        </Border.Width>
                                    </Border>
                                </Grid>
                                <DockPanel LastChildFill="False">
                                    <TextBlock
                                        DockPanel.Dock="Left"
                                        FontSize="{StaticResource Font.Size.Xs}"
                                        Foreground="{DynamicResource AppTextMuted}">
                                        <Run Text="{DynamicResource FinancialOverview.Hero.GoalProgress}" />
                                        <Run Text=" " />
                                        <Run Text="{Binding HeroGoalProgressDisplay, Mode=OneWay}" />
                                    </TextBlock>
                                    <TextBlock
                                        DockPanel.Dock="Right"
                                        FontSize="{StaticResource Font.Size.Xs}"
                                        Foreground="{DynamicResource AppTextMuted}">
                                        <Run Text="{DynamicResource FinancialOverview.Hero.GoalLabel}" />
                                        <Run Text=": " />
                                        <Run Text="{Binding HeroGoalTargetDisplay, Mode=OneWay}" />
                                    </TextBlock>
                                </DockPanel>
                            </StackPanel>

                            <!--
                                No-goal CTA — v3 2026-05-17：改成可點擊（左鍵跳 Goals tab
                                觸發建立目標流程）。底部 GoalsWidget 在無目標時已自動隱藏
                                (避免 Hero + widget 兩處 CTA 重複)，所以此處變成唯一的
                                目標設定入口；Cursor=Hand 讓使用者一眼看出 actionable。
                            -->
                            <TextBlock
                                Cursor="Hand"
                                FontSize="{StaticResource Font.Size.Xs}"
                                Foreground="{DynamicResource AppTextMuted}"
                                Visibility="{Binding HasGoalTarget, Converter={StaticResource InverseBooleanToVisibilityConverter}}">
                                <TextBlock.InputBindings>
                                    <MouseBinding Command="{Binding NavigateToGoalsAndAddCommand}" MouseAction="LeftClick" />
                                </TextBlock.InputBindings>
                                <Run Text="{DynamicResource FinancialOverview.Hero.NoGoal}" />
                                <Run Text="   " />
                                <Run Foreground="{DynamicResource AppAccent}" Text="{DynamicResource FinancialOverview.Hero.NoGoalCta}" />
                            </TextBlock>
                        </StackPanel>

                        <!--  Right: 今日漲跌（盤後 / 無報價時整段不渲染）  -->
                        <StackPanel
                            Grid.Column="1"
                            Margin="16,0,0,0"
                            HorizontalAlignment="Right"
                            VerticalAlignment="Center"
                            Visibility="{Binding HasHeroTodayDelta, Converter={StaticResource BooleanToVisibilityConverter}}">
                            <TextBlock
                                HorizontalAlignment="Right"
                                FontSize="{StaticResource Font.Size.Xs}"
                                Foreground="{DynamicResource AppTextMuted}"
                                Text="{DynamicResource FinancialOverview.Hero.Today}" />
                            <TextBlock
                                Margin="0,4,0,0"
                                HorizontalAlignment="Right"
                                FontFamily="{StaticResource Font.Family.Base}"
                                FontSize="{StaticResource Font.Size.Lg}"
                                FontWeight="SemiBold"
                                Text="{Binding HeroTodayDeltaDisplay, Mode=OneWay}"
                                Typography.NumeralAlignment="Tabular">
                                <TextBlock.Style>
                                    <Style TargetType="TextBlock">
                                        <Setter Property="Foreground" Value="{DynamicResource AppDown}" />
                                        <Style.Triggers>
                                            <DataTrigger Binding="{Binding IsHeroTodayPositive}" Value="True">
                                                <Setter Property="Foreground" Value="{DynamicResource AppUp}" />
                                            </DataTrigger>
                                        </Style.Triggers>
                                    </Style>
                                </TextBlock.Style>
                            </TextBlock>
                        </StackPanel>
                    </Grid>
                </Border>

                <!--
                    ═══ ❷ 公式列 — 總資產 − 總負債 = 淨資產 ═══
                    三個對等 card 用 "−" 和 "=" operator 連接，把 balance-sheet 等式
                    視覺化。固定永久顯示，KPI dialog 已不再列出這三個。
                -->
                <Grid Margin="0,0,0,16">
                    <Grid.ColumnDefinitions>
                        <ColumnDefinition Width="*" />
                        <ColumnDefinition Width="Auto" />
                        <ColumnDefinition Width="*" />
                        <ColumnDefinition Width="Auto" />
                        <ColumnDefinition Width="*" />
                    </Grid.ColumnDefinitions>
                    <!--
                        總資產 — P2.14 migrated to AppCardSummary (Cards.xaml)，
                        BorderLight + Padding.Card + Radius.Sm。
                    -->
                    <Border Grid.Column="0" Style="{StaticResource AppCardSummary}">
                        <StackPanel>
                            <TextBlock
                                FontSize="{StaticResource Font.Size.Xs}"
                                Foreground="{DynamicResource AppTextMuted}"
                                Text="{DynamicResource FinancialOverview.Header.TotalAssets}" />
                            <!--
                                綁 BalanceSheetTotalAssetsDisplay 而非 TotalAssetsDisplay。
                                後者只是 asset_item 表的 cash + 手動 entry，會漏 Physical /
                                RealEstate / Retirement。BalanceSheet 系列直接從各 widget
                                VM 加總，跟資產組成 view 一致。
                                P2.16 H — IsLoading=True 時 skeleton 取代，等資料載完才顯示
                                真實數字 (跟 Hero card 一致的 loading 體驗)。
                            -->
                            <Grid Height="24" Margin="0,4,0,0">
                                <Border
                                    Width="120"
                                    Height="18"
                                    HorizontalAlignment="Left"
                                    VerticalAlignment="Center"
                                    Style="{StaticResource AppSkeletonRect}"
                                    Visibility="{Binding IsLoading, Converter={StaticResource BooleanToVisibilityConverter}}" />
                                <TextBlock
                                    FontFamily="{StaticResource Font.Family.Base}"
                                    FontSize="{StaticResource Font.Size.Lg}"
                                    FontWeight="SemiBold"
                                    Foreground="{DynamicResource AppTextPrimary}"
                                    Text="{Binding BalanceSheetTotalAssetsDisplay}"
                                    Typography.NumeralAlignment="Tabular"
                                    Visibility="{Binding IsLoading, Converter={StaticResource InverseBooleanToVisibilityConverter}}" />
                            </Grid>
                        </StackPanel>
                    </Border>
                    <!--  − operator  -->
                    <TextBlock
                        Grid.Column="1"
                        Margin="12,0"
                        VerticalAlignment="Center"
                        FontSize="{StaticResource Font.Size.Lg}"
                        FontWeight="Bold"
                        Foreground="{DynamicResource AppTextMuted}"
                        Text="−" />
                    <!--  總負債 — P2.14 migrated to AppCardSummary，T02 加 skeleton  -->
                    <Border Grid.Column="2" Style="{StaticResource AppCardSummary}">
                        <StackPanel>
                            <TextBlock
                                FontSize="{StaticResource Font.Size.Xs}"
                                Foreground="{DynamicResource AppTextMuted}"
                                Text="{DynamicResource FinancialOverview.Header.Liabilities}" />
                            <Grid Height="24" Margin="0,4,0,0">
                                <Border
                                    Width="120"
                                    Height="18"
                                    HorizontalAlignment="Left"
                                    VerticalAlignment="Center"
                                    Style="{StaticResource AppSkeletonRect}"
                                    Visibility="{Binding IsLoading, Converter={StaticResource BooleanToVisibilityConverter}}" />
                                <TextBlock
                                    FontFamily="{StaticResource Font.Family.Base}"
                                    FontSize="{StaticResource Font.Size.Lg}"
                                    FontWeight="SemiBold"
                                    Foreground="{DynamicResource AppDown}"
                                    Text="{Binding TotalLiabilitiesDisplay}"
                                    Typography.NumeralAlignment="Tabular"
                                    Visibility="{Binding IsLoading, Converter={StaticResource InverseBooleanToVisibilityConverter}}" />
                            </Grid>
                        </StackPanel>
                    </Border>
                    <!--  = operator  -->
                    <TextBlock
                        Grid.Column="3"
                        Margin="12,0"
                        VerticalAlignment="Center"
                        FontSize="{StaticResource Font.Size.Lg}"
                        FontWeight="Bold"
                        Foreground="{DynamicResource AppTextMuted}"
                        Text="=" />
                    <!--
                        淨資產 (re-displayed compact for visual closure of equation)
                        — 用 AppCardSummary 但 override BorderBrush 成 AppAccent 強調這
                        是公式結果。
                    -->
                    <Border
                        Grid.Column="4"
                        BorderBrush="{DynamicResource AppAccent}"
                        Style="{StaticResource AppCardSummary}">
                        <StackPanel>
                            <TextBlock
                                FontSize="{StaticResource Font.Size.Xs}"
                                Foreground="{DynamicResource AppTextMuted}"
                                Text="{DynamicResource FinancialOverview.Header.NetWorth}" />
                            <Grid Height="24" Margin="0,4,0,0">
                                <Border
                                    Width="120"
                                    Height="18"
                                    HorizontalAlignment="Left"
                                    VerticalAlignment="Center"
                                    Style="{StaticResource AppSkeletonRect}"
                                    Visibility="{Binding IsLoading, Converter={StaticResource BooleanToVisibilityConverter}}" />
                                <TextBlock
                                    FontFamily="{StaticResource Font.Family.Base}"
                                    FontSize="{StaticResource Font.Size.Lg}"
                                    FontWeight="SemiBold"
                                    Foreground="{DynamicResource AppAccent}"
                                    Text="{Binding BalanceSheetNetWorthDisplay}"
                                    Typography.NumeralAlignment="Tabular"
                                    Visibility="{Binding IsLoading, Converter={StaticResource InverseBooleanToVisibilityConverter}}" />
                            </Grid>
                        </StackPanel>
                    </Border>
                </Grid>


                <!--  ── Widgets（與 KPI bar 同一個 ScrollViewer / StackPanel 內，橫向對齊） ──  -->

                <!--
                    Plan A 重排（v0.x）：
                    1. AssetClassFocusWidget — 主要導航入口（現金/負債/不動產/...），
                    上移到 KPI 緊鄰下方，使用者一進頁面就能跳到目標資產類
                    2. TodaysMoversWidget — 每日掃視（盤中誰漲誰跌）
                    3. InvestmentFocusWidget — 投資 drill-down 含 30d sparkline
                    4. AssistantWidget — 洞察提醒（沒洞察時整段隱藏）
                    5. GoalsWidget + FireWidget — 長期規劃，並排
                    6. 資產 / 收支 expander — 詳細列表
                    移除：原本 KPI 下方獨立「30 天投資組合趨勢」sparkline 區塊 —
                    與 InvestmentFocusWidget 內畫的線是同一張，重複佔空間。
                -->

                <!--
                    ═══ ❸ 資產組成（v2 取代「資產類焦點」6 cards） ═══
                    水平 stacked bar 把 4-5 個資產類視覺化（金額比例 = 視覺寬度），
                    下方 legend 行列出每類絕對金額 + 佔比。
                    - 自動排除 0 值類（保險、退休空 → 不渲染）
                    - 負債放在 stacked bar 底下、紅色獨立 bar，避免跟資產混色
                    - 點 legend item 跳到對應 tab（沿用原 NavigateToXxxCommand）
                    舊的 AssetClassFocusWidget 已不再使用，保留檔案以備回退。
                -->
                <!--
                    P2.14 — 資產組成 Analytics card migrated to AppCardSummary。Margin
                    local override (style default Margin 是 0)，因為下方還有 widgets list。
                -->
                <Border
                    Margin="0,0,0,16"
                    Style="{StaticResource AppCardSummary}"
                    Visibility="{Binding HasCompositionData, Converter={StaticResource BooleanToVisibilityConverter}}">
                    <StackPanel>
                        <DockPanel Margin="0,0,0,10">
                            <TextBlock
                                VerticalAlignment="Center"
                                DockPanel.Dock="Left"
                                FontSize="{StaticResource Font.Size.Sm}"
                                FontWeight="SemiBold"
                                Foreground="{DynamicResource AppTextPrimary}"
                                Text="{DynamicResource FinancialOverview.Composition.Heading}" />
                            <TextBlock
                                VerticalAlignment="Center"
                                DockPanel.Dock="Right"
                                FontFamily="{StaticResource Font.Family.Base}"
                                FontSize="{StaticResource Font.Size.Sm}"
                                FontWeight="SemiBold"
                                Foreground="{DynamicResource AppTextPrimary}"
                                Text="{Binding CompositionTotalDisplay, Mode=OneWay}"
                                Typography.NumeralAlignment="Tabular" />
                        </DockPanel>

                        <!--  Real stacked bar with per-segment proportional widths  -->
                        <Grid Height="14" Margin="0,0,0,4">
                            <Border Background="{DynamicResource AppBorder}" CornerRadius="2" />
                            <ItemsControl ItemsSource="{Binding CompositionSlices}">
                                <ItemsControl.ItemsPanel>
                                    <ItemsPanelTemplate>
                                        <StackPanel Orientation="Horizontal" />
                                    </ItemsPanelTemplate>
                                </ItemsControl.ItemsPanel>
                                <ItemsControl.ItemTemplate>
                                    <DataTemplate>
                                        <Border
                                            Margin="0,0,1,0"
                                            Background="{Binding ColorHex, Converter={StaticResource HexToBrushConverter}}"
                                            ToolTip="{Binding NameKey, Converter={StaticResource ResourceKeyToStringConverter}}">
                                            <Border.Width>
                                                <MultiBinding Converter="{StaticResource PercentToWidthConverter}">
                                                    <Binding Path="Percent" />
                                                    <Binding Path="ActualWidth" RelativeSource="{RelativeSource AncestorType=ItemsControl}" />
                                                </MultiBinding>
                                            </Border.Width>
                                        </Border>
                                    </DataTemplate>
                                </ItemsControl.ItemTemplate>
                            </ItemsControl>
                        </Grid>

                        <!--  Legend rows — each: ▇ name 65% NT$8.67M  -->
                        <ItemsControl Margin="0,8,0,0" ItemsSource="{Binding CompositionSlices}">
                            <ItemsControl.ItemTemplate>
                                <DataTemplate>
                                    <Grid Margin="0,2,0,2" Cursor="Hand">
                                        <Grid.ColumnDefinitions>
                                            <ColumnDefinition Width="12" />
                                            <ColumnDefinition Width="8" />
                                            <ColumnDefinition Width="*" />
                                            <ColumnDefinition Width="Auto" />
                                            <ColumnDefinition Width="16" />
                                            <ColumnDefinition Width="Auto" />
                                        </Grid.ColumnDefinitions>
                                        <Border
                                            Grid.Column="0"
                                            Width="10"
                                            Height="10"
                                            VerticalAlignment="Center"
                                            Background="{Binding ColorHex, Converter={StaticResource HexToBrushConverter}}"
                                            CornerRadius="2" />
                                        <TextBlock
                                            Grid.Column="2"
                                            VerticalAlignment="Center"
                                            FontSize="{StaticResource Font.Size.Xs}"
                                            Foreground="{DynamicResource AppTextSecondary}"
                                            Text="{Binding NameKey, Converter={StaticResource ResourceKeyToStringConverter}}" />
                                        <TextBlock
                                            Grid.Column="3"
                                            VerticalAlignment="Center"
                                            FontFamily="{StaticResource Font.Family.Base}"
                                            FontSize="{StaticResource Font.Size.Xs}"
                                            Foreground="{DynamicResource AppTextMuted}"
                                            Text="{Binding PercentDisplay}"
                                            Typography.NumeralAlignment="Tabular" />
                                        <TextBlock
                                            Grid.Column="5"
                                            VerticalAlignment="Center"
                                            FontFamily="{StaticResource Font.Family.Base}"
                                            FontSize="{StaticResource Font.Size.Xs}"
                                            FontWeight="SemiBold"
                                            Foreground="{DynamicResource AppTextPrimary}"
                                            Text="{Binding ValueDisplay}"
                                            Typography.NumeralAlignment="Tabular" />
                                    </Grid>
                                </DataTemplate>
                            </ItemsControl.ItemTemplate>
                        </ItemsControl>

                        <!--  Liabilities standalone (red, separated visually) — 只在有負債時顯示  -->
                        <StackPanel Margin="0,12,0,0" Visibility="{Binding HasLiabilities, Converter={StaticResource BooleanToVisibilityConverter}}">
                            <Border
                                Height="3"
                                Margin="0,0,0,6"
                                Background="{DynamicResource AppBorder}"
                                CornerRadius="1.5" />
                            <Grid>
                                <Grid.ColumnDefinitions>
                                    <ColumnDefinition Width="12" />
                                    <ColumnDefinition Width="8" />
                                    <ColumnDefinition Width="*" />
                                    <ColumnDefinition Width="Auto" />
                                    <ColumnDefinition Width="16" />
                                    <ColumnDefinition Width="Auto" />
                                </Grid.ColumnDefinitions>
                                <Border
                                    Grid.Column="0"
                                    Width="10"
                                    Height="10"
                                    VerticalAlignment="Center"
                                    Background="{DynamicResource AppDown}"
                                    CornerRadius="2" />
                                <TextBlock
                                    Grid.Column="2"
                                    VerticalAlignment="Center"
                                    FontSize="{StaticResource Font.Size.Xs}"
                                    Foreground="{DynamicResource AppTextSecondary}"
                                    Text="{DynamicResource FinancialOverview.Composition.Liability}" />
                                <TextBlock
                                    Grid.Column="3"
                                    VerticalAlignment="Center"
                                    FontFamily="{StaticResource Font.Family.Base}"
                                    FontSize="{StaticResource Font.Size.Xs}"
                                    Foreground="{DynamicResource AppTextMuted}"
                                    Text="{Binding LiabilityShareDisplay}"
                                    Typography.NumeralAlignment="Tabular" />
                                <TextBlock
                                    Grid.Column="5"
                                    VerticalAlignment="Center"
                                    FontFamily="{StaticResource Font.Family.Base}"
                                    FontSize="{StaticResource Font.Size.Xs}"
                                    FontWeight="SemiBold"
                                    Foreground="{DynamicResource AppDown}"
                                    Text="{Binding CompositionLiabilityDisplay}"
                                    Typography.NumeralAlignment="Tabular" />
                            </Grid>
                        </StackPanel>
                    </StackPanel>
                </Border>

                <!--
                    KPI bar + 齒輪按鈕同列：齒輪原本獨佔一整列只放一顆 32×32 按鈕，
                    上方留白 ~40px 浪費。用 DockPanel 把齒輪 dock 到右側、KPI bar 填左側。
                    齒輪 VerticalAlignment=Top 對齊 KPI 卡頂端，視覺輕量。
                    用負 Margin 抵消內部每張卡的 4px 左右 margin，讓 KPI bar 的最外側
                    對齊容器邊緣（與下方 widgets 對齊）。
                -->
                <DockPanel Margin="0,0,0,16" LastChildFill="True">
                    <Button
                        Width="32"
                        Height="32"
                        Margin="8,0,0,0"
                        Padding="0"
                        VerticalAlignment="Top"
                        Command="{Binding OpenKpiEditorCommand}"
                        DockPanel.Dock="Right"
                        Style="{StaticResource AppIconButton}"
                        ToolTip="{DynamicResource Settings.OverviewKpis.Title}">
                        <ds:AppIcon FontSize="{StaticResource Font.Size.Md}" Symbol="Settings24" />
                    </Button>
                    <ItemsControl Margin="-4,0,-4,0" ItemsSource="{Binding KpiCards}">
                        <ItemsControl.ItemsPanel>
                            <ItemsPanelTemplate>
                                <UniformGrid Rows="1" />
                            </ItemsPanelTemplate>
                        </ItemsControl.ItemsPanel>
                        <ItemsControl.ItemTemplate>
                            <DataTemplate>
                                <Border Margin="4,0" Style="{StaticResource FormCard}">
                                    <StackPanel>
                                        <TextBlock
                                            FontSize="{StaticResource Font.Size.Xs}"
                                            Foreground="{DynamicResource AppTextMuted}"
                                            Text="{Binding LabelKey, Converter={StaticResource ResourceKeyToStringConverter}}" />
                                        <TextBlock
                                            Margin="0,8,0,0"
                                            FontFamily="{StaticResource Font.Family.Base}"
                                            FontSize="{StaticResource Font.Size.Lg}"
                                            FontWeight="SemiBold"
                                            Text="{Binding ValueDisplay}"
                                            Typography.NumeralAlignment="Tabular">
                                            <TextBlock.Style>
                                                <Style TargetType="TextBlock">
                                                    <Setter Property="Foreground" Value="{DynamicResource AppTextPrimary}" />
                                                    <Style.Triggers>
                                                        <DataTrigger Binding="{Binding Tone}" Value="Up">
                                                            <Setter Property="Foreground" Value="{DynamicResource AppUp}" />
                                                        </DataTrigger>
                                                        <DataTrigger Binding="{Binding Tone}" Value="Down">
                                                            <Setter Property="Foreground" Value="{DynamicResource AppDown}" />
                                                        </DataTrigger>
                                                        <DataTrigger Binding="{Binding Tone}" Value="Accent">
                                                            <Setter Property="Foreground" Value="{DynamicResource AppAccent}" />
                                                        </DataTrigger>
                                                    </Style.Triggers>
                                                </Style>
                                            </TextBlock.Style>
                                        </TextBlock>
                                        <!--
                                            Optional secondary line — 例：負債比率 27.1% 下方顯示
                                            「槓桿比 1.37」副值。HasSecondary=false 時 TextBlock 不渲染。
                                        -->
                                        <TextBlock
                                            Margin="0,4,0,0"
                                            FontFamily="{StaticResource Font.Family.Base}"
                                            FontSize="{StaticResource Font.Size.Xs}"
                                            Foreground="{DynamicResource AppTextMuted}"
                                            Typography.NumeralAlignment="Tabular"
                                            Visibility="{Binding HasSecondary, Converter={StaticResource BooleanToVisibilityConverter}}">
                                            <Run Text="{Binding SecondaryLabelKey, Converter={StaticResource ResourceKeyToStringConverter}, Mode=OneWay}" />
                                            <Run Text=" " />
                                            <Run Text="{Binding SecondaryValueDisplay, Mode=OneWay}" />
                                        </TextBlock>
                                    </StackPanel>
                                </Border>
                            </DataTemplate>
                        </ItemsControl.ItemTemplate>
                    </ItemsControl>
                </DockPanel>

                <!--
                    v2 consolidation 2026-05-13：TodaysMoversWidget 已合併進
                    InvestmentFocusWidget 內「今日漲跌」sub-section。獨立 widget
                    保留檔案但不再被引用，避免訊息分散。
                -->

                <!--  ↓ 投資焦點：總市值 / 成本 / 總損益 + 淨值走勢 + 今日漲跌 (merged)  -->
                <widgets:InvestmentFocusWidget />

                <!--  ↓ 助手洞察：有洞察才顯示（widget 內部 visibility 控制）  -->
                <widgets:AssistantWidget />

                <!--  ↓ 目標 / FIRE 並排  -->
                <Grid Margin="0,0,0,4">
                    <Grid.ColumnDefinitions>
                        <ColumnDefinition Width="*" />
                        <ColumnDefinition Width="*" />
                    </Grid.ColumnDefinitions>
                    <widgets:GoalsWidget Grid.Column="0" Margin="0,0,6,0" />
                    <widgets:FireWidget Grid.Column="1" Margin="6,0,0,0" />
                </Grid>

                <!--
                    Removed (v2 consolidation 2026-05-13)：資產 / 投資 / 負債 三個
                    Expander 已從總覽移除。理由：
                    - 跟 ❹ 資產組成 view 嚴重重複（後者是 aggregated stacked bar
                    + legend，前者是 grouped flat list — 同樣資料兩種呈現）
                    - 每個 tab 分頁本身已有 DataGrid 細部資料，drill-down 走
                    navigation 即可，不需要 dashboard inline 全展開
                    - 減少 scroll 高度 ~600px，視覺集中
                -->

            </StackPanel>
        </ScrollViewer>

        <!--
            ═══ 「從這裡開始」onboarding hero（全新使用者空狀態） ═══
            IsEmpty=True 時覆蓋整頁、置中顯示。golden action =「加第一筆持股」
            (→ Portfolio)；兩個 secondary quick-start =「串現金帳戶」(→ CashAccounts)
            /「記一筆收支」(→ Categories)。CTA 全走既有 ShellNavigationEvents
            RequestNavigateTo（NavigateToXxxCommand），跟其他 widget 導覽同一機制。
            使用共用 AppEmptyState* 樣式，視覺跟各頁空狀態一致。
        -->
        <StackPanel
            Style="{StaticResource AppEmptyState}"
            Visibility="{Binding IsEmpty, Converter={StaticResource BooleanToVisibilityConverter}}">
            <ds:AppIcon Style="{StaticResource EmptyStateIcon}" Symbol="Rocket24" />
            <TextBlock Style="{StaticResource AppEmptyStateTitle}" Text="{DynamicResource Overview.Empty.Title}" />
            <StackPanel Style="{StaticResource AppEmptyStateActionBar}">
                <!--  Golden action：加第一筆持股 → 投資組合  -->
                <Button
                    Command="{Binding NavigateToPortfolioCommand}"
                    Style="{StaticResource AppEmptyStatePrimaryAction}">
                    <StackPanel Style="{StaticResource AppButtonContent}">
                        <ds:AppIcon Style="{StaticResource AppButtonLeadingIcon}" Symbol="Add24" />
                        <TextBlock Style="{StaticResource AppButtonText}" Text="{DynamicResource Overview.Empty.PrimaryCta}" />
                    </StackPanel>
                </Button>
            </StackPanel>
            <!--  Secondary quick-starts — 並排，次要視覺權重  -->
            <StackPanel HorizontalAlignment="Center" Margin="0,10,0,0" Orientation="Horizontal">
                <Button
                    Margin="0,0,8,0"
                    Command="{Binding NavigateToCashAccountsCommand}"
                    Style="{StaticResource AppEmptyStateSecondaryAction}">
                    <TextBlock Style="{StaticResource AppButtonText}" Text="{DynamicResource Overview.Empty.QuickCash}" />
                </Button>
                <Button
                    Command="{Binding NavigateToCategoriesCommand}"
                    Style="{StaticResource AppEmptyStateSecondaryAction}">
                    <TextBlock Style="{StaticResource AppButtonText}" Text="{DynamicResource Overview.Empty.QuickExpense}" />
                </Button>
            </StackPanel>
        </StackPanel>

        <!--  ── KPI selector dialog ──────────────────────────────────────  -->
        <Grid behaviors:EscapeKeyCommandBehavior.Command="{Binding CloseKpiEditorCommand}" Visibility="{Binding IsKpiEditorOpen, Converter={StaticResource BooleanToVisibilityConverter}}">
            <!--  Backdrop  -->
            <Border Background="{DynamicResource AppModalOverlay}" MouseDown="KpiEditorBackdrop_MouseDown" />
            <!--  Card  -->
            <Border
                MaxWidth="520"
                MaxHeight="640"
                Margin="24"
                HorizontalAlignment="Center"
                VerticalAlignment="Center"
                Style="{StaticResource AppDialogShell}">
                <Grid>
                    <Grid.RowDefinitions>
                        <RowDefinition Height="Auto" />
                        <RowDefinition Height="*" />
                        <RowDefinition Height="Auto" />
                    </Grid.RowDefinitions>

                    <!--  Header  -->
                    <StackPanel Grid.Row="0" Margin="0,0,0,16">
                        <TextBlock
                            FontSize="{StaticResource Font.Size.Lg}"
                            FontWeight="SemiBold"
                            Foreground="{DynamicResource AppTextPrimary}"
                            Text="{DynamicResource Settings.OverviewKpis.Title}" />
                        <TextBlock
                            Margin="0,4,0,0"
                            FontSize="{StaticResource Font.Size.Xs}"
                            Foreground="{DynamicResource AppTextMuted}"
                            Text="{DynamicResource Settings.OverviewKpis.Description}"
                            TextWrapping="Wrap" />
                    </StackPanel>

                    <!--  Checkbox list  -->
                    <ScrollViewer Grid.Row="1" VerticalScrollBarVisibility="Auto">
                        <ItemsControl ItemsSource="{Binding KpiEditorItems}">
                            <ItemsControl.ItemTemplate>
                                <DataTemplate>
                                    <Grid Margin="0,4">
                                        <Grid.ColumnDefinitions>
                                            <ColumnDefinition Width="*" />
                                            <ColumnDefinition Width="Auto" />
                                            <ColumnDefinition Width="Auto" />
                                        </Grid.ColumnDefinitions>
                                        <CheckBox Grid.Column="0" IsChecked="{Binding IsSelected, Mode=TwoWay}">
                                            <StackPanel>
                                                <TextBlock
                                                    FontSize="{StaticResource Font.Size.Sm}"
                                                    FontWeight="Medium"
                                                    Foreground="{DynamicResource AppTextPrimary}"
                                                    Text="{Binding LabelKey, Converter={StaticResource ResourceKeyToStringConverter}}" />
                                                <TextBlock
                                                    Margin="0,2,0,0"
                                                    FontSize="{StaticResource Font.Size.Xs}"
                                                    Foreground="{DynamicResource AppTextMuted}"
                                                    Text="{Binding DescriptionKey, Converter={StaticResource ResourceKeyToStringConverter}}"
                                                    TextWrapping="Wrap" />
                                            </StackPanel>
                                        </CheckBox>
                                        <!--  v2：reorder（▲▼）— 按勾選順序排會混亂，用上下鈕較直覺。  -->
                                        <Button
                                            Grid.Column="1"
                                            Width="28"
                                            Height="28"
                                            Margin="0,0,4,0"
                                            Padding="0"
                                            Command="{Binding DataContext.MoveKpiUpCommand, RelativeSource={RelativeSource AncestorType=UserControl}}"
                                            CommandParameter="{Binding}"
                                            Style="{StaticResource AppIconButton}"
                                            ToolTip="{DynamicResource FinancialOverview.Kpi.MoveUp}">
                                            <ds:AppIcon
                                                FontSize="14"
                                                Foreground="{DynamicResource AppTextSecondary}"
                                                Symbol="ChevronUp24" />
                                        </Button>
                                        <Button
                                            Grid.Column="2"
                                            Width="28"
                                            Height="28"
                                            Padding="0"
                                            Command="{Binding DataContext.MoveKpiDownCommand, RelativeSource={RelativeSource AncestorType=UserControl}}"
                                            CommandParameter="{Binding}"
                                            Style="{StaticResource AppIconButton}"
                                            ToolTip="{DynamicResource FinancialOverview.Kpi.MoveDown}">
                                            <ds:AppIcon
                                                FontSize="14"
                                                Foreground="{DynamicResource AppTextSecondary}"
                                                Symbol="ChevronDown24" />
                                        </Button>
                                    </Grid>
                                </DataTemplate>
                            </ItemsControl.ItemTemplate>
                        </ItemsControl>
                    </ScrollViewer>

                    <!--  Footer  -->
                    <DockPanel
                        Grid.Row="2"
                        Margin="0,16,0,0"
                        LastChildFill="False">
                        <TextBlock
                            VerticalAlignment="Center"
                            DockPanel.Dock="Left"
                            FontSize="{StaticResource Font.Size.Xs}"
                            Foreground="{DynamicResource AppTextMuted}">
                            <Run Text="{Binding KpiSelectedCount, Mode=OneWay}" />
                            <Run Text=" / " />
                            <Run Text="{Binding KpiMaxSelected, Mode=OneWay}" />
                            <Run Text=" (min " />
                            <Run Text="{Binding KpiMinSelected, Mode=OneWay}" />
                            <Run Text=")" />
                        </TextBlock>
                        <Button
                            Height="32"
                            MinHeight="32"
                            Margin="0,0,0,0"
                            Padding="14,0"
                            Command="{Binding SaveKpiSelectionCommand}"
                            DockPanel.Dock="Right"
                            Style="{StaticResource AppPrimaryButton}">
                            <TextBlock Style="{StaticResource AppButtonText}" Text="{DynamicResource Common.Save}" />
                        </Button>
                        <Button
                            Height="32"
                            MinHeight="32"
                            Margin="0,0,8,0"
                            Padding="14,0"
                            Command="{Binding CloseKpiEditorCommand}"
                            DockPanel.Dock="Right"
                            Style="{StaticResource AppSecondaryButton}">
                            <TextBlock Style="{StaticResource AppButtonText}" Text="{DynamicResource Common.Cancel}" />
                        </Button>
                    </DockPanel>
                </Grid>
            </Border>
        </Grid>

    </Grid>
</UserControl>
