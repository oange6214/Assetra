<UserControl
    x:Class="Assetra.WPF.Features.FinancialOverview.FinancialOverviewView"
    xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
    xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
    xmlns:d="http://schemas.microsoft.com/expression/blend/2008"
    xmlns:mc="http://schemas.openxmlformats.org/markup-compatibility/2006"
    xmlns:vm="clr-namespace:Assetra.WPF.Features.FinancialOverview"
    d:DataContext="{d:DesignInstance Type={x:Type vm:FinancialOverviewViewModel}}"
    d:DesignHeight="800"
    d:DesignWidth="900"
    Background="{DynamicResource AppBackground}"
    mc:Ignorable="d">

    <Grid Style="{StaticResource PageRootGrid}">
        <Grid.RowDefinitions>
            <RowDefinition Height="Auto" />
            <RowDefinition Height="*" />
        </Grid.RowDefinitions>

        <!--  ── KPI Bar ─────────────────────────────────────────────────────  -->
        <UniformGrid
            Grid.Row="0"
            Margin="0,0,0,16"
            Columns="4"
            Rows="1">

            <!--  總淨資產  -->
            <Border Margin="0,0,8,0" Style="{StaticResource FormCard}">
                <StackPanel>
                    <TextBlock
                        FontSize="{StaticResource Font.Size.Xs}"
                        Foreground="{DynamicResource AppTextMuted}"
                        Text="{DynamicResource FinancialOverview.Header.NetWorth}" />
                    <TextBlock
                        Margin="0,8,0,0"
                        FontFamily="{StaticResource Font.Family.Base}"
                        Typography.NumeralAlignment="Tabular"
                        FontSize="{StaticResource Font.Size.Lg}"
                        FontWeight="SemiBold"
                        Foreground="{DynamicResource AppTextPrimary}"
                        Text="{Binding TotalNetWorthDisplay}" />
                </StackPanel>
            </Border>

            <!--  資產  -->
            <Border Margin="8,0" Style="{StaticResource FormCard}">
                <StackPanel>
                    <TextBlock
                        FontSize="{StaticResource Font.Size.Xs}"
                        Foreground="{DynamicResource AppTextMuted}"
                        Text="{DynamicResource FinancialOverview.Header.Assets}" />
                    <TextBlock
                        Margin="0,8,0,0"
                        FontFamily="{StaticResource Font.Family.Base}"
                        Typography.NumeralAlignment="Tabular"
                        FontSize="{StaticResource Font.Size.Lg}"
                        FontWeight="SemiBold"
                        Foreground="{DynamicResource AppUp}"
                        Text="{Binding TotalAssetsDisplay}" />
                </StackPanel>
            </Border>

            <!--  投資  -->
            <Border Margin="8,0" Style="{StaticResource FormCard}">
                <StackPanel>
                    <TextBlock
                        FontSize="{StaticResource Font.Size.Xs}"
                        Foreground="{DynamicResource AppTextMuted}"
                        Text="{DynamicResource FinancialOverview.Header.Investments}" />
                    <TextBlock
                        Margin="0,8,0,0"
                        FontFamily="{StaticResource Font.Family.Base}"
                        Typography.NumeralAlignment="Tabular"
                        FontSize="{StaticResource Font.Size.Lg}"
                        FontWeight="SemiBold"
                        Foreground="{DynamicResource AppAccent}"
                        Text="{Binding TotalInvestmentsDisplay}" />
                </StackPanel>
            </Border>

            <!--  負債  -->
            <Border Margin="8,0,0,0" Style="{StaticResource FormCard}">
                <StackPanel>
                    <TextBlock
                        FontSize="{StaticResource Font.Size.Xs}"
                        Foreground="{DynamicResource AppTextMuted}"
                        Text="{DynamicResource FinancialOverview.Header.Liabilities}" />
                    <TextBlock
                        Margin="0,8,0,0"
                        FontFamily="{StaticResource Font.Family.Base}"
                        Typography.NumeralAlignment="Tabular"
                        FontSize="{StaticResource Font.Size.Lg}"
                        FontWeight="SemiBold"
                        Foreground="{DynamicResource AppDown}"
                        Text="{Binding TotalLiabilitiesDisplay}" />
                </StackPanel>
            </Border>
        </UniformGrid>

        <!--  ── Accordion  ───────────────────────────────────────────────────  -->
        <ScrollViewer
            Grid.Row="1"
            Margin="0"
            VerticalScrollBarVisibility="Auto">
            <StackPanel>

                <!--  資產 Expander  -->
                <Expander
                    Margin="0,0,0,16"
                    Background="{DynamicResource AppSurface}"
                    BorderBrush="{DynamicResource AppBorder}"
                    BorderThickness="1"
                    Foreground="{DynamicResource AppTextPrimary}"
                    IsExpanded="True">
                    <Expander.Header>
                        <TextBlock
                            FontSize="{StaticResource Font.Size.Md}"
                            FontWeight="SemiBold"
                            Foreground="{DynamicResource AppUp}"
                            Text="{DynamicResource FinancialOverview.Section.Assets}" />
                    </Expander.Header>
                    <ItemsControl Margin="0,4,0,4" ItemsSource="{Binding AssetGroups}">
                        <ItemsControl.ItemTemplate>
                            <DataTemplate DataType="{x:Type vm:AssetGroupVm}">
                                <StackPanel Margin="8,4">
                                    <Grid Margin="0,2,0,4">
                                        <Grid.ColumnDefinitions>
                                            <ColumnDefinition Width="*" />
                                            <ColumnDefinition Width="Auto" />
                                        </Grid.ColumnDefinitions>
                                        <TextBlock
                                            Grid.Column="0"
                                            FontSize="{StaticResource Font.Size.Base}"
                                            FontWeight="SemiBold"
                                            Foreground="{DynamicResource AppTextMuted}"
                                            Text="{Binding Name}" />
                                        <TextBlock
                                            Grid.Column="1"
                                            FontSize="{StaticResource Font.Size.Base}"
                                            Foreground="{DynamicResource AppTextMuted}"
                                            Text="{Binding SubtotalDisplay}" />
                                    </Grid>
                                    <ItemsControl ItemsSource="{Binding Items}">
                                        <ItemsControl.ItemTemplate>
                                            <DataTemplate DataType="{x:Type vm:AssetItemVm}">
                                                <Grid Margin="12,2,0,2">
                                                    <Grid.ColumnDefinitions>
                                                        <ColumnDefinition Width="*" />
                                                        <ColumnDefinition Width="Auto" />
                                                    </Grid.ColumnDefinitions>
                                                    <TextBlock
                                                        Grid.Column="0"
                                                        FontSize="{StaticResource Font.Size.Base}"
                                                        Foreground="{DynamicResource AppTextPrimary}"
                                                        Text="{Binding Name}" />
                                                    <TextBlock
                                                        Grid.Column="1"
                                                        FontSize="{StaticResource Font.Size.Base}"
                                                        Foreground="{DynamicResource AppTextPrimary}"
                                                        Text="{Binding CurrentValueDisplay}" />
                                                </Grid>
                                            </DataTemplate>
                                        </ItemsControl.ItemTemplate>
                                    </ItemsControl>
                                </StackPanel>
                            </DataTemplate>
                        </ItemsControl.ItemTemplate>
                    </ItemsControl>
                </Expander>

                <!--  投資 Expander  -->
                <Expander
                    Margin="0,0,0,16"
                    Background="{DynamicResource AppSurface}"
                    BorderBrush="{DynamicResource AppBorder}"
                    BorderThickness="1"
                    Foreground="{DynamicResource AppTextPrimary}"
                    IsExpanded="True">
                    <Expander.Header>
                        <TextBlock
                            FontSize="{StaticResource Font.Size.Md}"
                            FontWeight="SemiBold"
                            Foreground="{DynamicResource AppAccent}"
                            Text="{DynamicResource FinancialOverview.Section.Investments}" />
                    </Expander.Header>
                    <ItemsControl Margin="0,4,0,4" ItemsSource="{Binding InvestGroups}">
                        <ItemsControl.ItemTemplate>
                            <DataTemplate DataType="{x:Type vm:AssetGroupVm}">
                                <StackPanel Margin="8,4">
                                    <Grid Margin="0,2,0,4">
                                        <Grid.ColumnDefinitions>
                                            <ColumnDefinition Width="*" />
                                            <ColumnDefinition Width="Auto" />
                                        </Grid.ColumnDefinitions>
                                        <TextBlock
                                            Grid.Column="0"
                                            FontSize="{StaticResource Font.Size.Base}"
                                            FontWeight="SemiBold"
                                            Foreground="{DynamicResource AppTextMuted}"
                                            Text="{Binding Name}" />
                                        <TextBlock
                                            Grid.Column="1"
                                            FontSize="{StaticResource Font.Size.Base}"
                                            Foreground="{DynamicResource AppTextMuted}"
                                            Text="{Binding SubtotalDisplay}" />
                                    </Grid>
                                    <ItemsControl ItemsSource="{Binding Items}">
                                        <ItemsControl.ItemTemplate>
                                            <DataTemplate DataType="{x:Type vm:AssetItemVm}">
                                                <Grid Margin="12,2,0,2">
                                                    <Grid.ColumnDefinitions>
                                                        <ColumnDefinition Width="*" />
                                                        <ColumnDefinition Width="Auto" />
                                                    </Grid.ColumnDefinitions>
                                                    <TextBlock
                                                        Grid.Column="0"
                                                        FontSize="{StaticResource Font.Size.Base}"
                                                        Foreground="{DynamicResource AppTextPrimary}"
                                                        Text="{Binding Name}" />
                                                    <TextBlock
                                                        Grid.Column="1"
                                                        FontSize="{StaticResource Font.Size.Base}"
                                                        Foreground="{DynamicResource AppTextPrimary}"
                                                        Text="{Binding CurrentValueDisplay}" />
                                                </Grid>
                                            </DataTemplate>
                                        </ItemsControl.ItemTemplate>
                                    </ItemsControl>
                                </StackPanel>
                            </DataTemplate>
                        </ItemsControl.ItemTemplate>
                    </ItemsControl>
                </Expander>

                <!--  負債 Expander  -->
                <Expander
                    Margin="0,0,0,16"
                    Background="{DynamicResource AppSurface}"
                    BorderBrush="{DynamicResource AppBorder}"
                    BorderThickness="1"
                    Foreground="{DynamicResource AppTextPrimary}"
                    IsExpanded="True">
                    <Expander.Header>
                        <TextBlock
                            FontSize="{StaticResource Font.Size.Md}"
                            FontWeight="SemiBold"
                            Foreground="{DynamicResource AppDown}"
                            Text="{DynamicResource FinancialOverview.Section.Liabilities}" />
                    </Expander.Header>
                    <ItemsControl Margin="0,4,0,4" ItemsSource="{Binding LiabGroups}">
                        <ItemsControl.ItemTemplate>
                            <DataTemplate DataType="{x:Type vm:AssetGroupVm}">
                                <StackPanel Margin="8,4">
                                    <Grid Margin="0,2,0,4">
                                        <Grid.ColumnDefinitions>
                                            <ColumnDefinition Width="*" />
                                            <ColumnDefinition Width="Auto" />
                                        </Grid.ColumnDefinitions>
                                        <TextBlock
                                            Grid.Column="0"
                                            FontSize="{StaticResource Font.Size.Base}"
                                            FontWeight="SemiBold"
                                            Foreground="{DynamicResource AppTextMuted}"
                                            Text="{Binding Name}" />
                                        <TextBlock
                                            Grid.Column="1"
                                            FontSize="{StaticResource Font.Size.Base}"
                                            Foreground="{DynamicResource AppTextMuted}"
                                            Text="{Binding SubtotalDisplay}" />
                                    </Grid>
                                    <ItemsControl ItemsSource="{Binding Items}">
                                        <ItemsControl.ItemTemplate>
                                            <DataTemplate DataType="{x:Type vm:AssetItemVm}">
                                                <Grid Margin="12,2,0,2">
                                                    <Grid.ColumnDefinitions>
                                                        <ColumnDefinition Width="*" />
                                                        <ColumnDefinition Width="Auto" />
                                                    </Grid.ColumnDefinitions>
                                                    <TextBlock
                                                        Grid.Column="0"
                                                        FontSize="{StaticResource Font.Size.Base}"
                                                        Foreground="{DynamicResource AppTextPrimary}"
                                                        Text="{Binding Name}" />
                                                    <TextBlock
                                                        Grid.Column="1"
                                                        FontSize="{StaticResource Font.Size.Base}"
                                                        Foreground="{DynamicResource AppDown}"
                                                        Text="{Binding CurrentValueDisplay}" />
                                                </Grid>
                                            </DataTemplate>
                                        </ItemsControl.ItemTemplate>
                                    </ItemsControl>
                                </StackPanel>
                            </DataTemplate>
                        </ItemsControl.ItemTemplate>
                    </ItemsControl>
                </Expander>

            </StackPanel>
        </ScrollViewer>

    </Grid>
</UserControl>
