<UserControl
    x:Class="Assetra.WPF.Features.FinancialOverview.FinancialOverviewView"
    xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
    xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
    xmlns:d="http://schemas.microsoft.com/expression/blend/2008"
    xmlns:mc="http://schemas.openxmlformats.org/markup-compatibility/2006"
    xmlns:vm="clr-namespace:Assetra.WPF.Features.FinancialOverview"
    d:DataContext="{d:DesignInstance Type={x:Type vm:FinancialOverviewViewModel}, IsDesignTimeCreatable=False}"
    d:DesignHeight="800"
    d:DesignWidth="900"
    Background="{DynamicResource AppBackground}"
    mc:Ignorable="d">

    <Grid>
        <Grid.RowDefinitions>
            <RowDefinition Height="Auto" />
            <RowDefinition Height="*" />
        </Grid.RowDefinitions>

        <!--  ── KPI Bar ─────────────────────────────────────────────────────  -->
        <Border
            Grid.Row="0"
            Margin="16,12,16,0"
            Background="{DynamicResource AppSurface}"
            BorderBrush="{DynamicResource AppBorder}"
            BorderThickness="1"
            CornerRadius="{StaticResource RadiusMd}">
            <Grid Margin="16,12">
                <Grid.ColumnDefinitions>
                    <ColumnDefinition Width="*" />
                    <ColumnDefinition Width="*" />
                    <ColumnDefinition Width="*" />
                    <ColumnDefinition Width="*" />
                </Grid.ColumnDefinitions>

                <!--  總淨資產  -->
                <StackPanel Grid.Column="0" Margin="0,0,8,0">
                    <TextBlock
                        FontSize="{StaticResource FontSizeSm}"
                        Foreground="{DynamicResource AppTextMuted}"
                        Text="{DynamicResource FinancialOverview.Header.NetWorth}" />
                    <TextBlock
                        FontSize="{StaticResource FontSizeLg}"
                        FontWeight="SemiBold"
                        Foreground="{DynamicResource AppTextPrimary}"
                        Text="{Binding TotalNetWorthDisplay}" />
                </StackPanel>

                <!--  資產  -->
                <StackPanel Grid.Column="1" Margin="8,0">
                    <TextBlock
                        FontSize="{StaticResource FontSizeSm}"
                        Foreground="{DynamicResource AppTextMuted}"
                        Text="{DynamicResource FinancialOverview.Header.Assets}" />
                    <TextBlock
                        FontSize="{StaticResource FontSizeLg}"
                        FontWeight="SemiBold"
                        Foreground="{DynamicResource AppUp}"
                        Text="{Binding TotalAssetsDisplay}" />
                </StackPanel>

                <!--  投資  -->
                <StackPanel Grid.Column="2" Margin="8,0">
                    <TextBlock
                        FontSize="{StaticResource FontSizeSm}"
                        Foreground="{DynamicResource AppTextMuted}"
                        Text="{DynamicResource FinancialOverview.Header.Investments}" />
                    <TextBlock
                        FontSize="{StaticResource FontSizeLg}"
                        FontWeight="SemiBold"
                        Foreground="{DynamicResource AppAccent}"
                        Text="{Binding TotalInvestmentsDisplay}" />
                </StackPanel>

                <!--  負債  -->
                <StackPanel Grid.Column="3" Margin="8,0,0,0">
                    <TextBlock
                        FontSize="{StaticResource FontSizeSm}"
                        Foreground="{DynamicResource AppTextMuted}"
                        Text="{DynamicResource FinancialOverview.Header.Liabilities}" />
                    <TextBlock
                        FontSize="{StaticResource FontSizeLg}"
                        FontWeight="SemiBold"
                        Foreground="{DynamicResource AppDown}"
                        Text="{Binding TotalLiabilitiesDisplay}" />
                </StackPanel>
            </Grid>
        </Border>

        <!--  ── Accordion  ───────────────────────────────────────────────────  -->
        <ScrollViewer Grid.Row="1" Margin="16,8,16,16" VerticalScrollBarVisibility="Auto">
            <StackPanel>

                <!--  資產 Expander  -->
                <Expander
                    Margin="0,0,0,8"
                    IsExpanded="True"
                    Background="{DynamicResource AppSurface}"
                    BorderBrush="{DynamicResource AppBorder}"
                    BorderThickness="1"
                    Foreground="{DynamicResource AppTextPrimary}">
                    <Expander.Header>
                        <TextBlock
                            FontSize="{StaticResource FontSizeMd}"
                            FontWeight="SemiBold"
                            Foreground="{DynamicResource AppUp}"
                            Text="{DynamicResource FinancialOverview.Section.Assets}" />
                    </Expander.Header>
                    <ItemsControl ItemsSource="{Binding AssetGroups}" Margin="0,4,0,4">
                        <ItemsControl.ItemTemplate>
                            <DataTemplate DataType="{x:Type vm:AssetGroupVm}">
                                <StackPanel Margin="8,4">
                                    <Grid Margin="0,2,0,4">
                                        <Grid.ColumnDefinitions>
                                            <ColumnDefinition Width="*" />
                                            <ColumnDefinition Width="Auto" />
                                        </Grid.ColumnDefinitions>
                                        <TextBlock
                                            Grid.Column="0"
                                            FontSize="{StaticResource FontSizeBase}"
                                            FontWeight="SemiBold"
                                            Foreground="{DynamicResource AppTextMuted}"
                                            Text="{Binding Name}" />
                                        <TextBlock
                                            Grid.Column="1"
                                            FontSize="{StaticResource FontSizeBase}"
                                            Foreground="{DynamicResource AppTextMuted}"
                                            Text="{Binding SubtotalDisplay}" />
                                    </Grid>
                                    <ItemsControl ItemsSource="{Binding Items}">
                                        <ItemsControl.ItemTemplate>
                                            <DataTemplate DataType="{x:Type vm:AssetItemVm}">
                                                <Grid Margin="12,2,0,2">
                                                    <Grid.ColumnDefinitions>
                                                        <ColumnDefinition Width="*" />
                                                        <ColumnDefinition Width="Auto" />
                                                    </Grid.ColumnDefinitions>
                                                    <TextBlock
                                                        Grid.Column="0"
                                                        FontSize="{StaticResource FontSizeBase}"
                                                        Foreground="{DynamicResource AppTextPrimary}"
                                                        Text="{Binding Name}" />
                                                    <TextBlock
                                                        Grid.Column="1"
                                                        FontSize="{StaticResource FontSizeBase}"
                                                        Foreground="{DynamicResource AppTextPrimary}"
                                                        Text="{Binding CurrentValueDisplay}" />
                                                </Grid>
                                            </DataTemplate>
                                        </ItemsControl.ItemTemplate>
                                    </ItemsControl>
                                </StackPanel>
                            </DataTemplate>
                        </ItemsControl.ItemTemplate>
                    </ItemsControl>
                </Expander>

                <!--  投資 Expander  -->
                <Expander
                    Margin="0,0,0,8"
                    IsExpanded="True"
                    Background="{DynamicResource AppSurface}"
                    BorderBrush="{DynamicResource AppBorder}"
                    BorderThickness="1"
                    Foreground="{DynamicResource AppTextPrimary}">
                    <Expander.Header>
                        <TextBlock
                            FontSize="{StaticResource FontSizeMd}"
                            FontWeight="SemiBold"
                            Foreground="{DynamicResource AppAccent}"
                            Text="{DynamicResource FinancialOverview.Section.Investments}" />
                    </Expander.Header>
                    <ItemsControl ItemsSource="{Binding InvestGroups}" Margin="0,4,0,4">
                        <ItemsControl.ItemTemplate>
                            <DataTemplate DataType="{x:Type vm:AssetGroupVm}">
                                <StackPanel Margin="8,4">
                                    <Grid Margin="0,2,0,4">
                                        <Grid.ColumnDefinitions>
                                            <ColumnDefinition Width="*" />
                                            <ColumnDefinition Width="Auto" />
                                        </Grid.ColumnDefinitions>
                                        <TextBlock
                                            Grid.Column="0"
                                            FontSize="{StaticResource FontSizeBase}"
                                            FontWeight="SemiBold"
                                            Foreground="{DynamicResource AppTextMuted}"
                                            Text="{Binding Name}" />
                                        <TextBlock
                                            Grid.Column="1"
                                            FontSize="{StaticResource FontSizeBase}"
                                            Foreground="{DynamicResource AppTextMuted}"
                                            Text="{Binding SubtotalDisplay}" />
                                    </Grid>
                                    <ItemsControl ItemsSource="{Binding Items}">
                                        <ItemsControl.ItemTemplate>
                                            <DataTemplate DataType="{x:Type vm:AssetItemVm}">
                                                <Grid Margin="12,2,0,2">
                                                    <Grid.ColumnDefinitions>
                                                        <ColumnDefinition Width="*" />
                                                        <ColumnDefinition Width="Auto" />
                                                    </Grid.ColumnDefinitions>
                                                    <TextBlock
                                                        Grid.Column="0"
                                                        FontSize="{StaticResource FontSizeBase}"
                                                        Foreground="{DynamicResource AppTextPrimary}"
                                                        Text="{Binding Name}" />
                                                    <TextBlock
                                                        Grid.Column="1"
                                                        FontSize="{StaticResource FontSizeBase}"
                                                        Foreground="{DynamicResource AppTextPrimary}"
                                                        Text="{Binding CurrentValueDisplay}" />
                                                </Grid>
                                            </DataTemplate>
                                        </ItemsControl.ItemTemplate>
                                    </ItemsControl>
                                </StackPanel>
                            </DataTemplate>
                        </ItemsControl.ItemTemplate>
                    </ItemsControl>
                </Expander>

                <!--  負債 Expander  -->
                <Expander
                    Margin="0,0,0,8"
                    IsExpanded="True"
                    Background="{DynamicResource AppSurface}"
                    BorderBrush="{DynamicResource AppBorder}"
                    BorderThickness="1"
                    Foreground="{DynamicResource AppTextPrimary}">
                    <Expander.Header>
                        <TextBlock
                            FontSize="{StaticResource FontSizeMd}"
                            FontWeight="SemiBold"
                            Foreground="{DynamicResource AppDown}"
                            Text="{DynamicResource FinancialOverview.Section.Liabilities}" />
                    </Expander.Header>
                    <ItemsControl ItemsSource="{Binding LiabGroups}" Margin="0,4,0,4">
                        <ItemsControl.ItemTemplate>
                            <DataTemplate DataType="{x:Type vm:AssetGroupVm}">
                                <StackPanel Margin="8,4">
                                    <Grid Margin="0,2,0,4">
                                        <Grid.ColumnDefinitions>
                                            <ColumnDefinition Width="*" />
                                            <ColumnDefinition Width="Auto" />
                                        </Grid.ColumnDefinitions>
                                        <TextBlock
                                            Grid.Column="0"
                                            FontSize="{StaticResource FontSizeBase}"
                                            FontWeight="SemiBold"
                                            Foreground="{DynamicResource AppTextMuted}"
                                            Text="{Binding Name}" />
                                        <TextBlock
                                            Grid.Column="1"
                                            FontSize="{StaticResource FontSizeBase}"
                                            Foreground="{DynamicResource AppTextMuted}"
                                            Text="{Binding SubtotalDisplay}" />
                                    </Grid>
                                    <ItemsControl ItemsSource="{Binding Items}">
                                        <ItemsControl.ItemTemplate>
                                            <DataTemplate DataType="{x:Type vm:AssetItemVm}">
                                                <Grid Margin="12,2,0,2">
                                                    <Grid.ColumnDefinitions>
                                                        <ColumnDefinition Width="*" />
                                                        <ColumnDefinition Width="Auto" />
                                                    </Grid.ColumnDefinitions>
                                                    <TextBlock
                                                        Grid.Column="0"
                                                        FontSize="{StaticResource FontSizeBase}"
                                                        Foreground="{DynamicResource AppTextPrimary}"
                                                        Text="{Binding Name}" />
                                                    <TextBlock
                                                        Grid.Column="1"
                                                        FontSize="{StaticResource FontSizeBase}"
                                                        Foreground="{DynamicResource AppDown}"
                                                        Text="{Binding CurrentValueDisplay}" />
                                                </Grid>
                                            </DataTemplate>
                                        </ItemsControl.ItemTemplate>
                                    </ItemsControl>
                                </StackPanel>
                            </DataTemplate>
                        </ItemsControl.ItemTemplate>
                    </ItemsControl>
                </Expander>

            </StackPanel>
        </ScrollViewer>

    </Grid>
</UserControl>
