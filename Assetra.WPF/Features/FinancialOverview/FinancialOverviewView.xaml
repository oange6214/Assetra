<UserControl
    x:Class="Assetra.WPF.Features.FinancialOverview.FinancialOverviewView"
    xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
    xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
    xmlns:d="http://schemas.microsoft.com/expression/blend/2008"
    xmlns:mc="http://schemas.openxmlformats.org/markup-compatibility/2006"
    xmlns:vm="clr-namespace:Assetra.WPF.Features.FinancialOverview"
    d:DataContext="{d:DesignInstance Type={x:Type vm:FinancialOverviewViewModel}}"
    d:DesignHeight="800"
    d:DesignWidth="900"
    Background="{DynamicResource AppBackground}"
    mc:Ignorable="d">

    <Grid Style="{StaticResource PageRootGrid}">
        <Grid.RowDefinitions>
            <RowDefinition Height="Auto" />
            <RowDefinition Height="*" />
        </Grid.RowDefinitions>

        <!--
            KPI Bar — driven by AppSettings.OverviewKpis. The user picks
            which 3-6 metrics to show in the Settings page; this view just
            renders whatever the ViewModel emits.
        -->
        <ItemsControl
            Grid.Row="0"
            Margin="0,0,0,16"
            ItemsSource="{Binding KpiCards}">
            <ItemsControl.ItemsPanel>
                <ItemsPanelTemplate>
                    <UniformGrid Rows="1" />
                </ItemsPanelTemplate>
            </ItemsControl.ItemsPanel>
            <ItemsControl.ItemTemplate>
                <DataTemplate>
                    <Border Margin="4,0" Style="{StaticResource FormCard}">
                        <StackPanel>
                            <TextBlock
                                FontSize="{StaticResource Font.Size.Xs}"
                                Foreground="{DynamicResource AppTextMuted}"
                                Text="{Binding LabelKey, Converter={StaticResource ResourceKeyToStringConverter}}" />
                            <TextBlock
                                Margin="0,8,0,0"
                                FontFamily="{StaticResource Font.Family.Base}"
                                FontSize="{StaticResource Font.Size.Lg}"
                                FontWeight="SemiBold"
                                Text="{Binding ValueDisplay}"
                                Typography.NumeralAlignment="Tabular">
                                <TextBlock.Style>
                                    <Style TargetType="TextBlock">
                                        <Setter Property="Foreground" Value="{DynamicResource AppTextPrimary}" />
                                        <Style.Triggers>
                                            <DataTrigger Binding="{Binding Tone}" Value="Up">
                                                <Setter Property="Foreground" Value="{DynamicResource AppUp}" />
                                            </DataTrigger>
                                            <DataTrigger Binding="{Binding Tone}" Value="Down">
                                                <Setter Property="Foreground" Value="{DynamicResource AppDown}" />
                                            </DataTrigger>
                                            <DataTrigger Binding="{Binding Tone}" Value="Accent">
                                                <Setter Property="Foreground" Value="{DynamicResource AppAccent}" />
                                            </DataTrigger>
                                        </Style.Triggers>
                                    </Style>
                                </TextBlock.Style>
                            </TextBlock>
                        </StackPanel>
                    </Border>
                </DataTemplate>
            </ItemsControl.ItemTemplate>
        </ItemsControl>

        <!--  ── Accordion  ───────────────────────────────────────────────────  -->
        <ScrollViewer
            Grid.Row="1"
            Margin="0"
            VerticalScrollBarVisibility="Auto">
            <StackPanel>

                <!--  資產 Expander  -->
                <Expander
                    Margin="0,0,0,16"
                    IsExpanded="True"
                    Style="{StaticResource AppExpander}">
                    <Expander.Header>
                        <TextBlock
                            FontSize="{StaticResource Font.Size.Md}"
                            FontWeight="SemiBold"
                            Foreground="{DynamicResource AppUp}"
                            Text="{DynamicResource FinancialOverview.Section.Assets}" />
                    </Expander.Header>
                    <ItemsControl Margin="0,4,0,4" ItemsSource="{Binding AssetGroups}">
                        <ItemsControl.ItemTemplate>
                            <DataTemplate DataType="{x:Type vm:AssetGroupVm}">
                                <StackPanel Margin="8,4">
                                    <Grid Margin="0,2,0,4">
                                        <Grid.ColumnDefinitions>
                                            <ColumnDefinition Width="*" />
                                            <ColumnDefinition Width="Auto" />
                                        </Grid.ColumnDefinitions>
                                        <TextBlock
                                            Grid.Column="0"
                                            FontSize="{StaticResource Font.Size.Base}"
                                            FontWeight="SemiBold"
                                            Foreground="{DynamicResource AppTextMuted}"
                                            Text="{Binding Name}" />
                                        <TextBlock
                                            Grid.Column="1"
                                            FontSize="{StaticResource Font.Size.Base}"
                                            Foreground="{DynamicResource AppTextMuted}"
                                            Text="{Binding SubtotalDisplay}" />
                                    </Grid>
                                    <ItemsControl ItemsSource="{Binding Items}">
                                        <ItemsControl.ItemTemplate>
                                            <DataTemplate DataType="{x:Type vm:AssetItemVm}">
                                                <Grid Margin="12,2,0,2">
                                                    <Grid.ColumnDefinitions>
                                                        <ColumnDefinition Width="*" />
                                                        <ColumnDefinition Width="Auto" />
                                                    </Grid.ColumnDefinitions>
                                                    <TextBlock
                                                        Grid.Column="0"
                                                        FontSize="{StaticResource Font.Size.Base}"
                                                        Foreground="{DynamicResource AppTextPrimary}"
                                                        Text="{Binding Name}" />
                                                    <TextBlock
                                                        Grid.Column="1"
                                                        FontSize="{StaticResource Font.Size.Base}"
                                                        Foreground="{DynamicResource AppTextPrimary}"
                                                        Text="{Binding CurrentValueDisplay}" />
                                                </Grid>
                                            </DataTemplate>
                                        </ItemsControl.ItemTemplate>
                                    </ItemsControl>
                                </StackPanel>
                            </DataTemplate>
                        </ItemsControl.ItemTemplate>
                    </ItemsControl>
                </Expander>

                <!--  投資 Expander  -->
                <Expander
                    Margin="0,0,0,16"
                    IsExpanded="True"
                    Style="{StaticResource AppExpander}">
                    <Expander.Header>
                        <TextBlock
                            FontSize="{StaticResource Font.Size.Md}"
                            FontWeight="SemiBold"
                            Foreground="{DynamicResource AppAccent}"
                            Text="{DynamicResource FinancialOverview.Section.Investments}" />
                    </Expander.Header>
                    <ItemsControl Margin="0,4,0,4" ItemsSource="{Binding InvestGroups}">
                        <ItemsControl.ItemTemplate>
                            <DataTemplate DataType="{x:Type vm:AssetGroupVm}">
                                <StackPanel Margin="8,4">
                                    <Grid Margin="0,2,0,4">
                                        <Grid.ColumnDefinitions>
                                            <ColumnDefinition Width="*" />
                                            <ColumnDefinition Width="Auto" />
                                        </Grid.ColumnDefinitions>
                                        <TextBlock
                                            Grid.Column="0"
                                            FontSize="{StaticResource Font.Size.Base}"
                                            FontWeight="SemiBold"
                                            Foreground="{DynamicResource AppTextMuted}"
                                            Text="{Binding Name}" />
                                        <TextBlock
                                            Grid.Column="1"
                                            FontSize="{StaticResource Font.Size.Base}"
                                            Foreground="{DynamicResource AppTextMuted}"
                                            Text="{Binding SubtotalDisplay}" />
                                    </Grid>
                                    <ItemsControl ItemsSource="{Binding Items}">
                                        <ItemsControl.ItemTemplate>
                                            <DataTemplate DataType="{x:Type vm:AssetItemVm}">
                                                <Grid Margin="12,2,0,2">
                                                    <Grid.ColumnDefinitions>
                                                        <ColumnDefinition Width="*" />
                                                        <ColumnDefinition Width="Auto" />
                                                    </Grid.ColumnDefinitions>
                                                    <TextBlock
                                                        Grid.Column="0"
                                                        FontSize="{StaticResource Font.Size.Base}"
                                                        Foreground="{DynamicResource AppTextPrimary}"
                                                        Text="{Binding Name}" />
                                                    <TextBlock
                                                        Grid.Column="1"
                                                        FontSize="{StaticResource Font.Size.Base}"
                                                        Foreground="{DynamicResource AppTextPrimary}"
                                                        Text="{Binding CurrentValueDisplay}" />
                                                </Grid>
                                            </DataTemplate>
                                        </ItemsControl.ItemTemplate>
                                    </ItemsControl>
                                </StackPanel>
                            </DataTemplate>
                        </ItemsControl.ItemTemplate>
                    </ItemsControl>
                </Expander>

                <!--  負債 Expander  -->
                <Expander
                    Margin="0,0,0,16"
                    IsExpanded="True"
                    Style="{StaticResource AppExpander}">
                    <Expander.Header>
                        <TextBlock
                            FontSize="{StaticResource Font.Size.Md}"
                            FontWeight="SemiBold"
                            Foreground="{DynamicResource AppDown}"
                            Text="{DynamicResource FinancialOverview.Section.Liabilities}" />
                    </Expander.Header>
                    <ItemsControl Margin="0,4,0,4" ItemsSource="{Binding LiabGroups}">
                        <ItemsControl.ItemTemplate>
                            <DataTemplate DataType="{x:Type vm:AssetGroupVm}">
                                <StackPanel Margin="8,4">
                                    <Grid Margin="0,2,0,4">
                                        <Grid.ColumnDefinitions>
                                            <ColumnDefinition Width="*" />
                                            <ColumnDefinition Width="Auto" />
                                        </Grid.ColumnDefinitions>
                                        <TextBlock
                                            Grid.Column="0"
                                            FontSize="{StaticResource Font.Size.Base}"
                                            FontWeight="SemiBold"
                                            Foreground="{DynamicResource AppTextMuted}"
                                            Text="{Binding Name}" />
                                        <TextBlock
                                            Grid.Column="1"
                                            FontSize="{StaticResource Font.Size.Base}"
                                            Foreground="{DynamicResource AppTextMuted}"
                                            Text="{Binding SubtotalDisplay}" />
                                    </Grid>
                                    <ItemsControl ItemsSource="{Binding Items}">
                                        <ItemsControl.ItemTemplate>
                                            <DataTemplate DataType="{x:Type vm:AssetItemVm}">
                                                <Grid Margin="12,2,0,2">
                                                    <Grid.ColumnDefinitions>
                                                        <ColumnDefinition Width="*" />
                                                        <ColumnDefinition Width="Auto" />
                                                    </Grid.ColumnDefinitions>
                                                    <TextBlock
                                                        Grid.Column="0"
                                                        FontSize="{StaticResource Font.Size.Base}"
                                                        Foreground="{DynamicResource AppTextPrimary}"
                                                        Text="{Binding Name}" />
                                                    <TextBlock
                                                        Grid.Column="1"
                                                        FontSize="{StaticResource Font.Size.Base}"
                                                        Foreground="{DynamicResource AppDown}"
                                                        Text="{Binding CurrentValueDisplay}" />
                                                </Grid>
                                            </DataTemplate>
                                        </ItemsControl.ItemTemplate>
                                    </ItemsControl>
                                </StackPanel>
                            </DataTemplate>
                        </ItemsControl.ItemTemplate>
                    </ItemsControl>
                </Expander>

            </StackPanel>
        </ScrollViewer>

    </Grid>
</UserControl>
