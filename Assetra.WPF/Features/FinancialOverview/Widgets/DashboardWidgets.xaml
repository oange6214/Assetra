<ResourceDictionary
    xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
    xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
    xmlns:ds="clr-namespace:Assetra.WPF.DesignSystem.Controls">

    <!--
        Stage 2.5 (Dashboard consolidation)：儀表板「總覽」tab 上的 widget 通用樣式。
        - DashboardWidgetCardStyle：統一 padding / radius / border
        - DashboardWidgetHeader：標題列文字樣式
        - DashboardWidgetFooter：footer link 樣式
        widget 內容由各個 UserControl 自填，這裡只定義外框與行距。
    -->

    <!--
        P2.14 — Setters 直接對齊 design-system 的 AppCardSubtle (in Cards.xaml)：
        BorderLight + Radius.Md + Padding 16,14 + Margin 0,0,0,12。不用 BasedOn 是
        因為 Cards.xaml 跟這個 dict 在不同 ResourceDictionary，BasedOn 跨 dict
        WPF 不支援。後續新 widget 建議直接用 AppCardSubtle (走 App-level resource
        無需本地 dict)，這個 key 保留作 backwards-compat。
    -->
    <Style x:Key="DashboardWidgetCard" TargetType="Border">
        <Setter Property="Background" Value="{DynamicResource AppCardBackground}" />
        <Setter Property="BorderBrush" Value="{DynamicResource AppBorderLight}" />
        <Setter Property="BorderThickness" Value="1" />
        <Setter Property="CornerRadius" Value="{StaticResource Radius.Md}" />
        <Setter Property="Padding" Value="16,14" />
        <Setter Property="Margin" Value="0,0,0,12" />
    </Style>

    <Style x:Key="DashboardWidgetHeader" TargetType="TextBlock">
        <Setter Property="FontSize" Value="{StaticResource Font.Size.Sm}" />
        <Setter Property="FontWeight" Value="SemiBold" />
        <Setter Property="Foreground" Value="{DynamicResource AppTextSecondary}" />
        <Setter Property="Margin" Value="0,0,0,10" />
    </Style>

    <!--
        Footer link 樣式 — Hand cursor 與 hover 變色只作用在「實際文字」上。
        刻意不設 Background=Transparent / HorizontalAlignment=Stretch，因為那會讓
        TextBlock 的 hit-test 區域整列展開到 widget 寬度，造成滑到 body 內容區也
        顯示 Hand 的錯覺（用戶反饋已實際看到）。Hover 時直接變色而非變底色，
        affordance 仍清楚但區域不會誤導。
    -->
    <Style x:Key="DashboardWidgetFooter" TargetType="TextBlock">
        <Setter Property="FontSize" Value="{StaticResource Font.Size.Xs}" />
        <Setter Property="Foreground" Value="{DynamicResource AppAccent}" />
        <Setter Property="Margin" Value="0,10,0,0" />
        <Setter Property="HorizontalAlignment" Value="Left" />
        <Setter Property="Cursor" Value="Hand" />
        <Style.Triggers>
            <Trigger Property="IsMouseOver" Value="True">
                <Setter Property="TextDecorations" Value="Underline" />
            </Trigger>
        </Style.Triggers>
    </Style>

</ResourceDictionary>
