<UserControl
    x:Class="Assetra.WPF.Features.FinancialOverview.Widgets.AssetClassFocusWidget"
    xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
    xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
    xmlns:d="http://schemas.microsoft.com/expression/blend/2008"
    xmlns:ds="clr-namespace:Assetra.WPF.DesignSystem.Controls"
    xmlns:vm="clr-namespace:Assetra.WPF.Features.FinancialOverview"
    xmlns:mc="http://schemas.openxmlformats.org/markup-compatibility/2006"
    d:DataContext="{d:DesignInstance Type={x:Type vm:FinancialOverviewViewModel},
                                     IsDesignTimeCreatable=False}"
    mc:Ignorable="d">

    <UserControl.Resources>
        <ResourceDictionary>
            <ResourceDictionary.MergedDictionaries>
                <ResourceDictionary Source="DashboardWidgets.xaml" />
            </ResourceDictionary.MergedDictionaries>
        </ResourceDictionary>
    </UserControl.Resources>

    <!--
        Phase C：「資產類焦點」widget — 6 個資產類做成 2×3 grid，每格顯示
        總額 + 項目數 + 跳轉。對應 VM 未注入時該格自動隱藏；六格全 null
        時整個 widget 隱藏（HasAnyAssetClassFocus 控制）。
    -->
    <Border Style="{StaticResource DashboardWidgetCard}"
            Visibility="{Binding HasAnyAssetClassFocus, Converter={StaticResource BooleanToVisibilityConverter}}">
        <StackPanel>
            <TextBlock Style="{StaticResource DashboardWidgetHeader}"
                       Text="{DynamicResource Dashboard.Widget.AssetClass.Heading}" />

            <UniformGrid Columns="3" Rows="2">
                <!--  ── 現金 ──  -->
                <Border Margin="0,0,4,4"
                        Padding="12,10"
                        Background="{DynamicResource AppHover}"
                        BorderBrush="{DynamicResource AppBorder}"
                        BorderThickness="1"
                        CornerRadius="{StaticResource Radius.Sm}"
                        Cursor="Hand"
                        Visibility="{Binding PortfolioRef, Converter={StaticResource NullToVisibilityConverter}}">
                    <Border.InputBindings>
                        <MouseBinding Command="{Binding NavigateToCashAccountsCommand}" MouseAction="LeftClick" />
                    </Border.InputBindings>
                    <StackPanel>
                        <StackPanel Orientation="Horizontal">
                            <ds:AppIcon Margin="0,0,6,0" VerticalAlignment="Center" FontSize="14"
                                        Foreground="{DynamicResource AppAccent}" Symbol="Wallet24" />
                            <TextBlock VerticalAlignment="Center"
                                       FontSize="{StaticResource Font.Size.Xs}"
                                       Foreground="{DynamicResource AppTextSecondary}"
                                       Text="{DynamicResource Dashboard.Widget.AssetClass.Cash}" />
                        </StackPanel>
                        <TextBlock Margin="0,6,0,0"
                                   FontFamily="{StaticResource Font.Family.Base}"
                                   FontSize="{StaticResource Font.Size.Md}" FontWeight="SemiBold"
                                   Foreground="{DynamicResource AppTextPrimary}"
                                   Text="{Binding PortfolioRef.TotalCash, StringFormat='N0'}"
                                   Typography.NumeralAlignment="Tabular" />
                        <TextBlock Margin="0,2,0,0"
                                   FontSize="{StaticResource Font.Size.Xs}"
                                   Foreground="{DynamicResource AppTextMuted}">
                            <Run Text="{Binding PortfolioRef.CashAccounts.Count, Mode=OneWay}" />
                            <Run Text="{DynamicResource Dashboard.Widget.AssetClass.CashAccountsSuffix}" />
                        </TextBlock>
                    </StackPanel>
                </Border>

                <!--  ── 負債 ──  -->
                <Border Margin="2,0,2,4"
                        Padding="12,10"
                        Background="{DynamicResource AppHover}"
                        BorderBrush="{DynamicResource AppBorder}"
                        BorderThickness="1"
                        CornerRadius="{StaticResource Radius.Sm}"
                        Cursor="Hand"
                        Visibility="{Binding PortfolioRef, Converter={StaticResource NullToVisibilityConverter}}">
                    <Border.InputBindings>
                        <MouseBinding Command="{Binding NavigateToLiabilitiesCommand}" MouseAction="LeftClick" />
                    </Border.InputBindings>
                    <StackPanel>
                        <StackPanel Orientation="Horizontal">
                            <ds:AppIcon Margin="0,0,6,0" VerticalAlignment="Center" FontSize="14"
                                        Foreground="{DynamicResource AppDown}" Symbol="Cut24" />
                            <TextBlock VerticalAlignment="Center"
                                       FontSize="{StaticResource Font.Size.Xs}"
                                       Foreground="{DynamicResource AppTextSecondary}"
                                       Text="{DynamicResource Dashboard.Widget.AssetClass.Liability}" />
                        </StackPanel>
                        <TextBlock Margin="0,6,0,0"
                                   FontFamily="{StaticResource Font.Family.Base}"
                                   FontSize="{StaticResource Font.Size.Md}" FontWeight="SemiBold"
                                   Foreground="{DynamicResource AppTextPrimary}"
                                   Text="{Binding PortfolioRef.TotalLiabilities, StringFormat='N0'}"
                                   Typography.NumeralAlignment="Tabular" />
                        <TextBlock Margin="0,2,0,0"
                                   FontSize="{StaticResource Font.Size.Xs}"
                                   Foreground="{DynamicResource AppTextMuted}">
                            <Run Text="{Binding PortfolioRef.Liabilities.Count, Mode=OneWay}" />
                            <Run Text="{DynamicResource Dashboard.Widget.AssetClass.LiabilityItemsSuffix}" />
                        </TextBlock>
                    </StackPanel>
                </Border>

                <!--  ── 不動產 ──  -->
                <Border Margin="4,0,0,4"
                        Padding="12,10"
                        Background="{DynamicResource AppHover}"
                        BorderBrush="{DynamicResource AppBorder}"
                        BorderThickness="1"
                        CornerRadius="{StaticResource Radius.Sm}"
                        Cursor="Hand"
                        Visibility="{Binding RealEstateFocusWidget, Converter={StaticResource NullToVisibilityConverter}}">
                    <Border.InputBindings>
                        <MouseBinding Command="{Binding NavigateToRealEstateCommand}" MouseAction="LeftClick" />
                    </Border.InputBindings>
                    <StackPanel>
                        <StackPanel Orientation="Horizontal">
                            <ds:AppIcon Margin="0,0,6,0" VerticalAlignment="Center" FontSize="14"
                                        Foreground="{DynamicResource AppAccent}" Symbol="Home24" />
                            <TextBlock VerticalAlignment="Center"
                                       FontSize="{StaticResource Font.Size.Xs}"
                                       Foreground="{DynamicResource AppTextSecondary}"
                                       Text="{DynamicResource Dashboard.Widget.AssetClass.RealEstate}" />
                        </StackPanel>
                        <TextBlock Margin="0,6,0,0"
                                   FontFamily="{StaticResource Font.Family.Base}"
                                   FontSize="{StaticResource Font.Size.Md}" FontWeight="SemiBold"
                                   Foreground="{DynamicResource AppTextPrimary}"
                                   Text="{Binding RealEstateFocusWidget.TotalCurrentValue, StringFormat='N0'}"
                                   Typography.NumeralAlignment="Tabular" />
                        <TextBlock Margin="0,2,0,0"
                                   FontSize="{StaticResource Font.Size.Xs}"
                                   Foreground="{DynamicResource AppTextMuted}">
                            <Run Text="{Binding RealEstateFocusWidget.PropertyCount, Mode=OneWay}" />
                            <Run Text="{DynamicResource Dashboard.Widget.AssetClass.PropertiesSuffix}" />
                        </TextBlock>
                    </StackPanel>
                </Border>

                <!--  ── 保險 ──  -->
                <Border Margin="0,4,4,0"
                        Padding="12,10"
                        Background="{DynamicResource AppHover}"
                        BorderBrush="{DynamicResource AppBorder}"
                        BorderThickness="1"
                        CornerRadius="{StaticResource Radius.Sm}"
                        Cursor="Hand"
                        Visibility="{Binding InsuranceFocusWidget, Converter={StaticResource NullToVisibilityConverter}}">
                    <Border.InputBindings>
                        <MouseBinding Command="{Binding NavigateToInsuranceCommand}" MouseAction="LeftClick" />
                    </Border.InputBindings>
                    <StackPanel>
                        <StackPanel Orientation="Horizontal">
                            <ds:AppIcon Margin="0,0,6,0" VerticalAlignment="Center" FontSize="14"
                                        Foreground="{DynamicResource AppAccent}" Symbol="ShieldCheckmark24" />
                            <TextBlock VerticalAlignment="Center"
                                       FontSize="{StaticResource Font.Size.Xs}"
                                       Foreground="{DynamicResource AppTextSecondary}"
                                       Text="{DynamicResource Dashboard.Widget.AssetClass.Insurance}" />
                        </StackPanel>
                        <TextBlock Margin="0,6,0,0"
                                   FontFamily="{StaticResource Font.Family.Base}"
                                   FontSize="{StaticResource Font.Size.Md}" FontWeight="SemiBold"
                                   Foreground="{DynamicResource AppTextPrimary}"
                                   Text="{Binding InsuranceFocusWidget.TotalAnnualPremium, StringFormat='N0'}"
                                   Typography.NumeralAlignment="Tabular" />
                        <TextBlock Margin="0,2,0,0"
                                   FontSize="{StaticResource Font.Size.Xs}"
                                   Foreground="{DynamicResource AppTextMuted}">
                            <Run Text="{Binding InsuranceFocusWidget.PolicyCount, Mode=OneWay}" />
                            <Run Text="{DynamicResource Dashboard.Widget.AssetClass.PoliciesSuffix}" />
                        </TextBlock>
                    </StackPanel>
                </Border>

                <!--  ── 退休 ──  -->
                <Border Margin="2,4,2,0"
                        Padding="12,10"
                        Background="{DynamicResource AppHover}"
                        BorderBrush="{DynamicResource AppBorder}"
                        BorderThickness="1"
                        CornerRadius="{StaticResource Radius.Sm}"
                        Cursor="Hand"
                        Visibility="{Binding RetirementFocusWidget, Converter={StaticResource NullToVisibilityConverter}}">
                    <Border.InputBindings>
                        <MouseBinding Command="{Binding NavigateToRetirementCommand}" MouseAction="LeftClick" />
                    </Border.InputBindings>
                    <StackPanel>
                        <StackPanel Orientation="Horizontal">
                            <ds:AppIcon Margin="0,0,6,0" VerticalAlignment="Center" FontSize="14"
                                        Foreground="{DynamicResource AppAccent}" Symbol="PersonClock24" />
                            <TextBlock VerticalAlignment="Center"
                                       FontSize="{StaticResource Font.Size.Xs}"
                                       Foreground="{DynamicResource AppTextSecondary}"
                                       Text="{DynamicResource Dashboard.Widget.AssetClass.Retirement}" />
                        </StackPanel>
                        <TextBlock Margin="0,6,0,0"
                                   FontFamily="{StaticResource Font.Family.Base}"
                                   FontSize="{StaticResource Font.Size.Md}" FontWeight="SemiBold"
                                   Foreground="{DynamicResource AppTextPrimary}"
                                   Text="{Binding RetirementFocusWidget.TotalBalance, StringFormat='N0'}"
                                   Typography.NumeralAlignment="Tabular" />
                        <TextBlock Margin="0,2,0,0"
                                   FontSize="{StaticResource Font.Size.Xs}"
                                   Foreground="{DynamicResource AppTextMuted}">
                            <Run Text="{Binding RetirementFocusWidget.AccountCount, Mode=OneWay}" />
                            <Run Text="{DynamicResource Dashboard.Widget.AssetClass.RetirementAccountsSuffix}" />
                        </TextBlock>
                    </StackPanel>
                </Border>

                <!--  ── 實物 ──  -->
                <Border Margin="4,4,0,0"
                        Padding="12,10"
                        Background="{DynamicResource AppHover}"
                        BorderBrush="{DynamicResource AppBorder}"
                        BorderThickness="1"
                        CornerRadius="{StaticResource Radius.Sm}"
                        Cursor="Hand"
                        Visibility="{Binding PhysicalAssetFocusWidget, Converter={StaticResource NullToVisibilityConverter}}">
                    <Border.InputBindings>
                        <MouseBinding Command="{Binding NavigateToPhysicalAssetCommand}" MouseAction="LeftClick" />
                    </Border.InputBindings>
                    <StackPanel>
                        <StackPanel Orientation="Horizontal">
                            <ds:AppIcon Margin="0,0,6,0" VerticalAlignment="Center" FontSize="14"
                                        Foreground="{DynamicResource AppAccent}" Symbol="Box24" />
                            <TextBlock VerticalAlignment="Center"
                                       FontSize="{StaticResource Font.Size.Xs}"
                                       Foreground="{DynamicResource AppTextSecondary}"
                                       Text="{DynamicResource Dashboard.Widget.AssetClass.Physical}" />
                        </StackPanel>
                        <TextBlock Margin="0,6,0,0"
                                   FontFamily="{StaticResource Font.Family.Base}"
                                   FontSize="{StaticResource Font.Size.Md}" FontWeight="SemiBold"
                                   Foreground="{DynamicResource AppTextPrimary}"
                                   Text="{Binding PhysicalAssetFocusWidget.TotalCurrentValue, StringFormat='N0'}"
                                   Typography.NumeralAlignment="Tabular" />
                        <TextBlock Margin="0,2,0,0"
                                   FontSize="{StaticResource Font.Size.Xs}"
                                   Foreground="{DynamicResource AppTextMuted}">
                            <Run Text="{Binding PhysicalAssetFocusWidget.AssetCount, Mode=OneWay}" />
                            <Run Text="{DynamicResource Dashboard.Widget.AssetClass.PhysicalItemsSuffix}" />
                        </TextBlock>
                    </StackPanel>
                </Border>
            </UniformGrid>
        </StackPanel>
    </Border>
</UserControl>
