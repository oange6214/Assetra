<UserControl
    x:Class="Assetra.WPF.Features.FinancialOverview.Widgets.TodaysMoversWidget"
    xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
    xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
    xmlns:d="http://schemas.microsoft.com/expression/blend/2008"
    xmlns:ds="clr-namespace:Assetra.WPF.DesignSystem.Controls"
    xmlns:vm="clr-namespace:Assetra.WPF.Features.FinancialOverview"
    xmlns:mc="http://schemas.openxmlformats.org/markup-compatibility/2006"
    d:DataContext="{d:DesignInstance Type={x:Type vm:FinancialOverviewViewModel},
                                     IsDesignTimeCreatable=False}"
    Visibility="{Binding HasTodaysMovers, Converter={StaticResource BooleanToVisibilityConverter}}"
    mc:Ignorable="d">

    <UserControl.Resources>
        <ResourceDictionary>
            <ResourceDictionary.MergedDictionaries>
                <ResourceDictionary Source="DashboardWidgets.xaml" />
            </ResourceDictionary.MergedDictionaries>

            <!--  Row template — symbol + name + day change + day pct  -->
            <DataTemplate x:Key="MoverRow">
            <Grid Margin="0,3,0,3">
                <Grid.ColumnDefinitions>
                    <ColumnDefinition Width="*" />
                    <ColumnDefinition Width="Auto" />
                    <ColumnDefinition Width="64" />
                </Grid.ColumnDefinitions>
                <StackPanel Grid.Column="0" Orientation="Horizontal">
                    <TextBlock VerticalAlignment="Center"
                               FontSize="{StaticResource Font.Size.Xs}"
                               FontWeight="SemiBold"
                               Foreground="{DynamicResource AppTextMuted}"
                               Text="{Binding Symbol}" />
                    <TextBlock Margin="6,0,0,0"
                               VerticalAlignment="Center"
                               FontSize="{StaticResource Font.Size.Xs}"
                               Foreground="{DynamicResource AppTextSecondary}"
                               Text="{Binding Name}"
                               TextTrimming="CharacterEllipsis" />
                </StackPanel>
                <TextBlock Grid.Column="1"
                           Margin="8,0,8,0"
                           VerticalAlignment="Center"
                           FontFamily="{StaticResource Font.Family.Base}"
                           FontSize="{StaticResource Font.Size.Sm}"
                           FontWeight="SemiBold"
                           Text="{Binding DayChange, StringFormat='+#\,##0;-#\,##0;0'}"
                           Typography.NumeralAlignment="Tabular">
                    <TextBlock.Style>
                        <Style TargetType="TextBlock">
                            <Setter Property="Foreground" Value="{DynamicResource AppTextPrimary}" />
                            <Style.Triggers>
                                <DataTrigger Binding="{Binding IsDayChangePositive}" Value="True">
                                    <Setter Property="Foreground" Value="{DynamicResource AppUp}" />
                                </DataTrigger>
                                <DataTrigger Binding="{Binding IsDayChangePositive}" Value="False">
                                    <Setter Property="Foreground" Value="{DynamicResource AppDown}" />
                                </DataTrigger>
                            </Style.Triggers>
                        </Style>
                    </TextBlock.Style>
                </TextBlock>
                <TextBlock Grid.Column="2"
                           VerticalAlignment="Center"
                           HorizontalAlignment="Right"
                           FontFamily="{StaticResource Font.Family.Base}"
                           FontSize="{StaticResource Font.Size.Xs}"
                           Text="{Binding DayChangePercent, StringFormat='+0.00\%;-0.00\%;0.00\%'}"
                           Typography.NumeralAlignment="Tabular">
                    <TextBlock.Style>
                        <Style TargetType="TextBlock">
                            <Setter Property="Foreground" Value="{DynamicResource AppTextMuted}" />
                            <Style.Triggers>
                                <DataTrigger Binding="{Binding IsDayChangePositive}" Value="True">
                                    <Setter Property="Foreground" Value="{DynamicResource AppUp}" />
                                </DataTrigger>
                                <DataTrigger Binding="{Binding IsDayChangePositive}" Value="False">
                                    <Setter Property="Foreground" Value="{DynamicResource AppDown}" />
                                </DataTrigger>
                            </Style.Triggers>
                        </Style>
                    </TextBlock.Style>
                </TextBlock>
            </Grid>
            </DataTemplate>
        </ResourceDictionary>
    </UserControl.Resources>

    <!--
        Today's Movers — broker app「即時損益」的橫切面：今天誰漲多 / 跌多。
        資料來自 PortfolioRef.Positions 即時更新；HasTodaysMovers 控制整 widget
        可見性（避免「未開盤 / 無持倉」期間顯示空白 card）。
    -->
    <Border Style="{StaticResource DashboardWidgetCard}">
        <StackPanel>
            <DockPanel LastChildFill="True">
                <ds:AppIcon
                    Margin="0,0,8,0"
                    VerticalAlignment="Center"
                    DockPanel.Dock="Left"
                    FontSize="16"
                    Foreground="{DynamicResource AppAccent}"
                    Symbol="ArrowTrendingLines24" />
                <TextBlock
                    VerticalAlignment="Center"
                    Style="{StaticResource DashboardWidgetHeader}"
                    Text="{DynamicResource Dashboard.Widget.TodaysMovers.Heading}" />
            </DockPanel>

            <Grid>
                <Grid.ColumnDefinitions>
                    <ColumnDefinition Width="*" />
                    <ColumnDefinition Width="12" />
                    <ColumnDefinition Width="*" />
                </Grid.ColumnDefinitions>

                <!--  Gainers 欄  -->
                <StackPanel Grid.Column="0">
                    <TextBlock Margin="0,0,0,4"
                               FontSize="{StaticResource Font.Size.Xs}"
                               FontWeight="SemiBold"
                               Foreground="{DynamicResource AppUp}"
                               Text="{DynamicResource Dashboard.Widget.TodaysMovers.Gainers}" />
                    <ItemsControl ItemsSource="{Binding TopGainersToday}"
                                  ItemTemplate="{StaticResource MoverRow}" />
                </StackPanel>

                <!--  Losers 欄  -->
                <StackPanel Grid.Column="2">
                    <TextBlock Margin="0,0,0,4"
                               FontSize="{StaticResource Font.Size.Xs}"
                               FontWeight="SemiBold"
                               Foreground="{DynamicResource AppDown}"
                               Text="{DynamicResource Dashboard.Widget.TodaysMovers.Losers}" />
                    <ItemsControl ItemsSource="{Binding TopLosersToday}"
                                  ItemTemplate="{StaticResource MoverRow}" />
                </StackPanel>
            </Grid>

            <TextBlock Style="{StaticResource DashboardWidgetFooter}"
                       Text="{DynamicResource Dashboard.Widget.TodaysMovers.OpenLink}">
                <TextBlock.InputBindings>
                    <MouseBinding Command="{Binding NavigateToPortfolioCommand}" MouseAction="LeftClick" />
                </TextBlock.InputBindings>
            </TextBlock>
        </StackPanel>
    </Border>
</UserControl>
