<UserControl
    x:Class="Assetra.WPF.Features.AuditLog.AuditLogView"
    xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
    xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
    xmlns:d="http://schemas.microsoft.com/expression/blend/2008"
    xmlns:local="clr-namespace:Assetra.WPF.Features.AuditLog"
    xmlns:mc="http://schemas.openxmlformats.org/markup-compatibility/2006"
    xmlns:vm="clr-namespace:Assetra.WPF.Features.AuditLog"
    d:DataContext="{d:DesignInstance Type={x:Type vm:AuditLogViewModel}}"
    Background="{DynamicResource AppBackground}"
    mc:Ignorable="d">

    <UserControl.Resources>
        <!--  Quick-filter chip style — small toggle pill.  -->
        <Style x:Key="AuditFilterChip" TargetType="{x:Type Button}">
            <Setter Property="Margin" Value="0,0,6,0" />
            <Setter Property="Padding" Value="10,4" />
            <Setter Property="Cursor" Value="Hand" />
            <Setter Property="Background" Value="Transparent" />
            <Setter Property="BorderBrush" Value="{DynamicResource AppBorder}" />
            <Setter Property="BorderThickness" Value="1" />
            <Setter Property="Foreground" Value="{DynamicResource AppTextSecondary}" />
            <Setter Property="FontSize" Value="{StaticResource Font.Size.Xs}" />
            <Setter Property="Template">
                <Setter.Value>
                    <ControlTemplate TargetType="{x:Type Button}">
                        <Border
                            x:Name="Chrome"
                            Background="{TemplateBinding Background}"
                            BorderBrush="{TemplateBinding BorderBrush}"
                            BorderThickness="{TemplateBinding BorderThickness}"
                            CornerRadius="12">
                            <ContentPresenter
                                Margin="{TemplateBinding Padding}"
                                HorizontalAlignment="Center"
                                VerticalAlignment="Center" />
                        </Border>
                        <ControlTemplate.Triggers>
                            <Trigger Property="IsMouseOver" Value="True">
                                <Setter TargetName="Chrome" Property="Background" Value="{DynamicResource AppHover}" />
                            </Trigger>
                        </ControlTemplate.Triggers>
                    </ControlTemplate>
                </Setter.Value>
            </Setter>
        </Style>

        <Style
            x:Key="AuditFilterChipActive"
            BasedOn="{StaticResource AuditFilterChip}"
            TargetType="{x:Type Button}">
            <Setter Property="Background" Value="{DynamicResource AppAccentSoft}" />
            <Setter Property="BorderBrush" Value="{DynamicResource AppAccent}" />
            <Setter Property="Foreground" Value="{DynamicResource AppAccent}" />
        </Style>
    </UserControl.Resources>

    <Grid Margin="20">
        <Grid.RowDefinitions>
            <RowDefinition Height="Auto" />
            <RowDefinition Height="Auto" />
            <RowDefinition Height="*" />
        </Grid.RowDefinitions>

        <!--  Header  -->
        <StackPanel Grid.Row="0" Margin="0,0,0,16">
            <TextBlock
                FontSize="{StaticResource Font.Size.Lg}"
                FontWeight="SemiBold"
                Foreground="{DynamicResource AppTextPrimary}"
                Text="{DynamicResource AuditLog.Title}" />
            <TextBlock
                Margin="0,4,0,0"
                Foreground="{DynamicResource AppTextSecondary}"
                Text="{DynamicResource AuditLog.Subtitle}"
                TextWrapping="Wrap" />
        </StackPanel>

        <!--  Toolbar: refresh + chip filters + text filter + count  -->
        <Grid Grid.Row="1" Margin="0,0,0,12">
            <Grid.ColumnDefinitions>
                <ColumnDefinition Width="Auto" />
                <ColumnDefinition Width="Auto" />
                <ColumnDefinition Width="*" />
                <ColumnDefinition Width="Auto" />
                <ColumnDefinition Width="Auto" />
                <ColumnDefinition Width="Auto" />
            </Grid.ColumnDefinitions>

            <Button
                Grid.Column="0"
                Padding="14,8"
                Command="{Binding LoadCommand}"
                Content="{DynamicResource AuditLog.Refresh}"
                Style="{StaticResource AppSecondaryButton}" />

            <!--  Chip group (active state via DataTrigger swapping the style)  -->
            <StackPanel
                Grid.Column="1"
                Margin="12,0,0,0"
                VerticalAlignment="Center"
                Orientation="Horizontal">
                <Button
                    Command="{Binding SetChipCommand}"
                    CommandParameter="All"
                    Content="{DynamicResource AuditLog.Chip.All}">
                    <Button.Style>
                        <Style BasedOn="{StaticResource AuditFilterChip}" TargetType="{x:Type Button}">
                            <Style.Triggers>
                                <DataTrigger Binding="{Binding IsChipAll}" Value="True">
                                    <Setter Property="Background" Value="{DynamicResource AppAccentSoft}" />
                                    <Setter Property="BorderBrush" Value="{DynamicResource AppAccent}" />
                                    <Setter Property="Foreground" Value="{DynamicResource AppAccent}" />
                                </DataTrigger>
                            </Style.Triggers>
                        </Style>
                    </Button.Style>
                </Button>
                <Button
                    Command="{Binding SetChipCommand}"
                    CommandParameter="Delete"
                    Content="{DynamicResource AuditLog.Chip.Delete}">
                    <Button.Style>
                        <Style BasedOn="{StaticResource AuditFilterChip}" TargetType="{x:Type Button}">
                            <Style.Triggers>
                                <DataTrigger Binding="{Binding IsChipDelete}" Value="True">
                                    <Setter Property="Background" Value="{DynamicResource AppAccentSoft}" />
                                    <Setter Property="BorderBrush" Value="{DynamicResource AppAccent}" />
                                    <Setter Property="Foreground" Value="{DynamicResource AppAccent}" />
                                </DataTrigger>
                            </Style.Triggers>
                        </Style>
                    </Button.Style>
                </Button>
                <Button
                    Command="{Binding SetChipCommand}"
                    CommandParameter="Edit"
                    Content="{DynamicResource AuditLog.Chip.Edit}">
                    <Button.Style>
                        <Style BasedOn="{StaticResource AuditFilterChip}" TargetType="{x:Type Button}">
                            <Style.Triggers>
                                <DataTrigger Binding="{Binding IsChipEdit}" Value="True">
                                    <Setter Property="Background" Value="{DynamicResource AppAccentSoft}" />
                                    <Setter Property="BorderBrush" Value="{DynamicResource AppAccent}" />
                                    <Setter Property="Foreground" Value="{DynamicResource AppAccent}" />
                                </DataTrigger>
                            </Style.Triggers>
                        </Style>
                    </Button.Style>
                </Button>
                <Button
                    Command="{Binding SetChipCommand}"
                    CommandParameter="24h"
                    Content="{DynamicResource AuditLog.Chip.Day}">
                    <Button.Style>
                        <Style BasedOn="{StaticResource AuditFilterChip}" TargetType="{x:Type Button}">
                            <Style.Triggers>
                                <DataTrigger Binding="{Binding IsChipDay}" Value="True">
                                    <Setter Property="Background" Value="{DynamicResource AppAccentSoft}" />
                                    <Setter Property="BorderBrush" Value="{DynamicResource AppAccent}" />
                                    <Setter Property="Foreground" Value="{DynamicResource AppAccent}" />
                                </DataTrigger>
                            </Style.Triggers>
                        </Style>
                    </Button.Style>
                </Button>
            </StackPanel>

            <TextBox
                Grid.Column="2"
                MinWidth="200"
                Margin="12,0,0,0"
                Padding="8,6"
                VerticalAlignment="Center"
                Text="{Binding FilterText, UpdateSourceTrigger=PropertyChanged}"
                ToolTip="{DynamicResource AuditLog.Filter.Tooltip}" />

            <TextBlock
                Grid.Column="3"
                Margin="12,0,0,0"
                VerticalAlignment="Center"
                FontSize="{StaticResource Font.Size.Xs}"
                Foreground="{DynamicResource AppTextMuted}"
                Text="{Binding EntryCount, StringFormat={}共 {0} 筆}" />

            <ProgressBar
                Grid.Column="4"
                Width="120"
                Height="3"
                Margin="12,0,0,0"
                VerticalAlignment="Center"
                IsIndeterminate="True"
                Visibility="{Binding IsLoading, Converter={StaticResource BooleanToVisibilityConverter}}" />

            <TextBlock
                Grid.Column="5"
                Margin="12,0,0,0"
                VerticalAlignment="Center"
                Foreground="{DynamicResource AppDanger}"
                Text="{Binding ErrorMessage}"
                Visibility="{Binding ErrorMessage, Converter={StaticResource StringToVisibilityConverter}}" />
        </Grid>

        <!--  Master-detail body  -->
        <Border
            Grid.Row="2"
            Background="{DynamicResource AppSurface}"
            BorderBrush="{DynamicResource AppBorder}"
            BorderThickness="1"
            CornerRadius="{StaticResource Radius.Md}">
            <Grid>
                <!--  Empty state covers the whole body when no entries.  -->
                <TextBlock
                    Margin="32"
                    HorizontalAlignment="Center"
                    VerticalAlignment="Center"
                    FontStyle="Italic"
                    Foreground="{DynamicResource AppTextSecondary}"
                    Text="{DynamicResource AuditLog.Empty}"
                    Visibility="{Binding HasNoEntries, Converter={StaticResource BooleanToVisibilityConverter}}" />

                <Grid Visibility="{Binding HasEntries, Converter={StaticResource BooleanToVisibilityConverter}}">
                    <Grid.ColumnDefinitions>
                        <ColumnDefinition Width="*" MinWidth="420" />
                        <ColumnDefinition Width="6" />
                        <ColumnDefinition Width="2*" MinWidth="380" />
                    </Grid.ColumnDefinitions>

                    <!--  Master list  -->
                    <DataGrid
                        Grid.Column="0"
                        AutoGenerateColumns="False"
                        Background="Transparent"
                        BorderThickness="0"
                        CanUserAddRows="False"
                        CanUserDeleteRows="False"
                        CanUserReorderColumns="False"
                        GridLinesVisibility="Horizontal"
                        HeadersVisibility="Column"
                        IsReadOnly="True"
                        ItemsSource="{Binding EntriesView}"
                        SelectedItem="{Binding SelectedEntry, Mode=TwoWay}"
                        SelectionMode="Single"
                        Style="{StaticResource AppDataGrid}">
                        <DataGrid.Columns>
                            <DataGridTextColumn Width="140" Binding="{Binding RecordedAtDisplay}">
                                <DataGridTextColumn.Header>
                                    <TextBlock Text="{DynamicResource AuditLog.Col.RecordedAt}" />
                                </DataGridTextColumn.Header>
                            </DataGridTextColumn>
                            <DataGridTextColumn Width="80" Binding="{Binding Action}">
                                <DataGridTextColumn.Header>
                                    <TextBlock Text="{DynamicResource AuditLog.Col.Action}" />
                                </DataGridTextColumn.Header>
                            </DataGridTextColumn>
                            <DataGridTextColumn Width="80" Binding="{Binding TradeIdShort}">
                                <DataGridTextColumn.Header>
                                    <TextBlock Text="{DynamicResource AuditLog.Col.TradeId}" />
                                </DataGridTextColumn.Header>
                            </DataGridTextColumn>
                            <DataGridTextColumn Width="*" Binding="{Binding SummaryLine}">
                                <DataGridTextColumn.Header>
                                    <TextBlock Text="{DynamicResource AuditLog.Col.Summary}" />
                                </DataGridTextColumn.Header>
                            </DataGridTextColumn>
                        </DataGrid.Columns>
                    </DataGrid>

                    <GridSplitter
                        Grid.Column="1"
                        HorizontalAlignment="Stretch"
                        VerticalAlignment="Stretch"
                        Background="Transparent"
                        ShowsPreview="True" />

                    <!--  Detail pane  -->
                    <Grid Grid.Column="2" Background="{DynamicResource AppBackground}">
                        <Grid.RowDefinitions>
                            <RowDefinition Height="*" />
                            <RowDefinition Height="Auto" />
                        </Grid.RowDefinitions>
                        <local:TradeDetailCardView Grid.Row="0" DataContext="{Binding Detail}" />

                        <!--  Action footer (restore + confirm preview)  -->
                        <Border
                            Grid.Row="1"
                            Padding="16,10"
                            Background="{DynamicResource AppSurface}"
                            BorderBrush="{DynamicResource AppBorderLight}"
                            BorderThickness="0,1,0,0"
                            Visibility="{Binding HasSelection, Converter={StaticResource BooleanToVisibilityConverter}}">
                            <Grid>
                                <!--  Idle: just a "還原" button (only when service available)  -->
                                <Button
                                    HorizontalAlignment="Right"
                                    Padding="14,6"
                                    Command="{Binding RequestRestoreCommand}"
                                    CommandParameter="{Binding SelectedEntry}"
                                    Content="{DynamicResource AuditLog.Restore}"
                                    Style="{StaticResource AppSecondaryButton}"
                                    ToolTip="{DynamicResource AuditLog.Restore.Tooltip}"
                                    Visibility="{Binding ShouldShowRestoreButton, Converter={StaticResource BooleanToVisibilityConverter}}" />

                                <!--  Preview state: confirm/cancel pair with explanation  -->
                                <StackPanel
                                    HorizontalAlignment="Right"
                                    Orientation="Horizontal"
                                    Visibility="{Binding IsRestorePreviewActive, Converter={StaticResource BooleanToVisibilityConverter}}">
                                    <TextBlock
                                        Margin="0,0,12,0"
                                        VerticalAlignment="Center"
                                        FontSize="{StaticResource Font.Size.Xs}"
                                        Foreground="{DynamicResource AppTextSecondary}"
                                        Text="{DynamicResource AuditLog.Restore.ConfirmPrompt}" />
                                    <Button
                                        Margin="0,0,8,0"
                                        Padding="14,6"
                                        Command="{Binding CancelRestoreCommand}"
                                        Content="{DynamicResource Common.Cancel}"
                                        Style="{StaticResource AppSecondaryButton}" />
                                    <Button
                                        Padding="14,6"
                                        Command="{Binding ConfirmRestoreCommand}"
                                        Content="{DynamicResource AuditLog.Restore.Confirm}"
                                        Style="{StaticResource AppPrimaryButton}" />
                                </StackPanel>
                            </Grid>
                        </Border>
                    </Grid>
                </Grid>
            </Grid>
        </Border>
    </Grid>
</UserControl>
