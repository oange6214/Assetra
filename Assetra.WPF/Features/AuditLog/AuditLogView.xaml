<UserControl
    x:Class="Assetra.WPF.Features.AuditLog.AuditLogView"
    xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
    xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
    xmlns:d="http://schemas.microsoft.com/expression/blend/2008"
    xmlns:mc="http://schemas.openxmlformats.org/markup-compatibility/2006"
    xmlns:vm="clr-namespace:Assetra.WPF.Features.AuditLog"
    d:DataContext="{d:DesignInstance Type={x:Type vm:AuditLogViewModel}}"
    Background="{DynamicResource AppBackground}"
    mc:Ignorable="d">

    <Grid Margin="20">
        <Grid.RowDefinitions>
            <RowDefinition Height="Auto" />
            <RowDefinition Height="Auto" />
            <RowDefinition Height="*" />
        </Grid.RowDefinitions>

        <StackPanel Grid.Row="0" Margin="0,0,0,16">
            <TextBlock
                FontSize="{StaticResource Font.Size.Lg}"
                FontWeight="SemiBold"
                Foreground="{DynamicResource AppTextPrimary}"
                Text="{DynamicResource AuditLog.Title}" />
            <TextBlock
                Margin="0,4,0,0"
                Foreground="{DynamicResource AppTextSecondary}"
                Text="{DynamicResource AuditLog.Subtitle}"
                TextWrapping="Wrap" />
        </StackPanel>

        <StackPanel Grid.Row="1" Margin="0,0,0,12" Orientation="Horizontal">
            <Button
                Padding="14,8"
                Command="{Binding LoadCommand}"
                Content="{DynamicResource AuditLog.Refresh}"
                Style="{StaticResource AppSecondaryButton}" />
            <TextBlock
                Margin="12,0,0,0"
                VerticalAlignment="Center"
                FontSize="{StaticResource Font.Size.Xs}"
                Foreground="{DynamicResource AppTextMuted}"
                Text="{Binding EntryCount, StringFormat={}共 {0} 筆}" />
            <ProgressBar
                Width="120"
                Height="3"
                Margin="12,0,0,0"
                VerticalAlignment="Center"
                IsIndeterminate="True"
                Visibility="{Binding IsLoading, Converter={StaticResource BooleanToVisibilityConverter}}" />
            <TextBlock
                Margin="12,0,0,0"
                VerticalAlignment="Center"
                Foreground="{DynamicResource AppDanger}"
                Text="{Binding ErrorMessage}"
                Visibility="{Binding ErrorMessage, Converter={StaticResource StringToVisibilityConverter}}" />
        </StackPanel>

        <Border
            Grid.Row="2"
            Background="{DynamicResource AppSurface}"
            BorderBrush="{DynamicResource AppBorder}"
            BorderThickness="1"
            CornerRadius="{StaticResource Radius.Md}">
            <Grid>
                <TextBlock
                    Margin="32"
                    HorizontalAlignment="Center"
                    VerticalAlignment="Center"
                    FontStyle="Italic"
                    Foreground="{DynamicResource AppTextSecondary}"
                    Text="{DynamicResource AuditLog.Empty}"
                    Visibility="{Binding HasNoEntries, Converter={StaticResource BooleanToVisibilityConverter}}" />

                <DataGrid
                    AutoGenerateColumns="False"
                    Background="Transparent"
                    BorderThickness="0"
                    CanUserAddRows="False"
                    CanUserDeleteRows="False"
                    CanUserReorderColumns="False"
                    GridLinesVisibility="Horizontal"
                    HeadersVisibility="Column"
                    IsReadOnly="True"
                    ItemsSource="{Binding Entries}"
                    Style="{StaticResource AppDataGrid}"
                    Visibility="{Binding HasEntries, Converter={StaticResource BooleanToVisibilityConverter}}">
                    <DataGrid.Columns>
                        <DataGridTextColumn Width="160" Binding="{Binding RecordedAtDisplay}">
                            <DataGridTextColumn.Header>
                                <TextBlock Text="{DynamicResource AuditLog.Col.RecordedAt}" />
                            </DataGridTextColumn.Header>
                        </DataGridTextColumn>
                        <DataGridTextColumn Width="100" Binding="{Binding Action}">
                            <DataGridTextColumn.Header>
                                <TextBlock Text="{DynamicResource AuditLog.Col.Action}" />
                            </DataGridTextColumn.Header>
                        </DataGridTextColumn>
                        <DataGridTextColumn Width="100" Binding="{Binding TradeIdShort}">
                            <DataGridTextColumn.Header>
                                <TextBlock Text="{DynamicResource AuditLog.Col.TradeId}" />
                            </DataGridTextColumn.Header>
                        </DataGridTextColumn>
                        <DataGridTextColumn Width="180" Binding="{Binding Note}">
                            <DataGridTextColumn.Header>
                                <TextBlock Text="{DynamicResource AuditLog.Col.Note}" />
                            </DataGridTextColumn.Header>
                        </DataGridTextColumn>
                        <DataGridTemplateColumn Width="*">
                            <DataGridTemplateColumn.Header>
                                <TextBlock Text="{DynamicResource AuditLog.Col.TradeJson}" />
                            </DataGridTemplateColumn.Header>
                            <DataGridTemplateColumn.CellTemplate>
                                <DataTemplate>
                                    <TextBlock
                                        FontFamily="Consolas, Courier New, monospace"
                                        FontSize="{StaticResource Font.Size.Xs}"
                                        Foreground="{DynamicResource AppTextSecondary}"
                                        Text="{Binding TradeJsonPreview}"
                                        TextWrapping="Wrap" />
                                </DataTemplate>
                            </DataGridTemplateColumn.CellTemplate>
                        </DataGridTemplateColumn>
                    </DataGrid.Columns>
                </DataGrid>
            </Grid>
        </Border>
    </Grid>
</UserControl>
