<UserControl
    x:Class="Assetra.WPF.Features.Goals.GoalsView"
    xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
    xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
    xmlns:behaviors="clr-namespace:Assetra.WPF.Infrastructure.Behaviors"
    xmlns:d="http://schemas.microsoft.com/expression/blend/2008"
    xmlns:mc="http://schemas.openxmlformats.org/markup-compatibility/2006"
    xmlns:ui="http://schemas.lepo.co/wpfui/2022/xaml"
    xmlns:vm="clr-namespace:Assetra.WPF.Features.Goals"
    d:DataContext="{d:DesignInstance Type={x:Type vm:GoalsViewModel}}"
    d:DesignHeight="776"
    d:DesignWidth="1100"
    Background="{DynamicResource AppBackground}"
    mc:Ignorable="d">

    <Grid Background="{DynamicResource AppBackground}">
        <Grid Style="{StaticResource PageRootGrid}">
            <Grid.RowDefinitions>
                <RowDefinition Height="Auto" />
                <RowDefinition Height="Auto" />
                <RowDefinition Height="Auto" />
                <RowDefinition Height="*" />
            </Grid.RowDefinitions>

            <DockPanel Grid.Row="0" Style="{StaticResource PageHeaderDock}">
                            <ui:Button
                                DockPanel.Dock="Right"
                                Command="{Binding OpenAddFormCommand}"
                                Style="{StaticResource PagePrimaryButton}"
                                Visibility="{Binding IsFormOpen, Converter={StaticResource InverseBooleanToVisibilityConverter}}">
                                <StackPanel Orientation="Horizontal">
                                    <ui:SymbolIcon
                                        Margin="0,0,4,0"
                                        VerticalAlignment="Center"
                                        FontSize="{StaticResource FontSizeXs}"
                                        Foreground="{Binding Foreground, RelativeSource={RelativeSource AncestorType=Button}}"
                                        Symbol="Add24" />
                                    <TextBlock
                                        VerticalAlignment="Center"
                                        Foreground="{Binding Foreground, RelativeSource={RelativeSource AncestorType=Button}}"
                                        Text="{DynamicResource Goals.Add.Title}" />
                                </StackPanel>
                            </ui:Button>

                            <StackPanel VerticalAlignment="Center" Orientation="Horizontal">
                                <ui:SymbolIcon
                                    Margin="0,0,8,0"
                                    VerticalAlignment="Center"
                                    Foreground="{DynamicResource AppTextMuted}"
                                    Symbol="Target24" />
                                <TextBlock
                                    Style="{StaticResource PageTitleText}"
                                    Text="{DynamicResource Goals.Title}" />
                            </StackPanel>
            </DockPanel>

                <UniformGrid
                    Grid.Row="1"
                        Columns="4"
                        Rows="1"
                        Style="{StaticResource PageMetricsGrid}"
                        Visibility="{Binding HasGoals, Converter={StaticResource BooleanToVisibilityConverter}}">
                        <ui:Card Margin="0,0,8,0" Padding="16">
                            <StackPanel>
                                <TextBlock
                                    FontSize="{DynamicResource FontSizeXs}"
                                    Foreground="{DynamicResource AppTextSecondary}"
                                    Text="{DynamicResource Goals.Count}" />
                                <TextBlock
                                    Margin="0,8,0,0"
                                    FontFamily="{StaticResource FontBase}"
                                    FontSize="{DynamicResource FontSizeXl}"
                                    FontWeight="SemiBold"
                                    Foreground="{DynamicResource AppTextPrimary}"
                                    Text="{Binding GoalCount}"
                                    Typography.NumeralAlignment="Tabular" />
                            </StackPanel>
                        </ui:Card>
                        <ui:Card Margin="8,0" Padding="16">
                            <StackPanel>
                                <TextBlock
                                    FontSize="{DynamicResource FontSizeXs}"
                                    Foreground="{DynamicResource AppTextSecondary}"
                                    Text="{DynamicResource Goals.Add.Current}" />
                                <TextBlock
                                    Margin="0,8,0,0"
                                    FontFamily="{StaticResource FontBase}"
                                    FontSize="{DynamicResource FontSizeXl}"
                                    FontWeight="SemiBold"
                                    Foreground="{DynamicResource AppTextPrimary}"
                                    Text="{Binding TotalCurrentDisplay}"
                                    Typography.NumeralAlignment="Tabular" />
                            </StackPanel>
                        </ui:Card>
                        <ui:Card Margin="8,0" Padding="16">
                            <StackPanel>
                                <TextBlock
                                    FontSize="{DynamicResource FontSizeXs}"
                                    Foreground="{DynamicResource AppTextSecondary}"
                                    Text="{DynamicResource Goals.Add.Target}" />
                                <TextBlock
                                    Margin="0,8,0,0"
                                    FontFamily="{StaticResource FontBase}"
                                    FontSize="{DynamicResource FontSizeXl}"
                                    FontWeight="SemiBold"
                                    Foreground="{DynamicResource AppTextPrimary}"
                                    Text="{Binding TotalTargetDisplay}"
                                    Typography.NumeralAlignment="Tabular" />
                            </StackPanel>
                        </ui:Card>
                        <ui:Card Margin="8,0,0,0" Padding="16">
                            <StackPanel>
                                <TextBlock
                                    FontSize="{DynamicResource FontSizeXs}"
                                    Foreground="{DynamicResource AppTextSecondary}"
                                    Text="{DynamicResource Goals.OverallProgress}" />
                                <TextBlock
                                    Margin="0,8,0,0"
                                    FontFamily="{StaticResource FontBase}"
                                    FontSize="{DynamicResource FontSizeXl}"
                                    FontWeight="SemiBold"
                                    Foreground="{DynamicResource AppAccent}"
                                    Text="{Binding OverallProgressDisplay}"
                                    Typography.NumeralAlignment="Tabular" />
                            </StackPanel>
                        </ui:Card>
                </UniformGrid>

            <TextBlock
                Grid.Row="2"
                Style="{StaticResource PageErrorText}"
                Text="{Binding ErrorMessage}"
                Visibility="{Binding ErrorMessage, Converter={StaticResource StringToVisibilityConverter}}" />

                <Grid Grid.Row="3" Style="{StaticResource PageContentGrid}">
                    <StackPanel
                        Style="{StaticResource EmptyStatePanel}"
                        Visibility="{Binding HasNoGoals, Converter={StaticResource BooleanToVisibilityConverter}}">
                        <ui:SymbolIcon Style="{StaticResource EmptyStateIcon}" Symbol="Target24" />
                        <TextBlock Style="{StaticResource EmptyStateTitle}" Text="{DynamicResource Goals.Empty}" />
                        <TextBlock Style="{StaticResource EmptyStateHint}" Text="{DynamicResource Goals.Empty.Hint}" />
                        <ui:Button
                            Command="{Binding OpenAddFormCommand}"
                            Style="{StaticResource EmptyStateActionButton}"
                            Visibility="{Binding IsFormOpen, Converter={StaticResource InverseBooleanToVisibilityConverter}}">
                            <StackPanel Orientation="Horizontal">
                                <ui:SymbolIcon
                                    Margin="0,0,4,0"
                                    VerticalAlignment="Center"
                                    FontSize="{StaticResource FontSizeXs}"
                                    Foreground="{Binding Foreground, RelativeSource={RelativeSource AncestorType=Button}}"
                                    Symbol="Add24" />
                                <TextBlock
                                    VerticalAlignment="Center"
                                    Foreground="{Binding Foreground, RelativeSource={RelativeSource AncestorType=Button}}"
                                    Text="{DynamicResource Goals.Add.Title}" />
                            </StackPanel>
                        </ui:Button>
                    </StackPanel>

                    <ScrollViewer
                        HorizontalScrollBarVisibility="Disabled"
                        VerticalScrollBarVisibility="Auto"
                        Visibility="{Binding HasGoals, Converter={StaticResource BooleanToVisibilityConverter}}">
                        <ItemsControl ItemsSource="{Binding Goals}">
                        <ItemsControl.ItemsPanel>
                            <ItemsPanelTemplate>
                                <WrapPanel />
                            </ItemsPanelTemplate>
                        </ItemsControl.ItemsPanel>
                        <ItemsControl.ItemTemplate>
                            <DataTemplate DataType="{x:Type vm:GoalRowViewModel}">
                                <ui:Card
                                    Width="460"
                                    MinHeight="168"
                                    Margin="0,0,16,16"
                                    Padding="16">
                                    <Grid>
                                        <Grid.RowDefinitions>
                                            <RowDefinition Height="Auto" />
                                            <RowDefinition Height="Auto" />
                                            <RowDefinition Height="Auto" />
                                            <RowDefinition Height="*" />
                                        </Grid.RowDefinitions>
                                        <Grid.ColumnDefinitions>
                                            <ColumnDefinition Width="*" />
                                            <ColumnDefinition Width="Auto" />
                                        </Grid.ColumnDefinitions>

                                        <TextBlock
                                            Grid.Row="0"
                                            Grid.Column="0"
                                            FontSize="{DynamicResource FontSizeMd}"
                                            FontWeight="SemiBold"
                                            Foreground="{DynamicResource AppTextPrimary}"
                                            Text="{Binding Name}"
                                            TextTrimming="CharacterEllipsis" />

                                        <StackPanel
                                            Grid.Row="0"
                                            Grid.Column="1"
                                            VerticalAlignment="Center"
                                            Orientation="Horizontal">
                                            <ui:Button
                                                Width="30"
                                                Height="30"
                                                Margin="0,0,4,0"
                                                Padding="0"
                                                Appearance="Transparent"
                                                Command="{Binding DataContext.EditCommand, RelativeSource={RelativeSource AncestorType=UserControl}}"
                                                CommandParameter="{Binding}"
                                                ToolTip="{DynamicResource Goals.Edit.Action}">
                                                <ui:SymbolIcon FontSize="14" Symbol="Edit24" />
                                            </ui:Button>
                                            <ui:Button
                                                Width="30"
                                                Height="30"
                                                Padding="0"
                                                Appearance="Transparent"
                                                Command="{Binding DataContext.RemoveCommand, RelativeSource={RelativeSource AncestorType=UserControl}}"
                                                CommandParameter="{Binding}"
                                                ToolTip="{DynamicResource Goals.Delete.ConfirmTitle}">
                                                <ui:SymbolIcon FontSize="14" Symbol="Dismiss24" />
                                            </ui:Button>
                                        </StackPanel>

                                        <Grid
                                            Grid.Row="1"
                                            Grid.ColumnSpan="2"
                                            Margin="0,12,0,0">
                                            <Grid.ColumnDefinitions>
                                                <ColumnDefinition Width="*" />
                                                <ColumnDefinition Width="*" />
                                                <ColumnDefinition Width="*" />
                                            </Grid.ColumnDefinitions>

                                            <StackPanel Grid.Column="0" Margin="0,0,12,0">
                                                <TextBlock
                                                    FontSize="{DynamicResource FontSizeXs}"
                                                    Foreground="{DynamicResource AppTextSecondary}"
                                                    Text="{DynamicResource Goals.Add.Current}" />
                                                <TextBlock
                                                    Margin="0,4,0,0"
                                                    FontFamily="{StaticResource FontBase}"
                                                    FontWeight="SemiBold"
                                                    Foreground="{DynamicResource AppTextPrimary}"
                                                    Text="{Binding CurrentDisplay}"
                                                    Typography.NumeralAlignment="Tabular" />
                                            </StackPanel>
                                            <StackPanel Grid.Column="1" Margin="0,0,12,0">
                                                <TextBlock
                                                    FontSize="{DynamicResource FontSizeXs}"
                                                    Foreground="{DynamicResource AppTextSecondary}"
                                                    Text="{DynamicResource Goals.Remaining}" />
                                                <TextBlock
                                                    Margin="0,4,0,0"
                                                    FontFamily="{StaticResource FontBase}"
                                                    FontWeight="SemiBold"
                                                    Foreground="{DynamicResource AppTextPrimary}"
                                                    Text="{Binding RemainingDisplay}"
                                                    Typography.NumeralAlignment="Tabular" />
                                            </StackPanel>
                                            <StackPanel Grid.Column="2">
                                                <TextBlock
                                                    FontSize="{DynamicResource FontSizeXs}"
                                                    Foreground="{DynamicResource AppTextSecondary}"
                                                    Text="{DynamicResource Goals.Add.Deadline}" />
                                                <TextBlock
                                                    Margin="0,4,0,0"
                                                    FontFamily="{StaticResource FontBase}"
                                                    Foreground="{DynamicResource AppTextSecondary}"
                                                    Text="{Binding DeadlineDisplay}"
                                                    TextTrimming="CharacterEllipsis"
                                                    Typography.NumeralAlignment="Tabular" />
                                            </StackPanel>
                                        </Grid>

                                        <Grid
                                            Grid.Row="2"
                                            Grid.ColumnSpan="2"
                                            Margin="0,14,0,0">
                                            <Grid.ColumnDefinitions>
                                                <ColumnDefinition Width="*" />
                                                <ColumnDefinition Width="Auto" />
                                            </Grid.ColumnDefinitions>
                                            <TextBlock
                                                FontFamily="{StaticResource FontBase}"
                                                Foreground="{DynamicResource AppTextSecondary}"
                                                Text="{Binding TargetDisplay, StringFormat={}{0}}"
                                                Typography.NumeralAlignment="Tabular" />
                                            <TextBlock
                                                Grid.Column="1"
                                                FontFamily="{StaticResource FontBase}"
                                                FontWeight="SemiBold"
                                                Foreground="{DynamicResource AppAccent}"
                                                Text="{Binding ProgressDisplay}"
                                                Typography.NumeralAlignment="Tabular" />
                                        </Grid>

                                        <ProgressBar
                                            Grid.Row="3"
                                            Grid.ColumnSpan="2"
                                            Height="8"
                                            Margin="0,8,0,0"
                                            Foreground="{Binding StatusTag, Converter={StaticResource StatusTagToBrushConverter}}"
                                            Maximum="100"
                                            Value="{Binding ProgressPercent, Mode=OneWay}" />
                                    </Grid>
                                </ui:Card>
                            </DataTemplate>
                        </ItemsControl.ItemTemplate>
                        </ItemsControl>
                    </ScrollViewer>
                </Grid>

            <Border
                Grid.Row="0"
                Grid.RowSpan="4"
                Margin="-24"
                Panel.ZIndex="180"
                Background="#99000000"
                Visibility="{Binding IsFormOpen, Converter={StaticResource BooleanToVisibilityConverter}}" />

            <Border
                Grid.Row="0"
                Grid.RowSpan="4"
                Width="640"
                MaxWidth="720"
                MaxHeight="680"
                HorizontalAlignment="Center"
                VerticalAlignment="Center"
                Panel.ZIndex="181"
                Background="{DynamicResource AppSurface}"
                BorderBrush="{DynamicResource AppBorder}"
                BorderThickness="1"
                CornerRadius="{StaticResource RadiusLg}"
                SnapsToDevicePixels="True"
                Visibility="{Binding IsFormOpen, Converter={StaticResource BooleanToVisibilityConverter}}">
                <Border.Effect>
                    <DropShadowEffect
                        BlurRadius="32"
                        Direction="270"
                        Opacity="0.18"
                        ShadowDepth="10"
                        Color="#000000" />
                </Border.Effect>

                <Grid>
                    <Grid.RowDefinitions>
                        <RowDefinition Height="Auto" />
                        <RowDefinition Height="Auto" />
                        <RowDefinition Height="Auto" />
                        <RowDefinition Height="Auto" />
                    </Grid.RowDefinitions>

                    <StackPanel Margin="24,22,24,18">
                        <TextBlock
                            FontSize="{StaticResource FontSizeLg}"
                            FontWeight="SemiBold"
                            Foreground="{DynamicResource AppTextPrimary}"
                            Text="{Binding FormTitle}" />
                        <TextBlock
                            Margin="0,6,0,0"
                            Foreground="{DynamicResource AppTextSecondary}"
                            Text="{DynamicResource Goals.Form.Hint}"
                            TextWrapping="Wrap" />
                    </StackPanel>

                    <Border
                        Grid.Row="1"
                        Margin="20,0,20,0"
                        Padding="16"
                        Background="{DynamicResource AppSurfaceAlt}"
                        BorderBrush="{DynamicResource AppBorder}"
                        BorderThickness="1"
                        CornerRadius="{StaticResource RadiusLg}">
                        <Grid>
                        <Grid.Resources>
                            <Style x:Key="FormFieldLabel" TargetType="TextBlock">
                                <Setter Property="Margin" Value="0,0,0,6" />
                                <Setter Property="FontSize" Value="{DynamicResource FontSizeXs}" />
                                <Setter Property="FontWeight" Value="SemiBold" />
                                <Setter Property="Foreground" Value="{DynamicResource AppTextSecondary}" />
                            </Style>
                            <Style BasedOn="{StaticResource {x:Type ui:TextBox}}" TargetType="{x:Type ui:TextBox}">
                                <Setter Property="MinHeight" Value="40" />
                            </Style>
                        </Grid.Resources>
                        <Grid.RowDefinitions>
                            <RowDefinition Height="Auto" />
                            <RowDefinition Height="Auto" />
                            <RowDefinition Height="Auto" />
                        </Grid.RowDefinitions>
                        <Grid.ColumnDefinitions>
                            <ColumnDefinition Width="*" />
                            <ColumnDefinition Width="16" />
                            <ColumnDefinition Width="*" />
                        </Grid.ColumnDefinitions>

                        <StackPanel
                            Grid.Row="0"
                            Grid.Column="0"
                            Grid.ColumnSpan="3"
                            Margin="0,0,0,14">
                            <TextBlock Style="{StaticResource FormFieldLabel}" Text="{DynamicResource Goals.Add.Name}" />
                            <ui:TextBox Text="{Binding AddName, UpdateSourceTrigger=PropertyChanged}" />
                        </StackPanel>

                        <StackPanel
                            Grid.Row="1"
                            Grid.Column="0"
                            Margin="0,0,0,14">
                            <TextBlock Style="{StaticResource FormFieldLabel}" Text="{DynamicResource Goals.Add.Target}" />
                            <ui:TextBox
                                behaviors:ThousandSeparatorBehavior.IsEnabled="True"
                                Text="{Binding AddTargetAmount, UpdateSourceTrigger=PropertyChanged}" />
                        </StackPanel>

                        <StackPanel
                            Grid.Row="1"
                            Grid.Column="2"
                            Margin="0,0,0,14">
                            <TextBlock Style="{StaticResource FormFieldLabel}" Text="{DynamicResource Goals.Add.Current}" />
                            <ui:TextBox
                                behaviors:ThousandSeparatorBehavior.IsEnabled="True"
                                Text="{Binding AddCurrentAmount, UpdateSourceTrigger=PropertyChanged}" />
                        </StackPanel>

                        <StackPanel Grid.Row="2" Grid.Column="0">
                            <TextBlock Style="{StaticResource FormFieldLabel}" Text="{DynamicResource Goals.Add.Deadline}" />
                            <ui:CalendarDatePicker
                                MinWidth="132"
                                HorizontalContentAlignment="Left"
                                Content="{Binding AddDeadline, Converter={StaticResource DateDisplayConverter}}"
                                Date="{Binding AddDeadline, Mode=TwoWay}" />
                        </StackPanel>

                        <StackPanel Grid.Row="2" Grid.Column="2">
                            <TextBlock Style="{StaticResource FormFieldLabel}" Text="{DynamicResource Goals.Add.Notes}" />
                            <ui:TextBox Text="{Binding AddNotes, UpdateSourceTrigger=PropertyChanged}" />
                        </StackPanel>
                    </Grid>
                    </Border>

                    <TextBlock
                        Grid.Row="2"
                        Margin="24,10,24,0"
                        Foreground="{DynamicResource AppDown}"
                        Text="{Binding AddError}"
                        Visibility="{Binding AddError, Converter={StaticResource StringToVisibilityConverter}}" />

                    <Border
                        Grid.Row="3"
                        Margin="0,18,0,0"
                        Padding="20,16"
                        BorderBrush="{DynamicResource AppBorder}"
                        BorderThickness="0,1,0,0">
                        <DockPanel LastChildFill="False">
                            <ui:Button
                                Margin="8,0,0,0"
                                DockPanel.Dock="Right"
                                Command="{Binding AddCommand}"
                                Style="{StaticResource PagePrimaryButton}">
                                <TextBlock
                                    Foreground="{Binding Foreground, RelativeSource={RelativeSource AncestorType=Button}}"
                                    Text="{Binding SubmitText}" />
                            </ui:Button>

                            <ui:Button
                                DockPanel.Dock="Right"
                                Command="{Binding CancelEditCommand}"
                                Content="{DynamicResource Goals.Edit.Cancel}"
                                Style="{StaticResource PageSecondaryButton}" />
                        </DockPanel>
                    </Border>
                </Grid>
            </Border>
        </Grid>

        <Grid
            Panel.ZIndex="220"
            Visibility="{Binding IsConfirmDialogOpen, Converter={StaticResource BooleanToVisibilityConverter}}">
            <Border Background="{DynamicResource AppModalOverlay}" />
            <Border
                Width="320"
                HorizontalAlignment="Center"
                VerticalAlignment="Center"
                Background="{DynamicResource AppSurface}"
                BorderBrush="{DynamicResource AppBorder}"
                BorderThickness="1"
                CornerRadius="{StaticResource RadiusMd}">
                <StackPanel Margin="24,20">
                    <TextBlock
                        Margin="0,0,0,4"
                        FontSize="{StaticResource FontSizeSm}"
                        FontWeight="SemiBold"
                        Foreground="{DynamicResource AppTextPrimary}"
                        Text="{DynamicResource Goals.Delete.ConfirmTitle}" />
                    <TextBlock
                        Margin="0,0,0,20"
                        FontSize="{StaticResource FontSizeSm}"
                        Foreground="{DynamicResource AppTextSecondary}"
                        Text="{Binding ConfirmDialogMessage}"
                        TextWrapping="Wrap" />
                    <StackPanel HorizontalAlignment="Right" Orientation="Horizontal">
                        <ui:Button
                            Margin="0,0,8,0"
                            Command="{Binding ConfirmDialogNoCommand}"
                            Style="{StaticResource PageSecondaryButton}">
                            <TextBlock Text="{DynamicResource Common.Cancel}" />
                        </ui:Button>
                        <ui:Button
                            Command="{Binding ConfirmDialogYesCommand}"
                            Style="{StaticResource PageDangerButton}">
                            <TextBlock
                                Foreground="{Binding Foreground, RelativeSource={RelativeSource AncestorType=Button}}"
                                Text="{DynamicResource Common.Delete}" />
                        </ui:Button>
                    </StackPanel>
                </StackPanel>
            </Border>
        </Grid>
    </Grid>
</UserControl>
