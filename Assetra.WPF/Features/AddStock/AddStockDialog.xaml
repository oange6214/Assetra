<ui:FluentWindow
    x:Class="Assetra.WPF.Features.AddStock.AddStockDialog"
    xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
    xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
    xmlns:ui="http://schemas.lepo.co/wpfui/2022/xaml"
    Title="新增自選股"
    Width="400"
    Height="520"
    MinWidth="360"
    MinHeight="460"
    Background="{DynamicResource AppBackground}"
    WindowStartupLocation="CenterOwner">

    <Grid>
        <Grid.RowDefinitions>
            <RowDefinition Height="Auto" />
            <RowDefinition Height="*" />
            <RowDefinition Height="Auto" />
        </Grid.RowDefinitions>

        <!--  Header  -->
        <Border
            Grid.Row="0"
            Padding="20,16"
            Background="{DynamicResource AppSurface}"
            BorderBrush="{DynamicResource AppBorder}"
            BorderThickness="0,0,0,1">
            <TextBlock
                FontFamily="{StaticResource FontBase}"
                FontSize="{StaticResource FontSizeLg}"
                FontWeight="SemiBold"
                Foreground="{DynamicResource AppTextPrimary}"
                Text="新增自選股" />
        </Border>

        <!--  Content  -->
        <StackPanel Grid.Row="1" Margin="20,16,20,0">

            <!--  Search Input  -->
            <ui:TextBox
                Margin="0,0,0,6"
                PlaceholderText="輸入股票代號或名稱（如：2330、台積電）"
                Text="{Binding SearchQuery, UpdateSourceTrigger=PropertyChanged}" />

            <!--  Error Message  -->
            <TextBlock
                Margin="0,0,0,10"
                FontSize="{StaticResource FontSizeSm}"
                Foreground="{DynamicResource AppDown}"
                Text="{Binding ErrorMessage}"
                TextWrapping="Wrap"
                Visibility="{Binding ErrorMessage, Converter={StaticResource StringToVisibilityConverter}}" />

            <!--  Results List  -->
            <Border
                BorderBrush="{DynamicResource AppBorder}"
                BorderThickness="1"
                CornerRadius="{StaticResource RadiusMd}">
                <ListBox
                    MaxHeight="320"
                    Background="{DynamicResource AppSurface}"
                    BorderThickness="0"
                    ItemsSource="{Binding SearchResults}"
                    ScrollViewer.HorizontalScrollBarVisibility="Disabled"
                    SelectedItem="{Binding SelectedResult}">
                    <ListBox.ItemContainerStyle>
                        <Style TargetType="ListBoxItem">
                            <Setter Property="Padding" Value="12,8" />
                            <Setter Property="Background" Value="Transparent" />
                            <Setter Property="BorderThickness" Value="0" />
                            <Setter Property="HorizontalContentAlignment" Value="Stretch" />
                            <Setter Property="FocusVisualStyle" Value="{x:Null}" />
                            <Style.Triggers>
                                <Trigger Property="IsMouseOver" Value="True">
                                    <Setter Property="Background" Value="{DynamicResource AppHover}" />
                                </Trigger>
                                <Trigger Property="IsSelected" Value="True">
                                    <Setter Property="Background" Value="{DynamicResource AppAccentSubtle}" />
                                </Trigger>
                            </Style.Triggers>
                        </Style>
                    </ListBox.ItemContainerStyle>
                    <ListBox.ItemTemplate>
                        <DataTemplate>
                            <Grid>
                                <Grid.ColumnDefinitions>
                                    <ColumnDefinition Width="60" />
                                    <ColumnDefinition Width="*" />
                                    <ColumnDefinition Width="Auto" />
                                </Grid.ColumnDefinitions>
                                <TextBlock
                                    Grid.Column="0"
                                    VerticalAlignment="Center"
                                    FontFamily="{StaticResource FontTabular}"
                                    FontSize="{StaticResource FontSizeSm}"
                                    FontWeight="SemiBold"
                                    Foreground="{DynamicResource AppAccent}"
                                    Text="{Binding Symbol}" />
                                <TextBlock
                                    Grid.Column="1"
                                    VerticalAlignment="Center"
                                    FontSize="{StaticResource FontSizeSm}"
                                    Foreground="{DynamicResource AppTextPrimary}"
                                    Text="{Binding Name}"
                                    TextTrimming="CharacterEllipsis" />
                                <Border
                                    Grid.Column="2"
                                    Padding="5,2"
                                    VerticalAlignment="Center"
                                    Background="{DynamicResource AppBackground}"
                                    CornerRadius="{StaticResource RadiusSm}">
                                    <TextBlock
                                        FontSize="{StaticResource FontSizeXs}"
                                        Foreground="{DynamicResource AppTextMuted}"
                                        Text="{Binding Exchange}" />
                                </Border>
                            </Grid>
                        </DataTemplate>
                    </ListBox.ItemTemplate>
                </ListBox>
            </Border>
        </StackPanel>

        <!--  Footer Buttons  -->
        <Border
            Grid.Row="2"
            Padding="20,12"
            Background="{DynamicResource AppSurface}"
            BorderBrush="{DynamicResource AppBorder}"
            BorderThickness="0,1,0,0">
            <StackPanel HorizontalAlignment="Right" Orientation="Horizontal">
                <Button
                    Margin="0,0,8,0"
                    Command="{Binding CancelCommand}"
                    Content="取消"
                    Style="{StaticResource BtnGhost}" />
                <Button
                    Command="{Binding AddCommand}"
                    Content="加入自選"
                    Style="{StaticResource BtnPrimary}" />
            </StackPanel>
        </Border>
    </Grid>
</ui:FluentWindow>
