<UserControl
    x:Name="Root"
    x:Class="Assetra.WPF.Features.Recurring.RecurringView"
    xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
    xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
    xmlns:ui="http://schemas.lepo.co/wpfui/2022/xaml"
    xmlns:d="http://schemas.microsoft.com/expression/blend/2008"
    xmlns:mc="http://schemas.openxmlformats.org/markup-compatibility/2006"
    xmlns:vm="clr-namespace:Assetra.WPF.Features.Recurring"
    d:DataContext="{d:DesignInstance Type={x:Type vm:RecurringViewModel}, IsDesignTimeCreatable=False}"
    d:DesignHeight="700" d:DesignWidth="1000"
    Background="{DynamicResource AppBackground}"
    mc:Ignorable="d">
  <UserControl.Resources>
    <Style x:Key="InlineFormLabel" TargetType="TextBlock">
      <Setter Property="Margin" Value="0,0,0,6" />
      <Setter Property="FontSize" Value="{StaticResource FontSizeXs}" />
      <Setter Property="Foreground" Value="{DynamicResource AppTextMuted}" />
    </Style>
    <Style x:Key="InlineFormField" TargetType="StackPanel">
      <Setter Property="Margin" Value="0,0,12,10" />
      <Setter Property="VerticalAlignment" Value="Top" />
    </Style>
  </UserControl.Resources>

  <Grid Margin="20">
    <Grid.RowDefinitions>
      <RowDefinition Height="Auto" />
      <RowDefinition Height="*" />
    </Grid.RowDefinitions>

    <!-- Header -->
    <DockPanel Grid.Row="0" Margin="0,0,0,16">
      <ui:Button
          DockPanel.Dock="Right"
          Margin="8,0,0,0"
          Command="{Binding RunSchedulerCommand}"
          Content="{DynamicResource Recurring.Run}" />
      <TextBlock
          Margin="16,0,0,0"
          VerticalAlignment="Center"
          FontSize="{StaticResource FontSizeSm}"
          Foreground="{DynamicResource AppTextMuted}"
          Text="{Binding RunStatus}" />
    </DockPanel>

    <TabControl Grid.Row="1" Background="Transparent" BorderThickness="0">

      <!-- Subscriptions tab -->
      <TabItem Header="{DynamicResource Recurring.Tab.Subscriptions}">
        <Grid Margin="0,12,0,0">
          <Grid.RowDefinitions>
            <RowDefinition Height="Auto" />
            <RowDefinition Height="Auto" />
            <RowDefinition Height="*" />
          </Grid.RowDefinitions>

          <!-- Toolbar: + Add Subscription button -->
          <DockPanel Grid.Row="0" Margin="0,0,0,12" LastChildFill="False">
            <ui:Button
                DockPanel.Dock="Right"
                Command="{Binding OpenAddFormCommand}"
                Appearance="Primary"
                Visibility="{Binding IsAddFormOpen, Converter={StaticResource InverseBooleanToVisibilityConverter}}">
              <StackPanel Orientation="Horizontal">
                <ui:SymbolIcon Symbol="Add24" Margin="0,0,4,0" VerticalAlignment="Center" />
                <TextBlock Text="{DynamicResource Recurring.Add}" VerticalAlignment="Center" />
              </StackPanel>
            </ui:Button>
          </DockPanel>

          <!-- Add form (collapsible) -->
          <ui:Card
              Grid.Row="1"
              Margin="0,0,0,12"
              Padding="12"
              Visibility="{Binding IsAddFormOpen, Converter={StaticResource BooleanToVisibilityConverter}}">
            <StackPanel>
              <TextBlock
                  FontSize="{StaticResource FontSizeMd}"
                  FontWeight="SemiBold"
                  Foreground="{DynamicResource AppTextPrimary}"
                  Text="{DynamicResource Recurring.AddForm.Title}" />
              <TextBlock
                  Margin="0,4,0,12"
                  FontSize="{StaticResource FontSizeSm}"
                  Foreground="{DynamicResource AppTextSecondary}"
                  Text="{DynamicResource Recurring.AddForm.Hint}"
                  TextWrapping="Wrap" />
              <WrapPanel Orientation="Horizontal">
                <StackPanel Style="{StaticResource InlineFormField}">
                  <TextBlock Style="{StaticResource InlineFormLabel}" Text="{DynamicResource Recurring.Field.Name}" />
                  <ui:TextBox
                      Width="240"
                      MinHeight="36"

                      ToolTip="{DynamicResource Recurring.NameHint}"
                      Text="{Binding AddName, UpdateSourceTrigger=PropertyChanged}" />
                </StackPanel>

                <StackPanel Style="{StaticResource InlineFormField}">
                  <TextBlock Style="{StaticResource InlineFormLabel}" Text="{DynamicResource Recurring.Field.Type}" />
                  <ComboBox
                      Width="180"
                      MinHeight="36"
                      ItemsSource="{Binding TradeTypeOptions}"
                      SelectedItem="{Binding AddTradeType}"
                      Style="{StaticResource FormComboBox}">
                    <ComboBox.ItemTemplate>
                      <DataTemplate>
                        <TextBlock>
                          <TextBlock.Style>
                            <Style TargetType="TextBlock">
                              <Setter Property="Text" Value="{DynamicResource Portfolio.TradeType.Withdrawal}" />
                              <Style.Triggers>
                                <DataTrigger Binding="{Binding}" Value="Income">
                                  <Setter Property="Text" Value="{DynamicResource Portfolio.TradeType.Income}" />
                                </DataTrigger>
                                <DataTrigger Binding="{Binding}" Value="Deposit">
                                  <Setter Property="Text" Value="{DynamicResource Portfolio.TradeType.Deposit}" />
                                </DataTrigger>
                                <DataTrigger Binding="{Binding}" Value="CreditCardCharge">
                                  <Setter Property="Text" Value="{DynamicResource Portfolio.TradeType.CreditCardCharge}" />
                                </DataTrigger>
                              </Style.Triggers>
                            </Style>
                          </TextBlock.Style>
                        </TextBlock>
                      </DataTemplate>
                    </ComboBox.ItemTemplate>
                  </ComboBox>
                </StackPanel>

                <StackPanel Style="{StaticResource InlineFormField}">
                  <TextBlock Style="{StaticResource InlineFormLabel}" Text="{DynamicResource Recurring.Field.Amount}" />
                  <ui:TextBox
                      Width="140"
                      MinHeight="36"

                      ToolTip="{DynamicResource Recurring.AmountHint}"
                      Text="{Binding AddAmount, UpdateSourceTrigger=PropertyChanged}" />
                </StackPanel>

                <StackPanel Style="{StaticResource InlineFormField}">
                  <TextBlock Style="{StaticResource InlineFormLabel}" Text="{DynamicResource Recurring.Field.Frequency}" />
                  <ComboBox
                      Width="160"
                      MinHeight="36"
                      ItemsSource="{Binding FrequencyOptions}"
                      SelectedItem="{Binding AddFrequency}"
                      Style="{StaticResource FormComboBox}">
                    <ComboBox.ItemTemplate>
                      <DataTemplate>
                        <TextBlock>
                          <TextBlock.Style>
                            <Style TargetType="TextBlock">
                              <Setter Property="Text" Value="{DynamicResource Recurring.Frequency.Monthly}" />
                              <Style.Triggers>
                                <DataTrigger Binding="{Binding}" Value="Daily">
                                  <Setter Property="Text" Value="{DynamicResource Recurring.Frequency.Daily}" />
                                </DataTrigger>
                                <DataTrigger Binding="{Binding}" Value="Weekly">
                                  <Setter Property="Text" Value="{DynamicResource Recurring.Frequency.Weekly}" />
                                </DataTrigger>
                                <DataTrigger Binding="{Binding}" Value="BiWeekly">
                                  <Setter Property="Text" Value="{DynamicResource Recurring.Frequency.BiWeekly}" />
                                </DataTrigger>
                                <DataTrigger Binding="{Binding}" Value="Quarterly">
                                  <Setter Property="Text" Value="{DynamicResource Recurring.Frequency.Quarterly}" />
                                </DataTrigger>
                                <DataTrigger Binding="{Binding}" Value="Yearly">
                                  <Setter Property="Text" Value="{DynamicResource Recurring.Frequency.Yearly}" />
                                </DataTrigger>
                              </Style.Triggers>
                            </Style>
                          </TextBlock.Style>
                        </TextBlock>
                      </DataTemplate>
                    </ComboBox.ItemTemplate>
                  </ComboBox>
                </StackPanel>

                <StackPanel Style="{StaticResource InlineFormField}">
                  <TextBlock Style="{StaticResource InlineFormLabel}" Text="{DynamicResource Recurring.Field.Interval}" />
                  <ui:TextBox
                      Width="100"
                      MinHeight="36"

                      ToolTip="{DynamicResource Recurring.IntervalHint}"
                      Text="{Binding AddInterval, UpdateSourceTrigger=PropertyChanged}" />
                </StackPanel>

                <StackPanel Style="{StaticResource InlineFormField}">
                  <TextBlock Style="{StaticResource InlineFormLabel}" Text="{DynamicResource Recurring.Field.StartDate}" />
                  <ui:CalendarDatePicker
                      Width="160"
                      Date="{Binding AddStartDate, Mode=TwoWay}" />
                </StackPanel>

                <StackPanel Style="{StaticResource InlineFormField}">
                  <TextBlock Style="{StaticResource InlineFormLabel}" Text="{DynamicResource Recurring.Field.Mode}" />
                  <ComboBox
                      Width="180"
                      MinHeight="36"
                      ItemsSource="{Binding ModeOptions}"
                      SelectedItem="{Binding AddGenerationMode}"
                      Style="{StaticResource FormComboBox}">
                    <ComboBox.ItemTemplate>
                      <DataTemplate>
                        <TextBlock>
                          <TextBlock.Style>
                            <Style TargetType="TextBlock">
                              <Setter Property="Text" Value="{DynamicResource Recurring.Mode.PendingConfirm}" />
                              <Style.Triggers>
                                <DataTrigger Binding="{Binding}" Value="AutoApply">
                                  <Setter Property="Text" Value="{DynamicResource Recurring.Mode.AutoApply}" />
                                </DataTrigger>
                              </Style.Triggers>
                            </Style>
                          </TextBlock.Style>
                        </TextBlock>
                      </DataTemplate>
                    </ComboBox.ItemTemplate>
                  </ComboBox>
                </StackPanel>

                <StackPanel Style="{StaticResource InlineFormField}">
                  <TextBlock Style="{StaticResource InlineFormLabel}" Text="{DynamicResource Recurring.Field.Note}" />
                  <ui:TextBox
                      Width="260"
                      MinHeight="36"

                      Text="{Binding AddNote, UpdateSourceTrigger=PropertyChanged}" />
                </StackPanel>

              </WrapPanel>
              <Border
                  Margin="0,4,0,0"
                  Padding="0,10,0,0"
                  BorderBrush="{DynamicResource AppBorder}"
                  BorderThickness="0,1,0,0">
                <DockPanel LastChildFill="False">
                  <ui:Button
                      DockPanel.Dock="Right"
                      MinWidth="120"
                      MinHeight="36"
                      Command="{Binding AddSubscriptionCommand}"
                      Content="{DynamicResource Recurring.Add}"
                      Appearance="Primary" />
                  <ui:Button
                      DockPanel.Dock="Right"
                      MinWidth="80"
                      MinHeight="36"
                      Margin="0,0,8,0"
                      Command="{Binding CloseAddFormCommand}"
                      Content="{DynamicResource Common.Cancel}"
                      Appearance="Secondary" />
                </DockPanel>
              </Border>
              <TextBlock
                  Margin="2,4,0,0"
                  FontSize="{StaticResource FontSizeXs}"
                  Foreground="{DynamicResource AppDown}"
                  Text="{Binding AddError}"
                  Visibility="{Binding AddError, Converter={StaticResource StringToVisibilityConverter}}" />
            </StackPanel>
          </ui:Card>

          <!-- Empty state -->
          <StackPanel
              Grid.Row="2"
              HorizontalAlignment="Center"
              VerticalAlignment="Center"
              Visibility="{Binding HasNoSubscriptions, Converter={StaticResource BooleanToVisibilityConverter}}">
            <ui:SymbolIcon
                HorizontalAlignment="Center"
                FontSize="48"
                Foreground="{DynamicResource AppTextMuted}"
                Symbol="ArrowRepeatAll24" />
            <TextBlock
                Margin="0,12,0,0"
                HorizontalAlignment="Center"
                FontSize="{DynamicResource FontSizeSm}"
                Foreground="{DynamicResource AppTextSecondary}"
                Text="{DynamicResource Recurring.Empty}" />
          </StackPanel>

          <!-- Subscriptions list -->
          <ScrollViewer
              Grid.Row="2"
              VerticalScrollBarVisibility="Auto"
              Visibility="{Binding HasSubscriptions, Converter={StaticResource BooleanToVisibilityConverter}}">
            <ItemsControl ItemsSource="{Binding Subscriptions}">
              <ItemsControl.ItemTemplate>
                <DataTemplate DataType="{x:Type vm:RecurringRowViewModel}">
                  <ui:Card
                      Margin="0,0,0,6"
                      Padding="12,10">
                    <Grid>
                      <Grid.ColumnDefinitions>
                        <ColumnDefinition Width="*" />
                        <ColumnDefinition Width="Auto" />
                        <ColumnDefinition Width="Auto" />
                        <ColumnDefinition Width="Auto" />
                        <ColumnDefinition Width="Auto" />
                        <ColumnDefinition Width="Auto" />
                      </Grid.ColumnDefinitions>
                      <StackPanel Grid.Column="0" VerticalAlignment="Center">
                        <TextBlock
                            FontSize="{StaticResource FontSizeBase}"
                            FontWeight="SemiBold"
                            Foreground="{DynamicResource AppTextPrimary}"
                            Text="{Binding Name}" />
                        <TextBlock
                            FontSize="{StaticResource FontSizeXs}"
                            Foreground="{DynamicResource AppTextMuted}"
                            Text="{Binding Note}" />
                      </StackPanel>
                      <TextBlock
                          Grid.Column="1"
                          Margin="12,0"
                          VerticalAlignment="Center"
                          FontFamily="{StaticResource FontBase}" Typography.NumeralAlignment="Tabular"
                          FontSize="{StaticResource FontSizeBase}"
                          Foreground="{DynamicResource AppTextPrimary}"
                          Text="{Binding AmountDisplay}" />
                      <TextBlock
                          Grid.Column="2"
                          Margin="12,0"
                          VerticalAlignment="Center"
                          FontSize="{StaticResource FontSizeSm}"
                          Foreground="{DynamicResource AppTextSecondary}"
                          Text="{Binding FrequencyDisplay}" />
                      <TextBlock
                          Grid.Column="3"
                          Margin="12,0"
                          VerticalAlignment="Center"
                          FontSize="{StaticResource FontSizeSm}"
                          Foreground="{DynamicResource AppTextSecondary}"
                          Text="{Binding ModeDisplay}" />
                      <TextBlock
                          Grid.Column="4"
                          Margin="12,0"
                          VerticalAlignment="Center"
                          FontSize="{StaticResource FontSizeSm}"
                          Foreground="{DynamicResource AppTextMuted}"
                          Text="{Binding NextDueDisplay}" />
                      <StackPanel Grid.Column="5" VerticalAlignment="Center" Orientation="Horizontal">
                        <ui:ToggleSwitch
                            Margin="6,0"
                            VerticalAlignment="Center"
                            Command="{Binding DataContext.ToggleEnabledCommand, ElementName=Root}"
                            CommandParameter="{Binding}"
                            IsChecked="{Binding IsEnabled, Mode=OneWay}" />
                        <ui:Button
                            Margin="6,0,0,0"
                            Padding="8"
                            Appearance="Transparent"
                            Command="{Binding DataContext.DeleteSubscriptionCommand, ElementName=Root}"
                            CommandParameter="{Binding}"
                            ToolTip="{DynamicResource Common.Delete}">
                          <ui:SymbolIcon Symbol="Delete24" Foreground="{DynamicResource AppDanger}" />
                        </ui:Button>
                      </StackPanel>
                    </Grid>
                  </ui:Card>
                </DataTemplate>
              </ItemsControl.ItemTemplate>
            </ItemsControl>
          </ScrollViewer>
        </Grid>
      </TabItem>

      <!-- Pending tab -->
      <TabItem Header="{DynamicResource Recurring.Tab.Pending}">
        <Grid Margin="0,12,0,0">
          <!-- Empty state -->
          <StackPanel
              HorizontalAlignment="Center"
              VerticalAlignment="Center"
              Visibility="{Binding HasPending, Converter={StaticResource InverseBooleanToVisibilityConverter}}">
            <ui:SymbolIcon
                HorizontalAlignment="Center"
                FontSize="48"
                Foreground="{DynamicResource AppTextMuted}"
                Symbol="CheckmarkCircle24" />
            <TextBlock
                Margin="0,12,0,0"
                HorizontalAlignment="Center"
                FontSize="{DynamicResource FontSizeSm}"
                Foreground="{DynamicResource AppTextSecondary}"
                Text="{DynamicResource Recurring.Pending.Empty}" />
          </StackPanel>

          <ScrollViewer
              VerticalScrollBarVisibility="Auto"
              Visibility="{Binding HasPending, Converter={StaticResource BooleanToVisibilityConverter}}">
          <ItemsControl ItemsSource="{Binding Pending}">
            <ItemsControl.ItemTemplate>
              <DataTemplate DataType="{x:Type vm:PendingRecurringRowViewModel}">
                <ui:Card
                    Margin="0,0,0,6"
                    Padding="12,10">
                  <Grid>
                    <Grid.ColumnDefinitions>
                      <ColumnDefinition Width="*" />
                      <ColumnDefinition Width="Auto" />
                      <ColumnDefinition Width="Auto" />
                      <ColumnDefinition Width="Auto" />
                    </Grid.ColumnDefinitions>
                    <StackPanel Grid.Column="0" VerticalAlignment="Center">
                      <TextBlock
                          FontSize="{StaticResource FontSizeBase}"
                          FontWeight="SemiBold"
                          Foreground="{DynamicResource AppTextPrimary}"
                          Text="{Binding SourceDisplay}" />
                      <TextBlock
                          FontSize="{StaticResource FontSizeXs}"
                          Foreground="{DynamicResource AppTextMuted}"
                          Text="{Binding Note}" />
                    </StackPanel>
                    <TextBlock
                        Grid.Column="1"
                        Margin="12,0"
                        VerticalAlignment="Center"
                        FontSize="{StaticResource FontSizeSm}"
                        Foreground="{DynamicResource AppTextSecondary}"
                        Text="{Binding DueDateDisplay}" />
                    <TextBlock
                        Grid.Column="2"
                        Margin="12,0"
                        VerticalAlignment="Center"
                        FontFamily="{StaticResource FontBase}" Typography.NumeralAlignment="Tabular"
                        FontSize="{StaticResource FontSizeBase}"
                        Foreground="{DynamicResource AppTextPrimary}"
                        Text="{Binding AmountDisplay}" />
                    <StackPanel Grid.Column="3" VerticalAlignment="Center" Orientation="Horizontal">
                      <ui:Button
                          Margin="6,0,0,0"
                          Appearance="Primary"
                          Command="{Binding DataContext.ConfirmPendingCommand, ElementName=Root}"
                          CommandParameter="{Binding}"
                          Content="{DynamicResource Recurring.Pending.Confirm}" />
                      <ui:Button
                          Margin="6,0,0,0"
                          Appearance="Secondary"
                          Command="{Binding DataContext.SkipPendingCommand, ElementName=Root}"
                          CommandParameter="{Binding}"
                          Content="{DynamicResource Recurring.Pending.Skip}" />
                    </StackPanel>
                  </Grid>
                </ui:Card>
              </DataTemplate>
            </ItemsControl.ItemTemplate>
          </ItemsControl>
          </ScrollViewer>
        </Grid>
      </TabItem>

    </TabControl>
  </Grid>
</UserControl>
