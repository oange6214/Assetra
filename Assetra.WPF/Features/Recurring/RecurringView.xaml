<UserControl
    x:Name="Root"
    x:Class="Assetra.WPF.Features.Recurring.RecurringView"
    xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
    xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
    xmlns:behaviors="clr-namespace:Assetra.WPF.Infrastructure.Behaviors"
    xmlns:d="http://schemas.microsoft.com/expression/blend/2008"
    xmlns:mc="http://schemas.openxmlformats.org/markup-compatibility/2006"
    xmlns:ui="http://schemas.lepo.co/wpfui/2022/xaml"
    xmlns:vm="clr-namespace:Assetra.WPF.Features.Recurring"
    d:DataContext="{d:DesignInstance Type={x:Type vm:RecurringViewModel}, IsDesignTimeCreatable=False}"
    d:DesignHeight="700"
    d:DesignWidth="1000"
    Background="{DynamicResource AppBackground}"
    mc:Ignorable="d">

    <Grid Background="{DynamicResource AppBackground}">
        <Grid Style="{StaticResource PageRootGrid}">
            <Grid.RowDefinitions>
                <RowDefinition Height="Auto" />
                <RowDefinition Height="Auto" />
                <RowDefinition Height="*" />
            </Grid.RowDefinitions>

            <DockPanel Grid.Row="0" Style="{StaticResource PageHeaderDock}">
                    <StackPanel VerticalAlignment="Center" Orientation="Horizontal">
                        <ui:SymbolIcon
                            Margin="0,0,8,0"
                            VerticalAlignment="Center"
                            Foreground="{DynamicResource AppTextMuted}"
                            Symbol="ArrowRepeatAll24" />
                        <TextBlock
                            Style="{StaticResource PageTitleText}"
                            Text="{DynamicResource Recurring.Title}" />
                    </StackPanel>
            </DockPanel>

            <UniformGrid
                Grid.Row="1"
                Columns="3"
                Rows="1"
                Style="{StaticResource PageMetricsGrid}">
                <ui:Card Margin="0,0,8,0" Padding="16">
                    <StackPanel>
                        <TextBlock
                            FontSize="{DynamicResource FontSizeXs}"
                            Foreground="{DynamicResource AppTextSecondary}"
                            Text="{DynamicResource Recurring.SubscriptionCount}" />
                        <TextBlock
                            Margin="0,8,0,0"
                            FontFamily="{StaticResource FontBase}"
                            FontSize="{DynamicResource FontSizeXl}"
                            FontWeight="SemiBold"
                            Foreground="{DynamicResource AppTextPrimary}"
                            Text="{Binding SubscriptionCount}"
                            Typography.NumeralAlignment="Tabular" />
                    </StackPanel>
                </ui:Card>
                <ui:Card Margin="8,0" Padding="16">
                    <StackPanel>
                        <TextBlock
                            FontSize="{DynamicResource FontSizeXs}"
                            Foreground="{DynamicResource AppTextSecondary}"
                            Text="{DynamicResource Recurring.EnabledCount}" />
                        <TextBlock
                            Margin="0,8,0,0"
                            FontFamily="{StaticResource FontBase}"
                            FontSize="{DynamicResource FontSizeXl}"
                            FontWeight="SemiBold"
                            Foreground="{DynamicResource AppAccent}"
                            Text="{Binding EnabledSubscriptionCount}"
                            Typography.NumeralAlignment="Tabular" />
                    </StackPanel>
                </ui:Card>
                <ui:Card Margin="8,0,0,0" Padding="16">
                    <StackPanel>
                        <TextBlock
                            FontSize="{DynamicResource FontSizeXs}"
                            Foreground="{DynamicResource AppTextSecondary}"
                            Text="{DynamicResource Recurring.PendingCount}" />
                        <TextBlock
                            Margin="0,8,0,0"
                            FontFamily="{StaticResource FontBase}"
                            FontSize="{DynamicResource FontSizeXl}"
                            FontWeight="SemiBold"
                            Foreground="{DynamicResource AppTextPrimary}"
                            Text="{Binding PendingCount}"
                            Typography.NumeralAlignment="Tabular" />
                    </StackPanel>
                </ui:Card>
            </UniformGrid>

            <TabControl
                Grid.Row="2"
                Background="Transparent"
                BorderThickness="0"
                HorizontalAlignment="Stretch"
                HorizontalContentAlignment="Stretch"
                VerticalAlignment="Stretch"
                VerticalContentAlignment="Stretch">
                <TabControl.ItemContainerStyle>
                    <Style BasedOn="{StaticResource {x:Type TabItem}}" TargetType="{x:Type TabItem}">
                        <Setter Property="HorizontalContentAlignment" Value="Stretch" />
                        <Setter Property="VerticalContentAlignment" Value="Stretch" />
                    </Style>
                </TabControl.ItemContainerStyle>

                <TabItem Header="{DynamicResource Recurring.Tab.Subscriptions}">
                    <Grid Margin="0,16,0,0">
                        <Grid.RowDefinitions>
                            <RowDefinition Height="Auto" />
                            <RowDefinition Height="*" />
                        </Grid.RowDefinitions>

                        <DockPanel Grid.Row="0" Style="{StaticResource PageHeaderDock}">
                                    <ui:Button
                                        DockPanel.Dock="Right"
                                        Command="{Binding OpenAddFormCommand}"
                                        Style="{StaticResource PagePrimaryButton}">
                                        <StackPanel Orientation="Horizontal">
                                            <ui:SymbolIcon
                                                Margin="0,0,4,0"
                                                VerticalAlignment="Center"
                                                FontSize="{StaticResource FontSizeXs}"
                                                Foreground="{Binding Foreground, RelativeSource={RelativeSource AncestorType=Button}}"
                                                Symbol="Add24" />
                                            <TextBlock
                                                VerticalAlignment="Center"
                                                Foreground="{Binding Foreground, RelativeSource={RelativeSource AncestorType=Button}}"
                                                Text="{DynamicResource Recurring.Add}" />
                                        </StackPanel>
                                    </ui:Button>

                                    <StackPanel>
                                        <TextBlock
                                            FontSize="{DynamicResource FontSizeMd}"
                                            FontWeight="SemiBold"
                                            Foreground="{DynamicResource AppTextPrimary}"
                                            Text="{DynamicResource Recurring.Tab.Subscriptions}" />
                                        <TextBlock
                                            Margin="0,4,0,0"
                                            Foreground="{DynamicResource AppTextSecondary}"
                                            Text="{DynamicResource Recurring.Subscriptions.Hint}" />
                                    </StackPanel>
                        </DockPanel>

                        <Grid Grid.Row="1" Style="{StaticResource PageContentGrid}">
                            <StackPanel
                                Style="{StaticResource EmptyStatePanel}"
                                Visibility="{Binding HasNoSubscriptions, Converter={StaticResource BooleanToVisibilityConverter}}">
                                <ui:SymbolIcon Style="{StaticResource EmptyStateIcon}" Symbol="ArrowRepeatAll24" />
                                <TextBlock Style="{StaticResource EmptyStateTitle}" Text="{DynamicResource Recurring.Empty}" />
                                <TextBlock Style="{StaticResource EmptyStateHint}" Text="{DynamicResource Recurring.Empty.Hint}" />
                                <ui:Button
                                    Command="{Binding OpenAddFormCommand}"
                                    Style="{StaticResource EmptyStateActionButton}">
                                    <StackPanel Orientation="Horizontal">
                                        <ui:SymbolIcon
                                            Margin="0,0,4,0"
                                            VerticalAlignment="Center"
                                            FontSize="{StaticResource FontSizeXs}"
                                            Foreground="{Binding Foreground, RelativeSource={RelativeSource AncestorType=Button}}"
                                            Symbol="Add24" />
                                        <TextBlock
                                            VerticalAlignment="Center"
                                            Foreground="{Binding Foreground, RelativeSource={RelativeSource AncestorType=Button}}"
                                            Text="{DynamicResource Recurring.Add}" />
                                    </StackPanel>
                                </ui:Button>
                            </StackPanel>

                            <ScrollViewer
                                HorizontalScrollBarVisibility="Disabled"
                                VerticalScrollBarVisibility="Auto"
                                Visibility="{Binding HasSubscriptions, Converter={StaticResource BooleanToVisibilityConverter}}">
                                <ItemsControl ItemsSource="{Binding Subscriptions}">
                                <ItemsControl.ItemTemplate>
                                    <DataTemplate DataType="{x:Type vm:RecurringRowViewModel}">
                                        <ui:Card Margin="0,0,0,8" Padding="14">
                                            <Grid>
                                                <Grid.ColumnDefinitions>
                                                    <ColumnDefinition Width="2*" />
                                                    <ColumnDefinition Width="Auto" />
                                                    <ColumnDefinition Width="Auto" />
                                                    <ColumnDefinition Width="Auto" />
                                                    <ColumnDefinition Width="Auto" />
                                                    <ColumnDefinition Width="Auto" />
                                                </Grid.ColumnDefinitions>

                                                <StackPanel Grid.Column="0" VerticalAlignment="Center">
                                                    <TextBlock
                                                        FontSize="{StaticResource FontSizeBase}"
                                                        FontWeight="SemiBold"
                                                        Foreground="{DynamicResource AppTextPrimary}"
                                                        Text="{Binding Name}" />
                                                    <TextBlock
                                                        Margin="0,3,0,0"
                                                        FontSize="{StaticResource FontSizeXs}"
                                                        Foreground="{DynamicResource AppTextMuted}"
                                                        Text="{Binding Note}"
                                                        TextTrimming="CharacterEllipsis" />
                                                </StackPanel>

                                                <StackPanel Grid.Column="1" MinWidth="120" Margin="16,0,0,0" VerticalAlignment="Center">
                                                    <TextBlock
                                                        FontSize="{DynamicResource FontSizeXs}"
                                                        Foreground="{DynamicResource AppTextSecondary}"
                                                        Text="{DynamicResource Recurring.Field.Amount}" />
                                                    <TextBlock
                                                        Margin="0,3,0,0"
                                                        FontFamily="{StaticResource FontBase}"
                                                        FontWeight="SemiBold"
                                                        Foreground="{DynamicResource AppTextPrimary}"
                                                        Text="{Binding AmountDisplay}"
                                                        Typography.NumeralAlignment="Tabular" />
                                                </StackPanel>

                                                <StackPanel Grid.Column="2" MinWidth="120" Margin="16,0,0,0" VerticalAlignment="Center">
                                                    <TextBlock
                                                        FontSize="{DynamicResource FontSizeXs}"
                                                        Foreground="{DynamicResource AppTextSecondary}"
                                                        Text="{DynamicResource Recurring.Field.Frequency}" />
                                                    <TextBlock
                                                        Margin="0,3,0,0"
                                                        Foreground="{DynamicResource AppTextPrimary}"
                                                        Text="{Binding FrequencyDisplay}" />
                                                </StackPanel>

                                                <StackPanel Grid.Column="3" MinWidth="120" Margin="16,0,0,0" VerticalAlignment="Center">
                                                    <TextBlock
                                                        FontSize="{DynamicResource FontSizeXs}"
                                                        Foreground="{DynamicResource AppTextSecondary}"
                                                        Text="{DynamicResource Recurring.Field.Mode}" />
                                                    <TextBlock
                                                        Margin="0,3,0,0"
                                                        Foreground="{DynamicResource AppTextPrimary}"
                                                        Text="{Binding ModeDisplay}" />
                                                </StackPanel>

                                                <StackPanel Grid.Column="4" MinWidth="130" Margin="16,0,0,0" VerticalAlignment="Center">
                                                    <TextBlock
                                                        FontSize="{DynamicResource FontSizeXs}"
                                                        Foreground="{DynamicResource AppTextSecondary}"
                                                        Text="{DynamicResource Recurring.NextDue}" />
                                                    <TextBlock
                                                        Margin="0,3,0,0"
                                                        FontFamily="{StaticResource FontBase}"
                                                        Foreground="{DynamicResource AppTextPrimary}"
                                                        Text="{Binding NextDueDisplay}"
                                                        Typography.NumeralAlignment="Tabular" />
                                                </StackPanel>

                                                <StackPanel Grid.Column="5" Margin="16,0,0,0" VerticalAlignment="Center" Orientation="Horizontal">
                                                    <ui:ToggleSwitch
                                                        Margin="0,0,8,0"
                                                        VerticalAlignment="Center"
                                                        Command="{Binding DataContext.ToggleEnabledCommand, ElementName=Root}"
                                                        CommandParameter="{Binding}"
                                                        IsChecked="{Binding IsEnabled, Mode=OneWay}" />
                                                    <ui:Button
                                                        Width="32"
                                                        Height="32"
                                                        Padding="0"
                                                        Appearance="Transparent"
                                                        Command="{Binding DataContext.DeleteSubscriptionCommand, ElementName=Root}"
                                                        CommandParameter="{Binding}"
                                                        ToolTip="{DynamicResource Common.Delete}">
                                                        <ui:SymbolIcon
                                                            FontSize="14"
                                                            Foreground="{DynamicResource AppDanger}"
                                                            Symbol="Delete24" />
                                                    </ui:Button>
                                                </StackPanel>
                                            </Grid>
                                        </ui:Card>
                                    </DataTemplate>
                                </ItemsControl.ItemTemplate>
                                </ItemsControl>
                            </ScrollViewer>
                        </Grid>
                    </Grid>
                </TabItem>

                <TabItem Header="{DynamicResource Recurring.Tab.Pending}">
                    <Grid Margin="0,16,0,0">
                        <Grid.RowDefinitions>
                            <RowDefinition Height="Auto" />
                            <RowDefinition Height="*" />
                        </Grid.RowDefinitions>

                        <DockPanel Grid.Row="0" Style="{StaticResource PageHeaderDock}">
                                   <ui:Button
                                       DockPanel.Dock="Right"
                                        Command="{Binding RunSchedulerCommand}"
                                        Style="{StaticResource PagePrimaryButton}">
                                        <StackPanel Orientation="Horizontal">
                                            <ui:SymbolIcon
                                                Margin="0,0,4,0"
                                                VerticalAlignment="Center"
                                                FontSize="{StaticResource FontSizeXs}"
                                                Foreground="{Binding Foreground, RelativeSource={RelativeSource AncestorType=Button}}"
                                                Symbol="ArrowRepeatAll24" />
                                            <TextBlock
                                                VerticalAlignment="Center"
                                                Foreground="{Binding Foreground, RelativeSource={RelativeSource AncestorType=Button}}"
                                                Text="{DynamicResource Recurring.Run}" />
                                        </StackPanel>
                                    </ui:Button>

                                    <StackPanel>
                                        <TextBlock
                                            FontSize="{DynamicResource FontSizeMd}"
                                            FontWeight="SemiBold"
                                            Foreground="{DynamicResource AppTextPrimary}"
                                            Text="{DynamicResource Recurring.Tab.Pending}" />
                                        <TextBlock
                                            Margin="0,4,0,0"
                                            Foreground="{DynamicResource AppTextSecondary}"
                                            Text="{DynamicResource Recurring.Pending.Hint}" />
                                        <TextBlock
                                            Margin="0,6,0,0"
                                            FontSize="{DynamicResource FontSizeXs}"
                                            Foreground="{DynamicResource AppTextMuted}"
                                            Text="{Binding RunStatus}"
                                            Visibility="{Binding RunStatus, Converter={StaticResource StringToVisibilityConverter}}" />
                                    </StackPanel>
                        </DockPanel>

                        <Grid Grid.Row="1" Style="{StaticResource PageContentGrid}">
                            <StackPanel
                                Style="{StaticResource EmptyStatePanel}"
                                Visibility="{Binding HasNoPending, Converter={StaticResource BooleanToVisibilityConverter}}">
                                <ui:SymbolIcon Style="{StaticResource EmptyStateIcon}" Symbol="CheckmarkCircle24" />
                                <TextBlock Style="{StaticResource EmptyStateTitle}" Text="{DynamicResource Recurring.Pending.Empty}" />
                                <TextBlock Style="{StaticResource EmptyStateHint}" Text="{DynamicResource Recurring.Pending.Empty.Hint}" />
                            </StackPanel>

                            <ScrollViewer
                                HorizontalScrollBarVisibility="Disabled"
                                VerticalScrollBarVisibility="Auto"
                                Visibility="{Binding HasPending, Converter={StaticResource BooleanToVisibilityConverter}}">
                                <ItemsControl ItemsSource="{Binding Pending}">
                                <ItemsControl.ItemTemplate>
                                    <DataTemplate DataType="{x:Type vm:PendingRecurringRowViewModel}">
                                        <ui:Card Margin="0,0,0,8" Padding="14">
                                            <Grid>
                                                <Grid.ColumnDefinitions>
                                                    <ColumnDefinition Width="2*" />
                                                    <ColumnDefinition Width="Auto" />
                                                    <ColumnDefinition Width="Auto" />
                                                    <ColumnDefinition Width="Auto" />
                                                </Grid.ColumnDefinitions>

                                                <StackPanel Grid.Column="0" VerticalAlignment="Center">
                                                    <TextBlock
                                                        FontSize="{StaticResource FontSizeBase}"
                                                        FontWeight="SemiBold"
                                                        Foreground="{DynamicResource AppTextPrimary}"
                                                        Text="{Binding SourceDisplay}" />
                                                    <TextBlock
                                                        Margin="0,3,0,0"
                                                        FontSize="{StaticResource FontSizeXs}"
                                                        Foreground="{DynamicResource AppTextMuted}"
                                                        Text="{Binding Note}"
                                                        TextTrimming="CharacterEllipsis" />
                                                </StackPanel>

                                                <StackPanel Grid.Column="1" MinWidth="130" Margin="16,0,0,0" VerticalAlignment="Center">
                                                    <TextBlock
                                                        FontSize="{DynamicResource FontSizeXs}"
                                                        Foreground="{DynamicResource AppTextSecondary}"
                                                        Text="{DynamicResource Recurring.Field.StartDate}" />
                                                    <TextBlock
                                                        Margin="0,3,0,0"
                                                        FontFamily="{StaticResource FontBase}"
                                                        Foreground="{DynamicResource AppTextPrimary}"
                                                        Text="{Binding DueDateDisplay}"
                                                        Typography.NumeralAlignment="Tabular" />
                                                </StackPanel>

                                                <StackPanel Grid.Column="2" MinWidth="120" Margin="16,0,0,0" VerticalAlignment="Center">
                                                    <TextBlock
                                                        FontSize="{DynamicResource FontSizeXs}"
                                                        Foreground="{DynamicResource AppTextSecondary}"
                                                        Text="{DynamicResource Recurring.Field.Amount}" />
                                                    <TextBlock
                                                        Margin="0,3,0,0"
                                                        FontFamily="{StaticResource FontBase}"
                                                        FontWeight="SemiBold"
                                                        Foreground="{DynamicResource AppTextPrimary}"
                                                        Text="{Binding AmountDisplay}"
                                                        Typography.NumeralAlignment="Tabular" />
                                                </StackPanel>

                                                <StackPanel Grid.Column="3" Margin="16,0,0,0" VerticalAlignment="Center" Orientation="Horizontal">
                                                    <ui:Button
                                                        Margin="0,0,8,0"
                                                        Command="{Binding DataContext.ConfirmPendingCommand, ElementName=Root}"
                                                        CommandParameter="{Binding}"
                                                        Content="{DynamicResource Recurring.Pending.Confirm}"
                                                        Style="{StaticResource PagePrimaryButton}" />
                                                    <ui:Button
                                                        Command="{Binding DataContext.SkipPendingCommand, ElementName=Root}"
                                                        CommandParameter="{Binding}"
                                                        Content="{DynamicResource Recurring.Pending.Skip}"
                                                        Style="{StaticResource PageSecondaryButton}" />
                                                </StackPanel>
                                            </Grid>
                                        </ui:Card>
                                    </DataTemplate>
                                </ItemsControl.ItemTemplate>
                                </ItemsControl>
                            </ScrollViewer>
                        </Grid>
                    </Grid>
                </TabItem>
            </TabControl>

            <Border
                Grid.Row="0"
                Grid.RowSpan="3"
                Margin="-24"
                Panel.ZIndex="180"
                Background="#99000000"
                Visibility="{Binding IsAddFormOpen, Converter={StaticResource BooleanToVisibilityConverter}}" />

            <Border
                Grid.Row="0"
                Grid.RowSpan="3"
                Width="680"
                MaxWidth="760"
                MaxHeight="720"
                HorizontalAlignment="Center"
                VerticalAlignment="Center"
                Panel.ZIndex="181"
                Background="{DynamicResource AppSurface}"
                BorderBrush="{DynamicResource AppBorder}"
                BorderThickness="1"
                CornerRadius="{StaticResource RadiusLg}"
                SnapsToDevicePixels="True"
                Visibility="{Binding IsAddFormOpen, Converter={StaticResource BooleanToVisibilityConverter}}">
                <Border.Effect>
                    <DropShadowEffect
                        BlurRadius="32"
                        Direction="270"
                        Opacity="0.18"
                        ShadowDepth="10"
                        Color="#000000" />
                </Border.Effect>

                <Grid>
                    <Grid.RowDefinitions>
                        <RowDefinition Height="Auto" />
                        <RowDefinition Height="Auto" />
                        <RowDefinition Height="Auto" />
                        <RowDefinition Height="Auto" />
                    </Grid.RowDefinitions>

                    <StackPanel Margin="24,22,24,18">
                        <TextBlock
                            FontSize="{StaticResource FontSizeLg}"
                            FontWeight="SemiBold"
                            Foreground="{DynamicResource AppTextPrimary}"
                            Text="{DynamicResource Recurring.AddForm.Title}" />
                        <TextBlock
                            Margin="0,6,0,0"
                            Foreground="{DynamicResource AppTextSecondary}"
                            Text="{DynamicResource Recurring.AddForm.Hint}"
                            TextWrapping="Wrap" />
                    </StackPanel>

                    <Border
                        Grid.Row="1"
                        Margin="20,0,20,0"
                        Padding="16"
                        Background="{DynamicResource AppSurfaceAlt}"
                        BorderBrush="{DynamicResource AppBorder}"
                        BorderThickness="1"
                        CornerRadius="{StaticResource RadiusLg}">
                        <Grid>
                        <Grid.Resources>
                            <Style x:Key="FormFieldLabel" TargetType="TextBlock">
                                <Setter Property="Margin" Value="0,0,0,6" />
                                <Setter Property="FontSize" Value="{DynamicResource FontSizeXs}" />
                                <Setter Property="FontWeight" Value="SemiBold" />
                                <Setter Property="Foreground" Value="{DynamicResource AppTextSecondary}" />
                            </Style>
                            <Style BasedOn="{StaticResource {x:Type ui:TextBox}}" TargetType="{x:Type ui:TextBox}">
                                <Setter Property="MinHeight" Value="40" />
                            </Style>
                            <Style
                                x:Key="SheetComboBox"
                                BasedOn="{StaticResource FormComboBox}"
                                TargetType="ComboBox">
                                <Setter Property="MinHeight" Value="40" />
                            </Style>
                        </Grid.Resources>
                        <Grid.RowDefinitions>
                            <RowDefinition Height="Auto" />
                            <RowDefinition Height="Auto" />
                            <RowDefinition Height="Auto" />
                            <RowDefinition Height="Auto" />
                            <RowDefinition Height="Auto" />
                        </Grid.RowDefinitions>
                        <Grid.ColumnDefinitions>
                            <ColumnDefinition Width="*" />
                            <ColumnDefinition Width="16" />
                            <ColumnDefinition Width="*" />
                        </Grid.ColumnDefinitions>

                        <StackPanel
                            Grid.Row="0"
                            Grid.Column="0"
                            Grid.ColumnSpan="3"
                            Margin="0,0,0,14">
                            <TextBlock Style="{StaticResource FormFieldLabel}" Text="{DynamicResource Recurring.Field.Name}" />
                            <ui:TextBox
                                Text="{Binding AddName, UpdateSourceTrigger=PropertyChanged}"
                                ToolTip="{DynamicResource Recurring.NameHint}" />
                        </StackPanel>

                        <StackPanel
                            Grid.Row="1"
                            Grid.Column="0"
                            Margin="0,0,0,14">
                            <TextBlock Style="{StaticResource FormFieldLabel}" Text="{DynamicResource Recurring.Field.Type}" />
                            <ComboBox
                                ItemsSource="{Binding TradeTypeOptions}"
                                SelectedItem="{Binding AddTradeType}"
                                Style="{StaticResource SheetComboBox}">
                                <ComboBox.ItemTemplate>
                                    <DataTemplate>
                                        <TextBlock>
                                            <TextBlock.Style>
                                                <Style TargetType="TextBlock">
                                                    <Setter Property="Text" Value="{DynamicResource Portfolio.TradeType.Withdrawal}" />
                                                    <Style.Triggers>
                                                        <DataTrigger Binding="{Binding}" Value="Income">
                                                            <Setter Property="Text" Value="{DynamicResource Portfolio.TradeType.Income}" />
                                                        </DataTrigger>
                                                        <DataTrigger Binding="{Binding}" Value="Deposit">
                                                            <Setter Property="Text" Value="{DynamicResource Portfolio.TradeType.Deposit}" />
                                                        </DataTrigger>
                                                        <DataTrigger Binding="{Binding}" Value="CreditCardCharge">
                                                            <Setter Property="Text" Value="{DynamicResource Portfolio.TradeType.CreditCardCharge}" />
                                                        </DataTrigger>
                                                    </Style.Triggers>
                                                </Style>
                                            </TextBlock.Style>
                                        </TextBlock>
                                    </DataTemplate>
                                </ComboBox.ItemTemplate>
                            </ComboBox>
                        </StackPanel>

                        <StackPanel
                            Grid.Row="1"
                            Grid.Column="2"
                            Margin="0,0,0,14">
                            <TextBlock Style="{StaticResource FormFieldLabel}" Text="{DynamicResource Recurring.Field.Amount}" />
                            <ui:TextBox
                                behaviors:ThousandSeparatorBehavior.IsEnabled="True"
                                Text="{Binding AddAmount, UpdateSourceTrigger=PropertyChanged}"
                                ToolTip="{DynamicResource Recurring.AmountHint}" />
                        </StackPanel>

                        <StackPanel
                            Grid.Row="2"
                            Grid.Column="0"
                            Margin="0,0,0,14">
                            <TextBlock Style="{StaticResource FormFieldLabel}" Text="{DynamicResource Recurring.Field.StartDate}" />
                            <ui:CalendarDatePicker
                                MinHeight="40"
                                MinWidth="132"
                                HorizontalContentAlignment="Left"
                                Content="{Binding AddStartDate, Converter={StaticResource DateDisplayConverter}}"
                                Date="{Binding AddStartDate, Mode=TwoWay}" />
                        </StackPanel>

                        <StackPanel
                            Grid.Row="2"
                            Grid.Column="2"
                            Margin="0,0,0,14">
                            <TextBlock Style="{StaticResource FormFieldLabel}" Text="{DynamicResource Recurring.Field.Frequency}" />
                            <ComboBox
                                ItemsSource="{Binding FrequencyOptions}"
                                SelectedItem="{Binding AddFrequency}"
                                Style="{StaticResource SheetComboBox}">
                                <ComboBox.ItemTemplate>
                                    <DataTemplate>
                                        <TextBlock>
                                            <TextBlock.Style>
                                                <Style TargetType="TextBlock">
                                                    <Setter Property="Text" Value="{DynamicResource Recurring.Frequency.Monthly}" />
                                                    <Style.Triggers>
                                                        <DataTrigger Binding="{Binding}" Value="Daily">
                                                            <Setter Property="Text" Value="{DynamicResource Recurring.Frequency.Daily}" />
                                                        </DataTrigger>
                                                        <DataTrigger Binding="{Binding}" Value="Weekly">
                                                            <Setter Property="Text" Value="{DynamicResource Recurring.Frequency.Weekly}" />
                                                        </DataTrigger>
                                                        <DataTrigger Binding="{Binding}" Value="BiWeekly">
                                                            <Setter Property="Text" Value="{DynamicResource Recurring.Frequency.BiWeekly}" />
                                                        </DataTrigger>
                                                        <DataTrigger Binding="{Binding}" Value="Quarterly">
                                                            <Setter Property="Text" Value="{DynamicResource Recurring.Frequency.Quarterly}" />
                                                        </DataTrigger>
                                                        <DataTrigger Binding="{Binding}" Value="Yearly">
                                                            <Setter Property="Text" Value="{DynamicResource Recurring.Frequency.Yearly}" />
                                                        </DataTrigger>
                                                    </Style.Triggers>
                                                </Style>
                                            </TextBlock.Style>
                                        </TextBlock>
                                    </DataTemplate>
                                </ComboBox.ItemTemplate>
                            </ComboBox>
                        </StackPanel>

                        <StackPanel
                            Grid.Row="3"
                            Grid.Column="0"
                            Margin="0,0,0,14">
                            <TextBlock Style="{StaticResource FormFieldLabel}" Text="{DynamicResource Recurring.Field.Interval}" />
                            <ui:TextBox
                                Text="{Binding AddInterval, UpdateSourceTrigger=PropertyChanged}"
                                ToolTip="{DynamicResource Recurring.IntervalHint}" />
                        </StackPanel>

                        <StackPanel
                            Grid.Row="3"
                            Grid.Column="2"
                            Margin="0,0,0,14">
                            <TextBlock Style="{StaticResource FormFieldLabel}" Text="{DynamicResource Recurring.Field.Mode}" />
                            <ComboBox
                                ItemsSource="{Binding ModeOptions}"
                                SelectedItem="{Binding AddGenerationMode}"
                                Style="{StaticResource SheetComboBox}">
                                <ComboBox.ItemTemplate>
                                    <DataTemplate>
                                        <TextBlock>
                                            <TextBlock.Style>
                                                <Style TargetType="TextBlock">
                                                    <Setter Property="Text" Value="{DynamicResource Recurring.Mode.PendingConfirm}" />
                                                    <Style.Triggers>
                                                        <DataTrigger Binding="{Binding}" Value="AutoApply">
                                                            <Setter Property="Text" Value="{DynamicResource Recurring.Mode.AutoApply}" />
                                                        </DataTrigger>
                                                    </Style.Triggers>
                                                </Style>
                                            </TextBlock.Style>
                                        </TextBlock>
                                    </DataTemplate>
                                </ComboBox.ItemTemplate>
                            </ComboBox>
                        </StackPanel>

                        <StackPanel Grid.Row="4" Grid.Column="0" Grid.ColumnSpan="3">
                            <TextBlock Style="{StaticResource FormFieldLabel}" Text="{DynamicResource Recurring.Field.Note}" />
                            <ui:TextBox Text="{Binding AddNote, UpdateSourceTrigger=PropertyChanged}" />
                        </StackPanel>
                    </Grid>
                    </Border>

                    <TextBlock
                        Grid.Row="2"
                        Margin="24,10,24,0"
                        FontSize="{StaticResource FontSizeXs}"
                        Foreground="{DynamicResource AppDown}"
                        Text="{Binding AddError}"
                        Visibility="{Binding AddError, Converter={StaticResource StringToVisibilityConverter}}" />

                    <Border
                        Grid.Row="3"
                        Margin="0,18,0,0"
                        Padding="20,16"
                        BorderBrush="{DynamicResource AppBorder}"
                        BorderThickness="0,1,0,0">
                        <DockPanel LastChildFill="False">
                            <ui:Button
                                Margin="8,0,0,0"
                                DockPanel.Dock="Right"
                                Command="{Binding AddSubscriptionCommand}"
                                Content="{DynamicResource Recurring.Add}"
                                Style="{StaticResource PagePrimaryButton}" />
                            <ui:Button
                                DockPanel.Dock="Right"
                                Command="{Binding CloseAddFormCommand}"
                                Content="{DynamicResource Common.Cancel}"
                                Style="{StaticResource PageSecondaryButton}" />
                        </DockPanel>
                    </Border>
                </Grid>
            </Border>
        </Grid>
    </Grid>
</UserControl>
