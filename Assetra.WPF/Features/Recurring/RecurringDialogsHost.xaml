<UserControl
    x:Class="Assetra.WPF.Features.Recurring.RecurringDialogsHost"
    xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
    xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
    xmlns:behaviors="clr-namespace:Assetra.WPF.Infrastructure.Behaviors"
    xmlns:d="http://schemas.microsoft.com/expression/blend/2008"
    xmlns:ds="clr-namespace:Assetra.WPF.DesignSystem.Controls"
    xmlns:mc="http://schemas.openxmlformats.org/markup-compatibility/2006"
    xmlns:vm="clr-namespace:Assetra.WPF.Features.Recurring"
    d:DataContext="{d:DesignInstance Type={x:Type vm:RecurringViewModel}, IsDesignTimeCreatable=False}"
    mc:Ignorable="d">

    <!--
        外提到 MainWindow 的 Recurring dialog host — 包含新增訂閱表單與
        刪除確認 modal。
    -->
    <Grid Background="Transparent" IsHitTestVisible="True">

        <!--  訂閱排程 — 新增表單  -->
        <Grid
            Style="{StaticResource AppDialogOverlay}"
            Visibility="{Binding IsAddFormOpen, Converter={StaticResource BooleanToVisibilityConverter}}">
            <Border
                Width="680"
                MaxWidth="760"
                MaxHeight="720"
                HorizontalAlignment="Center"
                VerticalAlignment="Center"
                behaviors:EscapeKeyCommandBehavior.Command="{Binding CloseAddFormCommand}"
                SnapsToDevicePixels="True"
                Style="{StaticResource AppDialogShell}">
                <Grid>
                    <Grid.RowDefinitions>
                        <RowDefinition Height="Auto" />
                        <RowDefinition Height="Auto" />
                        <RowDefinition Height="Auto" />
                        <RowDefinition Height="Auto" />
                    </Grid.RowDefinitions>

                    <Grid Margin="0,0,0,16">
                        <StackPanel Margin="0,4,40,0">
                            <TextBlock
                                Style="{StaticResource AppDialogTitle}"
                                Text="{DynamicResource Recurring.AddForm.Title}" />
                            <TextBlock
                                Style="{StaticResource AppDialogSubtitle}"
                                Text="{DynamicResource Recurring.AddForm.Hint}"
                                TextWrapping="Wrap" />
                        </StackPanel>
                        <Button
                            Width="32"
                            Height="32"
                            Margin="0,-4,-4,0"
                            Padding="0"
                            HorizontalAlignment="Right"
                            VerticalAlignment="Top"
                            Command="{Binding CloseAddFormCommand}"
                            Style="{StaticResource AppIconButton}"
                            ToolTip="{DynamicResource Common.Close}">
                            <ds:AppIcon FontSize="13" Symbol="Dismiss24" />
                        </Button>
                    </Grid>

                    <Border
                        Grid.Row="1"
                        Style="{StaticResource FormSection}">
                        <Grid>
                            <Grid.Resources>
                                <Style x:Key="FormFieldLabel" TargetType="TextBlock">
                                    <Setter Property="Margin" Value="0,0,0,6" />
                                    <Setter Property="FontSize" Value="{DynamicResource Font.Size.Xs}" />
                                    <Setter Property="FontWeight" Value="SemiBold" />
                                    <Setter Property="Foreground" Value="{DynamicResource AppTextSecondary}" />
                                </Style>
                                <Style BasedOn="{StaticResource AppTextBox}" TargetType="{x:Type TextBox}">
                                    <Setter Property="MinHeight" Value="40" />
                                </Style>
                                <Style
                                    x:Key="SheetComboBox"
                                    BasedOn="{StaticResource AppComboBox}"
                                    TargetType="ComboBox">
                                    <Setter Property="MinHeight" Value="40" />
                                </Style>
                            </Grid.Resources>
                            <Grid.RowDefinitions>
                                <RowDefinition Height="Auto" />
                                <RowDefinition Height="Auto" />
                                <RowDefinition Height="Auto" />
                                <RowDefinition Height="Auto" />
                                <RowDefinition Height="Auto" />
                            </Grid.RowDefinitions>
                            <Grid.ColumnDefinitions>
                                <ColumnDefinition Width="*" />
                                <ColumnDefinition Width="16" />
                                <ColumnDefinition Width="*" />
                            </Grid.ColumnDefinitions>

                            <StackPanel
                                Grid.Row="0"
                                Grid.Column="0"
                                Grid.ColumnSpan="3"
                                Margin="0,0,0,14">
                                <TextBlock Style="{StaticResource FormFieldLabel}" Text="{DynamicResource Recurring.Field.Name}" />
                                <TextBox
                                    Text="{Binding AddName, UpdateSourceTrigger=PropertyChanged}"
                                    ToolTip="{DynamicResource Recurring.NameHint}" />
                            </StackPanel>

                            <StackPanel
                                Grid.Row="1"
                                Grid.Column="0"
                                Margin="0,0,0,14">
                                <TextBlock Style="{StaticResource FormFieldLabel}" Text="{DynamicResource Recurring.Field.Type}" />
                                <ComboBox
                                    ItemsSource="{Binding TradeTypeOptions}"
                                    SelectedItem="{Binding AddTradeType}"
                                    Style="{StaticResource SheetComboBox}">
                                    <ComboBox.ItemTemplate>
                                        <DataTemplate>
                                            <TextBlock>
                                                <TextBlock.Style>
                                                    <Style TargetType="TextBlock">
                                                        <Setter Property="Text" Value="{DynamicResource Portfolio.TradeType.Withdrawal}" />
                                                        <Style.Triggers>
                                                            <DataTrigger Binding="{Binding}" Value="Income">
                                                                <Setter Property="Text" Value="{DynamicResource Portfolio.TradeType.Income}" />
                                                            </DataTrigger>
                                                            <DataTrigger Binding="{Binding}" Value="Deposit">
                                                                <Setter Property="Text" Value="{DynamicResource Portfolio.TradeType.Deposit}" />
                                                            </DataTrigger>
                                                            <DataTrigger Binding="{Binding}" Value="CreditCardCharge">
                                                                <Setter Property="Text" Value="{DynamicResource Portfolio.TradeType.CreditCardCharge}" />
                                                            </DataTrigger>
                                                        </Style.Triggers>
                                                    </Style>
                                                </TextBlock.Style>
                                            </TextBlock>
                                        </DataTemplate>
                                    </ComboBox.ItemTemplate>
                                </ComboBox>
                            </StackPanel>

                            <StackPanel
                                Grid.Row="1"
                                Grid.Column="2"
                                Margin="0,0,0,14">
                                <TextBlock Style="{StaticResource FormFieldLabel}" Text="{DynamicResource Recurring.Field.Amount}" />
                                <TextBox
                                    behaviors:ThousandSeparatorBehavior.IsEnabled="True"
                                    Text="{Binding AddAmount, UpdateSourceTrigger=PropertyChanged}"
                                    ToolTip="{DynamicResource Recurring.AmountHint}" />
                            </StackPanel>

                            <StackPanel
                                Grid.Row="2"
                                Grid.Column="0"
                                Margin="0,0,0,14">
                                <TextBlock Style="{StaticResource FormFieldLabel}" Text="{DynamicResource Recurring.Field.StartDate}" />
                                <DatePicker
                                    MinHeight="40"
                                    MinWidth="132"
                                    HorizontalContentAlignment="Left"
                                    SelectedDate="{Binding AddStartDate, Mode=TwoWay}"
                                    Style="{StaticResource AppDatePicker}" />
                            </StackPanel>

                            <StackPanel
                                Grid.Row="2"
                                Grid.Column="2"
                                Margin="0,0,0,14">
                                <TextBlock Style="{StaticResource FormFieldLabel}" Text="{DynamicResource Recurring.Field.Frequency}" />
                                <ComboBox
                                    ItemsSource="{Binding FrequencyOptions}"
                                    SelectedItem="{Binding AddFrequency}"
                                    Style="{StaticResource SheetComboBox}">
                                    <ComboBox.ItemTemplate>
                                        <DataTemplate>
                                            <TextBlock>
                                                <TextBlock.Style>
                                                    <Style TargetType="TextBlock">
                                                        <Setter Property="Text" Value="{DynamicResource Recurring.Frequency.Monthly}" />
                                                        <Style.Triggers>
                                                            <DataTrigger Binding="{Binding}" Value="Daily">
                                                                <Setter Property="Text" Value="{DynamicResource Recurring.Frequency.Daily}" />
                                                            </DataTrigger>
                                                            <DataTrigger Binding="{Binding}" Value="Weekly">
                                                                <Setter Property="Text" Value="{DynamicResource Recurring.Frequency.Weekly}" />
                                                            </DataTrigger>
                                                            <DataTrigger Binding="{Binding}" Value="BiWeekly">
                                                                <Setter Property="Text" Value="{DynamicResource Recurring.Frequency.BiWeekly}" />
                                                            </DataTrigger>
                                                            <DataTrigger Binding="{Binding}" Value="Quarterly">
                                                                <Setter Property="Text" Value="{DynamicResource Recurring.Frequency.Quarterly}" />
                                                            </DataTrigger>
                                                            <DataTrigger Binding="{Binding}" Value="Yearly">
                                                                <Setter Property="Text" Value="{DynamicResource Recurring.Frequency.Yearly}" />
                                                            </DataTrigger>
                                                        </Style.Triggers>
                                                    </Style>
                                                </TextBlock.Style>
                                            </TextBlock>
                                        </DataTemplate>
                                    </ComboBox.ItemTemplate>
                                </ComboBox>
                            </StackPanel>

                            <StackPanel
                                Grid.Row="3"
                                Grid.Column="0"
                                Margin="0,0,0,14">
                                <TextBlock Style="{StaticResource FormFieldLabel}" Text="{DynamicResource Recurring.Field.Interval}" />
                                <TextBox
                                    Text="{Binding AddInterval, UpdateSourceTrigger=PropertyChanged}"
                                    ToolTip="{DynamicResource Recurring.IntervalHint}" />
                            </StackPanel>

                            <StackPanel
                                Grid.Row="3"
                                Grid.Column="2"
                                Margin="0,0,0,14">
                                <TextBlock Style="{StaticResource FormFieldLabel}" Text="{DynamicResource Recurring.Field.Mode}" />
                                <ComboBox
                                    ItemsSource="{Binding ModeOptions}"
                                    SelectedItem="{Binding AddGenerationMode}"
                                    Style="{StaticResource SheetComboBox}">
                                    <ComboBox.ItemTemplate>
                                        <DataTemplate>
                                            <TextBlock>
                                                <TextBlock.Style>
                                                    <Style TargetType="TextBlock">
                                                        <Setter Property="Text" Value="{DynamicResource Recurring.Mode.PendingConfirm}" />
                                                        <Style.Triggers>
                                                            <DataTrigger Binding="{Binding}" Value="AutoApply">
                                                                <Setter Property="Text" Value="{DynamicResource Recurring.Mode.AutoApply}" />
                                                            </DataTrigger>
                                                        </Style.Triggers>
                                                    </Style>
                                                </TextBlock.Style>
                                            </TextBlock>
                                        </DataTemplate>
                                    </ComboBox.ItemTemplate>
                                </ComboBox>
                            </StackPanel>

                            <StackPanel Grid.Row="4" Grid.Column="0" Grid.ColumnSpan="3">
                                <TextBlock Style="{StaticResource FormFieldLabel}" Text="{DynamicResource Recurring.Field.Note}" />
                                <TextBox Text="{Binding AddNote, UpdateSourceTrigger=PropertyChanged}" />
                            </StackPanel>
                        </Grid>
                    </Border>

                    <TextBlock
                        Grid.Row="2"
                        Margin="24,10,24,0"
                        FontSize="{StaticResource Font.Size.Xs}"
                        Foreground="{DynamicResource AppDown}"
                        Text="{Binding AddError}"
                        Visibility="{Binding AddError, Converter={StaticResource StringToVisibilityConverter}}" />

                    <Border
                        Grid.Row="3"
                        Margin="0,16,0,0"
                        Padding="0"
                        BorderBrush="{DynamicResource AppBorder}"
                        BorderThickness="0">
                        <StackPanel Style="{StaticResource AppDialogFooter}">
                            <Button
                                Margin="0,0,8,0"
                                Command="{Binding CloseAddFormCommand}"
                                Content="{DynamicResource Common.Cancel}"
                                Style="{StaticResource AppSecondaryButton}" />
                            <Button
                                Command="{Binding AddSubscriptionCommand}"
                                Content="{DynamicResource Recurring.Add}"
                                Style="{StaticResource AppPrimaryButton}" />
                        </StackPanel>
                    </Border>
                </Grid>
            </Border>
        </Grid>

        <!--  訂閱排程 — 刪除確認  -->
        <Grid
            Style="{StaticResource AppDialogOverlay}"
            Visibility="{Binding IsDeleteConfirmOpen, Converter={StaticResource BooleanToVisibilityConverter}}">
            <Border
                HorizontalAlignment="Center"
                VerticalAlignment="Center"
                behaviors:EscapeKeyCommandBehavior.Command="{Binding CancelDeleteCommand}"
                Style="{StaticResource AppDestructiveDialogShell}">
                <Grid>
                    <Grid.RowDefinitions>
                        <RowDefinition Height="Auto" />
                        <RowDefinition Height="Auto" />
                        <RowDefinition Height="Auto" />
                    </Grid.RowDefinitions>

                    <TextBlock Style="{StaticResource AppDialogTitle}" Text="{DynamicResource Common.DeleteConfirmTitle}" />
                    <TextBlock
                        Grid.Row="1"
                        Style="{StaticResource AppDialogSubtitle}">
                        <Run Text="{DynamicResource Common.DeleteConfirmPrefix}" />
                        <Run Text="{Binding DeleteTargetName}" />
                        <Run Text="{DynamicResource Common.DeleteConfirmSuffix}" />
                    </TextBlock>

                    <StackPanel Grid.Row="2" Style="{StaticResource AppDialogFooter}">
                        <Button
                            Margin="0,0,8,0"
                            Command="{Binding CancelDeleteCommand}"
                            Content="{DynamicResource Common.Cancel}"
                            Style="{StaticResource AppSecondaryButton}" />
                        <Button
                            Command="{Binding ConfirmDeleteCommand}"
                            Content="{DynamicResource Common.Delete}"
                            Style="{StaticResource AppDangerButton}" />
                    </StackPanel>
                </Grid>
            </Border>
        </Grid>
    </Grid>
</UserControl>
