<UserControl
    x:Class="Assetra.WPF.Features.Fire.FireView"
    xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
    xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
    xmlns:ui="http://schemas.lepo.co/wpfui/2022/xaml"
    xmlns:d="http://schemas.microsoft.com/expression/blend/2008"
    xmlns:mc="http://schemas.openxmlformats.org/markup-compatibility/2006"
    xmlns:vm="clr-namespace:Assetra.WPF.Features.Fire"
    d:DataContext="{d:DesignInstance Type={x:Type vm:FireViewModel}, IsDesignTimeCreatable=False}"
    d:DesignHeight="700"
    d:DesignWidth="1000"
    Background="{DynamicResource AppBackground}"
    mc:Ignorable="d">

    <UserControl.Resources>
    </UserControl.Resources>

    <Grid Margin="20">
        <Grid.RowDefinitions>
            <RowDefinition Height="Auto" />
            <RowDefinition Height="Auto" />
            <RowDefinition Height="Auto" />
            <RowDefinition Height="Auto" />
        </Grid.RowDefinitions>


        <ui:Card Grid.Row="1" Padding="16">
            <StackPanel>
                <UniformGrid Columns="5" Rows="1">
                    <StackPanel Margin="0,0,8,0">
                        <TextBlock Foreground="{DynamicResource AppTextSecondary}" Text="{DynamicResource Fire.Input.NetWorth}" />
                        <ui:TextBox Text="{Binding CurrentNetWorth, UpdateSourceTrigger=PropertyChanged}" />
                    </StackPanel>
                    <StackPanel Margin="0,0,8,0">
                        <TextBlock Foreground="{DynamicResource AppTextSecondary}" Text="{DynamicResource Fire.Input.AnnualExpenses}" />
                        <ui:TextBox Text="{Binding AnnualExpenses, UpdateSourceTrigger=PropertyChanged}" />
                    </StackPanel>
                    <StackPanel Margin="0,0,8,0">
                        <TextBlock Foreground="{DynamicResource AppTextSecondary}" Text="{DynamicResource Fire.Input.AnnualSavings}" />
                        <ui:TextBox Text="{Binding AnnualSavings, UpdateSourceTrigger=PropertyChanged}" />
                    </StackPanel>
                    <StackPanel Margin="0,0,8,0">
                        <TextBlock Foreground="{DynamicResource AppTextSecondary}" Text="{DynamicResource Fire.Input.Return}" />
                        <ui:TextBox Text="{Binding ExpectedAnnualReturn, UpdateSourceTrigger=PropertyChanged}" />
                    </StackPanel>
                    <StackPanel>
                        <TextBlock Foreground="{DynamicResource AppTextSecondary}" Text="{DynamicResource Fire.Input.WithdrawalRate}" />
                        <ui:TextBox Text="{Binding WithdrawalRate, UpdateSourceTrigger=PropertyChanged}" />
                    </StackPanel>
                </UniformGrid>
                <TextBlock Margin="0,8,0,0" Foreground="{DynamicResource AppDanger}" Text="{Binding ErrorMessage}"
                           Visibility="{Binding ErrorMessage, Converter={StaticResource NullToVisibilityConverter}}" />
                <TextBlock Margin="0,8,0,0" Foreground="{DynamicResource AppAccent}" Text="{Binding StatusMessage}"
                           Visibility="{Binding StatusMessage, Converter={StaticResource NullToVisibilityConverter}}" />
                <StackPanel Margin="0,12,0,0" HorizontalAlignment="Right" Orientation="Horizontal">
                    <ui:Button Margin="0,0,8,0"
                               Command="{Binding SaveToGoalsCommand}"
                               Content="{DynamicResource Fire.SaveToGoals}"
                               Appearance="Secondary" />
                    <ui:Button Command="{Binding CalculateCommand}" Content="{DynamicResource Fire.Calculate}" />
                </StackPanel>
            </StackPanel>
        </ui:Card>

        <ui:Card Grid.Row="2" Margin="0,16,0,0" Padding="16">
            <UniformGrid Columns="3">
                <StackPanel>
                    <TextBlock Foreground="{DynamicResource AppTextSecondary}" Text="{DynamicResource Fire.Result.FireNumber}" />
                    <TextBlock FontSize="{DynamicResource FontSizeLg}" FontWeight="SemiBold"
                               Foreground="{DynamicResource AppTextPrimary}"
                               Text="{Binding FireNumber, StringFormat=N0}" />
                </StackPanel>
                <StackPanel>
                    <TextBlock Foreground="{DynamicResource AppTextSecondary}" Text="{DynamicResource Fire.Result.YearsToFire}" />
                    <TextBlock FontSize="{DynamicResource FontSizeLg}" FontWeight="SemiBold"
                               Foreground="{DynamicResource AppTextPrimary}"
                               Text="{Binding YearsToFire}" />
                </StackPanel>
                <StackPanel>
                    <TextBlock Foreground="{DynamicResource AppTextSecondary}" Text="{DynamicResource Fire.Result.Projected}" />
                    <TextBlock FontSize="{DynamicResource FontSizeLg}" FontWeight="SemiBold"
                               Foreground="{DynamicResource AppTextPrimary}"
                               Text="{Binding ProjectedNetWorthAtFire, StringFormat=N0}" />
                </StackPanel>
            </UniformGrid>
        </ui:Card>

        <Border Grid.Row="3" Margin="0,16,0,0"
                Background="{DynamicResource AppSurface}"
                BorderBrush="{DynamicResource AppBorder}"
                BorderThickness="1" CornerRadius="8">
            <ui:DataGrid MaxHeight="500" AutoGenerateColumns="False" CanUserAddRows="False" CanUserDeleteRows="False"
                      GridLinesVisibility="Horizontal" HeadersVisibility="Column" IsReadOnly="True"
                      ItemsSource="{Binding WealthPath}" RowBackground="Transparent" SelectionMode="Single">
                <DataGrid.Columns>
                    <DataGridTextColumn Width="100" Binding="{Binding Year}" Header="{DynamicResource Fire.Path.Year}" />
                    <DataGridTextColumn Width="*" Binding="{Binding NetWorth, StringFormat=N0}" Header="{DynamicResource Fire.Path.NetWorth}" />
                </DataGrid.Columns>
            </ui:DataGrid>
        </Border>
    </Grid>
</UserControl>
