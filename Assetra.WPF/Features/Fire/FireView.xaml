<UserControl
    x:Class="Assetra.WPF.Features.Fire.FireView"
    xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
    xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
    xmlns:behaviors="clr-namespace:Assetra.WPF.Infrastructure.Behaviors"
    xmlns:d="http://schemas.microsoft.com/expression/blend/2008"
    xmlns:mc="http://schemas.openxmlformats.org/markup-compatibility/2006"
    xmlns:ui="http://schemas.lepo.co/wpfui/2022/xaml"
    xmlns:vm="clr-namespace:Assetra.WPF.Features.Fire"
    d:DataContext="{d:DesignInstance Type={x:Type vm:FireViewModel}, IsDesignTimeCreatable=False}"
    d:DesignHeight="800"
    d:DesignWidth="1200"
    Background="{DynamicResource AppBackground}"
    mc:Ignorable="d">

    <Grid Style="{StaticResource PageRootGrid}">
        <Grid.RowDefinitions>
            <RowDefinition Height="Auto" />
            <RowDefinition Height="Auto" />
            <RowDefinition Height="Auto" />
            <RowDefinition Height="*" />
        </Grid.RowDefinitions>

        <DockPanel Grid.Row="0" Style="{StaticResource PageHeaderDock}">
            <TextBlock
                Style="{StaticResource PageTitleText}"
                Text="{DynamicResource Fire.Title}" />
        </DockPanel>

        <ui:Card Grid.Row="1" Padding="20">
            <StackPanel>
                <UniformGrid Columns="5" Rows="1">
                    <StackPanel Margin="0,0,16,0">
                        <TextBlock
                            Margin="0,0,0,4"
                            Foreground="{DynamicResource AppTextSecondary}"
                            Text="{DynamicResource Fire.Input.NetWorth}" />
                        <ui:TextBox
                            behaviors:ThousandSeparatorBehavior.IsEnabled="True"
                            Text="{Binding CurrentNetWorth, UpdateSourceTrigger=PropertyChanged}" />
                    </StackPanel>
                    <StackPanel Margin="0,0,16,0">
                        <TextBlock
                            Margin="0,0,0,4"
                            Foreground="{DynamicResource AppTextSecondary}"
                            Text="{DynamicResource Fire.Input.AnnualExpenses}" />
                        <ui:TextBox
                            behaviors:ThousandSeparatorBehavior.IsEnabled="True"
                            Text="{Binding AnnualExpenses, UpdateSourceTrigger=PropertyChanged}" />
                    </StackPanel>
                    <StackPanel Margin="0,0,16,0">
                        <TextBlock
                            Margin="0,0,0,4"
                            Foreground="{DynamicResource AppTextSecondary}"
                            Text="{DynamicResource Fire.Input.AnnualSavings}" />
                        <ui:TextBox
                            behaviors:ThousandSeparatorBehavior.IsEnabled="True"
                            Text="{Binding AnnualSavings, UpdateSourceTrigger=PropertyChanged}" />
                    </StackPanel>
                    <StackPanel Margin="0,0,16,0">
                        <TextBlock
                            Margin="0,0,0,4"
                            Foreground="{DynamicResource AppTextSecondary}"
                            Text="{DynamicResource Fire.Input.Return}" />
                        <ui:TextBox Text="{Binding ExpectedAnnualReturn, UpdateSourceTrigger=PropertyChanged}" />
                    </StackPanel>
                    <StackPanel>
                        <TextBlock
                            Margin="0,0,0,4"
                            Foreground="{DynamicResource AppTextSecondary}"
                            Text="{DynamicResource Fire.Input.WithdrawalRate}" />
                        <ui:TextBox Text="{Binding WithdrawalRate, UpdateSourceTrigger=PropertyChanged}" />
                    </StackPanel>
                </UniformGrid>

                <StackPanel
                    Margin="0,16,0,0"
                    HorizontalAlignment="Right"
                    Orientation="Horizontal">
                    <ui:Button
                        Margin="0,0,8,0"
                        Command="{Binding SaveToGoalsCommand}"
                        Content="{DynamicResource Fire.SaveToGoals}"
                        Style="{StaticResource PageSecondaryButton}" />
                    <ui:Button Command="{Binding CalculateCommand}" Style="{StaticResource PagePrimaryButton}">
                        <TextBlock
                            Foreground="{Binding Foreground, RelativeSource={RelativeSource AncestorType=Button}}"
                            Text="{DynamicResource Fire.Calculate}" />
                    </ui:Button>
                </StackPanel>
            </StackPanel>
        </ui:Card>

        <TextBlock
            Grid.Row="2"
            Style="{StaticResource PageErrorText}"
            Text="{Binding ErrorMessage}"
            Visibility="{Binding ErrorMessage, Converter={StaticResource NullToVisibilityConverter}}" />

        <Grid
            Grid.Row="3"
            Margin="{StaticResource PageContentTopGapMargin}"
            Style="{StaticResource PageContentGrid}">
            <StackPanel
                Style="{StaticResource EmptyStatePanel}"
                Visibility="{Binding HasCalculatedResult, Converter={StaticResource InverseBooleanToVisibilityConverter}}">
                <ui:SymbolIcon Style="{StaticResource EmptyStateIcon}" Symbol="Calculator24" />
                <TextBlock Style="{StaticResource EmptyStateTitle}" Text="{DynamicResource Fire.Empty.Title}" />
                <TextBlock Style="{StaticResource EmptyStateHint}" Text="{DynamicResource Fire.Result.NotCalculated}" />
                <ui:Button
                    Command="{Binding CalculateCommand}"
                    Style="{StaticResource EmptyStateActionButton}">
                    <TextBlock
                        Foreground="{Binding Foreground, RelativeSource={RelativeSource AncestorType=Button}}"
                        Text="{DynamicResource Fire.Calculate}" />
                </ui:Button>
            </StackPanel>

            <ScrollViewer
                VerticalScrollBarVisibility="Auto"
                Visibility="{Binding HasCalculatedResult, Converter={StaticResource BooleanToVisibilityConverter}}">
                <StackPanel>
                    <UniformGrid Columns="3">
                    <ui:Card Margin="0,0,12,0" Padding="16">
                        <StackPanel>
                            <TextBlock
                                FontSize="{StaticResource FontSizeXs}"
                                Foreground="{DynamicResource AppTextSecondary}"
                                Text="{DynamicResource Fire.Result.FireNumber}" />
                            <TextBlock
                                Margin="0,8,0,0"
                                FontSize="{StaticResource FontSizeXl}"
                                FontWeight="SemiBold"
                                Foreground="{DynamicResource AppTextPrimary}"
                                Text="{Binding FireNumber, StringFormat=N0}"
                                Typography.NumeralAlignment="Tabular" />
                        </StackPanel>
                    </ui:Card>
                    <ui:Card Margin="0,0,12,0" Padding="16">
                        <StackPanel>
                            <TextBlock
                                FontSize="{StaticResource FontSizeXs}"
                                Foreground="{DynamicResource AppTextSecondary}"
                                Text="{DynamicResource Fire.Result.YearsToFire}" />
                            <TextBlock
                                Margin="0,8,0,0"
                                FontSize="{StaticResource FontSizeXl}"
                                FontWeight="SemiBold"
                                Foreground="{DynamicResource AppTextPrimary}"
                                Text="{Binding YearsToFire}" />
                        </StackPanel>
                    </ui:Card>
                    <ui:Card Padding="16">
                        <StackPanel>
                            <TextBlock
                                FontSize="{StaticResource FontSizeXs}"
                                Foreground="{DynamicResource AppTextSecondary}"
                                Text="{DynamicResource Fire.Result.Projected}" />
                            <TextBlock
                                Margin="0,8,0,0"
                                FontSize="{StaticResource FontSizeXl}"
                                FontWeight="SemiBold"
                                Foreground="{DynamicResource AppTextPrimary}"
                                Text="{Binding ProjectedNetWorthAtFire, StringFormat=N0}"
                                Typography.NumeralAlignment="Tabular" />
                        </StackPanel>
                    </ui:Card>
                </UniformGrid>

                    <StackPanel Margin="0,16,0,0">
                    <TextBlock
                        Margin="0,0,0,8"
                        FontSize="{StaticResource FontSizeMd}"
                        FontWeight="SemiBold"
                        Foreground="{DynamicResource AppTextPrimary}"
                        Text="{DynamicResource Fire.Path.Title}" />
                    <ItemsControl ItemsSource="{Binding WealthPath}">
                        <ItemsControl.ItemTemplate>
                            <DataTemplate DataType="{x:Type vm:FireWealthPoint}">
                                <Border
                                    Margin="0,0,0,8"
                                    Padding="14"
                                    Background="{DynamicResource AppSurface}"
                                    BorderBrush="{DynamicResource AppBorder}"
                                    BorderThickness="1"
                                    CornerRadius="{StaticResource RadiusMd}">
                                    <Grid>
                                        <Grid.ColumnDefinitions>
                                            <ColumnDefinition Width="*" />
                                            <ColumnDefinition Width="Auto" />
                                        </Grid.ColumnDefinitions>
                                        <StackPanel Orientation="Horizontal">
                                            <TextBlock
                                                FontSize="{StaticResource FontSizeXs}"
                                                Foreground="{DynamicResource AppTextSecondary}"
                                                Text="{DynamicResource Fire.Path.Year}" />
                                            <TextBlock
                                                Margin="8,0,0,0"
                                                FontWeight="SemiBold"
                                                Foreground="{DynamicResource AppTextPrimary}"
                                                Text="{Binding Year}" />
                                        </StackPanel>
                                        <TextBlock
                                            Grid.Column="1"
                                            FontWeight="SemiBold"
                                            Foreground="{DynamicResource AppTextPrimary}"
                                            Text="{Binding NetWorth, StringFormat=N0}"
                                            Typography.NumeralAlignment="Tabular" />
                                    </Grid>
                                </Border>
                            </DataTemplate>
                        </ItemsControl.ItemTemplate>
                    </ItemsControl>
                </StackPanel>
                </StackPanel>
            </ScrollViewer>
        </Grid>
    </Grid>
</UserControl>
