<UserControl
    x:Class="Assetra.WPF.Features.Alerts.AlertsView"
    xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
    xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
    xmlns:behaviors="clr-namespace:Assetra.WPF.Infrastructure.Behaviors"
    xmlns:d="http://schemas.microsoft.com/expression/blend/2008"
    xmlns:mc="http://schemas.openxmlformats.org/markup-compatibility/2006"
    xmlns:ds="clr-namespace:Assetra.WPF.DesignSystem.Controls"
    xmlns:vm="clr-namespace:Assetra.WPF.Features.Alerts"
    x:Name="Root"
    d:DataContext="{d:DesignInstance Type={x:Type vm:AlertsViewModel}, IsDesignTimeCreatable=False}"
    d:DesignHeight="800"
    d:DesignWidth="1200"
    Background="{DynamicResource AppBackground}"
    mc:Ignorable="d">

    <UserControl.Resources>
        <Style BasedOn="{StaticResource AppTextBox}" TargetType="TextBox" />
        <Style BasedOn="{StaticResource AppComboBox}" TargetType="ComboBox" />
    </UserControl.Resources>

    <Grid Style="{StaticResource PageRootGrid}">
        <Grid.RowDefinitions>
            <RowDefinition Height="Auto" />
            <RowDefinition Height="Auto" />
            <RowDefinition Height="Auto" />
            <RowDefinition Height="*" />
        </Grid.RowDefinitions>

        <DockPanel Grid.Row="0" Style="{StaticResource PageHeaderDock}">
            <Button
                DockPanel.Dock="Right"
                Command="{Binding OpenAddFormCommand}"
                Style="{StaticResource AppPrimaryButton}"
                Visibility="{Binding IsFormOpen, Converter={StaticResource InverseBooleanToVisibilityConverter}}">
                <StackPanel Orientation="Horizontal">
                    <ds:AppIcon
                        Margin="0,0,4,0"
                        VerticalAlignment="Center"
                        FontSize="{StaticResource Font.Size.Xs}"
                        Foreground="{Binding Foreground, RelativeSource={RelativeSource AncestorType=Button}}"
                        Symbol="Add24" />
                    <TextBlock
                        VerticalAlignment="Center"
                        Foreground="{Binding Foreground, RelativeSource={RelativeSource AncestorType=Button}}"
                        Text="{DynamicResource Alerts.AddAlert}" />
                </StackPanel>
            </Button>

            <TextBlock
                Style="{StaticResource PageTitleText}"
                Text="{DynamicResource Alerts.Title}" />
        </DockPanel>

        <UniformGrid Grid.Row="1" Columns="3" Style="{StaticResource PageMetricsGrid}">
            <Border Style="{StaticResource FormCard}" Margin="0,0,12,0" Padding="16">
                <StackPanel>
                    <StackPanel Orientation="Horizontal">
                        <ds:AppIcon
                            Margin="0,0,8,0"
                            Foreground="{DynamicResource AppTextMuted}"
                            Symbol="Alert24" />
                        <TextBlock
                            FontSize="{StaticResource Font.Size.Xs}"
                            Foreground="{DynamicResource AppTextSecondary}"
                            Text="{DynamicResource Alerts.Count}" />
                    </StackPanel>
                    <TextBlock
                        Margin="0,8,0,0"
                        FontSize="{StaticResource Font.Size.Xl}"
                        FontWeight="SemiBold"
                        Foreground="{DynamicResource AppTextPrimary}"
                        Text="{Binding AlertCount}" />
                </StackPanel>
            </Border>

            <Border Style="{StaticResource FormCard}" Margin="0,0,12,0" Padding="16">
                <StackPanel>
                    <TextBlock
                        FontSize="{StaticResource Font.Size.Xs}"
                        Foreground="{DynamicResource AppTextSecondary}"
                        Text="{DynamicResource Alerts.MonitoringCount}" />
                    <TextBlock
                        Margin="0,8,0,0"
                        FontSize="{StaticResource Font.Size.Xl}"
                        FontWeight="SemiBold"
                        Foreground="{DynamicResource AppTextPrimary}"
                        Text="{Binding MonitoringCount}" />
                </StackPanel>
            </Border>

            <Border Style="{StaticResource FormCard}" Padding="16">
                <StackPanel>
                    <TextBlock
                        FontSize="{StaticResource Font.Size.Xs}"
                        Foreground="{DynamicResource AppTextSecondary}"
                        Text="{DynamicResource Alerts.TriggeredCount}" />
                    <TextBlock
                        Margin="0,8,0,0"
                        FontSize="{StaticResource Font.Size.Xl}"
                        FontWeight="SemiBold"
                        Foreground="{DynamicResource AppTextPrimary}"
                        Text="{Binding TriggeredCount}" />
                </StackPanel>
            </Border>
        </UniformGrid>

        <Grid Grid.Row="3" Style="{StaticResource PageContentGrid}">
            <ScrollViewer
                VerticalScrollBarVisibility="Auto"
                Visibility="{Binding HasNoRules, Converter={StaticResource InverseBooleanToVisibilityConverter}}">
                <ItemsControl ItemsSource="{Binding Rules}">
                    <ItemsControl.ItemTemplate>
                        <DataTemplate DataType="{x:Type vm:AlertRowViewModel}">
                            <Border
                                Margin="0,0,0,12"
                                Padding="16"
                                Background="{DynamicResource AppSurface}"
                                BorderBrush="{DynamicResource AppBorder}"
                                BorderThickness="1"
                                CornerRadius="{StaticResource Radius.Md}">
                                <Grid>
                                    <Grid.RowDefinitions>
                                        <RowDefinition Height="Auto" />
                                        <RowDefinition Height="Auto" />
                                        <RowDefinition Height="Auto" />
                                    </Grid.RowDefinitions>
                                    <Grid.ColumnDefinitions>
                                        <ColumnDefinition Width="*" />
                                        <ColumnDefinition Width="Auto" />
                                    </Grid.ColumnDefinitions>

                                    <StackPanel Grid.Row="0" Grid.Column="0">
                                        <StackPanel Orientation="Horizontal">
                                            <TextBlock
                                                FontSize="{StaticResource Font.Size.Md}"
                                                FontWeight="SemiBold"
                                                Foreground="{DynamicResource AppTextPrimary}"
                                                Text="{Binding Symbol}" />
                                            <Border
                                                Margin="8,0,0,0"
                                                Padding="8,2"
                                                VerticalAlignment="Center"
                                                Background="{DynamicResource AppHover}"
                                                CornerRadius="{StaticResource Radius.Sm}">
                                                <TextBlock
                                                    FontSize="{StaticResource Font.Size.Xs}"
                                                    Foreground="{DynamicResource AppTextSecondary}"
                                                    Text="{Binding Exchange}" />
                                            </Border>
                                        </StackPanel>
                                        <TextBlock
                                            Margin="0,4,0,0"
                                            FontSize="{StaticResource Font.Size.Sm}"
                                            Foreground="{DynamicResource AppTextSecondary}"
                                            Text="{Binding Name}"
                                            TextTrimming="CharacterEllipsis" />
                                    </StackPanel>

                                    <StackPanel
                                        Grid.Row="0"
                                        Grid.Column="1"
                                        Orientation="Horizontal">
                                        <Button
                                            Width="32"
                                            Height="32"
                                            Margin="0,0,4,0"
                                            Padding="0"
                                            Command="{Binding BeginEditCommand}"
                                            ToolTip="{DynamicResource Alerts.Edit}">
                                            <Button.Style>
                                                <Style BasedOn="{StaticResource AppIconButton}" TargetType="{x:Type Button}">
                                                    <Setter Property="Visibility" Value="Visible" />
                                                    <Style.Triggers>
                                                        <DataTrigger Binding="{Binding IsEditing}" Value="True">
                                                            <Setter Property="Visibility" Value="Collapsed" />
                                                        </DataTrigger>
                                                    </Style.Triggers>
                                                </Style>
                                            </Button.Style>
                                            <ds:AppIcon FontSize="14" Symbol="Edit24" />
                                        </Button>
                                        <Button
                                            Width="32"
                                            Height="32"
                                            Margin="0,0,4,0"
                                            Padding="0"
                                            Command="{Binding DataContext.RequestRemoveRuleCommand, RelativeSource={RelativeSource AncestorType=ItemsControl}}"
                                            CommandParameter="{Binding}"
                                            ToolTip="{DynamicResource Alerts.Delete}">
                                            <Button.Style>
                                                <Style BasedOn="{StaticResource AppIconButton}" TargetType="{x:Type Button}">
                                                    <Setter Property="Visibility" Value="Visible" />
                                                    <Style.Triggers>
                                                        <DataTrigger Binding="{Binding IsEditing}" Value="True">
                                                            <Setter Property="Visibility" Value="Collapsed" />
                                                        </DataTrigger>
                                                    </Style.Triggers>
                                                </Style>
                                            </Button.Style>
                                            <ds:AppIcon
                                                FontSize="14"
                                                Foreground="{DynamicResource AppDanger}"
                                                Symbol="Delete24" />
                                        </Button>
                                        <Button
                                            Width="32"
                                            Height="32"
                                            Margin="0,0,4,0"
                                            Padding="0"
                                            Command="{Binding DataContext.SaveRuleCommand, RelativeSource={RelativeSource AncestorType=ItemsControl}}"
                                            CommandParameter="{Binding}"
                                            ToolTip="{DynamicResource Alerts.Save}">
                                            <Button.Style>
                                                <Style BasedOn="{StaticResource AppIconButton}" TargetType="{x:Type Button}">
                                                    <Setter Property="Visibility" Value="Collapsed" />
                                                    <Style.Triggers>
                                                        <DataTrigger Binding="{Binding IsEditing}" Value="True">
                                                            <Setter Property="Visibility" Value="Visible" />
                                                        </DataTrigger>
                                                    </Style.Triggers>
                                                </Style>
                                            </Button.Style>
                                            <ds:AppIcon
                                                FontSize="14"
                                                Foreground="{DynamicResource AppUp}"
                                                Symbol="Checkmark24" />
                                        </Button>
                                        <Button
                                            Width="32"
                                            Height="32"
                                            Padding="0"
                                            Command="{Binding CancelEditCommand}"
                                            ToolTip="{DynamicResource Alerts.Cancel}">
                                            <Button.Style>
                                                <Style BasedOn="{StaticResource AppIconButton}" TargetType="{x:Type Button}">
                                                    <Setter Property="Visibility" Value="Collapsed" />
                                                    <Style.Triggers>
                                                        <DataTrigger Binding="{Binding IsEditing}" Value="True">
                                                            <Setter Property="Visibility" Value="Visible" />
                                                        </DataTrigger>
                                                    </Style.Triggers>
                                                </Style>
                                            </Button.Style>
                                            <ds:AppIcon FontSize="14" Symbol="Dismiss24" />
                                        </Button>
                                    </StackPanel>

                                    <UniformGrid
                                        Grid.Row="1"
                                        Grid.Column="0"
                                        Grid.ColumnSpan="2"
                                        Margin="0,16,0,0"
                                        Columns="4">
                                        <StackPanel Margin="0,0,16,0">
                                            <TextBlock
                                                FontSize="{StaticResource Font.Size.Xs}"
                                                Foreground="{DynamicResource AppTextSecondary}"
                                                Text="{DynamicResource Alerts.Condition}" />
                                            <TextBlock
                                                Margin="0,4,0,0"
                                                FontWeight="SemiBold"
                                                Foreground="{DynamicResource AppTextPrimary}">
                                                <TextBlock.Style>
                                                    <Style TargetType="TextBlock">
                                                        <Setter Property="Text" Value="{DynamicResource Alerts.ConditionBelow}" />
                                                        <Setter Property="Visibility" Value="Visible" />
                                                        <Style.Triggers>
                                                            <DataTrigger Binding="{Binding Condition}" Value="Above">
                                                                <Setter Property="Text" Value="{DynamicResource Alerts.ConditionAbove}" />
                                                            </DataTrigger>
                                                            <DataTrigger Binding="{Binding IsEditing}" Value="True">
                                                                <Setter Property="Visibility" Value="Collapsed" />
                                                            </DataTrigger>
                                                        </Style.Triggers>
                                                    </Style>
                                                </TextBlock.Style>
                                            </TextBlock>
                                            <ComboBox
                                                MinWidth="140"
                                                Margin="0,4,0,0"
                                                ItemsSource="{Binding Conditions}"
                                                SelectedItem="{Binding EditCondition, UpdateSourceTrigger=PropertyChanged}">
                                                <ComboBox.ItemTemplate>
                                                    <DataTemplate>
                                                        <TextBlock>
                                                            <TextBlock.Style>
                                                                <Style TargetType="TextBlock">
                                                                    <Setter Property="Text" Value="{DynamicResource Alerts.ConditionBelow}" />
                                                                    <Style.Triggers>
                                                                        <DataTrigger Binding="{Binding}" Value="突破">
                                                                            <Setter Property="Text" Value="{DynamicResource Alerts.ConditionAbove}" />
                                                                        </DataTrigger>
                                                                    </Style.Triggers>
                                                                </Style>
                                                            </TextBlock.Style>
                                                        </TextBlock>
                                                    </DataTemplate>
                                                </ComboBox.ItemTemplate>
                                                <ComboBox.Style>
                                                    <Style BasedOn="{StaticResource AppComboBox}" TargetType="ComboBox">
                                                        <Setter Property="Visibility" Value="Collapsed" />
                                                        <Style.Triggers>
                                                            <DataTrigger Binding="{Binding IsEditing}" Value="True">
                                                                <Setter Property="Visibility" Value="Visible" />
                                                            </DataTrigger>
                                                        </Style.Triggers>
                                                    </Style>
                                                </ComboBox.Style>
                                            </ComboBox>
                                        </StackPanel>

                                        <StackPanel Margin="0,0,16,0">
                                            <TextBlock
                                                FontSize="{StaticResource Font.Size.Xs}"
                                                Foreground="{DynamicResource AppTextSecondary}"
                                                Text="{DynamicResource Alerts.TargetPrice}" />
                                            <TextBlock
                                                Margin="0,4,0,0"
                                                FontWeight="SemiBold"
                                                Foreground="{DynamicResource AppTextPrimary}"
                                                Text="{Binding TargetPrice, Converter={StaticResource CurrencyConverter}, ConverterParameter=price}"
                                                Typography.NumeralAlignment="Tabular">
                                                <TextBlock.Style>
                                                    <Style TargetType="TextBlock">
                                                        <Setter Property="Visibility" Value="Visible" />
                                                        <Style.Triggers>
                                                            <DataTrigger Binding="{Binding IsEditing}" Value="True">
                                                                <Setter Property="Visibility" Value="Collapsed" />
                                                            </DataTrigger>
                                                        </Style.Triggers>
                                                    </Style>
                                                </TextBlock.Style>
                                            </TextBlock>
                                            <TextBox
                                                MinWidth="140"
                                                Margin="0,4,0,0"
                                                behaviors:ThousandSeparatorBehavior.IsEnabled="True"
                                                Text="{Binding EditTargetPrice, UpdateSourceTrigger=PropertyChanged}">
                                                <TextBox.Style>
                                                    <Style BasedOn="{StaticResource {x:Type TextBox}}" TargetType="TextBox">
                                                        <Setter Property="Visibility" Value="Collapsed" />
                                                        <Style.Triggers>
                                                            <DataTrigger Binding="{Binding IsEditing}" Value="True">
                                                                <Setter Property="Visibility" Value="Visible" />
                                                            </DataTrigger>
                                                        </Style.Triggers>
                                                    </Style>
                                                </TextBox.Style>
                                            </TextBox>
                                        </StackPanel>

                                        <StackPanel Margin="0,0,16,0">
                                            <TextBlock
                                                FontSize="{StaticResource Font.Size.Xs}"
                                                Foreground="{DynamicResource AppTextSecondary}"
                                                Text="{DynamicResource Alerts.CurrentPrice}" />
                                            <TextBlock
                                                Margin="0,4,0,0"
                                                Foreground="{DynamicResource AppTextPrimary}"
                                                Typography.NumeralAlignment="Tabular">
                                                <TextBlock.Style>
                                                    <Style TargetType="TextBlock">
                                                        <Setter Property="Text" Value="{Binding CurrentPrice, Converter={StaticResource CurrencyConverter}, ConverterParameter=price}" />
                                                        <Style.Triggers>
                                                            <DataTrigger Binding="{Binding CurrentPrice}" Value="{x:Null}">
                                                                <Setter Property="Text" Value="-" />
                                                            </DataTrigger>
                                                        </Style.Triggers>
                                                    </Style>
                                                </TextBlock.Style>
                                            </TextBlock>
                                        </StackPanel>

                                        <StackPanel>
                                            <TextBlock
                                                FontSize="{StaticResource Font.Size.Xs}"
                                                Foreground="{DynamicResource AppTextSecondary}"
                                                Text="{DynamicResource Alerts.Status}" />
                                            <TextBlock
                                                Margin="0,4,0,0"
                                                Foreground="{DynamicResource AppTextSecondary}"
                                                Text="{DynamicResource Alerts.Monitoring}"
                                                Visibility="{Binding IsTriggered, Converter={StaticResource InverseBooleanToVisibilityConverter}}" />
                                            <TextBlock
                                                Margin="0,4,0,0"
                                                FontWeight="SemiBold"
                                                Foreground="{DynamicResource AppDown}"
                                                Visibility="{Binding IsTriggered, Converter={StaticResource BooleanToVisibilityConverter}}">
                                                <Run Text="{DynamicResource Alerts.Triggered}" />
                                                <Run Text=" " />
                                                <Run Text="{Binding TriggeredAt}" />
                                            </TextBlock>
                                        </StackPanel>
                                    </UniformGrid>

                                    <TextBlock
                                        Grid.Row="2"
                                        Grid.Column="0"
                                        Grid.ColumnSpan="2"
                                        Margin="0,10,0,0"
                                        FontSize="{StaticResource Font.Size.Xs}"
                                        Foreground="{DynamicResource AppDown}"
                                        Text="{Binding EditError}"
                                        Visibility="{Binding EditError, Converter={StaticResource StringToVisibilityConverter}}" />
                                </Grid>
                            </Border>
                        </DataTemplate>
                    </ItemsControl.ItemTemplate>
                </ItemsControl>
            </ScrollViewer>

            <StackPanel
                Style="{StaticResource EmptyStatePanel}"
                Visibility="{Binding HasNoRules, Converter={StaticResource BooleanToVisibilityConverter}}">
                <ds:AppIcon Style="{StaticResource EmptyStateIcon}" Symbol="Alert24" />
                <TextBlock Style="{StaticResource EmptyStateTitle}" Text="{DynamicResource Alerts.Empty}" />
                <TextBlock Style="{StaticResource EmptyStateHint}" Text="{DynamicResource Alerts.Empty.Hint}" />
                <Button
                    Command="{Binding OpenAddFormCommand}"
                    HorizontalAlignment="Center"
                    Style="{StaticResource AppEmptyStatePrimaryAction}"
                    Visibility="{Binding IsFormOpen, Converter={StaticResource InverseBooleanToVisibilityConverter}}">
                    <StackPanel Style="{StaticResource AppButtonContent}">
                        <ds:AppIcon
                            Style="{StaticResource AppButtonLeadingIcon}"
                            VerticalAlignment="Center"
                            FontSize="{StaticResource Font.Size.Xs}"
                            Foreground="{Binding Foreground, RelativeSource={RelativeSource AncestorType=Button}}"
                            Symbol="Add24" />
                        <TextBlock
                            VerticalAlignment="Center"
                            Foreground="{Binding Foreground, RelativeSource={RelativeSource AncestorType=Button}}"
                            Text="{DynamicResource Alerts.AddAlert}" />
                    </StackPanel>
                </Button>
            </StackPanel>
        </Grid>
        <!-- Dialogs (新增規則 + 刪除確認) 外提到 MainWindow.xaml → AlertsDialogsHost。VM property 仍是 AlertsViewModel.IsFormOpen / IsDeleteConfirmOpen。-->
    </Grid>
</UserControl>
