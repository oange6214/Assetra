<UserControl
    x:Class="Assetra.WPF.Features.Alerts.AlertsView"
    xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
    xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
    xmlns:ui="http://schemas.lepo.co/wpfui/2022/xaml"
    xmlns:d="http://schemas.microsoft.com/expression/blend/2008"
    xmlns:mc="http://schemas.openxmlformats.org/markup-compatibility/2006"
    xmlns:vm="clr-namespace:Assetra.WPF.Features.Alerts"
    x:Name="Root"
    d:DataContext="{d:DesignInstance Type={x:Type vm:AlertsViewModel}}"
    d:DesignHeight="776"
    d:DesignWidth="1100"
    Background="{DynamicResource AppBackground}"
    mc:Ignorable="d">

  <Grid>
    <Grid.RowDefinitions>
      <RowDefinition Height="*" />
      <!--  DataGrid  -->
      <RowDefinition Height="Auto" />
      <!--  Add form  -->
    </Grid.RowDefinitions>

    <!--  ── Rules List / DataGrid ──  -->
    <Grid Grid.Row="0">
      <ListBox
                Margin="12"
                Background="Transparent"
                BorderThickness="0"
                ItemContainerStyle="{x:Null}"
                ItemsSource="{Binding Rules}"
                ScrollViewer.HorizontalScrollBarVisibility="Disabled"
                ScrollViewer.VerticalScrollBarVisibility="Auto">
        <ListBox.Style>
          <Style TargetType="ListBox">
            <Setter Property="Visibility" Value="Collapsed" />
            <Style.Triggers>
              <DataTrigger Value="True">
                <DataTrigger.Binding>
                  <MultiBinding Converter="{StaticResource WidthScaleThresholdToBooleanConverter}" ConverterParameter="1080">
                    <Binding ElementName="Root" Path="ActualWidth" />
                    <Binding Path="DataContext.Settings.UiScale" RelativeSource="{RelativeSource AncestorType=Window}" />
                  </MultiBinding>
                </DataTrigger.Binding>
                <Setter Property="Visibility" Value="Visible" />
              </DataTrigger>
            </Style.Triggers>
          </Style>
        </ListBox.Style>
        <ListBox.ItemTemplate>
          <DataTemplate>
            <Border
                            Margin="0,0,0,10"
                            Padding="14,12"
                            Background="{DynamicResource AppSurface}"
                            BorderBrush="{DynamicResource AppBorder}"
                            BorderThickness="1"
                            CornerRadius="{StaticResource RadiusMd}">
              <StackPanel>
                <DockPanel LastChildFill="False">
                  <StackPanel DockPanel.Dock="Left">
                    <WrapPanel VerticalAlignment="Center">
                      <TextBlock
                                                Margin="0,0,8,0"
                                                VerticalAlignment="Center"
                                                FontFamily="{StaticResource FontBase}" Typography.NumeralAlignment="Tabular"
                                                FontSize="{StaticResource FontSizeBase}"
                                                FontWeight="SemiBold"
                                                Foreground="{DynamicResource AppTextPrimary}"
                                                Text="{Binding Symbol}" />
                      <TextBlock
                                                VerticalAlignment="Center"
                                                FontSize="{StaticResource FontSizeSm}"
                                                Foreground="{DynamicResource AppTextSecondary}"
                                                Text="{Binding Name}" />
                    </WrapPanel>
                    <TextBlock
                                            Margin="0,4,0,0"
                                            FontSize="{StaticResource FontSizeXs}"
                                            Foreground="{DynamicResource AppTextMuted}">
                      <TextBlock.Style>
                        <Style TargetType="TextBlock">
                          <Setter Property="Text" Value="{Binding CurrentPrice, StringFormat={}{0}}" />
                          <Style.Triggers>
                            <DataTrigger Binding="{Binding CurrentPrice}" Value="{x:Null}">
                              <Setter Property="Text" Value="-" />
                            </DataTrigger>
                          </Style.Triggers>
                        </Style>
                      </TextBlock.Style>
                    </TextBlock>
                  </StackPanel>

                  <StackPanel DockPanel.Dock="Right" Orientation="Horizontal">
                    <ui:Button
                                            Width="28"
                                            Height="28"
                                            Margin="0,0,4,0"
                                            Command="{Binding BeginEditCommand}"
                                            ToolTip="{DynamicResource Alerts.Edit}">
                      <ui:Button.Style>
                        <Style BasedOn="{StaticResource {x:Type ui:Button}}" TargetType="{x:Type ui:Button}">
                          <Setter Property="Appearance" Value="Transparent" />
                          <Setter Property="Visibility" Value="Visible" />
                          <Style.Triggers>
                            <DataTrigger Binding="{Binding IsEditing}" Value="True">
                              <Setter Property="Visibility" Value="Collapsed" />
                            </DataTrigger>
                          </Style.Triggers>
                        </Style>
                      </ui:Button.Style>
                      <ui:SymbolIcon Symbol="Edit24" FontSize="{StaticResource FontSizeXs}" Foreground="{DynamicResource AppTextPrimary}" />
                    </ui:Button>

                    <ui:Button
                                            Width="28"
                                            Height="28"
                                            Margin="0,0,4,0"
                                            Command="{Binding DataContext.RemoveRuleCommand, RelativeSource={RelativeSource AncestorType=ListBox}}"
                                            CommandParameter="{Binding Id}"
                                            ToolTip="{DynamicResource Alerts.Delete}">
                      <ui:Button.Style>
                        <Style BasedOn="{StaticResource {x:Type ui:Button}}" TargetType="{x:Type ui:Button}">
                          <Setter Property="Appearance" Value="Transparent" />
                          <Setter Property="Visibility" Value="Visible" />
                          <Style.Triggers>
                            <DataTrigger Binding="{Binding IsEditing}" Value="True">
                              <Setter Property="Visibility" Value="Collapsed" />
                            </DataTrigger>
                          </Style.Triggers>
                        </Style>
                      </ui:Button.Style>
                      <ui:SymbolIcon Symbol="Delete24" FontSize="{StaticResource FontSizeXs}" Foreground="{DynamicResource AppDanger}" />
                    </ui:Button>

                    <ui:Button
                                            Width="28"
                                            Height="28"
                                            Margin="0,0,4,0"
                                            Command="{Binding DataContext.SaveRuleCommand, RelativeSource={RelativeSource AncestorType=ListBox}}"
                                            CommandParameter="{Binding}"
                                            ToolTip="{DynamicResource Alerts.Save}">
                      <ui:Button.Style>
                        <Style BasedOn="{StaticResource {x:Type ui:Button}}" TargetType="{x:Type ui:Button}">
                          <Setter Property="Appearance" Value="Transparent" />
                          <Setter Property="Visibility" Value="Collapsed" />
                          <Style.Triggers>
                            <DataTrigger Binding="{Binding IsEditing}" Value="True">
                              <Setter Property="Visibility" Value="Visible" />
                            </DataTrigger>
                          </Style.Triggers>
                        </Style>
                      </ui:Button.Style>
                      <ui:SymbolIcon Symbol="Checkmark24" FontSize="{StaticResource FontSizeSm}" Foreground="{DynamicResource AppUp}" />
                    </ui:Button>

                    <ui:Button
                                            Width="28"
                                            Height="28"
                                            Command="{Binding CancelEditCommand}"
                                            ToolTip="{DynamicResource Alerts.Cancel}">
                      <ui:Button.Style>
                        <Style BasedOn="{StaticResource {x:Type ui:Button}}" TargetType="{x:Type ui:Button}">
                          <Setter Property="Appearance" Value="Transparent" />
                          <Setter Property="Visibility" Value="Collapsed" />
                          <Style.Triggers>
                            <DataTrigger Binding="{Binding IsEditing}" Value="True">
                              <Setter Property="Visibility" Value="Visible" />
                            </DataTrigger>
                          </Style.Triggers>
                        </Style>
                      </ui:Button.Style>
                      <ui:SymbolIcon Symbol="Dismiss24" FontSize="{StaticResource FontSizeXs}" Foreground="{DynamicResource AppTextSecondary}" />
                    </ui:Button>
                  </StackPanel>
                </DockPanel>

                <WrapPanel Margin="0,12,0,0">
                  <Border
                                        Margin="0,0,10,10"
                                        Padding="10,8"
                                        Background="{DynamicResource AppBackground}"
                                        BorderBrush="{DynamicResource AppBorder}"
                                        BorderThickness="1"
                                        CornerRadius="{StaticResource RadiusSm}">
                    <StackPanel>
                      <TextBlock
                                                FontSize="{StaticResource FontSizeXs}"
                                                Foreground="{DynamicResource AppTextMuted}"
                                                Text="{DynamicResource Alerts.Condition}" />
                      <TextBlock
                                                Margin="0,4,0,0"
                                                FontSize="{StaticResource FontSizeSm}"
                                                FontWeight="SemiBold">
                        <TextBlock.Style>
                          <Style TargetType="TextBlock">
                            <Setter Property="Text" Value="{DynamicResource Alerts.ConditionBelow}" />
                            <Setter Property="Visibility" Value="Visible" />
                            <Style.Triggers>
                              <DataTrigger Binding="{Binding Condition}" Value="Above">
                                <Setter Property="Text" Value="{DynamicResource Alerts.ConditionAbove}" />
                              </DataTrigger>
                              <DataTrigger Binding="{Binding IsEditing}" Value="True">
                                <Setter Property="Visibility" Value="Collapsed" />
                              </DataTrigger>
                            </Style.Triggers>
                          </Style>
                        </TextBlock.Style>
                      </TextBlock>
                      <ComboBox
                                                MinWidth="120"
                                                Margin="0,4,0,0"
                                                ItemsSource="{Binding Conditions}"
                                                SelectedItem="{Binding EditCondition, UpdateSourceTrigger=PropertyChanged}">
                        <ComboBox.ItemTemplate>
                          <DataTemplate>
                            <TextBlock>
                              <TextBlock.Style>
                                <Style TargetType="TextBlock">
                                  <Setter Property="Text" Value="{DynamicResource Alerts.ConditionBelow}" />
                                  <Style.Triggers>
                                    <DataTrigger Binding="{Binding}" Value="突破">
                                      <Setter Property="Text" Value="{DynamicResource Alerts.ConditionAbove}" />
                                    </DataTrigger>
                                  </Style.Triggers>
                                </Style>
                              </TextBlock.Style>
                            </TextBlock>
                          </DataTemplate>
                        </ComboBox.ItemTemplate>
                        <ComboBox.Style>
                          <Style BasedOn="{StaticResource FormComboBox}" TargetType="ComboBox">
                            <Setter Property="Visibility" Value="Collapsed" />
                            <Style.Triggers>
                              <DataTrigger Binding="{Binding IsEditing}" Value="True">
                                <Setter Property="Visibility" Value="Visible" />
                              </DataTrigger>
                            </Style.Triggers>
                          </Style>
                        </ComboBox.Style>
                      </ComboBox>
                    </StackPanel>
                  </Border>

                  <Border
                                        Margin="0,0,10,10"
                                        Padding="10,8"
                                        Background="{DynamicResource AppBackground}"
                                        BorderBrush="{DynamicResource AppBorder}"
                                        BorderThickness="1"
                                        CornerRadius="{StaticResource RadiusSm}">
                    <StackPanel>
                      <TextBlock
                                                FontSize="{StaticResource FontSizeXs}"
                                                Foreground="{DynamicResource AppTextMuted}"
                                                Text="{DynamicResource Alerts.TargetPrice}" />
                      <TextBlock
                                                Margin="0,4,0,0"
                                                FontFamily="{StaticResource FontBase}" Typography.NumeralAlignment="Tabular"
                                                FontSize="{StaticResource FontSizeBase}"
                                                FontWeight="SemiBold"
                                                Text="{Binding TargetPrice, Converter={StaticResource CurrencyConverter}, ConverterParameter=price}">
                        <TextBlock.Style>
                          <Style TargetType="TextBlock">
                            <Setter Property="Visibility" Value="Visible" />
                            <Style.Triggers>
                              <DataTrigger Binding="{Binding IsEditing}" Value="True">
                                <Setter Property="Visibility" Value="Collapsed" />
                              </DataTrigger>
                            </Style.Triggers>
                          </Style>
                        </TextBlock.Style>
                      </TextBlock>
                      <ui:TextBox
                                                MinWidth="120"
                                                Margin="0,4,0,0"
                                                Padding="4,0"
                                                VerticalContentAlignment="Center"
                                                Background="{DynamicResource AppBackground}"
                                                BorderBrush="{DynamicResource AppAccent}"
                                                BorderThickness="1"
                                                FocusVisualStyle="{x:Null}"
                                                FontFamily="{StaticResource FontBase}" Typography.NumeralAlignment="Tabular"
                                                FontSize="{StaticResource FontSizeSm}"
                                                Foreground="{DynamicResource AppTextPrimary}"
                                                Text="{Binding EditTargetPrice, UpdateSourceTrigger=PropertyChanged}">
                        <TextBox.Style>
                          <Style BasedOn="{StaticResource {x:Type TextBox}}" TargetType="TextBox">
                            <Setter Property="Visibility" Value="Collapsed" />
                            <Style.Triggers>
                              <DataTrigger Binding="{Binding IsEditing}" Value="True">
                                <Setter Property="Visibility" Value="Visible" />
                              </DataTrigger>
                            </Style.Triggers>
                          </Style>
                        </TextBox.Style>
                      </ui:TextBox>
                      <TextBlock
                                                Margin="0,6,0,0"
                                                FontSize="{StaticResource FontSizeXs}"
                                                Foreground="{DynamicResource AppDown}"
                                                Text="{Binding EditError}"
                                                Visibility="{Binding EditError, Converter={StaticResource StringToVisibilityConverter}}" />
                    </StackPanel>
                  </Border>

                  <Border
                                        Margin="0,0,10,10"
                                        Padding="10,8"
                                        Background="{DynamicResource AppBackground}"
                                        BorderBrush="{DynamicResource AppBorder}"
                                        BorderThickness="1"
                                        CornerRadius="{StaticResource RadiusSm}">
                    <StackPanel>
                      <TextBlock
                                                FontSize="{StaticResource FontSizeXs}"
                                                Foreground="{DynamicResource AppTextMuted}"
                                                Text="{DynamicResource Alerts.CurrentPrice}" />
                      <TextBlock
                                                Margin="0,4,0,0"
                                                FontFamily="{StaticResource FontBase}" Typography.NumeralAlignment="Tabular"
                                                FontSize="{StaticResource FontSizeBase}"
                                                FontWeight="SemiBold">
                        <TextBlock.Style>
                          <Style TargetType="TextBlock">
                            <Setter Property="Text" Value="{Binding CurrentPrice, Converter={StaticResource CurrencyConverter}, ConverterParameter=price}" />
                            <Style.Triggers>
                              <DataTrigger Binding="{Binding CurrentPrice}" Value="{x:Null}">
                                <Setter Property="Text" Value="-" />
                              </DataTrigger>
                            </Style.Triggers>
                          </Style>
                        </TextBlock.Style>
                      </TextBlock>
                    </StackPanel>
                  </Border>

                  <Border
                                        Margin="0,0,0,10"
                                        Padding="10,8"
                                        Background="{DynamicResource AppBackground}"
                                        BorderBrush="{DynamicResource AppBorder}"
                                        BorderThickness="1"
                                        CornerRadius="{StaticResource RadiusSm}">
                    <StackPanel>
                      <TextBlock
                                                FontSize="{StaticResource FontSizeXs}"
                                                Foreground="{DynamicResource AppTextMuted}"
                                                Text="{DynamicResource Alerts.Status}" />
                      <TextBlock
                                                Margin="0,4,0,0"
                                                FontSize="{StaticResource FontSizeSm}"
                                                Foreground="{DynamicResource AppTextSecondary}"
                                                Text="{DynamicResource Alerts.Monitoring}">
                        <TextBlock.Style>
                          <Style TargetType="TextBlock">
                            <Setter Property="Visibility" Value="Visible" />
                            <Style.Triggers>
                              <DataTrigger Binding="{Binding IsEditing}" Value="True">
                                <Setter Property="Visibility" Value="Collapsed" />
                              </DataTrigger>
                              <DataTrigger Binding="{Binding IsTriggered}" Value="True">
                                <Setter Property="Foreground" Value="{DynamicResource AppDown}" />
                                <Setter Property="FontWeight" Value="SemiBold" />
                                <Setter Property="Text" Value="{Binding TriggeredAt, StringFormat={}{0}}" />
                              </DataTrigger>
                            </Style.Triggers>
                          </Style>
                        </TextBlock.Style>
                      </TextBlock>
                    </StackPanel>
                  </Border>
                </WrapPanel>
              </StackPanel>
            </Border>
          </DataTemplate>
        </ListBox.ItemTemplate>
      </ListBox>

      <ui:DataGrid
                x:Name="AlertsGrid"
                AutoGenerateColumns="False"
                Background="{DynamicResource AppBackground}"
                BorderThickness="0"
                CanUserAddRows="False"
                CanUserDeleteRows="False"
                CanUserReorderColumns="False"
                CanUserResizeColumns="False"
                CanUserSortColumns="True"
                ColumnHeaderHeight="{StaticResource DataGridHeaderHeight}"
                EnableRowVirtualization="True"
                FontFamily="{StaticResource FontBase}"
                FontSize="{StaticResource FontSizeSm}"
                Foreground="{DynamicResource AppTextPrimary}"
                GridLinesVisibility="None"
                HeadersVisibility="Column"
                HorizontalScrollBarVisibility="Auto"
                IsReadOnly="True"
                ItemsSource="{Binding Rules}"
                PreviewKeyDown="OnGridPreviewKeyDown"
                PreviewMouseDown="OnGridPreviewMouseDown"
                RowHeight="{StaticResource DataGridRowHeight}"
                SelectionMode="Single"
                VirtualizingPanel.IsVirtualizing="True"
                VirtualizingPanel.VirtualizationMode="Recycling">
        <DataGrid.Style>
          <Style TargetType="DataGrid">
            <Setter Property="Visibility" Value="Visible" />
            <Style.Triggers>
              <DataTrigger Value="True">
                <DataTrigger.Binding>
                  <MultiBinding Converter="{StaticResource WidthScaleThresholdToBooleanConverter}" ConverterParameter="1080">
                    <Binding ElementName="Root" Path="ActualWidth" />
                    <Binding Path="DataContext.Settings.UiScale" RelativeSource="{RelativeSource AncestorType=Window}" />
                  </MultiBinding>
                </DataTrigger.Binding>
                <Setter Property="Visibility" Value="Collapsed" />
              </DataTrigger>
            </Style.Triggers>
          </Style>
        </DataGrid.Style>

        <DataGrid.ColumnHeaderStyle>
          <Style BasedOn="{StaticResource AppDataGridColHeader}" TargetType="DataGridColumnHeader" />
        </DataGrid.ColumnHeaderStyle>
        <DataGrid.CellStyle>
          <Style BasedOn="{StaticResource AppDataGridCell}" TargetType="DataGridCell" />
        </DataGrid.CellStyle>
        <DataGrid.RowStyle>
          <Style BasedOn="{StaticResource AppDataGridRowSelectable}" TargetType="DataGridRow" />
        </DataGrid.RowStyle>

        <DataGrid.Columns>
          <!--  代號  -->
          <DataGridTemplateColumn Width="100" SortMemberPath="Symbol">
            <DataGridTemplateColumn.Header>
              <TextBlock Text="{DynamicResource Alerts.Symbol}" />
            </DataGridTemplateColumn.Header>
            <DataGridTemplateColumn.CellTemplate>
              <DataTemplate>
                <TextBlock
                                    Margin="8,0,0,0"
                                    VerticalAlignment="Center"
                                    FontFamily="{StaticResource FontBase}" Typography.NumeralAlignment="Tabular"
                                    FontSize="{StaticResource FontSizeSm}"
                                    FontWeight="SemiBold"
                                    Foreground="{DynamicResource AppTextPrimary}"
                                    Text="{Binding Symbol}" />
              </DataTemplate>
            </DataGridTemplateColumn.CellTemplate>
          </DataGridTemplateColumn>

          <!--  名稱  -->
          <DataGridTemplateColumn
                        Width="*"
                        MinWidth="100"
                        SortMemberPath="Name">
            <DataGridTemplateColumn.Header>
              <TextBlock Text="{DynamicResource Alerts.Name}" />
            </DataGridTemplateColumn.Header>
            <DataGridTemplateColumn.CellTemplate>
              <DataTemplate>
                <TextBlock
                                    Margin="8,0,4,0"
                                    VerticalAlignment="Center"
                                    FontFamily="{StaticResource FontBase}"
                                    FontSize="{StaticResource FontSizeBase}"
                                    Foreground="{DynamicResource AppTextSecondary}"
                                    Text="{Binding Name}"
                                    TextTrimming="CharacterEllipsis" />
              </DataTemplate>
            </DataGridTemplateColumn.CellTemplate>
          </DataGridTemplateColumn>

          <!--  條件  -->
          <DataGridTemplateColumn Width="100">
            <DataGridTemplateColumn.Header>
              <TextBlock Text="{DynamicResource Alerts.Condition}" />
            </DataGridTemplateColumn.Header>
            <DataGridTemplateColumn.CellTemplate>
              <DataTemplate>
                <Grid Margin="4,0">
                  <!--  View  -->
                  <TextBlock
                                        VerticalAlignment="Center"
                                        FontFamily="{StaticResource FontBase}"
                                        FontSize="{StaticResource FontSizeSm}">
                    <TextBlock.Style>
                      <Style TargetType="TextBlock">
                        <Setter Property="Visibility" Value="Visible" />
                        <Setter Property="Text" Value="{DynamicResource Alerts.ConditionBelow}" />
                        <Style.Triggers>
                          <DataTrigger Binding="{Binding Condition}" Value="Above">
                            <Setter Property="Text" Value="{DynamicResource Alerts.ConditionAbove}" />
                          </DataTrigger>
                          <DataTrigger Binding="{Binding IsEditing}" Value="True">
                            <Setter Property="Visibility" Value="Collapsed" />
                          </DataTrigger>
                        </Style.Triggers>
                      </Style>
                    </TextBlock.Style>
                  </TextBlock>
                  <!--  Edit  -->
                  <ComboBox
                                        Height="28"
                                        Margin="0,4"
                                        ItemsSource="{Binding Conditions}"
                                        SelectedItem="{Binding EditCondition, UpdateSourceTrigger=PropertyChanged}">
                    <ComboBox.ItemTemplate>
                      <DataTemplate>
                        <TextBlock>
                          <TextBlock.Style>
                            <Style TargetType="TextBlock">
                              <Setter Property="Text" Value="{DynamicResource Alerts.ConditionBelow}" />
                              <Style.Triggers>
                                <DataTrigger Binding="{Binding}" Value="突破">
                                  <Setter Property="Text" Value="{DynamicResource Alerts.ConditionAbove}" />
                                </DataTrigger>
                              </Style.Triggers>
                            </Style>
                          </TextBlock.Style>
                        </TextBlock>
                      </DataTemplate>
                    </ComboBox.ItemTemplate>
                    <ComboBox.Style>
                      <Style BasedOn="{StaticResource FormComboBox}" TargetType="ComboBox">
                        <Setter Property="Visibility" Value="Collapsed" />
                        <Style.Triggers>
                          <DataTrigger Binding="{Binding IsEditing}" Value="True">
                            <Setter Property="Visibility" Value="Visible" />
                          </DataTrigger>
                        </Style.Triggers>
                      </Style>
                    </ComboBox.Style>
                  </ComboBox>
                </Grid>
              </DataTemplate>
            </DataGridTemplateColumn.CellTemplate>
          </DataGridTemplateColumn>

          <!--  目標價  -->
          <DataGridTemplateColumn Width="110" SortMemberPath="TargetPrice">
            <DataGridTemplateColumn.HeaderStyle>
              <Style BasedOn="{StaticResource AppDataGridColHeader}" TargetType="DataGridColumnHeader">
                <Setter Property="HorizontalContentAlignment" Value="Right" />
              </Style>
            </DataGridTemplateColumn.HeaderStyle>
            <DataGridTemplateColumn.Header>
              <TextBlock Text="{DynamicResource Alerts.TargetPrice}" />
            </DataGridTemplateColumn.Header>
            <DataGridTemplateColumn.CellTemplate>
              <DataTemplate>
                <Grid Margin="4,0">
                  <!--  View  -->
                  <TextBlock
                                        HorizontalAlignment="Right"
                                        VerticalAlignment="Center"
                                        FontFamily="{StaticResource FontBase}" Typography.NumeralAlignment="Tabular"
                                        FontSize="{StaticResource FontSizeBase}"
                                        FontWeight="SemiBold"
                                        Text="{Binding TargetPrice, Converter={StaticResource CurrencyConverter}, ConverterParameter=price}">
                    <TextBlock.Style>
                      <Style TargetType="TextBlock">
                        <Setter Property="Visibility" Value="Visible" />
                        <Style.Triggers>
                          <DataTrigger Binding="{Binding IsEditing}" Value="True">
                            <Setter Property="Visibility" Value="Collapsed" />
                          </DataTrigger>
                        </Style.Triggers>
                      </Style>
                    </TextBlock.Style>
                  </TextBlock>
                  <!--  Edit  -->
                  <ui:TextBox
                                        Margin="0,4"
                                        Padding="4,0"
                                        VerticalContentAlignment="Center"
                                        Background="{DynamicResource AppBackground}"
                                        BorderBrush="{DynamicResource AppAccent}"
                                        BorderThickness="1"
                                        FocusVisualStyle="{x:Null}"
                                        FontFamily="{StaticResource FontBase}" Typography.NumeralAlignment="Tabular"
                                        FontSize="{StaticResource FontSizeSm}"
                                        Foreground="{DynamicResource AppTextPrimary}"
                                        Text="{Binding EditTargetPrice, UpdateSourceTrigger=PropertyChanged}">
                    <TextBox.Style>
                      <Style BasedOn="{StaticResource {x:Type TextBox}}" TargetType="TextBox">
                        <Setter Property="Visibility" Value="Collapsed" />
                        <Style.Triggers>
                          <DataTrigger Binding="{Binding IsEditing}" Value="True">
                            <Setter Property="Visibility" Value="Visible" />
                          </DataTrigger>
                        </Style.Triggers>
                      </Style>
                    </TextBox.Style>
                  </ui:TextBox>
                  <!--  Validation error  -->
                  <TextBlock
                                        Margin="0,28,0,0"
                                        FontSize="{StaticResource FontSizeXs}"
                                        Foreground="{DynamicResource AppDown}"
                                        Text="{Binding EditError}"
                                        Visibility="{Binding EditError, Converter={StaticResource StringToVisibilityConverter}}" />
                </Grid>
              </DataTemplate>
            </DataGridTemplateColumn.CellTemplate>
          </DataGridTemplateColumn>

          <!--  現價  -->
          <DataGridTemplateColumn Width="100" SortMemberPath="CurrentPrice">
            <DataGridTemplateColumn.HeaderStyle>
              <Style BasedOn="{StaticResource AppDataGridColHeader}" TargetType="DataGridColumnHeader">
                <Setter Property="HorizontalContentAlignment" Value="Right" />
              </Style>
            </DataGridTemplateColumn.HeaderStyle>
            <DataGridTemplateColumn.Header>
              <TextBlock Text="{DynamicResource Alerts.CurrentPrice}" />
            </DataGridTemplateColumn.Header>
            <DataGridTemplateColumn.CellTemplate>
              <DataTemplate>
                <TextBlock
                                    Margin="0,0,8,0"
                                    HorizontalAlignment="Right"
                                    VerticalAlignment="Center"
                                    FontFamily="{StaticResource FontBase}" Typography.NumeralAlignment="Tabular"
                                    FontSize="{StaticResource FontSizeBase}">
                  <TextBlock.Style>
                    <Style TargetType="TextBlock">
                      <Setter Property="Text" Value="{Binding CurrentPrice, Converter={StaticResource CurrencyConverter}, ConverterParameter=price}" />
                      <Style.Triggers>
                        <DataTrigger Binding="{Binding CurrentPrice}" Value="{x:Null}">
                          <Setter Property="Text" Value="-" />
                        </DataTrigger>
                      </Style.Triggers>
                    </Style>
                  </TextBlock.Style>
                </TextBlock>
              </DataTemplate>
            </DataGridTemplateColumn.CellTemplate>
          </DataGridTemplateColumn>

          <!--  狀態  -->
          <DataGridTemplateColumn Width="120">
            <DataGridTemplateColumn.Header>
              <TextBlock Text="{DynamicResource Alerts.Status}" />
            </DataGridTemplateColumn.Header>
            <DataGridTemplateColumn.CellTemplate>
              <DataTemplate>
                <Grid Margin="8,0,4,0">
                  <!--  Triggered  -->
                  <TextBlock
                                        VerticalAlignment="Center"
                                        FontFamily="{StaticResource FontBase}"
                                        FontSize="{StaticResource FontSizeSm}"
                                        FontWeight="SemiBold"
                                        Foreground="{DynamicResource AppDown}"
                                        Visibility="{Binding IsTriggered, Converter={StaticResource BooleanToVisibilityConverter}}">
                                        <Run Text="{DynamicResource Alerts.Triggered}" />
                                        <Run Text="{Binding TriggeredAt}" />
                  </TextBlock>
                  <!--  Pending  -->
                  <TextBlock
                                        VerticalAlignment="Center"
                                        FontFamily="{StaticResource FontBase}"
                                        FontSize="{StaticResource FontSizeSm}"
                                        Foreground="{DynamicResource AppTextSecondary}"
                                        Text="{DynamicResource Alerts.Monitoring}"
                                        Visibility="{Binding IsTriggered, Converter={StaticResource InverseBooleanToVisibilityConverter}}">
                    <TextBlock.Style>
                      <Style TargetType="TextBlock">
                        <Style.Triggers>
                          <DataTrigger Binding="{Binding IsEditing}" Value="True">
                            <Setter Property="Visibility" Value="Collapsed" />
                          </DataTrigger>
                        </Style.Triggers>
                      </Style>
                    </TextBlock.Style>
                  </TextBlock>
                </Grid>
              </DataTemplate>
            </DataGridTemplateColumn.CellTemplate>
          </DataGridTemplateColumn>

          <!--  操作  -->
          <DataGridTemplateColumn Width="80" CanUserSort="False">
            <DataGridTemplateColumn.CellStyle>
              <Style BasedOn="{StaticResource AppDataGridCell}" TargetType="DataGridCell">
                <Setter Property="Padding" Value="0" />
              </Style>
            </DataGridTemplateColumn.CellStyle>
            <DataGridTemplateColumn.CellTemplate>
              <DataTemplate>
                <StackPanel HorizontalAlignment="Center" Orientation="Horizontal">

                  <!--  View mode: pencil  -->
                  <ui:Button
                                        Width="24"
                                        Height="24"
                                        Command="{Binding BeginEditCommand}"
                                        FontSize="11"
                                        ToolTip="{DynamicResource Alerts.Edit}">
                    <ui:Button.Style>
                      <Style BasedOn="{StaticResource {x:Type ui:Button}}" TargetType="{x:Type ui:Button}">
                          <Setter Property="Appearance" Value="Transparent" />
                        <Setter Property="Visibility" Value="Collapsed" />
                        <Style.Triggers>
                          <MultiDataTrigger>
                            <MultiDataTrigger.Conditions>
                              <Condition Binding="{Binding RelativeSource={RelativeSource AncestorType=DataGridRow}, Path=IsMouseOver}" Value="True" />
                              <Condition Binding="{Binding IsEditing}" Value="False" />
                            </MultiDataTrigger.Conditions>
                            <Setter Property="Visibility" Value="Visible" />
                          </MultiDataTrigger>
                        </Style.Triggers>
                      </Style>
                    </ui:Button.Style>
                    <ui:SymbolIcon Symbol="Edit24" FontSize="11" Foreground="{DynamicResource AppTextPrimary}" />
                  </ui:Button>

                  <!--  View mode: delete  -->
                  <ui:Button
                                        Width="24"
                                        Height="24"
                                        Command="{Binding DataContext.RemoveRuleCommand, RelativeSource={RelativeSource AncestorType=DataGrid}}"
                                        CommandParameter="{Binding Id}"
                                        ToolTip="{DynamicResource Alerts.Delete}">
                    <ui:Button.Style>
                      <Style BasedOn="{StaticResource {x:Type ui:Button}}" TargetType="{x:Type ui:Button}">
                          <Setter Property="Appearance" Value="Transparent" />
                        <Setter Property="Visibility" Value="Collapsed" />
                        <Style.Triggers>
                          <MultiDataTrigger>
                            <MultiDataTrigger.Conditions>
                              <Condition Binding="{Binding RelativeSource={RelativeSource AncestorType=DataGridRow}, Path=IsMouseOver}" Value="True" />
                              <Condition Binding="{Binding IsEditing}" Value="False" />
                            </MultiDataTrigger.Conditions>
                            <Setter Property="Visibility" Value="Visible" />
                          </MultiDataTrigger>
                        </Style.Triggers>
                      </Style>
                    </ui:Button.Style>
                    <ui:SymbolIcon Symbol="Delete24" FontSize="11" Foreground="{DynamicResource AppDanger}" />
                  </ui:Button>

                  <!--  Edit mode: save ✓  -->
                  <ui:Button
                                        Width="24"
                                        Height="24"
                                        Command="{Binding DataContext.SaveRuleCommand, RelativeSource={RelativeSource AncestorType=DataGrid}}"
                                        CommandParameter="{Binding}"
                                        ToolTip="{DynamicResource Alerts.Save}">
                    <ui:Button.Style>
                      <Style BasedOn="{StaticResource {x:Type ui:Button}}" TargetType="{x:Type ui:Button}">
                          <Setter Property="Appearance" Value="Transparent" />
                        <Setter Property="Visibility" Value="Collapsed" />
                        <Style.Triggers>
                          <DataTrigger Binding="{Binding IsEditing}" Value="True">
                            <Setter Property="Visibility" Value="Visible" />
                          </DataTrigger>
                        </Style.Triggers>
                      </Style>
                    </ui:Button.Style>
                    <ui:SymbolIcon Symbol="Checkmark24" FontSize="12" Foreground="{DynamicResource AppUp}" />
                  </ui:Button>

                  <!--  Edit mode: cancel ✕  -->
                  <ui:Button
                                        Width="24"
                                        Height="24"
                                        Command="{Binding CancelEditCommand}"
                                        ToolTip="{DynamicResource Alerts.Cancel}">
                    <ui:Button.Style>
                      <Style BasedOn="{StaticResource {x:Type ui:Button}}" TargetType="{x:Type ui:Button}">
                          <Setter Property="Appearance" Value="Transparent" />
                        <Setter Property="Visibility" Value="Collapsed" />
                        <Style.Triggers>
                          <DataTrigger Binding="{Binding IsEditing}" Value="True">
                            <Setter Property="Visibility" Value="Visible" />
                          </DataTrigger>
                        </Style.Triggers>
                      </Style>
                    </ui:Button.Style>
                    <ui:SymbolIcon Symbol="Dismiss24" FontSize="11" Foreground="{DynamicResource AppTextSecondary}" />
                  </ui:Button>

                </StackPanel>
              </DataTemplate>
            </DataGridTemplateColumn.CellTemplate>
          </DataGridTemplateColumn>
        </DataGrid.Columns>
      </ui:DataGrid>

      <!--  Empty state  -->
      <ui:Card Padding="32" Visibility="{Binding HasNoRules, Converter={StaticResource BooleanToVisibilityConverter}}">
        <StackPanel HorizontalAlignment="Center" VerticalAlignment="Center">
          <TextBlock
                        Margin="0,0,0,12"
                        HorizontalAlignment="Center"
                        FontSize="{StaticResource FontSize3xl}"
                        Opacity="0.45"
                        Text="🔔" />
          <TextBlock
                        HorizontalAlignment="Center"
                        FontSize="{StaticResource FontSizeMd}"
                        FontWeight="SemiBold"
                        Foreground="{DynamicResource AppTextPrimary}"
                        Text="{DynamicResource Alerts.Empty}" />
          <TextBlock
                        Margin="0,6,0,20"
                        HorizontalAlignment="Center"
                        FontSize="{StaticResource FontSizeSm}"
                        Foreground="{DynamicResource AppTextSecondary}"
                        Text="{DynamicResource Alerts.Empty.Hint}" />
          <TextBlock
                        HorizontalAlignment="Center"
                        FontSize="{StaticResource FontSizeXs}"
                        Foreground="{DynamicResource AppTextMuted}"
                        Text="{DynamicResource Alerts.Empty.Cta}" />
        </StackPanel>
      </ui:Card>
    </Grid>

    <!--  ── Add Form ──  -->
    <Border
            Grid.Row="1"
            Padding="16,12"
            Background="{DynamicResource AppSurface}"
            BorderBrush="{DynamicResource AppBorder}"
            BorderThickness="0,1,0,0">
      <Grid>
        <Grid.RowDefinitions>
          <RowDefinition Height="Auto" />
          <RowDefinition Height="Auto" />
        </Grid.RowDefinitions>
        <Grid Grid.Row="0">
          <Grid.ColumnDefinitions>
            <ColumnDefinition Width="*" />
            <ColumnDefinition Width="16" />
            <ColumnDefinition Width="160" />
            <ColumnDefinition Width="16" />
            <ColumnDefinition Width="160" />
            <ColumnDefinition Width="16" />
            <ColumnDefinition Width="Auto" />
          </Grid.ColumnDefinitions>
          <Grid.RowDefinitions>
            <RowDefinition Height="Auto" />
            <RowDefinition Height="Auto" />
          </Grid.RowDefinitions>
          <Grid.Style>
            <Style TargetType="Grid">
              <Setter Property="Visibility" Value="Visible" />
              <Style.Triggers>
                <DataTrigger Value="True">
                  <DataTrigger.Binding>
                    <MultiBinding Converter="{StaticResource WidthScaleThresholdToBooleanConverter}" ConverterParameter="980">
                      <Binding ElementName="Root" Path="ActualWidth" />
                      <Binding Path="DataContext.Settings.UiScale" RelativeSource="{RelativeSource AncestorType=Window}" />
                    </MultiBinding>
                  </DataTrigger.Binding>
                  <Setter Property="Visibility" Value="Collapsed" />
                </DataTrigger>
              </Style.Triggers>
            </Style>
          </Grid.Style>

          <TextBlock
                        Grid.Row="0"
                        Grid.Column="0"
                        Margin="0,0,0,4"
                        FontSize="{StaticResource FontSizeXs}"
                        FontWeight="SemiBold"
                        Foreground="{DynamicResource AppTextSecondary}"
                        Text="{DynamicResource Alerts.Symbol}" />
          <TextBlock
                        Grid.Row="0"
                        Grid.Column="2"
                        Margin="0,0,0,4"
                        FontSize="{StaticResource FontSizeXs}"
                        FontWeight="SemiBold"
                        Foreground="{DynamicResource AppTextSecondary}"
                        Text="{DynamicResource Alerts.Condition}" />
          <TextBlock
                        Grid.Row="0"
                        Grid.Column="4"
                        Margin="0,0,0,4"
                        FontSize="{StaticResource FontSizeXs}"
                        FontWeight="SemiBold"
                        Foreground="{DynamicResource AppTextSecondary}"
                        Text="{DynamicResource Alerts.TargetPrice}" />

          <Grid Grid.Row="1" Grid.Column="0">
            <TextBlock Visibility="Collapsed" />
            <ui:TextBox
                            x:Name="AddAlertSymbolBox"

                            Text="{Binding AddSymbol, UpdateSourceTrigger=PropertyChanged}" />
            <Popup
                            Width="{Binding ActualWidth, ElementName=AddAlertSymbolBox}"
                            AllowsTransparency="True"
                            IsOpen="{Binding IsSuggestionsOpen}"
                            Placement="Bottom"
                            PlacementTarget="{Binding ElementName=AddAlertSymbolBox}"
                            StaysOpen="True">
              <Border
                                Background="{DynamicResource AppSurface}"
                                BorderBrush="{DynamicResource AppBorder}"
                                BorderThickness="1"
                                CornerRadius="{StaticResource RadiusSm}">
                <ListBox
                                    MaxHeight="240"
                                    Background="Transparent"
                                    BorderThickness="0"
                                    ItemContainerStyle="{StaticResource StockSuggestionListBoxItemStyle}"
                                    ItemTemplate="{StaticResource StockSuggestionItemTemplate}"
                                    ItemsSource="{Binding SymbolSuggestions}"
                                    ScrollViewer.HorizontalScrollBarVisibility="Disabled"
                                    SelectedItem="{Binding SelectedSuggestion, Mode=TwoWay}" />
              </Border>
            </Popup>
          </Grid>

          <ComboBox
                        Grid.Row="1"
                        Grid.Column="2"
                        Height="Auto"
                        FontSize="{StaticResource FontSizeXs}"
                        ItemsSource="{Binding Conditions}"
                        SelectedItem="{Binding AddCondition}"
                        Style="{StaticResource FormComboBox}">
            <ComboBox.ItemTemplate>
              <DataTemplate>
                <TextBlock>
                  <TextBlock.Style>
                    <Style TargetType="TextBlock">
                      <Setter Property="Text" Value="{DynamicResource Alerts.ConditionBelow}" />
                      <Style.Triggers>
                        <DataTrigger Binding="{Binding}" Value="突破">
                          <Setter Property="Text" Value="{DynamicResource Alerts.ConditionAbove}" />
                        </DataTrigger>
                      </Style.Triggers>
                    </Style>
                  </TextBlock.Style>
                </TextBlock>
              </DataTemplate>
            </ComboBox.ItemTemplate>
          </ComboBox>

          <ui:TextBox
                        Grid.Row="1"
                        Grid.Column="4"

                        Text="{Binding AddTargetPrice, UpdateSourceTrigger=PropertyChanged}" />

          <ui:Button
                        Grid.Row="1"
                        Grid.Column="6"
                        MinWidth="180"
                        MinHeight="36"
                        Margin="0,0,0,1"
                        Padding="16,0"
                        VerticalAlignment="Bottom"
                        Command="{Binding AddRuleCommand}"
                        Appearance="Primary">
            <TextBlock Foreground="{Binding Foreground, RelativeSource={RelativeSource AncestorType=Button}}" Text="{DynamicResource Alerts.AddAlert}" />
          </ui:Button>
        </Grid>

        <StackPanel Grid.Row="0" Margin="0,0,0,4">
          <StackPanel.Style>
            <Style TargetType="StackPanel">
              <Setter Property="Visibility" Value="Collapsed" />
              <Style.Triggers>
                <DataTrigger Value="True">
                  <DataTrigger.Binding>
                    <MultiBinding Converter="{StaticResource WidthScaleThresholdToBooleanConverter}" ConverterParameter="980">
                      <Binding ElementName="Root" Path="ActualWidth" />
                      <Binding Path="DataContext.Settings.UiScale" RelativeSource="{RelativeSource AncestorType=Window}" />
                    </MultiBinding>
                  </DataTrigger.Binding>
                  <Setter Property="Visibility" Value="Visible" />
                </DataTrigger>
              </Style.Triggers>
            </Style>
          </StackPanel.Style>

          <TextBlock
                        Margin="0,0,0,4"
                        FontSize="{StaticResource FontSizeXs}"
                        FontWeight="SemiBold"
                        Foreground="{DynamicResource AppTextSecondary}"
                        Text="{DynamicResource Alerts.Symbol}" />
          <Grid Margin="0,0,0,10">
            <ui:TextBox
                            x:Name="AddAlertSymbolBoxCompact"

                            Text="{Binding AddSymbol, UpdateSourceTrigger=PropertyChanged}" />
            <Popup
                            Width="{Binding ActualWidth, ElementName=AddAlertSymbolBoxCompact}"
                            AllowsTransparency="True"
                            IsOpen="{Binding IsSuggestionsOpen}"
                            Placement="Bottom"
                            PlacementTarget="{Binding ElementName=AddAlertSymbolBoxCompact}"
                            StaysOpen="True">
              <Border
                                Background="{DynamicResource AppSurface}"
                                BorderBrush="{DynamicResource AppBorder}"
                                BorderThickness="1"
                                CornerRadius="{StaticResource RadiusSm}">
                <ListBox
                                    MaxHeight="240"
                                    Background="Transparent"
                                    BorderThickness="0"
                                    ItemContainerStyle="{StaticResource StockSuggestionListBoxItemStyle}"
                                    ItemTemplate="{StaticResource StockSuggestionItemTemplate}"
                                    ItemsSource="{Binding SymbolSuggestions}"
                                    ScrollViewer.HorizontalScrollBarVisibility="Disabled"
                                    SelectedItem="{Binding SelectedSuggestion, Mode=TwoWay}" />
              </Border>
            </Popup>
          </Grid>

          <Grid Margin="0,0,0,10">
            <Grid.ColumnDefinitions>
              <ColumnDefinition Width="*" />
              <ColumnDefinition Width="12" />
              <ColumnDefinition Width="*" />
            </Grid.ColumnDefinitions>

            <StackPanel Grid.Column="0">
              <TextBlock
                                Margin="0,0,0,4"
                                FontSize="{StaticResource FontSizeXs}"
                                FontWeight="SemiBold"
                                Foreground="{DynamicResource AppTextSecondary}"
                                Text="{DynamicResource Alerts.Condition}" />
              <ComboBox
                                Height="Auto"
                                FontSize="{StaticResource FontSizeXs}"
                                ItemsSource="{Binding Conditions}"
                                SelectedItem="{Binding AddCondition}"
                                Style="{StaticResource FormComboBox}">
                <ComboBox.ItemTemplate>
                  <DataTemplate>
                    <TextBlock>
                      <TextBlock.Style>
                        <Style TargetType="TextBlock">
                          <Setter Property="Text" Value="{DynamicResource Alerts.ConditionBelow}" />
                          <Style.Triggers>
                            <DataTrigger Binding="{Binding}" Value="突破">
                              <Setter Property="Text" Value="{DynamicResource Alerts.ConditionAbove}" />
                            </DataTrigger>
                          </Style.Triggers>
                        </Style>
                      </TextBlock.Style>
                    </TextBlock>
                  </DataTemplate>
                </ComboBox.ItemTemplate>
              </ComboBox>
            </StackPanel>

            <StackPanel Grid.Column="2">
              <TextBlock
                                Margin="0,0,0,4"
                                FontSize="{StaticResource FontSizeXs}"
                                FontWeight="SemiBold"
                                Foreground="{DynamicResource AppTextSecondary}"
                                Text="{DynamicResource Alerts.TargetPrice}" />
              <ui:TextBox Text="{Binding AddTargetPrice, UpdateSourceTrigger=PropertyChanged}" />
            </StackPanel>
          </Grid>

          <ui:Button
                        MinHeight="36"
                        Padding="16,0"
                        HorizontalAlignment="Stretch"
                        Command="{Binding AddRuleCommand}"
                        Appearance="Primary">
            <TextBlock Foreground="{Binding Foreground, RelativeSource={RelativeSource AncestorType=Button}}" Text="{DynamicResource Alerts.AddAlert}" />
          </ui:Button>
        </StackPanel>
        <TextBlock
                    Grid.Row="1"
                    Margin="0,8,0,0"
                    FontSize="{StaticResource FontSizeXs}"
                    Foreground="{DynamicResource AppDown}"
                    Text="{Binding AddError}"
                    Visibility="{Binding AddError, Converter={StaticResource StringToVisibilityConverter}}" />
      </Grid>
    </Border>
  </Grid>
</UserControl>
