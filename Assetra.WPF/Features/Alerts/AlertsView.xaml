<UserControl
    x:Class="Assetra.WPF.Features.Alerts.AlertsView"
    xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
    xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
    xmlns:d="http://schemas.microsoft.com/expression/blend/2008"
    xmlns:mc="http://schemas.openxmlformats.org/markup-compatibility/2006"
    xmlns:vm="clr-namespace:Assetra.WPF.Features.Alerts"
    d:DataContext="{d:DesignInstance Type={x:Type vm:AlertsViewModel},
                                     IsDesignTimeCreatable=False}"
    d:DesignHeight="776"
    d:DesignWidth="1100"
    Background="{DynamicResource AppBackground}"
    mc:Ignorable="d">

    <Grid>
        <Grid.RowDefinitions>
            <RowDefinition Height="*" />
            <!--  DataGrid  -->
            <RowDefinition Height="Auto" />
            <!--  Add form  -->
        </Grid.RowDefinitions>

        <!--  ── Rules DataGrid ──  -->
        <Grid Grid.Row="0">
            <DataGrid
                x:Name="AlertsGrid"
                AutoGenerateColumns="False"
                Background="{DynamicResource AppBackground}"
                BorderThickness="0"
                CanUserAddRows="False"
                CanUserDeleteRows="False"
                CanUserReorderColumns="False"
                CanUserResizeColumns="False"
                CanUserSortColumns="True"
                ColumnHeaderHeight="{StaticResource DataGridHeaderHeight}"
                EnableRowVirtualization="True"
                FontFamily="{StaticResource FontBase}"
                FontSize="{StaticResource FontSizeSm}"
                Foreground="{DynamicResource AppTextPrimary}"
                GridLinesVisibility="None"
                HeadersVisibility="Column"
                HorizontalScrollBarVisibility="Disabled"
                IsReadOnly="True"
                ItemsSource="{Binding Rules}"
                PreviewKeyDown="OnGridPreviewKeyDown"
                PreviewMouseDown="OnGridPreviewMouseDown"
                RowHeight="{StaticResource DataGridRowHeight}"
                SelectionMode="Single"
                VirtualizingPanel.IsVirtualizing="True"
                VirtualizingPanel.VirtualizationMode="Recycling">

                <DataGrid.ColumnHeaderStyle>
                    <Style BasedOn="{StaticResource AppDataGridColHeader}" TargetType="DataGridColumnHeader" />
                </DataGrid.ColumnHeaderStyle>
                <DataGrid.CellStyle>
                    <Style BasedOn="{StaticResource AppDataGridCell}" TargetType="DataGridCell" />
                </DataGrid.CellStyle>
                <DataGrid.RowStyle>
                    <Style BasedOn="{StaticResource AppDataGridRowSelectable}" TargetType="DataGridRow" />
                </DataGrid.RowStyle>

                <DataGrid.Columns>
                    <!--  代號  -->
                    <DataGridTemplateColumn Width="100" SortMemberPath="Symbol">
                        <DataGridTemplateColumn.Header>
                            <TextBlock Text="{DynamicResource Alerts.Symbol}" />
                        </DataGridTemplateColumn.Header>
                        <DataGridTemplateColumn.CellTemplate>
                            <DataTemplate>
                                <TextBlock
                                    Margin="8,0,0,0"
                                    VerticalAlignment="Center"
                                    FontFamily="{StaticResource FontTabular}"
                                    FontSize="{StaticResource FontSizeSm}"
                                    FontWeight="SemiBold"
                                    Foreground="{DynamicResource AppTextPrimary}"
                                    Text="{Binding Symbol}" />
                            </DataTemplate>
                        </DataGridTemplateColumn.CellTemplate>
                    </DataGridTemplateColumn>

                    <!--  名稱  -->
                    <DataGridTemplateColumn
                        Width="*"
                        MinWidth="100"
                        SortMemberPath="Name">
                        <DataGridTemplateColumn.Header>
                            <TextBlock Text="{DynamicResource Alerts.Name}" />
                        </DataGridTemplateColumn.Header>
                        <DataGridTemplateColumn.CellTemplate>
                            <DataTemplate>
                                <TextBlock
                                    Margin="8,0,4,0"
                                    VerticalAlignment="Center"
                                    FontFamily="{StaticResource FontBase}"
                                    FontSize="{StaticResource FontSizeBase}"
                                    Foreground="{DynamicResource AppTextSecondary}"
                                    Text="{Binding Name}"
                                    TextTrimming="CharacterEllipsis" />
                            </DataTemplate>
                        </DataGridTemplateColumn.CellTemplate>
                    </DataGridTemplateColumn>

                    <!--  條件  -->
                    <DataGridTemplateColumn Width="100">
                        <DataGridTemplateColumn.Header>
                            <TextBlock Text="{DynamicResource Alerts.Condition}" />
                        </DataGridTemplateColumn.Header>
                        <DataGridTemplateColumn.CellTemplate>
                            <DataTemplate>
                                <Grid Margin="4,0">
                                    <!--  View  -->
                                    <TextBlock
                                        VerticalAlignment="Center"
                                        FontFamily="{StaticResource FontBase}"
                                        FontSize="{StaticResource FontSizeSm}">
                                        <TextBlock.Style>
                                            <Style TargetType="TextBlock">
                                                <Setter Property="Visibility" Value="Visible" />
                                                <Setter Property="Text" Value="{DynamicResource Alerts.ConditionBelow}" />
                                                <Style.Triggers>
                                                    <DataTrigger Binding="{Binding Condition}" Value="Above">
                                                        <Setter Property="Text" Value="{DynamicResource Alerts.ConditionAbove}" />
                                                    </DataTrigger>
                                                    <DataTrigger Binding="{Binding IsEditing}" Value="True">
                                                        <Setter Property="Visibility" Value="Collapsed" />
                                                    </DataTrigger>
                                                </Style.Triggers>
                                            </Style>
                                        </TextBlock.Style>
                                    </TextBlock>
                                    <!--  Edit  -->
                                    <ComboBox
                                        Height="28"
                                        Margin="0,4"
                                        ItemsSource="{Binding Conditions}"
                                        SelectedItem="{Binding EditCondition, UpdateSourceTrigger=PropertyChanged}">
                                        <ComboBox.ItemTemplate>
                                            <DataTemplate>
                                                <TextBlock>
                                                    <TextBlock.Style>
                                                        <Style TargetType="TextBlock">
                                                            <Setter Property="Text" Value="{DynamicResource Alerts.ConditionBelow}" />
                                                            <Style.Triggers>
                                                                <DataTrigger Binding="{Binding}" Value="突破">
                                                                    <Setter Property="Text" Value="{DynamicResource Alerts.ConditionAbove}" />
                                                                </DataTrigger>
                                                            </Style.Triggers>
                                                        </Style>
                                                    </TextBlock.Style>
                                                </TextBlock>
                                            </DataTemplate>
                                        </ComboBox.ItemTemplate>
                                        <ComboBox.Style>
                                            <Style BasedOn="{StaticResource FormComboBox}" TargetType="ComboBox">
                                                <Setter Property="Visibility" Value="Collapsed" />
                                                <Style.Triggers>
                                                    <DataTrigger Binding="{Binding IsEditing}" Value="True">
                                                        <Setter Property="Visibility" Value="Visible" />
                                                    </DataTrigger>
                                                </Style.Triggers>
                                            </Style>
                                        </ComboBox.Style>
                                    </ComboBox>
                                </Grid>
                            </DataTemplate>
                        </DataGridTemplateColumn.CellTemplate>
                    </DataGridTemplateColumn>

                    <!--  目標價  -->
                    <DataGridTemplateColumn Width="110" SortMemberPath="TargetPrice">
                        <DataGridTemplateColumn.HeaderStyle>
                            <Style BasedOn="{StaticResource AppDataGridColHeader}" TargetType="DataGridColumnHeader">
                                <Setter Property="HorizontalContentAlignment" Value="Right" />
                            </Style>
                        </DataGridTemplateColumn.HeaderStyle>
                        <DataGridTemplateColumn.Header>
                            <TextBlock Text="{DynamicResource Alerts.TargetPrice}" />
                        </DataGridTemplateColumn.Header>
                        <DataGridTemplateColumn.CellTemplate>
                            <DataTemplate>
                                <Grid Margin="4,0">
                                    <!--  View  -->
                                    <TextBlock
                                        HorizontalAlignment="Right"
                                        VerticalAlignment="Center"
                                        FontFamily="{StaticResource FontTabular}"
                                        FontSize="{StaticResource FontSizeBase}"
                                        FontWeight="SemiBold"
                                        Text="{Binding TargetPrice, Converter={StaticResource CurrencyConverter}, ConverterParameter=price}">
                                        <TextBlock.Style>
                                            <Style TargetType="TextBlock">
                                                <Setter Property="Visibility" Value="Visible" />
                                                <Style.Triggers>
                                                    <DataTrigger Binding="{Binding IsEditing}" Value="True">
                                                        <Setter Property="Visibility" Value="Collapsed" />
                                                    </DataTrigger>
                                                </Style.Triggers>
                                            </Style>
                                        </TextBlock.Style>
                                    </TextBlock>
                                    <!--  Edit  -->
                                    <TextBox
                                        Margin="0,4"
                                        Padding="4,0"
                                        VerticalContentAlignment="Center"
                                        Background="{DynamicResource AppBackground}"
                                        BorderBrush="{DynamicResource AppAccent}"
                                        BorderThickness="1"
                                        FocusVisualStyle="{x:Null}"
                                        FontFamily="{StaticResource FontTabular}"
                                        FontSize="{StaticResource FontSizeSm}"
                                        Foreground="{DynamicResource AppTextPrimary}"
                                        Text="{Binding EditTargetPrice, UpdateSourceTrigger=PropertyChanged}">
                                        <TextBox.Style>
                                            <Style BasedOn="{StaticResource {x:Type TextBox}}" TargetType="TextBox">
                                                <Setter Property="Visibility" Value="Collapsed" />
                                                <Style.Triggers>
                                                    <DataTrigger Binding="{Binding IsEditing}" Value="True">
                                                        <Setter Property="Visibility" Value="Visible" />
                                                    </DataTrigger>
                                                </Style.Triggers>
                                            </Style>
                                        </TextBox.Style>
                                    </TextBox>
                                    <!--  Validation error  -->
                                    <TextBlock
                                        Margin="0,28,0,0"
                                        FontSize="{StaticResource FontSizeXs}"
                                        Foreground="{DynamicResource AppDown}"
                                        Text="{Binding EditError}"
                                        Visibility="{Binding EditError, Converter={StaticResource StringToVisibilityConverter}}" />
                                </Grid>
                            </DataTemplate>
                        </DataGridTemplateColumn.CellTemplate>
                    </DataGridTemplateColumn>

                    <!--  現價  -->
                    <DataGridTemplateColumn Width="100" SortMemberPath="CurrentPrice">
                        <DataGridTemplateColumn.HeaderStyle>
                            <Style BasedOn="{StaticResource AppDataGridColHeader}" TargetType="DataGridColumnHeader">
                                <Setter Property="HorizontalContentAlignment" Value="Right" />
                            </Style>
                        </DataGridTemplateColumn.HeaderStyle>
                        <DataGridTemplateColumn.Header>
                            <TextBlock Text="{DynamicResource Alerts.CurrentPrice}" />
                        </DataGridTemplateColumn.Header>
                        <DataGridTemplateColumn.CellTemplate>
                            <DataTemplate>
                                <TextBlock
                                    Margin="0,0,8,0"
                                    HorizontalAlignment="Right"
                                    VerticalAlignment="Center"
                                    FontFamily="{StaticResource FontTabular}"
                                    FontSize="{StaticResource FontSizeBase}"
                                    Text="{Binding CurrentPrice, Converter={StaticResource CurrencyConverter}, ConverterParameter=price}" />
                            </DataTemplate>
                        </DataGridTemplateColumn.CellTemplate>
                    </DataGridTemplateColumn>

                    <!--  狀態  -->
                    <DataGridTemplateColumn Width="120">
                        <DataGridTemplateColumn.Header>
                            <TextBlock Text="{DynamicResource Alerts.Status}" />
                        </DataGridTemplateColumn.Header>
                        <DataGridTemplateColumn.CellTemplate>
                            <DataTemplate>
                                <Grid Margin="8,0,4,0">
                                    <!--  Triggered  -->
                                    <TextBlock
                                        VerticalAlignment="Center"
                                        FontFamily="{StaticResource FontBase}"
                                        FontSize="{StaticResource FontSizeSm}"
                                        FontWeight="SemiBold"
                                        Foreground="{DynamicResource AppDown}"
                                        Visibility="{Binding IsTriggered, Converter={StaticResource BooleanToVisibilityConverter}}">
                                        <Run Text="{DynamicResource Alerts.Triggered}" />
                                        <Run Text="{Binding TriggeredAt}" />
                                    </TextBlock>
                                    <!--  Pending  -->
                                    <TextBlock
                                        VerticalAlignment="Center"
                                        FontFamily="{StaticResource FontBase}"
                                        FontSize="{StaticResource FontSizeSm}"
                                        Foreground="{DynamicResource AppTextSecondary}"
                                        Text="{DynamicResource Alerts.Monitoring}"
                                        Visibility="{Binding IsTriggered, Converter={StaticResource InverseBooleanToVisibilityConverter}}">
                                        <TextBlock.Style>
                                            <Style TargetType="TextBlock">
                                                <Style.Triggers>
                                                    <DataTrigger Binding="{Binding IsEditing}" Value="True">
                                                        <Setter Property="Visibility" Value="Collapsed" />
                                                    </DataTrigger>
                                                </Style.Triggers>
                                            </Style>
                                        </TextBlock.Style>
                                    </TextBlock>
                                </Grid>
                            </DataTemplate>
                        </DataGridTemplateColumn.CellTemplate>
                    </DataGridTemplateColumn>

                    <!--  操作  -->
                    <DataGridTemplateColumn Width="80" CanUserSort="False">
                        <DataGridTemplateColumn.CellStyle>
                            <Style BasedOn="{StaticResource AppDataGridCell}" TargetType="DataGridCell">
                                <Setter Property="Padding" Value="0" />
                            </Style>
                        </DataGridTemplateColumn.CellStyle>
                        <DataGridTemplateColumn.CellTemplate>
                            <DataTemplate>
                                <StackPanel HorizontalAlignment="Center" Orientation="Horizontal">

                                    <!--  View mode: pencil  -->
                                    <Button
                                        Width="24"
                                        Height="24"
                                        Command="{Binding BeginEditCommand}"
                                        FontFamily="Segoe MDL2 Assets"
                                        FontSize="11"
                                        ToolTip="{DynamicResource Alerts.Edit}">
                                        <Button.Style>
                                            <Style BasedOn="{StaticResource BtnIcon}" TargetType="Button">
                                                <Setter Property="Visibility" Value="Collapsed" />
                                                <Style.Triggers>
                                                    <MultiDataTrigger>
                                                        <MultiDataTrigger.Conditions>
                                                            <Condition Binding="{Binding RelativeSource={RelativeSource AncestorType=DataGridRow}, Path=IsMouseOver}" Value="True" />
                                                            <Condition Binding="{Binding IsEditing}" Value="False" />
                                                        </MultiDataTrigger.Conditions>
                                                        <Setter Property="Visibility" Value="Visible" />
                                                    </MultiDataTrigger>
                                                </Style.Triggers>
                                            </Style>
                                        </Button.Style>
                                        <TextBlock
                                            FontFamily="Segoe MDL2 Assets"
                                            FontSize="11"
                                            Foreground="{DynamicResource AppTextPrimary}"
                                            Text="&#xE70F;" />
                                    </Button>

                                    <!--  View mode: delete  -->
                                    <Button
                                        Width="24"
                                        Height="24"
                                        Command="{Binding DataContext.RemoveRuleCommand, RelativeSource={RelativeSource AncestorType=DataGrid}}"
                                        CommandParameter="{Binding Id}"
                                        ToolTip="{DynamicResource Alerts.Delete}">
                                        <Button.Style>
                                            <Style BasedOn="{StaticResource DataGridDeleteBtn}" TargetType="Button">
                                                <Setter Property="Visibility" Value="Collapsed" />
                                                <Style.Triggers>
                                                    <MultiDataTrigger>
                                                        <MultiDataTrigger.Conditions>
                                                            <Condition Binding="{Binding RelativeSource={RelativeSource AncestorType=DataGridRow}, Path=IsMouseOver}" Value="True" />
                                                            <Condition Binding="{Binding IsEditing}" Value="False" />
                                                        </MultiDataTrigger.Conditions>
                                                        <Setter Property="Visibility" Value="Visible" />
                                                    </MultiDataTrigger>
                                                </Style.Triggers>
                                            </Style>
                                        </Button.Style>
                                        <TextBlock
                                            FontFamily="Segoe MDL2 Assets"
                                            FontSize="11"
                                            Text="&#xE74D;" />
                                    </Button>

                                    <!--  Edit mode: save ✓  -->
                                    <Button
                                        Width="24"
                                        Height="24"
                                        Command="{Binding DataContext.SaveRuleCommand, RelativeSource={RelativeSource AncestorType=DataGrid}}"
                                        CommandParameter="{Binding}"
                                        ToolTip="{DynamicResource Alerts.Save}">
                                        <Button.Style>
                                            <Style BasedOn="{StaticResource BtnIcon}" TargetType="Button">
                                                <Setter Property="Visibility" Value="Collapsed" />
                                                <Style.Triggers>
                                                    <DataTrigger Binding="{Binding IsEditing}" Value="True">
                                                        <Setter Property="Visibility" Value="Visible" />
                                                    </DataTrigger>
                                                </Style.Triggers>
                                            </Style>
                                        </Button.Style>
                                        <TextBlock
                                            FontFamily="Segoe MDL2 Assets"
                                            FontSize="12"
                                            Foreground="{DynamicResource AppUp}"
                                            Text="&#xE73E;" />
                                    </Button>

                                    <!--  Edit mode: cancel ✕  -->
                                    <Button
                                        Width="24"
                                        Height="24"
                                        Command="{Binding CancelEditCommand}"
                                        ToolTip="{DynamicResource Alerts.Cancel}">
                                        <Button.Style>
                                            <Style BasedOn="{StaticResource BtnIcon}" TargetType="Button">
                                                <Setter Property="Visibility" Value="Collapsed" />
                                                <Style.Triggers>
                                                    <DataTrigger Binding="{Binding IsEditing}" Value="True">
                                                        <Setter Property="Visibility" Value="Visible" />
                                                    </DataTrigger>
                                                </Style.Triggers>
                                            </Style>
                                        </Button.Style>
                                        <TextBlock
                                            FontFamily="Segoe MDL2 Assets"
                                            FontSize="11"
                                            Foreground="{DynamicResource AppTextSecondary}"
                                            Text="&#xE711;" />
                                    </Button>

                                </StackPanel>
                            </DataTemplate>
                        </DataGridTemplateColumn.CellTemplate>
                    </DataGridTemplateColumn>
                </DataGrid.Columns>
            </DataGrid>

            <!--  Empty state  -->
            <Border
                Padding="32"
                Visibility="{Binding HasNoRules, Converter={StaticResource BooleanToVisibilityConverter}}">
                <StackPanel HorizontalAlignment="Center" VerticalAlignment="Center">
                    <TextBlock
                        Margin="0,0,0,12"
                        HorizontalAlignment="Center"
                        FontSize="{StaticResource FontSize3xl}"
                        Opacity="0.45"
                        Text="🔔" />
                    <TextBlock
                        HorizontalAlignment="Center"
                        FontSize="{StaticResource FontSizeMd}"
                        FontWeight="SemiBold"
                        Foreground="{DynamicResource AppTextPrimary}"
                        Text="{DynamicResource Alerts.Empty}" />
                    <TextBlock
                        Margin="0,6,0,20"
                        HorizontalAlignment="Center"
                        FontSize="{StaticResource FontSizeSm}"
                        Foreground="{DynamicResource AppTextSecondary}"
                        Text="{DynamicResource Alerts.Empty.Hint}" />
                    <TextBlock
                        HorizontalAlignment="Center"
                        FontSize="{StaticResource FontSizeXs}"
                        Foreground="{DynamicResource AppTextMuted}"
                        Text="{DynamicResource Alerts.Empty.Cta}" />
                </StackPanel>
            </Border>
        </Grid>

        <!--  ── Add Form ──  -->
        <Border
            Grid.Row="1"
            Padding="16,10"
            Background="{DynamicResource AppSurface}"
            BorderBrush="{DynamicResource AppBorder}"
            BorderThickness="0,1,0,0">
            <Grid>
                <Grid.RowDefinitions>
                    <RowDefinition Height="Auto" />
                    <RowDefinition Height="Auto" />
                </Grid.RowDefinitions>
                <StackPanel Grid.Row="0">
                    <!--  Field labels  -->
                    <StackPanel Margin="0,0,0,4" Orientation="Horizontal">
                        <TextBlock
                            Width="80"
                            Margin="0,0,8,0"
                            FontSize="{StaticResource FontSizeXs}"
                            FontWeight="SemiBold"
                            Foreground="{DynamicResource AppTextSecondary}"
                            Text="{DynamicResource Alerts.Symbol}" />
                        <TextBlock
                            Width="96"
                            Margin="0,0,8,0"
                            FontSize="{StaticResource FontSizeXs}"
                            FontWeight="SemiBold"
                            Foreground="{DynamicResource AppTextSecondary}"
                            Text="{DynamicResource Alerts.Condition}" />
                        <TextBlock
                            Width="88"
                            FontSize="{StaticResource FontSizeXs}"
                            FontWeight="SemiBold"
                            Foreground="{DynamicResource AppTextSecondary}"
                            Text="{DynamicResource Alerts.TargetPrice}" />
                    </StackPanel>
                    <!--  Inputs  -->
                    <StackPanel Orientation="Horizontal">
                        <TextBox
                            Width="80"
                            Margin="0,0,8,0"
                            Style="{StaticResource FormTextBox}"
                            Text="{Binding AddSymbol, UpdateSourceTrigger=PropertyChanged}" />
                        <ComboBox
                            Width="96"
                            Margin="0,0,8,0"
                            FontSize="{StaticResource FontSizeXs}"
                            ItemsSource="{Binding Conditions}"
                            SelectedItem="{Binding AddCondition}"
                            Style="{StaticResource FormComboBox}">
                            <ComboBox.ItemTemplate>
                                <DataTemplate>
                                    <TextBlock>
                                        <TextBlock.Style>
                                            <Style TargetType="TextBlock">
                                                <Setter Property="Text" Value="{DynamicResource Alerts.ConditionBelow}" />
                                                <Style.Triggers>
                                                    <DataTrigger Binding="{Binding}" Value="突破">
                                                        <Setter Property="Text" Value="{DynamicResource Alerts.ConditionAbove}" />
                                                    </DataTrigger>
                                                </Style.Triggers>
                                            </Style>
                                        </TextBlock.Style>
                                    </TextBlock>
                                </DataTemplate>
                            </ComboBox.ItemTemplate>
                        </ComboBox>
                        <TextBox
                            Width="88"
                            Margin="0,0,8,0"
                            Style="{StaticResource FormTextBox}"
                            Text="{Binding AddTargetPrice, UpdateSourceTrigger=PropertyChanged}" />
                        <Button
                            Height="30"
                            Padding="12,0"
                            VerticalAlignment="Center"
                            Command="{Binding AddRuleCommand}"
                            Style="{StaticResource BtnPrimary}">
                            <TextBlock Foreground="{Binding Foreground, RelativeSource={RelativeSource AncestorType=Button}}" Text="{DynamicResource Alerts.AddAlert}" />
                        </Button>
                    </StackPanel>
                </StackPanel>
                <TextBlock
                    Grid.Row="1"
                    Margin="0,4,0,0"
                    FontSize="{StaticResource FontSizeXs}"
                    Foreground="{DynamicResource AppDown}"
                    Text="{Binding AddError}"
                    Visibility="{Binding AddError, Converter={StaticResource StringToVisibilityConverter}}" />
            </Grid>
        </Border>
    </Grid>
</UserControl>
