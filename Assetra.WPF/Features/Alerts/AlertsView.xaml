<UserControl
    x:Class="Assetra.WPF.Features.Alerts.AlertsView"
    xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
    xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
    xmlns:behaviors="clr-namespace:Assetra.WPF.Infrastructure.Behaviors"
    xmlns:d="http://schemas.microsoft.com/expression/blend/2008"
    xmlns:mc="http://schemas.openxmlformats.org/markup-compatibility/2006"
    xmlns:ui="http://schemas.lepo.co/wpfui/2022/xaml"
    xmlns:vm="clr-namespace:Assetra.WPF.Features.Alerts"
    x:Name="Root"
    d:DataContext="{d:DesignInstance Type={x:Type vm:AlertsViewModel}, IsDesignTimeCreatable=False}"
    d:DesignHeight="800"
    d:DesignWidth="1200"
    Background="{DynamicResource AppBackground}"
    mc:Ignorable="d">

    <UserControl.Resources>
        <Style BasedOn="{StaticResource FormComboBox}" TargetType="ComboBox" />
    </UserControl.Resources>

    <Grid Margin="24">
        <Grid.RowDefinitions>
            <RowDefinition Height="Auto" />
            <RowDefinition Height="Auto" />
            <RowDefinition Height="Auto" />
            <RowDefinition Height="*" />
        </Grid.RowDefinitions>

        <DockPanel Grid.Row="0" Margin="0,0,0,16" LastChildFill="True">
            <ui:Button
                DockPanel.Dock="Right"
                VerticalAlignment="Center"
                Command="{Binding OpenAddFormCommand}"
                Appearance="Primary"
                Visibility="{Binding IsFormOpen, Converter={StaticResource InverseBooleanToVisibilityConverter}}">
                <StackPanel Orientation="Horizontal">
                    <ui:SymbolIcon
                        Margin="0,0,4,0"
                        VerticalAlignment="Center"
                        FontSize="{StaticResource FontSizeXs}"
                        Foreground="{Binding Foreground, RelativeSource={RelativeSource AncestorType=Button}}"
                        Symbol="Add24" />
                    <TextBlock
                        VerticalAlignment="Center"
                        Foreground="{Binding Foreground, RelativeSource={RelativeSource AncestorType=Button}}"
                        Text="{DynamicResource Alerts.AddAlert}" />
                </StackPanel>
            </ui:Button>

            <TextBlock
                VerticalAlignment="Center"
                FontSize="{StaticResource FontSizeXl}"
                FontWeight="SemiBold"
                Foreground="{DynamicResource AppTextPrimary}"
                Text="{DynamicResource Alerts.Title}" />
        </DockPanel>

        <UniformGrid Grid.Row="1" Margin="0,0,0,16" Columns="3">
            <ui:Card Margin="0,0,12,0" Padding="16">
                <StackPanel>
                    <StackPanel Orientation="Horizontal">
                        <ui:SymbolIcon
                            Margin="0,0,8,0"
                            Foreground="{DynamicResource AppTextMuted}"
                            Symbol="Alert24" />
                        <TextBlock
                            FontSize="{StaticResource FontSizeXs}"
                            Foreground="{DynamicResource AppTextSecondary}"
                            Text="{DynamicResource Alerts.Count}" />
                    </StackPanel>
                    <TextBlock
                        Margin="0,8,0,0"
                        FontSize="{StaticResource FontSizeXl}"
                        FontWeight="SemiBold"
                        Foreground="{DynamicResource AppTextPrimary}"
                        Text="{Binding AlertCount}" />
                </StackPanel>
            </ui:Card>

            <ui:Card Margin="0,0,12,0" Padding="16">
                <StackPanel>
                    <TextBlock
                        FontSize="{StaticResource FontSizeXs}"
                        Foreground="{DynamicResource AppTextSecondary}"
                        Text="{DynamicResource Alerts.MonitoringCount}" />
                    <TextBlock
                        Margin="0,8,0,0"
                        FontSize="{StaticResource FontSizeXl}"
                        FontWeight="SemiBold"
                        Foreground="{DynamicResource AppTextPrimary}"
                        Text="{Binding MonitoringCount}" />
                </StackPanel>
            </ui:Card>

            <ui:Card Padding="16">
                <StackPanel>
                    <TextBlock
                        FontSize="{StaticResource FontSizeXs}"
                        Foreground="{DynamicResource AppTextSecondary}"
                        Text="{DynamicResource Alerts.TriggeredCount}" />
                    <TextBlock
                        Margin="0,8,0,0"
                        FontSize="{StaticResource FontSizeXl}"
                        FontWeight="SemiBold"
                        Foreground="{DynamicResource AppTextPrimary}"
                        Text="{Binding TriggeredCount}" />
                </StackPanel>
            </ui:Card>
        </UniformGrid>

        <Grid Grid.Row="3">
            <ScrollViewer
                VerticalScrollBarVisibility="Auto"
                Visibility="{Binding HasNoRules, Converter={StaticResource InverseBooleanToVisibilityConverter}}">
                <ItemsControl ItemsSource="{Binding Rules}">
                    <ItemsControl.ItemTemplate>
                        <DataTemplate DataType="{x:Type vm:AlertRowViewModel}">
                            <Border
                                Margin="0,0,0,12"
                                Padding="16"
                                Background="{DynamicResource AppSurface}"
                                BorderBrush="{DynamicResource AppBorder}"
                                BorderThickness="1"
                                CornerRadius="{StaticResource RadiusMd}">
                                <Grid>
                                    <Grid.RowDefinitions>
                                        <RowDefinition Height="Auto" />
                                        <RowDefinition Height="Auto" />
                                        <RowDefinition Height="Auto" />
                                    </Grid.RowDefinitions>
                                    <Grid.ColumnDefinitions>
                                        <ColumnDefinition Width="*" />
                                        <ColumnDefinition Width="Auto" />
                                    </Grid.ColumnDefinitions>

                                    <StackPanel Grid.Row="0" Grid.Column="0">
                                        <StackPanel Orientation="Horizontal">
                                            <TextBlock
                                                FontSize="{StaticResource FontSizeMd}"
                                                FontWeight="SemiBold"
                                                Foreground="{DynamicResource AppTextPrimary}"
                                                Text="{Binding Symbol}" />
                                            <Border
                                                Margin="8,0,0,0"
                                                Padding="8,2"
                                                VerticalAlignment="Center"
                                                Background="{DynamicResource AppHover}"
                                                CornerRadius="{StaticResource RadiusSm}">
                                                <TextBlock
                                                    FontSize="{StaticResource FontSizeXs}"
                                                    Foreground="{DynamicResource AppTextSecondary}"
                                                    Text="{Binding Exchange}" />
                                            </Border>
                                        </StackPanel>
                                        <TextBlock
                                            Margin="0,4,0,0"
                                            FontSize="{StaticResource FontSizeSm}"
                                            Foreground="{DynamicResource AppTextSecondary}"
                                            Text="{Binding Name}"
                                            TextTrimming="CharacterEllipsis" />
                                    </StackPanel>

                                    <StackPanel
                                        Grid.Row="0"
                                        Grid.Column="1"
                                        Orientation="Horizontal">
                                        <ui:Button
                                            Width="32"
                                            Height="32"
                                            Margin="0,0,4,0"
                                            Padding="0"
                                            Command="{Binding BeginEditCommand}"
                                            ToolTip="{DynamicResource Alerts.Edit}">
                                            <ui:Button.Style>
                                                <Style BasedOn="{StaticResource {x:Type ui:Button}}" TargetType="{x:Type ui:Button}">
                                                    <Setter Property="Appearance" Value="Transparent" />
                                                    <Setter Property="Visibility" Value="Visible" />
                                                    <Style.Triggers>
                                                        <DataTrigger Binding="{Binding IsEditing}" Value="True">
                                                            <Setter Property="Visibility" Value="Collapsed" />
                                                        </DataTrigger>
                                                    </Style.Triggers>
                                                </Style>
                                            </ui:Button.Style>
                                            <ui:SymbolIcon FontSize="14" Symbol="Edit24" />
                                        </ui:Button>
                                        <ui:Button
                                            Width="32"
                                            Height="32"
                                            Margin="0,0,4,0"
                                            Padding="0"
                                            Command="{Binding DataContext.RemoveRuleCommand, RelativeSource={RelativeSource AncestorType=ItemsControl}}"
                                            CommandParameter="{Binding Id}"
                                            ToolTip="{DynamicResource Alerts.Delete}">
                                            <ui:Button.Style>
                                                <Style BasedOn="{StaticResource {x:Type ui:Button}}" TargetType="{x:Type ui:Button}">
                                                    <Setter Property="Appearance" Value="Transparent" />
                                                    <Setter Property="Visibility" Value="Visible" />
                                                    <Style.Triggers>
                                                        <DataTrigger Binding="{Binding IsEditing}" Value="True">
                                                            <Setter Property="Visibility" Value="Collapsed" />
                                                        </DataTrigger>
                                                    </Style.Triggers>
                                                </Style>
                                            </ui:Button.Style>
                                            <ui:SymbolIcon
                                                FontSize="14"
                                                Foreground="{DynamicResource AppDanger}"
                                                Symbol="Delete24" />
                                        </ui:Button>
                                        <ui:Button
                                            Width="32"
                                            Height="32"
                                            Margin="0,0,4,0"
                                            Padding="0"
                                            Command="{Binding DataContext.SaveRuleCommand, RelativeSource={RelativeSource AncestorType=ItemsControl}}"
                                            CommandParameter="{Binding}"
                                            ToolTip="{DynamicResource Alerts.Save}">
                                            <ui:Button.Style>
                                                <Style BasedOn="{StaticResource {x:Type ui:Button}}" TargetType="{x:Type ui:Button}">
                                                    <Setter Property="Appearance" Value="Transparent" />
                                                    <Setter Property="Visibility" Value="Collapsed" />
                                                    <Style.Triggers>
                                                        <DataTrigger Binding="{Binding IsEditing}" Value="True">
                                                            <Setter Property="Visibility" Value="Visible" />
                                                        </DataTrigger>
                                                    </Style.Triggers>
                                                </Style>
                                            </ui:Button.Style>
                                            <ui:SymbolIcon
                                                FontSize="14"
                                                Foreground="{DynamicResource AppUp}"
                                                Symbol="Checkmark24" />
                                        </ui:Button>
                                        <ui:Button
                                            Width="32"
                                            Height="32"
                                            Padding="0"
                                            Command="{Binding CancelEditCommand}"
                                            ToolTip="{DynamicResource Alerts.Cancel}">
                                            <ui:Button.Style>
                                                <Style BasedOn="{StaticResource {x:Type ui:Button}}" TargetType="{x:Type ui:Button}">
                                                    <Setter Property="Appearance" Value="Transparent" />
                                                    <Setter Property="Visibility" Value="Collapsed" />
                                                    <Style.Triggers>
                                                        <DataTrigger Binding="{Binding IsEditing}" Value="True">
                                                            <Setter Property="Visibility" Value="Visible" />
                                                        </DataTrigger>
                                                    </Style.Triggers>
                                                </Style>
                                            </ui:Button.Style>
                                            <ui:SymbolIcon FontSize="14" Symbol="Dismiss24" />
                                        </ui:Button>
                                    </StackPanel>

                                    <UniformGrid
                                        Grid.Row="1"
                                        Grid.Column="0"
                                        Grid.ColumnSpan="2"
                                        Margin="0,16,0,0"
                                        Columns="4">
                                        <StackPanel Margin="0,0,16,0">
                                            <TextBlock
                                                FontSize="{StaticResource FontSizeXs}"
                                                Foreground="{DynamicResource AppTextSecondary}"
                                                Text="{DynamicResource Alerts.Condition}" />
                                            <TextBlock
                                                Margin="0,4,0,0"
                                                FontWeight="SemiBold"
                                                Foreground="{DynamicResource AppTextPrimary}">
                                                <TextBlock.Style>
                                                    <Style TargetType="TextBlock">
                                                        <Setter Property="Text" Value="{DynamicResource Alerts.ConditionBelow}" />
                                                        <Setter Property="Visibility" Value="Visible" />
                                                        <Style.Triggers>
                                                            <DataTrigger Binding="{Binding Condition}" Value="Above">
                                                                <Setter Property="Text" Value="{DynamicResource Alerts.ConditionAbove}" />
                                                            </DataTrigger>
                                                            <DataTrigger Binding="{Binding IsEditing}" Value="True">
                                                                <Setter Property="Visibility" Value="Collapsed" />
                                                            </DataTrigger>
                                                        </Style.Triggers>
                                                    </Style>
                                                </TextBlock.Style>
                                            </TextBlock>
                                            <ComboBox
                                                MinWidth="140"
                                                Margin="0,4,0,0"
                                                ItemsSource="{Binding Conditions}"
                                                SelectedItem="{Binding EditCondition, UpdateSourceTrigger=PropertyChanged}">
                                                <ComboBox.ItemTemplate>
                                                    <DataTemplate>
                                                        <TextBlock>
                                                            <TextBlock.Style>
                                                                <Style TargetType="TextBlock">
                                                                    <Setter Property="Text" Value="{DynamicResource Alerts.ConditionBelow}" />
                                                                    <Style.Triggers>
                                                                        <DataTrigger Binding="{Binding}" Value="突破">
                                                                            <Setter Property="Text" Value="{DynamicResource Alerts.ConditionAbove}" />
                                                                        </DataTrigger>
                                                                    </Style.Triggers>
                                                                </Style>
                                                            </TextBlock.Style>
                                                        </TextBlock>
                                                    </DataTemplate>
                                                </ComboBox.ItemTemplate>
                                                <ComboBox.Style>
                                                    <Style BasedOn="{StaticResource FormComboBox}" TargetType="ComboBox">
                                                        <Setter Property="Visibility" Value="Collapsed" />
                                                        <Style.Triggers>
                                                            <DataTrigger Binding="{Binding IsEditing}" Value="True">
                                                                <Setter Property="Visibility" Value="Visible" />
                                                            </DataTrigger>
                                                        </Style.Triggers>
                                                    </Style>
                                                </ComboBox.Style>
                                            </ComboBox>
                                        </StackPanel>

                                        <StackPanel Margin="0,0,16,0">
                                            <TextBlock
                                                FontSize="{StaticResource FontSizeXs}"
                                                Foreground="{DynamicResource AppTextSecondary}"
                                                Text="{DynamicResource Alerts.TargetPrice}" />
                                            <TextBlock
                                                Margin="0,4,0,0"
                                                FontWeight="SemiBold"
                                                Foreground="{DynamicResource AppTextPrimary}"
                                                Text="{Binding TargetPrice, Converter={StaticResource CurrencyConverter}, ConverterParameter=price}"
                                                Typography.NumeralAlignment="Tabular">
                                                <TextBlock.Style>
                                                    <Style TargetType="TextBlock">
                                                        <Setter Property="Visibility" Value="Visible" />
                                                        <Style.Triggers>
                                                            <DataTrigger Binding="{Binding IsEditing}" Value="True">
                                                                <Setter Property="Visibility" Value="Collapsed" />
                                                            </DataTrigger>
                                                        </Style.Triggers>
                                                    </Style>
                                                </TextBlock.Style>
                                            </TextBlock>
                                            <ui:TextBox
                                                MinWidth="140"
                                                Margin="0,4,0,0"
                                                behaviors:ThousandSeparatorBehavior.IsEnabled="True"
                                                Text="{Binding EditTargetPrice, UpdateSourceTrigger=PropertyChanged}">
                                                <TextBox.Style>
                                                    <Style BasedOn="{StaticResource {x:Type TextBox}}" TargetType="TextBox">
                                                        <Setter Property="Visibility" Value="Collapsed" />
                                                        <Style.Triggers>
                                                            <DataTrigger Binding="{Binding IsEditing}" Value="True">
                                                                <Setter Property="Visibility" Value="Visible" />
                                                            </DataTrigger>
                                                        </Style.Triggers>
                                                    </Style>
                                                </TextBox.Style>
                                            </ui:TextBox>
                                        </StackPanel>

                                        <StackPanel Margin="0,0,16,0">
                                            <TextBlock
                                                FontSize="{StaticResource FontSizeXs}"
                                                Foreground="{DynamicResource AppTextSecondary}"
                                                Text="{DynamicResource Alerts.CurrentPrice}" />
                                            <TextBlock
                                                Margin="0,4,0,0"
                                                Foreground="{DynamicResource AppTextPrimary}"
                                                Typography.NumeralAlignment="Tabular">
                                                <TextBlock.Style>
                                                    <Style TargetType="TextBlock">
                                                        <Setter Property="Text" Value="{Binding CurrentPrice, Converter={StaticResource CurrencyConverter}, ConverterParameter=price}" />
                                                        <Style.Triggers>
                                                            <DataTrigger Binding="{Binding CurrentPrice}" Value="{x:Null}">
                                                                <Setter Property="Text" Value="-" />
                                                            </DataTrigger>
                                                        </Style.Triggers>
                                                    </Style>
                                                </TextBlock.Style>
                                            </TextBlock>
                                        </StackPanel>

                                        <StackPanel>
                                            <TextBlock
                                                FontSize="{StaticResource FontSizeXs}"
                                                Foreground="{DynamicResource AppTextSecondary}"
                                                Text="{DynamicResource Alerts.Status}" />
                                            <TextBlock
                                                Margin="0,4,0,0"
                                                Foreground="{DynamicResource AppTextSecondary}"
                                                Text="{DynamicResource Alerts.Monitoring}"
                                                Visibility="{Binding IsTriggered, Converter={StaticResource InverseBooleanToVisibilityConverter}}" />
                                            <TextBlock
                                                Margin="0,4,0,0"
                                                FontWeight="SemiBold"
                                                Foreground="{DynamicResource AppDown}"
                                                Visibility="{Binding IsTriggered, Converter={StaticResource BooleanToVisibilityConverter}}">
                                                <Run Text="{DynamicResource Alerts.Triggered}" />
                                                <Run Text=" " />
                                                <Run Text="{Binding TriggeredAt}" />
                                            </TextBlock>
                                        </StackPanel>
                                    </UniformGrid>

                                    <TextBlock
                                        Grid.Row="2"
                                        Grid.Column="0"
                                        Grid.ColumnSpan="2"
                                        Margin="0,10,0,0"
                                        FontSize="{StaticResource FontSizeXs}"
                                        Foreground="{DynamicResource AppDown}"
                                        Text="{Binding EditError}"
                                        Visibility="{Binding EditError, Converter={StaticResource StringToVisibilityConverter}}" />
                                </Grid>
                            </Border>
                        </DataTemplate>
                    </ItemsControl.ItemTemplate>
                </ItemsControl>
            </ScrollViewer>

            <ui:Card
                MinHeight="260"
                Padding="32"
                Visibility="{Binding HasNoRules, Converter={StaticResource BooleanToVisibilityConverter}}">
                <StackPanel HorizontalAlignment="Center" VerticalAlignment="Center">
                    <ui:SymbolIcon
                        HorizontalAlignment="Center"
                        FontSize="44"
                        Foreground="{DynamicResource AppTextMuted}"
                        Symbol="Alert24" />
                    <TextBlock
                        Margin="0,12,0,0"
                        HorizontalAlignment="Center"
                        FontSize="{StaticResource FontSizeMd}"
                        FontWeight="SemiBold"
                        Foreground="{DynamicResource AppTextPrimary}"
                        Text="{DynamicResource Alerts.Empty}" />
                    <TextBlock
                        Margin="0,6,0,0"
                        HorizontalAlignment="Center"
                        Foreground="{DynamicResource AppTextSecondary}"
                        Text="{DynamicResource Alerts.Empty.Hint}"
                        TextAlignment="Center"
                        TextWrapping="Wrap" />
                    <ui:Button
                        Margin="0,16,0,0"
                        HorizontalAlignment="Center"
                        Command="{Binding OpenAddFormCommand}"
                        Appearance="Primary"
                        Visibility="{Binding IsFormOpen, Converter={StaticResource InverseBooleanToVisibilityConverter}}">
                        <StackPanel Orientation="Horizontal">
                            <ui:SymbolIcon
                                Margin="0,0,4,0"
                                VerticalAlignment="Center"
                                FontSize="{StaticResource FontSizeXs}"
                                Foreground="{Binding Foreground, RelativeSource={RelativeSource AncestorType=Button}}"
                                Symbol="Add24" />
                            <TextBlock
                                VerticalAlignment="Center"
                                Foreground="{Binding Foreground, RelativeSource={RelativeSource AncestorType=Button}}"
                                Text="{DynamicResource Alerts.AddAlert}" />
                        </StackPanel>
                    </ui:Button>
                </StackPanel>
            </ui:Card>
        </Grid>

        <Border
            Grid.Row="0"
            Grid.RowSpan="4"
            Margin="-24"
            Panel.ZIndex="180"
            Background="{DynamicResource AppModalOverlay}"
            Visibility="{Binding IsFormOpen, Converter={StaticResource BooleanToVisibilityConverter}}" />

        <Border
            Grid.Row="0"
            Grid.RowSpan="4"
            Width="720"
            MaxHeight="520"
            HorizontalAlignment="Center"
            VerticalAlignment="Center"
            Panel.ZIndex="181"
            Style="{StaticResource FormCard}"
            Visibility="{Binding IsFormOpen, Converter={StaticResource BooleanToVisibilityConverter}}">
            <Grid>
                <Grid.RowDefinitions>
                    <RowDefinition Height="Auto" />
                    <RowDefinition Height="Auto" />
                    <RowDefinition Height="Auto" />
                    <RowDefinition Height="Auto" />
                </Grid.RowDefinitions>

                <DockPanel Grid.Row="0" Margin="0,0,0,16">
                    <ui:Button
                        Width="32"
                        Height="32"
                        Padding="0"
                        Command="{Binding CancelAddFormCommand}"
                        DockPanel.Dock="Right"
                        Appearance="Transparent"
                        ToolTip="{DynamicResource Common.Close}">
                        <ui:SymbolIcon FontSize="12" Symbol="Dismiss24" />
                    </ui:Button>
                    <StackPanel>
                        <TextBlock Style="{StaticResource FormSectionTitle}" Text="{DynamicResource Alerts.Form.Title}" />
                        <TextBlock
                            Margin="0,4,0,0"
                            FontSize="{StaticResource FontSizeSm}"
                            Foreground="{DynamicResource AppTextSecondary}"
                            Text="{DynamicResource Alerts.Form.Hint}" />
                    </StackPanel>
                </DockPanel>

                <UniformGrid Grid.Row="1" Columns="2" Rows="2">
                    <StackPanel Margin="0,0,12,12">
                        <TextBlock Foreground="{DynamicResource AppTextSecondary}" Text="{DynamicResource Alerts.Symbol}" />
                        <Grid>
                            <ui:TextBox
                                x:Name="AddAlertSymbolBox"
                                Text="{Binding AddSymbol, UpdateSourceTrigger=PropertyChanged}" />
                            <Popup
                                Width="{Binding ActualWidth, ElementName=AddAlertSymbolBox}"
                                AllowsTransparency="True"
                                IsOpen="{Binding IsSuggestionsOpen}"
                                Placement="Bottom"
                                PlacementTarget="{Binding ElementName=AddAlertSymbolBox}"
                                StaysOpen="True">
                                <Border
                                    Background="{DynamicResource AppSurface}"
                                    BorderBrush="{DynamicResource AppBorder}"
                                    BorderThickness="1"
                                    CornerRadius="{StaticResource RadiusSm}">
                                    <ListBox
                                        MaxHeight="240"
                                        Background="Transparent"
                                        BorderThickness="0"
                                        ItemContainerStyle="{StaticResource StockSuggestionListBoxItemStyle}"
                                        ItemTemplate="{StaticResource StockSuggestionItemTemplate}"
                                        ItemsSource="{Binding SymbolSuggestions}"
                                        ScrollViewer.HorizontalScrollBarVisibility="Disabled"
                                        SelectedItem="{Binding SelectedSuggestion, Mode=TwoWay}" />
                                </Border>
                            </Popup>
                        </Grid>
                    </StackPanel>

                    <StackPanel Margin="0,0,0,12">
                        <TextBlock Foreground="{DynamicResource AppTextSecondary}" Text="{DynamicResource Alerts.Condition}" />
                        <ComboBox ItemsSource="{Binding Conditions}" SelectedItem="{Binding AddCondition}">
                            <ComboBox.ItemTemplate>
                                <DataTemplate>
                                    <TextBlock>
                                        <TextBlock.Style>
                                            <Style TargetType="TextBlock">
                                                <Setter Property="Text" Value="{DynamicResource Alerts.ConditionBelow}" />
                                                <Style.Triggers>
                                                    <DataTrigger Binding="{Binding}" Value="突破">
                                                        <Setter Property="Text" Value="{DynamicResource Alerts.ConditionAbove}" />
                                                    </DataTrigger>
                                                </Style.Triggers>
                                            </Style>
                                        </TextBlock.Style>
                                    </TextBlock>
                                </DataTemplate>
                            </ComboBox.ItemTemplate>
                        </ComboBox>
                    </StackPanel>

                    <StackPanel Margin="0,0,12,0">
                        <TextBlock Foreground="{DynamicResource AppTextSecondary}" Text="{DynamicResource Alerts.TargetPrice}" />
                        <ui:TextBox
                            behaviors:ThousandSeparatorBehavior.IsEnabled="True"
                            Text="{Binding AddTargetPrice, UpdateSourceTrigger=PropertyChanged}" />
                    </StackPanel>
                </UniformGrid>

                <TextBlock
                    Grid.Row="2"
                    Margin="0,8,0,0"
                    Foreground="{DynamicResource AppDanger}"
                    Text="{Binding AddError}"
                    Visibility="{Binding AddError, Converter={StaticResource StringToVisibilityConverter}}" />

                <StackPanel
                    Grid.Row="3"
                    Margin="0,16,0,0"
                    HorizontalAlignment="Right"
                    Orientation="Horizontal">
                    <ui:Button
                        Margin="0,0,8,0"
                        Command="{Binding CancelAddFormCommand}"
                        Content="{DynamicResource Common.Cancel}"
                        Appearance="Secondary" />
                    <ui:Button Command="{Binding AddRuleCommand}" Appearance="Primary">
                        <TextBlock
                            Foreground="{Binding Foreground, RelativeSource={RelativeSource AncestorType=Button}}"
                            Text="{DynamicResource Alerts.AddAlert}" />
                    </ui:Button>
                </StackPanel>
            </Grid>
        </Border>
    </Grid>
</UserControl>
