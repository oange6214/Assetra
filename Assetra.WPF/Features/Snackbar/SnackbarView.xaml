<UserControl
    x:Class="Assetra.WPF.Features.Snackbar.SnackbarView"
    xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
    xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
    xmlns:ui="http://schemas.lepo.co/wpfui/2022/xaml"
    xmlns:d="http://schemas.microsoft.com/expression/blend/2008"
    xmlns:local="clr-namespace:Assetra.WPF.Features.Snackbar"
    xmlns:mc="http://schemas.openxmlformats.org/markup-compatibility/2006"
    d:DataContext="{d:DesignInstance Type={x:Type local:SnackbarViewModel},
                                     IsDesignTimeCreatable=False}"
    IsHitTestVisible="True"
    mc:Ignorable="d">

    <ItemsControl Width="340" ItemsSource="{Binding Items}">
        <ItemsControl.ItemTemplate>
            <DataTemplate DataType="{x:Type local:SnackbarItemViewModel}">
                <Border
                    Margin="0,4,0,0"
                    Background="{DynamicResource AppSurface}"
                    BorderBrush="{DynamicResource AppBorder}"
                    BorderThickness="1"
                    ClipToBounds="True"
                    CornerRadius="{StaticResource RadiusMd}"
                    Loaded="SnackbarItem_Loaded">
                    <Border.Effect>
                        <DropShadowEffect
                            BlurRadius="12"
                            Direction="270"
                            Opacity="0.18"
                            ShadowDepth="2" />
                    </Border.Effect>
                    <Grid MinHeight="48">
                        <!--  Colored left accent bar  -->
                        <Border Width="4" HorizontalAlignment="Left">
                            <Border.Style>
                                <Style TargetType="Border">
                                    <Setter Property="Background" Value="{DynamicResource AppAccent}" />
                                    <Style.Triggers>
                                        <DataTrigger Binding="{Binding Kind}" Value="Success">
                                            <Setter Property="Background" Value="#4CAF50" />
                                        </DataTrigger>
                                        <DataTrigger Binding="{Binding Kind}" Value="Warning">
                                            <Setter Property="Background" Value="#FF9800" />
                                        </DataTrigger>
                                        <DataTrigger Binding="{Binding Kind}" Value="Error">
                                            <Setter Property="Background" Value="#F44336" />
                                        </DataTrigger>
                                    </Style.Triggers>
                                </Style>
                            </Border.Style>
                        </Border>

                        <!--  Content  -->
                        <DockPanel Margin="16,10,8,10">
                            <!--  Dismiss button  -->
                            <ui:Button
                                Width="24"
                                Height="24"
                                Padding="0"
                                VerticalAlignment="Top"
                                Appearance="Transparent"
                                Command="{Binding DismissCommand}"
                                Cursor="Hand"
                                DockPanel.Dock="Right"
                                ToolTip="關閉">
                                <ui:SymbolIcon Symbol="Dismiss24" HorizontalAlignment="Center" VerticalAlignment="Center" FontSize="10" Foreground="{DynamicResource AppTextMuted}" />
                            </ui:Button>

                            <!--  Kind icon  -->
                            <TextBlock
                                Margin="0,0,10,0"
                                VerticalAlignment="Center"
                                DockPanel.Dock="Left"
                                FontFamily="Segoe MDL2 Assets"
                                FontSize="14"
                                Text="{Binding IconGlyph}">
                                <TextBlock.Style>
                                    <Style TargetType="TextBlock">
                                        <Setter Property="Foreground" Value="{DynamicResource AppAccent}" />
                                        <Style.Triggers>
                                            <DataTrigger Binding="{Binding Kind}" Value="Success">
                                                <Setter Property="Foreground" Value="#4CAF50" />
                                            </DataTrigger>
                                            <DataTrigger Binding="{Binding Kind}" Value="Warning">
                                                <Setter Property="Foreground" Value="#FF9800" />
                                            </DataTrigger>
                                            <DataTrigger Binding="{Binding Kind}" Value="Error">
                                                <Setter Property="Foreground" Value="#F44336" />
                                            </DataTrigger>
                                        </Style.Triggers>
                                    </Style>
                                </TextBlock.Style>
                            </TextBlock>

                            <!--  Message text  -->
                            <TextBlock
                                VerticalAlignment="Center"
                                FontFamily="{StaticResource FontBase}"
                                FontSize="{StaticResource FontSizeSm}"
                                Foreground="{DynamicResource AppTextPrimary}"
                                Text="{Binding Text}"
                                TextWrapping="Wrap" />
                        </DockPanel>
                    </Grid>
                </Border>
            </DataTemplate>
        </ItemsControl.ItemTemplate>
    </ItemsControl>
</UserControl>
