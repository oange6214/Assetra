<UserControl
    x:Class="Assetra.WPF.Features.Snackbar.SnackbarView"
    xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
    xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
    xmlns:d="http://schemas.microsoft.com/expression/blend/2008"
    xmlns:ds="clr-namespace:Assetra.WPF.DesignSystem.Controls"
    xmlns:local="clr-namespace:Assetra.WPF.Features.Snackbar"
    xmlns:mc="http://schemas.openxmlformats.org/markup-compatibility/2006"
    d:DataContext="{d:DesignInstance Type={x:Type local:SnackbarViewModel},
                                     IsDesignTimeCreatable=False}"
    IsHitTestVisible="True"
    mc:Ignorable="d">

    <ItemsControl Width="340" ItemsSource="{Binding Items}">
        <ItemsControl.ItemTemplate>
            <DataTemplate DataType="{x:Type local:SnackbarItemViewModel}">
                <!--
                    P2.17 T06 — BorderBrush AppBorder → AppBorderLight 跟 card
                    lightening 一致；Drop shadow 保留作 elevation hint。
                -->
                <Border
                    Margin="0,4,0,0"
                    Background="{DynamicResource AppSurface}"
                    BorderBrush="{DynamicResource AppBorderLight}"
                    BorderThickness="1"
                    ClipToBounds="True"
                    CornerRadius="{StaticResource Radius.Md}"
                    Loaded="SnackbarItem_Loaded">
                    <Border.Effect>
                        <DropShadowEffect
                            BlurRadius="12"
                            Direction="270"
                            Opacity="0.18"
                            ShadowDepth="2" />
                    </Border.Effect>
                    <Grid MinHeight="48">
                        <!--  Colored left accent bar  -->
                        <Border Width="4" HorizontalAlignment="Left">
                            <Border.Style>
                                <Style TargetType="Border">
                                    <Setter Property="Background" Value="{DynamicResource AppAccent}" />
                                    <Style.Triggers>
                                        <DataTrigger Binding="{Binding Kind}" Value="Success">
                                            <Setter Property="Background" Value="#4CAF50" />
                                        </DataTrigger>
                                        <DataTrigger Binding="{Binding Kind}" Value="Warning">
                                            <Setter Property="Background" Value="#FF9800" />
                                        </DataTrigger>
                                        <DataTrigger Binding="{Binding Kind}" Value="Error">
                                            <Setter Property="Background" Value="#F44336" />
                                        </DataTrigger>
                                    </Style.Triggers>
                                </Style>
                            </Border.Style>
                        </Border>

                        <!--  Content  -->
                        <DockPanel Margin="16,10,8,10">
                            <!--  Dismiss button  -->
                            <Button
                                Width="24"
                                Height="24"
                                Padding="0"
                                VerticalAlignment="Top"
                                Command="{Binding DismissCommand}"
                                Cursor="Hand"
                                DockPanel.Dock="Right"
                                Style="{StaticResource AppIconButton}"
                                ToolTip="關閉">
                                <ds:AppIcon
                                    HorizontalAlignment="Center"
                                    VerticalAlignment="Center"
                                    FontSize="10"
                                    Foreground="{DynamicResource AppTextMuted}"
                                    Symbol="Dismiss24" />
                            </Button>

                            <!--  Kind icon  -->
                            <TextBlock
                                Margin="0,0,10,0"
                                VerticalAlignment="Center"
                                DockPanel.Dock="Left"
                                FontFamily="Segoe MDL2 Assets"
                                FontSize="14"
                                Text="{Binding IconGlyph}">
                                <TextBlock.Style>
                                    <Style TargetType="TextBlock">
                                        <Setter Property="Foreground" Value="{DynamicResource AppAccent}" />
                                        <Style.Triggers>
                                            <DataTrigger Binding="{Binding Kind}" Value="Success">
                                                <Setter Property="Foreground" Value="#4CAF50" />
                                            </DataTrigger>
                                            <DataTrigger Binding="{Binding Kind}" Value="Warning">
                                                <Setter Property="Foreground" Value="#FF9800" />
                                            </DataTrigger>
                                            <DataTrigger Binding="{Binding Kind}" Value="Error">
                                                <Setter Property="Foreground" Value="#F44336" />
                                            </DataTrigger>
                                        </Style.Triggers>
                                    </Style>
                                </TextBlock.Style>
                            </TextBlock>

                            <!--  Action button (e.g. 「查看交易」) — visible only when ActionLabel set  -->
                            <Button
                                Margin="8,0,4,0"
                                Padding="10,4"
                                VerticalAlignment="Center"
                                Command="{Binding InvokeActionCommand}"
                                Content="{Binding ActionLabel}"
                                Cursor="Hand"
                                DockPanel.Dock="Right"
                                FontSize="{StaticResource Font.Size.Xs}"
                                FontWeight="SemiBold"
                                Foreground="{DynamicResource AppAccent}"
                                Style="{StaticResource AppGhostButton}"
                                Visibility="{Binding HasAction, Converter={StaticResource BooleanToVisibilityConverter}}" />

                            <!--  Message text  -->
                            <TextBlock
                                VerticalAlignment="Center"
                                FontFamily="{StaticResource Font.Family.Base}"
                                FontSize="{StaticResource Font.Size.Sm}"
                                Foreground="{DynamicResource AppTextPrimary}"
                                Text="{Binding Text}"
                                TextWrapping="Wrap" />
                        </DockPanel>
                    </Grid>
                </Border>
            </DataTemplate>
        </ItemsControl.ItemTemplate>
    </ItemsControl>
</UserControl>
