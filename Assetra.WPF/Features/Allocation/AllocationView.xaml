<UserControl
    x:Class="Assetra.WPF.Features.Allocation.AllocationView"
    xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
    xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
    xmlns:alloccontrols="clr-namespace:Assetra.WPF.Features.Allocation.Controls"
    xmlns:controls="clr-namespace:Assetra.WPF.Infrastructure.Controls"
    xmlns:conv="clr-namespace:Assetra.WPF.Infrastructure.Converters"
    xmlns:d="http://schemas.microsoft.com/expression/blend/2008"
    xmlns:mc="http://schemas.openxmlformats.org/markup-compatibility/2006"
    xmlns:vm="clr-namespace:Assetra.WPF.Features.Allocation"
    d:DataContext="{d:DesignInstance Type={x:Type vm:AllocationViewModel},
                                     IsDesignTimeCreatable=False}"
    d:DesignHeight="776"
    d:DesignWidth="1100"
    Background="{DynamicResource AppBackground}"
    mc:Ignorable="d">

    <UserControl.Resources>
        <BooleanToVisibilityConverter x:Key="BoolToVis" />
        <conv:PercentToWidthConverter x:Key="PctToWidth" />
    </UserControl.Resources>

    <Grid>
        <Grid.RowDefinitions>
            <RowDefinition Height="Auto" />
            <!--  tab bar  -->
            <RowDefinition Height="*" />
            <!--  content  -->
        </Grid.RowDefinitions>

        <!--  ── Tab bar ───────────────────────────────────────────────────  -->
        <Border
            Grid.Row="0"
            Background="{DynamicResource AppSurface}"
            BorderBrush="{DynamicResource AppBorder}"
            BorderThickness="0,0,0,1">
            <StackPanel Margin="16,0" Orientation="Horizontal">
                <RadioButton
                    Command="{Binding SwitchToOverviewCommand}"
                    Content="{DynamicResource Allocation.Tab.Overview}"
                    GroupName="AllocTabs"
                    IsChecked="{Binding IsOverviewTab}"
                    Style="{StaticResource NavTabBtn}" />
                <RadioButton
                    Command="{Binding SwitchToRebalanceCommand}"
                    Content="{DynamicResource Allocation.Tab.Rebalance}"
                    GroupName="AllocTabs"
                    IsChecked="{Binding IsRebalanceTab}"
                    Style="{StaticResource NavTabBtn}" />
            </StackPanel>
        </Border>

        <!--  ── 配置概覽 tab ───────────────────────────────────────────────  -->
        <Grid
            Grid.Row="1"
            d:Visibility="Visible"
            Visibility="{Binding IsOverviewTab, Converter={StaticResource BoolToVis}}">
            <Grid.ColumnDefinitions>
                <ColumnDefinition Width="*" MinWidth="320" />
                <ColumnDefinition Width="*" MinWidth="360" />
            </Grid.ColumnDefinitions>

            <!--  Left: treemap  -->
            <Border
                Grid.Column="0"
                Margin="16,16,8,16"
                Padding="12"
                Background="{DynamicResource AppSurface}"
                BorderBrush="{DynamicResource AppBorder}"
                BorderThickness="1"
                CornerRadius="{StaticResource RadiusSm}">
                <Grid>
                    <Grid.RowDefinitions>
                        <RowDefinition Height="Auto" />
                        <RowDefinition Height="*" />
                    </Grid.RowDefinitions>

                    <TextBlock
                        Grid.Row="0"
                        Margin="0,0,0,10"
                        FontSize="{StaticResource FontSizeMd}"
                        FontWeight="SemiBold"
                        Foreground="{DynamicResource AppTextPrimary}"
                        Text="{DynamicResource Allocation.Overview.Title}" />

                    <!--  Treemap  -->
                    <!--
                        UseLayoutRounding forces WPF to snap all layout coordinates to whole
                        device pixels before compositing, so no sub-pixel hairlines appear
                        between tiles regardless of DPI scaling.
                    -->
                    <ItemsControl
                        Grid.Row="1"
                        ItemsSource="{Binding AllocationRows}"
                        UseLayoutRounding="True">
                        <ItemsControl.ItemsPanel>
                            <ItemsPanelTemplate>
                                <controls:TreemapPanel />
                            </ItemsPanelTemplate>
                        </ItemsControl.ItemsPanel>
                        <!--
                            IMPORTANT: ItemsControl wraps each DataTemplate root in a ContentPresenter.
                            TreemapPanel.ArrangeOverride reads Weight from its direct children
                            (ContentPresenter), NOT from the Border inside the DataTemplate.
                            Setting Weight here — on ContentPresenter via ItemContainerStyle —
                            is what actually drives the proportional tile sizes.
                        -->
                        <ItemsControl.ItemContainerStyle>
                            <Style TargetType="ContentPresenter">
                                <Setter Property="controls:TreemapPanel.Weight" Value="{Binding ActualPercentWeight}" />
                            </Style>
                        </ItemsControl.ItemContainerStyle>
                        <ItemsControl.ItemTemplate>
                            <DataTemplate DataType="{x:Type vm:AllocationRowViewModel}">
                                <!--
                                    Flat tile — no CornerRadius, no Border.
                                    CornerRadius creates larger apparent gaps at 4-tile corners
                                    (each arc bites into the gutter) vs. straight edges, giving
                                    the illusion of uneven spacing even when gaps are pixel-exact.
                                    BorderThickness adds asymmetry: interior edges get +2 px (one
                                    per side) while panel edges only get +1 px.
                                    Gap is handled solely by TreemapPanel's halfGap inset.
                                -->
                                <Border
                                    controls:ToolTipBehavior.FollowMouse="True"
                                    Background="{Binding PnlColorBrush}"
                                    ClipToBounds="True">
                                    <Border.ToolTip>
                                        <ToolTip>
                                            <StackPanel MinWidth="160">
                                                <!--  Symbol + name  -->
                                                <TextBlock
                                                    FontSize="{StaticResource FontSizeSm}"
                                                    FontWeight="SemiBold"
                                                    Text="{Binding Symbol}" />
                                                <TextBlock
                                                    Margin="0,1,0,6"
                                                    FontSize="{StaticResource FontSizeXs}"
                                                    Foreground="{DynamicResource AppTextMuted}"
                                                    Text="{Binding Name}" />
                                                <!--  Market value  -->
                                                <DockPanel Margin="0,2,0,0">
                                                    <TextBlock
                                                        DockPanel.Dock="Left"
                                                        FontSize="{StaticResource FontSizeXs}"
                                                        Text="市值" />
                                                    <TextBlock
                                                        HorizontalAlignment="Right"
                                                        FontFamily="{StaticResource FontTabular}"
                                                        FontSize="{StaticResource FontSizeXs}"
                                                        FontWeight="SemiBold"
                                                        Text="{Binding MarketValue, StringFormat='NT\${0:N0}'}" />
                                                </DockPanel>
                                                <!--  Actual allocation %  -->
                                                <DockPanel Margin="0,2,0,0">
                                                    <TextBlock
                                                        DockPanel.Dock="Left"
                                                        FontSize="{StaticResource FontSizeXs}"
                                                        Text="實際比例" />
                                                    <TextBlock
                                                        HorizontalAlignment="Right"
                                                        FontFamily="{StaticResource FontTabular}"
                                                        FontSize="{StaticResource FontSizeXs}"
                                                        FontWeight="SemiBold"
                                                        Text="{Binding ActualPercentDisplay}" />
                                                </DockPanel>
                                                <!--  PnL  -->
                                                <DockPanel Margin="0,2,0,0">
                                                    <TextBlock
                                                        DockPanel.Dock="Left"
                                                        FontSize="{StaticResource FontSizeXs}"
                                                        Text="損益" />
                                                    <TextBlock
                                                        HorizontalAlignment="Right"
                                                        FontFamily="{StaticResource FontTabular}"
                                                        FontSize="{StaticResource FontSizeXs}"
                                                        FontWeight="SemiBold"
                                                        Text="{Binding PnlDisplay}" />
                                                </DockPanel>
                                                <!--  PnL %  -->
                                                <DockPanel Margin="0,2,0,0">
                                                    <TextBlock
                                                        DockPanel.Dock="Left"
                                                        FontSize="{StaticResource FontSizeXs}"
                                                        Text="損益率" />
                                                    <TextBlock
                                                        HorizontalAlignment="Right"
                                                        FontFamily="{StaticResource FontTabular}"
                                                        FontSize="{StaticResource FontSizeXs}"
                                                        FontWeight="SemiBold"
                                                        Text="{Binding PnlPercentDisplay}" />
                                                </DockPanel>
                                            </StackPanel>
                                        </ToolTip>
                                    </Border.ToolTip>
                                    <StackPanel
                                        Margin="4"
                                        HorizontalAlignment="Center"
                                        VerticalAlignment="Center">
                                        <TextBlock
                                            HorizontalAlignment="Center"
                                            FontSize="{StaticResource FontSizeSm}"
                                            FontWeight="SemiBold"
                                            Foreground="{DynamicResource AppTextOnAccent}"
                                            Text="{Binding Symbol}"
                                            TextTrimming="CharacterEllipsis" />
                                        <TextBlock
                                            HorizontalAlignment="Center"
                                            FontSize="{StaticResource FontSizeXs}"
                                            Foreground="{DynamicResource AppTextOnAccent}"
                                            Text="{Binding ActualPercentDisplay}" />
                                        <TextBlock
                                            HorizontalAlignment="Center"
                                            FontSize="{StaticResource FontSizeXs}"
                                            FontWeight="SemiBold"
                                            Foreground="{DynamicResource AppTextOnAccent}"
                                            Text="{Binding PnlPercentTreemap}" />
                                    </StackPanel>
                                </Border>
                            </DataTemplate>
                        </ItemsControl.ItemTemplate>
                    </ItemsControl>
                </Grid>
            </Border>

            <!--  Right: asset list DataGrid  -->
            <DataGrid
                Grid.Column="1"
                Margin="8,16,16,16"
                AutoGenerateColumns="False"
                Background="{DynamicResource AppBackground}"
                BorderThickness="0"
                CanUserAddRows="False"
                CanUserDeleteRows="False"
                CanUserReorderColumns="False"
                CanUserResizeColumns="False"
                CanUserSortColumns="True"
                ColumnHeaderHeight="{StaticResource DataGridHeaderHeight}"
                EnableRowVirtualization="True"
                FontFamily="{StaticResource FontBase}"
                FontSize="{StaticResource FontSizeSm}"
                Foreground="{DynamicResource AppTextPrimary}"
                GridLinesVisibility="None"
                HeadersVisibility="Column"
                HorizontalScrollBarVisibility="Disabled"
                IsReadOnly="True"
                ItemsSource="{Binding AllocationRows}"
                RowHeight="{StaticResource DataGridRowHeight}"
                SelectionMode="Single"
                VirtualizingPanel.IsVirtualizing="True"
                VirtualizingPanel.VirtualizationMode="Recycling">

                <DataGrid.ColumnHeaderStyle>
                    <Style BasedOn="{StaticResource AppDataGridColHeader}" TargetType="DataGridColumnHeader" />
                </DataGrid.ColumnHeaderStyle>
                <DataGrid.CellStyle>
                    <Style BasedOn="{StaticResource AppDataGridCell}" TargetType="DataGridCell" />
                </DataGrid.CellStyle>
                <DataGrid.RowStyle>
                    <Style BasedOn="{StaticResource AppDataGridRow}" TargetType="DataGridRow" />
                </DataGrid.RowStyle>

                <DataGrid.Columns>

                    <!--  資產 (Symbol + Name)  -->
                    <DataGridTemplateColumn
                        Width="*"
                        MinWidth="100"
                        SortMemberPath="Symbol">
                        <DataGridTemplateColumn.Header>
                            <TextBlock Text="{DynamicResource Allocation.Col.Asset}" />
                        </DataGridTemplateColumn.Header>
                        <DataGridTemplateColumn.CellTemplate>
                            <DataTemplate DataType="{x:Type vm:AllocationRowViewModel}">
                                <StackPanel Margin="8,0" VerticalAlignment="Center">
                                    <DockPanel>
                                        <Border
                                            Width="10"
                                            Height="10"
                                            Margin="0,0,6,0"
                                            VerticalAlignment="Center"
                                            Background="{Binding ColorBrush}"
                                            CornerRadius="2" />
                                        <TextBlock
                                            FontSize="{StaticResource FontSizeSm}"
                                            FontWeight="SemiBold"
                                            Foreground="{DynamicResource AppTextPrimary}"
                                            Text="{Binding Symbol}" />
                                    </DockPanel>
                                    <TextBlock
                                        Margin="16,1,0,0"
                                        FontSize="{StaticResource FontSizeXs}"
                                        Foreground="{DynamicResource AppTextMuted}"
                                        Text="{Binding Name}"
                                        TextTrimming="CharacterEllipsis" />
                                </StackPanel>
                            </DataTemplate>
                        </DataGridTemplateColumn.CellTemplate>
                    </DataGridTemplateColumn>

                    <!--  現價  -->
                    <DataGridTemplateColumn Width="80" SortMemberPath="CurrentPrice">
                        <DataGridTemplateColumn.HeaderStyle>
                            <Style BasedOn="{StaticResource AppDataGridColHeader}" TargetType="DataGridColumnHeader">
                                <Setter Property="HorizontalContentAlignment" Value="Right" />
                            </Style>
                        </DataGridTemplateColumn.HeaderStyle>
                        <DataGridTemplateColumn.Header>
                            <TextBlock Text="{DynamicResource Allocation.Col.Price}" />
                        </DataGridTemplateColumn.Header>
                        <DataGridTemplateColumn.CellTemplate>
                            <DataTemplate DataType="{x:Type vm:AllocationRowViewModel}">
                                <TextBlock
                                    Margin="0,0,8,0"
                                    HorizontalAlignment="Right"
                                    VerticalAlignment="Center"
                                    FontFamily="{StaticResource FontTabular}"
                                    FontSize="{StaticResource FontSizeXs}"
                                    Foreground="{DynamicResource AppTextSecondary}"
                                    Text="{Binding CurrentPrice, StringFormat='NT\${0:N0}'}" />
                            </DataTemplate>
                        </DataGridTemplateColumn.CellTemplate>
                    </DataGridTemplateColumn>

                    <!--  市值 + allocation bar  -->
                    <DataGridTemplateColumn Width="140" SortMemberPath="MarketValue">
                        <DataGridTemplateColumn.HeaderStyle>
                            <Style BasedOn="{StaticResource AppDataGridColHeader}" TargetType="DataGridColumnHeader">
                                <Setter Property="HorizontalContentAlignment" Value="Right" />
                            </Style>
                        </DataGridTemplateColumn.HeaderStyle>
                        <DataGridTemplateColumn.Header>
                            <TextBlock Text="{DynamicResource Allocation.Col.Value}" />
                        </DataGridTemplateColumn.Header>
                        <DataGridTemplateColumn.CellTemplate>
                            <DataTemplate DataType="{x:Type vm:AllocationRowViewModel}">
                                <TextBlock
                                    Margin="0,0,8,0"
                                    HorizontalAlignment="Right"
                                    VerticalAlignment="Center"
                                    FontFamily="{StaticResource FontTabular}"
                                    FontSize="{StaticResource FontSizeSm}"
                                    FontWeight="SemiBold"
                                    Foreground="{DynamicResource AppTextPrimary}"
                                    Text="{Binding MarketValue, StringFormat='NT\${0:N0}'}" />
                            </DataTemplate>
                        </DataGridTemplateColumn.CellTemplate>
                    </DataGridTemplateColumn>

                    <!--  實際比例%  -->
                    <DataGridTemplateColumn Width="72" SortMemberPath="ActualPercent">
                        <DataGridTemplateColumn.HeaderStyle>
                            <Style BasedOn="{StaticResource AppDataGridColHeader}" TargetType="DataGridColumnHeader">
                                <Setter Property="HorizontalContentAlignment" Value="Right" />
                            </Style>
                        </DataGridTemplateColumn.HeaderStyle>
                        <DataGridTemplateColumn.Header>
                            <TextBlock Text="{DynamicResource Allocation.Col.ActualPct}" />
                        </DataGridTemplateColumn.Header>
                        <DataGridTemplateColumn.CellTemplate>
                            <DataTemplate DataType="{x:Type vm:AllocationRowViewModel}">
                                <TextBlock
                                    Margin="0,0,8,0"
                                    HorizontalAlignment="Right"
                                    VerticalAlignment="Center"
                                    FontFamily="{StaticResource FontTabular}"
                                    FontSize="{StaticResource FontSizeSm}"
                                    FontWeight="SemiBold"
                                    Foreground="{DynamicResource AppTextPrimary}"
                                    Text="{Binding ActualPercentDisplay}" />
                            </DataTemplate>
                        </DataGridTemplateColumn.CellTemplate>
                    </DataGridTemplateColumn>

                    <!--  淨損益  -->
                    <DataGridTemplateColumn Width="130" SortMemberPath="Pnl">
                        <DataGridTemplateColumn.HeaderStyle>
                            <Style BasedOn="{StaticResource AppDataGridColHeader}" TargetType="DataGridColumnHeader">
                                <Setter Property="HorizontalContentAlignment" Value="Right" />
                            </Style>
                        </DataGridTemplateColumn.HeaderStyle>
                        <DataGridTemplateColumn.Header>
                            <TextBlock Text="{DynamicResource Allocation.Col.TotalPnl}" />
                        </DataGridTemplateColumn.Header>
                        <DataGridTemplateColumn.CellTemplate>
                            <DataTemplate DataType="{x:Type vm:AllocationRowViewModel}">
                                <StackPanel
                                    Margin="0,0,8,0"
                                    HorizontalAlignment="Right"
                                    VerticalAlignment="Center">
                                    <TextBlock
                                        HorizontalAlignment="Right"
                                        FontFamily="{StaticResource FontTabular}"
                                        FontSize="{StaticResource FontSizeSm}"
                                        FontWeight="SemiBold">
                                        <TextBlock.Style>
                                            <Style TargetType="TextBlock">
                                                <Setter Property="Foreground" Value="{DynamicResource AppDown}" />
                                                <Style.Triggers>
                                                    <DataTrigger Binding="{Binding IsPnlPositive}" Value="True">
                                                        <Setter Property="Foreground" Value="{DynamicResource AppUp}" />
                                                    </DataTrigger>
                                                </Style.Triggers>
                                            </Style>
                                        </TextBlock.Style>
                                        <Run Text="{Binding PnlDisplay, Mode=OneWay}" />
                                    </TextBlock>
                                    <TextBlock
                                        HorizontalAlignment="Right"
                                        FontSize="{StaticResource FontSizeXs}"
                                        Foreground="{DynamicResource AppTextMuted}"
                                        Text="{Binding PnlPercentDisplay}" />
                                </StackPanel>
                            </DataTemplate>
                        </DataGridTemplateColumn.CellTemplate>
                    </DataGridTemplateColumn>

                </DataGrid.Columns>
            </DataGrid>
        </Grid>

        <!--  ── 再平衡 tab ──────────────────────────────────────────────────  -->
        <Grid
            Grid.Row="1"
            d:Visibility="Collapsed"
            Visibility="{Binding IsRebalanceTab, Converter={StaticResource BoolToVis}}">
            <Grid.RowDefinitions>
                <RowDefinition Height="Auto" />
                <!--  header card  -->
                <RowDefinition Height="Auto" />
                <!--  cash-flow info bar  -->
                <RowDefinition Height="Auto" />
                <!--  column headers  -->
                <RowDefinition Height="*" />
                <!--  rows  -->
            </Grid.RowDefinitions>

            <!--  Header card  -->
            <Border
                Grid.Row="0"
                Margin="16,16,16,12"
                Padding="16,12"
                Background="{DynamicResource AppSurface}"
                BorderBrush="{DynamicResource AppBorder}"
                BorderThickness="1"
                CornerRadius="{StaticResource RadiusSm}">
                <DockPanel>
                    <StackPanel DockPanel.Dock="Left">
                        <TextBlock
                            FontSize="{StaticResource FontSizeMd}"
                            FontWeight="SemiBold"
                            Foreground="{DynamicResource AppTextPrimary}"
                            Text="{DynamicResource Allocation.Rebalance.Title}" />
                        <TextBlock
                            Margin="0,2,0,0"
                            FontSize="{StaticResource FontSizeXs}"
                            Foreground="{DynamicResource AppTextMuted}"
                            Text="{DynamicResource Allocation.Rebalance.Subtitle}" />
                    </StackPanel>
                    <StackPanel
                        HorizontalAlignment="Right"
                        DockPanel.Dock="Right"
                        Orientation="Horizontal">
                        <!--  完整再平衡 / 現金流再平衡 toggle  -->
                        <Border
                            Margin="0,0,12,0"
                            Padding="2"
                            Background="{DynamicResource AppBackground}"
                            BorderBrush="{DynamicResource AppBorder}"
                            BorderThickness="1"
                            CornerRadius="{StaticResource RadiusSm}">
                            <StackPanel Orientation="Horizontal">
                                <RadioButton
                                    Command="{Binding SetFullRebalanceCommand}"
                                    Content="{DynamicResource Allocation.Rebalance.Full}"
                                    GroupName="RebalanceMode"
                                    IsChecked="{Binding IsFullRebalance}"
                                    Style="{StaticResource NavTabBtn}" />
                                <RadioButton
                                    Command="{Binding SetCashRebalanceCommand}"
                                    Content="{DynamicResource Allocation.Rebalance.CashFlow}"
                                    GroupName="RebalanceMode"
                                    IsChecked="{Binding IsCashRebalance}"
                                    Style="{StaticResource NavTabBtn}" />
                            </StackPanel>
                        </Border>
                        <!--  編輯目標配置  -->
                        <Button
                            Height="28"
                            Padding="10,0"
                            Command="{Binding BeginEditTargetsCommand}"
                            Style="{StaticResource BtnGhost}">
                            <TextBlock Text="{DynamicResource Allocation.Rebalance.EditTargets}" />
                        </Button>
                    </StackPanel>
                </DockPanel>
            </Border>

            <!--  Cash-flow info bar (only when IsCashRebalance)  -->
            <Border
                Grid.Row="1"
                Margin="16,0,16,8"
                Padding="14,10"
                Background="{DynamicResource AppSurface}"
                BorderBrush="{DynamicResource AppBorder}"
                BorderThickness="1"
                CornerRadius="{StaticResource RadiusSm}"
                Visibility="{Binding IsCashRebalance, Converter={StaticResource BoolToVis}}">
                <DockPanel>
                    <StackPanel
                        VerticalAlignment="Center"
                        DockPanel.Dock="Left"
                        Orientation="Horizontal">
                        <TextBlock
                            Margin="0,0,6,0"
                            VerticalAlignment="Center"
                            FontSize="{StaticResource FontSizeBase}"
                            Text="💰" />
                        <StackPanel>
                            <TextBlock
                                FontSize="{StaticResource FontSizeSm}"
                                FontWeight="SemiBold"
                                Foreground="{DynamicResource AppTextPrimary}"
                                Text="{DynamicResource Allocation.Rebalance.CashFlow}" />
                            <TextBlock
                                FontSize="{StaticResource FontSizeXs}"
                                Foreground="{DynamicResource AppTextMuted}"
                                Text="{DynamicResource Allocation.CashFlow.Desc}" />
                        </StackPanel>
                    </StackPanel>
                    <StackPanel
                        HorizontalAlignment="Right"
                        VerticalAlignment="Center"
                        DockPanel.Dock="Right"
                        Orientation="Horizontal">
                        <!--  總計顯示  -->
                        <Border
                            Margin="16,0,0,0"
                            Padding="10,4"
                            Background="{DynamicResource AppAccent}"
                            CornerRadius="{StaticResource RadiusSm}">
                            <TextBlock
                                VerticalAlignment="Center"
                                FontFamily="{StaticResource FontTabular}"
                                FontSize="{StaticResource FontSizeSm}"
                                FontWeight="SemiBold"
                                Foreground="{DynamicResource AppTextOnAccent}">
                                <Run Text="{DynamicResource Allocation.CashFlow.Total}" />
                                <Run Text="{Binding CashFlowTotalDisplay, Mode=OneWay}" />
                            </TextBlock>
                        </Border>
                        <!--  貨幣選擇（固定 TWD 顯示）  -->
                        <Border
                            Margin="8,0,0,0"
                            Padding="8,4"
                            Background="{DynamicResource AppBackground}"
                            BorderBrush="{DynamicResource AppBorder}"
                            BorderThickness="1"
                            CornerRadius="{StaticResource RadiusSm}">
                            <TextBlock
                                VerticalAlignment="Center"
                                FontSize="{StaticResource FontSizeXs}"
                                Foreground="{DynamicResource AppTextSecondary}"
                                Text="TWD" />
                        </Border>
                        <!--  輸入框  -->
                        <TextBlock
                            Margin="16,0,8,0"
                            VerticalAlignment="Center"
                            FontSize="{StaticResource FontSizeXs}"
                            Foreground="{DynamicResource AppTextSecondary}"
                            Text="{DynamicResource Allocation.CashFlow.InputLabel}" />
                        <TextBox
                            Width="100"
                            HorizontalContentAlignment="Right"
                            FontFamily="{StaticResource FontTabular}"
                            Style="{StaticResource FormTextBox}"
                            Text="{Binding CashFlowInput, UpdateSourceTrigger=PropertyChanged}" />
                    </StackPanel>
                </DockPanel>
            </Border>

            <!--  Rebalance DataGrid (extracted)  -->
            <alloccontrols:RebalanceDataGrid Grid.Row="2" Grid.RowSpan="2" />
        </Grid>

        <!--  ── 編輯目標配置 overlay ────────────────────────────────────────  -->
        <alloccontrols:EditTargetsOverlay Grid.Row="0" Grid.RowSpan="2" />
    </Grid>
</UserControl>
