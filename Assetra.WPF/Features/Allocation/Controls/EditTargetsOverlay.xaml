<UserControl
    x:Class="Assetra.WPF.Features.Allocation.Controls.EditTargetsOverlay"
    xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
    xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
    xmlns:d="http://schemas.microsoft.com/expression/blend/2008"
    xmlns:mc="http://schemas.openxmlformats.org/markup-compatibility/2006"
    xmlns:vm="clr-namespace:Assetra.WPF.Features.Allocation"
    d:DataContext="{d:DesignInstance Type={x:Type vm:AllocationViewModel},
                                     IsDesignTimeCreatable=False}"
    mc:Ignorable="d">

    <UserControl.Resources>
        <BooleanToVisibilityConverter x:Key="BoolToVis" />
    </UserControl.Resources>

    <!--  ── 編輯目標配置 overlay ────────────────────────────────────────  -->
    <Grid
        Background="#80000000"
        Visibility="{Binding IsEditingTargets, Converter={StaticResource BoolToVis}}">
        <Border
            Width="420"
            MaxHeight="560"
            Padding="0"
            HorizontalAlignment="Center"
            VerticalAlignment="Center"
            Background="{DynamicResource AppSurface}"
            BorderBrush="{DynamicResource AppBorder}"
            BorderThickness="1"
            CornerRadius="{StaticResource RadiusSm}">
            <Grid>
                <Grid.RowDefinitions>
                    <RowDefinition Height="Auto" />
                    <RowDefinition Height="*" />
                    <RowDefinition Height="Auto" />
                    <RowDefinition Height="Auto" />
                </Grid.RowDefinitions>

                <!--  Title  -->
                <Border
                    Grid.Row="0"
                    Padding="20,16"
                    BorderBrush="{DynamicResource AppBorder}"
                    BorderThickness="0,0,0,1">
                    <TextBlock
                        FontSize="{StaticResource FontSizeMd}"
                        FontWeight="SemiBold"
                        Foreground="{DynamicResource AppTextPrimary}"
                        Text="{DynamicResource Allocation.EditTargets.Title}" />
                </Border>

                <!--  Per-asset inputs  -->
                <ScrollViewer
                    Grid.Row="1"
                    Padding="20,12"
                    VerticalScrollBarVisibility="Auto">
                    <ItemsControl ItemsSource="{Binding AllocationRows}">
                        <ItemsControl.ItemTemplate>
                            <DataTemplate DataType="{x:Type vm:AllocationRowViewModel}">
                                <DockPanel Margin="0,0,0,8">
                                    <StackPanel
                                        Width="160"
                                        VerticalAlignment="Center"
                                        DockPanel.Dock="Left">
                                        <TextBlock
                                            FontSize="{StaticResource FontSizeSm}"
                                            FontWeight="SemiBold"
                                            Foreground="{DynamicResource AppTextPrimary}"
                                            Text="{Binding Symbol}" />
                                        <TextBlock
                                            FontSize="{StaticResource FontSizeXs}"
                                            Foreground="{DynamicResource AppTextSecondary}"
                                            Text="{Binding ActualPercentDisplay}"
                                            TextTrimming="CharacterEllipsis" />
                                    </StackPanel>
                                    <TextBlock
                                        Margin="8,0,0,0"
                                        VerticalAlignment="Center"
                                        DockPanel.Dock="Right"
                                        FontSize="{StaticResource FontSizeSm}"
                                        Foreground="{DynamicResource AppTextSecondary}"
                                        Text="%" />
                                    <TextBox
                                        HorizontalContentAlignment="Right"
                                        FontFamily="{StaticResource FontTabular}"
                                        Style="{StaticResource FormTextBox}"
                                        Text="{Binding EditTargetText, UpdateSourceTrigger=PropertyChanged}" />
                                </DockPanel>
                            </DataTemplate>
                        </ItemsControl.ItemTemplate>
                    </ItemsControl>
                </ScrollViewer>

                <!--  Error  -->
                <TextBlock
                    Grid.Row="2"
                    Margin="20,0,20,4"
                    FontSize="{StaticResource FontSizeXs}"
                    Foreground="{DynamicResource AppDown}"
                    Text="{Binding TargetEditError}"
                    TextWrapping="Wrap"
                    Visibility="{Binding TargetEditError, Converter={StaticResource StringToVisibilityConverter}}" />

                <!--  Buttons  -->
                <Border
                    Grid.Row="3"
                    Padding="20,12"
                    BorderBrush="{DynamicResource AppBorder}"
                    BorderThickness="0,1,0,0">
                    <StackPanel HorizontalAlignment="Right" Orientation="Horizontal">
                        <Button
                            Height="28"
                            Margin="0,0,8,0"
                            Padding="12,0"
                            Command="{Binding CancelEditTargetsCommand}"
                            Style="{StaticResource BtnGhost}">
                            <TextBlock Text="{DynamicResource Common.Cancel}" />
                        </Button>
                        <Button
                            Height="28"
                            Padding="12,0"
                            Command="{Binding SaveTargetsCommand}"
                            Style="{StaticResource BtnPrimary}">
                            <TextBlock Text="{DynamicResource Common.Save}" />
                        </Button>
                    </StackPanel>
                </Border>
            </Grid>
        </Border>
    </Grid>
</UserControl>
