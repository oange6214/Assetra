<UserControl
    x:Class="Assetra.WPF.Features.Assistant.AssistantView"
    xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
    xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
    xmlns:d="http://schemas.microsoft.com/expression/blend/2008"
    xmlns:mc="http://schemas.openxmlformats.org/markup-compatibility/2006"
    xmlns:vm="clr-namespace:Assetra.WPF.Features.Assistant"
    d:DataContext="{d:DesignInstance Type={x:Type vm:AssistantViewModel}}"
    Background="{DynamicResource AppBackground}"
    mc:Ignorable="d">

    <Grid Margin="20">
        <Grid.RowDefinitions>
            <RowDefinition Height="Auto" />
            <RowDefinition Height="*" />
            <RowDefinition Height="Auto" />
        </Grid.RowDefinitions>

        <!--  Header  -->
        <StackPanel Grid.Row="0" Margin="0,0,0,16">
            <TextBlock
                FontSize="{StaticResource Font.Size.Lg}"
                FontWeight="SemiBold"
                Foreground="{DynamicResource AppTextPrimary}"
                Text="{DynamicResource Assistant.Title}" />
            <TextBlock
                Margin="0,4,0,0"
                Foreground="{DynamicResource AppTextSecondary}"
                Text="{DynamicResource Assistant.Subtitle}"
                TextWrapping="Wrap" />
        </StackPanel>

        <!--  Chat area  -->
        <Border
            Grid.Row="1"
            Padding="0"
            Background="{DynamicResource AppSurface}"
            BorderBrush="{DynamicResource AppBorder}"
            BorderThickness="1"
            CornerRadius="{StaticResource Radius.Md}">
            <Grid>
                <!--  Empty state  -->
                <StackPanel
                    Margin="32"
                    HorizontalAlignment="Center"
                    VerticalAlignment="Center"
                    Visibility="{Binding HasNoMessages, Converter={StaticResource BooleanToVisibilityConverter}}">
                    <TextBlock
                        Margin="0,0,0,16"
                        HorizontalAlignment="Center"
                        FontSize="{StaticResource Font.Size.Md}"
                        Foreground="{DynamicResource AppTextSecondary}"
                        Text="{DynamicResource Assistant.EmptyState}"
                        TextWrapping="Wrap" />
                    <ItemsControl HorizontalAlignment="Center" ItemsSource="{Binding SuggestedQueries}">
                        <ItemsControl.ItemsPanel>
                            <ItemsPanelTemplate>
                                <WrapPanel HorizontalAlignment="Center" />
                            </ItemsPanelTemplate>
                        </ItemsControl.ItemsPanel>
                        <ItemsControl.ItemTemplate>
                            <DataTemplate>
                                <Button
                                    Margin="4"
                                    Padding="12,6"
                                    Command="{Binding DataContext.UseSuggestionCommand, RelativeSource={RelativeSource AncestorType=UserControl}}"
                                    CommandParameter="{Binding}"
                                    Content="{Binding}"
                                    Style="{StaticResource AppSecondaryButton}" />
                            </DataTemplate>
                        </ItemsControl.ItemTemplate>
                    </ItemsControl>
                </StackPanel>

                <!--  Messages  -->
                <ScrollViewer
                    Padding="16"
                    HorizontalScrollBarVisibility="Disabled"
                    VerticalScrollBarVisibility="Auto"
                    Visibility="{Binding HasMessages, Converter={StaticResource BooleanToVisibilityConverter}}">
                    <ItemsControl ItemsSource="{Binding Messages}">
                        <ItemsControl.ItemTemplate>
                            <DataTemplate>
                                <Border
                                    Margin="0,0,0,8"
                                    Padding="12,8"
                                    BorderBrush="{DynamicResource AppBorder}"
                                    BorderThickness="1"
                                    CornerRadius="{StaticResource Radius.Md}">
                                    <Border.Style>
                                        <Style TargetType="Border">
                                            <Setter Property="HorizontalAlignment" Value="Stretch" />
                                            <Setter Property="Background" Value="{DynamicResource AppSurfaceAlt}" />
                                            <Style.Triggers>
                                                <DataTrigger Binding="{Binding IsUser}" Value="True">
                                                    <Setter Property="Background" Value="{DynamicResource AppAccentSoft}" />
                                                    <Setter Property="HorizontalAlignment" Value="Right" />
                                                </DataTrigger>
                                            </Style.Triggers>
                                        </Style>
                                    </Border.Style>
                                    <StackPanel>
                                        <TextBlock
                                            FontFamily="{StaticResource Font.Family.Base}"
                                            Foreground="{DynamicResource AppTextPrimary}"
                                            Text="{Binding Text}"
                                            TextWrapping="Wrap" />
                                        <TextBlock
                                            Margin="0,4,0,0"
                                            FontSize="{StaticResource Font.Size.Xs}"
                                            FontStyle="Italic"
                                            Foreground="{DynamicResource AppTextMuted}"
                                            Text="{Binding Source, StringFormat=資料來源：{0}}"
                                            Visibility="{Binding HasSource, Converter={StaticResource BooleanToVisibilityConverter}}" />
                                    </StackPanel>
                                </Border>
                            </DataTemplate>
                        </ItemsControl.ItemTemplate>
                    </ItemsControl>
                </ScrollViewer>

                <!--  Busy indicator  -->
                <ProgressBar
                    Width="180"
                    Height="3"
                    HorizontalAlignment="Center"
                    VerticalAlignment="Bottom"
                    Margin="0,0,0,8"
                    IsIndeterminate="True"
                    Visibility="{Binding IsAnswering, Converter={StaticResource BooleanToVisibilityConverter}}" />
            </Grid>
        </Border>

        <!--  Input  -->
        <Grid Grid.Row="2" Margin="0,16,0,0">
            <Grid.ColumnDefinitions>
                <ColumnDefinition Width="*" />
                <ColumnDefinition Width="Auto" />
                <ColumnDefinition Width="Auto" />
            </Grid.ColumnDefinitions>
            <TextBox
                Grid.Column="0"
                Padding="10,8"
                FontSize="{StaticResource Font.Size.Sm}"
                Text="{Binding InputText, UpdateSourceTrigger=PropertyChanged}">
                <TextBox.InputBindings>
                    <KeyBinding Key="Enter" Command="{Binding SendCommand}" />
                </TextBox.InputBindings>
            </TextBox>
            <Button
                Grid.Column="1"
                Margin="8,0,0,0"
                Command="{Binding SendCommand}"
                Content="{DynamicResource Assistant.Send}"
                Style="{StaticResource AppPrimaryButton}" />
            <Button
                Grid.Column="2"
                Margin="8,0,0,0"
                Command="{Binding ClearConversationCommand}"
                Content="{DynamicResource Assistant.Clear}"
                Style="{StaticResource AppSecondaryButton}"
                Visibility="{Binding HasMessages, Converter={StaticResource BooleanToVisibilityConverter}}" />
        </Grid>
    </Grid>
</UserControl>
