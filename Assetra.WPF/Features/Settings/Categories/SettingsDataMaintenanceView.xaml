<UserControl
    x:Class="Assetra.WPF.Features.Settings.Categories.SettingsDataMaintenanceView"
    xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
    xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
    xmlns:d="http://schemas.microsoft.com/expression/blend/2008"
    xmlns:mc="http://schemas.openxmlformats.org/markup-compatibility/2006"
    xmlns:vm="clr-namespace:Assetra.WPF.Features.Settings"
    d:DataContext="{d:DesignInstance Type={x:Type vm:SettingsViewModel}, IsDesignTimeCreatable=False}"
    mc:Ignorable="d">

    <StackPanel HorizontalAlignment="Stretch">
        <!--  ── 資料與維護 ──  -->
        <TextBlock
            Margin="0,0,0,8"
            FontSize="{StaticResource Font.Size.Md}"
            FontWeight="SemiBold"
            Foreground="{DynamicResource AppTextPrimary}"
            Text="{DynamicResource Settings.Section.DataMaintenance}" />

        <Border Style="{StaticResource FormCard}"
            Margin="0,0,0,24"
            Padding="16,12">
            <StackPanel>
                <StackPanel Margin="0,0,0,14">
                    <TextBlock Foreground="{DynamicResource AppTextPrimary}" Text="{DynamicResource Settings.DataDir}" />
                    <StackPanel Margin="0,8,0,0">
                        <TextBlock
                            Margin="0,0,0,8"
                            FontSize="{StaticResource Font.Size.Xs}"
                            Foreground="{DynamicResource AppTextMuted}"
                            Text="{Binding DataFolderPath}"
                            TextWrapping="Wrap" />
                        <Button
                            HorizontalAlignment="Left"
                            Command="{Binding OpenDataFolderCommand}"
                            Content="{DynamicResource Settings.OpenDir}" Style="{StaticResource AppSecondaryButton}" />
                    </StackPanel>
                </StackPanel>

                <StackPanel Margin="0,0,0,14">
                    <TextBlock Foreground="{DynamicResource AppTextPrimary}" Text="{DynamicResource Settings.Version}" />
                    <TextBlock
                        Margin="0,8,0,0"
                        Foreground="{DynamicResource AppTextMuted}"
                        Text="{Binding AppVersion}" />
                </StackPanel>

                <!--  B Stage 2 — 重建快照歷史（dry-run 預覽 → 確認後自動備份再寫入）  -->
                <StackPanel>
                    <TextBlock
                        Foreground="{DynamicResource AppTextPrimary}"
                        FontWeight="SemiBold"
                        Text="{DynamicResource Settings.Rebuild.SectionTitle}" />
                    <TextBlock
                        Margin="0,4,0,8"
                        FontSize="{StaticResource Font.Size.Xs}"
                        Foreground="{DynamicResource AppTextMuted}"
                        Text="{DynamicResource Settings.Rebuild.SectionHint}"
                        TextWrapping="Wrap" />
                    <Button
                        HorizontalAlignment="Left"
                        Command="{Binding PreviewRebuildSnapshotHistoryCommand}"
                        Content="{DynamicResource Settings.Rebuild.Button}"
                        Style="{StaticResource AppSecondaryButton}" />
                </StackPanel>
            </StackPanel>
        </Border>
    </StackPanel>
</UserControl>
