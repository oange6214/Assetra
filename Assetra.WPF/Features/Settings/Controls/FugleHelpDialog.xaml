<UserControl
    x:Class="Assetra.WPF.Features.Settings.Controls.FugleHelpDialog"
    xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
    xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
    xmlns:d="http://schemas.microsoft.com/expression/blend/2008"
    xmlns:mc="http://schemas.openxmlformats.org/markup-compatibility/2006"
    mc:Ignorable="d">

    <Grid Visibility="{Binding IsFugleHelpOpen, Converter={StaticResource BooleanToVisibilityConverter}}">
        <Border Background="{DynamicResource AppModalOverlay}" />

        <Border
            Width="480"
            MaxWidth="480"
            MaxHeight="620"
            Padding="0"
            HorizontalAlignment="Center"
            VerticalAlignment="Center"
            Background="{DynamicResource AppSurface}"
            BorderBrush="{DynamicResource AppBorder}"
            BorderThickness="1"
            CornerRadius="{StaticResource RadiusMd}">
            <Grid>
                <Grid.RowDefinitions>
                    <RowDefinition Height="Auto" />
                    <RowDefinition Height="*" />
                    <RowDefinition Height="Auto" />
                </Grid.RowDefinitions>

                <Border
                    Grid.Row="0"
                    Padding="20,14"
                    BorderBrush="{DynamicResource AppBorder}"
                    BorderThickness="0,0,0,1">
                    <DockPanel>
                        <StackPanel>
                            <TextBlock
                                FontSize="{StaticResource FontSizeSm}"
                                FontWeight="SemiBold"
                                Foreground="{DynamicResource AppTextPrimary}"
                                Text="{DynamicResource Settings.FugleHelp.Title}" />
                            <TextBlock
                                Margin="0,2,0,0"
                                FontSize="{StaticResource FontSizeXs}"
                                Foreground="{DynamicResource AppTextMuted}"
                                Text="{DynamicResource Settings.FugleHelp.Subtitle}"
                                TextWrapping="Wrap" />
                        </StackPanel>
                        <Button
                            Width="28"
                            Height="28"
                            HorizontalAlignment="Right"
                            Command="{Binding CloseFugleHelpCommand}"
                            DockPanel.Dock="Right"
                            Style="{StaticResource BtnIcon}">
                            <TextBlock
                                FontFamily="Segoe MDL2 Assets"
                                FontSize="12"
                                Foreground="{DynamicResource AppTextMuted}"
                                Text="&#xE8BB;" />
                        </Button>
                    </DockPanel>
                </Border>

                <ScrollViewer
                    Grid.Row="1"
                    Padding="20,16"
                    VerticalScrollBarVisibility="Auto">
                    <StackPanel>
                        <Border
                            Margin="0,0,0,12"
                            Padding="12"
                            Background="{DynamicResource AppBackground}"
                            BorderBrush="{DynamicResource AppBorder}"
                            BorderThickness="1"
                            CornerRadius="{StaticResource RadiusSm}">
                            <TextBlock
                                FontSize="{StaticResource FontSizeXs}"
                                Foreground="{DynamicResource AppTextSecondary}"
                                Text="{DynamicResource Settings.FugleHelp.Intro}"
                                TextWrapping="Wrap" />
                        </Border>

                        <TextBlock
                            Margin="0,0,0,8"
                            FontSize="{StaticResource FontSizeXs}"
                            FontWeight="SemiBold"
                            Foreground="{DynamicResource AppTextPrimary}"
                            Text="{DynamicResource Settings.FugleHelp.Step1.Title}" />
                        <TextBlock
                            Margin="0,0,0,12"
                            FontSize="{StaticResource FontSizeXs}"
                            Foreground="{DynamicResource AppTextSecondary}"
                            Text="{DynamicResource Settings.FugleHelp.Step1.Body}"
                            TextWrapping="Wrap" />

                        <TextBlock
                            Margin="0,0,0,8"
                            FontSize="{StaticResource FontSizeXs}"
                            FontWeight="SemiBold"
                            Foreground="{DynamicResource AppTextPrimary}"
                            Text="{DynamicResource Settings.FugleHelp.Step2.Title}" />
                        <TextBlock
                            Margin="0,0,0,12"
                            FontSize="{StaticResource FontSizeXs}"
                            Foreground="{DynamicResource AppTextSecondary}"
                            Text="{DynamicResource Settings.FugleHelp.Step2.Body}"
                            TextWrapping="Wrap" />

                        <TextBlock
                            Margin="0,0,0,8"
                            FontSize="{StaticResource FontSizeXs}"
                            FontWeight="SemiBold"
                            Foreground="{DynamicResource AppTextPrimary}"
                            Text="{DynamicResource Settings.FugleHelp.Step3.Title}" />
                        <TextBlock
                            Margin="0,0,0,12"
                            FontSize="{StaticResource FontSizeXs}"
                            Foreground="{DynamicResource AppTextSecondary}"
                            Text="{DynamicResource Settings.FugleHelp.Step3.Body}"
                            TextWrapping="Wrap" />

                        <TextBlock
                            Margin="0,0,0,8"
                            FontSize="{StaticResource FontSizeXs}"
                            FontWeight="SemiBold"
                            Foreground="{DynamicResource AppTextPrimary}"
                            Text="{DynamicResource Settings.FugleHelp.Step4.Title}" />
                        <TextBlock
                            FontSize="{StaticResource FontSizeXs}"
                            Foreground="{DynamicResource AppTextSecondary}"
                            Text="{DynamicResource Settings.FugleHelp.Step4.Body}"
                            TextWrapping="Wrap" />
                    </StackPanel>
                </ScrollViewer>

                <Border
                    Grid.Row="2"
                    Padding="20,14"
                    BorderBrush="{DynamicResource AppBorder}"
                    BorderThickness="1,1,1,0">
                    <DockPanel LastChildFill="False">
                        <Button
                            Command="{Binding CloseFugleHelpCommand}"
                            Content="{DynamicResource Common.Close}"
                            DockPanel.Dock="Right"
                            Style="{StaticResource BtnGhost}" />
                        <Button
                            Margin="0,0,8,0"
                            Command="{Binding OpenFugleDeveloperSiteCommand}"
                            Content="{DynamicResource Settings.FugleHelp.OpenSite}"
                            DockPanel.Dock="Right"
                            Foreground="White"
                            Style="{StaticResource BtnPrimary}" />
                    </DockPanel>
                </Border>
            </Grid>
        </Border>
    </Grid>
</UserControl>
