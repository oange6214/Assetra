<UserControl
    x:Class="Assetra.WPF.Features.Settings.Controls.TwelveDataHelpDialog"
    xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
    xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
    xmlns:d="http://schemas.microsoft.com/expression/blend/2008"
    xmlns:ds="clr-namespace:Assetra.WPF.DesignSystem.Controls"
    xmlns:mc="http://schemas.openxmlformats.org/markup-compatibility/2006"
    mc:Ignorable="d">

    <!--
        Mirrors FugleHelpDialog.xaml structure exactly — same overlay, header,
        scrollable 4-step body, footer with "Open site" + "Close" buttons.
        Bindings target the Settings.TwelveDataHelp.* DynamicResource keys and
        the IsTwelveDataHelpOpen / OpenTwelveDataSite / CloseTwelveDataHelp
        VM members.
    -->
    <Grid Visibility="{Binding IsTwelveDataHelpOpen, Converter={StaticResource BooleanToVisibilityConverter}}">
        <Border Style="{StaticResource AppDialogOverlayBorder}" />

        <Border
            Width="Auto"
            MaxWidth="560"
            MaxHeight="620"
            Margin="24"
            Padding="0"
            HorizontalAlignment="Center"
            VerticalAlignment="Center"
            Style="{StaticResource FormCard}">
            <Grid>
                <Grid.RowDefinitions>
                    <RowDefinition Height="Auto" />
                    <RowDefinition Height="*" />
                    <RowDefinition Height="Auto" />
                </Grid.RowDefinitions>

                <Border
                    Grid.Row="0"
                    Padding="20,14"
                    BorderBrush="{DynamicResource AppBorder}"
                    BorderThickness="0,0,0,1">
                    <DockPanel>
                        <StackPanel>
                            <TextBlock
                                FontSize="{StaticResource Font.Size.Sm}"
                                FontWeight="SemiBold"
                                Foreground="{DynamicResource AppTextPrimary}"
                                Text="{DynamicResource Settings.TwelveDataHelp.Title}" />
                            <TextBlock
                                Margin="0,2,0,0"
                                FontSize="{StaticResource Font.Size.Xs}"
                                Foreground="{DynamicResource AppTextMuted}"
                                Text="{DynamicResource Settings.TwelveDataHelp.Subtitle}"
                                TextWrapping="Wrap" />
                        </StackPanel>
                        <Button
                            Width="28"
                            Height="28"
                            Padding="0"
                            HorizontalAlignment="Right"
                            Command="{Binding CloseTwelveDataHelpCommand}"
                            DockPanel.Dock="Right"
                            Style="{StaticResource AppIconButton}"
                            ToolTip="{DynamicResource Common.Close}">
                            <ds:AppIcon
                                FontSize="{StaticResource Font.Size.Xs}"
                                Foreground="{DynamicResource AppTextMuted}"
                                Symbol="Dismiss24" />
                        </Button>
                    </DockPanel>
                </Border>

                <ScrollViewer
                    Grid.Row="1"
                    Padding="20,16"
                    VerticalScrollBarVisibility="Auto">
                    <StackPanel>
                        <Border
                            Margin="0,0,0,12"
                            Padding="12"
                            Background="{DynamicResource AppBackground}"
                            BorderBrush="{DynamicResource AppBorderLight}"
                            BorderThickness="1"
                            CornerRadius="{StaticResource Radius.Sm}">
                            <TextBlock
                                FontSize="{StaticResource Font.Size.Xs}"
                                Foreground="{DynamicResource AppTextSecondary}"
                                Text="{DynamicResource Settings.TwelveDataHelp.Intro}"
                                TextWrapping="Wrap" />
                        </Border>

                        <TextBlock
                            Margin="0,0,0,8"
                            FontSize="{StaticResource Font.Size.Xs}"
                            FontWeight="SemiBold"
                            Foreground="{DynamicResource AppTextPrimary}"
                            Text="{DynamicResource Settings.TwelveDataHelp.Step1.Title}" />
                        <TextBlock
                            Margin="0,0,0,12"
                            FontSize="{StaticResource Font.Size.Xs}"
                            Foreground="{DynamicResource AppTextSecondary}"
                            Text="{DynamicResource Settings.TwelveDataHelp.Step1.Body}"
                            TextWrapping="Wrap" />

                        <TextBlock
                            Margin="0,0,0,8"
                            FontSize="{StaticResource Font.Size.Xs}"
                            FontWeight="SemiBold"
                            Foreground="{DynamicResource AppTextPrimary}"
                            Text="{DynamicResource Settings.TwelveDataHelp.Step2.Title}" />
                        <TextBlock
                            Margin="0,0,0,12"
                            FontSize="{StaticResource Font.Size.Xs}"
                            Foreground="{DynamicResource AppTextSecondary}"
                            Text="{DynamicResource Settings.TwelveDataHelp.Step2.Body}"
                            TextWrapping="Wrap" />

                        <TextBlock
                            Margin="0,0,0,8"
                            FontSize="{StaticResource Font.Size.Xs}"
                            FontWeight="SemiBold"
                            Foreground="{DynamicResource AppTextPrimary}"
                            Text="{DynamicResource Settings.TwelveDataHelp.Step3.Title}" />
                        <TextBlock
                            Margin="0,0,0,12"
                            FontSize="{StaticResource Font.Size.Xs}"
                            Foreground="{DynamicResource AppTextSecondary}"
                            Text="{DynamicResource Settings.TwelveDataHelp.Step3.Body}"
                            TextWrapping="Wrap" />

                        <TextBlock
                            Margin="0,0,0,8"
                            FontSize="{StaticResource Font.Size.Xs}"
                            FontWeight="SemiBold"
                            Foreground="{DynamicResource AppTextPrimary}"
                            Text="{DynamicResource Settings.TwelveDataHelp.Step4.Title}" />
                        <TextBlock
                            FontSize="{StaticResource Font.Size.Xs}"
                            Foreground="{DynamicResource AppTextSecondary}"
                            Text="{DynamicResource Settings.TwelveDataHelp.Step4.Body}"
                            TextWrapping="Wrap" />
                    </StackPanel>
                </ScrollViewer>

                <Border
                    Grid.Row="2"
                    Padding="20,14"
                    BorderBrush="{DynamicResource AppBorder}"
                    BorderThickness="1,1,1,0">
                    <DockPanel LastChildFill="False">
                        <Button
                            Command="{Binding CloseTwelveDataHelpCommand}"
                            Content="{DynamicResource Common.Close}"
                            DockPanel.Dock="Right"
                            Style="{StaticResource AppSecondaryButton}" />
                        <Button
                            Margin="0,0,8,0"
                            Command="{Binding OpenTwelveDataSiteCommand}"
                            Content="{DynamicResource Settings.TwelveDataHelp.OpenSite}"
                            DockPanel.Dock="Right"
                            Style="{StaticResource AppPrimaryButton}" />
                    </DockPanel>
                </Border>
            </Grid>
        </Border>
    </Grid>
</UserControl>
