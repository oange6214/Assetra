<UserControl
    x:Class="Assetra.WPF.Features.Settings.SettingsView"
    xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
    xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
    xmlns:ds="clr-namespace:Assetra.WPF.DesignSystem.Controls"
    xmlns:controls="clr-namespace:Assetra.WPF.Features.Settings.Controls"
    xmlns:d="http://schemas.microsoft.com/expression/blend/2008"
    xmlns:infra="clr-namespace:Assetra.WPF.Infrastructure"
    xmlns:mc="http://schemas.openxmlformats.org/markup-compatibility/2006"
    xmlns:vm="clr-namespace:Assetra.WPF.Features.Settings"
    d:DataContext="{d:DesignInstance Type={x:Type vm:SettingsViewModel}}"
    d:DesignHeight="600"
    d:DesignWidth="800"
    Background="{DynamicResource AppBackground}"
    Loaded="UserControl_Loaded"
    Unloaded="UserControl_Unloaded"
    mc:Ignorable="d">

    <Grid>
        <ScrollViewer
            Padding="24"
            HorizontalScrollBarVisibility="Disabled"
            VerticalScrollBarVisibility="Auto">

            <!--
                Stretch the settings surface like the other app pages. Individual
                controls still keep sensible field widths inside each section.
            -->
            <StackPanel
                HorizontalAlignment="Stretch"
                Grid.IsSharedSizeScope="True">

                <!--  Page title  -->
                <TextBlock
                    Margin="0,0,0,20"
                    FontSize="{StaticResource Font.Size.Lg}"
                    FontWeight="SemiBold"
                    Foreground="{DynamicResource AppTextPrimary}"
                    Text="{DynamicResource Settings.Title}" />

                <!--  ── 外觀 ──  -->
                <TextBlock
                    Margin="0,0,0,8"
                    FontSize="{StaticResource Font.Size.Md}"
                    FontWeight="SemiBold"
                    Foreground="{DynamicResource AppTextPrimary}"
                    Text="{DynamicResource Settings.Section.Appearance}" />

                <Border Style="{StaticResource FormCard}"
                    Margin="0,0,0,24"
                    Padding="16,12">
                    <StackPanel>
                        <StackPanel Margin="0,0,0,14">
                            <TextBlock Foreground="{DynamicResource AppTextPrimary}" Text="{DynamicResource Settings.DarkTheme}" />
                            <CheckBox
                                Margin="0,8,0,0"
                                HorizontalAlignment="Left"
                                IsChecked="{Binding IsDarkTheme}" />
                        </StackPanel>

                        <StackPanel Margin="0,0,0,14">
                            <TextBlock Foreground="{DynamicResource AppTextPrimary}" Text="{DynamicResource Settings.ColorScheme}" />
                            <WrapPanel Margin="0,8,0,0">
                                <RadioButton
                                    Margin="0,0,20,8"
                                    Content="{DynamicResource Settings.ColorScheme.Taiwan}"
                                    GroupName="ColorScheme"
                                    IsChecked="{Binding UseTaiwanColors}" />
                                <RadioButton
                                    Margin="0,0,0,8"
                                    Content="{DynamicResource Settings.ColorScheme.International}"
                                    GroupName="ColorScheme"
                                    IsChecked="{Binding UseInternationalColors}" />
                            </WrapPanel>
                        </StackPanel>

                        <StackPanel>
                            <TextBlock Foreground="{DynamicResource AppTextPrimary}" Text="{DynamicResource Settings.UiScale}" />
                            <TextBlock
                                Margin="0,8,0,6"
                                FontSize="{StaticResource Font.Size.Xs}"
                                Foreground="{DynamicResource AppTextMuted}"
                                Text="{DynamicResource Settings.UiScaleDesc}"
                                TextWrapping="Wrap" />
                            <Grid MaxWidth="420">
                                <Grid.ColumnDefinitions>
                                    <ColumnDefinition Width="*" />
                                    <ColumnDefinition Width="52" />
                                </Grid.ColumnDefinitions>
                                <Slider
                                    x:Name="UiScaleSlider"
                                    Grid.Column="0"
                                    VerticalAlignment="Center"
                                    IsSnapToTickEnabled="True"
                                    LargeChange="0.1"
                                    Maximum="1.5"
                                    Minimum="0.75"
                                    PreviewMouseLeftButtonUp="OnUiScaleSliderMouseUp"
                                    SmallChange="0.05"
                                    Thumb.DragCompleted="OnUiScaleSliderDragCompleted"
                                    TickFrequency="0.05"
                                    Value="{Binding UiScalePreview, UpdateSourceTrigger=PropertyChanged}" />
                                <TextBlock
                                    Grid.Column="1"
                                    Margin="8,0,0,0"
                                    VerticalAlignment="Center"
                                    FontFamily="{StaticResource Font.Family.Base}" Typography.NumeralAlignment="Tabular"
                                    FontSize="{StaticResource Font.Size.Sm}"
                                    Foreground="{DynamicResource AppTextPrimary}"
                                    Text="{Binding UiScaleDisplay}"
                                    TextAlignment="Right" />
                            </Grid>
                            <DockPanel
                                MaxWidth="360"
                                Margin="0,4,0,0"
                                LastChildFill="False">
                                <TextBlock
                                    DockPanel.Dock="Left"
                                    FontSize="{StaticResource Font.Size.Xs}"
                                    Foreground="{DynamicResource AppTextMuted}"
                                    Text="0.75×" />
                                <TextBlock
                                    DockPanel.Dock="Right"
                                    FontSize="{StaticResource Font.Size.Xs}"
                                    Foreground="{DynamicResource AppTextMuted}"
                                    Text="1.50×" />
                            </DockPanel>
                        </StackPanel>

                        <StackPanel>
                            <TextBlock Foreground="{DynamicResource AppTextPrimary}" Text="{DynamicResource Settings.DefaultHome}" />
                            <TextBlock
                                Margin="0,8,0,6"
                                FontSize="{StaticResource Font.Size.Xs}"
                                Foreground="{DynamicResource AppTextMuted}"
                                Text="{DynamicResource Settings.DefaultHomeDesc}"
                                TextWrapping="Wrap" />
                            <ComboBox
                                MinWidth="220"
                                MaxWidth="320"
                                HorizontalAlignment="Left"
                                Style="{StaticResource AppComboBox}"
                                DisplayMemberPath="Display"
                                ItemsSource="{Binding SupportedHomeSections}"
                                SelectedValuePath="Code"
                                SelectedValue="{Binding DefaultHomeSection, Mode=TwoWay}" />
                        </StackPanel>
                    </StackPanel>
                </Border>

                <!--  ── 語言與區域  ──  -->
                <TextBlock
                    Margin="0,0,0,8"
                    FontSize="{StaticResource Font.Size.Md}"
                    FontWeight="SemiBold"
                    Foreground="{DynamicResource AppTextPrimary}"
                    Text="{DynamicResource Settings.Section.Language}" />

                <Border Style="{StaticResource FormCard}"
                    Margin="0,0,0,24"
                    Padding="16,12">
                    <StackPanel>
                        <StackPanel Margin="0,0,0,14">
                            <TextBlock Foreground="{DynamicResource AppTextPrimary}" Text="{DynamicResource Settings.Language}" />
                            <ComboBox
                                MinWidth="220"
                                MaxWidth="320"
                                Margin="0,8,0,0"
                                HorizontalAlignment="Stretch"
                                DisplayMemberPath="Display"
                                ItemsSource="{x:Static vm:SettingsViewModel.SupportedLanguages}"
                                SelectedValue="{Binding Language}"
                                SelectedValuePath="Code" />
                        </StackPanel>

                        <StackPanel>
                            <TextBlock Foreground="{DynamicResource AppTextPrimary}" Text="{DynamicResource Settings.PrimaryCurrency}" />
                            <ComboBox
                                MinWidth="220"
                                MaxWidth="320"
                                Margin="0,8,0,0"
                                HorizontalAlignment="Stretch"
                                ItemsSource="{Binding SupportedCurrencies}"
                                SelectedItem="{Binding PrimaryCurrency}" />
                        </StackPanel>

                        <StackPanel>
                            <TextBlock Foreground="{DynamicResource AppTextPrimary}" Text="{DynamicResource Settings.BaseCurrency}" />
                            <ComboBox
                                MinWidth="220"
                                MaxWidth="320"
                                Margin="0,8,0,0"
                                HorizontalAlignment="Stretch"
                                ItemsSource="{Binding SupportedCurrencies}"
                                SelectedItem="{Binding BaseCurrency}"
                                ToolTip="{DynamicResource Settings.BaseCurrency.Tooltip}" />
                        </StackPanel>

                        <!--  ── 即時匯率（Frankfurter）──  -->
                        <StackPanel Margin="0,16,0,0">
                            <Grid>
                                <Grid.ColumnDefinitions>
                                    <ColumnDefinition Width="*" />
                                    <ColumnDefinition Width="Auto" />
                                </Grid.ColumnDefinitions>
                                <StackPanel Grid.Column="0">
                                    <TextBlock Foreground="{DynamicResource AppTextPrimary}" Text="{DynamicResource Settings.Fx.Title}" />
                                    <TextBlock
                                        Margin="0,2,0,0"
                                        FontSize="{StaticResource Font.Size.Xs}"
                                        Foreground="{DynamicResource AppTextMuted}">
                                        <Run Text="{DynamicResource Settings.Fx.LastRefreshed}" />
                                        <Run Text=" " />
                                        <Run FontFamily="{StaticResource Font.Family.Base}" Text="{Binding LastFxRefreshDisplay, Mode=OneWay}" />
                                    </TextBlock>
                                </StackPanel>
                                <Button
                                    Grid.Column="1"
                                    Margin="8,0,0,0"
                                    VerticalAlignment="Top"
                                    Command="{Binding RefreshFxRatesCommand}"
                                    Content="{DynamicResource Settings.Fx.Refresh}"
                                    IsEnabled="{Binding CanRefreshFxRates}"
                                    Style="{StaticResource AppSecondaryButton}" />
                            </Grid>
                            <Border
                                Margin="0,8,0,0"
                                Padding="10,8"
                                Background="{DynamicResource AppSurfaceAlt}"
                                BorderBrush="{DynamicResource AppBorder}"
                                BorderThickness="1"
                                CornerRadius="{StaticResource Radius.Sm}">
                                <ItemsControl ItemsSource="{Binding FxRateRows}">
                                    <ItemsControl.ItemTemplate>
                                        <DataTemplate>
                                            <TextBlock
                                                Margin="0,2,0,2"
                                                FontFamily="{StaticResource Font.Family.Base}"
                                                Foreground="{DynamicResource AppTextSecondary}"
                                                Text="{Binding RateDisplay}"
                                                Typography.NumeralAlignment="Tabular" />
                                        </DataTemplate>
                                    </ItemsControl.ItemTemplate>
                                </ItemsControl>
                            </Border>
                            <TextBlock
                                Margin="0,4,0,0"
                                FontSize="{StaticResource Font.Size.Xs}"
                                Foreground="{DynamicResource AppTextMuted}"
                                Text="{DynamicResource Settings.Fx.Source}"
                                TextWrapping="Wrap" />
                        </StackPanel>
                    </StackPanel>
                </Border>

                <!--  ── 資料 ──  -->
                <TextBlock
                    Margin="0,0,0,8"
                    FontSize="{StaticResource Font.Size.Md}"
                    FontWeight="SemiBold"
                    Foreground="{DynamicResource AppTextPrimary}"
                    Text="{DynamicResource Settings.Section.Data}" />

                <Border Style="{StaticResource FormCard}"
                    Margin="0,0,0,24"
                    Padding="16,12">
                    <StackPanel>
                        <StackPanel Margin="0,0,0,14">
                            <TextBlock Foreground="{DynamicResource AppTextPrimary}" Text="{DynamicResource Settings.DataDir}" />
                            <StackPanel Margin="0,8,0,0">
                                <TextBlock
                                    Margin="0,0,0,8"
                                    FontSize="{StaticResource Font.Size.Xs}"
                                    Foreground="{DynamicResource AppTextMuted}"
                                    Text="{Binding DataFolderPath}"
                                    TextWrapping="Wrap" />
                                <Button
                                    HorizontalAlignment="Left"
                                    Command="{Binding OpenDataFolderCommand}"
                                    Content="{DynamicResource Settings.OpenDir}" Style="{StaticResource AppSecondaryButton}" />
                            </StackPanel>
                        </StackPanel>

                        <StackPanel Margin="0,0,0,14">
                            <TextBlock Foreground="{DynamicResource AppTextPrimary}" Text="{DynamicResource Settings.Version}" />
                            <TextBlock
                                Margin="0,8,0,0"
                                Foreground="{DynamicResource AppTextMuted}"
                                Text="{Binding AppVersion}" />
                        </StackPanel>

                        <StackPanel Margin="0,0,0,14">
                            <TextBlock Foreground="{DynamicResource AppTextPrimary}" Text="{DynamicResource Settings.QuoteSource}" />
                            <ComboBox
                                MinWidth="220"
                                MaxWidth="320"
                                Margin="0,8,0,0"
                                HorizontalAlignment="Stretch"
                                DisplayMemberPath="Display"
                                ItemsSource="{x:Static vm:SettingsViewModel.SupportedQuoteProviders}"
                                SelectedValue="{Binding QuoteProvider}"
                                SelectedValuePath="Code" />
                        </StackPanel>

                        <StackPanel Margin="0,0,0,14">
                            <TextBlock Foreground="{DynamicResource AppTextPrimary}" Text="{DynamicResource Settings.DataSource}" />
                            <ComboBox
                                MinWidth="220"
                                MaxWidth="320"
                                Margin="0,8,0,0"
                                HorizontalAlignment="Stretch"
                                DisplayMemberPath="Display"
                                ItemsSource="{x:Static vm:SettingsViewModel.SupportedHistoryProviders}"
                                SelectedValue="{Binding HistoryProvider}"
                                SelectedValuePath="Code" />
                        </StackPanel>

                        <StackPanel Margin="0,0,0,14">
                            <TextBlock Foreground="{DynamicResource AppTextPrimary}" Text="{DynamicResource Settings.UsSymbolDirectory.Title}" />
                            <TextBlock
                                Margin="0,8,0,6"
                                FontSize="{StaticResource Font.Size.Xs}"
                                Foreground="{DynamicResource AppTextMuted}"
                                Text="{Binding UsSymbolDirectoryStatus}"
                                TextWrapping="Wrap" />
                            <Button
                                HorizontalAlignment="Left"
                                Command="{Binding RefreshUsSymbolDirectoryCommand}"
                                Content="{DynamicResource Settings.UsSymbolDirectory.Refresh}"
                                IsEnabled="{Binding CanRefreshUsSymbolDirectory}"
                                Style="{StaticResource AppSecondaryButton}" />
                        </StackPanel>

                        <StackPanel>
                            <StackPanel Orientation="Horizontal">
                                <TextBlock
                                    VerticalAlignment="Center"
                                    Foreground="{DynamicResource AppTextPrimary}"
                                    Text="{DynamicResource Settings.FugleApiKey}" />
                                <Button
                                    Margin="6,-2,0,0"
                                    Command="{Binding OpenFugleHelpCommand}"
                                    Padding="0" Style="{StaticResource AppGhostButton}"
                                    ToolTip="{DynamicResource Settings.FugleHelp.Tooltip}">
                                    <ds:AppIcon Symbol="Info24" FontSize="{StaticResource Font.Size.Xs}" Foreground="{DynamicResource AppTextMuted}" />
                                </Button>
                            </StackPanel>
                            <StackPanel MaxWidth="420" Margin="0,8,0,0">
                                <PasswordBox
                                    x:Name="FugleApiKeyBox"
                                    MinWidth="220"
                                    MaxWidth="420"
                                    Margin="0,0,0,8"
                                    HorizontalAlignment="Stretch"
                                    PasswordChanged="FugleApiKeyBox_OnPasswordChanged" />
                            </StackPanel>
                            <TextBlock
                                Margin="0,0,0,0"
                                FontSize="{StaticResource Font.Size.Xs}"
                                Foreground="{DynamicResource AppTextMuted}"
                                Text="{DynamicResource Settings.FugleApiKeyHint}"
                                TextWrapping="Wrap" />
                            <TextBlock
                                Margin="0,4,0,0"
                                FontSize="{StaticResource Font.Size.Xs}"
                                Foreground="{DynamicResource AppTextMuted}"
                                Text="{Binding DataSourceSaveStatus}"
                                TextWrapping="Wrap" />
                        </StackPanel>

                        <StackPanel Margin="0,16,0,0">
                            <TextBlock Foreground="{DynamicResource AppTextPrimary}" Text="{DynamicResource Settings.TwelveDataApiKey}" />
                            <StackPanel MaxWidth="420" Margin="0,8,0,0">
                                <PasswordBox
                                    x:Name="TwelveDataApiKeyBox"
                                    MinWidth="220"
                                    MaxWidth="420"
                                    Margin="0,0,0,8"
                                    HorizontalAlignment="Stretch"
                                    PasswordChanged="TwelveDataApiKeyBox_OnPasswordChanged" />
                                <WrapPanel>
                                    <Button
                                        Margin="0,0,8,8"
                                        Command="{Binding TestTwelveDataConnectionCommand}"
                                        Content="{DynamicResource Settings.TwelveData.Test}"
                                        IsEnabled="{Binding CanTestTwelveDataConnection}"
                                        Style="{StaticResource AppSecondaryButton}" />
                                    <TextBlock
                                        Margin="0,8,0,8"
                                        VerticalAlignment="Center"
                                        FontSize="{StaticResource Font.Size.Xs}"
                                        Foreground="{DynamicResource AppTextMuted}">
                                        <Run Text="{DynamicResource Settings.TwelveData.Quota}" />
                                        <Run Text=" " />
                                        <Run Text="{Binding TwelveDataQuotaDisplay, Mode=OneWay}" />
                                    </TextBlock>
                                </WrapPanel>
                            </StackPanel>
                            <TextBlock
                                FontSize="{StaticResource Font.Size.Xs}"
                                Foreground="{DynamicResource AppTextMuted}"
                                Text="{DynamicResource Settings.TwelveDataApiKeyHint}"
                                TextWrapping="Wrap" />
                            <TextBlock
                                Margin="0,4,0,0"
                                FontSize="{StaticResource Font.Size.Xs}"
                                Foreground="{DynamicResource AppTextMuted}"
                                Text="{Binding TwelveDataTestStatus}"
                                TextWrapping="Wrap" />
                        </StackPanel>

                        <Button
                            Margin="0,16,0,0"
                            HorizontalAlignment="Left"
                            Command="{Binding SaveDataSourceSettingsCommand}"
                            Content="{DynamicResource Common.Save}"
                            Style="{StaticResource AppSecondaryButton}" />
                    </StackPanel>
                </Border>

                <TextBlock
                    Margin="0,0,0,8"
                    FontSize="{StaticResource Font.Size.Md}"
                    FontWeight="SemiBold"
                    Foreground="{DynamicResource AppTextPrimary}"
                    Text="{DynamicResource Settings.Section.Ocr}" />

                <Border Style="{StaticResource FormCard}"
                    Margin="0,0,0,24"
                    Padding="16,12">
                    <StackPanel>
                        <StackPanel Margin="0,0,0,14">
                            <TextBlock Foreground="{DynamicResource AppTextPrimary}" Text="{DynamicResource Settings.Ocr.TessdataPath}" />
                            <StackPanel
                                MaxWidth="520"
                                Margin="0,8,0,0"
                                Orientation="Horizontal">
                                <TextBox
                                    MinWidth="320"
                                    Margin="0,0,8,0"
                                    Text="{Binding OcrTessdataPath, UpdateSourceTrigger=LostFocus}" />
                                <Button
                                    Command="{Binding BrowseOcrTessdataCommand}"
                                    Content="{DynamicResource Common.Browse}" Style="{StaticResource AppSecondaryButton}" />
                                <Button
                                    Margin="8,0,0,0"
                                    Command="{Binding OpenTessdataDownloadCommand}"
                                    Content="{DynamicResource Settings.Ocr.Download}"
                                    Style="{StaticResource AppSecondaryButton}"
                                    ToolTip="{DynamicResource Settings.Ocr.Download.Tooltip}" />
                            </StackPanel>
                            <TextBlock
                                Margin="0,4,0,0"
                                FontSize="{StaticResource Font.Size.Xs}"
                                Foreground="{DynamicResource AppTextMuted}"
                                Text="{DynamicResource Settings.Ocr.TessdataPath.Hint}"
                                TextWrapping="Wrap" />
                        </StackPanel>

                        <StackPanel>
                            <TextBlock Foreground="{DynamicResource AppTextPrimary}" Text="{DynamicResource Settings.Ocr.Language}" />
                            <TextBox
                                MinWidth="220"
                                MaxWidth="320"
                                Margin="0,8,0,0"
                                HorizontalAlignment="Left"
                                Text="{Binding OcrLanguage, UpdateSourceTrigger=LostFocus}" />
                            <TextBlock
                                Margin="0,4,0,0"
                                FontSize="{StaticResource Font.Size.Xs}"
                                Foreground="{DynamicResource AppTextMuted}"
                                Text="{DynamicResource Settings.Ocr.Language.Hint}"
                                TextWrapping="Wrap" />
                        </StackPanel>
                    </StackPanel>
                </Border>

                <!--  ── 最低稅負制（AMT）──  -->
                <TextBlock
                    Margin="0,0,0,8"
                    FontSize="{StaticResource Font.Size.Md}"
                    FontWeight="SemiBold"
                    Foreground="{DynamicResource AppTextPrimary}"
                    Text="{DynamicResource Settings.Section.Amt}" />

                <Border Style="{StaticResource FormCard}"
                    Margin="0,0,0,24"
                    Padding="16,12">
                    <StackPanel>
                        <TextBlock
                            Margin="0,0,0,12"
                            FontSize="{StaticResource Font.Size.Xs}"
                            Foreground="{DynamicResource AppTextMuted}"
                            Text="{DynamicResource Settings.Amt.Hint}"
                            TextWrapping="Wrap" />

                        <!-- 一般所得（手動覆寫，0 = 由 IncomeTaxCalculator 自動估算） -->
                        <Grid Margin="0,0,0,12">
                            <Grid.ColumnDefinitions>
                                <ColumnDefinition Width="*" />
                                <ColumnDefinition Width="*" />
                            </Grid.ColumnDefinitions>
                            <StackPanel Grid.Column="0" Margin="0,0,8,0">
                                <TextBlock Foreground="{DynamicResource AppTextPrimary}" Text="{DynamicResource Settings.Amt.RegularTaxableIncome}" />
                                <TextBox MinWidth="180" Margin="0,8,0,0" HorizontalAlignment="Left" FontFamily="{StaticResource Font.Family.Base}" Text="{Binding AmtRegularTaxableIncome, StringFormat={}{0:N0}, UpdateSourceTrigger=LostFocus}" Typography.NumeralAlignment="Tabular" />
                                <TextBlock Margin="0,4,0,0" FontSize="{StaticResource Font.Size.Xs}" Foreground="{DynamicResource AppTextMuted}" Text="{DynamicResource Settings.Amt.RegularTaxableIncome.Hint}" TextWrapping="Wrap" />
                            </StackPanel>
                            <StackPanel Grid.Column="1" Margin="8,0,0,0">
                                <TextBlock Foreground="{DynamicResource AppTextPrimary}" Text="{DynamicResource Settings.Amt.RegularIncomeTax}" />
                                <TextBox MinWidth="180" Margin="0,8,0,0" HorizontalAlignment="Left" FontFamily="{StaticResource Font.Family.Base}" Text="{Binding AmtRegularIncomeTax, StringFormat={}{0:N0}, UpdateSourceTrigger=LostFocus}" Typography.NumeralAlignment="Tabular" />
                                <TextBlock Margin="0,4,0,0" FontSize="{StaticResource Font.Size.Xs}" Foreground="{DynamicResource AppTextMuted}" Text="{DynamicResource Settings.Amt.RegularIncomeTax.Hint}" TextWrapping="Wrap" />
                            </StackPanel>
                        </Grid>

                        <!-- AMT 4 項加項 + 海外抵稅 -->
                        <TextBlock Margin="0,8,0,8" FontSize="{StaticResource Font.Size.Sm}" FontWeight="SemiBold" Foreground="{DynamicResource AppTextSecondary}" Text="{DynamicResource Settings.Amt.AddBackItems}" />
                        <Grid Margin="0,0,0,12">
                            <Grid.ColumnDefinitions>
                                <ColumnDefinition Width="*" />
                                <ColumnDefinition Width="*" />
                            </Grid.ColumnDefinitions>
                            <Grid.RowDefinitions>
                                <RowDefinition Height="Auto" />
                                <RowDefinition Height="Auto" />
                                <RowDefinition Height="Auto" />
                            </Grid.RowDefinitions>
                            <StackPanel Grid.Row="0" Grid.Column="0" Margin="0,0,8,8">
                                <TextBlock Foreground="{DynamicResource AppTextPrimary}" Text="{DynamicResource Settings.Amt.InsuranceDeathProceeds}" />
                                <TextBox Margin="0,4,0,0" FontFamily="{StaticResource Font.Family.Base}" Text="{Binding AmtInsuranceDeathProceeds, StringFormat={}{0:N0}, UpdateSourceTrigger=LostFocus}" Typography.NumeralAlignment="Tabular" />
                                <TextBlock Margin="0,2,0,0" FontSize="{StaticResource Font.Size.Xs}" Foreground="{DynamicResource AppTextMuted}" Text="{DynamicResource Settings.Amt.InsuranceDeathProceeds.Hint}" TextWrapping="Wrap" />
                            </StackPanel>
                            <StackPanel Grid.Row="0" Grid.Column="1" Margin="8,0,0,8">
                                <TextBlock Foreground="{DynamicResource AppTextPrimary}" Text="{DynamicResource Settings.Amt.InsuranceNonDeathProceeds}" />
                                <TextBox Margin="0,4,0,0" FontFamily="{StaticResource Font.Family.Base}" Text="{Binding AmtInsuranceNonDeathProceeds, StringFormat={}{0:N0}, UpdateSourceTrigger=LostFocus}" Typography.NumeralAlignment="Tabular" />
                                <TextBlock Margin="0,2,0,0" FontSize="{StaticResource Font.Size.Xs}" Foreground="{DynamicResource AppTextMuted}" Text="{DynamicResource Settings.Amt.InsuranceNonDeathProceeds.Hint}" TextWrapping="Wrap" />
                            </StackPanel>
                            <StackPanel Grid.Row="1" Grid.Column="0" Margin="0,0,8,8">
                                <TextBlock Foreground="{DynamicResource AppTextPrimary}" Text="{DynamicResource Settings.Amt.UnlistedSecurityGains}" />
                                <TextBox Margin="0,4,0,0" FontFamily="{StaticResource Font.Family.Base}" Text="{Binding AmtUnlistedSecurityGains, StringFormat={}{0:N0}, UpdateSourceTrigger=LostFocus}" Typography.NumeralAlignment="Tabular" />
                            </StackPanel>
                            <StackPanel Grid.Row="1" Grid.Column="1" Margin="8,0,0,8">
                                <TextBlock Foreground="{DynamicResource AppTextPrimary}" Text="{DynamicResource Settings.Amt.PrivateFundGains}" />
                                <TextBox Margin="0,4,0,0" FontFamily="{StaticResource Font.Family.Base}" Text="{Binding AmtPrivateFundGains, StringFormat={}{0:N0}, UpdateSourceTrigger=LostFocus}" Typography.NumeralAlignment="Tabular" />
                            </StackPanel>
                            <StackPanel Grid.Row="2" Grid.Column="0" Margin="0,0,8,8">
                                <TextBlock Foreground="{DynamicResource AppTextPrimary}" Text="{DynamicResource Settings.Amt.NonCashDonation}" />
                                <TextBox Margin="0,4,0,0" FontFamily="{StaticResource Font.Family.Base}" Text="{Binding AmtNonCashDonation, StringFormat={}{0:N0}, UpdateSourceTrigger=LostFocus}" Typography.NumeralAlignment="Tabular" />
                            </StackPanel>
                            <StackPanel Grid.Row="2" Grid.Column="1" Margin="8,0,0,8">
                                <TextBlock Foreground="{DynamicResource AppTextPrimary}" Text="{DynamicResource Settings.Amt.OverseasTaxCredit}" />
                                <TextBox Margin="0,4,0,0" FontFamily="{StaticResource Font.Family.Base}" Text="{Binding AmtOverseasTaxCredit, StringFormat={}{0:N0}, UpdateSourceTrigger=LostFocus}" Typography.NumeralAlignment="Tabular" />
                            </StackPanel>
                        </Grid>

                        <TextBlock Margin="0,4,0,0" FontSize="{StaticResource Font.Size.Xs}" Foreground="{DynamicResource AppTextMuted}" Text="{DynamicResource Settings.Amt.AutoNote}" TextWrapping="Wrap" />
                    </StackPanel>
                </Border>

                <!-- ── 個人稅務檔案（綜所稅試算用） ── -->
                <TextBlock Margin="0,0,0,8" FontSize="{StaticResource Font.Size.Md}" FontWeight="SemiBold" Foreground="{DynamicResource AppTextPrimary}" Text="{DynamicResource Settings.Section.TaxFiling}" />
                <Border Style="{StaticResource FormCard}" Margin="0,0,0,24" Padding="16">
                    <StackPanel>
                        <TextBlock Margin="0,0,0,12" FontSize="{StaticResource Font.Size.Xs}" Foreground="{DynamicResource AppTextMuted}" Text="{DynamicResource Settings.TaxFiling.Hint}" TextWrapping="Wrap" />

                        <CheckBox Margin="0,0,0,8" Content="{DynamicResource Settings.TaxFiling.IsMarried}" IsChecked="{Binding TaxIsMarried}" />

                        <Grid Margin="0,0,0,12">
                            <Grid.ColumnDefinitions>
                                <ColumnDefinition Width="*" />
                                <ColumnDefinition Width="*" />
                            </Grid.ColumnDefinitions>
                            <Grid.RowDefinitions>
                                <RowDefinition Height="Auto" />
                                <RowDefinition Height="Auto" />
                                <RowDefinition Height="Auto" />
                            </Grid.RowDefinitions>
                            <StackPanel Grid.Row="0" Grid.Column="0" Margin="0,0,8,8">
                                <TextBlock Foreground="{DynamicResource AppTextPrimary}" Text="{DynamicResource Settings.TaxFiling.SalaryIncome}" />
                                <TextBox Margin="0,4,0,0" FontFamily="{StaticResource Font.Family.Base}" Text="{Binding TaxSalaryIncome, StringFormat={}{0:N0}, UpdateSourceTrigger=LostFocus}" Typography.NumeralAlignment="Tabular" />
                            </StackPanel>
                            <StackPanel Grid.Row="0" Grid.Column="1" Margin="8,0,0,8">
                                <TextBlock Foreground="{DynamicResource AppTextPrimary}" Text="{DynamicResource Settings.TaxFiling.InterestIncome}" />
                                <TextBox Margin="0,4,0,0" FontFamily="{StaticResource Font.Family.Base}" Text="{Binding TaxInterestIncome, StringFormat={}{0:N0}, UpdateSourceTrigger=LostFocus}" Typography.NumeralAlignment="Tabular" />
                            </StackPanel>
                            <StackPanel Grid.Row="1" Grid.Column="0" Margin="0,0,8,8">
                                <TextBlock Foreground="{DynamicResource AppTextPrimary}" Text="{DynamicResource Settings.TaxFiling.DependentCount}" />
                                <TextBox Margin="0,4,0,0" FontFamily="{StaticResource Font.Family.Base}" Text="{Binding TaxDependentCount, UpdateSourceTrigger=LostFocus}" Typography.NumeralAlignment="Tabular" />
                            </StackPanel>
                            <StackPanel Grid.Row="1" Grid.Column="1" Margin="8,0,0,8">
                                <TextBlock Foreground="{DynamicResource AppTextPrimary}" Text="{DynamicResource Settings.TaxFiling.PreschoolCount}" />
                                <TextBox Margin="0,4,0,0" FontFamily="{StaticResource Font.Family.Base}" Text="{Binding TaxPreschoolCount, UpdateSourceTrigger=LostFocus}" Typography.NumeralAlignment="Tabular" />
                            </StackPanel>
                            <StackPanel Grid.Row="2" Grid.Column="0" Margin="0,0,8,0">
                                <TextBlock Foreground="{DynamicResource AppTextPrimary}" Text="{DynamicResource Settings.TaxFiling.CollegeStudentCount}" />
                                <TextBox Margin="0,4,0,0" FontFamily="{StaticResource Font.Family.Base}" Text="{Binding TaxCollegeStudentCount, UpdateSourceTrigger=LostFocus}" Typography.NumeralAlignment="Tabular" />
                            </StackPanel>
                            <StackPanel Grid.Row="2" Grid.Column="1" Margin="8,0,0,0">
                                <TextBlock Foreground="{DynamicResource AppTextPrimary}" Text="{DynamicResource Settings.TaxFiling.LongCareCount}" />
                                <TextBox Margin="0,4,0,0" FontFamily="{StaticResource Font.Family.Base}" Text="{Binding TaxLongCareCount, UpdateSourceTrigger=LostFocus}" Typography.NumeralAlignment="Tabular" />
                            </StackPanel>
                        </Grid>

                        <Grid Margin="0,0,0,12">
                            <Grid.ColumnDefinitions>
                                <ColumnDefinition Width="*" />
                                <ColumnDefinition Width="*" />
                            </Grid.ColumnDefinitions>
                            <StackPanel Grid.Column="0" Margin="0,0,8,0">
                                <TextBlock Foreground="{DynamicResource AppTextPrimary}" Text="{DynamicResource Settings.TaxFiling.DisabilityCount}" />
                                <TextBox Margin="0,4,0,0" FontFamily="{StaticResource Font.Family.Base}" Text="{Binding TaxDisabilityCount, UpdateSourceTrigger=LostFocus}" Typography.NumeralAlignment="Tabular" />
                            </StackPanel>
                            <StackPanel Grid.Column="1" Margin="8,0,0,0">
                                <TextBlock Foreground="{DynamicResource AppTextPrimary}" Text="{DynamicResource Settings.TaxFiling.RentalExpense}" />
                                <TextBox Margin="0,4,0,0" FontFamily="{StaticResource Font.Family.Base}" Text="{Binding TaxRentalExpense, StringFormat={}{0:N0}, UpdateSourceTrigger=LostFocus}" Typography.NumeralAlignment="Tabular" />
                            </StackPanel>
                        </Grid>

                        <CheckBox Margin="0,0,0,4" Content="{DynamicResource Settings.TaxFiling.UseItemized}" IsChecked="{Binding TaxUseItemizedDeduction}" />
                        <TextBox Margin="20,0,0,12" HorizontalAlignment="Left" MinWidth="200" FontFamily="{StaticResource Font.Family.Base}" IsEnabled="{Binding TaxUseItemizedDeduction}" Text="{Binding TaxItemizedDeductionAmount, StringFormat={}{0:N0}, UpdateSourceTrigger=LostFocus}" Typography.NumeralAlignment="Tabular" />

                        <CheckBox Content="{DynamicResource Settings.TaxFiling.DividendSeparate}" IsChecked="{Binding TaxDividendSeparate}" />
                        <TextBlock Margin="20,4,0,0" FontSize="{StaticResource Font.Size.Xs}" Foreground="{DynamicResource AppTextMuted}" Text="{DynamicResource Settings.TaxFiling.DividendSeparate.Hint}" TextWrapping="Wrap" />
                    </StackPanel>
                </Border>

                <!--  ── AI 助手 (Phase 3 LLM) ──  -->
                <TextBlock
                    Margin="0,0,0,8"
                    FontSize="{StaticResource Font.Size.Md}"
                    FontWeight="SemiBold"
                    Foreground="{DynamicResource AppTextPrimary}"
                    Text="{DynamicResource Settings.Section.Llm}" />

                <Border Style="{StaticResource FormCard}"
                    Margin="0,0,0,24"
                    Padding="16,12">
                    <StackPanel>
                        <TextBlock
                            Margin="0,0,0,12"
                            FontSize="{StaticResource Font.Size.Xs}"
                            Foreground="{DynamicResource AppTextMuted}"
                            Text="{DynamicResource Settings.Llm.Hint}"
                            TextWrapping="Wrap" />

                        <StackPanel Margin="0,0,0,12">
                            <TextBlock Foreground="{DynamicResource AppTextPrimary}" Text="{DynamicResource Settings.Llm.Provider}" />
                            <ComboBox
                                MinWidth="220"
                                MaxWidth="320"
                                Margin="0,8,0,0"
                                HorizontalAlignment="Stretch"
                                DisplayMemberPath="Display"
                                ItemsSource="{x:Static vm:SettingsViewModel.SupportedLlmProviders}"
                                SelectedValue="{Binding LlmProvider, Mode=TwoWay}"
                                SelectedValuePath="Code" />
                        </StackPanel>

                        <StackPanel Margin="0,0,0,12">
                            <TextBlock Foreground="{DynamicResource AppTextPrimary}" Text="{DynamicResource Settings.Llm.ApiKey}" />
                            <PasswordBox
                                MinWidth="320"
                                Margin="0,8,0,0"
                                HorizontalAlignment="Left"
                                infra:PasswordBoxBindingHelper.BoundPassword="{Binding LlmApiKey, Mode=TwoWay, UpdateSourceTrigger=PropertyChanged}" />
                            <TextBlock
                                Margin="0,4,0,0"
                                FontSize="{StaticResource Font.Size.Xs}"
                                Foreground="{DynamicResource AppTextMuted}"
                                Text="{DynamicResource Settings.Llm.ApiKey.Hint}"
                                TextWrapping="Wrap" />
                        </StackPanel>

                        <StackPanel Margin="0,0,0,12">
                            <TextBlock Foreground="{DynamicResource AppTextPrimary}" Text="{DynamicResource Settings.Llm.Model}" />
                            <TextBox
                                MinWidth="220"
                                MaxWidth="320"
                                Margin="0,8,0,0"
                                HorizontalAlignment="Left"
                                Text="{Binding LlmModel, UpdateSourceTrigger=LostFocus}" />
                            <TextBlock
                                Margin="0,4,0,0"
                                FontSize="{StaticResource Font.Size.Xs}"
                                Foreground="{DynamicResource AppTextMuted}"
                                Text="{DynamicResource Settings.Llm.Model.Hint}"
                                TextWrapping="Wrap" />
                        </StackPanel>

                        <StackPanel>
                            <TextBlock Foreground="{DynamicResource AppTextPrimary}" Text="{DynamicResource Settings.Llm.Endpoint}" />
                            <TextBox
                                MinWidth="320"
                                Margin="0,8,0,0"
                                HorizontalAlignment="Left"
                                Text="{Binding LlmEndpoint, UpdateSourceTrigger=LostFocus}" />
                            <TextBlock
                                Margin="0,4,0,0"
                                FontSize="{StaticResource Font.Size.Xs}"
                                Foreground="{DynamicResource AppTextMuted}"
                                Text="{DynamicResource Settings.Llm.Endpoint.Hint}"
                                TextWrapping="Wrap" />
                        </StackPanel>
                    </StackPanel>
                </Border>

                <!--  ── 雲端同步 ──  -->
                <TextBlock
                    Margin="0,0,0,8"
                    FontSize="{StaticResource Font.Size.Md}"
                    FontWeight="SemiBold"
                    Foreground="{DynamicResource AppTextPrimary}"
                    Text="{DynamicResource Settings.Section.Sync}" />

                <Border Style="{StaticResource FormCard}"
                    Margin="0,0,0,24"
                    Padding="16,12">
                    <StackPanel DataContext="{Binding Sync}">
                        <CheckBox
                            Margin="0,0,0,12"
                            Content="{DynamicResource Settings.Sync.Enabled}"
                            IsChecked="{Binding Enabled}" />

                        <StackPanel Margin="0,0,0,12">
                            <TextBlock Foreground="{DynamicResource AppTextPrimary}" Text="{DynamicResource Settings.Sync.BackendUrl}" />
                            <TextBox
                                MinWidth="320"
                                Margin="0,8,0,0"
                                HorizontalAlignment="Left"
                                Text="{Binding BackendUrl, UpdateSourceTrigger=LostFocus}" />
                            <TextBlock
                                Margin="0,4,0,0"
                                FontSize="{StaticResource Font.Size.Xs}"
                                Foreground="{DynamicResource AppTextMuted}"
                                Text="{DynamicResource Settings.Sync.BackendUrl.Hint}"
                                TextWrapping="Wrap" />
                        </StackPanel>

                        <StackPanel Margin="0,0,0,12">
                            <TextBlock Foreground="{DynamicResource AppTextPrimary}" Text="{DynamicResource Settings.Sync.AuthToken}" />
                            <TextBox
                                MinWidth="320"
                                Margin="0,8,0,0"
                                HorizontalAlignment="Left"
                                Text="{Binding AuthToken, UpdateSourceTrigger=LostFocus}" />
                        </StackPanel>

                        <StackPanel Margin="0,0,0,12">
                            <TextBlock Foreground="{DynamicResource AppTextPrimary}" Text="{DynamicResource Settings.Sync.Passphrase}" />
                            <PasswordBox
                                x:Name="SyncPassphraseBox"
                                MinWidth="320"
                                Margin="0,8,0,0"
                                HorizontalAlignment="Left"
                                PasswordChanged="SyncPassphrase_Changed" />
                            <TextBlock
                                Margin="0,4,0,0"
                                FontSize="{StaticResource Font.Size.Xs}"
                                Foreground="{DynamicResource AppTextMuted}"
                                Text="{DynamicResource Settings.Sync.Passphrase.Hint}"
                                TextWrapping="Wrap" />
                        </StackPanel>

                        <StackPanel Margin="0,0,0,12">
                            <TextBlock Foreground="{DynamicResource AppTextPrimary}" Text="{DynamicResource Settings.Sync.IntervalMinutes}" />
                            <TextBox
                                MinWidth="80"
                                Margin="0,8,0,0"
                                HorizontalAlignment="Left"
                                Text="{Binding IntervalMinutes, UpdateSourceTrigger=LostFocus}" />
                            <TextBlock
                                Margin="0,4,0,0"
                                FontSize="{StaticResource Font.Size.Xs}"
                                Foreground="{DynamicResource AppTextMuted}"
                                Text="{DynamicResource Settings.Sync.IntervalMinutes.Hint}"
                                TextWrapping="Wrap" />
                        </StackPanel>

                        <CheckBox
                            Margin="0,0,0,12"
                            Content="{DynamicResource Settings.Sync.CachePassphrase}"
                            IsChecked="{Binding CachePassphraseForBackground}"
                            ToolTip="{DynamicResource Settings.Sync.CachePassphrase.Hint}" />

                        <StackPanel Margin="0,0,0,12" Orientation="Horizontal">
                            <Button
                                Margin="0,0,8,0"
                                Command="{Binding SaveSettingsCommand}"
                                Content="{DynamicResource Common.Save}" Style="{StaticResource AppSecondaryButton}" />
                            <Button
                                Command="{Binding SyncNowCommand}"
                                Content="{DynamicResource Settings.Sync.SyncNow}" Style="{StaticResource AppSecondaryButton}" />
                        </StackPanel>

                        <TextBlock
                            Margin="0,4,0,0"
                            FontSize="{StaticResource Font.Size.Xs}"
                            Foreground="{DynamicResource AppTextMuted}"
                            Text="{Binding StatusMessage}"
                            TextWrapping="Wrap" />

                        <Grid Margin="0,8,0,0">
                            <Grid.ColumnDefinitions>
                                <ColumnDefinition Width="*" />
                                <ColumnDefinition Width="*" />
                            </Grid.ColumnDefinitions>
                            <StackPanel Grid.Column="0">
                                <TextBlock
                                    FontSize="{StaticResource Font.Size.Xs}"
                                    Foreground="{DynamicResource AppTextMuted}"
                                    Text="{DynamicResource Settings.Sync.LastSync}" />
                                <TextBlock Foreground="{DynamicResource AppTextPrimary}" Text="{Binding LastSyncAt, TargetNullValue='—'}" />
                            </StackPanel>
                            <StackPanel Grid.Column="1">
                                <TextBlock
                                    FontSize="{StaticResource Font.Size.Xs}"
                                    Foreground="{DynamicResource AppTextMuted}"
                                    Text="{DynamicResource Settings.Sync.LastResult}" />
                                <TextBlock Foreground="{DynamicResource AppTextPrimary}">
                                    <Run Text="↓" />
                                    <Run Text="{Binding LastPulled, Mode=OneWay}" />
                                    <Run Text="  ↑" />
                                    <Run Text="{Binding LastPushed, Mode=OneWay}" />
                                    <Run Text="  ⚠" />
                                    <Run Text="{Binding ManualConflicts, Mode=OneWay}" />
                                </TextBlock>
                            </StackPanel>
                        </Grid>

                        <TextBlock
                            Margin="0,8,0,0"
                            FontSize="{StaticResource Font.Size.Xs}"
                            Foreground="{DynamicResource AppTextMuted}">
                            <Run Text="{DynamicResource Settings.Sync.DeviceId}" />
                            <Run Text=": " />
                            <Run Text="{Binding DeviceId, Mode=OneWay, TargetNullValue='—'}" />
                        </TextBlock>

                        <!--  Conflict resolution panel  -->
                        <StackPanel Margin="0,16,0,0" DataContext="{Binding DataContext.Conflicts, RelativeSource={RelativeSource AncestorType=UserControl}}">
                            <StackPanel Margin="0,0,0,8" Orientation="Horizontal">
                                <TextBlock
                                    FontWeight="SemiBold"
                                    Foreground="{DynamicResource AppTextPrimary}"
                                    Text="{DynamicResource Settings.Sync.Conflicts}" />
                                <Button
                                    Margin="12,0,0,0"
                                    Command="{Binding ReloadCommand}"
                                    Content="{DynamicResource Settings.Sync.Conflicts.Reload}" Style="{StaticResource AppSecondaryButton}" />
                            </StackPanel>
                            <ItemsControl ItemsSource="{Binding Items}">
                                <ItemsControl.ItemTemplate>
                                    <DataTemplate>
                                        <Border
                                            Margin="0,0,0,6"
                                            Padding="8"
                                            BorderBrush="{DynamicResource AppBorder}"
                                            BorderThickness="1"
                                            CornerRadius="{StaticResource Radius.Xs}">
                                            <StackPanel>
                                                <TextBlock FontSize="{StaticResource Font.Size.Xs}" Foreground="{DynamicResource AppTextMuted}">
                                                    <Run Text="{Binding EntityType, Mode=OneWay}" />
                                                    <Run Text=" / " />
                                                    <Run Text="{Binding EntityId, Mode=OneWay}" />
                                                </TextBlock>
                                                <TextBlock FontSize="{StaticResource Font.Size.Xs}" Foreground="{DynamicResource AppTextPrimary}">
                                                    <Run Text="local v" /><Run Text="{Binding LocalVersion, Mode=OneWay}" />
                                                    <Run Text=" @ " /><Run Text="{Binding LocalAt, Mode=OneWay}" />
                                                    <Run Text=" / remote v" /><Run Text="{Binding RemoteVersion, Mode=OneWay}" />
                                                    <Run Text=" @ " /><Run Text="{Binding RemoteAt, Mode=OneWay}" />
                                                </TextBlock>
                                                <StackPanel Margin="0,6,0,0" Orientation="Horizontal">
                                                    <Button
                                                        Margin="0,0,6,0"
                                                        Command="{Binding DataContext.KeepLocalCommand, RelativeSource={RelativeSource AncestorType=ItemsControl}}"
                                                        CommandParameter="{Binding}"
                                                        Content="{DynamicResource Settings.Sync.Conflicts.KeepLocal}" Style="{StaticResource AppSecondaryButton}" />
                                                    <Button
                                                        Command="{Binding DataContext.UseRemoteCommand, RelativeSource={RelativeSource AncestorType=ItemsControl}}"
                                                        CommandParameter="{Binding}"
                                                        Content="{DynamicResource Settings.Sync.Conflicts.UseRemote}" Style="{StaticResource AppSecondaryButton}" />
                                                </StackPanel>
                                            </StackPanel>
                                        </Border>
                                    </DataTemplate>
                                </ItemsControl.ItemTemplate>
                            </ItemsControl>
                            <TextBlock
                                FontSize="{StaticResource Font.Size.Xs}"
                                Foreground="{DynamicResource AppTextMuted}"
                                Text="{Binding StatusMessage}" />
                        </StackPanel>
                    </StackPanel>
                </Border>

            </StackPanel>
        </ScrollViewer>

        <controls:FugleHelpDialog />
    </Grid>
</UserControl>
