<UserControl
    x:Class="Assetra.WPF.Features.Settings.SettingsView"
    xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
    xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
    xmlns:categories="clr-namespace:Assetra.WPF.Features.Settings.Categories"
    xmlns:d="http://schemas.microsoft.com/expression/blend/2008"
    xmlns:ds="clr-namespace:Assetra.WPF.DesignSystem.Controls"
    xmlns:mc="http://schemas.openxmlformats.org/markup-compatibility/2006"
    xmlns:vm="clr-namespace:Assetra.WPF.Features.Settings"
    d:DataContext="{d:DesignInstance Type={x:Type vm:SettingsViewModel}}"
    d:DesignHeight="600"
    d:DesignWidth="800"
    Background="{DynamicResource AppBackground}"
    mc:Ignorable="d">

    <UserControl.Resources>

        <!--
            ── 左側分類項目樣式 ──
            視覺語彙對齊 NavRailView 的 leaf item：左側 3px accent indicator（選取時）、
            hover / 選取背景用 AppHover、icon + label 兩欄。SelectedCategory 由 ListBox
            的 SelectedValue 驅動（SelectedValuePath=Tag）。
        -->
        <Style x:Key="SettingsCategoryItem" TargetType="{x:Type ListBoxItem}">
            <Setter Property="Margin" Value="3,1" />
            <Setter Property="Padding" Value="0" />
            <Setter Property="Background" Value="Transparent" />
            <Setter Property="Cursor" Value="Hand" />
            <Setter Property="HorizontalContentAlignment" Value="Stretch" />
            <Setter Property="Template">
                <Setter.Value>
                    <ControlTemplate TargetType="{x:Type ListBoxItem}">
                        <Border
                            x:Name="Chrome"
                            Height="40"
                            Background="{TemplateBinding Background}"
                            CornerRadius="{StaticResource Radius.Sm}">
                            <Grid>
                                <Grid.ColumnDefinitions>
                                    <ColumnDefinition Width="4" />
                                    <ColumnDefinition Width="24" />
                                    <ColumnDefinition Width="*" />
                                </Grid.ColumnDefinitions>
                                <Border
                                    x:Name="Indicator"
                                    Grid.Column="0"
                                    Width="3"
                                    Height="18"
                                    HorizontalAlignment="Left"
                                    VerticalAlignment="Center"
                                    Background="{DynamicResource AppAccent}"
                                    CornerRadius="0,2,2,0"
                                    Visibility="Collapsed" />
                                <ContentPresenter
                                    Grid.Column="1"
                                    Grid.ColumnSpan="2"
                                    Margin="10,0,8,0"
                                    VerticalAlignment="Center" />
                            </Grid>
                        </Border>
                        <ControlTemplate.Triggers>
                            <Trigger Property="IsMouseOver" Value="True">
                                <Setter TargetName="Chrome" Property="Background" Value="{DynamicResource AppHover}" />
                            </Trigger>
                            <Trigger Property="IsKeyboardFocused" Value="True">
                                <Setter TargetName="Chrome" Property="BorderBrush" Value="{DynamicResource AppAccent}" />
                            </Trigger>
                            <Trigger Property="IsSelected" Value="True">
                                <Setter TargetName="Chrome" Property="Background" Value="{DynamicResource AppHover}" />
                                <Setter TargetName="Indicator" Property="Visibility" Value="Visible" />
                            </Trigger>
                        </ControlTemplate.Triggers>
                    </ControlTemplate>
                </Setter.Value>
            </Setter>
        </Style>

        <!--  ── 右側分類內容 DataTemplate（由 ContentControl 依 SelectedCategory 切換）──  -->
        <DataTemplate x:Key="AppearanceContentTemplate">
            <categories:SettingsAppearanceView />
        </DataTemplate>
        <DataTemplate x:Key="LanguageRegionContentTemplate">
            <categories:SettingsLanguageRegionView />
        </DataTemplate>
        <DataTemplate x:Key="DataSourcesContentTemplate">
            <categories:SettingsDataSourcesView />
        </DataTemplate>
        <DataTemplate x:Key="DashboardContentTemplate">
            <categories:SettingsDashboardView />
        </DataTemplate>
        <DataTemplate x:Key="TradingContentTemplate">
            <categories:SettingsTradingView />
        </DataTemplate>
        <DataTemplate x:Key="ReportsTaxContentTemplate">
            <categories:SettingsReportsTaxView />
        </DataTemplate>
        <DataTemplate x:Key="AssistantContentTemplate">
            <categories:SettingsAssistantView />
        </DataTemplate>
        <DataTemplate x:Key="SyncContentTemplate">
            <categories:SettingsSyncView />
        </DataTemplate>
        <DataTemplate x:Key="DataMaintenanceContentTemplate">
            <categories:SettingsDataMaintenanceView />
        </DataTemplate>
    </UserControl.Resources>

    <Grid Margin="24">
        <Grid.RowDefinitions>
            <RowDefinition Height="Auto" />
            <RowDefinition Height="*" />
        </Grid.RowDefinitions>

        <!--  Page title  -->
        <TextBlock
            Grid.Row="0"
            Margin="0,0,0,20"
            FontSize="{StaticResource Font.Size.Lg}"
            FontWeight="SemiBold"
            Foreground="{DynamicResource AppTextPrimary}"
            Text="{DynamicResource Settings.Title}" />

        <Grid Grid.Row="1">
            <Grid.ColumnDefinitions>
                <ColumnDefinition Width="Auto" />
                <ColumnDefinition Width="*" />
            </Grid.ColumnDefinitions>

            <!--  ── LEFT：分類導覽 ──  -->
            <Border
                Grid.Column="0"
                Width="200"
                Margin="0,0,24,0"
                Padding="4"
                VerticalAlignment="Top"
                Background="{DynamicResource AppNavRailBackground}"
                BorderBrush="{DynamicResource AppBorderLight}"
                BorderThickness="1"
                CornerRadius="{StaticResource Radius.Md}">
                <ListBox
                    Background="Transparent"
                    BorderThickness="0"
                    ItemContainerStyle="{StaticResource SettingsCategoryItem}"
                    SelectedValue="{Binding SelectedCategory, Mode=TwoWay}"
                    SelectedValuePath="Tag">
                    <ListBoxItem Tag="{x:Static vm:SettingsCategory.Appearance}">
                        <StackPanel Orientation="Horizontal">
                            <ds:AppIcon VerticalAlignment="Center" Symbol="Star24" />
                            <TextBlock
                                Margin="10,0,0,0"
                                VerticalAlignment="Center"
                                FontSize="{StaticResource Font.Size.Sm}"
                                Foreground="{DynamicResource AppTextPrimary}"
                                Text="{DynamicResource Settings.Category.Appearance}" />
                        </StackPanel>
                    </ListBoxItem>
                    <ListBoxItem Tag="{x:Static vm:SettingsCategory.LanguageRegion}">
                        <StackPanel Orientation="Horizontal">
                            <ds:AppIcon VerticalAlignment="Center" Symbol="Money24" />
                            <TextBlock
                                Margin="10,0,0,0"
                                VerticalAlignment="Center"
                                FontSize="{StaticResource Font.Size.Sm}"
                                Foreground="{DynamicResource AppTextPrimary}"
                                Text="{DynamicResource Settings.Category.LanguageRegion}" />
                        </StackPanel>
                    </ListBoxItem>
                    <ListBoxItem Tag="{x:Static vm:SettingsCategory.DataSources}">
                        <StackPanel Orientation="Horizontal">
                            <ds:AppIcon VerticalAlignment="Center" Symbol="DataPie24" />
                            <TextBlock
                                Margin="10,0,0,0"
                                VerticalAlignment="Center"
                                FontSize="{StaticResource Font.Size.Sm}"
                                Foreground="{DynamicResource AppTextPrimary}"
                                Text="{DynamicResource Settings.Category.DataSources}" />
                        </StackPanel>
                    </ListBoxItem>
                    <ListBoxItem Tag="{x:Static vm:SettingsCategory.Dashboard}">
                        <StackPanel Orientation="Horizontal">
                            <ds:AppIcon VerticalAlignment="Center" Symbol="DataBarVertical24" />
                            <TextBlock
                                Margin="10,0,0,0"
                                VerticalAlignment="Center"
                                FontSize="{StaticResource Font.Size.Sm}"
                                Foreground="{DynamicResource AppTextPrimary}"
                                Text="{DynamicResource Settings.Category.Dashboard}" />
                        </StackPanel>
                    </ListBoxItem>
                    <ListBoxItem Tag="{x:Static vm:SettingsCategory.Trading}">
                        <StackPanel Orientation="Horizontal">
                            <ds:AppIcon VerticalAlignment="Center" Symbol="ArrowSwap24" />
                            <TextBlock
                                Margin="10,0,0,0"
                                VerticalAlignment="Center"
                                FontSize="{StaticResource Font.Size.Sm}"
                                Foreground="{DynamicResource AppTextPrimary}"
                                Text="{DynamicResource Settings.Category.Trading}" />
                        </StackPanel>
                    </ListBoxItem>
                    <ListBoxItem Tag="{x:Static vm:SettingsCategory.ReportsTax}">
                        <StackPanel Orientation="Horizontal">
                            <ds:AppIcon VerticalAlignment="Center" Symbol="BuildingBank24" />
                            <TextBlock
                                Margin="10,0,0,0"
                                VerticalAlignment="Center"
                                FontSize="{StaticResource Font.Size.Sm}"
                                Foreground="{DynamicResource AppTextPrimary}"
                                Text="{DynamicResource Settings.Category.ReportsTax}" />
                        </StackPanel>
                    </ListBoxItem>
                    <ListBoxItem Tag="{x:Static vm:SettingsCategory.Assistant}">
                        <StackPanel Orientation="Horizontal">
                            <ds:AppIcon VerticalAlignment="Center" Symbol="Sparkle24" />
                            <TextBlock
                                Margin="10,0,0,0"
                                VerticalAlignment="Center"
                                FontSize="{StaticResource Font.Size.Sm}"
                                Foreground="{DynamicResource AppTextPrimary}"
                                Text="{DynamicResource Settings.Category.Assistant}" />
                        </StackPanel>
                    </ListBoxItem>
                    <ListBoxItem Tag="{x:Static vm:SettingsCategory.Sync}">
                        <StackPanel Orientation="Horizontal">
                            <ds:AppIcon VerticalAlignment="Center" Symbol="ArrowSync24" />
                            <TextBlock
                                Margin="10,0,0,0"
                                VerticalAlignment="Center"
                                FontSize="{StaticResource Font.Size.Sm}"
                                Foreground="{DynamicResource AppTextPrimary}"
                                Text="{DynamicResource Settings.Category.Sync}" />
                        </StackPanel>
                    </ListBoxItem>
                    <ListBoxItem Tag="{x:Static vm:SettingsCategory.DataMaintenance}">
                        <StackPanel Orientation="Horizontal">
                            <ds:AppIcon VerticalAlignment="Center" Symbol="Wrench24" />
                            <TextBlock
                                Margin="10,0,0,0"
                                VerticalAlignment="Center"
                                FontSize="{StaticResource Font.Size.Sm}"
                                Foreground="{DynamicResource AppTextPrimary}"
                                Text="{DynamicResource Settings.Category.DataMaintenance}" />
                        </StackPanel>
                    </ListBoxItem>
                </ListBox>
            </Border>

            <!--  ── RIGHT：選取分類的內容 ──  -->
            <ScrollViewer
                Grid.Column="1"
                HorizontalScrollBarVisibility="Disabled"
                VerticalScrollBarVisibility="Auto">
                <!--
                    Content="{Binding}" 讓子視圖沿用 SettingsViewModel DataContext；
                    ContentTemplate 依 SelectedCategory 由 DataTrigger 切換（鏡 NavRailView
                    的 ContentControl section-switching）。
                -->
                <ContentControl
                    HorizontalAlignment="Stretch"
                    HorizontalContentAlignment="Stretch"
                    Content="{Binding}">
                    <ContentControl.Style>
                        <Style TargetType="{x:Type ContentControl}">
                            <Setter Property="ContentTemplate" Value="{StaticResource AppearanceContentTemplate}" />
                            <Style.Triggers>
                                <DataTrigger Binding="{Binding SelectedCategory}" Value="{x:Static vm:SettingsCategory.Appearance}">
                                    <Setter Property="ContentTemplate" Value="{StaticResource AppearanceContentTemplate}" />
                                </DataTrigger>
                                <DataTrigger Binding="{Binding SelectedCategory}" Value="{x:Static vm:SettingsCategory.LanguageRegion}">
                                    <Setter Property="ContentTemplate" Value="{StaticResource LanguageRegionContentTemplate}" />
                                </DataTrigger>
                                <DataTrigger Binding="{Binding SelectedCategory}" Value="{x:Static vm:SettingsCategory.DataSources}">
                                    <Setter Property="ContentTemplate" Value="{StaticResource DataSourcesContentTemplate}" />
                                </DataTrigger>
                                <DataTrigger Binding="{Binding SelectedCategory}" Value="{x:Static vm:SettingsCategory.Dashboard}">
                                    <Setter Property="ContentTemplate" Value="{StaticResource DashboardContentTemplate}" />
                                </DataTrigger>
                                <DataTrigger Binding="{Binding SelectedCategory}" Value="{x:Static vm:SettingsCategory.Trading}">
                                    <Setter Property="ContentTemplate" Value="{StaticResource TradingContentTemplate}" />
                                </DataTrigger>
                                <DataTrigger Binding="{Binding SelectedCategory}" Value="{x:Static vm:SettingsCategory.ReportsTax}">
                                    <Setter Property="ContentTemplate" Value="{StaticResource ReportsTaxContentTemplate}" />
                                </DataTrigger>
                                <DataTrigger Binding="{Binding SelectedCategory}" Value="{x:Static vm:SettingsCategory.Assistant}">
                                    <Setter Property="ContentTemplate" Value="{StaticResource AssistantContentTemplate}" />
                                </DataTrigger>
                                <DataTrigger Binding="{Binding SelectedCategory}" Value="{x:Static vm:SettingsCategory.Sync}">
                                    <Setter Property="ContentTemplate" Value="{StaticResource SyncContentTemplate}" />
                                </DataTrigger>
                                <DataTrigger Binding="{Binding SelectedCategory}" Value="{x:Static vm:SettingsCategory.DataMaintenance}">
                                    <Setter Property="ContentTemplate" Value="{StaticResource DataMaintenanceContentTemplate}" />
                                </DataTrigger>
                            </Style.Triggers>
                        </Style>
                    </ContentControl.Style>
                </ContentControl>
            </ScrollViewer>
        </Grid>
    </Grid>

    <!--
        FugleHelpDialog / TwelveDataHelpDialog / RebuildSnapshotHistoryDialog 掛載於
        MainWindow.xaml（讓 backdrop 蓋住 NavRail + 標題列）。相關 VM property
        (IsFugleHelpOpen / IsTwelveDataHelpOpen / IsRebuildPreviewOpen 等) 不變。
    -->
</UserControl>
