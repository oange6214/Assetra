<UserControl
    x:Class="Assetra.WPF.Features.Settings.SettingsView"
    xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
    xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
    xmlns:controls="clr-namespace:Assetra.WPF.Features.Settings.Controls"
    xmlns:d="http://schemas.microsoft.com/expression/blend/2008"
    xmlns:mc="http://schemas.openxmlformats.org/markup-compatibility/2006"
    xmlns:vm="clr-namespace:Assetra.WPF.Features.Settings"
    d:DataContext="{d:DesignInstance Type={x:Type vm:SettingsViewModel},
                                     IsDesignTimeCreatable=False}"
    d:DesignHeight="600"
    d:DesignWidth="800"
    Background="{DynamicResource AppBackground}"
    Loaded="UserControl_Loaded"
    mc:Ignorable="d">

  <Grid>
    <ScrollViewer
            Padding="24"
            HorizontalScrollBarVisibility="Disabled"
            VerticalScrollBarVisibility="Auto">

      <!--
                HorizontalAlignment="Stretch" 讓 Grid 星號欄能正確撐開；
                MaxWidth 限制最大寬度避免過寬。
                Grid.IsSharedSizeScope="True" 讓兩個 section 的 label 欄共享同一寬度。
            -->
      <StackPanel
                MaxWidth="680"
                HorizontalAlignment="Stretch"
                Grid.IsSharedSizeScope="True">

        <!--  Page title  -->
        <TextBlock
                    Margin="0,0,0,20"
                    FontSize="{StaticResource FontSizeLg}"
                    FontWeight="SemiBold"
                    Foreground="{DynamicResource AppTextPrimary}"
                    Text="{DynamicResource Settings.Title}" />

        <!--  ── 外觀 ──  -->
        <TextBlock
                    Margin="0,0,0,8"
                    FontSize="{StaticResource FontSizeMd}"
                    FontWeight="SemiBold"
                    Foreground="{DynamicResource AppTextPrimary}"
                    Text="{DynamicResource Settings.Section.Appearance}" />

        <Border
                    Margin="0,0,0,24"
                    Padding="16,12"
                    Background="{DynamicResource AppSurface}"
                    BorderBrush="{DynamicResource AppBorder}"
                    BorderThickness="1"
                    CornerRadius="{StaticResource RadiusSm}">
          <StackPanel>
            <StackPanel Margin="0,0,0,14">
              <TextBlock
                                Foreground="{DynamicResource AppTextPrimary}"
                                Text="{DynamicResource Settings.DarkTheme}" />
              <CheckBox
                                Margin="0,8,0,0"
                                HorizontalAlignment="Left"
                                IsChecked="{Binding IsDarkTheme}" />
            </StackPanel>

            <StackPanel Margin="0,0,0,14">
              <TextBlock
                                Foreground="{DynamicResource AppTextPrimary}"
                                Text="{DynamicResource Settings.ColorScheme}" />
              <WrapPanel Margin="0,8,0,0">
                <RadioButton
                                    Margin="0,0,20,8"
                                    Content="{DynamicResource Settings.ColorScheme.Taiwan}"
                                    GroupName="ColorScheme"
                                    IsChecked="{Binding UseTaiwanColors}" />
                <RadioButton
                                    Margin="0,0,0,8"
                                    Content="{DynamicResource Settings.ColorScheme.International}"
                                    GroupName="ColorScheme"
                                    IsChecked="{Binding UseInternationalColors}" />
              </WrapPanel>
            </StackPanel>

            <StackPanel>
              <TextBlock
                                Foreground="{DynamicResource AppTextPrimary}"
                                Text="{DynamicResource Settings.UiScale}" />
              <TextBlock
                                Margin="0,8,0,6"
                                FontSize="{StaticResource FontSizeXs}"
                                Foreground="{DynamicResource AppTextMuted}"
                                Text="{DynamicResource Settings.UiScaleDesc}"
                                TextWrapping="Wrap" />
              <Grid MaxWidth="420">
                <Grid.ColumnDefinitions>
                  <ColumnDefinition Width="*" />
                  <ColumnDefinition Width="52" />
                </Grid.ColumnDefinitions>
                <Slider
                                    x:Name="UiScaleSlider"
                                    Grid.Column="0"
                                    VerticalAlignment="Center"
                                    IsSnapToTickEnabled="True"
                                    LargeChange="0.1"
                                    Maximum="1.5"
                                    Minimum="0.75"
                                    PreviewMouseLeftButtonUp="OnUiScaleSliderMouseUp"
                                    SmallChange="0.05"
                                    Thumb.DragCompleted="OnUiScaleSliderDragCompleted"
                                    TickFrequency="0.05"
                                    Value="{Binding UiScalePreview, UpdateSourceTrigger=PropertyChanged}" />
                <TextBlock
                                    Grid.Column="1"
                                    Margin="8,0,0,0"
                                    VerticalAlignment="Center"
                                    FontFamily="{StaticResource FontTabular}"
                                    FontSize="{StaticResource FontSizeSm}"
                                    Foreground="{DynamicResource AppTextPrimary}"
                                    Text="{Binding UiScaleDisplay}"
                                    TextAlignment="Right" />
              </Grid>
              <DockPanel Margin="0,4,0,0" MaxWidth="360" LastChildFill="False">
                <TextBlock
                                    DockPanel.Dock="Left"
                                    FontSize="{StaticResource FontSizeXs}"
                                    Foreground="{DynamicResource AppTextMuted}"
                                    Text="0.75×" />
                <TextBlock
                                    DockPanel.Dock="Right"
                                    FontSize="{StaticResource FontSizeXs}"
                                    Foreground="{DynamicResource AppTextMuted}"
                                    Text="1.50×" />
              </DockPanel>
            </StackPanel>
          </StackPanel>
        </Border>

        <!--  ── 語言與區域  ──  -->
        <TextBlock
                    Margin="0,0,0,8"
                    FontSize="{StaticResource FontSizeMd}"
                    FontWeight="SemiBold"
                    Foreground="{DynamicResource AppTextPrimary}"
                    Text="{DynamicResource Settings.Section.Language}" />

        <Border
                    Margin="0,0,0,24"
                    Padding="16,12"
                    Background="{DynamicResource AppSurface}"
                    BorderBrush="{DynamicResource AppBorder}"
                    BorderThickness="1"
                    CornerRadius="{StaticResource RadiusSm}">
          <StackPanel>
            <StackPanel Margin="0,0,0,14">
              <TextBlock
                                Foreground="{DynamicResource AppTextPrimary}"
                                Text="{DynamicResource Settings.Language}" />
              <ComboBox
                                MinWidth="220"
                                MaxWidth="320"
                                Margin="0,8,0,0"
                                HorizontalAlignment="Stretch"
                                DisplayMemberPath="Display"
                                ItemsSource="{x:Static vm:SettingsViewModel.SupportedLanguages}"
                                SelectedValue="{Binding Language}"
                                SelectedValuePath="Code" />
            </StackPanel>

            <StackPanel>
              <TextBlock
                                Foreground="{DynamicResource AppTextPrimary}"
                                Text="{DynamicResource Settings.PrimaryCurrency}" />
              <ComboBox
                                MinWidth="220"
                                MaxWidth="320"
                                Margin="0,8,0,0"
                                HorizontalAlignment="Stretch"
                                ItemsSource="{Binding SupportedCurrencies}"
                                SelectedItem="{Binding PrimaryCurrency}" />
            </StackPanel>

            <StackPanel>
              <TextBlock
                                Foreground="{DynamicResource AppTextPrimary}"
                                Text="{DynamicResource Settings.BaseCurrency}" />
              <ComboBox
                                MinWidth="220"
                                MaxWidth="320"
                                Margin="0,8,0,0"
                                HorizontalAlignment="Stretch"
                                ItemsSource="{Binding SupportedCurrencies}"
                                SelectedItem="{Binding BaseCurrency}"
                                ToolTip="{DynamicResource Settings.BaseCurrency.Tooltip}" />
            </StackPanel>
          </StackPanel>
        </Border>

        <!--  ── 資料 ──  -->
        <TextBlock
                    Margin="0,0,0,8"
                    FontSize="{StaticResource FontSizeMd}"
                    FontWeight="SemiBold"
                    Foreground="{DynamicResource AppTextPrimary}"
                    Text="{DynamicResource Settings.Section.Data}" />

        <Border
                    Margin="0,0,0,24"
                    Padding="16,12"
                    Background="{DynamicResource AppSurface}"
                    BorderBrush="{DynamicResource AppBorder}"
                    BorderThickness="1"
                    CornerRadius="{StaticResource RadiusSm}">
          <StackPanel>
            <StackPanel Margin="0,0,0,14">
              <TextBlock
                                Foreground="{DynamicResource AppTextPrimary}"
                                Text="{DynamicResource Settings.DataDir}" />
              <StackPanel Margin="0,8,0,0">
                <TextBlock
                                    Margin="0,0,0,8"
                                    FontSize="{StaticResource FontSizeXs}"
                                    Foreground="{DynamicResource AppTextMuted}"
                                    Text="{Binding DataFolderPath}"
                                    TextWrapping="Wrap" />
                <Button
                                    HorizontalAlignment="Left"
                                    Command="{Binding OpenDataFolderCommand}"
                                    Content="{DynamicResource Settings.OpenDir}"
                                    Style="{StaticResource BtnGhost}" />
              </StackPanel>
            </StackPanel>

            <StackPanel Margin="0,0,0,14">
              <TextBlock
                                Foreground="{DynamicResource AppTextPrimary}"
                                Text="{DynamicResource Settings.Version}" />
              <TextBlock
                                Margin="0,8,0,0"
                                Foreground="{DynamicResource AppTextMuted}"
                                Text="{Binding AppVersion}" />
            </StackPanel>

            <StackPanel Margin="0,0,0,14">
              <TextBlock
                                Foreground="{DynamicResource AppTextPrimary}"
                                Text="{DynamicResource Settings.QuoteSource}" />
              <ComboBox
                                MinWidth="220"
                                MaxWidth="320"
                                Margin="0,8,0,0"
                                HorizontalAlignment="Stretch"
                                DisplayMemberPath="Display"
                                ItemsSource="{x:Static vm:SettingsViewModel.SupportedQuoteProviders}"
                                SelectedValue="{Binding QuoteProvider}"
                                SelectedValuePath="Code" />
            </StackPanel>

            <StackPanel Margin="0,0,0,14">
              <TextBlock
                                Foreground="{DynamicResource AppTextPrimary}"
                                Text="{DynamicResource Settings.DataSource}" />
              <ComboBox
                                MinWidth="220"
                                MaxWidth="320"
                                Margin="0,8,0,0"
                                HorizontalAlignment="Stretch"
                                DisplayMemberPath="Display"
                                ItemsSource="{x:Static vm:SettingsViewModel.SupportedHistoryProviders}"
                                SelectedValue="{Binding HistoryProvider}"
                                SelectedValuePath="Code" />
            </StackPanel>

            <StackPanel>
              <StackPanel Orientation="Horizontal">
                <TextBlock
                                    VerticalAlignment="Center"
                                    Foreground="{DynamicResource AppTextPrimary}"
                                    Text="{DynamicResource Settings.FugleApiKey}" />
                <Button
                                    Margin="6,-2,0,0"
                                    Command="{Binding OpenFugleHelpCommand}"
                                    Style="{StaticResource BtnIcon}"
                                    ToolTip="{DynamicResource Settings.FugleHelp.Tooltip}">
                  <TextBlock
                                        FontFamily="Segoe MDL2 Assets"
                                        FontSize="{StaticResource FontSizeXs}"
                                        Foreground="{DynamicResource AppTextMuted}"
                                        Text="&#xE946;" />
                </Button>
              </StackPanel>
              <StackPanel Margin="0,8,0,0" MaxWidth="420">
                <PasswordBox
                                    x:Name="FugleApiKeyBox"
                                    MinWidth="220"
                                    MaxWidth="420"
                                    Margin="0,0,0,8"
                                    HorizontalAlignment="Stretch"
                                    PasswordChanged="FugleApiKeyBox_OnPasswordChanged" />
                <Button
                                    Margin="0,0,0,8"
                                    HorizontalAlignment="Left"
                                    Command="{Binding SaveDataSourceSettingsCommand}"
                                    Content="{DynamicResource Common.Save}"
                                    Style="{StaticResource BtnGhost}" />
              </StackPanel>
              <TextBlock
                                Margin="0,0,0,0"
                                FontSize="{StaticResource FontSizeXs}"
                                Foreground="{DynamicResource AppTextMuted}"
                                Text="{DynamicResource Settings.FugleApiKeyHint}"
                                TextWrapping="Wrap" />
              <TextBlock
                                Margin="0,4,0,0"
                                FontSize="{StaticResource FontSizeXs}"
                                Foreground="{DynamicResource AppTextMuted}"
                                Text="{Binding DataSourceSaveStatus}"
                                TextWrapping="Wrap" />
            </StackPanel>
          </StackPanel>
        </Border>

        <TextBlock
                    Margin="0,0,0,8"
                    FontSize="{StaticResource FontSizeMd}"
                    FontWeight="SemiBold"
                    Foreground="{DynamicResource AppTextPrimary}"
                    Text="{DynamicResource Settings.Section.Ocr}" />

        <Border
                    Margin="0,0,0,24"
                    Padding="16,12"
                    Background="{DynamicResource AppSurface}"
                    BorderBrush="{DynamicResource AppBorder}"
                    BorderThickness="1"
                    CornerRadius="{StaticResource RadiusSm}">
          <StackPanel>
            <StackPanel Margin="0,0,0,14">
              <TextBlock
                                Foreground="{DynamicResource AppTextPrimary}"
                                Text="{DynamicResource Settings.Ocr.TessdataPath}" />
              <StackPanel Margin="0,8,0,0" MaxWidth="520" Orientation="Horizontal">
                <TextBox
                                    MinWidth="320"
                                    Margin="0,0,8,0"
                                    Text="{Binding OcrTessdataPath, UpdateSourceTrigger=LostFocus}" />
                <Button
                                    Command="{Binding BrowseOcrTessdataCommand}"
                                    Content="{DynamicResource Common.Browse}"
                                    Style="{StaticResource BtnGhost}" />
              </StackPanel>
              <TextBlock
                                Margin="0,4,0,0"
                                FontSize="{StaticResource FontSizeXs}"
                                Foreground="{DynamicResource AppTextMuted}"
                                Text="{DynamicResource Settings.Ocr.TessdataPath.Hint}"
                                TextWrapping="Wrap" />
            </StackPanel>

            <StackPanel>
              <TextBlock
                                Foreground="{DynamicResource AppTextPrimary}"
                                Text="{DynamicResource Settings.Ocr.Language}" />
              <TextBox
                                MinWidth="220"
                                MaxWidth="320"
                                Margin="0,8,0,0"
                                HorizontalAlignment="Left"
                                Text="{Binding OcrLanguage, UpdateSourceTrigger=LostFocus}" />
              <TextBlock
                                Margin="0,4,0,0"
                                FontSize="{StaticResource FontSizeXs}"
                                Foreground="{DynamicResource AppTextMuted}"
                                Text="{DynamicResource Settings.Ocr.Language.Hint}"
                                TextWrapping="Wrap" />
            </StackPanel>
          </StackPanel>
        </Border>

        <!--  ── 雲端同步 ──  -->
        <TextBlock
                    Margin="0,0,0,8"
                    FontSize="{StaticResource FontSizeMd}"
                    FontWeight="SemiBold"
                    Foreground="{DynamicResource AppTextPrimary}"
                    Text="{DynamicResource Settings.Section.Sync}" />

        <Border
                    Margin="0,0,0,24"
                    Padding="16,12"
                    Background="{DynamicResource AppSurface}"
                    BorderBrush="{DynamicResource AppBorder}"
                    BorderThickness="1"
                    CornerRadius="{StaticResource RadiusSm}">
          <StackPanel DataContext="{Binding Sync}">
            <CheckBox
                                Margin="0,0,0,12"
                                Content="{DynamicResource Settings.Sync.Enabled}"
                                IsChecked="{Binding Enabled}" />

            <StackPanel Margin="0,0,0,12">
              <TextBlock
                                Foreground="{DynamicResource AppTextPrimary}"
                                Text="{DynamicResource Settings.Sync.BackendUrl}" />
              <TextBox
                                MinWidth="320"
                                Margin="0,8,0,0"
                                HorizontalAlignment="Left"
                                Text="{Binding BackendUrl, UpdateSourceTrigger=LostFocus}" />
              <TextBlock
                                Margin="0,4,0,0"
                                FontSize="{StaticResource FontSizeXs}"
                                Foreground="{DynamicResource AppTextMuted}"
                                Text="{DynamicResource Settings.Sync.BackendUrl.Hint}"
                                TextWrapping="Wrap" />
            </StackPanel>

            <StackPanel Margin="0,0,0,12">
              <TextBlock
                                Foreground="{DynamicResource AppTextPrimary}"
                                Text="{DynamicResource Settings.Sync.AuthToken}" />
              <TextBox
                                MinWidth="320"
                                Margin="0,8,0,0"
                                HorizontalAlignment="Left"
                                Text="{Binding AuthToken, UpdateSourceTrigger=LostFocus}" />
            </StackPanel>

            <StackPanel Margin="0,0,0,12">
              <TextBlock
                                Foreground="{DynamicResource AppTextPrimary}"
                                Text="{DynamicResource Settings.Sync.Passphrase}" />
              <PasswordBox
                                x:Name="SyncPassphraseBox"
                                MinWidth="320"
                                Margin="0,8,0,0"
                                HorizontalAlignment="Left"
                                PasswordChanged="SyncPassphrase_Changed" />
              <TextBlock
                                Margin="0,4,0,0"
                                FontSize="{StaticResource FontSizeXs}"
                                Foreground="{DynamicResource AppTextMuted}"
                                Text="{DynamicResource Settings.Sync.Passphrase.Hint}"
                                TextWrapping="Wrap" />
            </StackPanel>

            <StackPanel Margin="0,0,0,12">
              <TextBlock
                                Foreground="{DynamicResource AppTextPrimary}"
                                Text="{DynamicResource Settings.Sync.IntervalMinutes}" />
              <TextBox
                                MinWidth="80"
                                Margin="0,8,0,0"
                                HorizontalAlignment="Left"
                                Text="{Binding IntervalMinutes, UpdateSourceTrigger=LostFocus}" />
              <TextBlock
                                Margin="0,4,0,0"
                                FontSize="{StaticResource FontSizeXs}"
                                Foreground="{DynamicResource AppTextMuted}"
                                Text="{DynamicResource Settings.Sync.IntervalMinutes.Hint}"
                                TextWrapping="Wrap" />
            </StackPanel>

            <CheckBox
                                Margin="0,0,0,12"
                                Content="{DynamicResource Settings.Sync.CachePassphrase}"
                                IsChecked="{Binding CachePassphraseForBackground}"
                                ToolTip="{DynamicResource Settings.Sync.CachePassphrase.Hint}" />

            <StackPanel Margin="0,0,0,12" Orientation="Horizontal">
              <Button
                                Margin="0,0,8,0"
                                Command="{Binding SaveSettingsCommand}"
                                Content="{DynamicResource Common.Save}"
                                Style="{StaticResource BtnGhost}" />
              <Button
                                Command="{Binding SyncNowCommand}"
                                Content="{DynamicResource Settings.Sync.SyncNow}"
                                Style="{StaticResource BtnGhost}" />
            </StackPanel>

            <TextBlock
                            Margin="0,4,0,0"
                            FontSize="{StaticResource FontSizeXs}"
                            Foreground="{DynamicResource AppTextMuted}"
                            Text="{Binding StatusMessage}"
                            TextWrapping="Wrap" />

            <Grid Margin="0,8,0,0">
              <Grid.ColumnDefinitions>
                <ColumnDefinition Width="*" />
                <ColumnDefinition Width="*" />
              </Grid.ColumnDefinitions>
              <StackPanel Grid.Column="0">
                <TextBlock
                                    FontSize="{StaticResource FontSizeXs}"
                                    Foreground="{DynamicResource AppTextMuted}"
                                    Text="{DynamicResource Settings.Sync.LastSync}" />
                <TextBlock
                                    Foreground="{DynamicResource AppTextPrimary}"
                                    Text="{Binding LastSyncAt, TargetNullValue='—'}" />
              </StackPanel>
              <StackPanel Grid.Column="1">
                <TextBlock
                                    FontSize="{StaticResource FontSizeXs}"
                                    Foreground="{DynamicResource AppTextMuted}"
                                    Text="{DynamicResource Settings.Sync.LastResult}" />
                <TextBlock Foreground="{DynamicResource AppTextPrimary}">
                  <Run Text="↓" />
                  <Run Text="{Binding LastPulled, Mode=OneWay}" />
                  <Run Text="  ↑" />
                  <Run Text="{Binding LastPushed, Mode=OneWay}" />
                  <Run Text="  ⚠" />
                  <Run Text="{Binding ManualConflicts, Mode=OneWay}" />
                </TextBlock>
              </StackPanel>
            </Grid>

            <TextBlock
                            Margin="0,8,0,0"
                            FontSize="{StaticResource FontSizeXs}"
                            Foreground="{DynamicResource AppTextMuted}">
              <Run Text="{DynamicResource Settings.Sync.DeviceId}" />
              <Run Text=": " />
              <Run Text="{Binding DeviceId, Mode=OneWay, TargetNullValue='—'}" />
            </TextBlock>

            <!-- Conflict resolution panel -->
            <StackPanel Margin="0,16,0,0" DataContext="{Binding DataContext.Conflicts, RelativeSource={RelativeSource AncestorType=UserControl}}">
              <StackPanel Orientation="Horizontal" Margin="0,0,0,8">
                <TextBlock
                                    FontWeight="SemiBold"
                                    Foreground="{DynamicResource AppTextPrimary}"
                                    Text="{DynamicResource Settings.Sync.Conflicts}" />
                <Button
                                    Margin="12,0,0,0"
                                    Command="{Binding ReloadCommand}"
                                    Content="{DynamicResource Settings.Sync.Conflicts.Reload}"
                                    Style="{StaticResource BtnGhost}" />
              </StackPanel>
              <ItemsControl ItemsSource="{Binding Items}">
                <ItemsControl.ItemTemplate>
                  <DataTemplate>
                    <Border
                                            Margin="0,0,0,6"
                                            Padding="8"
                                            BorderBrush="{DynamicResource AppBorder}"
                                            BorderThickness="1"
                                            CornerRadius="{StaticResource RadiusXs}">
                      <StackPanel>
                        <TextBlock FontSize="{StaticResource FontSizeXs}" Foreground="{DynamicResource AppTextMuted}">
                          <Run Text="{Binding EntityType, Mode=OneWay}" />
                          <Run Text=" / " />
                          <Run Text="{Binding EntityId, Mode=OneWay}" />
                        </TextBlock>
                        <TextBlock FontSize="{StaticResource FontSizeXs}" Foreground="{DynamicResource AppTextPrimary}">
                          <Run Text="local v" /><Run Text="{Binding LocalVersion, Mode=OneWay}" />
                          <Run Text=" @ " /><Run Text="{Binding LocalAt, Mode=OneWay}" />
                          <Run Text=" / remote v" /><Run Text="{Binding RemoteVersion, Mode=OneWay}" />
                          <Run Text=" @ " /><Run Text="{Binding RemoteAt, Mode=OneWay}" />
                        </TextBlock>
                        <StackPanel Margin="0,6,0,0" Orientation="Horizontal">
                          <Button
                                                        Margin="0,0,6,0"
                                                        Command="{Binding DataContext.KeepLocalCommand, RelativeSource={RelativeSource AncestorType=ItemsControl}}"
                                                        CommandParameter="{Binding}"
                                                        Content="{DynamicResource Settings.Sync.Conflicts.KeepLocal}"
                                                        Style="{StaticResource BtnGhost}" />
                          <Button
                                                        Command="{Binding DataContext.UseRemoteCommand, RelativeSource={RelativeSource AncestorType=ItemsControl}}"
                                                        CommandParameter="{Binding}"
                                                        Content="{DynamicResource Settings.Sync.Conflicts.UseRemote}"
                                                        Style="{StaticResource BtnGhost}" />
                        </StackPanel>
                      </StackPanel>
                    </Border>
                  </DataTemplate>
                </ItemsControl.ItemTemplate>
              </ItemsControl>
              <TextBlock
                                FontSize="{StaticResource FontSizeXs}"
                                Foreground="{DynamicResource AppTextMuted}"
                                Text="{Binding StatusMessage}" />
            </StackPanel>
          </StackPanel>
        </Border>

      </StackPanel>
    </ScrollViewer>

    <controls:FugleHelpDialog />
  </Grid>
</UserControl>
