<UserControl
    x:Class="Assetra.WPF.Features.PortfolioGroups.PortfolioGroupsView"
    xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
    xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
    xmlns:d="http://schemas.microsoft.com/expression/blend/2008"
    xmlns:mc="http://schemas.openxmlformats.org/markup-compatibility/2006"
    xmlns:vm="clr-namespace:Assetra.WPF.Features.PortfolioGroups"
    xmlns:ds="clr-namespace:Assetra.WPF.DesignSystem.Controls"
    xmlns:behaviors="clr-namespace:Assetra.WPF.Infrastructure.Behaviors"
    d:DataContext="{d:DesignInstance Type={x:Type vm:PortfolioGroupsViewModel},
                                     IsDesignTimeCreatable=False}"
    Background="{DynamicResource AppBackground}"
    mc:Ignorable="d">

    <!--
        Portfolio-Groups-Refactor P2：簡易 CRUD page（現於 shell 對話框內）。
        標題／副標／「+ 新增」鈕在對話框 header（MainWindow）。此處 = 就地新增列 + 群組清單。
        每一列：顯示模式（名稱 + 系統 badge + 編輯/刪除）↔ 就地編輯模式（名稱輸入 + 儲存/取消），
        依 row.IsBeingEdited 切換（PortfolioGroupsViewModel 依 EditingId 設定）。
        系統預設群組顯示「系統」badge 且 Delete 按鈕隱藏。
    -->
    <Grid>
        <Grid.RowDefinitions>
            <RowDefinition Height="Auto" />
            <RowDefinition Height="*" />
        </Grid.RowDefinitions>

        <!--  就地「新增」列：點對話框 header 的「+ 新增投資組合」時冒出（IsAddingNew）。  -->
        <Border Grid.Row="0"
                Margin="0,0,12,12"
                Padding="14,10"
                Background="{DynamicResource AppCardBackground}"
                BorderBrush="{DynamicResource AppAccent}"
                BorderThickness="1"
                CornerRadius="{StaticResource Radius.Sm}"
                behaviors:EscapeKeyCommandBehavior.Command="{Binding CancelCommand}"
                Visibility="{Binding IsAddingNew, Converter={StaticResource BooleanToVisibilityConverter}}">
            <StackPanel>
                <DockPanel LastChildFill="True">
                    <Button DockPanel.Dock="Right"
                            Margin="8,0,0,0"
                            Padding="12,4"
                            Command="{Binding SaveCommand}"
                            Content="{DynamicResource Common.Save}"
                            Style="{StaticResource AppPrimaryButton}" />
                    <Button DockPanel.Dock="Right"
                            Padding="12,4"
                            Command="{Binding CancelCommand}"
                            Content="{DynamicResource Common.Cancel}"
                            Style="{StaticResource AppSecondaryButton}" />
                    <TextBox VerticalAlignment="Center"
                             Text="{Binding FormName, UpdateSourceTrigger=PropertyChanged}" />
                </DockPanel>
                <TextBlock Margin="0,8,0,0"
                           FontSize="{StaticResource Font.Size.Xs}"
                           Foreground="{DynamicResource AppDown}"
                           Text="{Binding FormError}"
                           TextWrapping="Wrap"
                           Visibility="{Binding FormError, Converter={StaticResource StringToVisibilityConverter}}" />
            </StackPanel>
        </Border>

        <!--  群組清單  -->
        <ScrollViewer Grid.Row="1" VerticalScrollBarVisibility="Auto">
            <ItemsControl ItemsSource="{Binding Groups}">
                <ItemsControl.ItemTemplate>
                    <DataTemplate DataType="{x:Type vm:PortfolioGroupRowViewModel}">
                        <Border Margin="0,0,12,8"
                                Padding="14,12"
                                Background="{DynamicResource AppCardBackground}"
                                BorderBrush="{DynamicResource AppBorder}"
                                BorderThickness="1"
                                CornerRadius="{StaticResource Radius.Sm}">
                            <Grid>
                                <Grid.ColumnDefinitions>
                                    <ColumnDefinition Width="6" />
                                    <ColumnDefinition Width="12" />
                                    <ColumnDefinition Width="*" />
                                    <ColumnDefinition Width="Auto" />
                                </Grid.ColumnDefinitions>

                                <!--  Color swatch (left strip)  -->
                                <Border Grid.Column="0"
                                        Background="{Binding EffectiveColorHex, Converter={StaticResource HexToBrushConverter}}"
                                        CornerRadius="3"
                                        VerticalAlignment="Stretch" />

                                <!--  顯示模式：名稱 + 系統 badge + 說明  -->
                                <StackPanel Grid.Column="2"
                                            VerticalAlignment="Center"
                                            Visibility="{Binding IsBeingEdited, Converter={StaticResource InverseBooleanToVisibilityConverter}}">
                                    <StackPanel Orientation="Horizontal">
                                        <TextBlock FontSize="{StaticResource Font.Size.Sm}"
                                                   FontWeight="SemiBold"
                                                   Foreground="{DynamicResource AppTextPrimary}"
                                                   Text="{Binding Name}" />
                                        <Border Margin="8,0,0,0"
                                                Padding="6,1"
                                                VerticalAlignment="Center"
                                                Background="{DynamicResource AppSurface}"
                                                BorderBrush="{DynamicResource AppBorder}"
                                                BorderThickness="1"
                                                CornerRadius="{StaticResource Radius.Lg}"
                                                Visibility="{Binding IsSystem, Converter={StaticResource BooleanToVisibilityConverter}}">
                                            <TextBlock FontSize="{StaticResource Font.Size.Xs}"
                                                       Foreground="{DynamicResource AppTextMuted}"
                                                       Text="{DynamicResource PortfolioGroups.SystemBadge}" />
                                        </Border>
                                    </StackPanel>
                                    <TextBlock Margin="0,2,0,0"
                                               FontSize="{StaticResource Font.Size.Xs}"
                                               Foreground="{DynamicResource AppTextMuted}"
                                               Text="{Binding Description}"
                                               TextTrimming="CharacterEllipsis"
                                               Visibility="{Binding Description, Converter={StaticResource StringToVisibilityConverter}}" />
                                </StackPanel>

                                <!--  就地編輯模式：名稱輸入（綁父 VM 的 FormName 緩衝，Esc 取消）  -->
                                <TextBox Grid.Column="2"
                                         VerticalAlignment="Center"
                                         behaviors:EscapeKeyCommandBehavior.Command="{Binding DataContext.CancelCommand, RelativeSource={RelativeSource AncestorType=UserControl}}"
                                         Text="{Binding DataContext.FormName, RelativeSource={RelativeSource AncestorType=UserControl}, UpdateSourceTrigger=PropertyChanged}"
                                         Visibility="{Binding IsBeingEdited, Converter={StaticResource BooleanToVisibilityConverter}}" />

                                <!--  Actions  -->
                                <Grid Grid.Column="3" VerticalAlignment="Center">
                                    <!--  顯示模式：編輯 / 刪除  -->
                                    <StackPanel Orientation="Horizontal"
                                                Visibility="{Binding IsBeingEdited, Converter={StaticResource InverseBooleanToVisibilityConverter}}">
                                        <Button Margin="0,0,4,0"
                                                Padding="8,4"
                                                Command="{Binding DataContext.StartEditCommand, RelativeSource={RelativeSource AncestorType=UserControl}}"
                                                CommandParameter="{Binding}"
                                                Content="{DynamicResource Common.Edit}"
                                                Style="{StaticResource AppSecondaryButton}" />
                                        <Button Padding="8,4"
                                                Command="{Binding DataContext.RemoveCommand, RelativeSource={RelativeSource AncestorType=UserControl}}"
                                                CommandParameter="{Binding}"
                                                Content="{DynamicResource Common.Delete}"
                                                Style="{StaticResource AppSecondaryButton}"
                                                Visibility="{Binding IsSystem, Converter={StaticResource InverseBooleanToVisibilityConverter}}" />
                                    </StackPanel>
                                    <!--  就地編輯模式：儲存 / 取消  -->
                                    <StackPanel Orientation="Horizontal"
                                                Visibility="{Binding IsBeingEdited, Converter={StaticResource BooleanToVisibilityConverter}}">
                                        <Button Margin="0,0,4,0"
                                                Padding="10,4"
                                                Command="{Binding DataContext.SaveCommand, RelativeSource={RelativeSource AncestorType=UserControl}}"
                                                Content="{DynamicResource Common.Save}"
                                                Style="{StaticResource AppPrimaryButton}" />
                                        <Button Padding="10,4"
                                                Command="{Binding DataContext.CancelCommand, RelativeSource={RelativeSource AncestorType=UserControl}}"
                                                Content="{DynamicResource Common.Cancel}"
                                                Style="{StaticResource AppSecondaryButton}" />
                                    </StackPanel>
                                </Grid>
                            </Grid>
                        </Border>
                    </DataTemplate>
                </ItemsControl.ItemTemplate>
            </ItemsControl>
        </ScrollViewer>
    </Grid>
</UserControl>
