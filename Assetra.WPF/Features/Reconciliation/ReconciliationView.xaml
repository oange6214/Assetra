<UserControl
    x:Class="Assetra.WPF.Features.Reconciliation.ReconciliationView"
    xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
    xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
    xmlns:d="http://schemas.microsoft.com/expression/blend/2008"
    xmlns:mc="http://schemas.openxmlformats.org/markup-compatibility/2006"
    xmlns:ui="http://schemas.lepo.co/wpfui/2022/xaml"
    xmlns:vm="clr-namespace:Assetra.WPF.Features.Reconciliation"
    d:DataContext="{d:DesignInstance Type={x:Type vm:ReconciliationViewModel},
                                     IsDesignTimeCreatable=False}"
    d:DesignHeight="600"
    d:DesignWidth="1000"
    Background="{DynamicResource AppBackground}"
    mc:Ignorable="d">

    <UserControl.Resources>
        <Style BasedOn="{StaticResource FormComboBox}" TargetType="ComboBox" />
    </UserControl.Resources>

    <Grid Margin="16">
        <Grid.RowDefinitions>
            <RowDefinition Height="Auto" />
            <RowDefinition Height="Auto" />
            <RowDefinition Height="Auto" />
            <RowDefinition Height="*" />
            <RowDefinition Height="Auto" />
        </Grid.RowDefinitions>

        <!--  Header  -->
        <StackPanel Grid.Row="0" Margin="0,0,0,12">
            <TextBlock
                Margin="0,4,0,0"
                Foreground="{DynamicResource AppTextSecondary}"
                Text="{DynamicResource Reconciliation.Subtitle}" />
        </StackPanel>

        <!--  Toolbar  -->
        <ui:Card
            Grid.Row="1"
            Margin="0,0,0,12"
            Padding="12">
            <Grid>
                <Grid.ColumnDefinitions>
                    <ColumnDefinition Width="Auto" />
                    <ColumnDefinition Width="*" />
                    <ColumnDefinition Width="Auto" />
                </Grid.ColumnDefinitions>

                <StackPanel
                    Grid.Column="0"
                    Orientation="Horizontal"
                    VerticalAlignment="Center">
                    <TextBlock
                        Margin="0,0,8,0"
                        VerticalAlignment="Center"
                        Foreground="{DynamicResource AppTextSecondary}"
                        Text="{DynamicResource Reconciliation.Session}" />
                    <ComboBox
                        MinWidth="280"
                        DisplayMemberPath="PeriodStart"
                        ItemsSource="{Binding Sessions}"
                        SelectedItem="{Binding SelectedSession, Mode=TwoWay}" />
                </StackPanel>

                <TextBlock
                    Grid.Column="1"
                    Margin="16,0,0,0"
                    VerticalAlignment="Center"
                    FontFamily="{StaticResource FontBase}" Typography.NumeralAlignment="Tabular"
                    Foreground="{DynamicResource AppTextSecondary}"
                    Text="{Binding SummaryDisplay}" />

                <StackPanel
                    Grid.Column="2"
                    Orientation="Horizontal"
                    VerticalAlignment="Center">
                    <ui:Button
                        Margin="0,0,8,0"
                        Command="{Binding ToggleNewSessionPanelCommand}"
                        Content="{DynamicResource Reconciliation.NewSession}" />
                    <ui:Button
                        Margin="0,0,8,0"
                        Command="{Binding RecomputeCommand}"
                        Content="{DynamicResource Reconciliation.Recompute}" />
                    <ui:Button
                        Appearance="Primary"
                        Command="{Binding SignOffCommand}"
                        Content="{DynamicResource Reconciliation.SignOff}" />
                </StackPanel>
            </Grid>
        </ui:Card>

        <!--  New Session Panel (collapsible)  -->
        <ui:Card
            Grid.Row="2"
            Margin="0,0,0,12"
            Padding="12"
            Visibility="{Binding IsNewSessionPanelOpen, Converter={StaticResource BooleanToVisibilityConverter}}">
            <Grid>
                <Grid.ColumnDefinitions>
                    <ColumnDefinition Width="Auto" />
                    <ColumnDefinition Width="*" />
                    <ColumnDefinition Width="Auto" />
                </Grid.ColumnDefinitions>
                <Grid.RowDefinitions>
                    <RowDefinition Height="Auto" />
                    <RowDefinition Height="Auto" />
                    <RowDefinition Height="Auto" />
                    <RowDefinition Height="Auto" />
                    <RowDefinition Height="Auto" />
                </Grid.RowDefinitions>

                <TextBlock
                    Grid.Row="0" Grid.Column="0"
                    Margin="0,0,12,8"
                    VerticalAlignment="Center"
                    Foreground="{DynamicResource AppTextSecondary}"
                    Text="{DynamicResource Reconciliation.NewSession.Account}" />
                <ComboBox
                    Grid.Row="0" Grid.Column="1"
                    Margin="0,0,0,8"
                    DisplayMemberPath="Name"
                    ItemsSource="{Binding AccountOptions}"
                    SelectedItem="{Binding NewSessionAccount, Mode=TwoWay}" />

                <TextBlock
                    Grid.Row="1" Grid.Column="0"
                    Margin="0,0,12,8"
                    VerticalAlignment="Center"
                    Foreground="{DynamicResource AppTextSecondary}"
                    Text="{DynamicResource Reconciliation.NewSession.Period}" />
                <StackPanel Grid.Row="1" Grid.Column="1" Orientation="Horizontal" Margin="0,0,0,8">
                    <ui:CalendarDatePicker Date="{Binding NewPeriodStart, Mode=TwoWay}" />
                    <TextBlock Margin="8,0,8,0" VerticalAlignment="Center" Text="–" />
                    <ui:CalendarDatePicker Date="{Binding NewPeriodEnd, Mode=TwoWay}" />
                </StackPanel>

                <TextBlock
                    Grid.Row="2" Grid.Column="0"
                    Margin="0,0,12,8"
                    VerticalAlignment="Center"
                    Foreground="{DynamicResource AppTextSecondary}"
                    Text="{DynamicResource Reconciliation.NewSession.Source}" />
                <StackPanel Grid.Row="2" Grid.Column="1" Margin="0,0,0,8">
                    <StackPanel Orientation="Horizontal" Margin="0,0,0,4">
                        <RadioButton
                            GroupName="ReconSource"
                            Margin="0,0,16,0"
                            IsChecked="{Binding UseExistingBatch, Mode=TwoWay}"
                            Content="{DynamicResource Reconciliation.NewSession.Source.ExistingBatch}" />
                        <ComboBox
                            MinWidth="320"
                            DisplayMemberPath="Display"
                            ItemsSource="{Binding BatchOptions}"
                            SelectedItem="{Binding SelectedBatch, Mode=TwoWay}"
                            IsEnabled="{Binding UseExistingBatch}" />
                    </StackPanel>
                    <StackPanel Orientation="Horizontal">
                        <RadioButton
                            GroupName="ReconSource"
                            Margin="0,0,16,0"
                            IsChecked="{Binding UseUploadedFile, Mode=TwoWay}"
                            Content="{DynamicResource Reconciliation.NewSession.Source.Upload}" />
                        <ui:Button
                            Margin="0,0,8,0"
                            Command="{Binding BrowseFileCommand}"
                            Content="{DynamicResource Reconciliation.NewSession.Browse}" />
                        <TextBlock
                            VerticalAlignment="Center"
                            Foreground="{DynamicResource AppTextSecondary}"
                            Text="{Binding UploadedFilePath}" />
                    </StackPanel>
                </StackPanel>

                <TextBlock
                    Grid.Row="3" Grid.Column="0"
                    Margin="0,0,12,8"
                    VerticalAlignment="Center"
                    Foreground="{DynamicResource AppTextSecondary}"
                    Text="{DynamicResource Reconciliation.NewSession.EndingBalance}" />
                <ui:TextBox
                    Grid.Row="3" Grid.Column="1"
                    Margin="0,0,0,8"
                    HorizontalAlignment="Left"
                    MinWidth="160"
                    Text="{Binding StatementEndingBalance, Mode=TwoWay, UpdateSourceTrigger=PropertyChanged, TargetNullValue=''}" />

                <StackPanel
                    Grid.Row="4" Grid.Column="2"
                    Orientation="Horizontal"
                    HorizontalAlignment="Right"
                    VerticalAlignment="Bottom">
                    <ui:Button
                        Margin="0,0,8,0"
                        Command="{Binding ToggleNewSessionPanelCommand}"
                        Content="{DynamicResource Reconciliation.NewSession.Cancel}" />
                    <ui:Button
                        Appearance="Primary"
                        Command="{Binding CreateSessionCommand}"
                        Content="{DynamicResource Reconciliation.NewSession.Create}" />
                </StackPanel>
            </Grid>
        </ui:Card>

        <!--  Body: DataGrid + Balance panel  -->
        <Grid Grid.Row="3">
            <Grid.ColumnDefinitions>
                <ColumnDefinition Width="*" />
                <ColumnDefinition Width="Auto" />
            </Grid.ColumnDefinitions>

            <Border
                Grid.Column="0"
                Background="{DynamicResource AppSurface}"
                BorderBrush="{DynamicResource AppBorder}"
                BorderThickness="1"
                CornerRadius="{StaticResource Card.Radius}">
                <ui:DataGrid
                    AutoGenerateColumns="False"
                    Background="Transparent"
                    BorderThickness="0"
                    CanUserAddRows="False"
                    CanUserDeleteRows="False"
                    CanUserReorderColumns="False"
                    GridLinesVisibility="Horizontal"
                    HeadersVisibility="Column"
                    IsReadOnly="True"
                    ItemsSource="{Binding GroupedDiffs}"
                    SelectionMode="Single">
                    <ui:DataGrid.GroupStyle>
                        <GroupStyle>
                            <GroupStyle.HeaderTemplate>
                                <DataTemplate>
                                    <TextBlock
                                        Margin="8,8,0,4"
                                        FontWeight="SemiBold"
                                        Foreground="{DynamicResource AppTextPrimary}"
                                        Text="{Binding Name}" />
                                </DataTemplate>
                            </GroupStyle.HeaderTemplate>
                        </GroupStyle>
                    </ui:DataGrid.GroupStyle>
                    <ui:DataGrid.Columns>
                        <DataGridTextColumn
                            Width="120"
                            Binding="{Binding KindDisplay}">
                            <DataGridTextColumn.Header>
                                <TextBlock Text="{DynamicResource Reconciliation.Col.Kind}" />
                            </DataGridTextColumn.Header>
                        </DataGridTextColumn>
                        <DataGridTextColumn
                            Width="100"
                            Binding="{Binding DateDisplay}">
                            <DataGridTextColumn.Header>
                                <TextBlock Text="{DynamicResource Reconciliation.Col.Date}" />
                            </DataGridTextColumn.Header>
                        </DataGridTextColumn>
                        <DataGridTextColumn
                            Width="90"
                            Binding="{Binding TradeIdDisplay}">
                            <DataGridTextColumn.Header>
                                <TextBlock Text="{DynamicResource Reconciliation.Col.Trade}" />
                            </DataGridTextColumn.Header>
                        </DataGridTextColumn>
                        <DataGridTextColumn
                            Width="120"
                            Binding="{Binding AmountDisplay}">
                            <DataGridTextColumn.Header>
                                <TextBlock Text="{DynamicResource Reconciliation.Col.Amount}" />
                            </DataGridTextColumn.Header>
                        </DataGridTextColumn>
                        <DataGridTextColumn
                            Width="*"
                            Binding="{Binding CounterpartyDisplay}">
                            <DataGridTextColumn.Header>
                                <TextBlock Text="{DynamicResource Reconciliation.Col.Counterparty}" />
                            </DataGridTextColumn.Header>
                        </DataGridTextColumn>
                        <DataGridTextColumn
                            Width="120"
                            Binding="{Binding ResolutionDisplay}">
                            <DataGridTextColumn.Header>
                                <TextBlock Text="{DynamicResource Reconciliation.Col.Resolution}" />
                            </DataGridTextColumn.Header>
                        </DataGridTextColumn>
                        <DataGridTemplateColumn Width="360">
                            <DataGridTemplateColumn.Header>
                                <TextBlock Text="{DynamicResource Reconciliation.Col.Actions}" />
                            </DataGridTemplateColumn.Header>
                            <DataGridTemplateColumn.CellTemplate>
                                <DataTemplate DataType="{x:Type vm:ReconciliationDiffRowViewModel}">
                                    <StackPanel
                                        Orientation="Horizontal"
                                        IsEnabled="{Binding IsPending}">
                                        <ui:Button
                                            Margin="0,0,4,0"
                                            Padding="8,2,8,2"
                                            Command="{Binding DataContext.CreateTradeCommand, RelativeSource={RelativeSource AncestorType=UserControl}}"
                                            CommandParameter="{Binding}"
                                            Content="{DynamicResource Reconciliation.Action.CreateTrade}"
                                            Visibility="{Binding IsMissing, Converter={StaticResource BooleanToVisibilityConverter}}" />
                                        <ui:Button
                                            Margin="0,0,4,0"
                                            Padding="8,2,8,2"
                                            Command="{Binding DataContext.OverwriteFromStatementCommand, RelativeSource={RelativeSource AncestorType=UserControl}}"
                                            CommandParameter="{Binding}"
                                            Content="{DynamicResource Reconciliation.Action.Overwrite}"
                                            Visibility="{Binding IsAmountMismatch, Converter={StaticResource BooleanToVisibilityConverter}}" />
                                        <ui:Button
                                            Margin="0,0,4,0"
                                            Padding="8,2,8,2"
                                            Command="{Binding DataContext.DeleteTradeCommand, RelativeSource={RelativeSource AncestorType=UserControl}}"
                                            CommandParameter="{Binding}"
                                            Content="{DynamicResource Reconciliation.Action.DeleteTrade}"
                                            Visibility="{Binding IsExtra, Converter={StaticResource BooleanToVisibilityConverter}}" />
                                        <ui:Button
                                            Margin="0,0,4,0"
                                            Padding="8,2,8,2"
                                            Command="{Binding DataContext.MarkResolvedCommand, RelativeSource={RelativeSource AncestorType=UserControl}}"
                                            CommandParameter="{Binding}"
                                            Content="{DynamicResource Reconciliation.Action.MarkResolved}" />
                                        <ui:Button
                                            Padding="8,2,8,2"
                                            Command="{Binding DataContext.IgnoreCommand, RelativeSource={RelativeSource AncestorType=UserControl}}"
                                            CommandParameter="{Binding}"
                                            Content="{DynamicResource Reconciliation.Action.Ignore}" />
                                    </StackPanel>
                                </DataTemplate>
                            </DataGridTemplateColumn.CellTemplate>
                        </DataGridTemplateColumn>
                    </ui:DataGrid.Columns>
                </ui:DataGrid>
            </Border>

            <ui:Card
                Grid.Column="1"
                Width="260"
                Margin="12,0,0,0"
                Padding="12">
                <StackPanel>
                    <TextBlock
                        Margin="0,0,0,8"
                        FontWeight="SemiBold"
                        Foreground="{DynamicResource AppTextPrimary}"
                        Text="{DynamicResource Reconciliation.Balance.Title}" />
                    <TextBlock
                        FontFamily="{StaticResource FontBase}" Typography.NumeralAlignment="Tabular"
                        Foreground="{DynamicResource AppTextSecondary}"
                        TextWrapping="Wrap"
                        Text="{Binding BalancePanelDisplay}" />
                </StackPanel>
            </ui:Card>
        </Grid>

        <!--  Status footer  -->
        <TextBlock
            Grid.Row="4"
            Margin="0,8,0,0"
            Foreground="{DynamicResource AppTextSecondary}"
            Text="{Binding StatusMessage}" />
    </Grid>
</UserControl>
