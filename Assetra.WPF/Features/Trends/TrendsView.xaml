<UserControl
    x:Class="Assetra.WPF.Features.Trends.TrendsView"
    xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
    xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
    xmlns:controls="clr-namespace:Assetra.WPF.Controls"
    xmlns:d="http://schemas.microsoft.com/expression/blend/2008"
    xmlns:lvc="clr-namespace:LiveChartsCore.SkiaSharpView.WPF;assembly=LiveChartsCore.SkiaSharpView.WPF"
    xmlns:mc="http://schemas.openxmlformats.org/markup-compatibility/2006"
    xmlns:portfolio="clr-namespace:Assetra.WPF.Features.Portfolio"
    xmlns:ds="clr-namespace:Assetra.WPF.DesignSystem.Controls"
    d:DataContext="{d:DesignInstance Type={x:Type portfolio:PortfolioHistoryViewModel},
                                     IsDesignTimeCreatable=False}"
    d:DesignHeight="776"
    d:DesignWidth="1100"
    Background="{DynamicResource AppBackground}"
    Loaded="TrendsView_Loaded"
    mc:Ignorable="d">

    <!--
        本頁為「績效比較」(vs 大盤)：只保留 期間 chip / 比較圖 / 對標清單 / footer。
        原本的 報酬率 hero + 風險指標 KPI 卡已移除（屬個人績效，將另做新「資產趨勢」頁承接）。
    -->
    <Grid Style="{StaticResource PageRootGrid}">
        <Grid.RowDefinitions>
            <RowDefinition Height="Auto" />
            <!--  period chip bar  -->
            <RowDefinition Height="*" />
            <!--  比較模組（圖表＋對標清單合併成一張卡）— 拿剩餘高度  -->
            <RowDefinition Height="Auto" />
            <!--  footer hint  -->
        </Grid.RowDefinitions>

        <!--  ── Period selector + custom range picker ──  -->
        <DockPanel Grid.Row="0" Style="{StaticResource PageHeaderDock}">
            <controls:DateRangePicker
                MinWidth="260"
                DockPanel.Dock="Right"
                EndDate="{Binding CustomEndDate, Mode=TwoWay}"
                Placeholder="{DynamicResource Trends.CustomRange}"
                StartDate="{Binding CustomStartDate, Mode=TwoWay}" />

            <!--
                Period filter — RadioButton group sharing NavTabBtn (the
                same underline-indicator style used by the Allocation
                inner tabs and the new TabItem template). Replaces the
                previous five verbose Style/DataTrigger Primary/Secondary
                button blocks (~90 lines) with a single visual treatment
                aligned with the rest of the app.
            -->
            <!--  P5.9 — 7 chips: 5 天 / 1 個月 / 6 個月 / 本年迄今 / 1 年 / 5 年 / 全部  -->
            <StackPanel Orientation="Horizontal">
                <RadioButton
                    Command="{Binding ChangePeriodCommand}"
                    CommandParameter="1"
                    Content="{DynamicResource Trends.Period.1}"
                    GroupName="TrendsPeriod"
                    IsChecked="{Binding ActivePeriod, Mode=OneWay, Converter={StaticResource EqualityConverter}, ConverterParameter=1}"
                    Style="{StaticResource NavTabBtn}" />
                <RadioButton
                    Command="{Binding ChangePeriodCommand}"
                    CommandParameter="5"
                    Content="{DynamicResource Trends.Period.5}"
                    GroupName="TrendsPeriod"
                    IsChecked="{Binding ActivePeriod, Mode=OneWay, Converter={StaticResource EqualityConverter}, ConverterParameter=5}"
                    Style="{StaticResource NavTabBtn}" />
                <RadioButton
                    Command="{Binding ChangePeriodCommand}"
                    CommandParameter="30"
                    Content="{DynamicResource Trends.Period.30}"
                    GroupName="TrendsPeriod"
                    IsChecked="{Binding ActivePeriod, Mode=OneWay, Converter={StaticResource EqualityConverter}, ConverterParameter=30}"
                    Style="{StaticResource NavTabBtn}" />
                <RadioButton
                    Command="{Binding ChangePeriodCommand}"
                    CommandParameter="180"
                    Content="{DynamicResource Trends.Period.180}"
                    GroupName="TrendsPeriod"
                    IsChecked="{Binding ActivePeriod, Mode=OneWay, Converter={StaticResource EqualityConverter}, ConverterParameter=180}"
                    Style="{StaticResource NavTabBtn}" />
                <RadioButton
                    Command="{Binding ChangePeriodCommand}"
                    CommandParameter="YTD"
                    Content="{DynamicResource Trends.Period.YTD}"
                    GroupName="TrendsPeriod"
                    IsChecked="{Binding ActivePeriod, Mode=OneWay, Converter={StaticResource EqualityConverter}, ConverterParameter=YTD}"
                    Style="{StaticResource NavTabBtn}" />
                <RadioButton
                    Command="{Binding ChangePeriodCommand}"
                    CommandParameter="365"
                    Content="{DynamicResource Trends.Period.365}"
                    GroupName="TrendsPeriod"
                    IsChecked="{Binding ActivePeriod, Mode=OneWay, Converter={StaticResource EqualityConverter}, ConverterParameter=365}"
                    Style="{StaticResource NavTabBtn}" />
                <RadioButton
                    Command="{Binding ChangePeriodCommand}"
                    CommandParameter="1825"
                    Content="{DynamicResource Trends.Period.1825}"
                    GroupName="TrendsPeriod"
                    IsChecked="{Binding ActivePeriod, Mode=OneWay, Converter={StaticResource EqualityConverter}, ConverterParameter=1825}"
                    Style="{StaticResource NavTabBtn}" />
                <RadioButton
                    Command="{Binding ChangePeriodCommand}"
                    CommandParameter="All"
                    Content="{DynamicResource Trends.Period.All}"
                    GroupName="TrendsPeriod"
                    IsChecked="{Binding ActivePeriod, Mode=OneWay, Converter={StaticResource EqualityConverter}, ConverterParameter=All}"
                    Style="{StaticResource NavTabBtn}" />
                <!--
                    「可用資料 X 天」hint — 跟在 chip 後面，讓使用者一眼看到實際 snapshot
                    範圍。若 chip 選了 180 / 365 但 hint 顯示「可用資料 22 天」，
                    使用者就知道 chart / KPI / 對標數值跟 30 天 chip 一樣是預期行為。
                    DataRangeHint 為空字串時 TextBlock 不渲染。
                -->
                <TextBlock
                    Margin="12,0,0,0"
                    VerticalAlignment="Center"
                    FontSize="{DynamicResource Font.Size.Xs}"
                    Foreground="{DynamicResource AppTextMuted}"
                    Text="{Binding DataRangeHint}" />
            </StackPanel>
        </DockPanel>

        <!--  ── Chart / empty state — P3.6 migrated to AppCardSummary baseline ──  -->
        <!--  ── 比較模組：圖表 ＋ 對標清單 合併在同一張卡（去掉中間空隙、讀起來是一個完整模組）。──  -->
        <Border Grid.Row="1" Style="{StaticResource AppCardSummary}">
          <Grid>
            <Grid.RowDefinitions>
                <RowDefinition Height="*" />
                <RowDefinition Height="Auto" />
            </Grid.RowDefinitions>
            <Grid Grid.Row="0" Style="{StaticResource PageContentGrid}">
                <lvc:CartesianChart
                    x:Name="CompareChart"
                    Background="Transparent"
                    MouseLeave="CompareChart_MouseLeave"
                    MouseMove="CompareChart_MouseMove"
                    Series="{Binding CompareSeries}"
                    TooltipPosition="Hidden"
                    Visibility="{Binding HasComparableLines, Converter={StaticResource BooleanToVisibilityConverter}}"
                    XAxes="{Binding CompareXAxes}"
                    YAxes="{Binding CompareYAxes}" />

                <!--  所選項目全都畫不出（如買賣不成對的群組）→ 清楚說明，取代空白格線圖  -->
                <StackPanel
                    HorizontalAlignment="Center"
                    VerticalAlignment="Center"
                    Visibility="{Binding ShowComparisonUnavailableState, Converter={StaticResource BooleanToVisibilityConverter}}">
                    <ds:AppIcon
                        HorizontalAlignment="Center"
                        FontSize="28"
                        Foreground="{DynamicResource AppTextMuted}"
                        Symbol="Warning24" />
                    <TextBlock
                        MaxWidth="360"
                        Margin="0,8,0,0"
                        HorizontalAlignment="Center"
                        FontSize="{StaticResource Font.Size.Sm}"
                        Foreground="{DynamicResource AppTextMuted}"
                        Text="{DynamicResource Portfolio.History.CompareAllUnavailable}"
                        TextAlignment="Center"
                        TextWrapping="Wrap" />
                </StackPanel>

                <!--  載入指示：benchmark/盤中抓取期間顯示「更新中…」，讓使用者知道在抓資料（非當機）。  -->
                <Border
                    Padding="16,9"
                    HorizontalAlignment="Center"
                    VerticalAlignment="Center"
                    Background="{DynamicResource AppHover}"
                    BorderBrush="{DynamicResource AppBorderLight}"
                    BorderThickness="1"
                    CornerRadius="{StaticResource Radius.Sm}"
                    Visibility="{Binding IsRefreshingComparison, Converter={StaticResource BooleanToVisibilityConverter}}">
                    <TextBlock
                        FontSize="{StaticResource Font.Size.Sm}"
                        Foreground="{DynamicResource AppTextSecondary}"
                        Text="{DynamicResource Portfolio.History.Loading}" />
                </Border>

                <!--  對比 chips（投組／大盤固定、自訂可移除 ✕）＋「＋比較」搜尋 popup；疊在圖左上。  -->
                <StackPanel
                    Margin="6,2,0,0"
                    HorizontalAlignment="Left"
                    VerticalAlignment="Top"
                    Orientation="Horizontal">
                    <ItemsControl ItemsSource="{Binding ComparisonLegend}">
                        <ItemsControl.ItemsPanel>
                            <ItemsPanelTemplate>
                                <WrapPanel Orientation="Horizontal" />
                            </ItemsPanelTemplate>
                        </ItemsControl.ItemsPanel>
                        <ItemsControl.ItemTemplate>
                            <DataTemplate>
                                <Border
                                    Margin="0,0,6,0"
                                    Padding="10,5"
                                    VerticalAlignment="Center"
                                    Background="{DynamicResource AppHover}"
                                    BorderBrush="{DynamicResource AppBorderLight}"
                                    BorderThickness="1"
                                    CornerRadius="13"
                                    ToolTip="{Binding UnavailableReason}">
                                    <!--  IsUnavailable：已加入卻畫不出的項目 → 整顆 chip 淡化，hover 看 UnavailableReason  -->
                                    <Border.Style>
                                        <Style TargetType="Border">
                                            <Style.Triggers>
                                                <DataTrigger Binding="{Binding IsUnavailable}" Value="True">
                                                    <Setter Property="Opacity" Value="0.72" />
                                                </DataTrigger>
                                            </Style.Triggers>
                                        </Style>
                                    </Border.Style>
                                    <StackPanel Orientation="Horizontal" VerticalAlignment="Center">
                                        <!--  正常：彩色圓點；無法顯示：改用 ⚠ 灰色圖示  -->
                                        <Ellipse
                                            Width="8" Height="8"
                                            Margin="0,0,5,0"
                                            VerticalAlignment="Center"
                                            Visibility="{Binding IsUnavailable, Converter={StaticResource InverseBooleanToVisibilityConverter}}">
                                            <Ellipse.Fill>
                                                <SolidColorBrush Color="{Binding ColorHex}" />
                                            </Ellipse.Fill>
                                        </Ellipse>
                                        <ds:AppIcon
                                            Margin="0,0,4,0"
                                            VerticalAlignment="Center"
                                            FontSize="11"
                                            Foreground="{DynamicResource AppTextMuted}"
                                            Symbol="Warning24"
                                            Visibility="{Binding IsUnavailable, Converter={StaticResource BooleanToVisibilityConverter}}" />
                                        <TextBlock
                                            VerticalAlignment="Center"
                                            FontSize="{StaticResource Font.Size.Xs}"
                                            FontWeight="Medium"
                                            Foreground="{DynamicResource AppTextPrimary}"
                                            Text="{Binding Label}" />
                                        <Button
                                            Width="14" Height="14"
                                            Margin="5,0,0,0" Padding="0"
                                            VerticalAlignment="Center"
                                            Background="Transparent"
                                            BorderThickness="0"
                                            Command="{Binding DataContext.RemoveComparisonCommand, RelativeSource={RelativeSource AncestorType=ItemsControl}}"
                                            CommandParameter="{Binding RemoveSymbol}"
                                            Cursor="Hand"
                                            ToolTip="{DynamicResource Portfolio.History.RemoveComparison}"
                                            Visibility="{Binding RemoveSymbol, Converter={StaticResource NullToVisibilityConverter}}">
                                            <ds:AppIcon FontSize="9" Foreground="{DynamicResource AppTextMuted}" Symbol="Dismiss24" />
                                        </Button>
                                    </StackPanel>
                                </Border>
                            </DataTemplate>
                        </ItemsControl.ItemTemplate>
                    </ItemsControl>

                    <!--  空清單提示（預設無比較項目時）  -->
                    <TextBlock
                        Margin="8,0,0,0"
                        VerticalAlignment="Center"
                        FontSize="{StaticResource Font.Size.Xs}"
                        Foreground="{DynamicResource AppTextMuted}"
                        Text="{DynamicResource Portfolio.History.ComparePrompt}"
                        Visibility="{Binding HasComparisonItems, Converter={StaticResource InverseBooleanToVisibilityConverter}}" />
                </StackPanel>

                <!--  hover 讀數（Google 式）：滑到曲線時於上方顯示「日期時間 ＋ 每項 現值＋同期%」；固定置中、不擋圖。
                      只在 hover（ComparisonHoverDate 非 null）時顯示；資料由 ComparisonRows / ComparisonAsOfText 隨游標更新。  -->
                <Border
                    Margin="0,8,0,0"
                    Padding="10,5"
                    HorizontalAlignment="Center"
                    VerticalAlignment="Top"
                    Background="{DynamicResource AppHover}"
                    BorderBrush="{DynamicResource AppBorderLight}"
                    BorderThickness="1"
                    CornerRadius="{StaticResource Radius.Sm}"
                    IsHitTestVisible="False"
                    Visibility="{Binding ComparisonHoverDate, Converter={StaticResource NullToVisibilityConverter}}">
                    <StackPanel Orientation="Horizontal" VerticalAlignment="Center">
                        <TextBlock
                            Margin="0,0,10,0"
                            VerticalAlignment="Center"
                            FontSize="{StaticResource Font.Size.Xs}"
                            FontWeight="SemiBold"
                            Foreground="{DynamicResource AppTextSecondary}"
                            Text="{Binding ComparisonAsOfText}" />
                        <ItemsControl ItemsSource="{Binding ComparisonRows}">
                            <ItemsControl.ItemsPanel>
                                <ItemsPanelTemplate>
                                    <WrapPanel Orientation="Horizontal" />
                                </ItemsPanelTemplate>
                            </ItemsControl.ItemsPanel>
                            <ItemsControl.ItemTemplate>
                                <DataTemplate>
                                    <StackPanel Margin="0,0,10,0" Orientation="Horizontal" VerticalAlignment="Center">
                                        <Ellipse Width="8" Height="8" Margin="0,0,5,0" VerticalAlignment="Center">
                                            <Ellipse.Fill>
                                                <SolidColorBrush Color="{Binding ColorHex}" />
                                            </Ellipse.Fill>
                                        </Ellipse>
                                        <TextBlock
                                            VerticalAlignment="Center"
                                            FontSize="{StaticResource Font.Size.Xs}"
                                            Foreground="{DynamicResource AppTextSecondary}"
                                            Text="{Binding Label}" />
                                        <TextBlock
                                            Margin="6,0,0,0"
                                            VerticalAlignment="Center"
                                            FontSize="{StaticResource Font.Size.Xs}"
                                            Foreground="{DynamicResource AppTextSecondary}"
                                            Text="{Binding Value, StringFormat='{}{0:#,##0.##}'}" />
                                        <TextBlock
                                            Margin="5,0,0,0"
                                            VerticalAlignment="Center"
                                            FontSize="{StaticResource Font.Size.Xs}"
                                            Foreground="{Binding PercentBrush}"
                                            Text="{Binding Percent, StringFormat='+0.00%;-0.00%;0.00%'}" />
                                    </StackPanel>
                                </DataTemplate>
                            </ItemsControl.ItemTemplate>
                        </ItemsControl>
                    </StackPanel>
                </Border>

                <!--  「＋比較」鈕 ＋ 搜尋 popup；疊在圖右上（與 chips 分開、仿 Google 工具列把「比較」獨立）。  -->
                <StackPanel
                    Margin="0,2,6,0"
                    HorizontalAlignment="Right"
                    VerticalAlignment="Top">
                    <Button
                        x:Name="CompareBtn"
                        Margin="2,0,0,0"
                        Padding="10,2"
                        VerticalAlignment="Center"
                        Command="{Binding OpenComparisonPickerCommand}"
                        Content="{DynamicResource Portfolio.History.Compare}"
                        Cursor="Hand"
                        FontSize="{StaticResource Font.Size.Xs}"
                        Style="{StaticResource AppSecondaryButton}" />

                    <Popup
                        AllowsTransparency="True"
                        IsOpen="{Binding IsComparisonPickerOpen, Mode=TwoWay}"
                        Placement="Bottom"
                        PlacementTarget="{Binding ElementName=CompareBtn}"
                        StaysOpen="False">
                        <Border
                            Width="262"
                            Margin="0,4,0,0"
                            Padding="8"
                            Background="{DynamicResource AppBackground}"
                            BorderBrush="{DynamicResource AppBorderLight}"
                            BorderThickness="1"
                            CornerRadius="8">
                            <Border.Effect>
                                <DropShadowEffect BlurRadius="14" Direction="270" Opacity="0.18" ShadowDepth="3" />
                            </Border.Effect>
                            <StackPanel>
                                <!--  快速加入：我的投組 / 大盤（已加入時自動 disabled）  -->
                                <StackPanel Margin="0,0,0,8" Orientation="Horizontal">
                                    <Button
                                        Margin="0,0,6,0"
                                        Padding="10,3"
                                        Command="{Binding AddMyPortfolioCommand}"
                                        Content="{DynamicResource Portfolio.History.MeLabel}"
                                        FontSize="{StaticResource Font.Size.Xs}"
                                        Style="{StaticResource AppSecondaryButton}" />
                                    <Button
                                        Padding="10,3"
                                        Command="{Binding AddMarketCommand}"
                                        Content="{DynamicResource Portfolio.History.BenchmarkTaiex}"
                                        FontSize="{StaticResource Font.Size.Xs}"
                                        Style="{StaticResource AppSecondaryButton}" />
                                </StackPanel>
                                <!--  群組（投資組合 bucket）快速加入 — 比較「我的指定組合」  -->
                                <ItemsControl ItemsSource="{Binding ComparisonGroupOptions}">
                                    <ItemsControl.ItemsPanel>
                                        <ItemsPanelTemplate>
                                            <WrapPanel Orientation="Horizontal" />
                                        </ItemsPanelTemplate>
                                    </ItemsControl.ItemsPanel>
                                    <ItemsControl.ItemTemplate>
                                        <DataTemplate>
                                            <Button
                                                Margin="0,0,6,6"
                                                Padding="10,3"
                                                Command="{Binding DataContext.AddGroupCommand, RelativeSource={RelativeSource AncestorType=ItemsControl}}"
                                                CommandParameter="{Binding}"
                                                Content="{Binding Name}"
                                                FontSize="{StaticResource Font.Size.Xs}"
                                                Style="{StaticResource AppSecondaryButton}" />
                                        </DataTemplate>
                                    </ItemsControl.ItemTemplate>
                                </ItemsControl>
                                <DockPanel>
                                    <Button
                                        DockPanel.Dock="Right"
                                        Margin="6,0,0,0"
                                        MinHeight="28"
                                        Padding="10,0"
                                        Command="{Binding AddComparisonCommand}"
                                        Content="＋"
                                        Style="{StaticResource AppSecondaryButton}"
                                        ToolTip="{DynamicResource Portfolio.History.AddComparison.Hint}" />
                                    <TextBox
                                        VerticalContentAlignment="Center"
                                        Tag="{DynamicResource Portfolio.History.AddComparison.Hint}"
                                        Text="{Binding ComparisonInput, UpdateSourceTrigger=PropertyChanged}" />
                                </DockPanel>
                                <ItemsControl Margin="0,6,0,0" ItemsSource="{Binding ComparisonSuggestions}">
                                    <ItemsControl.ItemTemplate>
                                        <DataTemplate>
                                            <Button
                                                Padding="6,4"
                                                HorizontalContentAlignment="Stretch"
                                                Background="Transparent"
                                                BorderThickness="0"
                                                Command="{Binding DataContext.SelectComparisonSuggestionCommand, RelativeSource={RelativeSource AncestorType=ItemsControl}}"
                                                CommandParameter="{Binding}"
                                                Cursor="Hand">
                                                <Grid>
                                                    <Grid.ColumnDefinitions>
                                                        <ColumnDefinition Width="*" />
                                                        <ColumnDefinition Width="Auto" />
                                                    </Grid.ColumnDefinitions>
                                                    <StackPanel Grid.Column="0">
                                                        <TextBlock
                                                            FontWeight="SemiBold"
                                                            Foreground="{DynamicResource AppTextPrimary}"
                                                            Text="{Binding Symbol}" />
                                                        <TextBlock
                                                            FontSize="{StaticResource Font.Size.Xs}"
                                                            Foreground="{DynamicResource AppTextMuted}"
                                                            Text="{Binding Name}" />
                                                    </StackPanel>
                                                    <TextBlock
                                                        Grid.Column="1"
                                                        VerticalAlignment="Center"
                                                        FontSize="{StaticResource Font.Size.Xs}"
                                                        Foreground="{DynamicResource AppTextMuted}"
                                                        Text="{Binding Exchange}" />
                                                </Grid>
                                            </Button>
                                        </DataTemplate>
                                    </ItemsControl.ItemTemplate>
                                </ItemsControl>
                            </StackPanel>
                        </Border>
                    </Popup>
                </StackPanel>

                <StackPanel
                    Style="{StaticResource EmptyStatePanel}"
                    Visibility="{Binding HasHistory, Converter={StaticResource InverseBooleanToVisibilityConverter}}">
                    <ds:AppIcon Style="{StaticResource EmptyStateIcon}" Symbol="DataTrending24" />
                    <TextBlock Style="{StaticResource EmptyStateHint}" Text="{DynamicResource Trends.Empty}" />
                </StackPanel>
            </Grid>
            <!--  ── 對標清單：與圖表合併在同一張卡，上方加分隔線分隔。──  -->
            <StackPanel
                Grid.Row="1"
                Margin="0,16,0,0"
                Visibility="{Binding HasComparisonItems, Converter={StaticResource BooleanToVisibilityConverter}}">
                <Border Height="1" Margin="0,0,0,12" Background="{DynamicResource AppBorderLight}" />
                <DockPanel Margin="0,0,0,6" LastChildFill="False">
                    <TextBlock
                        DockPanel.Dock="Left"
                        FontSize="{StaticResource Font.Size.Xs}"
                        FontWeight="SemiBold"
                        Foreground="{DynamicResource AppTextSecondary}"
                        Text="{DynamicResource Portfolio.History.CompareTableHeading}" />
                    <TextBlock
                        DockPanel.Dock="Right"
                        FontSize="{StaticResource Font.Size.Xs}"
                        Foreground="{DynamicResource AppTextMuted}"
                        Text="{Binding ComparisonAsOfText}" />
                </DockPanel>
                <!--  欄標題（仿 Google：項目 / 現值 / 漲跌 / 同期 % / 期初）  -->
                <Grid Margin="0,0,0,4">
                    <Grid.ColumnDefinitions>
                        <ColumnDefinition Width="*" />
                        <ColumnDefinition Width="100" />
                        <ColumnDefinition Width="96" />
                        <ColumnDefinition Width="80" />
                        <ColumnDefinition Width="100" />
                    </Grid.ColumnDefinitions>
                    <TextBlock Grid.Column="0" FontSize="{StaticResource Font.Size.Xs}" Foreground="{DynamicResource AppTextMuted}" Text="{DynamicResource Portfolio.History.Col.Item}" />
                    <TextBlock Grid.Column="1" HorizontalAlignment="Right" FontSize="{StaticResource Font.Size.Xs}" Foreground="{DynamicResource AppTextMuted}" Text="{DynamicResource Portfolio.History.Col.Value}" />
                    <TextBlock Grid.Column="2" HorizontalAlignment="Right" FontSize="{StaticResource Font.Size.Xs}" Foreground="{DynamicResource AppTextMuted}" Text="{DynamicResource Portfolio.History.Col.Change}" />
                    <TextBlock Grid.Column="3" HorizontalAlignment="Right" FontSize="{StaticResource Font.Size.Xs}" Foreground="{DynamicResource AppTextMuted}" Text="{DynamicResource Portfolio.History.Col.Pct}" />
                    <TextBlock Grid.Column="4" HorizontalAlignment="Right" FontSize="{StaticResource Font.Size.Xs}" Foreground="{DynamicResource AppTextMuted}" Text="{DynamicResource Portfolio.History.Col.Start}" />
                </Grid>
                <ItemsControl ItemsSource="{Binding ComparisonRows}">
                    <ItemsControl.ItemTemplate>
                        <DataTemplate>
                            <Border Padding="0,7" BorderBrush="{DynamicResource AppBorderLight}" BorderThickness="0,0,0,1">
                            <Grid>
                                <Grid.ColumnDefinitions>
                                    <ColumnDefinition Width="*" />
                                    <ColumnDefinition Width="100" />
                                    <ColumnDefinition Width="96" />
                                    <ColumnDefinition Width="80" />
                                    <ColumnDefinition Width="100" />
                                </Grid.ColumnDefinitions>
                                <!--  項目：色點 ＋ 名稱  -->
                                <StackPanel Grid.Column="0" Orientation="Horizontal" VerticalAlignment="Center">
                                    <Ellipse Width="9" Height="9" Margin="0,0,8,0" VerticalAlignment="Center">
                                        <Ellipse.Fill>
                                            <SolidColorBrush Color="{Binding ColorHex}" />
                                        </Ellipse.Fill>
                                    </Ellipse>
                                    <TextBlock
                                        VerticalAlignment="Center"
                                        FontSize="{StaticResource Font.Size.Sm}"
                                        FontWeight="SemiBold"
                                        Foreground="{DynamicResource AppTextPrimary}"
                                        Text="{Binding Label}" />
                                </StackPanel>
                                <!--  現值（股票現價 / 我的投組現淨值 / 組合現市值）  -->
                                <TextBlock
                                    Grid.Column="1"
                                    HorizontalAlignment="Right"
                                    VerticalAlignment="Center"
                                    FontFamily="{StaticResource Font.Family.Numeric}"
                                    FontSize="{StaticResource Font.Size.Sm}"
                                    Foreground="{DynamicResource AppTextPrimary}"
                                    Text="{Binding Value, StringFormat='{}{0:#,##0.##}'}"
                                    Typography.NumeralAlignment="Tabular" />
                                <!--  漲跌（現值 − 期初；漲紅跌綠）  -->
                                <TextBlock
                                    Grid.Column="2"
                                    HorizontalAlignment="Right"
                                    VerticalAlignment="Center"
                                    FontFamily="{StaticResource Font.Family.Numeric}"
                                    FontSize="{StaticResource Font.Size.Sm}"
                                    Foreground="{Binding PercentBrush}"
                                    Text="{Binding AbsChange, StringFormat='+#,##0.##;-#,##0.##;0'}"
                                    Typography.NumeralAlignment="Tabular" />
                                <!--  同期 %（＋方向箭頭 ▲▼，漲紅跌綠）  -->
                                <StackPanel
                                    Grid.Column="3"
                                    HorizontalAlignment="Right"
                                    VerticalAlignment="Center"
                                    Orientation="Horizontal">
                                    <TextBlock
                                        Margin="0,0,3,0"
                                        VerticalAlignment="Center"
                                        FontSize="8"
                                        Foreground="{Binding PercentBrush}"
                                        Text="{Binding Arrow}" />
                                    <TextBlock
                                        VerticalAlignment="Center"
                                        FontFamily="{StaticResource Font.Family.Numeric}"
                                        FontSize="{StaticResource Font.Size.Sm}"
                                        FontWeight="SemiBold"
                                        Foreground="{Binding PercentBrush}"
                                        Text="{Binding Percent, StringFormat='+0.00%;-0.00%;0.00%'}"
                                        Typography.NumeralAlignment="Tabular" />
                                </StackPanel>
                                <!--  期初（區間基準值）  -->
                                <TextBlock
                                    Grid.Column="4"
                                    HorizontalAlignment="Right"
                                    VerticalAlignment="Center"
                                    FontFamily="{StaticResource Font.Family.Numeric}"
                                    FontSize="{StaticResource Font.Size.Sm}"
                                    Foreground="{DynamicResource AppTextMuted}"
                                    Text="{Binding StartValue, StringFormat='{}{0:#,##0.##}'}"
                                    Typography.NumeralAlignment="Tabular" />
                            </Grid>
                            </Border>
                        </DataTemplate>
                    </ItemsControl.ItemTemplate>
                </ItemsControl>
            </StackPanel>
          </Grid>
        </Border>

        <!--  ── Footer hint — P5.1 修復可疑點工具列已移除（曲線改算真實淨值後 partial-price 假象問題不存在）  -->
        <TextBlock
            Grid.Row="2"
            Margin="0,12,0,0"
            VerticalAlignment="Center"
            FontSize="{DynamicResource Font.Size.Xs}"
            Foreground="{DynamicResource AppTextSecondary}"
            Text="{DynamicResource Trends.Hint}" />
    </Grid>
</UserControl>
