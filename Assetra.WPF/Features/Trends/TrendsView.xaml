<UserControl
    x:Class="Assetra.WPF.Features.Trends.TrendsView"
    xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
    xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
    xmlns:controls="clr-namespace:Assetra.WPF.Controls"
    xmlns:d="http://schemas.microsoft.com/expression/blend/2008"
    xmlns:lvc="clr-namespace:LiveChartsCore.SkiaSharpView.WPF;assembly=LiveChartsCore.SkiaSharpView.WPF"
    xmlns:mc="http://schemas.openxmlformats.org/markup-compatibility/2006"
    xmlns:portfolio="clr-namespace:Assetra.WPF.Features.Portfolio"
    xmlns:ui="http://schemas.lepo.co/wpfui/2022/xaml"
    d:DataContext="{d:DesignInstance Type={x:Type portfolio:PortfolioHistoryViewModel},
                                     IsDesignTimeCreatable=False}"
    d:DesignHeight="776"
    d:DesignWidth="1100"
    Background="{DynamicResource AppBackground}"
    mc:Ignorable="d">

    <Grid Margin="24">
        <Grid.RowDefinitions>
            <RowDefinition Height="Auto" />
            <RowDefinition Height="*" />
            <RowDefinition Height="Auto" />
        </Grid.RowDefinitions>

        <!--  ── Period selector + custom range picker ──  -->
        <DockPanel Grid.Row="0" Margin="0,0,0,16">
            <controls:DateRangePicker
                MinWidth="260"
                DockPanel.Dock="Right"
                EndDate="{Binding CustomEndDate, Mode=TwoWay}"
                Placeholder="{DynamicResource Trends.CustomRange}"
                StartDate="{Binding CustomStartDate, Mode=TwoWay}" />

            <!--
                Period filter — RadioButton group sharing NavTabBtn (the
                same underline-indicator style used by the Allocation
                inner tabs and the new TabItem template). Replaces the
                previous five verbose Style/DataTrigger Primary/Secondary
                button blocks (~90 lines) with a single visual treatment
                aligned with the rest of the app.
            -->
            <StackPanel Orientation="Horizontal">
                <RadioButton
                    Command="{Binding ChangePeriodCommand}"
                    CommandParameter="30"
                    Content="{DynamicResource Trends.Period.30}"
                    GroupName="TrendsPeriod"
                    IsChecked="{Binding ActivePeriod, Mode=OneWay, Converter={StaticResource EqualityConverter}, ConverterParameter=30}"
                    Style="{StaticResource NavTabBtn}" />
                <RadioButton
                    Command="{Binding ChangePeriodCommand}"
                    CommandParameter="90"
                    Content="{DynamicResource Trends.Period.90}"
                    GroupName="TrendsPeriod"
                    IsChecked="{Binding ActivePeriod, Mode=OneWay, Converter={StaticResource EqualityConverter}, ConverterParameter=90}"
                    Style="{StaticResource NavTabBtn}" />
                <RadioButton
                    Command="{Binding ChangePeriodCommand}"
                    CommandParameter="180"
                    Content="{DynamicResource Trends.Period.180}"
                    GroupName="TrendsPeriod"
                    IsChecked="{Binding ActivePeriod, Mode=OneWay, Converter={StaticResource EqualityConverter}, ConverterParameter=180}"
                    Style="{StaticResource NavTabBtn}" />
                <RadioButton
                    Command="{Binding ChangePeriodCommand}"
                    CommandParameter="365"
                    Content="{DynamicResource Trends.Period.365}"
                    GroupName="TrendsPeriod"
                    IsChecked="{Binding ActivePeriod, Mode=OneWay, Converter={StaticResource EqualityConverter}, ConverterParameter=365}"
                    Style="{StaticResource NavTabBtn}" />
                <RadioButton
                    Command="{Binding ChangePeriodCommand}"
                    CommandParameter="All"
                    Content="{DynamicResource Trends.Period.All}"
                    GroupName="TrendsPeriod"
                    IsChecked="{Binding ActivePeriod, Mode=OneWay, Converter={StaticResource EqualityConverter}, ConverterParameter=All}"
                    Style="{StaticResource NavTabBtn}" />
            </StackPanel>
        </DockPanel>

        <!--  ── Chart card ──  -->
        <ui:Card Grid.Row="1" Padding="20">
            <Grid>
                <lvc:CartesianChart
                    Background="Transparent"
                    Series="{Binding ValueSeries}"
                    TooltipPosition="Top"
                    TooltipTextSize="12"
                    Visibility="{Binding HasHistory, Converter={StaticResource BooleanToVisibilityConverter}}"
                    XAxes="{Binding XAxes}"
                    YAxes="{Binding YAxes}" />

                <!--  Empty state — no history yet  -->
                <StackPanel
                    HorizontalAlignment="Center"
                    VerticalAlignment="Center"
                    Visibility="{Binding HasHistory, Converter={StaticResource InverseBooleanToVisibilityConverter}}">
                    <ui:SymbolIcon
                        HorizontalAlignment="Center"
                        FontSize="48"
                        Foreground="{DynamicResource AppTextMuted}"
                        Symbol="DataTrending24" />
                    <TextBlock
                        Margin="0,12,0,0"
                        HorizontalAlignment="Center"
                        FontSize="{DynamicResource FontSizeSm}"
                        Foreground="{DynamicResource AppTextSecondary}"
                        Text="{DynamicResource Trends.Empty}" />
                </StackPanel>
            </Grid>
        </ui:Card>

        <!--  ── Footer hint ──  -->
        <TextBlock
            Grid.Row="2"
            Margin="0,12,0,0"
            FontSize="{DynamicResource FontSizeXs}"
            Foreground="{DynamicResource AppTextSecondary}"
            Text="{DynamicResource Trends.Hint}" />
    </Grid>
</UserControl>
