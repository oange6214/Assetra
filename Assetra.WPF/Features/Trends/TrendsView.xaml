<UserControl
    x:Class="Assetra.WPF.Features.Trends.TrendsView"
    xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
    xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
    xmlns:controls="clr-namespace:Assetra.WPF.Controls"
    xmlns:d="http://schemas.microsoft.com/expression/blend/2008"
    xmlns:lvc="clr-namespace:LiveChartsCore.SkiaSharpView.WPF;assembly=LiveChartsCore.SkiaSharpView.WPF"
    xmlns:mc="http://schemas.openxmlformats.org/markup-compatibility/2006"
    xmlns:portfolio="clr-namespace:Assetra.WPF.Features.Portfolio"
    xmlns:ui="http://schemas.lepo.co/wpfui/2022/xaml"
    d:DataContext="{d:DesignInstance Type={x:Type portfolio:PortfolioHistoryViewModel},
                                     IsDesignTimeCreatable=False}"
    d:DesignHeight="776"
    d:DesignWidth="1100"
    Background="{DynamicResource AppBackground}"
    mc:Ignorable="d">

    <Grid Margin="24">
        <Grid.RowDefinitions>
            <RowDefinition Height="Auto" />
            <RowDefinition Height="*" />
            <RowDefinition Height="Auto" />
        </Grid.RowDefinitions>

        <!--  ── Period selector + custom range picker ──  -->
        <DockPanel Grid.Row="0" Margin="0,0,0,16">
            <controls:DateRangePicker
                MinWidth="260"
                DockPanel.Dock="Right"
                EndDate="{Binding CustomEndDate, Mode=TwoWay}"
                Placeholder="{DynamicResource Trends.CustomRange}"
                StartDate="{Binding CustomStartDate, Mode=TwoWay}" />

            <StackPanel Orientation="Horizontal">
                <!--
                    Each preset button's Appearance is driven by a DataTrigger
                    comparing ViewModel.ActivePeriod to that button's Tag, so
                    the currently-active range is highlighted as Primary while
                    the rest stay Secondary.
                -->
                <ui:Button
                    Margin="0,0,8,0"
                    Command="{Binding ChangePeriodCommand}"
                    CommandParameter="30"
                    Content="{DynamicResource Trends.Period.30}"
                    Tag="30">
                    <ui:Button.Style>
                        <Style BasedOn="{StaticResource {x:Type ui:Button}}" TargetType="ui:Button">
                            <Setter Property="Appearance" Value="Secondary" />
                            <Style.Triggers>
                                <DataTrigger Binding="{Binding ActivePeriod}" Value="30">
                                    <Setter Property="Appearance" Value="Primary" />
                                </DataTrigger>
                            </Style.Triggers>
                        </Style>
                    </ui:Button.Style>
                </ui:Button>

                <ui:Button
                    Margin="0,0,8,0"
                    Command="{Binding ChangePeriodCommand}"
                    CommandParameter="90"
                    Content="{DynamicResource Trends.Period.90}"
                    Tag="90">
                    <ui:Button.Style>
                        <Style BasedOn="{StaticResource {x:Type ui:Button}}" TargetType="ui:Button">
                            <Setter Property="Appearance" Value="Secondary" />
                            <Style.Triggers>
                                <DataTrigger Binding="{Binding ActivePeriod}" Value="90">
                                    <Setter Property="Appearance" Value="Primary" />
                                </DataTrigger>
                            </Style.Triggers>
                        </Style>
                    </ui:Button.Style>
                </ui:Button>

                <ui:Button
                    Margin="0,0,8,0"
                    Command="{Binding ChangePeriodCommand}"
                    CommandParameter="180"
                    Content="{DynamicResource Trends.Period.180}"
                    Tag="180">
                    <ui:Button.Style>
                        <Style BasedOn="{StaticResource {x:Type ui:Button}}" TargetType="ui:Button">
                            <Setter Property="Appearance" Value="Secondary" />
                            <Style.Triggers>
                                <DataTrigger Binding="{Binding ActivePeriod}" Value="180">
                                    <Setter Property="Appearance" Value="Primary" />
                                </DataTrigger>
                            </Style.Triggers>
                        </Style>
                    </ui:Button.Style>
                </ui:Button>

                <ui:Button
                    Margin="0,0,8,0"
                    Command="{Binding ChangePeriodCommand}"
                    CommandParameter="365"
                    Content="{DynamicResource Trends.Period.365}"
                    Tag="365">
                    <ui:Button.Style>
                        <Style BasedOn="{StaticResource {x:Type ui:Button}}" TargetType="ui:Button">
                            <Setter Property="Appearance" Value="Secondary" />
                            <Style.Triggers>
                                <DataTrigger Binding="{Binding ActivePeriod}" Value="365">
                                    <Setter Property="Appearance" Value="Primary" />
                                </DataTrigger>
                            </Style.Triggers>
                        </Style>
                    </ui:Button.Style>
                </ui:Button>

                <ui:Button
                    Margin="0,0,16,0"
                    Command="{Binding ChangePeriodCommand}"
                    CommandParameter="All"
                    Content="{DynamicResource Trends.Period.All}"
                    Tag="All">
                    <ui:Button.Style>
                        <Style BasedOn="{StaticResource {x:Type ui:Button}}" TargetType="ui:Button">
                            <Setter Property="Appearance" Value="Secondary" />
                            <Style.Triggers>
                                <DataTrigger Binding="{Binding ActivePeriod}" Value="All">
                                    <Setter Property="Appearance" Value="Primary" />
                                </DataTrigger>
                            </Style.Triggers>
                        </Style>
                    </ui:Button.Style>
                </ui:Button>
            </StackPanel>
        </DockPanel>

        <!--  ── Chart card ──  -->
        <ui:Card Grid.Row="1" Padding="20">
            <Grid>
                <lvc:CartesianChart
                    Background="Transparent"
                    Series="{Binding ValueSeries}"
                    TooltipPosition="Top"
                    TooltipTextSize="12"
                    Visibility="{Binding HasHistory, Converter={StaticResource BooleanToVisibilityConverter}}"
                    XAxes="{Binding XAxes}"
                    YAxes="{Binding YAxes}" />

                <!--  Empty state — no history yet  -->
                <StackPanel
                    HorizontalAlignment="Center"
                    VerticalAlignment="Center"
                    Visibility="{Binding HasHistory, Converter={StaticResource InverseBooleanToVisibilityConverter}}">
                    <ui:SymbolIcon
                        HorizontalAlignment="Center"
                        FontSize="48"
                        Foreground="{DynamicResource AppTextMuted}"
                        Symbol="DataTrending24" />
                    <TextBlock
                        Margin="0,12,0,0"
                        HorizontalAlignment="Center"
                        FontSize="{DynamicResource FontSizeSm}"
                        Foreground="{DynamicResource AppTextSecondary}"
                        Text="{DynamicResource Trends.Empty}" />
                </StackPanel>
            </Grid>
        </ui:Card>

        <!--  ── Footer hint ──  -->
        <TextBlock
            Grid.Row="2"
            Margin="0,12,0,0"
            FontSize="{DynamicResource FontSizeXs}"
            Foreground="{DynamicResource AppTextSecondary}"
            Text="{DynamicResource Trends.Hint}" />
    </Grid>
</UserControl>
