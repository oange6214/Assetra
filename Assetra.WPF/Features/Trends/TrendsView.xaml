<UserControl
    x:Class="Assetra.WPF.Features.Trends.TrendsView"
    xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
    xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
    xmlns:controls="clr-namespace:Assetra.WPF.Controls"
    xmlns:d="http://schemas.microsoft.com/expression/blend/2008"
    xmlns:lvc="clr-namespace:LiveChartsCore.SkiaSharpView.WPF;assembly=LiveChartsCore.SkiaSharpView.WPF"
    xmlns:mc="http://schemas.openxmlformats.org/markup-compatibility/2006"
    xmlns:portfolio="clr-namespace:Assetra.WPF.Features.Portfolio"
    xmlns:ds="clr-namespace:Assetra.WPF.DesignSystem.Controls"
    d:DataContext="{d:DesignInstance Type={x:Type portfolio:PortfolioHistoryViewModel},
                                     IsDesignTimeCreatable=False}"
    d:DesignHeight="776"
    d:DesignWidth="1100"
    Background="{DynamicResource AppBackground}"
    Loaded="TrendsView_Loaded"
    mc:Ignorable="d">

    <!--
        Row 順序（v2 重排）：原本 chart 用 Height="*" 在 Row 1，KPI/risk 在 Row 2/3 下方，
        導致畫面短時 KPI 卡完全在 fold 之下，使用者看不到區間報酬等核心數字。重排後
        KPI 與 risk row 上移到 chart 上方 — 一進頁就能看見「賺多少 / 報酬率」等摘要，
        chart 用剩餘空間繪製趨勢。
    -->
    <Grid Style="{StaticResource PageRootGrid}">
        <Grid.RowDefinitions>
            <RowDefinition Height="Auto" />
            <!--  period chip bar  -->
            <RowDefinition Height="Auto" />
            <!--  KPI 列（期初 / 期末 / 區間損益 / 報酬率 / 年化）— 上移到 chart 上方  -->
            <RowDefinition Height="Auto" />
            <!--  風險指標列（最大回撤 / 波動率 / Sharpe / HHI）  -->
            <RowDefinition Height="*" />
            <!--  main chart — 拿剩餘高度  -->
            <RowDefinition Height="Auto" />
            <!--  對標比較區  -->
            <RowDefinition Height="Auto" />
            <!--  footer hint  -->
        </Grid.RowDefinitions>

        <!--  ── Period selector + custom range picker ──  -->
        <DockPanel Grid.Row="0" Style="{StaticResource PageHeaderDock}">
            <controls:DateRangePicker
                MinWidth="260"
                DockPanel.Dock="Right"
                EndDate="{Binding CustomEndDate, Mode=TwoWay}"
                Placeholder="{DynamicResource Trends.CustomRange}"
                StartDate="{Binding CustomStartDate, Mode=TwoWay}" />

            <!--
                Period filter — RadioButton group sharing NavTabBtn (the
                same underline-indicator style used by the Allocation
                inner tabs and the new TabItem template). Replaces the
                previous five verbose Style/DataTrigger Primary/Secondary
                button blocks (~90 lines) with a single visual treatment
                aligned with the rest of the app.
            -->
            <!--  P5.9 — 7 chips: 5 天 / 1 個月 / 6 個月 / 本年迄今 / 1 年 / 5 年 / 全部  -->
            <StackPanel Orientation="Horizontal">
                <RadioButton
                    Command="{Binding ChangePeriodCommand}"
                    CommandParameter="5"
                    Content="{DynamicResource Trends.Period.5}"
                    GroupName="TrendsPeriod"
                    IsChecked="{Binding ActivePeriod, Mode=OneWay, Converter={StaticResource EqualityConverter}, ConverterParameter=5}"
                    Style="{StaticResource NavTabBtn}" />
                <RadioButton
                    Command="{Binding ChangePeriodCommand}"
                    CommandParameter="30"
                    Content="{DynamicResource Trends.Period.30}"
                    GroupName="TrendsPeriod"
                    IsChecked="{Binding ActivePeriod, Mode=OneWay, Converter={StaticResource EqualityConverter}, ConverterParameter=30}"
                    Style="{StaticResource NavTabBtn}" />
                <RadioButton
                    Command="{Binding ChangePeriodCommand}"
                    CommandParameter="180"
                    Content="{DynamicResource Trends.Period.180}"
                    GroupName="TrendsPeriod"
                    IsChecked="{Binding ActivePeriod, Mode=OneWay, Converter={StaticResource EqualityConverter}, ConverterParameter=180}"
                    Style="{StaticResource NavTabBtn}" />
                <RadioButton
                    Command="{Binding ChangePeriodCommand}"
                    CommandParameter="YTD"
                    Content="{DynamicResource Trends.Period.YTD}"
                    GroupName="TrendsPeriod"
                    IsChecked="{Binding ActivePeriod, Mode=OneWay, Converter={StaticResource EqualityConverter}, ConverterParameter=YTD}"
                    Style="{StaticResource NavTabBtn}" />
                <RadioButton
                    Command="{Binding ChangePeriodCommand}"
                    CommandParameter="365"
                    Content="{DynamicResource Trends.Period.365}"
                    GroupName="TrendsPeriod"
                    IsChecked="{Binding ActivePeriod, Mode=OneWay, Converter={StaticResource EqualityConverter}, ConverterParameter=365}"
                    Style="{StaticResource NavTabBtn}" />
                <RadioButton
                    Command="{Binding ChangePeriodCommand}"
                    CommandParameter="1825"
                    Content="{DynamicResource Trends.Period.1825}"
                    GroupName="TrendsPeriod"
                    IsChecked="{Binding ActivePeriod, Mode=OneWay, Converter={StaticResource EqualityConverter}, ConverterParameter=1825}"
                    Style="{StaticResource NavTabBtn}" />
                <RadioButton
                    Command="{Binding ChangePeriodCommand}"
                    CommandParameter="All"
                    Content="{DynamicResource Trends.Period.All}"
                    GroupName="TrendsPeriod"
                    IsChecked="{Binding ActivePeriod, Mode=OneWay, Converter={StaticResource EqualityConverter}, ConverterParameter=All}"
                    Style="{StaticResource NavTabBtn}" />
                <!--
                    「可用資料 X 天」hint — 跟在 chip 後面，讓使用者一眼看到實際 snapshot
                    範圍。若 chip 選了 180 / 365 但 hint 顯示「可用資料 22 天」，
                    使用者就知道 chart / KPI / 對標數值跟 30 天 chip 一樣是預期行為。
                    DataRangeHint 為空字串時 TextBlock 不渲染。
                -->
                <TextBlock
                    Margin="12,0,0,0"
                    VerticalAlignment="Center"
                    FontSize="{DynamicResource Font.Size.Xs}"
                    Foreground="{DynamicResource AppTextMuted}"
                    Text="{Binding DataRangeHint}" />
            </StackPanel>
        </DockPanel>

        <!--  ── Chart / empty state — P3.6 migrated to AppCardSummary baseline ──  -->
        <Border Grid.Row="3" Style="{StaticResource AppCardSummary}">
            <Grid Style="{StaticResource PageContentGrid}">
                <lvc:CartesianChart
                    Background="Transparent"
                    Series="{Binding CompareSeries}"
                    TooltipPosition="Top"
                    TooltipTextSize="12"
                    Visibility="{Binding HasHistory, Converter={StaticResource BooleanToVisibilityConverter}}"
                    XAxes="{Binding CompareXAxes}"
                    YAxes="{Binding CompareYAxes}" />

                <!--  對比 chips（投組／大盤固定、自訂可移除 ✕）＋「＋比較」搜尋 popup；疊在圖左上。  -->
                <StackPanel
                    Margin="6,2,0,0"
                    HorizontalAlignment="Left"
                    VerticalAlignment="Top"
                    Orientation="Horizontal">
                    <ItemsControl ItemsSource="{Binding ComparisonLegend}">
                        <ItemsControl.ItemsPanel>
                            <ItemsPanelTemplate>
                                <WrapPanel Orientation="Horizontal" />
                            </ItemsPanelTemplate>
                        </ItemsControl.ItemsPanel>
                        <ItemsControl.ItemTemplate>
                            <DataTemplate>
                                <Border
                                    Margin="0,0,6,0"
                                    Padding="7,2"
                                    VerticalAlignment="Center"
                                    BorderBrush="{DynamicResource AppBorderLight}"
                                    BorderThickness="1"
                                    CornerRadius="10">
                                    <StackPanel Orientation="Horizontal" VerticalAlignment="Center">
                                        <Ellipse Width="8" Height="8" Margin="0,0,5,0" VerticalAlignment="Center">
                                            <Ellipse.Fill>
                                                <SolidColorBrush Color="{Binding ColorHex}" />
                                            </Ellipse.Fill>
                                        </Ellipse>
                                        <TextBlock
                                            VerticalAlignment="Center"
                                            FontSize="{StaticResource Font.Size.Xs}"
                                            Foreground="{DynamicResource AppTextSecondary}"
                                            Text="{Binding Label}" />
                                        <Button
                                            Width="14" Height="14"
                                            Margin="5,0,0,0" Padding="0"
                                            VerticalAlignment="Center"
                                            Background="Transparent"
                                            BorderThickness="0"
                                            Command="{Binding DataContext.RemoveComparisonCommand, RelativeSource={RelativeSource AncestorType=ItemsControl}}"
                                            CommandParameter="{Binding RemoveSymbol}"
                                            Cursor="Hand"
                                            ToolTip="{DynamicResource Portfolio.History.RemoveComparison}"
                                            Visibility="{Binding RemoveSymbol, Converter={StaticResource NullToVisibilityConverter}}">
                                            <ds:AppIcon FontSize="9" Foreground="{DynamicResource AppTextMuted}" Symbol="Dismiss24" />
                                        </Button>
                                    </StackPanel>
                                </Border>
                            </DataTemplate>
                        </ItemsControl.ItemTemplate>
                    </ItemsControl>

                    <Button
                        x:Name="CompareBtn"
                        Margin="2,0,0,0"
                        Padding="10,2"
                        VerticalAlignment="Center"
                        Command="{Binding OpenComparisonPickerCommand}"
                        Content="{DynamicResource Portfolio.History.Compare}"
                        Cursor="Hand"
                        FontSize="{StaticResource Font.Size.Xs}"
                        Style="{StaticResource AppSecondaryButton}" />

                    <Popup
                        AllowsTransparency="True"
                        IsOpen="{Binding IsComparisonPickerOpen, Mode=TwoWay}"
                        Placement="Bottom"
                        PlacementTarget="{Binding ElementName=CompareBtn}"
                        StaysOpen="False">
                        <Border
                            Width="262"
                            Margin="0,4,0,0"
                            Padding="8"
                            Background="{DynamicResource AppBackground}"
                            BorderBrush="{DynamicResource AppBorderLight}"
                            BorderThickness="1"
                            CornerRadius="8">
                            <Border.Effect>
                                <DropShadowEffect BlurRadius="14" Direction="270" Opacity="0.18" ShadowDepth="3" />
                            </Border.Effect>
                            <StackPanel>
                                <!--  快速加入：我的投組 / 大盤（已加入時自動 disabled）  -->
                                <StackPanel Margin="0,0,0,8" Orientation="Horizontal">
                                    <Button
                                        Margin="0,0,6,0"
                                        Padding="10,3"
                                        Command="{Binding AddMyPortfolioCommand}"
                                        Content="{DynamicResource Portfolio.History.MeLabel}"
                                        FontSize="{StaticResource Font.Size.Xs}"
                                        Style="{StaticResource AppSecondaryButton}" />
                                    <Button
                                        Padding="10,3"
                                        Command="{Binding AddMarketCommand}"
                                        Content="{DynamicResource Portfolio.History.BenchmarkTaiex}"
                                        FontSize="{StaticResource Font.Size.Xs}"
                                        Style="{StaticResource AppSecondaryButton}" />
                                </StackPanel>
                                <!--  群組（投資組合 bucket）快速加入 — 比較「我的指定組合」  -->
                                <ItemsControl ItemsSource="{Binding ComparisonGroupOptions}">
                                    <ItemsControl.ItemsPanel>
                                        <ItemsPanelTemplate>
                                            <WrapPanel Orientation="Horizontal" />
                                        </ItemsPanelTemplate>
                                    </ItemsControl.ItemsPanel>
                                    <ItemsControl.ItemTemplate>
                                        <DataTemplate>
                                            <Button
                                                Margin="0,0,6,6"
                                                Padding="10,3"
                                                Command="{Binding DataContext.AddGroupCommand, RelativeSource={RelativeSource AncestorType=ItemsControl}}"
                                                CommandParameter="{Binding}"
                                                Content="{Binding Name}"
                                                FontSize="{StaticResource Font.Size.Xs}"
                                                Style="{StaticResource AppSecondaryButton}" />
                                        </DataTemplate>
                                    </ItemsControl.ItemTemplate>
                                </ItemsControl>
                                <DockPanel>
                                    <Button
                                        DockPanel.Dock="Right"
                                        Margin="6,0,0,0"
                                        MinHeight="28"
                                        Padding="10,0"
                                        Command="{Binding AddComparisonCommand}"
                                        Content="＋"
                                        Style="{StaticResource AppSecondaryButton}"
                                        ToolTip="{DynamicResource Portfolio.History.AddComparison.Hint}" />
                                    <TextBox
                                        VerticalContentAlignment="Center"
                                        Tag="{DynamicResource Portfolio.History.AddComparison.Hint}"
                                        Text="{Binding ComparisonInput, UpdateSourceTrigger=PropertyChanged}" />
                                </DockPanel>
                                <ItemsControl Margin="0,6,0,0" ItemsSource="{Binding ComparisonSuggestions}">
                                    <ItemsControl.ItemTemplate>
                                        <DataTemplate>
                                            <Button
                                                Padding="6,4"
                                                HorizontalContentAlignment="Stretch"
                                                Background="Transparent"
                                                BorderThickness="0"
                                                Command="{Binding DataContext.SelectComparisonSuggestionCommand, RelativeSource={RelativeSource AncestorType=ItemsControl}}"
                                                CommandParameter="{Binding}"
                                                Cursor="Hand">
                                                <Grid>
                                                    <Grid.ColumnDefinitions>
                                                        <ColumnDefinition Width="*" />
                                                        <ColumnDefinition Width="Auto" />
                                                    </Grid.ColumnDefinitions>
                                                    <StackPanel Grid.Column="0">
                                                        <TextBlock
                                                            FontWeight="SemiBold"
                                                            Foreground="{DynamicResource AppTextPrimary}"
                                                            Text="{Binding Symbol}" />
                                                        <TextBlock
                                                            FontSize="{StaticResource Font.Size.Xs}"
                                                            Foreground="{DynamicResource AppTextMuted}"
                                                            Text="{Binding Name}" />
                                                    </StackPanel>
                                                    <TextBlock
                                                        Grid.Column="1"
                                                        VerticalAlignment="Center"
                                                        FontSize="{StaticResource Font.Size.Xs}"
                                                        Foreground="{DynamicResource AppTextMuted}"
                                                        Text="{Binding Exchange}" />
                                                </Grid>
                                            </Button>
                                        </DataTemplate>
                                    </ItemsControl.ItemTemplate>
                                </ItemsControl>
                            </StackPanel>
                        </Border>
                    </Popup>

                    <!--  空清單提示（預設無比較項目時）  -->
                    <TextBlock
                        Margin="8,0,0,0"
                        VerticalAlignment="Center"
                        FontSize="{StaticResource Font.Size.Xs}"
                        Foreground="{DynamicResource AppTextMuted}"
                        Text="{DynamicResource Portfolio.History.ComparePrompt}"
                        Visibility="{Binding HasComparisonItems, Converter={StaticResource InverseBooleanToVisibilityConverter}}" />
                </StackPanel>

                <StackPanel
                    Style="{StaticResource EmptyStatePanel}"
                    Visibility="{Binding HasHistory, Converter={StaticResource InverseBooleanToVisibilityConverter}}">
                    <ds:AppIcon Style="{StaticResource EmptyStateIcon}" Symbol="DataTrending24" />
                    <TextBlock Style="{StaticResource EmptyStateHint}" Text="{DynamicResource Trends.Empty}" />
                </StackPanel>
            </Grid>
        </Border>

        <!--
            ── Hero summary card（取代原本 5+4 個小卡）──
            個人理財 dashboard 風格：一個 HERO 數字主視覺，搭配 supporting metrics 小字。
            設計優先級：
              1. 主視覺：報酬率 % + 區間損益 NT$（最大字、紅綠分色）
              2. 期初 → 期末 走勢（中字）
              3. 年化（小字、tooltip 解釋）
            風險指標（最大回撤 / 波動率 / Sharpe / HHI）改放在圖表「下方」次要區，
            非高頻使用者不該被它們淹沒。
        -->
        <!--  P3.6 Hero KPI summary card — migrated to AppCardSummary baseline  -->
        <Border Grid.Row="1"
                Margin="0,12,0,0"
                Style="{StaticResource AppCardSummary}"
                Visibility="{Binding HasKpis, Converter={StaticResource BooleanToVisibilityConverter}}">
            <Grid>
                <Grid.ColumnDefinitions>
                    <ColumnDefinition Width="*" />
                    <ColumnDefinition Width="Auto" />
                </Grid.ColumnDefinitions>

                <!--  Left：HERO 報酬率 + 區間損益  -->
                <StackPanel Grid.Column="0">
                    <TextBlock FontSize="{DynamicResource Font.Size.Xs}"
                               Foreground="{DynamicResource AppTextMuted}"
                               Text="{DynamicResource Trends.Kpi.ReturnPct}" />
                    <StackPanel Margin="0,2,0,0" Orientation="Horizontal" VerticalAlignment="Bottom">
                        <TextBlock FontFamily="{StaticResource Font.Family.Base}"
                                   FontSize="{StaticResource Font.Size.3xl}"
                                   FontWeight="SemiBold"
                                   Foreground="{DynamicResource AppTextPrimary}"
                                   Text="{Binding KpiReturnPct, StringFormat='+0.00%;-0.00%;0.00%'}"
                                   Typography.NumeralAlignment="Tabular" />
                        <TextBlock Margin="10,0,0,8"
                                   VerticalAlignment="Bottom"
                                   FontFamily="{StaticResource Font.Family.Base}"
                                   FontSize="{StaticResource Font.Size.Md}"
                                   Foreground="{DynamicResource AppTextSecondary}"
                                   Text="{Binding KpiAbsolutePnl, StringFormat='+#\,##0;-#\,##0;0'}"
                                   Typography.NumeralAlignment="Tabular" />
                    </StackPanel>
                    <!--  期初 → 期末 走勢小字  -->
                    <StackPanel Margin="0,8,0,0" Orientation="Horizontal">
                        <TextBlock FontFamily="{StaticResource Font.Family.Base}"
                                   FontSize="{StaticResource Font.Size.Sm}"
                                   Foreground="{DynamicResource AppTextMuted}"
                                   Text="{Binding KpiStartValue, StringFormat='N0'}"
                                   Typography.NumeralAlignment="Tabular" />
                        <TextBlock Margin="6,0,6,0"
                                   FontSize="{StaticResource Font.Size.Sm}"
                                   Foreground="{DynamicResource AppTextMuted}"
                                   Text="→" />
                        <TextBlock FontFamily="{StaticResource Font.Family.Base}"
                                   FontSize="{StaticResource Font.Size.Sm}"
                                   FontWeight="SemiBold"
                                   Foreground="{DynamicResource AppTextPrimary}"
                                   Text="{Binding KpiEndValue, StringFormat='N0'}"
                                   Typography.NumeralAlignment="Tabular" />
                    </StackPanel>
                </StackPanel>

                <!--  Right：年化（次要、靠右垂直置中）  -->
                <StackPanel Grid.Column="1" VerticalAlignment="Center">
                    <TextBlock HorizontalAlignment="Right"
                               FontSize="{DynamicResource Font.Size.Xs}"
                               Foreground="{DynamicResource AppTextMuted}"
                               Text="{DynamicResource Trends.Kpi.Annualized}" />
                    <TextBlock Margin="0,4,0,0"
                               HorizontalAlignment="Right"
                               FontFamily="{StaticResource Font.Family.Base}"
                               FontSize="{StaticResource Font.Size.Xl}"
                               FontWeight="SemiBold"
                               Foreground="{DynamicResource AppTextPrimary}"
                               Text="{Binding KpiAnnualizedPct, StringFormat='+0.00%;-0.00%;0.00%'}"
                               Typography.NumeralAlignment="Tabular" />
                </StackPanel>
            </Grid>
        </Border>

        <!--
            ── 風險指標列 ──
            從原本「KPI row 之後」改放在 chart 下方（與對標 row 同層次），
            減少進階指標對主視覺的視覺競爭。波動率 / Sharpe 對個人理財一般使用者是
            次要資訊；放這裡仍可看，但不會干擾主要「賺多少 / 報酬率」的訊息。
        -->
        <!--
            P3.3 — 4 個 KPI cards 升級成 mockup「Portfolio Analytics」風格：
              - Style=AppCardSummary inherit P3.1 baseline (radius 2Xl /
                Shadow.Card / BorderLight)
              - Padding 16 (local override，比 Summary 預設 20 緊一階給 KPI grid)
              - FontSize 升 Md→Xl (24px) tabular，數字成為真正 KPI 主視覺
              - Label margin 統一 0,0,0,6 跟 form rhythm 對齊
            UniformGrid Columns=4 + 每張獨立 Margin gap 製造 grid spacing。
        -->
        <UniformGrid
            Grid.Row="2"
            Margin="0,8,0,12"
            Columns="4"
            Visibility="{Binding HasKpis, Converter={StaticResource BooleanToVisibilityConverter}}">
            <!--  最大回撤  -->
            <Border Margin="0,0,6,0" Padding="16"
                    Style="{StaticResource AppCardSummary}"
                    Visibility="{Binding HasDrawdown, Converter={StaticResource BooleanToVisibilityConverter}}">
                <StackPanel>
                    <TextBlock Margin="0,0,0,6"
                               FontSize="{StaticResource Font.Size.Xs}"
                               Foreground="{DynamicResource AppTextMuted}"
                               Text="{DynamicResource Trends.Kpi.MaxDrawdown}" />
                    <TextBlock FontFamily="{StaticResource Font.Family.Numeric}"
                               FontSize="{StaticResource Font.Size.Xl}"
                               FontWeight="Bold"
                               Foreground="{DynamicResource AppDown}"
                               Text="{Binding KpiMaxDrawdownPct, StringFormat='0.00%'}"
                               Typography.NumeralAlignment="Tabular" />
                </StackPanel>
            </Border>
            <!--  年化波動率  -->
            <Border Margin="3,0,3,0" Padding="16"
                    Style="{StaticResource AppCardSummary}"
                    Visibility="{Binding HasVolatility, Converter={StaticResource BooleanToVisibilityConverter}}">
                <StackPanel>
                    <TextBlock Margin="0,0,0,6"
                               FontSize="{StaticResource Font.Size.Xs}"
                               Foreground="{DynamicResource AppTextMuted}"
                               Text="{DynamicResource Trends.Kpi.Volatility}" />
                    <TextBlock FontFamily="{StaticResource Font.Family.Numeric}"
                               FontSize="{StaticResource Font.Size.Xl}"
                               FontWeight="Bold"
                               Foreground="{DynamicResource AppTextPrimary}"
                               Text="{Binding KpiVolatilityPct, StringFormat='0.00%'}"
                               Typography.NumeralAlignment="Tabular" />
                </StackPanel>
            </Border>
            <!--  Sharpe  -->
            <Border Margin="3,0,3,0" Padding="16"
                    Style="{StaticResource AppCardSummary}"
                    Visibility="{Binding HasSharpe, Converter={StaticResource BooleanToVisibilityConverter}}">
                <StackPanel>
                    <TextBlock Margin="0,0,0,6"
                               FontSize="{StaticResource Font.Size.Xs}"
                               Foreground="{DynamicResource AppTextMuted}"
                               Text="{DynamicResource Trends.Kpi.Sharpe}" />
                    <TextBlock FontFamily="{StaticResource Font.Family.Numeric}"
                               FontSize="{StaticResource Font.Size.Xl}"
                               FontWeight="Bold"
                               Foreground="{DynamicResource AppTextPrimary}"
                               Text="{Binding KpiSharpeRatio, StringFormat='0.00'}"
                               Typography.NumeralAlignment="Tabular" />
                </StackPanel>
            </Border>
            <!--  HHI 集中度  -->
            <Border Margin="6,0,0,0" Padding="16"
                    Style="{StaticResource AppCardSummary}"
                    Visibility="{Binding HasHhi, Converter={StaticResource BooleanToVisibilityConverter}}">
                <StackPanel>
                    <TextBlock Margin="0,0,0,6"
                               FontSize="{StaticResource Font.Size.Xs}"
                               Foreground="{DynamicResource AppTextMuted}"
                               Text="{DynamicResource Trends.Kpi.Hhi}" />
                    <TextBlock FontFamily="{StaticResource Font.Family.Numeric}"
                               FontSize="{StaticResource Font.Size.Xl}"
                               FontWeight="Bold"
                               Foreground="{DynamicResource AppTextPrimary}"
                               Text="{Binding KpiHhi, StringFormat='0.000'}"
                               Typography.NumeralAlignment="Tabular" />
                </StackPanel>
            </Border>
        </UniformGrid>

        <!--  舊「同期對標報酬率」固定表已移除；比較改由圖上方 chips ＋「＋比較」彈性選擇（ComparisonItems）。  -->

        <!--  ── Footer hint — P5.1 修復可疑點工具列已移除（曲線改算真實淨值後 partial-price 假象問題不存在）  -->
        <TextBlock
            Grid.Row="5"
            Margin="0,12,0,0"
            VerticalAlignment="Center"
            FontSize="{DynamicResource Font.Size.Xs}"
            Foreground="{DynamicResource AppTextSecondary}"
            Text="{DynamicResource Trends.Hint}" />
    </Grid>
</UserControl>
