<UserControl
    x:Class="Assetra.WPF.Features.Trends.TrendsView"
    xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
    xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
    xmlns:controls="clr-namespace:Assetra.WPF.Controls"
    xmlns:d="http://schemas.microsoft.com/expression/blend/2008"
    xmlns:lvc="clr-namespace:LiveChartsCore.SkiaSharpView.WPF;assembly=LiveChartsCore.SkiaSharpView.WPF"
    xmlns:mc="http://schemas.openxmlformats.org/markup-compatibility/2006"
    xmlns:portfolio="clr-namespace:Assetra.WPF.Features.Portfolio"
    xmlns:ds="clr-namespace:Assetra.WPF.DesignSystem.Controls"
    d:DataContext="{d:DesignInstance Type={x:Type portfolio:PortfolioHistoryViewModel},
                                     IsDesignTimeCreatable=False}"
    d:DesignHeight="776"
    d:DesignWidth="1100"
    Background="{DynamicResource AppBackground}"
    mc:Ignorable="d">

    <Grid Style="{StaticResource PageRootGrid}">
        <Grid.RowDefinitions>
            <RowDefinition Height="Auto" />
            <!--  period chip bar  -->
            <RowDefinition Height="*" />
            <!--  main chart  -->
            <RowDefinition Height="Auto" />
            <!--  Stage 1: 區間 KPI 列（期初 / 期末 / 區間損益 / 報酬率 / 年化）  -->
            <RowDefinition Height="Auto" />
            <!--  風險指標列（最大回撤 / 波動率 / Sharpe / HHI）  -->
            <RowDefinition Height="Auto" />
            <!--  對標比較區  -->
            <RowDefinition Height="Auto" />
            <!--  footer hint  -->
        </Grid.RowDefinitions>

        <!--  ── Period selector + custom range picker ──  -->
        <DockPanel Grid.Row="0" Style="{StaticResource PageHeaderDock}">
            <controls:DateRangePicker
                MinWidth="260"
                DockPanel.Dock="Right"
                EndDate="{Binding CustomEndDate, Mode=TwoWay}"
                Placeholder="{DynamicResource Trends.CustomRange}"
                StartDate="{Binding CustomStartDate, Mode=TwoWay}" />

            <!--
                Period filter — RadioButton group sharing NavTabBtn (the
                same underline-indicator style used by the Allocation
                inner tabs and the new TabItem template). Replaces the
                previous five verbose Style/DataTrigger Primary/Secondary
                button blocks (~90 lines) with a single visual treatment
                aligned with the rest of the app.
            -->
            <StackPanel Orientation="Horizontal">
                <RadioButton
                    Command="{Binding ChangePeriodCommand}"
                    CommandParameter="30"
                    Content="{DynamicResource Trends.Period.30}"
                    GroupName="TrendsPeriod"
                    IsChecked="{Binding ActivePeriod, Mode=OneWay, Converter={StaticResource EqualityConverter}, ConverterParameter=30}"
                    Style="{StaticResource NavTabBtn}" />
                <RadioButton
                    Command="{Binding ChangePeriodCommand}"
                    CommandParameter="90"
                    Content="{DynamicResource Trends.Period.90}"
                    GroupName="TrendsPeriod"
                    IsChecked="{Binding ActivePeriod, Mode=OneWay, Converter={StaticResource EqualityConverter}, ConverterParameter=90}"
                    Style="{StaticResource NavTabBtn}" />
                <RadioButton
                    Command="{Binding ChangePeriodCommand}"
                    CommandParameter="180"
                    Content="{DynamicResource Trends.Period.180}"
                    GroupName="TrendsPeriod"
                    IsChecked="{Binding ActivePeriod, Mode=OneWay, Converter={StaticResource EqualityConverter}, ConverterParameter=180}"
                    Style="{StaticResource NavTabBtn}" />
                <RadioButton
                    Command="{Binding ChangePeriodCommand}"
                    CommandParameter="365"
                    Content="{DynamicResource Trends.Period.365}"
                    GroupName="TrendsPeriod"
                    IsChecked="{Binding ActivePeriod, Mode=OneWay, Converter={StaticResource EqualityConverter}, ConverterParameter=365}"
                    Style="{StaticResource NavTabBtn}" />
                <RadioButton
                    Command="{Binding ChangePeriodCommand}"
                    CommandParameter="All"
                    Content="{DynamicResource Trends.Period.All}"
                    GroupName="TrendsPeriod"
                    IsChecked="{Binding ActivePeriod, Mode=OneWay, Converter={StaticResource EqualityConverter}, ConverterParameter=All}"
                    Style="{StaticResource NavTabBtn}" />
            </StackPanel>
        </DockPanel>

        <!--  ── Chart / empty state — wrapped in FormCard for visual consistency ──  -->
        <Border Grid.Row="1" Style="{StaticResource FormCard}">
            <Grid Style="{StaticResource PageContentGrid}">
                <lvc:CartesianChart
                    Background="Transparent"
                    Series="{Binding ValueSeries}"
                    TooltipPosition="Top"
                    TooltipTextSize="12"
                    Visibility="{Binding HasHistory, Converter={StaticResource BooleanToVisibilityConverter}}"
                    XAxes="{Binding XAxes}"
                    YAxes="{Binding YAxes}" />

                <StackPanel
                    Style="{StaticResource EmptyStatePanel}"
                    Visibility="{Binding HasHistory, Converter={StaticResource InverseBooleanToVisibilityConverter}}">
                    <ds:AppIcon Style="{StaticResource EmptyStateIcon}" Symbol="DataTrending24" />
                    <TextBlock Style="{StaticResource EmptyStateHint}" Text="{DynamicResource Trends.Empty}" />
                </StackPanel>
            </Grid>
        </Border>

        <!--  ── Stage 1: 區間 KPI 列（期初/期末/絕對 PnL/報酬率/年化/最大回撤）──  -->
        <!--
            注意：XAML StringFormat 中的逗號是 markup extension 分隔符，
            需用單引號包住整段 format 字串避免被誤切。百分比 0.00% 同理。
        -->
        <UniformGrid
            Grid.Row="2"
            Margin="0,12,0,0"
            Columns="5"
            Visibility="{Binding HasKpis, Converter={StaticResource BooleanToVisibilityConverter}}">
            <!--  期初  -->
            <Border Margin="0,0,4,0" Padding="10,8" Background="{DynamicResource AppCardBackground}"
                    BorderBrush="{DynamicResource AppBorder}" BorderThickness="1"
                    CornerRadius="{StaticResource Radius.Sm}">
                <StackPanel>
                    <TextBlock FontSize="{DynamicResource Font.Size.Xs}"
                               Foreground="{DynamicResource AppTextMuted}"
                               Text="{DynamicResource Trends.Kpi.StartValue}" />
                    <TextBlock FontSize="{DynamicResource Font.Size.Md}" FontWeight="SemiBold"
                               Foreground="{DynamicResource AppTextPrimary}"
                               Text="{Binding KpiStartValue, StringFormat='N0'}" />
                </StackPanel>
            </Border>
            <!--  期末  -->
            <Border Margin="2,0,2,0" Padding="10,8" Background="{DynamicResource AppCardBackground}"
                    BorderBrush="{DynamicResource AppBorder}" BorderThickness="1"
                    CornerRadius="{StaticResource Radius.Sm}">
                <StackPanel>
                    <TextBlock FontSize="{DynamicResource Font.Size.Xs}"
                               Foreground="{DynamicResource AppTextMuted}"
                               Text="{DynamicResource Trends.Kpi.EndValue}" />
                    <TextBlock FontSize="{DynamicResource Font.Size.Md}" FontWeight="SemiBold"
                               Foreground="{DynamicResource AppTextPrimary}"
                               Text="{Binding KpiEndValue, StringFormat='N0'}" />
                </StackPanel>
            </Border>
            <!--  區間絕對損益  -->
            <Border Margin="2,0,2,0" Padding="10,8" Background="{DynamicResource AppCardBackground}"
                    BorderBrush="{DynamicResource AppBorder}" BorderThickness="1"
                    CornerRadius="{StaticResource Radius.Sm}">
                <StackPanel>
                    <TextBlock FontSize="{DynamicResource Font.Size.Xs}"
                               Foreground="{DynamicResource AppTextMuted}"
                               Text="{DynamicResource Trends.Kpi.AbsolutePnl}" />
                    <TextBlock FontSize="{DynamicResource Font.Size.Md}" FontWeight="SemiBold"
                               Foreground="{DynamicResource AppTextPrimary}"
                               Text="{Binding KpiAbsolutePnl, StringFormat='+#\,##0;-#\,##0;0'}" />
                </StackPanel>
            </Border>
            <!--  區間報酬率  -->
            <Border Margin="2,0,2,0" Padding="10,8" Background="{DynamicResource AppCardBackground}"
                    BorderBrush="{DynamicResource AppBorder}" BorderThickness="1"
                    CornerRadius="{StaticResource Radius.Sm}">
                <StackPanel>
                    <TextBlock FontSize="{DynamicResource Font.Size.Xs}"
                               Foreground="{DynamicResource AppTextMuted}"
                               Text="{DynamicResource Trends.Kpi.ReturnPct}" />
                    <TextBlock FontSize="{DynamicResource Font.Size.Md}" FontWeight="SemiBold"
                               Foreground="{DynamicResource AppTextPrimary}"
                               Text="{Binding KpiReturnPct, StringFormat='+0.00%;-0.00%;0.00%'}" />
                </StackPanel>
            </Border>
            <!--  年化  -->
            <Border Margin="4,0,0,0" Padding="10,8" Background="{DynamicResource AppCardBackground}"
                    BorderBrush="{DynamicResource AppBorder}" BorderThickness="1"
                    CornerRadius="{StaticResource Radius.Sm}">
                <StackPanel>
                    <TextBlock FontSize="{DynamicResource Font.Size.Xs}"
                               Foreground="{DynamicResource AppTextMuted}"
                               Text="{DynamicResource Trends.Kpi.Annualized}" />
                    <TextBlock FontSize="{DynamicResource Font.Size.Md}" FontWeight="SemiBold"
                               Foreground="{DynamicResource AppTextPrimary}"
                               Text="{Binding KpiAnnualizedPct, StringFormat='+0.00%;-0.00%;0.00%'}" />
                </StackPanel>
            </Border>
        </UniformGrid>

        <!--
            ── 風險指標列 ──
            從 Reports.Risk Expander 搬到 Trends（合併「動態觀察」語意）。
            每張卡有獨立的 Has* 旗標控制顯示；都沒注入時整列空白。
        -->
        <UniformGrid
            Grid.Row="3"
            Margin="0,8,0,0"
            Columns="4"
            Visibility="{Binding HasKpis, Converter={StaticResource BooleanToVisibilityConverter}}">
            <!--  最大回撤  -->
            <Border Margin="0,0,4,0" Padding="10,8" Background="{DynamicResource AppCardBackground}"
                    BorderBrush="{DynamicResource AppBorder}" BorderThickness="1"
                    CornerRadius="{StaticResource Radius.Sm}"
                    Visibility="{Binding HasDrawdown, Converter={StaticResource BooleanToVisibilityConverter}}">
                <StackPanel>
                    <TextBlock FontSize="{DynamicResource Font.Size.Xs}"
                               Foreground="{DynamicResource AppTextMuted}"
                               Text="{DynamicResource Trends.Kpi.MaxDrawdown}" />
                    <TextBlock FontSize="{DynamicResource Font.Size.Md}" FontWeight="SemiBold"
                               Foreground="{DynamicResource AppDown}"
                               Text="{Binding KpiMaxDrawdownPct, StringFormat='0.00%'}" />
                </StackPanel>
            </Border>
            <!--  年化波動率  -->
            <Border Margin="2,0,2,0" Padding="10,8" Background="{DynamicResource AppCardBackground}"
                    BorderBrush="{DynamicResource AppBorder}" BorderThickness="1"
                    CornerRadius="{StaticResource Radius.Sm}"
                    Visibility="{Binding HasVolatility, Converter={StaticResource BooleanToVisibilityConverter}}">
                <StackPanel>
                    <TextBlock FontSize="{DynamicResource Font.Size.Xs}"
                               Foreground="{DynamicResource AppTextMuted}"
                               Text="{DynamicResource Trends.Kpi.Volatility}" />
                    <TextBlock FontSize="{DynamicResource Font.Size.Md}" FontWeight="SemiBold"
                               Foreground="{DynamicResource AppTextPrimary}"
                               Text="{Binding KpiVolatilityPct, StringFormat='0.00%'}" />
                </StackPanel>
            </Border>
            <!--  Sharpe  -->
            <Border Margin="2,0,2,0" Padding="10,8" Background="{DynamicResource AppCardBackground}"
                    BorderBrush="{DynamicResource AppBorder}" BorderThickness="1"
                    CornerRadius="{StaticResource Radius.Sm}"
                    Visibility="{Binding HasSharpe, Converter={StaticResource BooleanToVisibilityConverter}}">
                <StackPanel>
                    <TextBlock FontSize="{DynamicResource Font.Size.Xs}"
                               Foreground="{DynamicResource AppTextMuted}"
                               Text="{DynamicResource Trends.Kpi.Sharpe}" />
                    <TextBlock FontSize="{DynamicResource Font.Size.Md}" FontWeight="SemiBold"
                               Foreground="{DynamicResource AppTextPrimary}"
                               Text="{Binding KpiSharpeRatio, StringFormat='0.00'}" />
                </StackPanel>
            </Border>
            <!--  HHI 集中度  -->
            <Border Margin="4,0,0,0" Padding="10,8" Background="{DynamicResource AppCardBackground}"
                    BorderBrush="{DynamicResource AppBorder}" BorderThickness="1"
                    CornerRadius="{StaticResource Radius.Sm}"
                    Visibility="{Binding HasHhi, Converter={StaticResource BooleanToVisibilityConverter}}">
                <StackPanel>
                    <TextBlock FontSize="{DynamicResource Font.Size.Xs}"
                               Foreground="{DynamicResource AppTextMuted}"
                               Text="{DynamicResource Trends.Kpi.Hhi}" />
                    <TextBlock FontSize="{DynamicResource Font.Size.Md}" FontWeight="SemiBold"
                               Foreground="{DynamicResource AppTextPrimary}"
                               Text="{Binding KpiHhi, StringFormat='0.000'}" />
                </StackPanel>
            </Border>
        </UniformGrid>

        <!--  ── Stage 1: 對標比較區（4 個固定 benchmark TWR）──  -->
        <Border
            Grid.Row="4"
            Margin="0,8,0,0"
            Padding="14,10"
            Background="{DynamicResource AppCardBackground}"
            BorderBrush="{DynamicResource AppBorder}"
            BorderThickness="1"
            CornerRadius="{StaticResource Radius.Sm}"
            Visibility="{Binding HasBenchmark, Converter={StaticResource BooleanToVisibilityConverter}}">
            <StackPanel>
                <TextBlock
                    Margin="0,0,0,6"
                    FontSize="{DynamicResource Font.Size.Xs}"
                    FontWeight="SemiBold"
                    Foreground="{DynamicResource AppTextSecondary}"
                    Text="{DynamicResource Trends.Benchmark.Heading}" />
                <UniformGrid Columns="4">
                    <StackPanel Margin="0,0,8,0">
                        <TextBlock FontSize="{DynamicResource Font.Size.Xs}"
                                   Foreground="{DynamicResource AppTextMuted}"
                                   Text="{DynamicResource Trends.Benchmark.Taiex}" />
                        <TextBlock FontSize="{DynamicResource Font.Size.Sm}" FontWeight="SemiBold"
                                   Foreground="{DynamicResource AppTextPrimary}"
                                   Text="{Binding BenchmarkTaiexDisplay}" />
                    </StackPanel>
                    <StackPanel Margin="4,0,4,0">
                        <TextBlock FontSize="{DynamicResource Font.Size.Xs}"
                                   Foreground="{DynamicResource AppTextMuted}"
                                   Text="{DynamicResource Trends.Benchmark.Tw0050}" />
                        <TextBlock FontSize="{DynamicResource Font.Size.Sm}" FontWeight="SemiBold"
                                   Foreground="{DynamicResource AppTextPrimary}"
                                   Text="{Binding BenchmarkTw0050Display}" />
                    </StackPanel>
                    <StackPanel Margin="4,0,4,0">
                        <TextBlock FontSize="{DynamicResource Font.Size.Xs}"
                                   Foreground="{DynamicResource AppTextMuted}"
                                   Text="{DynamicResource Trends.Benchmark.Tw00981A}" />
                        <TextBlock FontSize="{DynamicResource Font.Size.Sm}" FontWeight="SemiBold"
                                   Foreground="{DynamicResource AppTextPrimary}"
                                   Text="{Binding BenchmarkTw00981ADisplay}" />
                    </StackPanel>
                    <StackPanel Margin="8,0,0,0">
                        <TextBlock FontSize="{DynamicResource Font.Size.Xs}"
                                   Foreground="{DynamicResource AppTextMuted}"
                                   Text="{DynamicResource Trends.Benchmark.Deposit15}" />
                        <TextBlock FontSize="{DynamicResource Font.Size.Sm}" FontWeight="SemiBold"
                                   Foreground="{DynamicResource AppTextPrimary}"
                                   Text="{Binding BenchmarkDeposit15Display}" />
                    </StackPanel>
                </UniformGrid>
            </StackPanel>
        </Border>

        <!--  ── Footer hint ──  -->
        <TextBlock
            Grid.Row="5"
            Margin="0,12,0,0"
            FontSize="{DynamicResource Font.Size.Xs}"
            Foreground="{DynamicResource AppTextSecondary}"
            Text="{DynamicResource Trends.Hint}" />
    </Grid>
</UserControl>
