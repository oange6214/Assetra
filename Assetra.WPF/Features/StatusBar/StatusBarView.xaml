<UserControl
    x:Class="Assetra.WPF.Features.StatusBar.StatusBarView"
    xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
    xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
    xmlns:d="http://schemas.microsoft.com/expression/blend/2008"
    xmlns:mc="http://schemas.openxmlformats.org/markup-compatibility/2006"
    xmlns:vm="clr-namespace:Assetra.WPF.Features.StatusBar"
    d:DataContext="{d:DesignInstance Type={x:Type vm:StatusBarViewModel},
                                     IsDesignTimeCreatable=False}"
    d:DesignHeight="32"
    d:DesignWidth="1440"
    mc:Ignorable="d">

    <!--
        Assetra simplified status bar — 28px, single row.
        Shows market open/closed indicator (clock-driven, TWSE 09:00–13:30)
        and current local time.
    -->
    <Border
        Height="28"
        Background="{DynamicResource AppSurface}"
        BorderBrush="{DynamicResource AppBorder}"
        BorderThickness="0,1,0,0">

        <Grid Margin="16,0">

            <!--  Left: sync indicator + market status (split by a thin divider)  -->
            <StackPanel VerticalAlignment="Center" Orientation="Horizontal">
                <!--  ── Sync status (dot + label) — Phase 1 of Sync-Status-Indicator  -->
                <StackPanel
                    VerticalAlignment="Center"
                    Orientation="Horizontal"
                    ToolTip="{Binding SyncStatusText}">
                    <Ellipse
                        Width="7"
                        Height="7"
                        Margin="0,0,5,0"
                        VerticalAlignment="Center"
                        Fill="{Binding SyncStatusBrush}" />
                    <TextBlock
                        VerticalAlignment="Center"
                        FontSize="{StaticResource Font.Size.Xs}"
                        Foreground="{DynamicResource AppTextPrimary}"
                        Text="{Binding SyncStatusText}" />
                </StackPanel>

                <!--  Divider  -->
                <Border
                    Width="1"
                    Height="12"
                    Margin="12,0"
                    VerticalAlignment="Center"
                    Background="{DynamicResource AppBorder}" />

                <!--  ── Market status (dot + label) — clock-driven  -->
                <Ellipse
                    Width="7"
                    Height="7"
                    Margin="0,0,5,0"
                    VerticalAlignment="Center"
                    Fill="{Binding IsMarketOpen, Converter={StaticResource BooleanToBrushConverter}}" />
                <TextBlock
                    VerticalAlignment="Center"
                    FontSize="{StaticResource Font.Size.Xs}"
                    Foreground="{DynamicResource AppTextPrimary}"
                    Text="{Binding MarketStatusText}" />
            </StackPanel>

            <!--  Right: clock  -->
            <TextBlock
                HorizontalAlignment="Right"
                VerticalAlignment="Center"
                FontFamily="{StaticResource Font.Family.Base}"
                FontSize="{StaticResource Font.Size.Xs}"
                Foreground="{DynamicResource AppTextMuted}"
                Text="{Binding ClockText}"
                Typography.NumeralAlignment="Tabular" />

        </Grid>
    </Border>
</UserControl>
