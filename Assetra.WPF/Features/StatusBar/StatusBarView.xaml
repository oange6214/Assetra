<UserControl
    x:Class="Assetra.WPF.Features.StatusBar.StatusBarView"
    xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
    xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
    xmlns:d="http://schemas.microsoft.com/expression/blend/2008"
    xmlns:mc="http://schemas.openxmlformats.org/markup-compatibility/2006"
    xmlns:vm="clr-namespace:Assetra.WPF.Features.StatusBar"
    d:DataContext="{d:DesignInstance Type={x:Type vm:StatusBarViewModel},
                                     IsDesignTimeCreatable=False}"
    d:DesignHeight="32"
    d:DesignWidth="1440"
    mc:Ignorable="d">

    <!--
        Assetra simplified status bar — 28px, single row.
        Shows market open/closed indicator (clock-driven, TWSE 09:00–13:30)
        and current local time.
    -->
    <Border
        Height="28"
        Background="{DynamicResource AppSurface}"
        BorderBrush="{DynamicResource AppBorder}"
        BorderThickness="0,1,0,0">

        <Grid Margin="16,0">

            <!--  Left: sync indicator + market status (split by a thin divider)  -->
            <StackPanel VerticalAlignment="Center" Orientation="Horizontal">
                <!--  ── Sync status (clickable chip → Phase 2 popover)  -->
                <Grid VerticalAlignment="Center">
                    <ToggleButton
                        x:Name="SyncChip"
                        Padding="6,2"
                        Background="Transparent"
                        BorderThickness="0"
                        Cursor="Hand"
                        IsChecked="{Binding SyncPopover.IsOpen, Mode=TwoWay}"
                        ToolTip="{Binding SyncStatusText}">
                        <ToggleButton.Style>
                            <Style TargetType="ToggleButton">
                                <Setter Property="Template">
                                    <Setter.Value>
                                        <ControlTemplate TargetType="ToggleButton">
                                            <Border
                                                x:Name="Bd"
                                                Padding="{TemplateBinding Padding}"
                                                Background="{TemplateBinding Background}"
                                                CornerRadius="4">
                                                <ContentPresenter VerticalAlignment="Center" HorizontalAlignment="Center" />
                                            </Border>
                                            <ControlTemplate.Triggers>
                                                <Trigger Property="IsMouseOver" Value="True">
                                                    <Setter TargetName="Bd" Property="Background" Value="{DynamicResource AppHoverOverlay}" />
                                                </Trigger>
                                                <Trigger Property="IsChecked" Value="True">
                                                    <Setter TargetName="Bd" Property="Background" Value="{DynamicResource AppActiveOverlay}" />
                                                </Trigger>
                                            </ControlTemplate.Triggers>
                                        </ControlTemplate>
                                    </Setter.Value>
                                </Setter>
                            </Style>
                        </ToggleButton.Style>
                        <StackPanel Orientation="Horizontal">
                            <Ellipse
                                Width="7"
                                Height="7"
                                Margin="0,0,5,0"
                                VerticalAlignment="Center"
                                Fill="{Binding SyncStatusBrush}" />
                            <TextBlock
                                VerticalAlignment="Center"
                                FontSize="{StaticResource Font.Size.Xs}"
                                Foreground="{DynamicResource AppTextPrimary}"
                                Text="{Binding SyncStatusText}" />
                        </StackPanel>
                    </ToggleButton>

                    <!--  Anchored popover above the chip; opens via the ToggleButton's IsChecked.  -->
                    <Popup
                        AllowsTransparency="True"
                        IsOpen="{Binding SyncPopover.IsOpen, Mode=TwoWay}"
                        Placement="Top"
                        PlacementTarget="{Binding ElementName=SyncChip}"
                        StaysOpen="False"
                        VerticalOffset="-6">
                        <ContentControl Content="{Binding SyncPopover}">
                            <ContentControl.Resources>
                                <DataTemplate DataType="{x:Type vm:SyncStatusPopoverViewModel}">
                                    <vm:SyncStatusPopoverView />
                                </DataTemplate>
                            </ContentControl.Resources>
                        </ContentControl>
                    </Popup>
                </Grid>

                <!--  Divider  -->
                <Border
                    Width="1"
                    Height="12"
                    Margin="12,0"
                    VerticalAlignment="Center"
                    Background="{DynamicResource AppBorder}" />

                <!--  ── Market status (dot + label) — clock-driven  -->
                <Ellipse
                    Width="7"
                    Height="7"
                    Margin="0,0,5,0"
                    VerticalAlignment="Center"
                    Fill="{Binding IsMarketOpen, Converter={StaticResource BooleanToBrushConverter}}" />
                <TextBlock
                    VerticalAlignment="Center"
                    FontSize="{StaticResource Font.Size.Xs}"
                    Foreground="{DynamicResource AppTextPrimary}"
                    Text="{Binding MarketStatusText}" />
            </StackPanel>

            <!--  Right: clock  -->
            <TextBlock
                HorizontalAlignment="Right"
                VerticalAlignment="Center"
                FontFamily="{StaticResource Font.Family.Base}"
                FontSize="{StaticResource Font.Size.Xs}"
                Foreground="{DynamicResource AppTextMuted}"
                Text="{Binding ClockText}"
                Typography.NumeralAlignment="Tabular" />

        </Grid>
    </Border>
</UserControl>
