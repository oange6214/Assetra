<UserControl
    x:Class="Assetra.WPF.Features.Categories.CategoriesDialogsHost"
    xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
    xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
    xmlns:behaviors="clr-namespace:Assetra.WPF.Infrastructure.Behaviors"
    xmlns:ctrl="clr-namespace:Assetra.WPF.Controls"
    xmlns:d="http://schemas.microsoft.com/expression/blend/2008"
    xmlns:ds="clr-namespace:Assetra.WPF.DesignSystem.Controls"
    xmlns:mc="http://schemas.openxmlformats.org/markup-compatibility/2006"
    xmlns:vm="clr-namespace:Assetra.WPF.Features.Categories"
    d:DataContext="{d:DesignInstance Type={x:Type vm:CategoriesViewModel},
                                     IsDesignTimeCreatable=False}"
    mc:Ignorable="d">

    <!--
        外提到 MainWindow 的 Categories dialog host — 包含 4 個 modal：
        新增分類 / 新增規則 / 新增預算 / 刪除確認。每個 modal 用 Grid 包住，
        overlay + card 共用同一個 Visibility 綁定。
        
        Root Grid 不設 Background：modal 沒開時 host 對 NavRail / title bar /
        status bar 點擊完全透明（避免吞 hit-test）。
    -->
    <Grid>

        <!--  分類 — 新增分類  -->
        <Grid Style="{StaticResource AppDialogOverlay}" Visibility="{Binding IsAddCategoryOpen, Converter={StaticResource BooleanToVisibilityConverter}}">
            <Border
                Width="640"
                MaxWidth="720"
                MaxHeight="620"
                HorizontalAlignment="Center"
                VerticalAlignment="Center"
                behaviors:EscapeKeyCommandBehavior.Command="{Binding CloseAddCategoryCommand}"
                SnapsToDevicePixels="True"
                Style="{StaticResource AppDialogShell}">
                <Grid>
                    <Grid.RowDefinitions>
                        <RowDefinition Height="Auto" />
                        <RowDefinition Height="Auto" />
                        <RowDefinition Height="Auto" />
                        <RowDefinition Height="Auto" />
                    </Grid.RowDefinitions>

                    <Grid Margin="0,0,0,16">
                        <StackPanel Margin="0,4,40,0">
                            <TextBlock Style="{StaticResource AppDialogTitle}" Text="{DynamicResource Categories.AddForm.Title}" />
                            <TextBlock
                                Style="{StaticResource AppDialogSubtitle}"
                                Text="{DynamicResource Categories.AddForm.Hint}"
                                TextWrapping="Wrap" />
                        </StackPanel>
                        <Button
                            Width="32"
                            Height="32"
                            Margin="0,-4,-4,0"
                            Padding="0"
                            HorizontalAlignment="Right"
                            VerticalAlignment="Top"
                            Command="{Binding CloseAddCategoryCommand}"
                            Style="{StaticResource AppIconButton}"
                            ToolTip="{DynamicResource Common.Close}">
                            <ds:AppIcon FontSize="13" Symbol="Dismiss24" />
                        </Button>
                    </Grid>

                    <Border Grid.Row="1" Style="{StaticResource FormSection}">
                        <Grid>
                            <Grid.Resources>
                                <Style x:Key="SheetFieldLabel" TargetType="TextBlock">
                                    <Setter Property="Margin" Value="0,0,0,6" />
                                    <Setter Property="FontSize" Value="{DynamicResource Font.Size.Xs}" />
                                    <Setter Property="FontWeight" Value="SemiBold" />
                                    <Setter Property="Foreground" Value="{DynamicResource AppTextSecondary}" />
                                </Style>
                                <Style BasedOn="{StaticResource AppTextBox}" TargetType="{x:Type TextBox}">
                                    <Setter Property="MinHeight" Value="40" />
                                </Style>
                                <Style
                                    x:Key="SheetComboBox"
                                    BasedOn="{StaticResource AppComboBox}"
                                    TargetType="ComboBox">
                                    <Setter Property="MinHeight" Value="40" />
                                </Style>
                            </Grid.Resources>
                            <Grid.RowDefinitions>
                                <RowDefinition Height="Auto" />
                                <RowDefinition Height="Auto" />
                                <RowDefinition Height="Auto" />
                            </Grid.RowDefinitions>
                            <Grid.ColumnDefinitions>
                                <ColumnDefinition Width="*" />
                                <ColumnDefinition Width="16" />
                                <ColumnDefinition Width="*" />
                            </Grid.ColumnDefinitions>

                            <StackPanel
                                Grid.Row="0"
                                Grid.Column="0"
                                Margin="0,0,0,14">
                                <TextBlock Style="{StaticResource SheetFieldLabel}" Text="{DynamicResource Categories.Field.Kind}" />
                                <ComboBox
                                    ItemsSource="{Binding KindOptions}"
                                    SelectedItem="{Binding AddKind}"
                                    Style="{StaticResource SheetComboBox}">
                                    <ComboBox.ItemTemplate>
                                        <DataTemplate>
                                            <TextBlock>
                                                <TextBlock.Style>
                                                    <Style TargetType="TextBlock">
                                                        <Setter Property="Text" Value="{DynamicResource Categories.Expense}" />
                                                        <Style.Triggers>
                                                            <DataTrigger Binding="{Binding}" Value="Income">
                                                                <Setter Property="Text" Value="{DynamicResource Categories.Income}" />
                                                            </DataTrigger>
                                                        </Style.Triggers>
                                                    </Style>
                                                </TextBlock.Style>
                                            </TextBlock>
                                        </DataTemplate>
                                    </ComboBox.ItemTemplate>
                                </ComboBox>
                            </StackPanel>

                            <StackPanel
                                Grid.Row="0"
                                Grid.Column="2"
                                Margin="0,0,0,14">
                                <TextBlock Style="{StaticResource SheetFieldLabel}" Text="{DynamicResource Categories.Field.Icon}" />
                                <ComboBox
                                    ItemsSource="{Binding IconOptions}"
                                    SelectedValue="{Binding AddIcon}"
                                    SelectedValuePath="Value"
                                    Style="{StaticResource SheetComboBox}"
                                    ToolTip="{DynamicResource Categories.IconHint}">
                                    <ComboBox.ItemTemplate>
                                        <DataTemplate>
                                            <StackPanel Orientation="Horizontal">
                                                <ds:AppIcon
                                                    Margin="0,0,8,0"
                                                    VerticalAlignment="Center"
                                                    FontSize="16"
                                                    Foreground="{DynamicResource AppTextPrimary}"
                                                    Symbol="{Binding Value}" />
                                                <TextBlock
                                                    VerticalAlignment="Center"
                                                    FontSize="{StaticResource Font.Size.Sm}"
                                                    Foreground="{DynamicResource AppTextSecondary}"
                                                    Text="{Binding Label}" />
                                            </StackPanel>
                                        </DataTemplate>
                                    </ComboBox.ItemTemplate>
                                </ComboBox>
                            </StackPanel>

                            <StackPanel Grid.Row="1" Grid.Column="0">
                                <TextBlock Style="{StaticResource SheetFieldLabel}" Text="{DynamicResource Categories.Field.Name}" />
                                <TextBox Text="{Binding AddName, UpdateSourceTrigger=PropertyChanged}" ToolTip="{DynamicResource Categories.NameHint}" />
                            </StackPanel>

                            <StackPanel Grid.Row="1" Grid.Column="2">
                                <TextBlock Style="{StaticResource SheetFieldLabel}" Text="{DynamicResource Categories.Field.Color}" />
                                <ctrl:HexColorPicker
                                    MinHeight="40"
                                    Presets="{Binding ColorOptions}"
                                    SelectedColorHex="{Binding AddColorHex, Mode=TwoWay}"
                                    ToolTip="{DynamicResource Categories.ColorHint}" />
                            </StackPanel>

                            <StackPanel
                                Grid.Row="2"
                                Grid.Column="0"
                                Grid.ColumnSpan="3"
                                Margin="0,8,0,0">
                                <TextBlock Style="{StaticResource SheetFieldLabel}" Text="{DynamicResource Categories.Field.Parent}" />
                                <ComboBox
                                    ItemsSource="{Binding AddParentOptions}"
                                    SelectedValue="{Binding AddParentId, Mode=TwoWay}"
                                    SelectedValuePath="Id" />
                            </StackPanel>
                        </Grid>
                    </Border>

                    <TextBlock
                        Grid.Row="2"
                        Margin="24,10,24,0"
                        FontSize="{StaticResource Font.Size.Xs}"
                        Foreground="{DynamicResource AppDown}"
                        Text="{Binding AddError}"
                        Visibility="{Binding AddError, Converter={StaticResource StringToVisibilityConverter}}" />

                    <Border
                        Grid.Row="3"
                        Margin="0,16,0,0"
                        Padding="0"
                        BorderBrush="{DynamicResource AppBorder}"
                        BorderThickness="0">
                        <StackPanel Style="{StaticResource AppDialogFooter}">
                            <Button
                                Margin="0,0,8,0"
                                Command="{Binding CloseAddCategoryCommand}"
                                Content="{DynamicResource Common.Cancel}"
                                Style="{StaticResource AppSecondaryButton}" />
                            <Button
                                Command="{Binding AddCategoryCommand}"
                                Content="{DynamicResource Categories.Add}"
                                Style="{StaticResource AppPrimaryButton}" />
                        </StackPanel>
                    </Border>
                </Grid>
            </Border>
        </Grid>

        <!--  分類 — 新增規則  -->
        <Grid Style="{StaticResource AppDialogOverlay}" Visibility="{Binding IsAddRuleOpen, Converter={StaticResource BooleanToVisibilityConverter}}">
            <Border
                Width="760"
                MaxWidth="820"
                MaxHeight="720"
                HorizontalAlignment="Center"
                VerticalAlignment="Center"
                behaviors:EscapeKeyCommandBehavior.Command="{Binding CloseAddRuleCommand}"
                SnapsToDevicePixels="True"
                Style="{StaticResource AppDialogShell}">
                <Grid>
                    <Grid.RowDefinitions>
                        <RowDefinition Height="Auto" />
                        <RowDefinition Height="*" />
                        <RowDefinition Height="Auto" />
                        <RowDefinition Height="Auto" />
                    </Grid.RowDefinitions>

                    <Grid Margin="0,0,0,16">
                        <StackPanel Margin="0,4,40,0">
                            <TextBlock Style="{StaticResource AppDialogTitle}" Text="{DynamicResource Categories.Rule.AddForm.Title}" />
                            <TextBlock
                                Style="{StaticResource AppDialogSubtitle}"
                                Text="{DynamicResource Categories.Rule.AddForm.Hint}"
                                TextWrapping="Wrap" />
                        </StackPanel>
                        <Button
                            Width="32"
                            Height="32"
                            Margin="0,-4,-4,0"
                            Padding="0"
                            HorizontalAlignment="Right"
                            VerticalAlignment="Top"
                            Command="{Binding CloseAddRuleCommand}"
                            Style="{StaticResource AppIconButton}"
                            ToolTip="{DynamicResource Common.Close}">
                            <ds:AppIcon FontSize="13" Symbol="Dismiss24" />
                        </Button>
                    </Grid>

                    <ScrollViewer
                        Grid.Row="1"
                        MaxHeight="500"
                        HorizontalScrollBarVisibility="Disabled"
                        VerticalScrollBarVisibility="Auto">
                        <StackPanel>
                            <Border Style="{StaticResource FormSection}">
                                <Grid>
                                    <Grid.RowDefinitions>
                                        <RowDefinition Height="Auto" />
                                        <RowDefinition Height="Auto" />
                                    </Grid.RowDefinitions>
                                    <Grid.ColumnDefinitions>
                                        <ColumnDefinition Width="*" />
                                        <ColumnDefinition Width="16" />
                                        <ColumnDefinition Width="*" />
                                        <ColumnDefinition Width="16" />
                                        <ColumnDefinition Width="120" />
                                    </Grid.ColumnDefinitions>

                                    <StackPanel
                                        Grid.Row="0"
                                        Grid.Column="0"
                                        Margin="0,0,0,14">
                                        <TextBlock Style="{StaticResource FormFieldLabel}" Text="{DynamicResource Categories.Field.Keyword}" />
                                        <TextBox
                                            Style="{StaticResource AppTextBox}"
                                            Text="{Binding AddRuleKeyword, UpdateSourceTrigger=PropertyChanged}"
                                            ToolTip="{DynamicResource Categories.Rule.KeywordHint}" />
                                    </StackPanel>

                                    <StackPanel
                                        Grid.Row="0"
                                        Grid.Column="2"
                                        Margin="0,0,0,14">
                                        <TextBlock Style="{StaticResource FormFieldLabel}" Text="{DynamicResource Categories.Field.Category}" />
                                        <ComboBox
                                            ItemsSource="{Binding AvailableCategories}"
                                            SelectedItem="{Binding AddRuleCategory}"
                                            Style="{StaticResource AppComboBox}"
                                            ToolTip="{DynamicResource Categories.Rule.CategoryHint}">
                                            <ComboBox.ItemTemplate>
                                                <DataTemplate>
                                                    <TextBlock Text="{Binding Name}" />
                                                </DataTemplate>
                                            </ComboBox.ItemTemplate>
                                        </ComboBox>
                                    </StackPanel>

                                    <StackPanel
                                        Grid.Row="0"
                                        Grid.Column="4"
                                        Margin="0,0,0,14">
                                        <TextBlock Style="{StaticResource FormFieldLabel}" Text="{DynamicResource Categories.Field.Priority}" />
                                        <TextBox
                                            Style="{StaticResource AppNumberTextBox}"
                                            Text="{Binding AddRulePriority, UpdateSourceTrigger=PropertyChanged}"
                                            ToolTip="{DynamicResource Categories.Rule.PriorityHint}" />
                                    </StackPanel>

                                    <StackPanel Grid.Row="1" Grid.Column="0">
                                        <TextBlock Style="{StaticResource FormFieldLabel}" Text="{DynamicResource Categories.Field.CaseSensitive}" />
                                        <CheckBox
                                            Content="{DynamicResource Categories.Rule.CaseSensitive}"
                                            Foreground="{DynamicResource AppTextSecondary}"
                                            IsChecked="{Binding AddRuleCaseSensitive}" />
                                    </StackPanel>
                                </Grid>
                            </Border>

                            <Expander
                                Margin="0,12,0,0"
                                Header="{DynamicResource Categories.Rule.Advanced}"
                                Style="{StaticResource AppExpander}">
                                <Border Margin="0,10,0,0" Style="{StaticResource FormSection}">
                                    <StackPanel>
                                        <StackPanel Margin="0,0,0,14">
                                            <TextBlock Style="{StaticResource FormFieldLabel}" Text="{DynamicResource Categories.Rule.Name}" />
                                            <TextBox Style="{StaticResource AppTextBox}" Text="{Binding AddRuleName, UpdateSourceTrigger=PropertyChanged}" />
                                        </StackPanel>

                                        <TextBlock Style="{StaticResource FormFieldLabel}" Text="{DynamicResource Categories.Rule.MatchField}" />
                                        <WrapPanel Margin="0,0,0,14">
                                            <RadioButton
                                                Margin="0,0,12,8"
                                                Content="{DynamicResource Categories.Rule.MatchField.Counterparty}"
                                                GroupName="AddRuleField"
                                                IsChecked="{Binding AddRuleMatchField, Converter={StaticResource EnumToBoolConverter}, ConverterParameter=Counterparty}"
                                                Style="{StaticResource AppRadioButton}" />
                                            <RadioButton
                                                Margin="0,0,12,8"
                                                Content="{DynamicResource Categories.Rule.MatchField.Memo}"
                                                GroupName="AddRuleField"
                                                IsChecked="{Binding AddRuleMatchField, Converter={StaticResource EnumToBoolConverter}, ConverterParameter=Memo}"
                                                Style="{StaticResource AppRadioButton}" />
                                            <RadioButton
                                                Margin="0,0,12,8"
                                                Content="{DynamicResource Categories.Rule.MatchField.Either}"
                                                GroupName="AddRuleField"
                                                IsChecked="{Binding AddRuleMatchField, Converter={StaticResource EnumToBoolConverter}, ConverterParameter=Either}"
                                                Style="{StaticResource AppRadioButton}" />
                                            <RadioButton
                                                Margin="0,0,12,8"
                                                Content="{DynamicResource Categories.Rule.MatchField.AnyText}"
                                                GroupName="AddRuleField"
                                                IsChecked="{Binding AddRuleMatchField, Converter={StaticResource EnumToBoolConverter}, ConverterParameter=AnyText}"
                                                Style="{StaticResource AppRadioButton}" />
                                        </WrapPanel>

                                        <TextBlock Style="{StaticResource FormFieldLabel}" Text="{DynamicResource Categories.Rule.MatchType}" />
                                        <WrapPanel Margin="0,0,0,14">
                                            <RadioButton
                                                Margin="0,0,12,8"
                                                Content="{DynamicResource Categories.Rule.MatchType.Contains}"
                                                GroupName="AddRuleType"
                                                IsChecked="{Binding AddRuleMatchType, Converter={StaticResource EnumToBoolConverter}, ConverterParameter=Contains}"
                                                Style="{StaticResource AppRadioButton}" />
                                            <RadioButton
                                                Margin="0,0,12,8"
                                                Content="{DynamicResource Categories.Rule.MatchType.Equals}"
                                                GroupName="AddRuleType"
                                                IsChecked="{Binding AddRuleMatchType, Converter={StaticResource EnumToBoolConverter}, ConverterParameter=Equals}"
                                                Style="{StaticResource AppRadioButton}" />
                                            <RadioButton
                                                Margin="0,0,12,8"
                                                Content="{DynamicResource Categories.Rule.MatchType.StartsWith}"
                                                GroupName="AddRuleType"
                                                IsChecked="{Binding AddRuleMatchType, Converter={StaticResource EnumToBoolConverter}, ConverterParameter=StartsWith}"
                                                Style="{StaticResource AppRadioButton}" />
                                            <RadioButton
                                                Margin="0,0,12,8"
                                                Content="{DynamicResource Categories.Rule.MatchType.Regex}"
                                                GroupName="AddRuleType"
                                                IsChecked="{Binding AddRuleMatchType, Converter={StaticResource EnumToBoolConverter}, ConverterParameter=Regex}"
                                                Style="{StaticResource AppRadioButton}" />
                                        </WrapPanel>

                                        <TextBlock Style="{StaticResource FormFieldLabel}" Text="{DynamicResource Categories.Rule.AppliesTo}" />
                                        <StackPanel Orientation="Horizontal">
                                            <CheckBox
                                                Margin="0,0,12,0"
                                                Content="{DynamicResource Categories.Rule.AppliesTo.Manual}"
                                                IsChecked="{Binding AddRuleAppliesToManual}" />
                                            <CheckBox Content="{DynamicResource Categories.Rule.AppliesTo.Import}" IsChecked="{Binding AddRuleAppliesToImport}" />
                                        </StackPanel>
                                    </StackPanel>
                                </Border>
                            </Expander>
                        </StackPanel>
                    </ScrollViewer>

                    <TextBlock
                        Grid.Row="2"
                        Margin="24,10,24,0"
                        Style="{StaticResource FormFieldError}"
                        Text="{Binding AddRuleError}"
                        Visibility="{Binding AddRuleError, Converter={StaticResource StringToVisibilityConverter}}" />

                    <StackPanel Grid.Row="3" Style="{StaticResource AppDialogFooter}">
                        <Button
                            Margin="0,0,8,0"
                            Command="{Binding CloseAddRuleCommand}"
                            Content="{DynamicResource Common.Cancel}"
                            Style="{StaticResource AppSecondaryButton}" />
                        <Button
                            Command="{Binding AddRuleCommand}"
                            Content="{DynamicResource Categories.Rule.Add}"
                            Style="{StaticResource AppPrimaryButton}" />
                    </StackPanel>
                </Grid>
            </Border>
        </Grid>

        <!--  分類 — 新增預算  -->
        <Grid Style="{StaticResource AppDialogOverlay}" Visibility="{Binding IsAddBudgetOpen, Converter={StaticResource BooleanToVisibilityConverter}}">
            <Border
                Width="720"
                MaxWidth="780"
                MaxHeight="620"
                HorizontalAlignment="Center"
                VerticalAlignment="Center"
                behaviors:EscapeKeyCommandBehavior.Command="{Binding CloseAddBudgetCommand}"
                SnapsToDevicePixels="True"
                Style="{StaticResource AppDialogShell}">
                <Grid>
                    <Grid.RowDefinitions>
                        <RowDefinition Height="Auto" />
                        <RowDefinition Height="Auto" />
                        <RowDefinition Height="Auto" />
                        <RowDefinition Height="Auto" />
                    </Grid.RowDefinitions>

                    <Grid Margin="0,0,0,16">
                        <StackPanel Margin="0,4,40,0">
                            <TextBlock Style="{StaticResource AppDialogTitle}" Text="{DynamicResource Categories.Budget.AddForm.Title}" />
                            <TextBlock
                                Style="{StaticResource AppDialogSubtitle}"
                                Text="{DynamicResource Categories.Budget.AddForm.Hint}"
                                TextWrapping="Wrap" />
                        </StackPanel>
                        <Button
                            Width="32"
                            Height="32"
                            Margin="0,-4,-4,0"
                            Padding="0"
                            HorizontalAlignment="Right"
                            VerticalAlignment="Top"
                            Command="{Binding CloseAddBudgetCommand}"
                            Style="{StaticResource AppIconButton}"
                            ToolTip="{DynamicResource Common.Close}">
                            <ds:AppIcon FontSize="13" Symbol="Dismiss24" />
                        </Button>
                    </Grid>

                    <Border Grid.Row="1" Style="{StaticResource FormSection}">
                        <Grid>
                            <Grid.RowDefinitions>
                                <RowDefinition Height="Auto" />
                                <RowDefinition Height="Auto" />
                                <RowDefinition Height="Auto" />
                            </Grid.RowDefinitions>
                            <Grid.ColumnDefinitions>
                                <ColumnDefinition Width="*" />
                                <ColumnDefinition Width="16" />
                                <ColumnDefinition Width="*" />
                                <ColumnDefinition Width="16" />
                                <ColumnDefinition Width="*" />
                            </Grid.ColumnDefinitions>

                            <StackPanel
                                Grid.Row="0"
                                Grid.Column="0"
                                Margin="0,0,0,14">
                                <TextBlock Style="{StaticResource FormFieldLabel}" Text="{DynamicResource Categories.Field.BudgetMode}" />
                                <ComboBox
                                    ItemsSource="{Binding BudgetModeOptions}"
                                    SelectedItem="{Binding AddBudgetMode}"
                                    Style="{StaticResource AppComboBox}">
                                    <ComboBox.ItemTemplate>
                                        <DataTemplate>
                                            <TextBlock>
                                                <TextBlock.Style>
                                                    <Style TargetType="TextBlock">
                                                        <Setter Property="Text" Value="{DynamicResource Categories.Budget.Mode.Monthly}" />
                                                        <Style.Triggers>
                                                            <DataTrigger Binding="{Binding}" Value="Yearly">
                                                                <Setter Property="Text" Value="{DynamicResource Categories.Budget.Mode.Yearly}" />
                                                            </DataTrigger>
                                                        </Style.Triggers>
                                                    </Style>
                                                </TextBlock.Style>
                                            </TextBlock>
                                        </DataTemplate>
                                    </ComboBox.ItemTemplate>
                                </ComboBox>
                            </StackPanel>

                            <StackPanel
                                Grid.Row="0"
                                Grid.Column="2"
                                Margin="0,0,0,14">
                                <TextBlock Style="{StaticResource FormFieldLabel}" Text="{DynamicResource Categories.Field.Year}" />
                                <TextBox
                                    Style="{StaticResource AppNumberTextBox}"
                                    Text="{Binding AddBudgetYear, UpdateSourceTrigger=PropertyChanged}"
                                    ToolTip="{DynamicResource Categories.Budget.YearHint}" />
                            </StackPanel>

                            <StackPanel
                                Grid.Row="0"
                                Grid.Column="4"
                                Margin="0,0,0,14">
                                <TextBlock Style="{StaticResource FormFieldLabel}" Text="{DynamicResource Categories.Field.Month}" />
                                <TextBox
                                    Style="{StaticResource AppNumberTextBox}"
                                    Text="{Binding AddBudgetMonth, UpdateSourceTrigger=PropertyChanged}"
                                    ToolTip="{DynamicResource Categories.Budget.MonthHint}" />
                            </StackPanel>

                            <StackPanel
                                Grid.Row="1"
                                Grid.Column="0"
                                Grid.ColumnSpan="3"
                                Margin="0,0,0,14">
                                <TextBlock Style="{StaticResource FormFieldLabel}" Text="{DynamicResource Categories.Field.Category}" />
                                <ComboBox
                                    ItemsSource="{Binding AvailableCategories}"
                                    SelectedItem="{Binding AddBudgetCategory}"
                                    Style="{StaticResource AppComboBox}"
                                    ToolTip="{DynamicResource Categories.Budget.CategoryHint}">
                                    <ComboBox.ItemTemplate>
                                        <DataTemplate>
                                            <TextBlock Text="{Binding Name}" />
                                        </DataTemplate>
                                    </ComboBox.ItemTemplate>
                                </ComboBox>
                            </StackPanel>

                            <StackPanel
                                Grid.Row="1"
                                Grid.Column="4"
                                Margin="0,0,0,14">
                                <TextBlock Style="{StaticResource FormFieldLabel}" Text="{DynamicResource Categories.Field.Amount}" />
                                <TextBox
                                    Style="{StaticResource AppMoneyTextBox}"
                                    Text="{Binding AddBudgetAmount, UpdateSourceTrigger=PropertyChanged}"
                                    ToolTip="{DynamicResource Categories.Budget.AmountHint}" />
                            </StackPanel>

                            <StackPanel
                                Grid.Row="2"
                                Grid.Column="0"
                                Grid.ColumnSpan="5">
                                <TextBlock Style="{StaticResource FormFieldLabel}" Text="{DynamicResource Categories.Field.Note}" />
                                <TextBox
                                    Style="{StaticResource AppTextBox}"
                                    Text="{Binding AddBudgetNote, UpdateSourceTrigger=PropertyChanged}"
                                    ToolTip="{DynamicResource Categories.Budget.NoteHint}" />
                            </StackPanel>
                        </Grid>
                    </Border>

                    <TextBlock
                        Grid.Row="2"
                        Margin="24,10,24,0"
                        Style="{StaticResource FormFieldError}"
                        Text="{Binding AddBudgetError}"
                        Visibility="{Binding AddBudgetError, Converter={StaticResource StringToVisibilityConverter}}" />

                    <StackPanel Grid.Row="3" Style="{StaticResource AppDialogFooter}">
                        <Button
                            Margin="0,0,8,0"
                            Command="{Binding CloseAddBudgetCommand}"
                            Content="{DynamicResource Common.Cancel}"
                            Style="{StaticResource AppSecondaryButton}" />
                        <Button
                            Command="{Binding AddBudgetCommand}"
                            Content="{DynamicResource Categories.Budget.Add}"
                            Style="{StaticResource AppPrimaryButton}" />
                    </StackPanel>
                </Grid>
            </Border>
        </Grid>

        <!--  分類 — 刪除確認  -->
        <Grid Style="{StaticResource AppDialogOverlay}" Visibility="{Binding IsDeleteConfirmOpen, Converter={StaticResource BooleanToVisibilityConverter}}">
            <Border
                HorizontalAlignment="Center"
                VerticalAlignment="Center"
                behaviors:EscapeKeyCommandBehavior.Command="{Binding CancelDeleteCommand}"
                Style="{StaticResource AppDestructiveDialogShell}">
                <Grid>
                    <Grid.RowDefinitions>
                        <RowDefinition Height="Auto" />
                        <RowDefinition Height="Auto" />
                        <RowDefinition Height="Auto" />
                    </Grid.RowDefinitions>

                    <TextBlock Style="{StaticResource AppDialogTitle}" Text="{DynamicResource Common.DeleteConfirmTitle}" />
                    <TextBlock Grid.Row="1" Style="{StaticResource AppDialogSubtitle}">
                        <Run Text="{DynamicResource Common.DeleteConfirmPrefix}" />
                        <Run Text="{Binding DeleteTargetName}" />
                        <Run Text="{DynamicResource Common.DeleteConfirmSuffix}" />
                    </TextBlock>

                    <StackPanel Grid.Row="2" Style="{StaticResource AppDialogFooter}">
                        <Button
                            Margin="0,0,8,0"
                            Command="{Binding CancelDeleteCommand}"
                            Content="{DynamicResource Common.Cancel}"
                            Style="{StaticResource AppSecondaryButton}" />
                        <Button
                            Command="{Binding ConfirmDeleteCommand}"
                            Content="{DynamicResource Common.Delete}"
                            Style="{StaticResource AppDangerButton}" />
                    </StackPanel>
                </Grid>
            </Border>
        </Grid>
    </Grid>
</UserControl>
