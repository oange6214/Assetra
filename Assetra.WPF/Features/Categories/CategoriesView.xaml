<UserControl
    x:Name="Root"
    x:Class="Assetra.WPF.Features.Categories.CategoriesView"
    xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
    xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
    xmlns:d="http://schemas.microsoft.com/expression/blend/2008"
    xmlns:mc="http://schemas.openxmlformats.org/markup-compatibility/2006"
    xmlns:vm="clr-namespace:Assetra.WPF.Features.Categories"
    d:DataContext="{d:DesignInstance Type={x:Type vm:CategoriesViewModel},
                                     IsDesignTimeCreatable=False}"
    d:DesignHeight="776"
    d:DesignWidth="1100"
    Background="{DynamicResource AppBackground}"
    mc:Ignorable="d">

  <UserControl.Resources>
    <DataTemplate x:Key="CategoryRowTemplate" DataType="{x:Type vm:CategoryRowViewModel}">
      <Border
          Margin="0,0,0,6"
          Padding="10,8"
          Background="{DynamicResource AppSurface}"
          BorderBrush="{DynamicResource AppBorder}"
          BorderThickness="1"
          CornerRadius="{StaticResource RadiusSm}">
        <Grid>
          <Grid.ColumnDefinitions>
            <ColumnDefinition Width="*" />
            <ColumnDefinition Width="Auto" />
          </Grid.ColumnDefinitions>

          <!--  View mode  -->
          <StackPanel Grid.Column="0" Orientation="Horizontal" VerticalAlignment="Center">
            <StackPanel.Style>
              <Style TargetType="StackPanel">
                <Setter Property="Visibility" Value="Visible" />
                <Style.Triggers>
                  <DataTrigger Binding="{Binding IsEditing}" Value="True">
                    <Setter Property="Visibility" Value="Collapsed" />
                  </DataTrigger>
                </Style.Triggers>
              </Style>
            </StackPanel.Style>
            <TextBlock
                Margin="0,0,8,0"
                VerticalAlignment="Center"
                FontSize="{StaticResource FontSizeMd}"
                Text="{Binding Icon}" />
            <TextBlock
                VerticalAlignment="Center"
                FontSize="{StaticResource FontSizeBase}"
                FontWeight="SemiBold"
                Foreground="{DynamicResource AppTextPrimary}"
                Text="{Binding Name}" />
            <TextBlock
                Margin="8,0,0,0"
                VerticalAlignment="Center"
                FontSize="{StaticResource FontSizeXs}"
                Foreground="{DynamicResource AppTextMuted}"
                Text="{DynamicResource Categories.ArchivedTag}"
                Visibility="{Binding IsArchived, Converter={StaticResource BooleanToVisibilityConverter}}" />
          </StackPanel>

          <!--  Edit mode  -->
          <StackPanel Grid.Column="0" Orientation="Vertical">
            <StackPanel.Style>
              <Style TargetType="StackPanel">
                <Setter Property="Visibility" Value="Collapsed" />
                <Style.Triggers>
                  <DataTrigger Binding="{Binding IsEditing}" Value="True">
                    <Setter Property="Visibility" Value="Visible" />
                  </DataTrigger>
                </Style.Triggers>
              </Style>
            </StackPanel.Style>
            <Grid>
              <Grid.ColumnDefinitions>
                <ColumnDefinition Width="60" />
                <ColumnDefinition Width="6" />
                <ColumnDefinition Width="*" />
                <ColumnDefinition Width="6" />
                <ColumnDefinition Width="100" />
              </Grid.ColumnDefinitions>
              <TextBox
                  Grid.Column="0"
                  Style="{StaticResource FormTextBox}"
                  Text="{Binding EditIcon, UpdateSourceTrigger=PropertyChanged}" />
              <TextBox
                  Grid.Column="2"
                  Style="{StaticResource FormTextBox}"
                  Text="{Binding EditName, UpdateSourceTrigger=PropertyChanged}" />
              <TextBox
                  Grid.Column="4"
                  Style="{StaticResource FormTextBox}"
                  Text="{Binding EditColorHex, UpdateSourceTrigger=PropertyChanged}" />
            </Grid>
            <TextBlock
                Margin="0,4,0,0"
                FontSize="{StaticResource FontSizeXs}"
                Foreground="{DynamicResource AppDown}"
                Text="{Binding EditError}"
                Visibility="{Binding EditError, Converter={StaticResource StringToVisibilityConverter}}" />
          </StackPanel>

          <!--  Buttons  -->
          <StackPanel Grid.Column="1" Orientation="Horizontal" VerticalAlignment="Center">
            <!--  View mode buttons  -->
            <Button
                Width="28" Height="28" Margin="0,0,4,0"
                Command="{Binding DataContext.BeginEditCommand, RelativeSource={RelativeSource AncestorType=UserControl}}"
                CommandParameter="{Binding}"
                ToolTip="{DynamicResource Alerts.Edit}">
              <Button.Style>
                <Style BasedOn="{StaticResource BtnIcon}" TargetType="Button">
                  <Setter Property="Visibility" Value="Visible" />
                  <Style.Triggers>
                    <DataTrigger Binding="{Binding IsEditing}" Value="True">
                      <Setter Property="Visibility" Value="Collapsed" />
                    </DataTrigger>
                  </Style.Triggers>
                </Style>
              </Button.Style>
              <TextBlock FontFamily="Segoe MDL2 Assets" FontSize="{StaticResource FontSizeXs}"
                         Foreground="{DynamicResource AppTextPrimary}" Text="&#xE70F;" />
            </Button>

            <Button
                Width="28" Height="28" Margin="0,0,4,0"
                Command="{Binding DataContext.ToggleArchiveCommand, RelativeSource={RelativeSource AncestorType=UserControl}}"
                CommandParameter="{Binding}"
                ToolTip="{DynamicResource Categories.ToggleArchive}">
              <Button.Style>
                <Style BasedOn="{StaticResource BtnIcon}" TargetType="Button">
                  <Setter Property="Visibility" Value="Visible" />
                  <Style.Triggers>
                    <DataTrigger Binding="{Binding IsEditing}" Value="True">
                      <Setter Property="Visibility" Value="Collapsed" />
                    </DataTrigger>
                  </Style.Triggers>
                </Style>
              </Button.Style>
              <TextBlock FontFamily="Segoe MDL2 Assets" FontSize="{StaticResource FontSizeXs}"
                         Foreground="{DynamicResource AppTextSecondary}" Text="&#xE7B8;" />
            </Button>

            <Button
                Width="28" Height="28"
                Command="{Binding DataContext.DeleteCommand, RelativeSource={RelativeSource AncestorType=UserControl}}"
                CommandParameter="{Binding}"
                ToolTip="{DynamicResource Alerts.Delete}">
              <Button.Style>
                <Style BasedOn="{StaticResource DataGridDeleteBtn}" TargetType="Button">
                  <Setter Property="Visibility" Value="Visible" />
                  <Style.Triggers>
                    <DataTrigger Binding="{Binding IsEditing}" Value="True">
                      <Setter Property="Visibility" Value="Collapsed" />
                    </DataTrigger>
                  </Style.Triggers>
                </Style>
              </Button.Style>
              <TextBlock FontFamily="Segoe MDL2 Assets" FontSize="{StaticResource FontSizeXs}" Text="&#xE74D;" />
            </Button>

            <!--  Edit mode buttons  -->
            <Button
                Width="28" Height="28" Margin="0,0,4,0"
                Command="{Binding DataContext.SaveEditCommand, RelativeSource={RelativeSource AncestorType=UserControl}}"
                CommandParameter="{Binding}"
                ToolTip="{DynamicResource Alerts.Save}">
              <Button.Style>
                <Style BasedOn="{StaticResource BtnIcon}" TargetType="Button">
                  <Setter Property="Visibility" Value="Collapsed" />
                  <Style.Triggers>
                    <DataTrigger Binding="{Binding IsEditing}" Value="True">
                      <Setter Property="Visibility" Value="Visible" />
                    </DataTrigger>
                  </Style.Triggers>
                </Style>
              </Button.Style>
              <TextBlock FontFamily="Segoe MDL2 Assets" FontSize="{StaticResource FontSizeSm}"
                         Foreground="{DynamicResource AppUp}" Text="&#xE73E;" />
            </Button>

            <Button
                Width="28" Height="28"
                Command="{Binding DataContext.CancelEditCommand, RelativeSource={RelativeSource AncestorType=UserControl}}"
                CommandParameter="{Binding}"
                ToolTip="{DynamicResource Alerts.Cancel}">
              <Button.Style>
                <Style BasedOn="{StaticResource BtnIcon}" TargetType="Button">
                  <Setter Property="Visibility" Value="Collapsed" />
                  <Style.Triggers>
                    <DataTrigger Binding="{Binding IsEditing}" Value="True">
                      <Setter Property="Visibility" Value="Visible" />
                    </DataTrigger>
                  </Style.Triggers>
                </Style>
              </Button.Style>
              <TextBlock FontFamily="Segoe MDL2 Assets" FontSize="{StaticResource FontSizeXs}"
                         Foreground="{DynamicResource AppTextSecondary}" Text="&#xE711;" />
            </Button>
          </StackPanel>
        </Grid>
      </Border>
    </DataTemplate>
  </UserControl.Resources>

  <Grid Margin="24">
    <Grid.RowDefinitions>
      <RowDefinition Height="Auto" />
      <RowDefinition Height="*" />
    </Grid.RowDefinitions>

    <!--  Header  -->
    <DockPanel Grid.Row="0" LastChildFill="False" Margin="0,0,0,16">
      <TextBlock
          DockPanel.Dock="Left"
          VerticalAlignment="Center"
          FontSize="{StaticResource FontSizeXl}"
          FontWeight="SemiBold"
          Foreground="{DynamicResource AppTextPrimary}"
          Text="{DynamicResource Categories.Title}" />
      <CheckBox
          DockPanel.Dock="Right"
          VerticalAlignment="Center"
          Content="{DynamicResource Categories.ShowArchived}"
          Foreground="{DynamicResource AppTextSecondary}"
          IsChecked="{Binding ShowArchived}" />
    </DockPanel>

    <TabControl Grid.Row="1" Background="Transparent" BorderThickness="0">
    <TabItem Header="{DynamicResource Categories.Tab.Categories}">
     <Grid Margin="0,12,0,0">
    <Grid.RowDefinitions>
      <RowDefinition Height="*" />
      <RowDefinition Height="Auto" />
    </Grid.RowDefinitions>

    <!--  Two-column list  -->
    <Grid Grid.Row="0">
      <Grid.ColumnDefinitions>
        <ColumnDefinition Width="*" />
        <ColumnDefinition Width="16" />
        <ColumnDefinition Width="*" />
      </Grid.ColumnDefinitions>

      <!--  Expense  -->
      <Border
          Grid.Column="0"
          Padding="12"
          Background="{DynamicResource AppSurface}"
          BorderBrush="{DynamicResource AppBorder}"
          BorderThickness="1"
          CornerRadius="{StaticResource RadiusMd}">
        <Grid>
          <Grid.RowDefinitions>
            <RowDefinition Height="Auto" />
            <RowDefinition Height="*" />
          </Grid.RowDefinitions>
          <TextBlock
              Grid.Row="0"
              Margin="0,0,0,8"
              FontSize="{StaticResource FontSizeMd}"
              FontWeight="SemiBold"
              Foreground="{DynamicResource AppTextPrimary}"
              Text="{DynamicResource Categories.Expense}" />
          <ScrollViewer Grid.Row="1" VerticalScrollBarVisibility="Auto">
            <ItemsControl ItemsSource="{Binding ExpenseView}" ItemTemplate="{StaticResource CategoryRowTemplate}" />
          </ScrollViewer>
        </Grid>
      </Border>

      <!--  Income  -->
      <Border
          Grid.Column="2"
          Padding="12"
          Background="{DynamicResource AppSurface}"
          BorderBrush="{DynamicResource AppBorder}"
          BorderThickness="1"
          CornerRadius="{StaticResource RadiusMd}">
        <Grid>
          <Grid.RowDefinitions>
            <RowDefinition Height="Auto" />
            <RowDefinition Height="*" />
          </Grid.RowDefinitions>
          <TextBlock
              Grid.Row="0"
              Margin="0,0,0,8"
              FontSize="{StaticResource FontSizeMd}"
              FontWeight="SemiBold"
              Foreground="{DynamicResource AppTextPrimary}"
              Text="{DynamicResource Categories.Income}" />
          <ScrollViewer Grid.Row="1" VerticalScrollBarVisibility="Auto">
            <ItemsControl ItemsSource="{Binding IncomeView}" ItemTemplate="{StaticResource CategoryRowTemplate}" />
          </ScrollViewer>
        </Grid>
      </Border>
    </Grid>

    <!--  Add form  -->
    <Border
        Grid.Row="1"
        Margin="0,12,0,0"
        Padding="14,12"
        Background="{DynamicResource AppSurface}"
        BorderBrush="{DynamicResource AppBorder}"
        BorderThickness="1"
        CornerRadius="{StaticResource RadiusMd}">
      <Grid>
        <Grid.RowDefinitions>
          <RowDefinition Height="Auto" />
          <RowDefinition Height="Auto" />
        </Grid.RowDefinitions>
        <Grid Grid.Row="0">
          <Grid.ColumnDefinitions>
            <ColumnDefinition Width="120" />
            <ColumnDefinition Width="8" />
            <ColumnDefinition Width="60" />
            <ColumnDefinition Width="8" />
            <ColumnDefinition Width="*" />
            <ColumnDefinition Width="8" />
            <ColumnDefinition Width="100" />
            <ColumnDefinition Width="8" />
            <ColumnDefinition Width="Auto" />
          </Grid.ColumnDefinitions>

          <ComboBox
              Grid.Column="0"
              ItemsSource="{Binding KindOptions}"
              SelectedItem="{Binding AddKind}"
              Style="{StaticResource FormComboBox}">
            <ComboBox.ItemTemplate>
              <DataTemplate>
                <TextBlock>
                  <TextBlock.Style>
                    <Style TargetType="TextBlock">
                      <Setter Property="Text" Value="{DynamicResource Categories.Expense}" />
                      <Style.Triggers>
                        <DataTrigger Binding="{Binding}" Value="Income">
                          <Setter Property="Text" Value="{DynamicResource Categories.Income}" />
                        </DataTrigger>
                      </Style.Triggers>
                    </Style>
                  </TextBlock.Style>
                </TextBlock>
              </DataTemplate>
            </ComboBox.ItemTemplate>
          </ComboBox>

          <TextBox
              Grid.Column="2"
              Style="{StaticResource FormTextBox}"
              Text="{Binding AddIcon, UpdateSourceTrigger=PropertyChanged}"
              ToolTip="{DynamicResource Categories.IconHint}" />

          <TextBox
              Grid.Column="4"
              Style="{StaticResource FormTextBox}"
              Text="{Binding AddName, UpdateSourceTrigger=PropertyChanged}"
              ToolTip="{DynamicResource Categories.NameHint}" />

          <TextBox
              Grid.Column="6"
              Style="{StaticResource FormTextBox}"
              Text="{Binding AddColorHex, UpdateSourceTrigger=PropertyChanged}"
              ToolTip="{DynamicResource Categories.ColorHint}" />

          <Button
              Grid.Column="8"
              MinWidth="120"
              MinHeight="36"
              Padding="16,0"
              Command="{Binding AddCategoryCommand}"
              Style="{StaticResource BtnPrimary}">
            <TextBlock Foreground="{Binding Foreground, RelativeSource={RelativeSource AncestorType=Button}}"
                       Text="{DynamicResource Categories.Add}" />
          </Button>
        </Grid>
        <TextBlock
            Grid.Row="1"
            Margin="0,8,0,0"
            FontSize="{StaticResource FontSizeXs}"
            Foreground="{DynamicResource AppDown}"
            Text="{Binding AddError}"
            Visibility="{Binding AddError, Converter={StaticResource StringToVisibilityConverter}}" />
      </Grid>
    </Border>
     </Grid>
    </TabItem>

    <TabItem Header="{DynamicResource Categories.Tab.Rules}">
      <Grid Margin="0,12,0,0">
        <Grid.RowDefinitions>
          <RowDefinition Height="Auto" />
          <RowDefinition Height="*" />
          <RowDefinition Height="Auto" />
        </Grid.RowDefinitions>

        <TextBlock
            Grid.Row="0"
            Margin="0,0,0,12"
            FontSize="{StaticResource FontSizeBase}"
            Foreground="{DynamicResource AppTextSecondary}"
            Text="{DynamicResource Categories.Rule.Hint}"
            TextWrapping="Wrap" />

        <Border
            Grid.Row="1"
            Padding="12"
            Background="{DynamicResource AppSurface}"
            BorderBrush="{DynamicResource AppBorder}"
            BorderThickness="1"
            CornerRadius="{StaticResource RadiusMd}">
          <ScrollViewer VerticalScrollBarVisibility="Auto">
            <ItemsControl ItemsSource="{Binding Rules}">
              <ItemsControl.ItemTemplate>
                <DataTemplate>
                  <Border
                      Margin="0,0,0,6"
                      Padding="10,8"
                      Background="{DynamicResource AppBackground}"
                      BorderBrush="{DynamicResource AppBorder}"
                      BorderThickness="1"
                      CornerRadius="{StaticResource RadiusSm}">
                    <Grid>
                      <Grid.ColumnDefinitions>
                        <ColumnDefinition Width="Auto" />
                        <ColumnDefinition Width="*" />
                        <ColumnDefinition Width="Auto" />
                      </Grid.ColumnDefinitions>

                      <CheckBox
                          Grid.Column="0"
                          Margin="0,0,10,0"
                          VerticalAlignment="Center"
                          Command="{Binding DataContext.ToggleRuleEnabledCommand, RelativeSource={RelativeSource AncestorType=UserControl}}"
                          CommandParameter="{Binding}"
                          IsChecked="{Binding IsEnabled, Mode=OneWay}"
                          ToolTip="{DynamicResource Categories.Rule.ToggleEnabled}" />

                      <!--  View mode  -->
                      <StackPanel Grid.Column="1" Orientation="Horizontal" VerticalAlignment="Center">
                        <StackPanel.Style>
                          <Style TargetType="StackPanel">
                            <Setter Property="Visibility" Value="Visible" />
                            <Style.Triggers>
                              <DataTrigger Binding="{Binding IsEditing}" Value="True">
                                <Setter Property="Visibility" Value="Collapsed" />
                              </DataTrigger>
                            </Style.Triggers>
                          </Style>
                        </StackPanel.Style>
                        <TextBlock
                            VerticalAlignment="Center"
                            FontFamily="{StaticResource FontTabular}"
                            FontSize="{StaticResource FontSizeBase}"
                            FontWeight="SemiBold"
                            Foreground="{DynamicResource AppTextPrimary}"
                            Text="{Binding KeywordPattern}" />
                        <TextBlock
                            Margin="10,0,0,0"
                            VerticalAlignment="Center"
                            FontSize="{StaticResource FontSizeXs}"
                            Foreground="{DynamicResource AppTextMuted}"
                            Text="→" />
                        <TextBlock
                            Margin="6,0,0,0"
                            VerticalAlignment="Center"
                            FontSize="{StaticResource FontSizeSm}"
                            Foreground="{DynamicResource AppTextSecondary}"
                            Text="{Binding CategoryDisplay}" />
                        <TextBlock
                            Margin="10,0,0,0"
                            VerticalAlignment="Center"
                            FontSize="{StaticResource FontSizeXs}"
                            Foreground="{DynamicResource AppTextMuted}"
                            Text="{Binding Priority, StringFormat={}P:{0}}" />
                      </StackPanel>

                      <!--  Edit mode  -->
                      <Grid Grid.Column="1">
                        <Grid.Style>
                          <Style TargetType="Grid">
                            <Setter Property="Visibility" Value="Collapsed" />
                            <Style.Triggers>
                              <DataTrigger Binding="{Binding IsEditing}" Value="True">
                                <Setter Property="Visibility" Value="Visible" />
                              </DataTrigger>
                            </Style.Triggers>
                          </Style>
                        </Grid.Style>
                        <Grid.ColumnDefinitions>
                          <ColumnDefinition Width="*" />
                          <ColumnDefinition Width="6" />
                          <ColumnDefinition Width="160" />
                          <ColumnDefinition Width="6" />
                          <ColumnDefinition Width="60" />
                          <ColumnDefinition Width="6" />
                          <ColumnDefinition Width="Auto" />
                        </Grid.ColumnDefinitions>
                        <TextBox
                            Grid.Column="0"
                            Style="{StaticResource FormTextBox}"
                            Text="{Binding EditKeyword, UpdateSourceTrigger=PropertyChanged}" />
                        <ComboBox
                            Grid.Column="2"
                            DisplayMemberPath="Name"
                            ItemsSource="{Binding DataContext.AvailableCategories, RelativeSource={RelativeSource AncestorType=UserControl}}"
                            SelectedValuePath="Id"
                            SelectedValue="{Binding EditCategoryId}"
                            Style="{StaticResource FormComboBox}" />
                        <TextBox
                            Grid.Column="4"
                            Style="{StaticResource FormTextBox}"
                            Text="{Binding EditPriority, UpdateSourceTrigger=PropertyChanged}" />
                        <CheckBox
                            Grid.Column="6"
                            VerticalAlignment="Center"
                            Content="{DynamicResource Categories.Rule.CaseSensitive}"
                            Foreground="{DynamicResource AppTextSecondary}"
                            IsChecked="{Binding EditCaseSensitive}" />
                      </Grid>

                      <!--  Buttons  -->
                      <StackPanel Grid.Column="2" Orientation="Horizontal" VerticalAlignment="Center">
                        <Button
                            Width="28" Height="28" Margin="0,0,4,0"
                            Command="{Binding DataContext.BeginEditRuleCommand, RelativeSource={RelativeSource AncestorType=UserControl}}"
                            CommandParameter="{Binding}"
                            ToolTip="{DynamicResource Alerts.Edit}">
                          <Button.Style>
                            <Style BasedOn="{StaticResource BtnIcon}" TargetType="Button">
                              <Setter Property="Visibility" Value="Visible" />
                              <Style.Triggers>
                                <DataTrigger Binding="{Binding IsEditing}" Value="True">
                                  <Setter Property="Visibility" Value="Collapsed" />
                                </DataTrigger>
                              </Style.Triggers>
                            </Style>
                          </Button.Style>
                          <TextBlock FontFamily="Segoe MDL2 Assets" FontSize="{StaticResource FontSizeXs}"
                                     Foreground="{DynamicResource AppTextPrimary}" Text="&#xE70F;" />
                        </Button>

                        <Button
                            Width="28" Height="28"
                            Command="{Binding DataContext.DeleteRuleCommand, RelativeSource={RelativeSource AncestorType=UserControl}}"
                            CommandParameter="{Binding}"
                            ToolTip="{DynamicResource Alerts.Delete}">
                          <Button.Style>
                            <Style BasedOn="{StaticResource DataGridDeleteBtn}" TargetType="Button">
                              <Setter Property="Visibility" Value="Visible" />
                              <Style.Triggers>
                                <DataTrigger Binding="{Binding IsEditing}" Value="True">
                                  <Setter Property="Visibility" Value="Collapsed" />
                                </DataTrigger>
                              </Style.Triggers>
                            </Style>
                          </Button.Style>
                          <TextBlock FontFamily="Segoe MDL2 Assets" FontSize="{StaticResource FontSizeXs}" Text="&#xE74D;" />
                        </Button>

                        <Button
                            Width="28" Height="28" Margin="0,0,4,0"
                            Command="{Binding DataContext.SaveEditRuleCommand, RelativeSource={RelativeSource AncestorType=UserControl}}"
                            CommandParameter="{Binding}"
                            ToolTip="{DynamicResource Alerts.Save}">
                          <Button.Style>
                            <Style BasedOn="{StaticResource BtnIcon}" TargetType="Button">
                              <Setter Property="Visibility" Value="Collapsed" />
                              <Style.Triggers>
                                <DataTrigger Binding="{Binding IsEditing}" Value="True">
                                  <Setter Property="Visibility" Value="Visible" />
                                </DataTrigger>
                              </Style.Triggers>
                            </Style>
                          </Button.Style>
                          <TextBlock FontFamily="Segoe MDL2 Assets" FontSize="{StaticResource FontSizeSm}"
                                     Foreground="{DynamicResource AppUp}" Text="&#xE73E;" />
                        </Button>

                        <Button
                            Width="28" Height="28"
                            Command="{Binding DataContext.CancelEditRuleCommand, RelativeSource={RelativeSource AncestorType=UserControl}}"
                            CommandParameter="{Binding}"
                            ToolTip="{DynamicResource Alerts.Cancel}">
                          <Button.Style>
                            <Style BasedOn="{StaticResource BtnIcon}" TargetType="Button">
                              <Setter Property="Visibility" Value="Collapsed" />
                              <Style.Triggers>
                                <DataTrigger Binding="{Binding IsEditing}" Value="True">
                                  <Setter Property="Visibility" Value="Visible" />
                                </DataTrigger>
                              </Style.Triggers>
                            </Style>
                          </Button.Style>
                          <TextBlock FontFamily="Segoe MDL2 Assets" FontSize="{StaticResource FontSizeXs}"
                                     Foreground="{DynamicResource AppTextSecondary}" Text="&#xE711;" />
                        </Button>
                      </StackPanel>

                      <TextBlock
                          Grid.Row="1"
                          Grid.Column="1"
                          Margin="0,4,0,0"
                          FontSize="{StaticResource FontSizeXs}"
                          Foreground="{DynamicResource AppDown}"
                          Text="{Binding EditError}"
                          Visibility="{Binding EditError, Converter={StaticResource StringToVisibilityConverter}}" />
                    </Grid>
                  </Border>
                </DataTemplate>
              </ItemsControl.ItemTemplate>
            </ItemsControl>
          </ScrollViewer>
        </Border>

        <!--  Add rule form  -->
        <Border
            Grid.Row="2"
            Margin="0,12,0,0"
            Padding="14,12"
            Background="{DynamicResource AppSurface}"
            BorderBrush="{DynamicResource AppBorder}"
            BorderThickness="1"
            CornerRadius="{StaticResource RadiusMd}">
          <Grid>
            <Grid.RowDefinitions>
              <RowDefinition Height="Auto" />
              <RowDefinition Height="Auto" />
            </Grid.RowDefinitions>
            <Grid Grid.Row="0">
              <Grid.ColumnDefinitions>
                <ColumnDefinition Width="*" />
                <ColumnDefinition Width="8" />
                <ColumnDefinition Width="180" />
                <ColumnDefinition Width="8" />
                <ColumnDefinition Width="80" />
                <ColumnDefinition Width="8" />
                <ColumnDefinition Width="Auto" />
                <ColumnDefinition Width="8" />
                <ColumnDefinition Width="Auto" />
              </Grid.ColumnDefinitions>
              <TextBox
                  Grid.Column="0"
                  Style="{StaticResource FormTextBox}"
                  Text="{Binding AddRuleKeyword, UpdateSourceTrigger=PropertyChanged}"
                  ToolTip="{DynamicResource Categories.Rule.KeywordHint}" />
              <ComboBox
                  Grid.Column="2"
                  DisplayMemberPath="Name"
                  ItemsSource="{Binding AvailableCategories}"
                  SelectedItem="{Binding AddRuleCategory}"
                  Style="{StaticResource FormComboBox}"
                  ToolTip="{DynamicResource Categories.Rule.CategoryHint}" />
              <TextBox
                  Grid.Column="4"
                  Style="{StaticResource FormTextBox}"
                  Text="{Binding AddRulePriority, UpdateSourceTrigger=PropertyChanged}"
                  ToolTip="{DynamicResource Categories.Rule.PriorityHint}" />
              <CheckBox
                  Grid.Column="6"
                  VerticalAlignment="Center"
                  Content="{DynamicResource Categories.Rule.CaseSensitive}"
                  Foreground="{DynamicResource AppTextSecondary}"
                  IsChecked="{Binding AddRuleCaseSensitive}" />
              <Button
                  Grid.Column="8"
                  MinWidth="120"
                  MinHeight="36"
                  Padding="16,0"
                  Command="{Binding AddRuleCommand}"
                  Style="{StaticResource BtnPrimary}">
                <TextBlock Foreground="{Binding Foreground, RelativeSource={RelativeSource AncestorType=Button}}"
                           Text="{DynamicResource Categories.Rule.Add}" />
              </Button>
            </Grid>
            <TextBlock
                Grid.Row="1"
                Margin="0,8,0,0"
                FontSize="{StaticResource FontSizeXs}"
                Foreground="{DynamicResource AppDown}"
                Text="{Binding AddRuleError}"
                Visibility="{Binding AddRuleError, Converter={StaticResource StringToVisibilityConverter}}" />
          </Grid>
        </Border>
      </Grid>
    </TabItem>

    <TabItem Header="{DynamicResource Categories.Tab.Budgets}">
      <Grid Margin="0,12,0,0">
        <Grid.RowDefinitions>
          <RowDefinition Height="Auto" />
          <RowDefinition Height="*" />
          <RowDefinition Height="Auto" />
        </Grid.RowDefinitions>

        <TextBlock
            Grid.Row="0"
            Margin="0,0,0,12"
            FontSize="{StaticResource FontSizeBase}"
            Foreground="{DynamicResource AppTextSecondary}"
            Text="{DynamicResource Categories.Budget.Hint}"
            TextWrapping="Wrap" />

        <Border
            Grid.Row="1"
            Padding="12"
            Background="{DynamicResource AppSurface}"
            BorderBrush="{DynamicResource AppBorder}"
            BorderThickness="1"
            CornerRadius="{StaticResource RadiusMd}">
          <ScrollViewer VerticalScrollBarVisibility="Auto">
            <ItemsControl ItemsSource="{Binding Budgets}">
              <ItemsControl.ItemTemplate>
                <DataTemplate>
                  <Border
                      Margin="0,0,0,6"
                      Padding="10,8"
                      Background="{DynamicResource AppBackground}"
                      BorderBrush="{DynamicResource AppBorder}"
                      BorderThickness="1"
                      CornerRadius="{StaticResource RadiusSm}">
                    <Grid>
                      <Grid.ColumnDefinitions>
                        <ColumnDefinition Width="120" />
                        <ColumnDefinition Width="*" />
                        <ColumnDefinition Width="Auto" />
                        <ColumnDefinition Width="Auto" />
                      </Grid.ColumnDefinitions>

                      <TextBlock
                          Grid.Column="0"
                          VerticalAlignment="Center"
                          FontFamily="{StaticResource FontTabular}"
                          FontSize="{StaticResource FontSizeBase}"
                          FontWeight="SemiBold"
                          Foreground="{DynamicResource AppTextPrimary}"
                          Text="{Binding PeriodDisplay}" />

                      <!--  View mode  -->
                      <StackPanel Grid.Column="1" Orientation="Horizontal" VerticalAlignment="Center">
                        <StackPanel.Style>
                          <Style TargetType="StackPanel">
                            <Setter Property="Visibility" Value="Visible" />
                            <Style.Triggers>
                              <DataTrigger Binding="{Binding IsEditing}" Value="True">
                                <Setter Property="Visibility" Value="Collapsed" />
                              </DataTrigger>
                            </Style.Triggers>
                          </Style>
                        </StackPanel.Style>
                        <TextBlock
                            VerticalAlignment="Center"
                            FontSize="{StaticResource FontSizeBase}"
                            Foreground="{DynamicResource AppTextSecondary}"
                            Text="{Binding CategoryDisplay}" />
                        <TextBlock
                            Margin="12,0,0,0"
                            VerticalAlignment="Center"
                            FontSize="{StaticResource FontSizeBase}"
                            Foreground="{DynamicResource AppTextMuted}"
                            Text="{Binding Note}" />
                      </StackPanel>

                      <!--  Edit mode  -->
                      <Grid Grid.Column="1">
                        <Grid.Style>
                          <Style TargetType="Grid">
                            <Setter Property="Visibility" Value="Collapsed" />
                            <Style.Triggers>
                              <DataTrigger Binding="{Binding IsEditing}" Value="True">
                                <Setter Property="Visibility" Value="Visible" />
                              </DataTrigger>
                            </Style.Triggers>
                          </Style>
                        </Grid.Style>
                        <Grid.ColumnDefinitions>
                          <ColumnDefinition Width="*" />
                        </Grid.ColumnDefinitions>
                        <TextBox
                            Grid.Column="0"
                            Style="{StaticResource FormTextBox}"
                            Text="{Binding EditNote, UpdateSourceTrigger=PropertyChanged}" />
                      </Grid>

                      <!--  Amount column  -->
                      <StackPanel Grid.Column="2" Margin="12,0" Orientation="Horizontal" VerticalAlignment="Center">
                        <TextBlock
                            VerticalAlignment="Center"
                            FontFamily="{StaticResource FontTabular}"
                            FontSize="{StaticResource FontSizeBase}"
                            FontWeight="SemiBold"
                            Foreground="{DynamicResource AppTextPrimary}"
                            Text="{Binding Amount, StringFormat=NT$\{0:N0\}}">
                          <TextBlock.Style>
                            <Style BasedOn="{StaticResource {x:Type TextBlock}}" TargetType="TextBlock">
                              <Setter Property="Visibility" Value="Visible" />
                              <Style.Triggers>
                                <DataTrigger Binding="{Binding IsEditing}" Value="True">
                                  <Setter Property="Visibility" Value="Collapsed" />
                                </DataTrigger>
                              </Style.Triggers>
                            </Style>
                          </TextBlock.Style>
                        </TextBlock>
                        <TextBox
                            Width="120"
                            Text="{Binding EditAmount, UpdateSourceTrigger=PropertyChanged}">
                          <TextBox.Style>
                            <Style BasedOn="{StaticResource FormTextBox}" TargetType="TextBox">
                              <Setter Property="Visibility" Value="Collapsed" />
                              <Style.Triggers>
                                <DataTrigger Binding="{Binding IsEditing}" Value="True">
                                  <Setter Property="Visibility" Value="Visible" />
                                </DataTrigger>
                              </Style.Triggers>
                            </Style>
                          </TextBox.Style>
                        </TextBox>
                      </StackPanel>

                      <!--  Buttons  -->
                      <StackPanel Grid.Column="3" Orientation="Horizontal" VerticalAlignment="Center">
                        <Button
                            Width="28" Height="28" Margin="0,0,4,0"
                            Command="{Binding DataContext.BeginEditBudgetCommand, RelativeSource={RelativeSource AncestorType=UserControl}}"
                            CommandParameter="{Binding}"
                            ToolTip="{DynamicResource Alerts.Edit}">
                          <Button.Style>
                            <Style BasedOn="{StaticResource BtnIcon}" TargetType="Button">
                              <Setter Property="Visibility" Value="Visible" />
                              <Style.Triggers>
                                <DataTrigger Binding="{Binding IsEditing}" Value="True">
                                  <Setter Property="Visibility" Value="Collapsed" />
                                </DataTrigger>
                              </Style.Triggers>
                            </Style>
                          </Button.Style>
                          <TextBlock FontFamily="Segoe MDL2 Assets" FontSize="{StaticResource FontSizeXs}"
                                     Foreground="{DynamicResource AppTextPrimary}" Text="&#xE70F;" />
                        </Button>
                        <Button
                            Width="28" Height="28"
                            Command="{Binding DataContext.DeleteBudgetCommand, RelativeSource={RelativeSource AncestorType=UserControl}}"
                            CommandParameter="{Binding}"
                            ToolTip="{DynamicResource Alerts.Delete}">
                          <Button.Style>
                            <Style BasedOn="{StaticResource DataGridDeleteBtn}" TargetType="Button">
                              <Setter Property="Visibility" Value="Visible" />
                              <Style.Triggers>
                                <DataTrigger Binding="{Binding IsEditing}" Value="True">
                                  <Setter Property="Visibility" Value="Collapsed" />
                                </DataTrigger>
                              </Style.Triggers>
                            </Style>
                          </Button.Style>
                          <TextBlock FontFamily="Segoe MDL2 Assets" FontSize="{StaticResource FontSizeXs}" Text="&#xE74D;" />
                        </Button>
                        <Button
                            Width="28" Height="28" Margin="0,0,4,0"
                            Command="{Binding DataContext.SaveEditBudgetCommand, RelativeSource={RelativeSource AncestorType=UserControl}}"
                            CommandParameter="{Binding}"
                            ToolTip="{DynamicResource Alerts.Save}">
                          <Button.Style>
                            <Style BasedOn="{StaticResource BtnIcon}" TargetType="Button">
                              <Setter Property="Visibility" Value="Collapsed" />
                              <Style.Triggers>
                                <DataTrigger Binding="{Binding IsEditing}" Value="True">
                                  <Setter Property="Visibility" Value="Visible" />
                                </DataTrigger>
                              </Style.Triggers>
                            </Style>
                          </Button.Style>
                          <TextBlock FontFamily="Segoe MDL2 Assets" FontSize="{StaticResource FontSizeSm}"
                                     Foreground="{DynamicResource AppUp}" Text="&#xE73E;" />
                        </Button>
                        <Button
                            Width="28" Height="28"
                            Command="{Binding DataContext.CancelEditBudgetCommand, RelativeSource={RelativeSource AncestorType=UserControl}}"
                            CommandParameter="{Binding}"
                            ToolTip="{DynamicResource Alerts.Cancel}">
                          <Button.Style>
                            <Style BasedOn="{StaticResource BtnIcon}" TargetType="Button">
                              <Setter Property="Visibility" Value="Collapsed" />
                              <Style.Triggers>
                                <DataTrigger Binding="{Binding IsEditing}" Value="True">
                                  <Setter Property="Visibility" Value="Visible" />
                                </DataTrigger>
                              </Style.Triggers>
                            </Style>
                          </Button.Style>
                          <TextBlock FontFamily="Segoe MDL2 Assets" FontSize="{StaticResource FontSizeXs}"
                                     Foreground="{DynamicResource AppTextSecondary}" Text="&#xE711;" />
                        </Button>
                      </StackPanel>
                    </Grid>
                  </Border>
                </DataTemplate>
              </ItemsControl.ItemTemplate>
            </ItemsControl>
          </ScrollViewer>
        </Border>

        <!--  Add budget form  -->
        <Border
            Grid.Row="2"
            Margin="0,12,0,0"
            Padding="14,12"
            Background="{DynamicResource AppSurface}"
            BorderBrush="{DynamicResource AppBorder}"
            BorderThickness="1"
            CornerRadius="{StaticResource RadiusMd}">
          <Grid>
            <Grid.RowDefinitions>
              <RowDefinition Height="Auto" />
              <RowDefinition Height="Auto" />
            </Grid.RowDefinitions>
            <Grid Grid.Row="0">
              <Grid.ColumnDefinitions>
                <ColumnDefinition Width="100" />
                <ColumnDefinition Width="6" />
                <ColumnDefinition Width="80" />
                <ColumnDefinition Width="6" />
                <ColumnDefinition Width="60" />
                <ColumnDefinition Width="6" />
                <ColumnDefinition Width="*" />
                <ColumnDefinition Width="6" />
                <ColumnDefinition Width="120" />
                <ColumnDefinition Width="6" />
                <ColumnDefinition Width="*" />
                <ColumnDefinition Width="6" />
                <ColumnDefinition Width="Auto" />
              </Grid.ColumnDefinitions>
              <ComboBox
                  Grid.Column="0"
                  ItemsSource="{Binding BudgetModeOptions}"
                  SelectedItem="{Binding AddBudgetMode}"
                  Style="{StaticResource FormComboBox}">
                <ComboBox.ItemTemplate>
                  <DataTemplate>
                    <TextBlock>
                      <TextBlock.Style>
                        <Style TargetType="TextBlock">
                          <Setter Property="Text" Value="{DynamicResource Categories.Budget.Mode.Monthly}" />
                          <Style.Triggers>
                            <DataTrigger Binding="{Binding}" Value="Yearly">
                              <Setter Property="Text" Value="{DynamicResource Categories.Budget.Mode.Yearly}" />
                            </DataTrigger>
                          </Style.Triggers>
                        </Style>
                      </TextBlock.Style>
                    </TextBlock>
                  </DataTemplate>
                </ComboBox.ItemTemplate>
              </ComboBox>
              <TextBox
                  Grid.Column="2"
                  Style="{StaticResource FormTextBox}"
                  Text="{Binding AddBudgetYear, UpdateSourceTrigger=PropertyChanged}"
                  ToolTip="{DynamicResource Categories.Budget.YearHint}" />
              <TextBox
                  Grid.Column="4"
                  Style="{StaticResource FormTextBox}"
                  Text="{Binding AddBudgetMonth, UpdateSourceTrigger=PropertyChanged}"
                  ToolTip="{DynamicResource Categories.Budget.MonthHint}" />
              <ComboBox
                  Grid.Column="6"
                  DisplayMemberPath="Name"
                  ItemsSource="{Binding AvailableCategories}"
                  SelectedItem="{Binding AddBudgetCategory}"
                  Style="{StaticResource FormComboBox}"
                  ToolTip="{DynamicResource Categories.Budget.CategoryHint}" />
              <TextBox
                  Grid.Column="8"
                  Style="{StaticResource FormTextBox}"
                  Text="{Binding AddBudgetAmount, UpdateSourceTrigger=PropertyChanged}"
                  ToolTip="{DynamicResource Categories.Budget.AmountHint}" />
              <TextBox
                  Grid.Column="10"
                  Style="{StaticResource FormTextBox}"
                  Text="{Binding AddBudgetNote, UpdateSourceTrigger=PropertyChanged}"
                  ToolTip="{DynamicResource Categories.Budget.NoteHint}" />
              <Button
                  Grid.Column="12"
                  MinWidth="100"
                  MinHeight="36"
                  Padding="16,0"
                  Command="{Binding AddBudgetCommand}"
                  Style="{StaticResource BtnPrimary}">
                <TextBlock Foreground="{Binding Foreground, RelativeSource={RelativeSource AncestorType=Button}}"
                           Text="{DynamicResource Categories.Budget.Add}" />
              </Button>
            </Grid>
            <TextBlock
                Grid.Row="1"
                Margin="0,8,0,0"
                FontSize="{StaticResource FontSizeXs}"
                Foreground="{DynamicResource AppDown}"
                Text="{Binding AddBudgetError}"
                Visibility="{Binding AddBudgetError, Converter={StaticResource StringToVisibilityConverter}}" />
          </Grid>
        </Border>
      </Grid>
    </TabItem>
    </TabControl>
  </Grid>
</UserControl>
