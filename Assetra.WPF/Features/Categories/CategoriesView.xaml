<UserControl
    x:Class="Assetra.WPF.Features.Categories.CategoriesView"
    xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
    xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
    xmlns:ctrl="clr-namespace:Assetra.WPF.Controls"
    xmlns:d="http://schemas.microsoft.com/expression/blend/2008"
    xmlns:mc="http://schemas.openxmlformats.org/markup-compatibility/2006"
    xmlns:ui="http://schemas.lepo.co/wpfui/2022/xaml"
    xmlns:vm="clr-namespace:Assetra.WPF.Features.Categories"
    x:Name="Root"
    d:DataContext="{d:DesignInstance Type={x:Type vm:CategoriesViewModel},
                                     IsDesignTimeCreatable=False}"
    d:DesignHeight="776"
    d:DesignWidth="1100"
    Background="{DynamicResource AppBackground}"
    mc:Ignorable="d">

    <UserControl.Resources>
        <Style x:Key="InlineFormLabel" TargetType="TextBlock">
            <Setter Property="Margin" Value="0,0,0,6" />
            <Setter Property="FontSize" Value="{StaticResource FontSizeXs}" />
            <Setter Property="Foreground" Value="{DynamicResource AppTextMuted}" />
        </Style>

        <Style x:Key="InlineFormField" TargetType="StackPanel">
            <Setter Property="Margin" Value="0,0,12,10" />
            <Setter Property="VerticalAlignment" Value="Top" />
        </Style>

        <Style
            x:Key="InlineTextBox"
            BasedOn="{StaticResource {x:Type ui:TextBox}}"
            TargetType="ui:TextBox">
            <Setter Property="MinHeight" Value="36" />
            <Setter Property="VerticalContentAlignment" Value="Center" />
        </Style>

        <Style
            x:Key="InlineComboBox"
            BasedOn="{StaticResource FormComboBox}"
            TargetType="ComboBox">
            <Setter Property="MinHeight" Value="36" />
            <Setter Property="VerticalContentAlignment" Value="Center" />
        </Style>

        <Style
            x:Key="InlineNumericTextBox"
            BasedOn="{StaticResource {x:Type ui:TextBox}}"
            TargetType="ui:TextBox">
            <Setter Property="MinHeight" Value="36" />
            <Setter Property="VerticalContentAlignment" Value="Center" />
            <Setter Property="FontFamily" Value="{StaticResource FontBase}" />
            <Setter Property="Typography.NumeralAlignment" Value="Tabular" />
        </Style>

        <Style x:Key="CategoryColorPalette" TargetType="ListBox">
            <Setter Property="Background" Value="Transparent" />
            <Setter Property="BorderThickness" Value="0" />
            <Setter Property="Padding" Value="0" />
            <Setter Property="Margin" Value="0" />
            <Setter Property="HorizontalContentAlignment" Value="Left" />
            <Setter Property="ScrollViewer.HorizontalScrollBarVisibility" Value="Disabled" />
            <Setter Property="ScrollViewer.VerticalScrollBarVisibility" Value="Disabled" />
        </Style>

        <Style x:Key="CategoryColorPaletteItem" TargetType="ListBoxItem">
            <Setter Property="Padding" Value="0" />
            <Setter Property="Margin" Value="0,0,8,8" />
            <Setter Property="FocusVisualStyle" Value="{x:Null}" />
            <Setter Property="HorizontalContentAlignment" Value="Stretch" />
            <Setter Property="VerticalContentAlignment" Value="Stretch" />
            <Setter Property="Template">
                <Setter.Value>
                    <ControlTemplate TargetType="ListBoxItem">
                        <Border
                            x:Name="Outer"
                            Padding="3"
                            Background="Transparent"
                            BorderBrush="{DynamicResource AppBorder}"
                            BorderThickness="1"
                            CornerRadius="{StaticResource RadiusMd}">
                            <ContentPresenter />
                        </Border>
                        <ControlTemplate.Triggers>
                            <Trigger Property="IsMouseOver" Value="True">
                                <Setter TargetName="Outer" Property="BorderBrush" Value="{DynamicResource AppAccent}" />
                            </Trigger>
                            <Trigger Property="IsSelected" Value="True">
                                <Setter TargetName="Outer" Property="BorderBrush" Value="{DynamicResource AppAccent}" />
                                <Setter TargetName="Outer" Property="Background" Value="{DynamicResource AppHover}" />
                            </Trigger>
                        </ControlTemplate.Triggers>
                    </ControlTemplate>
                </Setter.Value>
            </Setter>
        </Style>

        <DataTemplate x:Key="CategoryRowTemplate" DataType="{x:Type vm:CategoryRowViewModel}">
            <Border
                Margin="0,0,0,6"
                Padding="10,8"
                Background="{DynamicResource AppSurface}"
                BorderBrush="{DynamicResource AppBorder}"
                BorderThickness="1"
                CornerRadius="{StaticResource RadiusSm}">
                <Grid>
                    <Grid.ColumnDefinitions>
                        <ColumnDefinition Width="*" />
                        <ColumnDefinition Width="Auto" />
                    </Grid.ColumnDefinitions>

                    <!--  View mode  -->
                    <StackPanel
                        Grid.Column="0"
                        VerticalAlignment="Center"
                        Orientation="Horizontal">
                        <StackPanel.Style>
                            <Style TargetType="StackPanel">
                                <Setter Property="Visibility" Value="Visible" />
                                <Style.Triggers>
                                    <DataTrigger Binding="{Binding IsEditing}" Value="True">
                                        <Setter Property="Visibility" Value="Collapsed" />
                                    </DataTrigger>
                                </Style.Triggers>
                            </Style>
                        </StackPanel.Style>
                        <TextBlock
                            Margin="0,0,8,0"
                            VerticalAlignment="Center"
                            FontSize="{StaticResource FontSizeMd}"
                            Text="{Binding Icon}" />
                        <TextBlock
                            VerticalAlignment="Center"
                            FontSize="{StaticResource FontSizeBase}"
                            FontWeight="SemiBold"
                            Foreground="{DynamicResource AppTextPrimary}"
                            Text="{Binding Name}" />
                        <TextBlock
                            Margin="8,0,0,0"
                            VerticalAlignment="Center"
                            FontSize="{StaticResource FontSizeXs}"
                            Foreground="{DynamicResource AppTextMuted}"
                            Text="{DynamicResource Categories.ArchivedTag}"
                            Visibility="{Binding IsArchived, Converter={StaticResource BooleanToVisibilityConverter}}" />
                    </StackPanel>

                    <!--  Edit mode  -->
                    <StackPanel Grid.Column="0" Orientation="Vertical">
                        <StackPanel.Style>
                            <Style TargetType="StackPanel">
                                <Setter Property="Visibility" Value="Collapsed" />
                                <Style.Triggers>
                                    <DataTrigger Binding="{Binding IsEditing}" Value="True">
                                        <Setter Property="Visibility" Value="Visible" />
                                    </DataTrigger>
                                </Style.Triggers>
                            </Style>
                        </StackPanel.Style>
                        <WrapPanel Orientation="Horizontal">
                            <StackPanel Width="152" Margin="0,0,12,8">
                                <TextBlock Style="{StaticResource InlineFormLabel}" Text="{DynamicResource Categories.Field.Icon}" />
                                <ComboBox
                                    ItemsSource="{Binding EditIconOptions}"
                                    SelectedValue="{Binding EditIcon}"
                                    SelectedValuePath="Value"
                                    Style="{StaticResource InlineComboBox}">
                                    <ComboBox.ItemTemplate>
                                        <DataTemplate>
                                            <StackPanel Orientation="Horizontal">
                                                <TextBlock
                                                    Margin="0,0,8,0"
                                                    VerticalAlignment="Center"
                                                    FontSize="{StaticResource FontSizeMd}"
                                                    Text="{Binding Value}" />
                                                <TextBlock
                                                    VerticalAlignment="Center"
                                                    FontSize="{StaticResource FontSizeSm}"
                                                    Foreground="{DynamicResource AppTextSecondary}"
                                                    Text="{Binding Label}" />
                                            </StackPanel>
                                        </DataTemplate>
                                    </ComboBox.ItemTemplate>
                                </ComboBox>
                            </StackPanel>

                            <StackPanel Width="280" Margin="0,0,12,8">
                                <TextBlock Style="{StaticResource InlineFormLabel}" Text="{DynamicResource Categories.Field.Name}" />
                                <ui:TextBox Style="{StaticResource InlineTextBox}" Text="{Binding EditName, UpdateSourceTrigger=PropertyChanged}" />
                            </StackPanel>

                            <StackPanel Width="196" Margin="0,0,0,8">
                                <TextBlock Style="{StaticResource InlineFormLabel}" Text="{DynamicResource Categories.Field.Color}" />
                                <ctrl:HexColorPicker
                                    MinHeight="36"
                                    Presets="{Binding DataContext.ColorOptions, RelativeSource={RelativeSource AncestorType=UserControl}}"
                                    SelectedColorHex="{Binding EditColorHex, Mode=TwoWay}" />
                            </StackPanel>
                        </WrapPanel>
                        <TextBlock
                            Margin="0,4,0,0"
                            FontSize="{StaticResource FontSizeXs}"
                            Foreground="{DynamicResource AppDown}"
                            Text="{Binding EditError}"
                            Visibility="{Binding EditError, Converter={StaticResource StringToVisibilityConverter}}" />
                    </StackPanel>

                    <!--  Buttons  -->
                    <StackPanel
                        Grid.Column="1"
                        VerticalAlignment="Center"
                        Orientation="Horizontal">
                        <!--  View mode buttons  -->
                        <ui:Button
                            Width="28"
                            Height="28"
                            Margin="0,0,4,0"
                            Command="{Binding DataContext.BeginEditCommand, RelativeSource={RelativeSource AncestorType=UserControl}}"
                            CommandParameter="{Binding}"
                            ToolTip="{DynamicResource Alerts.Edit}">
                            <ui:Button.Style>
                                <Style BasedOn="{StaticResource {x:Type ui:Button}}" TargetType="{x:Type ui:Button}">
                          <Setter Property="Appearance" Value="Transparent" />
                                    <Setter Property="Visibility" Value="Visible" />
                                    <Style.Triggers>
                                        <DataTrigger Binding="{Binding IsEditing}" Value="True">
                                            <Setter Property="Visibility" Value="Collapsed" />
                                        </DataTrigger>
                                    </Style.Triggers>
                                </Style>
                            </ui:Button.Style>
                            <ui:SymbolIcon
                                FontSize="{StaticResource FontSizeXs}"
                                Foreground="{DynamicResource AppTextPrimary}"
                                Symbol="Edit24" />
                        </ui:Button>

                        <ui:Button
                            Width="28"
                            Height="28"
                            Margin="0,0,4,0"
                            Command="{Binding DataContext.ToggleArchiveCommand, RelativeSource={RelativeSource AncestorType=UserControl}}"
                            CommandParameter="{Binding}"
                            ToolTip="{DynamicResource Categories.ToggleArchive}">
                            <ui:Button.Style>
                                <Style BasedOn="{StaticResource {x:Type ui:Button}}" TargetType="{x:Type ui:Button}">
                          <Setter Property="Appearance" Value="Transparent" />
                                    <Setter Property="Visibility" Value="Visible" />
                                    <Style.Triggers>
                                        <DataTrigger Binding="{Binding IsEditing}" Value="True">
                                            <Setter Property="Visibility" Value="Collapsed" />
                                        </DataTrigger>
                                    </Style.Triggers>
                                </Style>
                            </ui:Button.Style>
                            <ui:SymbolIcon
                                FontSize="{StaticResource FontSizeXs}"
                                Foreground="{DynamicResource AppTextSecondary}"
                                Symbol="Money24" />
                        </ui:Button>

                        <ui:Button
                            Width="28"
                            Height="28"
                            Command="{Binding DataContext.DeleteCommand, RelativeSource={RelativeSource AncestorType=UserControl}}"
                            CommandParameter="{Binding}"
                            ToolTip="{DynamicResource Alerts.Delete}">
                            <ui:Button.Style>
                                <Style BasedOn="{StaticResource {x:Type ui:Button}}" TargetType="{x:Type ui:Button}">
                          <Setter Property="Appearance" Value="Transparent" />
                                    <Setter Property="Visibility" Value="Visible" />
                                    <Style.Triggers>
                                        <DataTrigger Binding="{Binding IsEditing}" Value="True">
                                            <Setter Property="Visibility" Value="Collapsed" />
                                        </DataTrigger>
                                    </Style.Triggers>
                                </Style>
                            </ui:Button.Style>
                            <ui:SymbolIcon FontSize="{StaticResource FontSizeXs}" Symbol="Delete24" Foreground="{DynamicResource AppDanger}" />
                        </ui:Button>

                        <!--  Edit mode buttons  -->
                        <ui:Button
                            Width="28"
                            Height="28"
                            Margin="0,0,4,0"
                            Command="{Binding DataContext.SaveEditCommand, RelativeSource={RelativeSource AncestorType=UserControl}}"
                            CommandParameter="{Binding}"
                            ToolTip="{DynamicResource Alerts.Save}">
                            <ui:Button.Style>
                                <Style BasedOn="{StaticResource {x:Type ui:Button}}" TargetType="{x:Type ui:Button}">
                          <Setter Property="Appearance" Value="Transparent" />
                                    <Setter Property="Visibility" Value="Collapsed" />
                                    <Style.Triggers>
                                        <DataTrigger Binding="{Binding IsEditing}" Value="True">
                                            <Setter Property="Visibility" Value="Visible" />
                                        </DataTrigger>
                                    </Style.Triggers>
                                </Style>
                            </ui:Button.Style>
                            <ui:SymbolIcon
                                FontSize="{StaticResource FontSizeSm}"
                                Foreground="{DynamicResource AppUp}"
                                Symbol="Checkmark24" />
                        </ui:Button>

                        <ui:Button
                            Width="28"
                            Height="28"
                            Command="{Binding DataContext.CancelEditCommand, RelativeSource={RelativeSource AncestorType=UserControl}}"
                            CommandParameter="{Binding}"
                            ToolTip="{DynamicResource Alerts.Cancel}">
                            <ui:Button.Style>
                                <Style BasedOn="{StaticResource {x:Type ui:Button}}" TargetType="{x:Type ui:Button}">
                          <Setter Property="Appearance" Value="Transparent" />
                                    <Setter Property="Visibility" Value="Collapsed" />
                                    <Style.Triggers>
                                        <DataTrigger Binding="{Binding IsEditing}" Value="True">
                                            <Setter Property="Visibility" Value="Visible" />
                                        </DataTrigger>
                                    </Style.Triggers>
                                </Style>
                            </ui:Button.Style>
                            <ui:SymbolIcon
                                FontSize="{StaticResource FontSizeXs}"
                                Foreground="{DynamicResource AppTextSecondary}"
                                Symbol="Dismiss24" />
                        </ui:Button>
                    </StackPanel>
                </Grid>
            </Border>
        </DataTemplate>
    </UserControl.Resources>

    <Grid Margin="24">
        <Grid.RowDefinitions>
            <RowDefinition Height="Auto" />
            <RowDefinition Height="*" />
        </Grid.RowDefinitions>

        <!--  Header  -->
        <DockPanel
            Grid.Row="0"
            Margin="0,0,0,16"
            LastChildFill="False">
            <TextBlock
                VerticalAlignment="Center"
                DockPanel.Dock="Left"
                FontSize="{StaticResource FontSizeXl}"
                FontWeight="SemiBold"
                Foreground="{DynamicResource AppTextPrimary}"
                Text="{DynamicResource Categories.Title}" />
            <CheckBox
                VerticalAlignment="Center"
                Content="{DynamicResource Categories.ShowArchived}"
                DockPanel.Dock="Right"
                Foreground="{DynamicResource AppTextSecondary}"
                IsChecked="{Binding ShowArchived}" />
        </DockPanel>

        <ui:TabView
            Grid.Row="1"
            Background="Transparent"
            BorderThickness="0">
            <ui:TabViewItem Header="{DynamicResource Categories.Tab.Categories}">
                <Grid Margin="0,12,0,0">
                    <Grid.RowDefinitions>
                        <RowDefinition Height="*" />
                        <RowDefinition Height="Auto" />
                    </Grid.RowDefinitions>

                    <!--  Two-column list  -->
                    <Grid Grid.Row="0">
                        <Grid.ColumnDefinitions>
                            <ColumnDefinition Width="*" />
                            <ColumnDefinition Width="16" />
                            <ColumnDefinition Width="*" />
                        </Grid.ColumnDefinitions>

                        <!--  Expense  -->
                        <Border
                            Grid.Column="0"
                            Padding="12"
                            Background="{DynamicResource AppSurface}"
                            BorderBrush="{DynamicResource AppBorder}"
                            BorderThickness="1"
                            CornerRadius="{StaticResource RadiusMd}">
                            <Grid>
                                <Grid.RowDefinitions>
                                    <RowDefinition Height="Auto" />
                                    <RowDefinition Height="*" />
                                </Grid.RowDefinitions>
                                <TextBlock
                                    Grid.Row="0"
                                    Margin="0,0,0,8"
                                    FontSize="{StaticResource FontSizeMd}"
                                    FontWeight="SemiBold"
                                    Foreground="{DynamicResource AppTextPrimary}"
                                    Text="{DynamicResource Categories.Expense}" />
                                <ScrollViewer Grid.Row="1" VerticalScrollBarVisibility="Auto">
                                    <ItemsControl ItemTemplate="{StaticResource CategoryRowTemplate}" ItemsSource="{Binding ExpenseView}" />
                                </ScrollViewer>
                            </Grid>
                        </Border>

                        <!--  Income  -->
                        <Border
                            Grid.Column="2"
                            Padding="12"
                            Background="{DynamicResource AppSurface}"
                            BorderBrush="{DynamicResource AppBorder}"
                            BorderThickness="1"
                            CornerRadius="{StaticResource RadiusMd}">
                            <Grid>
                                <Grid.RowDefinitions>
                                    <RowDefinition Height="Auto" />
                                    <RowDefinition Height="*" />
                                </Grid.RowDefinitions>
                                <TextBlock
                                    Grid.Row="0"
                                    Margin="0,0,0,8"
                                    FontSize="{StaticResource FontSizeMd}"
                                    FontWeight="SemiBold"
                                    Foreground="{DynamicResource AppTextPrimary}"
                                    Text="{DynamicResource Categories.Income}" />
                                <ScrollViewer Grid.Row="1" VerticalScrollBarVisibility="Auto">
                                    <ItemsControl ItemTemplate="{StaticResource CategoryRowTemplate}" ItemsSource="{Binding IncomeView}" />
                                </ScrollViewer>
                            </Grid>
                        </Border>
                    </Grid>

                    <!--  Add form  -->
                    <Border
                        Grid.Row="1"
                        Margin="0,12,0,0"
                        Padding="14,12"
                        Background="{DynamicResource AppSurface}"
                        BorderBrush="{DynamicResource AppBorder}"
                        BorderThickness="1"
                        CornerRadius="{StaticResource RadiusMd}">
                        <StackPanel>
                            <TextBlock
                                FontSize="{StaticResource FontSizeMd}"
                                FontWeight="SemiBold"
                                Foreground="{DynamicResource AppTextPrimary}"
                                Text="{DynamicResource Categories.AddForm.Title}" />
                            <TextBlock
                                Margin="0,4,0,12"
                                FontSize="{StaticResource FontSizeSm}"
                                Foreground="{DynamicResource AppTextSecondary}"
                                Text="{DynamicResource Categories.AddForm.Hint}"
                                TextWrapping="Wrap" />
                            <WrapPanel Orientation="Horizontal">
                                <StackPanel Style="{StaticResource InlineFormField}">
                                    <TextBlock Style="{StaticResource InlineFormLabel}" Text="{DynamicResource Categories.Field.Kind}" />
                                    <ComboBox
                                        Width="140"
                                        ItemsSource="{Binding KindOptions}"
                                        SelectedItem="{Binding AddKind}"
                                        Style="{StaticResource InlineComboBox}">
                                        <ComboBox.ItemTemplate>
                                            <DataTemplate>
                                                <TextBlock>
                                                    <TextBlock.Style>
                                                        <Style TargetType="TextBlock">
                                                            <Setter Property="Text" Value="{DynamicResource Categories.Expense}" />
                                                            <Style.Triggers>
                                                                <DataTrigger Binding="{Binding}" Value="Income">
                                                                    <Setter Property="Text" Value="{DynamicResource Categories.Income}" />
                                                                </DataTrigger>
                                                            </Style.Triggers>
                                                        </Style>
                                                    </TextBlock.Style>
                                                </TextBlock>
                                            </DataTemplate>
                                        </ComboBox.ItemTemplate>
                                    </ComboBox>
                                </StackPanel>

                                <StackPanel Style="{StaticResource InlineFormField}">
                                    <TextBlock Style="{StaticResource InlineFormLabel}" Text="{DynamicResource Categories.Field.Icon}" />
                                    <ComboBox
                                        Width="152"
                                        ItemsSource="{Binding IconOptions}"
                                        SelectedValue="{Binding AddIcon}"
                                        SelectedValuePath="Value"
                                        Style="{StaticResource InlineComboBox}"
                                        ToolTip="{DynamicResource Categories.IconHint}">
                                        <ComboBox.ItemTemplate>
                                            <DataTemplate>
                                                <StackPanel Orientation="Horizontal">
                                                    <TextBlock
                                                        Margin="0,0,8,0"
                                                        VerticalAlignment="Center"
                                                        FontSize="{StaticResource FontSizeMd}"
                                                        Text="{Binding Value}" />
                                                    <TextBlock
                                                        VerticalAlignment="Center"
                                                        FontSize="{StaticResource FontSizeSm}"
                                                        Foreground="{DynamicResource AppTextSecondary}"
                                                        Text="{Binding Label}" />
                                                </StackPanel>
                                            </DataTemplate>
                                        </ComboBox.ItemTemplate>
                                    </ComboBox>
                                </StackPanel>

                                <StackPanel Style="{StaticResource InlineFormField}">
                                    <TextBlock Style="{StaticResource InlineFormLabel}" Text="{DynamicResource Categories.Field.Name}" />
                                    <ui:TextBox
                                        Width="320"
                                        Style="{StaticResource InlineTextBox}"
                                        Text="{Binding AddName, UpdateSourceTrigger=PropertyChanged}"
                                        ToolTip="{DynamicResource Categories.NameHint}" />
                                </StackPanel>

                                <StackPanel Style="{StaticResource InlineFormField}">
                                    <TextBlock Style="{StaticResource InlineFormLabel}" Text="{DynamicResource Categories.Field.Color}" />
                                    <ctrl:HexColorPicker
                                        Width="184"
                                        MinHeight="36"
                                        Presets="{Binding ColorOptions}"
                                        SelectedColorHex="{Binding AddColorHex, Mode=TwoWay}"
                                        ToolTip="{DynamicResource Categories.ColorHint}" />
                                </StackPanel>

                            </WrapPanel>
                            <Border
                                Margin="0,4,0,0"
                                Padding="0,10,0,0"
                                BorderBrush="{DynamicResource AppBorder}"
                                BorderThickness="0,1,0,0">
                                <DockPanel LastChildFill="False">
                                    <ui:Button
                                        MinWidth="120"
                                        MinHeight="36"
                                        Padding="16,0"
                                        Appearance="Primary"
                                        Command="{Binding AddCategoryCommand}"
                                        DockPanel.Dock="Right">
                                        <TextBlock Foreground="{Binding Foreground, RelativeSource={RelativeSource AncestorType=Button}}" Text="{DynamicResource Categories.Add}" />
                                    </ui:Button>
                                </DockPanel>
                            </Border>
                            <TextBlock
                                Margin="0,8,0,0"
                                FontSize="{StaticResource FontSizeXs}"
                                Foreground="{DynamicResource AppDown}"
                                Text="{Binding AddError}"
                                Visibility="{Binding AddError, Converter={StaticResource StringToVisibilityConverter}}" />
                        </StackPanel>
                    </Border>
                </Grid>
            </ui:TabViewItem>

            <ui:TabViewItem Header="{DynamicResource Categories.Tab.Rules}">
                <Grid Margin="0,12,0,0">
                    <Grid.RowDefinitions>
                        <RowDefinition Height="Auto" />
                        <RowDefinition Height="*" />
                        <RowDefinition Height="Auto" />
                    </Grid.RowDefinitions>

                    <TextBlock
                        Grid.Row="0"
                        Margin="0,0,0,12"
                        FontSize="{StaticResource FontSizeBase}"
                        Foreground="{DynamicResource AppTextSecondary}"
                        Text="{DynamicResource Categories.Rule.Hint}"
                        TextWrapping="Wrap" />

                    <Border
                        Grid.Row="1"
                        Padding="12"
                        Background="{DynamicResource AppSurface}"
                        BorderBrush="{DynamicResource AppBorder}"
                        BorderThickness="1"
                        CornerRadius="{StaticResource RadiusMd}">
                        <ScrollViewer VerticalScrollBarVisibility="Auto">
                            <ItemsControl ItemsSource="{Binding Rules}">
                                <ItemsControl.ItemTemplate>
                                    <DataTemplate>
                                        <Border
                                            Margin="0,0,0,6"
                                            Padding="10,8"
                                            Background="{DynamicResource AppBackground}"
                                            BorderBrush="{DynamicResource AppBorder}"
                                            BorderThickness="1"
                                            CornerRadius="{StaticResource RadiusSm}">
                                            <Grid>
                                                <Grid.ColumnDefinitions>
                                                    <ColumnDefinition Width="Auto" />
                                                    <ColumnDefinition Width="*" />
                                                    <ColumnDefinition Width="Auto" />
                                                </Grid.ColumnDefinitions>

                                                <CheckBox
                                                    Grid.Column="0"
                                                    Margin="0,0,10,0"
                                                    VerticalAlignment="Center"
                                                    Command="{Binding DataContext.ToggleRuleEnabledCommand, RelativeSource={RelativeSource AncestorType=UserControl}}"
                                                    CommandParameter="{Binding}"
                                                    IsChecked="{Binding IsEnabled, Mode=OneWay}"
                                                    ToolTip="{DynamicResource Categories.Rule.ToggleEnabled}" />

                                                <!--  View mode  -->
                                                <StackPanel
                                                    Grid.Column="1"
                                                    VerticalAlignment="Center"
                                                    Orientation="Horizontal">
                                                    <StackPanel.Style>
                                                        <Style TargetType="StackPanel">
                                                            <Setter Property="Visibility" Value="Visible" />
                                                            <Style.Triggers>
                                                                <DataTrigger Binding="{Binding IsEditing}" Value="True">
                                                                    <Setter Property="Visibility" Value="Collapsed" />
                                                                </DataTrigger>
                                                            </Style.Triggers>
                                                        </Style>
                                                    </StackPanel.Style>
                                                    <TextBlock
                                                        VerticalAlignment="Center"
                                                        FontFamily="{StaticResource FontBase}"
                                                        FontSize="{StaticResource FontSizeBase}"
                                                        FontWeight="SemiBold"
                                                        Foreground="{DynamicResource AppTextPrimary}"
                                                        Text="{Binding KeywordPattern}"
                                                        Typography.NumeralAlignment="Tabular" />
                                                    <TextBlock
                                                        Margin="10,0,0,0"
                                                        VerticalAlignment="Center"
                                                        FontSize="{StaticResource FontSizeXs}"
                                                        Foreground="{DynamicResource AppTextMuted}"
                                                        Text="→" />
                                                    <TextBlock
                                                        Margin="6,0,0,0"
                                                        VerticalAlignment="Center"
                                                        FontSize="{StaticResource FontSizeSm}"
                                                        Foreground="{DynamicResource AppTextSecondary}"
                                                        Text="{Binding CategoryDisplay}" />
                                                    <TextBlock
                                                        Margin="10,0,0,0"
                                                        VerticalAlignment="Center"
                                                        FontSize="{StaticResource FontSizeXs}"
                                                        Foreground="{DynamicResource AppTextMuted}"
                                                        Text="{Binding Priority, StringFormat={}P:{0}}" />
                                                </StackPanel>

                                                <!--  Edit mode  -->
                                                <StackPanel Grid.Column="1">
                                                    <StackPanel.Style>
                                                        <Style TargetType="StackPanel">
                                                            <Setter Property="Visibility" Value="Collapsed" />
                                                            <Style.Triggers>
                                                                <DataTrigger Binding="{Binding IsEditing}" Value="True">
                                                                    <Setter Property="Visibility" Value="Visible" />
                                                                </DataTrigger>
                                                            </Style.Triggers>
                                                        </Style>
                                                    </StackPanel.Style>
                                                    <Grid>
                                                        <Grid.ColumnDefinitions>
                                                            <ColumnDefinition Width="*" />
                                                            <ColumnDefinition Width="6" />
                                                            <ColumnDefinition Width="160" />
                                                            <ColumnDefinition Width="6" />
                                                            <ColumnDefinition Width="60" />
                                                            <ColumnDefinition Width="6" />
                                                            <ColumnDefinition Width="Auto" />
                                                        </Grid.ColumnDefinitions>
                                                        <ui:TextBox
                                                            Grid.Column="0"
                                                            Style="{StaticResource InlineTextBox}"
                                                            Text="{Binding EditKeyword, UpdateSourceTrigger=PropertyChanged}" />
                                                        <ComboBox
                                                            Grid.Column="2"
                                                            DisplayMemberPath="Name"
                                                            ItemsSource="{Binding DataContext.AvailableCategories, RelativeSource={RelativeSource AncestorType=UserControl}}"
                                                            SelectedValue="{Binding EditCategoryId}"
                                                            SelectedValuePath="Id"
                                                            Style="{StaticResource InlineComboBox}" />
                                                        <ui:TextBox
                                                            Grid.Column="4"
                                                            Style="{StaticResource InlineNumericTextBox}"
                                                            Text="{Binding EditPriority, UpdateSourceTrigger=PropertyChanged}" />
                                                        <CheckBox
                                                            Grid.Column="6"
                                                            VerticalAlignment="Center"
                                                            Content="{DynamicResource Categories.Rule.CaseSensitive}"
                                                            Foreground="{DynamicResource AppTextSecondary}"
                                                            IsChecked="{Binding EditCaseSensitive}" />
                                                    </Grid>

                                                    <ui:CardExpander
                                                        Margin="0,8,0,0"
                                                        Foreground="{DynamicResource AppTextSecondary}"
                                                        Header="{DynamicResource Categories.Rule.Advanced}">
