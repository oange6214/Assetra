                                                                            <ColumnDefinition Width="100" />
                                                                            <ColumnDefinition Width="*" />
                                                                            <ColumnDefinition Width="32" />
                                                                        </Grid.ColumnDefinitions>
                                                                        <TextBlock
                                                                            Grid.Column="0"
                                                                            VerticalAlignment="Center"
                                                                            FontSize="{StaticResource FontSizeXs}"
                                                                            Foreground="{DynamicResource AppTextMuted}"
