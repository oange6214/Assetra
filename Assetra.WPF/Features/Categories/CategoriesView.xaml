<UserControl
    x:Name="Root"
    x:Class="Assetra.WPF.Features.Categories.CategoriesView"
    xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
    xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
    xmlns:d="http://schemas.microsoft.com/expression/blend/2008"
    xmlns:mc="http://schemas.openxmlformats.org/markup-compatibility/2006"
    xmlns:ctrl="clr-namespace:Assetra.WPF.Controls"
    xmlns:vm="clr-namespace:Assetra.WPF.Features.Categories"
    d:DataContext="{d:DesignInstance Type={x:Type vm:CategoriesViewModel},
                                     IsDesignTimeCreatable=False}"
    d:DesignHeight="776"
    d:DesignWidth="1100"
    Background="{DynamicResource AppBackground}"
    mc:Ignorable="d">

  <UserControl.Resources>
    <Style x:Key="InlineFormLabel" TargetType="TextBlock">
      <Setter Property="Margin" Value="0,0,0,6" />
      <Setter Property="FontSize" Value="{StaticResource FontSizeXs}" />
      <Setter Property="Foreground" Value="{DynamicResource AppTextMuted}" />
    </Style>

    <Style x:Key="InlineFormField" TargetType="StackPanel">
      <Setter Property="Margin" Value="0,0,12,10" />
      <Setter Property="VerticalAlignment" Value="Top" />
    </Style>

    <Style x:Key="CategoryColorPalette" TargetType="ListBox">
      <Setter Property="Background" Value="Transparent" />
      <Setter Property="BorderThickness" Value="0" />
      <Setter Property="Padding" Value="0" />
      <Setter Property="Margin" Value="0" />
      <Setter Property="HorizontalContentAlignment" Value="Left" />
      <Setter Property="ScrollViewer.HorizontalScrollBarVisibility" Value="Disabled" />
      <Setter Property="ScrollViewer.VerticalScrollBarVisibility" Value="Disabled" />
    </Style>

    <Style x:Key="CategoryColorPaletteItem" TargetType="ListBoxItem">
      <Setter Property="Padding" Value="0" />
      <Setter Property="Margin" Value="0,0,8,8" />
      <Setter Property="FocusVisualStyle" Value="{x:Null}" />
      <Setter Property="HorizontalContentAlignment" Value="Stretch" />
      <Setter Property="VerticalContentAlignment" Value="Stretch" />
      <Setter Property="Template">
        <Setter.Value>
          <ControlTemplate TargetType="ListBoxItem">
            <Border
                x:Name="Outer"
                Padding="3"
                Background="Transparent"
                BorderBrush="{DynamicResource AppBorder}"
                BorderThickness="1"
                CornerRadius="{StaticResource RadiusMd}">
              <ContentPresenter />
            </Border>
            <ControlTemplate.Triggers>
              <Trigger Property="IsMouseOver" Value="True">
                <Setter TargetName="Outer" Property="BorderBrush" Value="{DynamicResource AppAccent}" />
              </Trigger>
              <Trigger Property="IsSelected" Value="True">
                <Setter TargetName="Outer" Property="BorderBrush" Value="{DynamicResource AppAccent}" />
                <Setter TargetName="Outer" Property="Background" Value="{DynamicResource AppHover}" />
              </Trigger>
            </ControlTemplate.Triggers>
          </ControlTemplate>
        </Setter.Value>
      </Setter>
    </Style>

    <DataTemplate x:Key="CategoryRowTemplate" DataType="{x:Type vm:CategoryRowViewModel}">
      <Border
          Margin="0,0,0,6"
          Padding="10,8"
          Background="{DynamicResource AppSurface}"
          BorderBrush="{DynamicResource AppBorder}"
          BorderThickness="1"
          CornerRadius="{StaticResource RadiusSm}">
        <Grid>
          <Grid.ColumnDefinitions>
            <ColumnDefinition Width="*" />
            <ColumnDefinition Width="Auto" />
          </Grid.ColumnDefinitions>

          <!--  View mode  -->
          <StackPanel Grid.Column="0" Orientation="Horizontal" VerticalAlignment="Center">
            <StackPanel.Style>
              <Style TargetType="StackPanel">
                <Setter Property="Visibility" Value="Visible" />
                <Style.Triggers>
                  <DataTrigger Binding="{Binding IsEditing}" Value="True">
                    <Setter Property="Visibility" Value="Collapsed" />
                  </DataTrigger>
                </Style.Triggers>
              </Style>
            </StackPanel.Style>
            <TextBlock
                Margin="0,0,8,0"
                VerticalAlignment="Center"
                FontSize="{StaticResource FontSizeMd}"
                Text="{Binding Icon}" />
            <TextBlock
                VerticalAlignment="Center"
                FontSize="{StaticResource FontSizeBase}"
                FontWeight="SemiBold"
                Foreground="{DynamicResource AppTextPrimary}"
                Text="{Binding Name}" />
            <TextBlock
                Margin="8,0,0,0"
                VerticalAlignment="Center"
                FontSize="{StaticResource FontSizeXs}"
                Foreground="{DynamicResource AppTextMuted}"
                Text="{DynamicResource Categories.ArchivedTag}"
                Visibility="{Binding IsArchived, Converter={StaticResource BooleanToVisibilityConverter}}" />
          </StackPanel>

          <!--  Edit mode  -->
          <StackPanel Grid.Column="0" Orientation="Vertical">
            <StackPanel.Style>
              <Style TargetType="StackPanel">
                <Setter Property="Visibility" Value="Collapsed" />
                <Style.Triggers>
                  <DataTrigger Binding="{Binding IsEditing}" Value="True">
                    <Setter Property="Visibility" Value="Visible" />
                  </DataTrigger>
                </Style.Triggers>
              </Style>
            </StackPanel.Style>
            <WrapPanel Orientation="Horizontal">
              <StackPanel Width="164" Margin="0,0,12,8">
                <TextBlock Style="{StaticResource InlineFormLabel}" Text="{DynamicResource Categories.Field.Icon}" />
                <ComboBox
                    MinHeight="36"
                    ItemsSource="{Binding DataContext.IconOptions, RelativeSource={RelativeSource AncestorType=UserControl}}"
                    SelectedValue="{Binding EditIcon}"
                    SelectedValuePath="Value"
                    Style="{StaticResource FormComboBox}">
                  <ComboBox.ItemTemplate>
                    <DataTemplate>
                      <StackPanel Orientation="Horizontal">
                        <TextBlock
                            Margin="0,0,8,0"
                            VerticalAlignment="Center"
                            FontSize="{StaticResource FontSizeMd}"
                            Text="{Binding Value}" />
                        <TextBlock
                            VerticalAlignment="Center"
                            FontSize="{StaticResource FontSizeSm}"
                            Foreground="{DynamicResource AppTextSecondary}"
                            Text="{Binding Label}" />
                      </StackPanel>
                    </DataTemplate>
                  </ComboBox.ItemTemplate>
                </ComboBox>
              </StackPanel>

              <StackPanel Width="240" Margin="0,0,12,8">
                <TextBlock Style="{StaticResource InlineFormLabel}" Text="{DynamicResource Categories.Field.Name}" />
                <TextBox
                    MinHeight="36"
                    Style="{StaticResource FormTextBox}"
                    Text="{Binding EditName, UpdateSourceTrigger=PropertyChanged}" />
              </StackPanel>

              <StackPanel Width="184" Margin="0,0,0,8">
                <TextBlock Style="{StaticResource InlineFormLabel}" Text="{DynamicResource Categories.Field.Color}" />
                <ctrl:ColorPickerButton
                    Presets="{Binding DataContext.ColorOptions, RelativeSource={RelativeSource AncestorType=UserControl}}"
                    SelectedColor="{Binding EditColorHex, Mode=TwoWay}" />
              </StackPanel>

              <StackPanel Width="180" Margin="12,0,0,8">
                <TextBlock Style="{StaticResource InlineFormLabel}" Text="{DynamicResource Categories.Field.Preview}" />
                <Border
                    Padding="10,8"
                    Background="{DynamicResource AppSurface}"
                    BorderBrush="{DynamicResource AppBorder}"
                    BorderThickness="1"
                    CornerRadius="{StaticResource RadiusSm}">
                  <Grid>
                    <Grid.ColumnDefinitions>
                      <ColumnDefinition Width="Auto" />
                      <ColumnDefinition Width="*" />
                      <ColumnDefinition Width="Auto" />
                    </Grid.ColumnDefinitions>
                    <TextBlock
                        Grid.Column="0"
                        Margin="0,0,8,0"
                        VerticalAlignment="Center"
                        FontSize="{StaticResource FontSizeMd}"
                        Text="{Binding EditIcon}" />
                    <TextBlock
                        Grid.Column="1"
                        VerticalAlignment="Center"
                        FontSize="{StaticResource FontSizeSm}"
                        FontWeight="SemiBold"
                        Foreground="{DynamicResource AppTextPrimary}"
                        Text="{Binding EditName}"
                        TextTrimming="CharacterEllipsis">
                      <TextBlock.Style>
                        <Style TargetType="TextBlock">
                          <Setter Property="Text" Value="{Binding EditName}" />
                          <Style.Triggers>
                            <DataTrigger Binding="{Binding EditName}" Value="">
                              <Setter Property="Text" Value="{DynamicResource Categories.PreviewPlaceholder}" />
                              <Setter Property="Foreground" Value="{DynamicResource AppTextMuted}" />
                              <Setter Property="FontWeight" Value="Normal" />
                            </DataTrigger>
                          </Style.Triggers>
                        </Style>
                      </TextBlock.Style>
                    </TextBlock>
                    <Border
                        Grid.Column="2"
                        Width="18"
                        Height="18"
                        Margin="8,0,0,0"
                        VerticalAlignment="Center"
                        Background="{Binding EditColorHex, Converter={StaticResource HexToBrushConverter}}"
                        BorderBrush="#33000000"
                        BorderThickness="1"
                        CornerRadius="{StaticResource RadiusSm}" />
                  </Grid>
                </Border>
              </StackPanel>
            </WrapPanel>
            <TextBlock
                Margin="0,4,0,0"
                FontSize="{StaticResource FontSizeXs}"
                Foreground="{DynamicResource AppDown}"
                Text="{Binding EditError}"
                Visibility="{Binding EditError, Converter={StaticResource StringToVisibilityConverter}}" />
          </StackPanel>

          <!--  Buttons  -->
          <StackPanel Grid.Column="1" Orientation="Horizontal" VerticalAlignment="Center">
            <!--  View mode buttons  -->
            <Button
                Width="28" Height="28" Margin="0,0,4,0"
                Command="{Binding DataContext.BeginEditCommand, RelativeSource={RelativeSource AncestorType=UserControl}}"
                CommandParameter="{Binding}"
                ToolTip="{DynamicResource Alerts.Edit}">
              <Button.Style>
                <Style BasedOn="{StaticResource BtnIcon}" TargetType="Button">
                  <Setter Property="Visibility" Value="Visible" />
                  <Style.Triggers>
                    <DataTrigger Binding="{Binding IsEditing}" Value="True">
                      <Setter Property="Visibility" Value="Collapsed" />
                    </DataTrigger>
                  </Style.Triggers>
                </Style>
              </Button.Style>
              <TextBlock FontFamily="Segoe MDL2 Assets" FontSize="{StaticResource FontSizeXs}"
                         Foreground="{DynamicResource AppTextPrimary}" Text="&#xE70F;" />
            </Button>

            <Button
                Width="28" Height="28" Margin="0,0,4,0"
                Command="{Binding DataContext.ToggleArchiveCommand, RelativeSource={RelativeSource AncestorType=UserControl}}"
                CommandParameter="{Binding}"
                ToolTip="{DynamicResource Categories.ToggleArchive}">
              <Button.Style>
                <Style BasedOn="{StaticResource BtnIcon}" TargetType="Button">
                  <Setter Property="Visibility" Value="Visible" />
                  <Style.Triggers>
                    <DataTrigger Binding="{Binding IsEditing}" Value="True">
                      <Setter Property="Visibility" Value="Collapsed" />
                    </DataTrigger>
                  </Style.Triggers>
                </Style>
              </Button.Style>
              <TextBlock FontFamily="Segoe MDL2 Assets" FontSize="{StaticResource FontSizeXs}"
                         Foreground="{DynamicResource AppTextSecondary}" Text="&#xE7B8;" />
            </Button>

            <Button
                Width="28" Height="28"
                Command="{Binding DataContext.DeleteCommand, RelativeSource={RelativeSource AncestorType=UserControl}}"
                CommandParameter="{Binding}"
                ToolTip="{DynamicResource Alerts.Delete}">
              <Button.Style>
                <Style BasedOn="{StaticResource DataGridDeleteBtn}" TargetType="Button">
                  <Setter Property="Visibility" Value="Visible" />
                  <Style.Triggers>
                    <DataTrigger Binding="{Binding IsEditing}" Value="True">
                      <Setter Property="Visibility" Value="Collapsed" />
                    </DataTrigger>
                  </Style.Triggers>
                </Style>
              </Button.Style>
              <TextBlock FontFamily="Segoe MDL2 Assets" FontSize="{StaticResource FontSizeXs}" Text="&#xE74D;" />
            </Button>

            <!--  Edit mode buttons  -->
            <Button
                Width="28" Height="28" Margin="0,0,4,0"
                Command="{Binding DataContext.SaveEditCommand, RelativeSource={RelativeSource AncestorType=UserControl}}"
                CommandParameter="{Binding}"
                ToolTip="{DynamicResource Alerts.Save}">
              <Button.Style>
                <Style BasedOn="{StaticResource BtnIcon}" TargetType="Button">
                  <Setter Property="Visibility" Value="Collapsed" />
                  <Style.Triggers>
                    <DataTrigger Binding="{Binding IsEditing}" Value="True">
                      <Setter Property="Visibility" Value="Visible" />
                    </DataTrigger>
                  </Style.Triggers>
                </Style>
              </Button.Style>
              <TextBlock FontFamily="Segoe MDL2 Assets" FontSize="{StaticResource FontSizeSm}"
                         Foreground="{DynamicResource AppUp}" Text="&#xE73E;" />
            </Button>

            <Button
                Width="28" Height="28"
                Command="{Binding DataContext.CancelEditCommand, RelativeSource={RelativeSource AncestorType=UserControl}}"
                CommandParameter="{Binding}"
                ToolTip="{DynamicResource Alerts.Cancel}">
              <Button.Style>
                <Style BasedOn="{StaticResource BtnIcon}" TargetType="Button">
                  <Setter Property="Visibility" Value="Collapsed" />
                  <Style.Triggers>
                    <DataTrigger Binding="{Binding IsEditing}" Value="True">
                      <Setter Property="Visibility" Value="Visible" />
                    </DataTrigger>
                  </Style.Triggers>
                </Style>
              </Button.Style>
              <TextBlock FontFamily="Segoe MDL2 Assets" FontSize="{StaticResource FontSizeXs}"
                         Foreground="{DynamicResource AppTextSecondary}" Text="&#xE711;" />
            </Button>
          </StackPanel>
        </Grid>
      </Border>
    </DataTemplate>
  </UserControl.Resources>

  <Grid Margin="24">
    <Grid.RowDefinitions>
      <RowDefinition Height="Auto" />
      <RowDefinition Height="*" />
    </Grid.RowDefinitions>

    <!--  Header  -->
    <DockPanel Grid.Row="0" LastChildFill="False" Margin="0,0,0,16">
      <TextBlock
          DockPanel.Dock="Left"
          VerticalAlignment="Center"
          FontSize="{StaticResource FontSizeXl}"
          FontWeight="SemiBold"
          Foreground="{DynamicResource AppTextPrimary}"
          Text="{DynamicResource Categories.Title}" />
      <CheckBox
          DockPanel.Dock="Right"
          VerticalAlignment="Center"
          Content="{DynamicResource Categories.ShowArchived}"
          Foreground="{DynamicResource AppTextSecondary}"
          IsChecked="{Binding ShowArchived}" />
    </DockPanel>

    <TabControl Grid.Row="1" Background="Transparent" BorderThickness="0">
    <TabItem Header="{DynamicResource Categories.Tab.Categories}">
     <Grid Margin="0,12,0,0">
    <Grid.RowDefinitions>
      <RowDefinition Height="*" />
      <RowDefinition Height="Auto" />
    </Grid.RowDefinitions>

    <!--  Two-column list  -->
    <Grid Grid.Row="0">
      <Grid.ColumnDefinitions>
        <ColumnDefinition Width="*" />
        <ColumnDefinition Width="16" />
        <ColumnDefinition Width="*" />
      </Grid.ColumnDefinitions>

      <!--  Expense  -->
      <Border
          Grid.Column="0"
          Padding="12"
          Background="{DynamicResource AppSurface}"
          BorderBrush="{DynamicResource AppBorder}"
          BorderThickness="1"
          CornerRadius="{StaticResource RadiusMd}">
        <Grid>
          <Grid.RowDefinitions>
            <RowDefinition Height="Auto" />
            <RowDefinition Height="*" />
          </Grid.RowDefinitions>
          <TextBlock
              Grid.Row="0"
              Margin="0,0,0,8"
              FontSize="{StaticResource FontSizeMd}"
              FontWeight="SemiBold"
              Foreground="{DynamicResource AppTextPrimary}"
              Text="{DynamicResource Categories.Expense}" />
          <ScrollViewer Grid.Row="1" VerticalScrollBarVisibility="Auto">
            <ItemsControl ItemsSource="{Binding ExpenseView}" ItemTemplate="{StaticResource CategoryRowTemplate}" />
          </ScrollViewer>
        </Grid>
      </Border>

      <!--  Income  -->
      <Border
          Grid.Column="2"
          Padding="12"
          Background="{DynamicResource AppSurface}"
          BorderBrush="{DynamicResource AppBorder}"
          BorderThickness="1"
          CornerRadius="{StaticResource RadiusMd}">
        <Grid>
          <Grid.RowDefinitions>
            <RowDefinition Height="Auto" />
            <RowDefinition Height="*" />
          </Grid.RowDefinitions>
          <TextBlock
              Grid.Row="0"
              Margin="0,0,0,8"
              FontSize="{StaticResource FontSizeMd}"
              FontWeight="SemiBold"
              Foreground="{DynamicResource AppTextPrimary}"
              Text="{DynamicResource Categories.Income}" />
          <ScrollViewer Grid.Row="1" VerticalScrollBarVisibility="Auto">
            <ItemsControl ItemsSource="{Binding IncomeView}" ItemTemplate="{StaticResource CategoryRowTemplate}" />
          </ScrollViewer>
        </Grid>
      </Border>
    </Grid>

    <!--  Add form  -->
    <Border
        Grid.Row="1"
        Margin="0,12,0,0"
        Padding="14,12"
        Background="{DynamicResource AppSurface}"
        BorderBrush="{DynamicResource AppBorder}"
        BorderThickness="1"
        CornerRadius="{StaticResource RadiusMd}">
      <StackPanel>
        <TextBlock
            FontSize="{StaticResource FontSizeMd}"
            FontWeight="SemiBold"
            Foreground="{DynamicResource AppTextPrimary}"
            Text="{DynamicResource Categories.AddForm.Title}" />
        <TextBlock
            Margin="0,4,0,12"
            FontSize="{StaticResource FontSizeSm}"
            Foreground="{DynamicResource AppTextSecondary}"
            Text="{DynamicResource Categories.AddForm.Hint}"
            TextWrapping="Wrap" />
        <WrapPanel Orientation="Horizontal">
          <StackPanel Style="{StaticResource InlineFormField}">
            <TextBlock Style="{StaticResource InlineFormLabel}" Text="{DynamicResource Categories.Field.Kind}" />
            <ComboBox
                Width="140"
                MinHeight="36"
                ItemsSource="{Binding KindOptions}"
                SelectedItem="{Binding AddKind}"
                Style="{StaticResource FormComboBox}">
              <ComboBox.ItemTemplate>
                <DataTemplate>
                  <TextBlock>
                    <TextBlock.Style>
                      <Style TargetType="TextBlock">
                        <Setter Property="Text" Value="{DynamicResource Categories.Expense}" />
                        <Style.Triggers>
                          <DataTrigger Binding="{Binding}" Value="Income">
                            <Setter Property="Text" Value="{DynamicResource Categories.Income}" />
                          </DataTrigger>
                        </Style.Triggers>
                      </Style>
                    </TextBlock.Style>
                  </TextBlock>
                </DataTemplate>
              </ComboBox.ItemTemplate>
            </ComboBox>
          </StackPanel>

          <StackPanel Style="{StaticResource InlineFormField}">
            <TextBlock Style="{StaticResource InlineFormLabel}" Text="{DynamicResource Categories.Field.Icon}" />
            <ComboBox
                Width="164"
                MinHeight="36"
                ItemsSource="{Binding IconOptions}"
                SelectedValue="{Binding AddIcon}"
                SelectedValuePath="Value"
                Style="{StaticResource FormComboBox}"
                ToolTip="{DynamicResource Categories.IconHint}">
              <ComboBox.ItemTemplate>
                <DataTemplate>
                  <StackPanel Orientation="Horizontal">
                    <TextBlock
                        Margin="0,0,8,0"
                        VerticalAlignment="Center"
                        FontSize="{StaticResource FontSizeMd}"
                        Text="{Binding Value}" />
                    <TextBlock
                        VerticalAlignment="Center"
                        FontSize="{StaticResource FontSizeSm}"
                        Foreground="{DynamicResource AppTextSecondary}"
                        Text="{Binding Label}" />
                  </StackPanel>
                </DataTemplate>
              </ComboBox.ItemTemplate>
            </ComboBox>
          </StackPanel>

          <StackPanel Style="{StaticResource InlineFormField}">
            <TextBlock Style="{StaticResource InlineFormLabel}" Text="{DynamicResource Categories.Field.Name}" />
            <TextBox
                Width="280"
                MinHeight="36"
                Style="{StaticResource FormTextBox}"
                Text="{Binding AddName, UpdateSourceTrigger=PropertyChanged}"
                ToolTip="{DynamicResource Categories.NameHint}" />
          </StackPanel>

          <StackPanel Style="{StaticResource InlineFormField}">
            <TextBlock Style="{StaticResource InlineFormLabel}" Text="{DynamicResource Categories.Field.Color}" />
            <ctrl:ColorPickerButton
                Width="184"
                Presets="{Binding ColorOptions}"
                SelectedColor="{Binding AddColorHex, Mode=TwoWay}"
                ToolTip="{DynamicResource Categories.ColorHint}" />
          </StackPanel>

          <StackPanel Style="{StaticResource InlineFormField}" Width="180">
            <TextBlock Style="{StaticResource InlineFormLabel}" Text="{DynamicResource Categories.Field.Preview}" />
            <Border
                Padding="10,8"
                Background="{DynamicResource AppSurface}"
                BorderBrush="{DynamicResource AppBorder}"
                BorderThickness="1"
                CornerRadius="{StaticResource RadiusSm}">
              <Grid>
                <Grid.ColumnDefinitions>
                  <ColumnDefinition Width="Auto" />
                  <ColumnDefinition Width="*" />
                  <ColumnDefinition Width="Auto" />
                </Grid.ColumnDefinitions>
                <TextBlock
                    Grid.Column="0"
                    Margin="0,0,8,0"
                    VerticalAlignment="Center"
                    FontSize="{StaticResource FontSizeMd}"
                    Text="{Binding AddIcon}" />
                <TextBlock
                    Grid.Column="1"
                    VerticalAlignment="Center"
                    FontSize="{StaticResource FontSizeSm}"
                    FontWeight="SemiBold"
                    Foreground="{DynamicResource AppTextPrimary}"
                    Text="{Binding AddName}"
                    TextTrimming="CharacterEllipsis">
                  <TextBlock.Style>
                    <Style TargetType="TextBlock">
                      <Setter Property="Text" Value="{Binding AddName}" />
                      <Style.Triggers>
                        <DataTrigger Binding="{Binding AddName}" Value="">
                          <Setter Property="Text" Value="{DynamicResource Categories.PreviewPlaceholder}" />
                          <Setter Property="Foreground" Value="{DynamicResource AppTextMuted}" />
                          <Setter Property="FontWeight" Value="Normal" />
                        </DataTrigger>
                      </Style.Triggers>
                    </Style>
                  </TextBlock.Style>
                </TextBlock>
                <Border
                    Grid.Column="2"
                    Width="18"
                    Height="18"
                    Margin="8,0,0,0"
                    VerticalAlignment="Center"
                    Background="{Binding AddColorHex, Converter={StaticResource HexToBrushConverter}}"
                    BorderBrush="#33000000"
                    BorderThickness="1"
                    CornerRadius="{StaticResource RadiusSm}" />
              </Grid>
            </Border>
          </StackPanel>

        </WrapPanel>
        <Border
            Margin="0,4,0,0"
            Padding="0,10,0,0"
            BorderBrush="{DynamicResource AppBorder}"
            BorderThickness="0,1,0,0">
          <DockPanel LastChildFill="False">
            <Button
                DockPanel.Dock="Right"
                MinWidth="120"
                MinHeight="36"
                Padding="16,0"
                Command="{Binding AddCategoryCommand}"
                Style="{StaticResource BtnPrimary}">
              <TextBlock Foreground="{Binding Foreground, RelativeSource={RelativeSource AncestorType=Button}}"
                         Text="{DynamicResource Categories.Add}" />
            </Button>
          </DockPanel>
        </Border>
        <TextBlock
            Margin="0,8,0,0"
            FontSize="{StaticResource FontSizeXs}"
            Foreground="{DynamicResource AppDown}"
            Text="{Binding AddError}"
            Visibility="{Binding AddError, Converter={StaticResource StringToVisibilityConverter}}" />
      </StackPanel>
    </Border>
     </Grid>
    </TabItem>

    <TabItem Header="{DynamicResource Categories.Tab.Rules}">
      <Grid Margin="0,12,0,0">
        <Grid.RowDefinitions>
          <RowDefinition Height="Auto" />
          <RowDefinition Height="*" />
          <RowDefinition Height="Auto" />
        </Grid.RowDefinitions>

        <TextBlock
            Grid.Row="0"
            Margin="0,0,0,12"
            FontSize="{StaticResource FontSizeBase}"
            Foreground="{DynamicResource AppTextSecondary}"
            Text="{DynamicResource Categories.Rule.Hint}"
            TextWrapping="Wrap" />

        <Border
            Grid.Row="1"
            Padding="12"
            Background="{DynamicResource AppSurface}"
            BorderBrush="{DynamicResource AppBorder}"
            BorderThickness="1"
            CornerRadius="{StaticResource RadiusMd}">
          <ScrollViewer VerticalScrollBarVisibility="Auto">
            <ItemsControl ItemsSource="{Binding Rules}">
              <ItemsControl.ItemTemplate>
                <DataTemplate>
                  <Border
                      Margin="0,0,0,6"
                      Padding="10,8"
                      Background="{DynamicResource AppBackground}"
                      BorderBrush="{DynamicResource AppBorder}"
                      BorderThickness="1"
                      CornerRadius="{StaticResource RadiusSm}">
                    <Grid>
                      <Grid.ColumnDefinitions>
                        <ColumnDefinition Width="Auto" />
                        <ColumnDefinition Width="*" />
                        <ColumnDefinition Width="Auto" />
                      </Grid.ColumnDefinitions>

                      <CheckBox
                          Grid.Column="0"
                          Margin="0,0,10,0"
                          VerticalAlignment="Center"
                          Command="{Binding DataContext.ToggleRuleEnabledCommand, RelativeSource={RelativeSource AncestorType=UserControl}}"
                          CommandParameter="{Binding}"
                          IsChecked="{Binding IsEnabled, Mode=OneWay}"
                          ToolTip="{DynamicResource Categories.Rule.ToggleEnabled}" />

                      <!--  View mode  -->
                      <StackPanel Grid.Column="1" Orientation="Horizontal" VerticalAlignment="Center">
                        <StackPanel.Style>
                          <Style TargetType="StackPanel">
                            <Setter Property="Visibility" Value="Visible" />
                            <Style.Triggers>
                              <DataTrigger Binding="{Binding IsEditing}" Value="True">
                                <Setter Property="Visibility" Value="Collapsed" />
                              </DataTrigger>
                            </Style.Triggers>
                          </Style>
                        </StackPanel.Style>
                        <TextBlock
                            VerticalAlignment="Center"
                            FontFamily="{StaticResource FontTabular}"
                            FontSize="{StaticResource FontSizeBase}"
                            FontWeight="SemiBold"
                            Foreground="{DynamicResource AppTextPrimary}"
                            Text="{Binding KeywordPattern}" />
                        <TextBlock
                            Margin="10,0,0,0"
                            VerticalAlignment="Center"
                            FontSize="{StaticResource FontSizeXs}"
                            Foreground="{DynamicResource AppTextMuted}"
                            Text="→" />
                        <TextBlock
                            Margin="6,0,0,0"
                            VerticalAlignment="Center"
                            FontSize="{StaticResource FontSizeSm}"
                            Foreground="{DynamicResource AppTextSecondary}"
                            Text="{Binding CategoryDisplay}" />
                        <TextBlock
                            Margin="10,0,0,0"
                            VerticalAlignment="Center"
                            FontSize="{StaticResource FontSizeXs}"
                            Foreground="{DynamicResource AppTextMuted}"
                            Text="{Binding Priority, StringFormat={}P:{0}}" />
                      </StackPanel>

                      <!--  Edit mode  -->
                      <StackPanel Grid.Column="1">
                        <StackPanel.Style>
                          <Style TargetType="StackPanel">
                            <Setter Property="Visibility" Value="Collapsed" />
                            <Style.Triggers>
                              <DataTrigger Binding="{Binding IsEditing}" Value="True">
                                <Setter Property="Visibility" Value="Visible" />
                              </DataTrigger>
                            </Style.Triggers>
                          </Style>
                        </StackPanel.Style>
                        <Grid>
                          <Grid.ColumnDefinitions>
                            <ColumnDefinition Width="*" />
                            <ColumnDefinition Width="6" />
                            <ColumnDefinition Width="160" />
                            <ColumnDefinition Width="6" />
                            <ColumnDefinition Width="60" />
                            <ColumnDefinition Width="6" />
                            <ColumnDefinition Width="Auto" />
                          </Grid.ColumnDefinitions>
                          <TextBox
                              Grid.Column="0"
                              Style="{StaticResource FormTextBox}"
                              Text="{Binding EditKeyword, UpdateSourceTrigger=PropertyChanged}" />
                          <ComboBox
                              Grid.Column="2"
                              DisplayMemberPath="Name"
                              ItemsSource="{Binding DataContext.AvailableCategories, RelativeSource={RelativeSource AncestorType=UserControl}}"
                              SelectedValuePath="Id"
                              SelectedValue="{Binding EditCategoryId}"
                              Style="{StaticResource FormComboBox}" />
                          <TextBox
                              Grid.Column="4"
                              Style="{StaticResource FormTextBox}"
                              Text="{Binding EditPriority, UpdateSourceTrigger=PropertyChanged}" />
                          <CheckBox
                              Grid.Column="6"
                              VerticalAlignment="Center"
                              Content="{DynamicResource Categories.Rule.CaseSensitive}"
                              Foreground="{DynamicResource AppTextSecondary}"
                              IsChecked="{Binding EditCaseSensitive}" />
                        </Grid>

                        <Expander Margin="0,8,0,0"
                                  Foreground="{DynamicResource AppTextSecondary}"
                                  Header="{DynamicResource Categories.Rule.Advanced}">
                          <StackPanel Margin="0,8,0,0">
                            <Grid Margin="0,0,0,6">
                              <Grid.ColumnDefinitions>
                                <ColumnDefinition Width="100" />
                                <ColumnDefinition Width="*" />
                              </Grid.ColumnDefinitions>
                              <TextBlock Grid.Column="0" VerticalAlignment="Center"
                                         FontSize="{StaticResource FontSizeXs}"
                                         Foreground="{DynamicResource AppTextMuted}"
                                         Text="{DynamicResource Categories.Rule.Name}" />
                              <TextBox Grid.Column="1"
                                       Style="{StaticResource FormTextBox}"
                                       Text="{Binding EditName, UpdateSourceTrigger=PropertyChanged}" />
                            </Grid>

                            <TextBlock FontSize="{StaticResource FontSizeXs}"
                                       Foreground="{DynamicResource AppTextMuted}"
                                       Text="{DynamicResource Categories.Rule.MatchField}" />
                            <StackPanel Margin="0,4,0,8" Orientation="Horizontal">
                              <RadioButton Margin="0,0,12,0"
                                           Content="{DynamicResource Categories.Rule.MatchField.Counterparty}"
                                           IsChecked="{Binding EditMatchField, Converter={StaticResource EnumToBoolConverter}, ConverterParameter=Counterparty}" />
                              <RadioButton Margin="0,0,12,0"
                                           Content="{DynamicResource Categories.Rule.MatchField.Memo}"
                                           IsChecked="{Binding EditMatchField, Converter={StaticResource EnumToBoolConverter}, ConverterParameter=Memo}" />
                              <RadioButton Margin="0,0,12,0"
                                           Content="{DynamicResource Categories.Rule.MatchField.Either}"
                                           IsChecked="{Binding EditMatchField, Converter={StaticResource EnumToBoolConverter}, ConverterParameter=Either}" />
                              <RadioButton Content="{DynamicResource Categories.Rule.MatchField.AnyText}"
                                           IsChecked="{Binding EditMatchField, Converter={StaticResource EnumToBoolConverter}, ConverterParameter=AnyText}" />
                            </StackPanel>

                            <TextBlock FontSize="{StaticResource FontSizeXs}"
                                       Foreground="{DynamicResource AppTextMuted}"
                                       Text="{DynamicResource Categories.Rule.MatchType}" />
                            <StackPanel Margin="0,4,0,8" Orientation="Horizontal">
                              <RadioButton Margin="0,0,12,0"
                                           Content="{DynamicResource Categories.Rule.MatchType.Contains}"
                                           IsChecked="{Binding EditMatchType, Converter={StaticResource EnumToBoolConverter}, ConverterParameter=Contains}" />
                              <RadioButton Margin="0,0,12,0"
                                           Content="{DynamicResource Categories.Rule.MatchType.Equals}"
                                           IsChecked="{Binding EditMatchType, Converter={StaticResource EnumToBoolConverter}, ConverterParameter=Equals}" />
                              <RadioButton Margin="0,0,12,0"
                                           Content="{DynamicResource Categories.Rule.MatchType.StartsWith}"
                                           IsChecked="{Binding EditMatchType, Converter={StaticResource EnumToBoolConverter}, ConverterParameter=StartsWith}" />
                              <RadioButton Content="{DynamicResource Categories.Rule.MatchType.Regex}"
                                           IsChecked="{Binding EditMatchType, Converter={StaticResource EnumToBoolConverter}, ConverterParameter=Regex}" />
                            </StackPanel>

                            <TextBlock FontSize="{StaticResource FontSizeXs}"
                                       Foreground="{DynamicResource AppTextMuted}"
                                       Text="{DynamicResource Categories.Rule.AppliesTo}" />
                            <StackPanel Margin="0,4,0,8" Orientation="Horizontal">
                              <CheckBox Margin="0,0,12,0"
                                        Content="{DynamicResource Categories.Rule.AppliesTo.Manual}"
                                        IsChecked="{Binding EditAppliesToManual}" />
                              <CheckBox Content="{DynamicResource Categories.Rule.AppliesTo.Import}"
                                        IsChecked="{Binding EditAppliesToImport}" />
                            </StackPanel>

                            <Border Margin="0,8,0,0" Padding="10,8"
                                    Background="{DynamicResource AppSurface}"
                                    BorderBrush="{DynamicResource AppBorder}"
                                    BorderThickness="1"
                                    CornerRadius="{StaticResource RadiusSm}">
                              <StackPanel>
                                <TextBlock FontSize="{StaticResource FontSizeXs}"
                                           FontWeight="SemiBold"
                                           Foreground="{DynamicResource AppTextSecondary}"
                                           Text="{DynamicResource Categories.Rule.LiveTest}" />
                                <Grid Margin="0,6,0,0">
                                  <Grid.ColumnDefinitions>
                                    <ColumnDefinition Width="100" />
                                    <ColumnDefinition Width="*" />
                                    <ColumnDefinition Width="32" />
                                  </Grid.ColumnDefinitions>
                                  <TextBlock Grid.Column="0" VerticalAlignment="Center"
                                             FontSize="{StaticResource FontSizeXs}"
                                             Foreground="{DynamicResource AppTextMuted}"
                                             Text="{DynamicResource Categories.Rule.LiveTest.Counterparty}" />
                                  <TextBox Grid.Column="1"
                                           Style="{StaticResource FormTextBox}"
                                           Text="{Binding LiveTestCounterparty, UpdateSourceTrigger=PropertyChanged}" />
                                  <TextBlock Grid.Column="2" VerticalAlignment="Center" HorizontalAlignment="Center"
                                             FontFamily="Segoe MDL2 Assets" FontSize="{StaticResource FontSizeBase}">
                                    <TextBlock.Style>
                                      <Style TargetType="TextBlock">
                                        <Setter Property="Text" Value="&#xE711;" />
                                        <Setter Property="Foreground" Value="{DynamicResource AppTextMuted}" />
                                        <Style.Triggers>
                                          <DataTrigger Binding="{Binding LiveTestCounterpartyHit}" Value="True">
                                            <Setter Property="Text" Value="&#xE73E;" />
                                            <Setter Property="Foreground" Value="{DynamicResource AppUp}" />
                                          </DataTrigger>
                                        </Style.Triggers>
                                      </Style>
                                    </TextBlock.Style>
                                  </TextBlock>
                                </Grid>
                                <Grid Margin="0,6,0,0">
                                  <Grid.ColumnDefinitions>
                                    <ColumnDefinition Width="100" />
                                    <ColumnDefinition Width="*" />
                                    <ColumnDefinition Width="32" />
                                  </Grid.ColumnDefinitions>
                                  <TextBlock Grid.Column="0" VerticalAlignment="Center"
                                             FontSize="{StaticResource FontSizeXs}"
                                             Foreground="{DynamicResource AppTextMuted}"
                                             Text="{DynamicResource Categories.Rule.LiveTest.Memo}" />
                                  <TextBox Grid.Column="1"
                                           Style="{StaticResource FormTextBox}"
                                           Text="{Binding LiveTestMemo, UpdateSourceTrigger=PropertyChanged}" />
                                  <TextBlock Grid.Column="2" VerticalAlignment="Center" HorizontalAlignment="Center"
                                             FontFamily="Segoe MDL2 Assets" FontSize="{StaticResource FontSizeBase}">
                                    <TextBlock.Style>
                                      <Style TargetType="TextBlock">
                                        <Setter Property="Text" Value="&#xE711;" />
                                        <Setter Property="Foreground" Value="{DynamicResource AppTextMuted}" />
                                        <Style.Triggers>
                                          <DataTrigger Binding="{Binding LiveTestMemoHit}" Value="True">
                                            <Setter Property="Text" Value="&#xE73E;" />
                                            <Setter Property="Foreground" Value="{DynamicResource AppUp}" />
                                          </DataTrigger>
                                        </Style.Triggers>
                                      </Style>
                                    </TextBlock.Style>
                                  </TextBlock>
                                </Grid>
                              </StackPanel>
                            </Border>
                          </StackPanel>
                        </Expander>
                      </StackPanel>

                      <!--  Buttons  -->
                      <StackPanel Grid.Column="2" Orientation="Horizontal" VerticalAlignment="Center">
                        <Button
                            Width="28" Height="28" Margin="0,0,4,0"
                            Command="{Binding DataContext.BeginEditRuleCommand, RelativeSource={RelativeSource AncestorType=UserControl}}"
                            CommandParameter="{Binding}"
                            ToolTip="{DynamicResource Alerts.Edit}">
                          <Button.Style>
                            <Style BasedOn="{StaticResource BtnIcon}" TargetType="Button">
                              <Setter Property="Visibility" Value="Visible" />
                              <Style.Triggers>
                                <DataTrigger Binding="{Binding IsEditing}" Value="True">
                                  <Setter Property="Visibility" Value="Collapsed" />
                                </DataTrigger>
                              </Style.Triggers>
                            </Style>
                          </Button.Style>
                          <TextBlock FontFamily="Segoe MDL2 Assets" FontSize="{StaticResource FontSizeXs}"
                                     Foreground="{DynamicResource AppTextPrimary}" Text="&#xE70F;" />
                        </Button>

                        <Button
                            Width="28" Height="28"
                            Command="{Binding DataContext.DeleteRuleCommand, RelativeSource={RelativeSource AncestorType=UserControl}}"
                            CommandParameter="{Binding}"
                            ToolTip="{DynamicResource Alerts.Delete}">
                          <Button.Style>
                            <Style BasedOn="{StaticResource DataGridDeleteBtn}" TargetType="Button">
                              <Setter Property="Visibility" Value="Visible" />
                              <Style.Triggers>
                                <DataTrigger Binding="{Binding IsEditing}" Value="True">
                                  <Setter Property="Visibility" Value="Collapsed" />
                                </DataTrigger>
                              </Style.Triggers>
                            </Style>
                          </Button.Style>
                          <TextBlock FontFamily="Segoe MDL2 Assets" FontSize="{StaticResource FontSizeXs}" Text="&#xE74D;" />
                        </Button>

                        <Button
                            Width="28" Height="28" Margin="0,0,4,0"
                            Command="{Binding DataContext.SaveEditRuleCommand, RelativeSource={RelativeSource AncestorType=UserControl}}"
                            CommandParameter="{Binding}"
                            ToolTip="{DynamicResource Alerts.Save}">
                          <Button.Style>
                            <Style BasedOn="{StaticResource BtnIcon}" TargetType="Button">
                              <Setter Property="Visibility" Value="Collapsed" />
                              <Style.Triggers>
                                <DataTrigger Binding="{Binding IsEditing}" Value="True">
                                  <Setter Property="Visibility" Value="Visible" />
                                </DataTrigger>
                              </Style.Triggers>
                            </Style>
                          </Button.Style>
                          <TextBlock FontFamily="Segoe MDL2 Assets" FontSize="{StaticResource FontSizeSm}"
                                     Foreground="{DynamicResource AppUp}" Text="&#xE73E;" />
                        </Button>

                        <Button
                            Width="28" Height="28"
                            Command="{Binding DataContext.CancelEditRuleCommand, RelativeSource={RelativeSource AncestorType=UserControl}}"
                            CommandParameter="{Binding}"
                            ToolTip="{DynamicResource Alerts.Cancel}">
                          <Button.Style>
                            <Style BasedOn="{StaticResource BtnIcon}" TargetType="Button">
                              <Setter Property="Visibility" Value="Collapsed" />
                              <Style.Triggers>
                                <DataTrigger Binding="{Binding IsEditing}" Value="True">
                                  <Setter Property="Visibility" Value="Visible" />
                                </DataTrigger>
                              </Style.Triggers>
                            </Style>
                          </Button.Style>
                          <TextBlock FontFamily="Segoe MDL2 Assets" FontSize="{StaticResource FontSizeXs}"
                                     Foreground="{DynamicResource AppTextSecondary}" Text="&#xE711;" />
                        </Button>
                      </StackPanel>

                      <TextBlock
                          Grid.Row="1"
                          Grid.Column="1"
                          Margin="0,4,0,0"
                          FontSize="{StaticResource FontSizeXs}"
                          Foreground="{DynamicResource AppDown}"
                          Text="{Binding EditError}"
                          Visibility="{Binding EditError, Converter={StaticResource StringToVisibilityConverter}}" />
                    </Grid>
                  </Border>
                </DataTemplate>
              </ItemsControl.ItemTemplate>
            </ItemsControl>
          </ScrollViewer>
        </Border>

        <!--  Add rule form  -->
        <Border
            Grid.Row="2"
            Margin="0,12,0,0"
            Padding="14,12"
            Background="{DynamicResource AppSurface}"
            BorderBrush="{DynamicResource AppBorder}"
            BorderThickness="1"
            CornerRadius="{StaticResource RadiusMd}">
          <StackPanel>
            <TextBlock
                FontSize="{StaticResource FontSizeMd}"
                FontWeight="SemiBold"
                Foreground="{DynamicResource AppTextPrimary}"
                Text="{DynamicResource Categories.Rule.AddForm.Title}" />
            <TextBlock
                Margin="0,4,0,12"
                FontSize="{StaticResource FontSizeSm}"
                Foreground="{DynamicResource AppTextSecondary}"
                Text="{DynamicResource Categories.Rule.AddForm.Hint}"
                TextWrapping="Wrap" />
            <WrapPanel Orientation="Horizontal">
              <StackPanel Style="{StaticResource InlineFormField}">
                <TextBlock Style="{StaticResource InlineFormLabel}" Text="{DynamicResource Categories.Field.Keyword}" />
                <TextBox
                    Width="280"
                    Style="{StaticResource FormTextBox}"
                    Text="{Binding AddRuleKeyword, UpdateSourceTrigger=PropertyChanged}"
                    ToolTip="{DynamicResource Categories.Rule.KeywordHint}" />
              </StackPanel>

              <StackPanel Style="{StaticResource InlineFormField}">
                <TextBlock Style="{StaticResource InlineFormLabel}" Text="{DynamicResource Categories.Field.Category}" />
                <ComboBox
                    Width="200"
                    DisplayMemberPath="Name"
                    ItemsSource="{Binding AvailableCategories}"
                    SelectedItem="{Binding AddRuleCategory}"
                    Style="{StaticResource FormComboBox}"
                    ToolTip="{DynamicResource Categories.Rule.CategoryHint}" />
              </StackPanel>

              <StackPanel Style="{StaticResource InlineFormField}">
                <TextBlock Style="{StaticResource InlineFormLabel}" Text="{DynamicResource Categories.Field.Priority}" />
                <TextBox
                    Width="88"
                    Style="{StaticResource FormTextBox}"
                    Text="{Binding AddRulePriority, UpdateSourceTrigger=PropertyChanged}"
                    ToolTip="{DynamicResource Categories.Rule.PriorityHint}" />
              </StackPanel>

              <StackPanel Style="{StaticResource InlineFormField}" Width="160" VerticalAlignment="Bottom">
                <TextBlock Style="{StaticResource InlineFormLabel}" Text="{DynamicResource Categories.Field.CaseSensitive}" />
                <CheckBox
                    VerticalAlignment="Center"
                    Content="{DynamicResource Categories.Rule.CaseSensitive}"
                    Foreground="{DynamicResource AppTextSecondary}"
                    IsChecked="{Binding AddRuleCaseSensitive}" />
              </StackPanel>
            </WrapPanel>
            <Border
                Margin="0,4,0,0"
                Padding="0,10,0,0"
                BorderBrush="{DynamicResource AppBorder}"
                BorderThickness="0,1,0,0">
              <DockPanel LastChildFill="False">
                <Button
                    DockPanel.Dock="Right"
                    MinWidth="120"
                    MinHeight="36"
                    Padding="16,0"
                    Command="{Binding AddRuleCommand}"
                    Style="{StaticResource BtnPrimary}">
                  <TextBlock Foreground="{Binding Foreground, RelativeSource={RelativeSource AncestorType=Button}}"
                             Text="{DynamicResource Categories.Rule.Add}" />
                </Button>
              </DockPanel>
            </Border>
            <Expander Margin="0,10,0,0"
                      Foreground="{DynamicResource AppTextSecondary}"
                      Header="{DynamicResource Categories.Rule.Advanced}">
              <StackPanel Margin="0,8,0,0">
                <Grid Margin="0,0,0,6">
                  <Grid.ColumnDefinitions>
                    <ColumnDefinition Width="100" />
                    <ColumnDefinition Width="*" />
                  </Grid.ColumnDefinitions>
                  <TextBlock Grid.Column="0" VerticalAlignment="Center"
                             FontSize="{StaticResource FontSizeXs}"
                             Foreground="{DynamicResource AppTextMuted}"
                             Text="{DynamicResource Categories.Rule.Name}" />
                  <TextBox Grid.Column="1"
                           Style="{StaticResource FormTextBox}"
                           Text="{Binding AddRuleName, UpdateSourceTrigger=PropertyChanged}" />
                </Grid>
                <TextBlock FontSize="{StaticResource FontSizeXs}"
                           Foreground="{DynamicResource AppTextMuted}"
                           Text="{DynamicResource Categories.Rule.MatchField}" />
                <StackPanel Margin="0,4,0,8" Orientation="Horizontal">
                  <RadioButton Margin="0,0,12,0" GroupName="AddRuleField"
                               Content="{DynamicResource Categories.Rule.MatchField.Counterparty}"
                               IsChecked="{Binding AddRuleMatchField, Converter={StaticResource EnumToBoolConverter}, ConverterParameter=Counterparty}" />
                  <RadioButton Margin="0,0,12,0" GroupName="AddRuleField"
                               Content="{DynamicResource Categories.Rule.MatchField.Memo}"
                               IsChecked="{Binding AddRuleMatchField, Converter={StaticResource EnumToBoolConverter}, ConverterParameter=Memo}" />
                  <RadioButton Margin="0,0,12,0" GroupName="AddRuleField"
                               Content="{DynamicResource Categories.Rule.MatchField.Either}"
                               IsChecked="{Binding AddRuleMatchField, Converter={StaticResource EnumToBoolConverter}, ConverterParameter=Either}" />
                  <RadioButton GroupName="AddRuleField"
                               Content="{DynamicResource Categories.Rule.MatchField.AnyText}"
                               IsChecked="{Binding AddRuleMatchField, Converter={StaticResource EnumToBoolConverter}, ConverterParameter=AnyText}" />
                </StackPanel>
                <TextBlock FontSize="{StaticResource FontSizeXs}"
                           Foreground="{DynamicResource AppTextMuted}"
                           Text="{DynamicResource Categories.Rule.MatchType}" />
                <StackPanel Margin="0,4,0,8" Orientation="Horizontal">
                  <RadioButton Margin="0,0,12,0" GroupName="AddRuleType"
                               Content="{DynamicResource Categories.Rule.MatchType.Contains}"
                               IsChecked="{Binding AddRuleMatchType, Converter={StaticResource EnumToBoolConverter}, ConverterParameter=Contains}" />
                  <RadioButton Margin="0,0,12,0" GroupName="AddRuleType"
                               Content="{DynamicResource Categories.Rule.MatchType.Equals}"
                               IsChecked="{Binding AddRuleMatchType, Converter={StaticResource EnumToBoolConverter}, ConverterParameter=Equals}" />
                  <RadioButton Margin="0,0,12,0" GroupName="AddRuleType"
                               Content="{DynamicResource Categories.Rule.MatchType.StartsWith}"
                               IsChecked="{Binding AddRuleMatchType, Converter={StaticResource EnumToBoolConverter}, ConverterParameter=StartsWith}" />
                  <RadioButton GroupName="AddRuleType"
                               Content="{DynamicResource Categories.Rule.MatchType.Regex}"
                               IsChecked="{Binding AddRuleMatchType, Converter={StaticResource EnumToBoolConverter}, ConverterParameter=Regex}" />
                </StackPanel>
                <TextBlock FontSize="{StaticResource FontSizeXs}"
                           Foreground="{DynamicResource AppTextMuted}"
                           Text="{DynamicResource Categories.Rule.AppliesTo}" />
                <StackPanel Margin="0,4,0,0" Orientation="Horizontal">
                  <CheckBox Margin="0,0,12,0"
                            Content="{DynamicResource Categories.Rule.AppliesTo.Manual}"
                            IsChecked="{Binding AddRuleAppliesToManual}" />
                  <CheckBox Content="{DynamicResource Categories.Rule.AppliesTo.Import}"
                            IsChecked="{Binding AddRuleAppliesToImport}" />
                </StackPanel>
              </StackPanel>
            </Expander>

            <TextBlock
                Margin="0,8,0,0"
                FontSize="{StaticResource FontSizeXs}"
                Foreground="{DynamicResource AppDown}"
                Text="{Binding AddRuleError}"
                Visibility="{Binding AddRuleError, Converter={StaticResource StringToVisibilityConverter}}" />
          </StackPanel>
        </Border>
      </Grid>
    </TabItem>

    <TabItem Header="{DynamicResource Categories.Tab.Budgets}">
      <Grid Margin="0,12,0,0">
        <Grid.RowDefinitions>
          <RowDefinition Height="Auto" />
          <RowDefinition Height="*" />
          <RowDefinition Height="Auto" />
        </Grid.RowDefinitions>

        <TextBlock
            Grid.Row="0"
            Margin="0,0,0,12"
            FontSize="{StaticResource FontSizeBase}"
            Foreground="{DynamicResource AppTextSecondary}"
            Text="{DynamicResource Categories.Budget.Hint}"
            TextWrapping="Wrap" />

        <Border
            Grid.Row="1"
            Padding="12"
            Background="{DynamicResource AppSurface}"
            BorderBrush="{DynamicResource AppBorder}"
            BorderThickness="1"
            CornerRadius="{StaticResource RadiusMd}">
          <ScrollViewer VerticalScrollBarVisibility="Auto">
            <ItemsControl ItemsSource="{Binding Budgets}">
              <ItemsControl.ItemTemplate>
                <DataTemplate>
                  <Border
                      Margin="0,0,0,6"
                      Padding="10,8"
                      Background="{DynamicResource AppBackground}"
                      BorderBrush="{DynamicResource AppBorder}"
                      BorderThickness="1"
                      CornerRadius="{StaticResource RadiusSm}">
                    <Grid>
                      <Grid.ColumnDefinitions>
                        <ColumnDefinition Width="120" />
                        <ColumnDefinition Width="*" />
                        <ColumnDefinition Width="Auto" />
                        <ColumnDefinition Width="Auto" />
                      </Grid.ColumnDefinitions>

                      <TextBlock
                          Grid.Column="0"
                          VerticalAlignment="Center"
                          FontFamily="{StaticResource FontTabular}"
                          FontSize="{StaticResource FontSizeBase}"
                          FontWeight="SemiBold"
                          Foreground="{DynamicResource AppTextPrimary}"
                          Text="{Binding PeriodDisplay}" />

                      <!--  View mode  -->
                      <StackPanel Grid.Column="1" Orientation="Horizontal" VerticalAlignment="Center">
                        <StackPanel.Style>
                          <Style TargetType="StackPanel">
                            <Setter Property="Visibility" Value="Visible" />
                            <Style.Triggers>
                              <DataTrigger Binding="{Binding IsEditing}" Value="True">
                                <Setter Property="Visibility" Value="Collapsed" />
                              </DataTrigger>
                            </Style.Triggers>
                          </Style>
                        </StackPanel.Style>
                        <TextBlock
                            VerticalAlignment="Center"
                            FontSize="{StaticResource FontSizeBase}"
                            Foreground="{DynamicResource AppTextSecondary}"
                            Text="{Binding CategoryDisplay}" />
                        <TextBlock
                            Margin="12,0,0,0"
                            VerticalAlignment="Center"
                            FontSize="{StaticResource FontSizeBase}"
                            Foreground="{DynamicResource AppTextMuted}"
                            Text="{Binding Note}" />
                      </StackPanel>

                      <!--  Edit mode  -->
                      <Grid Grid.Column="1">
                        <Grid.Style>
                          <Style TargetType="Grid">
                            <Setter Property="Visibility" Value="Collapsed" />
                            <Style.Triggers>
                              <DataTrigger Binding="{Binding IsEditing}" Value="True">
                                <Setter Property="Visibility" Value="Visible" />
                              </DataTrigger>
                            </Style.Triggers>
                          </Style>
                        </Grid.Style>
                        <Grid.ColumnDefinitions>
                          <ColumnDefinition Width="*" />
                        </Grid.ColumnDefinitions>
                        <TextBox
                            Grid.Column="0"
                            Style="{StaticResource FormTextBox}"
                            Text="{Binding EditNote, UpdateSourceTrigger=PropertyChanged}" />
                      </Grid>

                      <!--  Amount column  -->
                      <StackPanel Grid.Column="2" Margin="12,0" Orientation="Horizontal" VerticalAlignment="Center">
                        <TextBlock
                            VerticalAlignment="Center"
                            FontFamily="{StaticResource FontTabular}"
                            FontSize="{StaticResource FontSizeBase}"
                            FontWeight="SemiBold"
                            Foreground="{DynamicResource AppTextPrimary}"
                            Text="{Binding Amount, StringFormat=NT$\{0:N0\}}">
                          <TextBlock.Style>
                            <Style BasedOn="{StaticResource {x:Type TextBlock}}" TargetType="TextBlock">
                              <Setter Property="Visibility" Value="Visible" />
                              <Style.Triggers>
                                <DataTrigger Binding="{Binding IsEditing}" Value="True">
                                  <Setter Property="Visibility" Value="Collapsed" />
                                </DataTrigger>
                              </Style.Triggers>
                            </Style>
                          </TextBlock.Style>
                        </TextBlock>
                        <TextBox
                            Width="120"
                            Text="{Binding EditAmount, UpdateSourceTrigger=PropertyChanged}">
                          <TextBox.Style>
                            <Style BasedOn="{StaticResource FormTextBox}" TargetType="TextBox">
                              <Setter Property="Visibility" Value="Collapsed" />
                              <Style.Triggers>
                                <DataTrigger Binding="{Binding IsEditing}" Value="True">
                                  <Setter Property="Visibility" Value="Visible" />
                                </DataTrigger>
                              </Style.Triggers>
                            </Style>
                          </TextBox.Style>
                        </TextBox>
                      </StackPanel>

                      <!--  Buttons  -->
                      <StackPanel Grid.Column="3" Orientation="Horizontal" VerticalAlignment="Center">
                        <Button
                            Width="28" Height="28" Margin="0,0,4,0"
                            Command="{Binding DataContext.BeginEditBudgetCommand, RelativeSource={RelativeSource AncestorType=UserControl}}"
                            CommandParameter="{Binding}"
                            ToolTip="{DynamicResource Alerts.Edit}">
                          <Button.Style>
                            <Style BasedOn="{StaticResource BtnIcon}" TargetType="Button">
                              <Setter Property="Visibility" Value="Visible" />
                              <Style.Triggers>
                                <DataTrigger Binding="{Binding IsEditing}" Value="True">
                                  <Setter Property="Visibility" Value="Collapsed" />
                                </DataTrigger>
                              </Style.Triggers>
                            </Style>
                          </Button.Style>
                          <TextBlock FontFamily="Segoe MDL2 Assets" FontSize="{StaticResource FontSizeXs}"
                                     Foreground="{DynamicResource AppTextPrimary}" Text="&#xE70F;" />
                        </Button>
                        <Button
                            Width="28" Height="28"
                            Command="{Binding DataContext.DeleteBudgetCommand, RelativeSource={RelativeSource AncestorType=UserControl}}"
                            CommandParameter="{Binding}"
                            ToolTip="{DynamicResource Alerts.Delete}">
                          <Button.Style>
                            <Style BasedOn="{StaticResource DataGridDeleteBtn}" TargetType="Button">
                              <Setter Property="Visibility" Value="Visible" />
                              <Style.Triggers>
                                <DataTrigger Binding="{Binding IsEditing}" Value="True">
                                  <Setter Property="Visibility" Value="Collapsed" />
                                </DataTrigger>
                              </Style.Triggers>
                            </Style>
                          </Button.Style>
                          <TextBlock FontFamily="Segoe MDL2 Assets" FontSize="{StaticResource FontSizeXs}" Text="&#xE74D;" />
                        </Button>
                        <Button
                            Width="28" Height="28" Margin="0,0,4,0"
                            Command="{Binding DataContext.SaveEditBudgetCommand, RelativeSource={RelativeSource AncestorType=UserControl}}"
                            CommandParameter="{Binding}"
                            ToolTip="{DynamicResource Alerts.Save}">
                          <Button.Style>
                            <Style BasedOn="{StaticResource BtnIcon}" TargetType="Button">
                              <Setter Property="Visibility" Value="Collapsed" />
                              <Style.Triggers>
                                <DataTrigger Binding="{Binding IsEditing}" Value="True">
                                  <Setter Property="Visibility" Value="Visible" />
                                </DataTrigger>
                              </Style.Triggers>
                            </Style>
                          </Button.Style>
                          <TextBlock FontFamily="Segoe MDL2 Assets" FontSize="{StaticResource FontSizeSm}"
                                     Foreground="{DynamicResource AppUp}" Text="&#xE73E;" />
                        </Button>
                        <Button
                            Width="28" Height="28"
                            Command="{Binding DataContext.CancelEditBudgetCommand, RelativeSource={RelativeSource AncestorType=UserControl}}"
                            CommandParameter="{Binding}"
                            ToolTip="{DynamicResource Alerts.Cancel}">
                          <Button.Style>
                            <Style BasedOn="{StaticResource BtnIcon}" TargetType="Button">
                              <Setter Property="Visibility" Value="Collapsed" />
                              <Style.Triggers>
                                <DataTrigger Binding="{Binding IsEditing}" Value="True">
                                  <Setter Property="Visibility" Value="Visible" />
                                </DataTrigger>
                              </Style.Triggers>
                            </Style>
                          </Button.Style>
                          <TextBlock FontFamily="Segoe MDL2 Assets" FontSize="{StaticResource FontSizeXs}"
                                     Foreground="{DynamicResource AppTextSecondary}" Text="&#xE711;" />
                        </Button>
                      </StackPanel>
                    </Grid>
                  </Border>
                </DataTemplate>
              </ItemsControl.ItemTemplate>
            </ItemsControl>
          </ScrollViewer>
        </Border>

        <!--  Add budget form  -->
        <Border
            Grid.Row="2"
            Margin="0,12,0,0"
            Padding="14,12"
            Background="{DynamicResource AppSurface}"
            BorderBrush="{DynamicResource AppBorder}"
            BorderThickness="1"
            CornerRadius="{StaticResource RadiusMd}">
          <StackPanel>
            <TextBlock
                FontSize="{StaticResource FontSizeMd}"
                FontWeight="SemiBold"
                Foreground="{DynamicResource AppTextPrimary}"
                Text="{DynamicResource Categories.Budget.AddForm.Title}" />
            <TextBlock
                Margin="0,4,0,12"
                FontSize="{StaticResource FontSizeSm}"
                Foreground="{DynamicResource AppTextSecondary}"
                Text="{DynamicResource Categories.Budget.AddForm.Hint}"
                TextWrapping="Wrap" />
            <WrapPanel Orientation="Horizontal">
              <StackPanel Style="{StaticResource InlineFormField}">
                <TextBlock Style="{StaticResource InlineFormLabel}" Text="{DynamicResource Categories.Field.BudgetMode}" />
                <ComboBox
                    Width="120"
                    ItemsSource="{Binding BudgetModeOptions}"
                    SelectedItem="{Binding AddBudgetMode}"
                    Style="{StaticResource FormComboBox}">
                  <ComboBox.ItemTemplate>
                    <DataTemplate>
                      <TextBlock>
                        <TextBlock.Style>
                          <Style TargetType="TextBlock">
                            <Setter Property="Text" Value="{DynamicResource Categories.Budget.Mode.Monthly}" />
                            <Style.Triggers>
                              <DataTrigger Binding="{Binding}" Value="Yearly">
                                <Setter Property="Text" Value="{DynamicResource Categories.Budget.Mode.Yearly}" />
                              </DataTrigger>
                            </Style.Triggers>
                          </Style>
                        </TextBlock.Style>
                      </TextBlock>
                    </DataTemplate>
                  </ComboBox.ItemTemplate>
                </ComboBox>
              </StackPanel>

              <StackPanel Style="{StaticResource InlineFormField}">
                <TextBlock Style="{StaticResource InlineFormLabel}" Text="{DynamicResource Categories.Field.Year}" />
                <TextBox
                    Width="84"
                    Style="{StaticResource FormTextBox}"
                    Text="{Binding AddBudgetYear, UpdateSourceTrigger=PropertyChanged}"
                    ToolTip="{DynamicResource Categories.Budget.YearHint}" />
              </StackPanel>

              <StackPanel Style="{StaticResource InlineFormField}">
                <TextBlock Style="{StaticResource InlineFormLabel}" Text="{DynamicResource Categories.Field.Month}" />
                <TextBox
                    Width="72"
                    Style="{StaticResource FormTextBox}"
                    Text="{Binding AddBudgetMonth, UpdateSourceTrigger=PropertyChanged}"
                    ToolTip="{DynamicResource Categories.Budget.MonthHint}" />
              </StackPanel>

              <StackPanel Style="{StaticResource InlineFormField}">
                <TextBlock Style="{StaticResource InlineFormLabel}" Text="{DynamicResource Categories.Field.Category}" />
                <ComboBox
                    Width="240"
                    DisplayMemberPath="Name"
                    ItemsSource="{Binding AvailableCategories}"
                    SelectedItem="{Binding AddBudgetCategory}"
                    Style="{StaticResource FormComboBox}"
                    ToolTip="{DynamicResource Categories.Budget.CategoryHint}" />
              </StackPanel>

              <StackPanel Style="{StaticResource InlineFormField}">
                <TextBlock Style="{StaticResource InlineFormLabel}" Text="{DynamicResource Categories.Field.Amount}" />
                <TextBox
                    Width="120"
                    Style="{StaticResource FormTextBox}"
                    Text="{Binding AddBudgetAmount, UpdateSourceTrigger=PropertyChanged}"
                    ToolTip="{DynamicResource Categories.Budget.AmountHint}" />
              </StackPanel>

              <StackPanel Style="{StaticResource InlineFormField}">
                <TextBlock Style="{StaticResource InlineFormLabel}" Text="{DynamicResource Categories.Field.Note}" />
                <TextBox
                    Width="240"
                    Style="{StaticResource FormTextBox}"
                    Text="{Binding AddBudgetNote, UpdateSourceTrigger=PropertyChanged}"
                    ToolTip="{DynamicResource Categories.Budget.NoteHint}" />
              </StackPanel>
            </WrapPanel>
            <Border
                Margin="0,4,0,0"
                Padding="0,10,0,0"
                BorderBrush="{DynamicResource AppBorder}"
                BorderThickness="0,1,0,0">
              <DockPanel LastChildFill="False">
                <Button
                    DockPanel.Dock="Right"
                    MinWidth="100"
                    MinHeight="36"
                    Padding="16,0"
                    Command="{Binding AddBudgetCommand}"
                    Style="{StaticResource BtnPrimary}">
                  <TextBlock Foreground="{Binding Foreground, RelativeSource={RelativeSource AncestorType=Button}}"
                             Text="{DynamicResource Categories.Budget.Add}" />
                </Button>
              </DockPanel>
            </Border>
            <TextBlock
                Margin="0,8,0,0"
                FontSize="{StaticResource FontSizeXs}"
                Foreground="{DynamicResource AppDown}"
                Text="{Binding AddBudgetError}"
                Visibility="{Binding AddBudgetError, Converter={StaticResource StringToVisibilityConverter}}" />
          </StackPanel>
        </Border>
      </Grid>
    </TabItem>
    </TabControl>
  </Grid>
</UserControl>
