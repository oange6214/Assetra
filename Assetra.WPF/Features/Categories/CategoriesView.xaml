                                                        ToolTip="{DynamicResource Alerts.Edit}">
                                                        <ui:Button.Style>
                                                            <Style BasedOn="{StaticResource {x:Type ui:Button}}" TargetType="{x:Type ui:Button}">
                          <Setter Property="Appearance" Value="Transparent" />
                                                                <Setter Property="Visibility" Value="Visible" />
                                                                <Style.Triggers>
                                                                    <DataTrigger Binding="{Binding IsEditing}" Value="True">
                                                                        <Setter Property="Visibility" Value="Collapsed" />
                                                                    </DataTrigger>
                                                                </Style.Triggers>
                                                            </Style>
                                                        </ui:Button.Style>
                                                        <ui:SymbolIcon
                                                            FontSize="{StaticResource FontSizeXs}"
                                                            Foreground="{DynamicResource AppTextPrimary}"
                                                            Symbol="Edit24" />
                                                    </ui:Button>

                                                    <ui:Button
                                                        Width="28"
                                                        Height="28"
                                                        Command="{Binding DataContext.DeleteRuleCommand, RelativeSource={RelativeSource AncestorType=UserControl}}"
                                                        CommandParameter="{Binding}"
                                                        ToolTip="{DynamicResource Alerts.Delete}">
                                                        <ui:Button.Style>
                                                            <Style BasedOn="{StaticResource {x:Type ui:Button}}" TargetType="{x:Type ui:Button}">
                          <Setter Property="Appearance" Value="Transparent" />
                                                                <Setter Property="Visibility" Value="Visible" />
                                                                <Style.Triggers>
                                                                    <DataTrigger Binding="{Binding IsEditing}" Value="True">
                                                                        <Setter Property="Visibility" Value="Collapsed" />
                                                                    </DataTrigger>
