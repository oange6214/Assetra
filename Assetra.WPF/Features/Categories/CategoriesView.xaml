                                                                                        </DataTrigger>
                                                                                    </Style.Triggers>
                                                                                </Style>
                                                                            </ui:SymbolIcon.Style>
                                                                        </ui:SymbolIcon>
                                                                    </Grid>
                                                                    <Grid Margin="0,6,0,0">
