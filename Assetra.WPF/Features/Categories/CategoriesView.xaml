                                            IsChecked="{Binding AddRuleMatchField, Converter={StaticResource EnumToBoolConverter}, ConverterParameter=Counterparty}" />
                                        <RadioButton
                                            Margin="0,0,12,0"
                                            Content="{DynamicResource Categories.Rule.MatchField.Memo}"
                                            GroupName="AddRuleField"
                                            IsChecked="{Binding AddRuleMatchField, Converter={StaticResource EnumToBoolConverter}, ConverterParameter=Memo}" />
                                        <RadioButton
                                            Margin="0,0,12,0"
                                            Content="{DynamicResource Categories.Rule.MatchField.Either}"
                                            GroupName="AddRuleField"
                                            IsChecked="{Binding AddRuleMatchField, Converter={StaticResource EnumToBoolConverter}, ConverterParameter=Either}" />
                                        <RadioButton
                                            Content="{DynamicResource Categories.Rule.MatchField.AnyText}"
                                            GroupName="AddRuleField"
                                            IsChecked="{Binding AddRuleMatchField, Converter={StaticResource EnumToBoolConverter}, ConverterParameter=AnyText}" />
                                    </StackPanel>
                                    <TextBlock
                                        FontSize="{StaticResource FontSizeXs}"
