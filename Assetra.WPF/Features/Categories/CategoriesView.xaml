                        <StackPanel>
                            <TextBlock
                                FontSize="{StaticResource FontSizeMd}"
                                FontWeight="SemiBold"
                                Foreground="{DynamicResource AppTextPrimary}"
                                Text="{DynamicResource Categories.Rule.AddForm.Title}" />
                            <TextBlock
                                Margin="0,4,0,12"
                                FontSize="{StaticResource FontSizeSm}"
                                Foreground="{DynamicResource AppTextSecondary}"
                                Text="{DynamicResource Categories.Rule.AddForm.Hint}"
                                TextWrapping="Wrap" />
                            <WrapPanel Orientation="Horizontal">
                                <StackPanel Style="{StaticResource InlineFormField}">
                                    <TextBlock Style="{StaticResource InlineFormLabel}" Text="{DynamicResource Categories.Field.Keyword}" />
