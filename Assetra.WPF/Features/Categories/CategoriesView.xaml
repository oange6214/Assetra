                                                        Height="28"
                                                        Margin="0,0,4,0"
                                                        Command="{Binding DataContext.BeginEditBudgetCommand, RelativeSource={RelativeSource AncestorType=UserControl}}"
                                                        CommandParameter="{Binding}"
                                                        ToolTip="{DynamicResource Alerts.Edit}">
                                                        <ui:Button.Style>
                                                            <Style BasedOn="{StaticResource {x:Type ui:Button}}" TargetType="{x:Type ui:Button}">
                          <Setter Property="Appearance" Value="Transparent" />
                                                                <Setter Property="Visibility" Value="Visible" />
                                                                <Style.Triggers>
                                                                    <DataTrigger Binding="{Binding IsEditing}" Value="True">
                                                                        <Setter Property="Visibility" Value="Collapsed" />
                                                                    </DataTrigger>
                                                                </Style.Triggers>
                                                            </Style>
                                                        </ui:Button.Style>
                                                        <ui:SymbolIcon
                                                            FontSize="{StaticResource FontSizeXs}"
                                                            Foreground="{DynamicResource AppTextPrimary}"
                                                            Symbol="Edit24" />
                                                    </ui:Button>
                                                    <ui:Button
                                                        Width="28"
                                                        Height="28"
                                                        Command="{Binding DataContext.DeleteBudgetCommand, RelativeSource={RelativeSource AncestorType=UserControl}}"
                                                        CommandParameter="{Binding}"
                                                        ToolTip="{DynamicResource Alerts.Delete}">
                                                        <ui:Button.Style>
                                                            <Style BasedOn="{StaticResource {x:Type ui:Button}}" TargetType="{x:Type ui:Button}">
                          <Setter Property="Appearance" Value="Transparent" />
                                                                <Setter Property="Visibility" Value="Visible" />
                                                                <Style.Triggers>
                                                                    <DataTrigger Binding="{Binding IsEditing}" Value="True">
                                                                        <Setter Property="Visibility" Value="Collapsed" />
                                                                    </DataTrigger>
                                                                </Style.Triggers>
                                                            </Style>
                                                        </ui:Button.Style>
                                                        <ui:SymbolIcon FontSize="{StaticResource FontSizeXs}" Symbol="Delete24" Foreground="{DynamicResource AppDanger}" />
                                                    </ui:Button>
                                                    <ui:Button
                                                        Width="28"
                                                        Height="28"
                                                        Margin="0,0,4,0"
                                                        Command="{Binding DataContext.SaveEditBudgetCommand, RelativeSource={RelativeSource AncestorType=UserControl}}"
                                                        CommandParameter="{Binding}"
                                                        ToolTip="{DynamicResource Alerts.Save}">
                                                        <ui:Button.Style>
                                                            <Style BasedOn="{StaticResource {x:Type ui:Button}}" TargetType="{x:Type ui:Button}">
                          <Setter Property="Appearance" Value="Transparent" />
                                                                <Setter Property="Visibility" Value="Collapsed" />
                                                                <Style.Triggers>
                                                                    <DataTrigger Binding="{Binding IsEditing}" Value="True">
                                                                        <Setter Property="Visibility" Value="Visible" />
                                                                    </DataTrigger>
                                                                </Style.Triggers>
                                                            </Style>
                                                        </ui:Button.Style>
                                                        <ui:SymbolIcon
                                                            FontSize="{StaticResource FontSizeSm}"
                                                            Foreground="{DynamicResource AppUp}"
                                                            Symbol="Checkmark24" />
                                                    </ui:Button>
                                                    <ui:Button
                                                        Width="28"
                                                        Height="28"
                                                        Command="{Binding DataContext.CancelEditBudgetCommand, RelativeSource={RelativeSource AncestorType=UserControl}}"
                                                        CommandParameter="{Binding}"
                                                        ToolTip="{DynamicResource Alerts.Cancel}">
                                                        <ui:Button.Style>
                                                            <Style BasedOn="{StaticResource {x:Type ui:Button}}" TargetType="{x:Type ui:Button}">
                          <Setter Property="Appearance" Value="Transparent" />
                                                                <Setter Property="Visibility" Value="Collapsed" />
                                                                <Style.Triggers>
                                                                    <DataTrigger Binding="{Binding IsEditing}" Value="True">
                                                                        <Setter Property="Visibility" Value="Visible" />
                                                                    </DataTrigger>
                                                                </Style.Triggers>
                                                            </Style>
                                                        </ui:Button.Style>
                                                        <ui:SymbolIcon
                                                            FontSize="{StaticResource FontSizeXs}"
                                                            Foreground="{DynamicResource AppTextSecondary}"
                                                            Symbol="Dismiss24" />
                                                    </ui:Button>
                                                </StackPanel>
                                            </Grid>
                                        </Border>
                                    </DataTemplate>
                                </ItemsControl.ItemTemplate>
                            </ItemsControl>
                        </ScrollViewer>
                    </Border>

                    <!--  Add budget form  -->
                    <Border
                        Grid.Row="2"
                        Margin="0,12,0,0"
                        Padding="14,12"
                        Background="{DynamicResource AppSurface}"
                        BorderBrush="{DynamicResource AppBorder}"
                        BorderThickness="1"
                        CornerRadius="{StaticResource RadiusMd}">
                        <StackPanel>
                            <TextBlock
                                FontSize="{StaticResource FontSizeMd}"
                                FontWeight="SemiBold"
                                Foreground="{DynamicResource AppTextPrimary}"
                                Text="{DynamicResource Categories.Budget.AddForm.Title}" />
                            <TextBlock
                                Margin="0,4,0,12"
                                FontSize="{StaticResource FontSizeSm}"
                                Foreground="{DynamicResource AppTextSecondary}"
                                Text="{DynamicResource Categories.Budget.AddForm.Hint}"
                                TextWrapping="Wrap" />
                            <WrapPanel Orientation="Horizontal">
                                <StackPanel Style="{StaticResource InlineFormField}">
                                    <TextBlock Style="{StaticResource InlineFormLabel}" Text="{DynamicResource Categories.Field.BudgetMode}" />
                                    <ComboBox
                                        Width="120"
                                        ItemsSource="{Binding BudgetModeOptions}"
                                        SelectedItem="{Binding AddBudgetMode}"
                                        Style="{StaticResource InlineComboBox}">
                                        <ComboBox.ItemTemplate>
                                            <DataTemplate>
                                                <TextBlock>
                                                    <TextBlock.Style>
                                                        <Style TargetType="TextBlock">
                                                            <Setter Property="Text" Value="{DynamicResource Categories.Budget.Mode.Monthly}" />
                                                            <Style.Triggers>
                                                                <DataTrigger Binding="{Binding}" Value="Yearly">
                                                                    <Setter Property="Text" Value="{DynamicResource Categories.Budget.Mode.Yearly}" />
                                                                </DataTrigger>
                                                            </Style.Triggers>
                                                        </Style>
                                                    </TextBlock.Style>
                                                </TextBlock>
                                            </DataTemplate>
                                        </ComboBox.ItemTemplate>
                                    </ComboBox>
                                </StackPanel>

                                <StackPanel Style="{StaticResource InlineFormField}">
                                    <TextBlock Style="{StaticResource InlineFormLabel}" Text="{DynamicResource Categories.Field.Year}" />
                                    <ui:TextBox
                                        Width="84"
                                        Style="{StaticResource InlineNumericTextBox}"
                                        Text="{Binding AddBudgetYear, UpdateSourceTrigger=PropertyChanged}"
                                        ToolTip="{DynamicResource Categories.Budget.YearHint}" />
                                </StackPanel>

                                <StackPanel Style="{StaticResource InlineFormField}">
                                    <TextBlock Style="{StaticResource InlineFormLabel}" Text="{DynamicResource Categories.Field.Month}" />
                                    <ui:TextBox
                                        Width="72"
                                        Style="{StaticResource InlineNumericTextBox}"
                                        Text="{Binding AddBudgetMonth, UpdateSourceTrigger=PropertyChanged}"
                                        ToolTip="{DynamicResource Categories.Budget.MonthHint}" />
                                </StackPanel>

                                <StackPanel Style="{StaticResource InlineFormField}">
                                    <TextBlock Style="{StaticResource InlineFormLabel}" Text="{DynamicResource Categories.Field.Category}" />
                                    <ComboBox
                                        Width="240"
                                        DisplayMemberPath="Name"
                                        ItemsSource="{Binding AvailableCategories}"
                                        SelectedItem="{Binding AddBudgetCategory}"
                                        Style="{StaticResource InlineComboBox}"
                                        ToolTip="{DynamicResource Categories.Budget.CategoryHint}" />
                                </StackPanel>

                                <StackPanel Style="{StaticResource InlineFormField}">
                                    <TextBlock Style="{StaticResource InlineFormLabel}" Text="{DynamicResource Categories.Field.Amount}" />
                                    <ui:TextBox
                                        Width="120"
                                        Style="{StaticResource InlineNumericTextBox}"
                                        Text="{Binding AddBudgetAmount, UpdateSourceTrigger=PropertyChanged}"
                                        ToolTip="{DynamicResource Categories.Budget.AmountHint}" />
                                </StackPanel>

                                <StackPanel Style="{StaticResource InlineFormField}">
                                    <TextBlock Style="{StaticResource InlineFormLabel}" Text="{DynamicResource Categories.Field.Note}" />
                                    <ui:TextBox
                                        Width="240"
                                        Style="{StaticResource InlineTextBox}"
                                        Text="{Binding AddBudgetNote, UpdateSourceTrigger=PropertyChanged}"
                                        ToolTip="{DynamicResource Categories.Budget.NoteHint}" />
                                </StackPanel>
                            </WrapPanel>
                            <Border
                                Margin="0,4,0,0"
                                Padding="0,10,0,0"
                                BorderBrush="{DynamicResource AppBorder}"
                                BorderThickness="0,1,0,0">
                                <DockPanel LastChildFill="False">
                                    <ui:Button
                                        MinWidth="100"
                                        MinHeight="36"
                                        Padding="16,0"
                                        Appearance="Primary"
                                        Command="{Binding AddBudgetCommand}"
                                        DockPanel.Dock="Right">
                                        <TextBlock Foreground="{Binding Foreground, RelativeSource={RelativeSource AncestorType=Button}}" Text="{DynamicResource Categories.Budget.Add}" />
                                    </ui:Button>
                                </DockPanel>
                            </Border>
                            <TextBlock
                                Margin="0,8,0,0"
                                FontSize="{StaticResource FontSizeXs}"
                                Foreground="{DynamicResource AppDown}"
                                Text="{Binding AddBudgetError}"
                                Visibility="{Binding AddBudgetError, Converter={StaticResource StringToVisibilityConverter}}" />
                        </StackPanel>
                    </Border>
                </Grid>
            </ui:TabViewItem>
        </ui:TabView>
    </Grid>
</UserControl>
