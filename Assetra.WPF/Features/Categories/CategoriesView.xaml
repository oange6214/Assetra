<UserControl
    x:Class="Assetra.WPF.Features.Categories.CategoriesView"
    xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
    xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
    xmlns:behaviors="clr-namespace:Assetra.WPF.Infrastructure.Behaviors"
    xmlns:ctrl="clr-namespace:Assetra.WPF.Controls"
    xmlns:d="http://schemas.microsoft.com/expression/blend/2008"
    xmlns:mc="http://schemas.openxmlformats.org/markup-compatibility/2006"
    xmlns:ds="clr-namespace:Assetra.WPF.DesignSystem.Controls"
    xmlns:vm="clr-namespace:Assetra.WPF.Features.Categories"
    x:Name="Root"
    d:DataContext="{d:DesignInstance Type={x:Type vm:CategoriesViewModel},
                                     IsDesignTimeCreatable=False}"
    d:DesignHeight="776"
    d:DesignWidth="1100"
    Background="{DynamicResource AppBackground}"
    mc:Ignorable="d">

    <UserControl.Resources>
        <Style x:Key="InlineFormLabel" TargetType="TextBlock">
            <Setter Property="Margin" Value="0,0,0,6" />
            <Setter Property="FontSize" Value="{StaticResource Font.Size.Xs}" />
            <Setter Property="Foreground" Value="{DynamicResource AppTextMuted}" />
        </Style>

        <Style x:Key="InlineFormField" TargetType="StackPanel">
            <Setter Property="Margin" Value="0,0,12,10" />
            <Setter Property="VerticalAlignment" Value="Top" />
        </Style>

        <Style
            x:Key="InlineTextBox"
            BasedOn="{StaticResource AppTextBox}"
            TargetType="TextBox">
            <Setter Property="MinHeight" Value="36" />
            <Setter Property="VerticalContentAlignment" Value="Center" />
        </Style>

        <Style
            x:Key="InlineComboBox"
            BasedOn="{StaticResource AppComboBox}"
            TargetType="ComboBox">
            <Setter Property="MinHeight" Value="36" />
            <Setter Property="VerticalContentAlignment" Value="Center" />
        </Style>

        <Style
            x:Key="InlineNumericTextBox"
            BasedOn="{StaticResource AppTextBox}"
            TargetType="TextBox">
            <Setter Property="MinHeight" Value="36" />
            <Setter Property="VerticalContentAlignment" Value="Center" />
            <Setter Property="FontFamily" Value="{StaticResource Font.Family.Base}" />
            <Setter Property="Typography.NumeralAlignment" Value="Tabular" />
        </Style>

        <Style x:Key="CategoryColorPalette" TargetType="ListBox">
            <Setter Property="Background" Value="Transparent" />
            <Setter Property="BorderThickness" Value="0" />
            <Setter Property="Padding" Value="0" />
            <Setter Property="Margin" Value="0" />
            <Setter Property="HorizontalContentAlignment" Value="Left" />
            <Setter Property="ScrollViewer.HorizontalScrollBarVisibility" Value="Disabled" />
            <Setter Property="ScrollViewer.VerticalScrollBarVisibility" Value="Disabled" />
        </Style>

        <Style x:Key="CategoryColorPaletteItem" TargetType="ListBoxItem">
            <Setter Property="Padding" Value="0" />
            <Setter Property="Margin" Value="0,0,8,8" />
            <Setter Property="FocusVisualStyle" Value="{x:Null}" />
            <Setter Property="HorizontalContentAlignment" Value="Stretch" />
            <Setter Property="VerticalContentAlignment" Value="Stretch" />
            <Setter Property="Template">
                <Setter.Value>
                    <ControlTemplate TargetType="ListBoxItem">
                        <Border
                            x:Name="Outer"
                            Padding="3"
                            Background="Transparent"
                            BorderBrush="{DynamicResource AppBorder}"
                            BorderThickness="1"
                            CornerRadius="{StaticResource Radius.Md}">
                            <ContentPresenter />
                        </Border>
                        <ControlTemplate.Triggers>
                            <Trigger Property="IsMouseOver" Value="True">
                                <Setter TargetName="Outer" Property="BorderBrush" Value="{DynamicResource AppAccent}" />
                            </Trigger>
                            <Trigger Property="IsSelected" Value="True">
                                <Setter TargetName="Outer" Property="BorderBrush" Value="{DynamicResource AppAccent}" />
                                <Setter TargetName="Outer" Property="Background" Value="{DynamicResource AppHover}" />
                            </Trigger>
                        </ControlTemplate.Triggers>
                    </ControlTemplate>
                </Setter.Value>
            </Setter>
        </Style>

        <DataTemplate x:Key="CategoryRowTemplate" DataType="{x:Type vm:CategoryRowViewModel}">
            <Border Style="{StaticResource FormCard}" Margin="0,0,0,6" Padding="10,8">
                <Grid>
                    <Grid.ColumnDefinitions>
                        <ColumnDefinition Width="*" />
                        <ColumnDefinition Width="Auto" />
                    </Grid.ColumnDefinitions>

                    <!--  View mode  -->
                    <StackPanel
                        Grid.Column="0"
                        VerticalAlignment="Center"
                        Orientation="Horizontal">
                        <StackPanel.Style>
                            <Style TargetType="StackPanel">
                                <Setter Property="Visibility" Value="Visible" />
                                <Style.Triggers>
                                    <DataTrigger Binding="{Binding IsEditing}" Value="True">
                                        <Setter Property="Visibility" Value="Collapsed" />
                                    </DataTrigger>
                                </Style.Triggers>
                            </Style>
                        </StackPanel.Style>
                        <TextBlock
                            Margin="0,0,8,0"
                            VerticalAlignment="Center"
                            FontSize="{StaticResource Font.Size.Md}"
                            Text="{Binding Icon}" />
                        <TextBlock
                            VerticalAlignment="Center"
                            FontSize="{StaticResource Font.Size.Base}"
                            FontWeight="SemiBold"
                            Foreground="{DynamicResource AppTextPrimary}"
                            Text="{Binding Name}" />
                        <TextBlock
                            Margin="8,0,0,0"
                            VerticalAlignment="Center"
                            FontSize="{StaticResource Font.Size.Xs}"
                            Foreground="{DynamicResource AppTextMuted}"
                            Text="{DynamicResource Categories.ArchivedTag}"
                            Visibility="{Binding IsArchived, Converter={StaticResource BooleanToVisibilityConverter}}" />
                    </StackPanel>

                    <!--  Edit mode  -->
                    <StackPanel Grid.Column="0" Orientation="Vertical">
                        <StackPanel.Style>
                            <Style TargetType="StackPanel">
                                <Setter Property="Visibility" Value="Collapsed" />
                                <Style.Triggers>
                                    <DataTrigger Binding="{Binding IsEditing}" Value="True">
                                        <Setter Property="Visibility" Value="Visible" />
                                    </DataTrigger>
                                </Style.Triggers>
                            </Style>
                        </StackPanel.Style>
                        <WrapPanel Orientation="Horizontal">
                            <StackPanel Width="152" Margin="0,0,12,8">
                                <TextBlock Style="{StaticResource InlineFormLabel}" Text="{DynamicResource Categories.Field.Icon}" />
                                <ComboBox
                                    ItemsSource="{Binding EditIconOptions}"
                                    SelectedValue="{Binding EditIcon}"
                                    SelectedValuePath="Value"
                                    Style="{StaticResource InlineComboBox}">
                                    <ComboBox.ItemTemplate>
                                        <DataTemplate>
                                            <StackPanel Orientation="Horizontal">
                                                <TextBlock
                                                    Margin="0,0,8,0"
                                                    VerticalAlignment="Center"
                                                    FontSize="{StaticResource Font.Size.Md}"
                                                    Text="{Binding Value}" />
                                                <TextBlock
                                                    VerticalAlignment="Center"
                                                    FontSize="{StaticResource Font.Size.Sm}"
                                                    Foreground="{DynamicResource AppTextSecondary}"
                                                    Text="{Binding Label}" />
                                            </StackPanel>
                                        </DataTemplate>
                                    </ComboBox.ItemTemplate>
                                </ComboBox>
                            </StackPanel>

                            <StackPanel Width="280" Margin="0,0,12,8">
                                <TextBlock Style="{StaticResource InlineFormLabel}" Text="{DynamicResource Categories.Field.Name}" />
                                <TextBox Style="{StaticResource InlineTextBox}" Text="{Binding EditName, UpdateSourceTrigger=PropertyChanged}" />
                            </StackPanel>

                            <StackPanel Width="196" Margin="0,0,0,8">
                                <TextBlock Style="{StaticResource InlineFormLabel}" Text="{DynamicResource Categories.Field.Color}" />
                                <ctrl:HexColorPicker
                                    MinHeight="36"
                                    Presets="{Binding DataContext.ColorOptions, RelativeSource={RelativeSource AncestorType=UserControl}}"
                                    SelectedColorHex="{Binding EditColorHex, Mode=TwoWay}" />
                            </StackPanel>
                        </WrapPanel>
                        <TextBlock
                            Margin="0,4,0,0"
                            FontSize="{StaticResource Font.Size.Xs}"
                            Foreground="{DynamicResource AppDown}"
                            Text="{Binding EditError}"
                            Visibility="{Binding EditError, Converter={StaticResource StringToVisibilityConverter}}" />
                    </StackPanel>

                    <!--  Buttons  -->
                    <StackPanel
                        Grid.Column="1"
                        VerticalAlignment="Center"
                        Orientation="Horizontal">
                        <!--  View mode buttons  -->
                        <Button
                            Width="32"
                            Height="32"
                            Margin="0,0,4,0"
                            Padding="0"
                            Command="{Binding DataContext.BeginEditCommand, RelativeSource={RelativeSource AncestorType=UserControl}}"
                            CommandParameter="{Binding}"
                            ToolTip="{DynamicResource Common.Edit}">
                            <Button.Style>
                                <Style BasedOn="{StaticResource AppIconButton}" TargetType="{x:Type Button}">
                                    <Setter Property="Visibility" Value="Visible" />
                                    <Style.Triggers>
                                        <DataTrigger Binding="{Binding IsEditing}" Value="True">
                                            <Setter Property="Visibility" Value="Collapsed" />
                                        </DataTrigger>
                                    </Style.Triggers>
                                </Style>
                            </Button.Style>
                            <ds:AppIcon
                                FontSize="{StaticResource Font.Size.Xs}"
                                Foreground="{DynamicResource AppTextPrimary}"
                                Symbol="Edit24" />
                        </Button>

                        <Button
                            Width="32"
                            Height="32"
                            Margin="0,0,4,0"
                            Padding="0"
                            Command="{Binding DataContext.ToggleArchiveCommand, RelativeSource={RelativeSource AncestorType=UserControl}}"
                            CommandParameter="{Binding}"
                            ToolTip="{DynamicResource Categories.ToggleArchive}">
                            <Button.Style>
                                <Style BasedOn="{StaticResource AppIconButton}" TargetType="{x:Type Button}">
                                    <Setter Property="Visibility" Value="Visible" />
                                    <Style.Triggers>
                                        <DataTrigger Binding="{Binding IsEditing}" Value="True">
                                            <Setter Property="Visibility" Value="Collapsed" />
                                        </DataTrigger>
                                    </Style.Triggers>
                                </Style>
                            </Button.Style>
                            <ds:AppIcon
                                FontSize="{StaticResource Font.Size.Xs}"
                                Foreground="{DynamicResource AppTextSecondary}"
                                Symbol="Money24" />
                        </Button>

                        <Button
                            Width="32"
                            Height="32"
                            Padding="0"
                                                    Command="{Binding DataContext.RequestDeleteCommand, RelativeSource={RelativeSource AncestorType=UserControl}}"
                            CommandParameter="{Binding}"
                            ToolTip="{DynamicResource Common.Delete}">
                            <Button.Style>
                                <Style BasedOn="{StaticResource AppIconButton}" TargetType="{x:Type Button}">
                                    <Setter Property="Visibility" Value="Visible" />
                                    <Style.Triggers>
                                        <DataTrigger Binding="{Binding IsEditing}" Value="True">
                                            <Setter Property="Visibility" Value="Collapsed" />
                                        </DataTrigger>
                                    </Style.Triggers>
                                </Style>
                            </Button.Style>
                            <ds:AppIcon
                                FontSize="{StaticResource Font.Size.Xs}"
                                Foreground="{DynamicResource AppDanger}"
                                Symbol="Delete24" />
                        </Button>

                        <!--  Edit mode buttons  -->
                        <Button
                            Width="32"
                            Height="32"
                            Margin="0,0,4,0"
                            Padding="0"
                            Command="{Binding DataContext.SaveEditCommand, RelativeSource={RelativeSource AncestorType=UserControl}}"
                            CommandParameter="{Binding}"
                            ToolTip="{DynamicResource Common.Save}">
                            <Button.Style>
                                <Style BasedOn="{StaticResource AppIconButton}" TargetType="{x:Type Button}">
                                    <Setter Property="Visibility" Value="Collapsed" />
                                    <Style.Triggers>
                                        <DataTrigger Binding="{Binding IsEditing}" Value="True">
                                            <Setter Property="Visibility" Value="Visible" />
                                        </DataTrigger>
                                    </Style.Triggers>
                                </Style>
                            </Button.Style>
                            <ds:AppIcon
                                FontSize="{StaticResource Font.Size.Sm}"
                                Foreground="{DynamicResource AppUp}"
                                Symbol="Checkmark24" />
                        </Button>

                        <Button
                            Width="32"
                            Height="32"
                            Padding="0"
                            Command="{Binding DataContext.CancelEditCommand, RelativeSource={RelativeSource AncestorType=UserControl}}"
                            CommandParameter="{Binding}"
                            ToolTip="{DynamicResource Common.Cancel}">
                            <Button.Style>
                                <Style BasedOn="{StaticResource AppIconButton}" TargetType="{x:Type Button}">
                                    <Setter Property="Visibility" Value="Collapsed" />
                                    <Style.Triggers>
                                        <DataTrigger Binding="{Binding IsEditing}" Value="True">
                                            <Setter Property="Visibility" Value="Visible" />
                                        </DataTrigger>
                                    </Style.Triggers>
                                </Style>
                            </Button.Style>
                            <ds:AppIcon
                                FontSize="{StaticResource Font.Size.Xs}"
                                Foreground="{DynamicResource AppTextSecondary}"
                                Symbol="Dismiss24" />
                        </Button>
                    </StackPanel>
                </Grid>
            </Border>
        </DataTemplate>
    </UserControl.Resources>

    <Grid Style="{StaticResource PageRootGrid}">
        <Grid.RowDefinitions>
            <RowDefinition Height="Auto" />
            <RowDefinition Height="*" />
        </Grid.RowDefinitions>

        <!--  Header  -->
        <DockPanel
            Grid.Row="0"
            LastChildFill="False"
            Style="{StaticResource PageHeaderDock}">
            <TextBlock
                DockPanel.Dock="Left"
                Style="{StaticResource PageTitleText}"
                Text="{DynamicResource Categories.Title}" />
            <CheckBox
                VerticalAlignment="Center"
                Content="{DynamicResource Categories.ShowArchived}"
                DockPanel.Dock="Right"
                Foreground="{DynamicResource AppTextSecondary}"
                IsChecked="{Binding ShowArchived}" />
        </DockPanel>

        <TabControl
            Grid.Row="1"
            HorizontalAlignment="Stretch"
            VerticalAlignment="Stretch"
            HorizontalContentAlignment="Stretch"
            VerticalContentAlignment="Stretch"
            Background="Transparent"
            BorderThickness="0">
            <TabItem Header="{DynamicResource Categories.Tab.Categories}">
                <Grid Margin="0,4,0,0">
                    <Grid.RowDefinitions>
                        <RowDefinition Height="Auto" />
                        <RowDefinition Height="*" />
                        <RowDefinition Height="Auto" />
                    </Grid.RowDefinitions>

                    <!--  Toolbar  -->
                    <DockPanel
                        Grid.Row="0"
                        Margin="0,0,0,8"
                        LastChildFill="False">
                        <Button
                            Command="{Binding OpenAddCategoryCommand}"
                            DockPanel.Dock="Right"
                            Style="{StaticResource AppPrimaryButton}"
                            Visibility="{Binding IsAddCategoryOpen, Converter={StaticResource InverseBooleanToVisibilityConverter}}">
                            <StackPanel Style="{StaticResource AppButtonContent}">
                                <ds:AppIcon
                                    Style="{StaticResource AppButtonLeadingIcon}"
                                    VerticalAlignment="Center"
                                    Foreground="{Binding Foreground, RelativeSource={RelativeSource AncestorType={x:Type Button}}}"
                                    Symbol="Add24" />
                                <TextBlock
                                    VerticalAlignment="Center"
                                    Foreground="{Binding Foreground, RelativeSource={RelativeSource AncestorType={x:Type Button}}}"
                                    Text="{DynamicResource Categories.AddForm.Title}" />
                            </StackPanel>
                        </Button>
                    </DockPanel>

                    <!--  Two-column list  -->
                    <Grid Grid.Row="1">
                        <Grid.ColumnDefinitions>
                            <ColumnDefinition Width="*" />
                            <ColumnDefinition Width="16" />
                            <ColumnDefinition Width="*" />
                        </Grid.ColumnDefinitions>

                        <!--  Expense  -->
                        <Border Style="{StaticResource FormCard}"
                            Grid.Column="0"
                            Padding="12"
                            HorizontalAlignment="Stretch"
                            VerticalAlignment="Stretch">
                            <Grid>
                                <Grid.RowDefinitions>
                                    <RowDefinition Height="Auto" />
                                    <RowDefinition Height="*" />
                                </Grid.RowDefinitions>
                                <TextBlock
                                    Grid.Row="0"
                                    Margin="0,0,0,8"
                                    FontSize="{StaticResource Font.Size.Md}"
                                    FontWeight="SemiBold"
                                    Foreground="{DynamicResource AppTextPrimary}"
                                    Text="{DynamicResource Categories.Expense}" />
                                <ScrollViewer Grid.Row="1" VerticalScrollBarVisibility="Auto">
                                    <ItemsControl ItemTemplate="{StaticResource CategoryRowTemplate}" ItemsSource="{Binding ExpenseView}">
                                        <ItemsControl.ItemContainerStyle>
                                            <Style TargetType="{x:Type ContentPresenter}">
                                                <Setter Property="HorizontalAlignment" Value="Stretch" />
                                            </Style>
                                        </ItemsControl.ItemContainerStyle>
                                    </ItemsControl>
                                </ScrollViewer>
                            </Grid>
                        </Border>

                        <!--  Income  -->
                        <Border Style="{StaticResource FormCard}"
                            Grid.Column="2"
                            Padding="12"
                            HorizontalAlignment="Stretch"
                            VerticalAlignment="Stretch">
                            <Grid>
                                <Grid.RowDefinitions>
                                    <RowDefinition Height="Auto" />
                                    <RowDefinition Height="*" />
                                </Grid.RowDefinitions>
                                <TextBlock
                                    Grid.Row="0"
                                    Margin="0,0,0,8"
                                    FontSize="{StaticResource Font.Size.Md}"
                                    FontWeight="SemiBold"
                                    Foreground="{DynamicResource AppTextPrimary}"
                                    Text="{DynamicResource Categories.Income}" />
                                <ScrollViewer Grid.Row="1" VerticalScrollBarVisibility="Auto">
                                    <ItemsControl ItemTemplate="{StaticResource CategoryRowTemplate}" ItemsSource="{Binding IncomeView}">
                                        <ItemsControl.ItemContainerStyle>
                                            <Style TargetType="{x:Type ContentPresenter}">
                                                <Setter Property="HorizontalAlignment" Value="Stretch" />
                                            </Style>
                                        </ItemsControl.ItemContainerStyle>
                                    </ItemsControl>
                                </ScrollViewer>
                            </Grid>
                        </Border>
                    </Grid>

                </Grid>
            </TabItem>

            <TabItem Header="{DynamicResource Categories.Tab.Rules}">
                <Grid Margin="0,4,0,0">
                    <Grid.RowDefinitions>
                        <RowDefinition Height="Auto" />
                        <RowDefinition Height="*" />
                        <RowDefinition Height="Auto" />
                    </Grid.RowDefinitions>

                    <DockPanel
                        Grid.Row="0"
                        Margin="0,0,0,8"
                        LastChildFill="True">
                        <Button
                            Margin="12,0,0,0"
                            Command="{Binding OpenAddRuleCommand}"
                            DockPanel.Dock="Right"
                            Style="{StaticResource AppPrimaryButton}"
                            Visibility="{Binding IsAddRuleOpen, Converter={StaticResource InverseBooleanToVisibilityConverter}}">
                            <StackPanel Orientation="Horizontal">
                                <ds:AppIcon
                                    Margin="0,0,4,0"
                                    VerticalAlignment="Center"
                                    Foreground="{Binding Foreground, RelativeSource={RelativeSource AncestorType={x:Type Button}}}"
                                    Symbol="Add24" />
                                <TextBlock
                                    VerticalAlignment="Center"
                                    Foreground="{Binding Foreground, RelativeSource={RelativeSource AncestorType={x:Type Button}}}"
                                    Text="{DynamicResource Categories.Rule.AddTitle}" />
                            </StackPanel>
                        </Button>
                        <TextBlock
                            VerticalAlignment="Center"
                            FontSize="{StaticResource Font.Size.Base}"
                            Foreground="{DynamicResource AppTextSecondary}"
                            Text="{DynamicResource Categories.Rule.Hint}"
                            TextWrapping="Wrap" />
                    </DockPanel>

                    <Border Style="{StaticResource FormCard}"
                        Grid.Row="1"
                        Padding="12"
                        HorizontalAlignment="Stretch"
                        VerticalAlignment="Stretch">
                        <ScrollViewer VerticalScrollBarVisibility="Auto">
                            <ItemsControl ItemsSource="{Binding Rules}">
                                <ItemsControl.ItemContainerStyle>
                                    <Style TargetType="{x:Type ContentPresenter}">
                                        <Setter Property="HorizontalAlignment" Value="Stretch" />
                                    </Style>
                                </ItemsControl.ItemContainerStyle>
                                <ItemsControl.ItemTemplate>
                                    <DataTemplate>
                                        <Border
                                            Margin="0,0,0,6"
                                            Padding="10,8"
                                            Background="{DynamicResource AppBackground}"
                                            BorderBrush="{DynamicResource AppBorder}"
                                            BorderThickness="1"
                                            CornerRadius="{StaticResource Radius.Sm}">
                                            <Grid>
                                                <Grid.ColumnDefinitions>
                                                    <ColumnDefinition Width="Auto" />
                                                    <ColumnDefinition Width="*" />
                                                    <ColumnDefinition Width="Auto" />
                                                </Grid.ColumnDefinitions>

                                                <CheckBox
                                                    Grid.Column="0"
                                                    Margin="0,0,10,0"
                                                    VerticalAlignment="Center"
                                                    Command="{Binding DataContext.ToggleRuleEnabledCommand, RelativeSource={RelativeSource AncestorType=UserControl}}"
                                                    CommandParameter="{Binding}"
                                                    IsChecked="{Binding IsEnabled, Mode=OneWay}"
                                                    ToolTip="{DynamicResource Categories.Rule.ToggleEnabled}" />

                                                <!--  View mode  -->
                                                <StackPanel
                                                    Grid.Column="1"
                                                    VerticalAlignment="Center"
                                                    Orientation="Horizontal">
                                                    <StackPanel.Style>
                                                        <Style TargetType="StackPanel">
                                                            <Setter Property="Visibility" Value="Visible" />
                                                            <Style.Triggers>
                                                                <DataTrigger Binding="{Binding IsEditing}" Value="True">
                                                                    <Setter Property="Visibility" Value="Collapsed" />
                                                                </DataTrigger>
                                                            </Style.Triggers>
                                                        </Style>
                                                    </StackPanel.Style>
                                                    <TextBlock
                                                        VerticalAlignment="Center"
                                                        FontFamily="{StaticResource Font.Family.Base}"
                                                        FontSize="{StaticResource Font.Size.Base}"
                                                        FontWeight="SemiBold"
                                                        Foreground="{DynamicResource AppTextPrimary}"
                                                        Text="{Binding KeywordPattern}"
                                                        Typography.NumeralAlignment="Tabular" />
                                                    <TextBlock
                                                        Margin="10,0,0,0"
                                                        VerticalAlignment="Center"
                                                        FontSize="{StaticResource Font.Size.Xs}"
                                                        Foreground="{DynamicResource AppTextMuted}"
                                                        Text="→" />
                                                    <TextBlock
                                                        Margin="6,0,0,0"
                                                        VerticalAlignment="Center"
                                                        FontSize="{StaticResource Font.Size.Sm}"
                                                        Foreground="{DynamicResource AppTextSecondary}"
                                                        Text="{Binding CategoryDisplay}" />
                                                    <TextBlock
                                                        Margin="10,0,0,0"
                                                        VerticalAlignment="Center"
                                                        FontSize="{StaticResource Font.Size.Xs}"
                                                        Foreground="{DynamicResource AppTextMuted}"
                                                        Text="{Binding Priority, StringFormat={}P:{0}}" />
                                                </StackPanel>

                                                <!--  Edit mode  -->
                                                <StackPanel Grid.Column="1">
                                                    <StackPanel.Style>
                                                        <Style TargetType="StackPanel">
                                                            <Setter Property="Visibility" Value="Collapsed" />
                                                            <Style.Triggers>
                                                                <DataTrigger Binding="{Binding IsEditing}" Value="True">
                                                                    <Setter Property="Visibility" Value="Visible" />
                                                                </DataTrigger>
                                                            </Style.Triggers>
                                                        </Style>
                                                    </StackPanel.Style>
                                                    <Grid>
                                                        <Grid.ColumnDefinitions>
                                                            <ColumnDefinition Width="*" />
                                                            <ColumnDefinition Width="6" />
                                                            <ColumnDefinition Width="160" />
                                                            <ColumnDefinition Width="6" />
                                                            <ColumnDefinition Width="60" />
                                                            <ColumnDefinition Width="6" />
                                                            <ColumnDefinition Width="Auto" />
                                                        </Grid.ColumnDefinitions>
                                                        <TextBox
                                                            Grid.Column="0"
                                                            Style="{StaticResource InlineTextBox}"
                                                            Text="{Binding EditKeyword, UpdateSourceTrigger=PropertyChanged}" />
                                                        <ComboBox
                                                            Grid.Column="2"
                                                            DisplayMemberPath="Name"
                                                            ItemsSource="{Binding DataContext.AvailableCategories, RelativeSource={RelativeSource AncestorType=UserControl}}"
                                                            SelectedValue="{Binding EditCategoryId}"
                                                            SelectedValuePath="Id"
                                                            Style="{StaticResource InlineComboBox}" />
                                                        <TextBox
                                                            Grid.Column="4"
                                                            Style="{StaticResource InlineNumericTextBox}"
                                                            Text="{Binding EditPriority, UpdateSourceTrigger=PropertyChanged}" />
                                                        <CheckBox
                                                            Grid.Column="6"
                                                            VerticalAlignment="Center"
                                                            Content="{DynamicResource Categories.Rule.CaseSensitive}"
                                                            Foreground="{DynamicResource AppTextSecondary}"
                                                            IsChecked="{Binding EditCaseSensitive}" />
                                                    </Grid>

                                                    <Expander Style="{StaticResource AppExpander}"
                                                        Margin="0,8,0,0"
                                                        Foreground="{DynamicResource AppTextSecondary}"
                                                        Header="{DynamicResource Categories.Rule.Advanced}">
                                                        <StackPanel Margin="0,8,0,0">
                                                            <Grid Margin="0,0,0,6">
                                                                <Grid.ColumnDefinitions>
                                                                    <ColumnDefinition Width="100" />
                                                                    <ColumnDefinition Width="*" />
                                                                </Grid.ColumnDefinitions>
                                                                <TextBlock
                                                                    Grid.Column="0"
                                                                    VerticalAlignment="Center"
                                                                    FontSize="{StaticResource Font.Size.Xs}"
                                                                    Foreground="{DynamicResource AppTextMuted}"
                                                                    Text="{DynamicResource Categories.Rule.Name}" />
                                                                <TextBox
                                                                    Grid.Column="1"
                                                                    Style="{StaticResource InlineTextBox}"
                                                                    Text="{Binding EditName, UpdateSourceTrigger=PropertyChanged}" />
                                                            </Grid>

                                                            <TextBlock
                                                                FontSize="{StaticResource Font.Size.Xs}"
                                                                Foreground="{DynamicResource AppTextMuted}"
                                                                Text="{DynamicResource Categories.Rule.MatchField}" />
                                                            <StackPanel Margin="0,4,0,8" Orientation="Horizontal">
                                                                <RadioButton
                                                                    Margin="0,0,12,0"
                                                                    Content="{DynamicResource Categories.Rule.MatchField.Counterparty}"
                                                                    IsChecked="{Binding EditMatchField, Converter={StaticResource EnumToBoolConverter}, ConverterParameter=Counterparty}" />
                                                                <RadioButton
                                                                    Margin="0,0,12,0"
                                                                    Content="{DynamicResource Categories.Rule.MatchField.Memo}"
                                                                    IsChecked="{Binding EditMatchField, Converter={StaticResource EnumToBoolConverter}, ConverterParameter=Memo}" />
                                                                <RadioButton
                                                                    Margin="0,0,12,0"
                                                                    Content="{DynamicResource Categories.Rule.MatchField.Either}"
                                                                    IsChecked="{Binding EditMatchField, Converter={StaticResource EnumToBoolConverter}, ConverterParameter=Either}" />
                                                                <RadioButton Content="{DynamicResource Categories.Rule.MatchField.AnyText}" IsChecked="{Binding EditMatchField, Converter={StaticResource EnumToBoolConverter}, ConverterParameter=AnyText}" />
                                                            </StackPanel>

                                                            <TextBlock
                                                                FontSize="{StaticResource Font.Size.Xs}"
                                                                Foreground="{DynamicResource AppTextMuted}"
                                                                Text="{DynamicResource Categories.Rule.MatchType}" />
                                                            <StackPanel Margin="0,4,0,8" Orientation="Horizontal">
                                                                <RadioButton
                                                                    Margin="0,0,12,0"
                                                                    Content="{DynamicResource Categories.Rule.MatchType.Contains}"
                                                                    IsChecked="{Binding EditMatchType, Converter={StaticResource EnumToBoolConverter}, ConverterParameter=Contains}" />
                                                                <RadioButton
                                                                    Margin="0,0,12,0"
                                                                    Content="{DynamicResource Categories.Rule.MatchType.Equals}"
                                                                    IsChecked="{Binding EditMatchType, Converter={StaticResource EnumToBoolConverter}, ConverterParameter=Equals}" />
                                                                <RadioButton
                                                                    Margin="0,0,12,0"
                                                                    Content="{DynamicResource Categories.Rule.MatchType.StartsWith}"
                                                                    IsChecked="{Binding EditMatchType, Converter={StaticResource EnumToBoolConverter}, ConverterParameter=StartsWith}" />
                                                                <RadioButton Content="{DynamicResource Categories.Rule.MatchType.Regex}" IsChecked="{Binding EditMatchType, Converter={StaticResource EnumToBoolConverter}, ConverterParameter=Regex}" />
                                                            </StackPanel>

                                                            <TextBlock
                                                                FontSize="{StaticResource Font.Size.Xs}"
                                                                Foreground="{DynamicResource AppTextMuted}"
                                                                Text="{DynamicResource Categories.Rule.AppliesTo}" />
                                                            <StackPanel Margin="0,4,0,8" Orientation="Horizontal">
                                                                <CheckBox
                                                                    Margin="0,0,12,0"
                                                                    Content="{DynamicResource Categories.Rule.AppliesTo.Manual}"
                                                                    IsChecked="{Binding EditAppliesToManual}" />
                                                                <CheckBox Content="{DynamicResource Categories.Rule.AppliesTo.Import}" IsChecked="{Binding EditAppliesToImport}" />
                                                            </StackPanel>

                                                            <Border Style="{StaticResource FormCard}" Margin="0,8,0,0" Padding="10,8">
                                                                <StackPanel>
                                                                    <TextBlock
                                                                        FontSize="{StaticResource Font.Size.Xs}"
                                                                        FontWeight="SemiBold"
                                                                        Foreground="{DynamicResource AppTextSecondary}"
                                                                        Text="{DynamicResource Categories.Rule.LiveTest}" />
                                                                    <Grid Margin="0,6,0,0">
                                                                        <Grid.ColumnDefinitions>
                                                                            <ColumnDefinition Width="100" />
                                                                            <ColumnDefinition Width="*" />
                                                                            <ColumnDefinition Width="32" />
                                                                        </Grid.ColumnDefinitions>
                                                                        <TextBlock
                                                                            Grid.Column="0"
                                                                            VerticalAlignment="Center"
                                                                            FontSize="{StaticResource Font.Size.Xs}"
                                                                            Foreground="{DynamicResource AppTextMuted}"
                                                                            Text="{DynamicResource Categories.Rule.LiveTest.Counterparty}" />
                                                                        <TextBox
                                                                            Grid.Column="1"
                                                                            Style="{StaticResource InlineTextBox}"
                                                                            Text="{Binding LiveTestCounterparty, UpdateSourceTrigger=PropertyChanged}" />
                                                                        <ds:AppIcon
                                                                            Grid.Column="2"
                                                                            HorizontalAlignment="Center"
                                                                            VerticalAlignment="Center"
                                                                            FontSize="{StaticResource Font.Size.Base}">
                                                                            <ds:AppIcon.Style>
                                                                                <Style BasedOn="{StaticResource AppIcon}" TargetType="{x:Type ds:AppIcon}">
                                                                                    <Setter Property="Symbol" Value="Dismiss24" />
                                                                                    <Setter Property="Foreground" Value="{DynamicResource AppTextMuted}" />
                                                                                    <Style.Triggers>
                                                                                        <DataTrigger Binding="{Binding LiveTestCounterpartyHit}" Value="True">
                                                                                            <Setter Property="Symbol" Value="Checkmark24" />
                                                                                            <Setter Property="Foreground" Value="{DynamicResource AppUp}" />
                                                                                        </DataTrigger>
                                                                                    </Style.Triggers>
                                                                                </Style>
                                                                            </ds:AppIcon.Style>
                                                                        </ds:AppIcon>
                                                                    </Grid>
                                                                    <Grid Margin="0,6,0,0">
                                                                        <Grid.ColumnDefinitions>
                                                                            <ColumnDefinition Width="100" />
                                                                            <ColumnDefinition Width="*" />
                                                                            <ColumnDefinition Width="32" />
                                                                        </Grid.ColumnDefinitions>
                                                                        <TextBlock
                                                                            Grid.Column="0"
                                                                            VerticalAlignment="Center"
                                                                            FontSize="{StaticResource Font.Size.Xs}"
                                                                            Foreground="{DynamicResource AppTextMuted}"
                                                                            Text="{DynamicResource Categories.Rule.LiveTest.Memo}" />
                                                                        <TextBox
                                                                            Grid.Column="1"
                                                                            Style="{StaticResource InlineTextBox}"
                                                                            Text="{Binding LiveTestMemo, UpdateSourceTrigger=PropertyChanged}" />
                                                                        <ds:AppIcon
                                                                            Grid.Column="2"
                                                                            HorizontalAlignment="Center"
                                                                            VerticalAlignment="Center"
                                                                            FontSize="{StaticResource Font.Size.Base}">
                                                                            <ds:AppIcon.Style>
                                                                                <Style BasedOn="{StaticResource AppIcon}" TargetType="{x:Type ds:AppIcon}">
                                                                                    <Setter Property="Symbol" Value="Dismiss24" />
                                                                                    <Setter Property="Foreground" Value="{DynamicResource AppTextMuted}" />
                                                                                    <Style.Triggers>
                                                                                        <DataTrigger Binding="{Binding LiveTestMemoHit}" Value="True">
                                                                                            <Setter Property="Symbol" Value="Checkmark24" />
                                                                                            <Setter Property="Foreground" Value="{DynamicResource AppUp}" />
                                                                                        </DataTrigger>
                                                                                    </Style.Triggers>
                                                                                </Style>
                                                                            </ds:AppIcon.Style>
                                                                        </ds:AppIcon>
                                                                    </Grid>
                                                                </StackPanel>
                                                            </Border>
                                                        </StackPanel>
                                                    </Expander>
                                                </StackPanel>

                                                <!--  Buttons  -->
                                                <StackPanel
                                                    Grid.Column="2"
                                                    VerticalAlignment="Center"
                                                    Orientation="Horizontal">
                                                    <Button
                                                        Width="32"
                                                        Height="32"
                                                        Margin="0,0,4,0"
                                                        Padding="0"
                                                        Command="{Binding DataContext.BeginEditRuleCommand, RelativeSource={RelativeSource AncestorType=UserControl}}"
                                                        CommandParameter="{Binding}"
                                                        ToolTip="{DynamicResource Common.Edit}">
                                                        <Button.Style>
                                                            <Style BasedOn="{StaticResource AppIconButton}" TargetType="{x:Type Button}">
                                                                <Setter Property="Visibility" Value="Visible" />
                                                                <Style.Triggers>
                                                                    <DataTrigger Binding="{Binding IsEditing}" Value="True">
                                                                        <Setter Property="Visibility" Value="Collapsed" />
                                                                    </DataTrigger>
                                                                </Style.Triggers>
                                                            </Style>
                                                        </Button.Style>
                                                        <ds:AppIcon
                                                            FontSize="{StaticResource Font.Size.Xs}"
                                                            Foreground="{DynamicResource AppTextPrimary}"
                                                            Symbol="Edit24" />
                                                    </Button>

                                                    <Button
                                                        Width="32"
                                                        Height="32"
                                                        Padding="0"
                                                                Command="{Binding DataContext.RequestDeleteRuleCommand, RelativeSource={RelativeSource AncestorType=UserControl}}"
                                                        CommandParameter="{Binding}"
                                                        ToolTip="{DynamicResource Common.Delete}">
                                                        <Button.Style>
                                                            <Style BasedOn="{StaticResource AppIconButton}" TargetType="{x:Type Button}">
                                                                <Setter Property="Visibility" Value="Visible" />
                                                                <Style.Triggers>
                                                                    <DataTrigger Binding="{Binding IsEditing}" Value="True">
                                                                        <Setter Property="Visibility" Value="Collapsed" />
                                                                    </DataTrigger>
                                                                </Style.Triggers>
                                                            </Style>
                                                        </Button.Style>
                                                        <ds:AppIcon
                                                            FontSize="{StaticResource Font.Size.Xs}"
                                                            Foreground="{DynamicResource AppDanger}"
                                                            Symbol="Delete24" />
                                                    </Button>

                                                    <Button
                                                        Width="32"
                                                        Height="32"
                                                        Margin="0,0,4,0"
                                                        Padding="0"
                                                        Command="{Binding DataContext.SaveEditRuleCommand, RelativeSource={RelativeSource AncestorType=UserControl}}"
                                                        CommandParameter="{Binding}"
                                                        ToolTip="{DynamicResource Common.Save}">
                                                        <Button.Style>
                                                            <Style BasedOn="{StaticResource AppIconButton}" TargetType="{x:Type Button}">
                                                                <Setter Property="Visibility" Value="Collapsed" />
                                                                <Style.Triggers>
                                                                    <DataTrigger Binding="{Binding IsEditing}" Value="True">
                                                                        <Setter Property="Visibility" Value="Visible" />
                                                                    </DataTrigger>
                                                                </Style.Triggers>
                                                            </Style>
                                                        </Button.Style>
                                                        <ds:AppIcon
                                                            FontSize="{StaticResource Font.Size.Sm}"
                                                            Foreground="{DynamicResource AppUp}"
                                                            Symbol="Checkmark24" />
                                                    </Button>

                                                    <Button
                                                        Width="32"
                                                        Height="32"
                                                        Padding="0"
                                                        Command="{Binding DataContext.CancelEditRuleCommand, RelativeSource={RelativeSource AncestorType=UserControl}}"
                                                        CommandParameter="{Binding}"
                                                        ToolTip="{DynamicResource Common.Cancel}">
                                                        <Button.Style>
                                                            <Style BasedOn="{StaticResource AppIconButton}" TargetType="{x:Type Button}">
                                                                <Setter Property="Visibility" Value="Collapsed" />
                                                                <Style.Triggers>
                                                                    <DataTrigger Binding="{Binding IsEditing}" Value="True">
                                                                        <Setter Property="Visibility" Value="Visible" />
                                                                    </DataTrigger>
                                                                </Style.Triggers>
                                                            </Style>
                                                        </Button.Style>
                                                        <ds:AppIcon
                                                            FontSize="{StaticResource Font.Size.Xs}"
                                                            Foreground="{DynamicResource AppTextSecondary}"
                                                            Symbol="Dismiss24" />
                                                    </Button>
                                                </StackPanel>

                                                <TextBlock
                                                    Grid.Row="1"
                                                    Grid.Column="1"
                                                    Margin="0,4,0,0"
                                                    FontSize="{StaticResource Font.Size.Xs}"
                                                    Foreground="{DynamicResource AppDown}"
                                                    Text="{Binding EditError}"
                                                    Visibility="{Binding EditError, Converter={StaticResource StringToVisibilityConverter}}" />
                                            </Grid>
                                        </Border>
                                    </DataTemplate>
                                </ItemsControl.ItemTemplate>
                            </ItemsControl>
                        </ScrollViewer>
                    </Border>

                </Grid>
            </TabItem>

            <TabItem Header="{DynamicResource Categories.Tab.Budgets}">
                <Grid Margin="0,4,0,0">
                    <Grid.RowDefinitions>
                        <RowDefinition Height="Auto" />
                        <RowDefinition Height="*" />
                        <RowDefinition Height="Auto" />
                    </Grid.RowDefinitions>

                    <DockPanel
                        Grid.Row="0"
                        Margin="0,0,0,8"
                        LastChildFill="True">
                        <Button
                            Margin="12,0,0,0"
                            Command="{Binding OpenAddBudgetCommand}"
                            DockPanel.Dock="Right"
                            Style="{StaticResource AppPrimaryButton}"
                            Visibility="{Binding IsAddBudgetOpen, Converter={StaticResource InverseBooleanToVisibilityConverter}}">
                            <StackPanel Orientation="Horizontal">
                                <ds:AppIcon
                                    Margin="0,0,4,0"
                                    VerticalAlignment="Center"
                                    Foreground="{Binding Foreground, RelativeSource={RelativeSource AncestorType={x:Type Button}}}"
                                    Symbol="Add24" />
                                <TextBlock
                                    VerticalAlignment="Center"
                                    Foreground="{Binding Foreground, RelativeSource={RelativeSource AncestorType={x:Type Button}}}"
                                    Text="{DynamicResource Categories.Budget.AddTitle}" />
                            </StackPanel>
                        </Button>
                        <TextBlock
                            VerticalAlignment="Center"
                            FontSize="{StaticResource Font.Size.Base}"
                            Foreground="{DynamicResource AppTextSecondary}"
                            Text="{DynamicResource Categories.Budget.Hint}"
                            TextWrapping="Wrap" />
                    </DockPanel>

                    <Border Style="{StaticResource FormCard}"
                        Grid.Row="1"
                        Padding="12"
                        HorizontalAlignment="Stretch"
                        VerticalAlignment="Stretch">
                        <ScrollViewer VerticalScrollBarVisibility="Auto">
                            <ItemsControl ItemsSource="{Binding Budgets}">
                                <ItemsControl.ItemContainerStyle>
                                    <Style TargetType="{x:Type ContentPresenter}">
                                        <Setter Property="HorizontalAlignment" Value="Stretch" />
                                    </Style>
                                </ItemsControl.ItemContainerStyle>
                                <ItemsControl.ItemTemplate>
                                    <DataTemplate>
                                        <Border
                                            Margin="0,0,0,6"
                                            Padding="10,8"
                                            Background="{DynamicResource AppBackground}"
                                            BorderBrush="{DynamicResource AppBorder}"
                                            BorderThickness="1"
                                            CornerRadius="{StaticResource Radius.Sm}">
                                            <Grid>
                                                <Grid.ColumnDefinitions>
                                                    <ColumnDefinition Width="120" />
                                                    <ColumnDefinition Width="*" />
                                                    <ColumnDefinition Width="Auto" />
                                                    <ColumnDefinition Width="Auto" />
                                                </Grid.ColumnDefinitions>

                                                <TextBlock
                                                    Grid.Column="0"
                                                    VerticalAlignment="Center"
                                                    FontFamily="{StaticResource Font.Family.Base}"
                                                    FontSize="{StaticResource Font.Size.Base}"
                                                    FontWeight="SemiBold"
                                                    Foreground="{DynamicResource AppTextPrimary}"
                                                    Text="{Binding PeriodDisplay}"
                                                    Typography.NumeralAlignment="Tabular" />

                                                <!--  View mode  -->
                                                <StackPanel
                                                    Grid.Column="1"
                                                    VerticalAlignment="Center"
                                                    Orientation="Horizontal">
                                                    <StackPanel.Style>
                                                        <Style TargetType="StackPanel">
                                                            <Setter Property="Visibility" Value="Visible" />
                                                            <Style.Triggers>
                                                                <DataTrigger Binding="{Binding IsEditing}" Value="True">
                                                                    <Setter Property="Visibility" Value="Collapsed" />
                                                                </DataTrigger>
                                                            </Style.Triggers>
                                                        </Style>
                                                    </StackPanel.Style>
                                                    <TextBlock
                                                        VerticalAlignment="Center"
                                                        FontSize="{StaticResource Font.Size.Base}"
                                                        Foreground="{DynamicResource AppTextSecondary}"
                                                        Text="{Binding CategoryDisplay}" />
                                                    <TextBlock
                                                        Margin="12,0,0,0"
                                                        VerticalAlignment="Center"
                                                        FontSize="{StaticResource Font.Size.Base}"
                                                        Foreground="{DynamicResource AppTextMuted}"
                                                        Text="{Binding Note}" />
                                                </StackPanel>

                                                <!--  Edit mode  -->
                                                <Grid Grid.Column="1">
                                                    <Grid.Style>
                                                        <Style TargetType="Grid">
                                                            <Setter Property="Visibility" Value="Collapsed" />
                                                            <Style.Triggers>
                                                                <DataTrigger Binding="{Binding IsEditing}" Value="True">
                                                                    <Setter Property="Visibility" Value="Visible" />
                                                                </DataTrigger>
                                                            </Style.Triggers>
                                                        </Style>
                                                    </Grid.Style>
                                                    <Grid.ColumnDefinitions>
                                                        <ColumnDefinition Width="*" />
                                                    </Grid.ColumnDefinitions>
                                                    <TextBox
                                                        Grid.Column="0"
                                                        Style="{StaticResource InlineTextBox}"
                                                        Text="{Binding EditNote, UpdateSourceTrigger=PropertyChanged}" />
                                                </Grid>

                                                <!--
                                                    Amount column with budget-vs-actual visualization.
                                                    Shows "已支出 X / Y NT$"，progress bar (foreground
                                                    swaps to AppDanger when over-budget, AppWarning
                                                    when ≥80%) and an over-budget badge.
                                                -->
                                                <Grid
                                                    Grid.Column="2"
                                                    MinWidth="200"
                                                    Margin="12,0"
                                                    VerticalAlignment="Center">
                                                    <!--  View mode  -->
                                                    <StackPanel>
                                                        <StackPanel.Style>
                                                            <Style TargetType="StackPanel">
                                                                <Setter Property="Visibility" Value="Visible" />
                                                                <Style.Triggers>
                                                                    <DataTrigger Binding="{Binding IsEditing}" Value="True">
                                                                        <Setter Property="Visibility" Value="Collapsed" />
                                                                    </DataTrigger>
                                                                </Style.Triggers>
                                                            </Style>
                                                        </StackPanel.Style>
                                                        <DockPanel LastChildFill="False">
                                                            <TextBlock
                                                                VerticalAlignment="Center"
                                                                DockPanel.Dock="Left"
                                                                FontFamily="{StaticResource Font.Family.Base}"
                                                                FontSize="{StaticResource Font.Size.Sm}"
                                                                FontWeight="SemiBold"
                                                                Foreground="{DynamicResource AppTextPrimary}"
                                                                Text="{Binding SpentVsBudgetDisplay}"
                                                                Typography.NumeralAlignment="Tabular" />
                                                            <!--  Over-budget badge — only visible when IsOverBudget=true  -->
                                                            <Border
                                                                Margin="6,0,0,0"
                                                                Padding="6,1"
                                                                VerticalAlignment="Center"
                                                                Background="{DynamicResource AppDanger}"
                                                                CornerRadius="3"
                                                                DockPanel.Dock="Left"
                                                                Visibility="{Binding IsOverBudget, Converter={StaticResource BooleanToVisibilityConverter}}">
                                                                <TextBlock
                                                                    FontSize="{StaticResource Font.Size.Xs}"
                                                                    FontWeight="SemiBold"
                                                                    Foreground="{DynamicResource AppTextOnAccent}"
                                                                    Text="{DynamicResource Categories.Budget.OverBudget}" />
                                                            </Border>
                                                        </DockPanel>
                                                        <!--
                                                            Progress bar: 4 px track. Foreground colour:
                                                              IsOverBudget → AppDanger
                                                              IsNearBudget (≥80%) → AppWarning (fall back AppAccentHover)
                                                              otherwise → AppAccent
                                                        -->
                                                        <ProgressBar
                                                            Margin="0,4,0,0"
                                                            Height="4"
                                                            Maximum="100"
                                                            Value="{Binding ProgressPercent, Mode=OneWay}">
                                                            <ProgressBar.Style>
                                                                <Style BasedOn="{StaticResource {x:Type ProgressBar}}" TargetType="ProgressBar">
                                                                    <Setter Property="Foreground" Value="{DynamicResource AppAccent}" />
                                                                    <Style.Triggers>
                                                                        <DataTrigger Binding="{Binding IsNearBudget}" Value="True">
                                                                            <Setter Property="Foreground" Value="{DynamicResource AppAccentHover}" />
                                                                        </DataTrigger>
                                                                        <DataTrigger Binding="{Binding IsOverBudget}" Value="True">
                                                                            <Setter Property="Foreground" Value="{DynamicResource AppDanger}" />
                                                                        </DataTrigger>
                                                                    </Style.Triggers>
                                                                </Style>
                                                            </ProgressBar.Style>
                                                        </ProgressBar>
                                                    </StackPanel>
                                                    <!--  Edit mode (TextBox for budget amount) — same as before.  -->
                                                    <TextBox
                                                        Width="120"
                                                        MinHeight="36"
                                                        VerticalContentAlignment="Center"
                                                        behaviors:ThousandSeparatorBehavior.IsEnabled="True"
                                                        Text="{Binding EditAmount, UpdateSourceTrigger=PropertyChanged}">
                                                        <TextBox.Style>
                                                            <Style BasedOn="{StaticResource AppTextBox}" TargetType="TextBox">
                                                                <Setter Property="Visibility" Value="Collapsed" />
                                                                <Style.Triggers>
                                                                    <DataTrigger Binding="{Binding IsEditing}" Value="True">
                                                                        <Setter Property="Visibility" Value="Visible" />
                                                                    </DataTrigger>
                                                                </Style.Triggers>
                                                            </Style>
                                                        </TextBox.Style>
                                                    </TextBox>
                                                </Grid>

                                                <!--  Buttons  -->
                                                <StackPanel
                                                    Grid.Column="3"
                                                    VerticalAlignment="Center"
                                                    Orientation="Horizontal">
                                                    <Button
                                                        Width="32"
                                                        Height="32"
                                                        Margin="0,0,4,0"
                                                        Padding="0"
                                                        Command="{Binding DataContext.BeginEditBudgetCommand, RelativeSource={RelativeSource AncestorType=UserControl}}"
                                                        CommandParameter="{Binding}"
                                                        ToolTip="{DynamicResource Common.Edit}">
                                                        <Button.Style>
                                                            <Style BasedOn="{StaticResource AppIconButton}" TargetType="{x:Type Button}">
                                                                <Setter Property="Visibility" Value="Visible" />
                                                                <Style.Triggers>
                                                                    <DataTrigger Binding="{Binding IsEditing}" Value="True">
                                                                        <Setter Property="Visibility" Value="Collapsed" />
                                                                    </DataTrigger>
                                                                </Style.Triggers>
                                                            </Style>
                                                        </Button.Style>
                                                        <ds:AppIcon
                                                            FontSize="{StaticResource Font.Size.Xs}"
                                                            Foreground="{DynamicResource AppTextPrimary}"
                                                            Symbol="Edit24" />
                                                    </Button>
                                                    <Button
                                                        Width="32"
                                                        Height="32"
                                                        Padding="0"
                                                        Command="{Binding DataContext.RequestDeleteBudgetCommand, RelativeSource={RelativeSource AncestorType=UserControl}}"
                                                        CommandParameter="{Binding}"
                                                        ToolTip="{DynamicResource Common.Delete}">
                                                        <Button.Style>
                                                            <Style BasedOn="{StaticResource AppIconButton}" TargetType="{x:Type Button}">
                                                                <Setter Property="Visibility" Value="Visible" />
                                                                <Style.Triggers>
                                                                    <DataTrigger Binding="{Binding IsEditing}" Value="True">
                                                                        <Setter Property="Visibility" Value="Collapsed" />
                                                                    </DataTrigger>
                                                                </Style.Triggers>
                                                            </Style>
                                                        </Button.Style>
                                                        <ds:AppIcon
                                                            FontSize="{StaticResource Font.Size.Xs}"
                                                            Foreground="{DynamicResource AppDanger}"
                                                            Symbol="Delete24" />
                                                    </Button>
                                                    <Button
                                                        Width="32"
                                                        Height="32"
                                                        Margin="0,0,4,0"
                                                        Padding="0"
                                                        Command="{Binding DataContext.SaveEditBudgetCommand, RelativeSource={RelativeSource AncestorType=UserControl}}"
                                                        CommandParameter="{Binding}"
                                                        ToolTip="{DynamicResource Common.Save}">
                                                        <Button.Style>
                                                            <Style BasedOn="{StaticResource AppIconButton}" TargetType="{x:Type Button}">
                                                                <Setter Property="Visibility" Value="Collapsed" />
                                                                <Style.Triggers>
                                                                    <DataTrigger Binding="{Binding IsEditing}" Value="True">
                                                                        <Setter Property="Visibility" Value="Visible" />
                                                                    </DataTrigger>
                                                                </Style.Triggers>
                                                            </Style>
                                                        </Button.Style>
                                                        <ds:AppIcon
                                                            FontSize="{StaticResource Font.Size.Sm}"
                                                            Foreground="{DynamicResource AppUp}"
                                                            Symbol="Checkmark24" />
                                                    </Button>
                                                    <Button
                                                        Width="32"
                                                        Height="32"
                                                        Padding="0"
                                                        Command="{Binding DataContext.CancelEditBudgetCommand, RelativeSource={RelativeSource AncestorType=UserControl}}"
                                                        CommandParameter="{Binding}"
                                                        ToolTip="{DynamicResource Common.Cancel}">
                                                        <Button.Style>
                                                            <Style BasedOn="{StaticResource AppIconButton}" TargetType="{x:Type Button}">
                                                                <Setter Property="Visibility" Value="Collapsed" />
                                                                <Style.Triggers>
                                                                    <DataTrigger Binding="{Binding IsEditing}" Value="True">
                                                                        <Setter Property="Visibility" Value="Visible" />
                                                                    </DataTrigger>
                                                                </Style.Triggers>
                                                            </Style>
                                                        </Button.Style>
                                                        <ds:AppIcon
                                                            FontSize="{StaticResource Font.Size.Xs}"
                                                            Foreground="{DynamicResource AppTextSecondary}"
                                                            Symbol="Dismiss24" />
                                                    </Button>
                                                </StackPanel>
                                            </Grid>
                                        </Border>
                                    </DataTemplate>
                                </ItemsControl.ItemTemplate>
                            </ItemsControl>
                        </ScrollViewer>
                    </Border>

                </Grid>
            </TabItem>
        </TabControl>

        <Grid
            Grid.Row="0"
            Grid.RowSpan="2"
            Margin="-24"
            Panel.ZIndex="180"
            Style="{StaticResource AppDialogOverlay}"
            Visibility="{Binding IsAddCategoryOpen, Converter={StaticResource BooleanToVisibilityConverter}}" />

        <Border
            Grid.Row="0"
            Grid.RowSpan="2"
            Style="{StaticResource AppDialogShell}"
            Width="640"
            MaxWidth="720"
            MaxHeight="620"
            HorizontalAlignment="Center"
            VerticalAlignment="Center"
            Panel.ZIndex="181"
            behaviors:EscapeKeyCommandBehavior.Command="{Binding CloseAddCategoryCommand}"
            SnapsToDevicePixels="True"
            Visibility="{Binding IsAddCategoryOpen, Converter={StaticResource BooleanToVisibilityConverter}}">
            <Grid>
                <Grid.RowDefinitions>
                    <RowDefinition Height="Auto" />
                    <RowDefinition Height="Auto" />
                    <RowDefinition Height="Auto" />
                    <RowDefinition Height="Auto" />
                </Grid.RowDefinitions>

                <StackPanel Style="{StaticResource AppDialogHeader}">
                    <TextBlock
                        Style="{StaticResource AppDialogTitle}"
                        Text="{DynamicResource Categories.AddForm.Title}" />
                    <TextBlock
                        Style="{StaticResource AppDialogSubtitle}"
                        Text="{DynamicResource Categories.AddForm.Hint}"
                        TextWrapping="Wrap" />
                </StackPanel>

                <Border
                    Grid.Row="1"
                    Style="{StaticResource FormSection}">
                    <Grid>
                        <Grid.Resources>
                            <Style x:Key="SheetFieldLabel" TargetType="TextBlock">
                                <Setter Property="Margin" Value="0,0,0,6" />
                                <Setter Property="FontSize" Value="{DynamicResource Font.Size.Xs}" />
                                <Setter Property="FontWeight" Value="SemiBold" />
                                <Setter Property="Foreground" Value="{DynamicResource AppTextSecondary}" />
                            </Style>
                            <Style BasedOn="{StaticResource AppTextBox}" TargetType="{x:Type TextBox}">
                                <Setter Property="MinHeight" Value="40" />
                            </Style>
                            <Style
                                x:Key="SheetComboBox"
                                BasedOn="{StaticResource AppComboBox}"
                                TargetType="ComboBox">
                                <Setter Property="MinHeight" Value="40" />
                            </Style>
                        </Grid.Resources>
                        <Grid.RowDefinitions>
                            <RowDefinition Height="Auto" />
                            <RowDefinition Height="Auto" />
                        </Grid.RowDefinitions>
                        <Grid.ColumnDefinitions>
                            <ColumnDefinition Width="*" />
                            <ColumnDefinition Width="16" />
                            <ColumnDefinition Width="*" />
                        </Grid.ColumnDefinitions>

                        <StackPanel Grid.Row="0" Grid.Column="0" Margin="0,0,0,14">
                            <TextBlock Style="{StaticResource SheetFieldLabel}" Text="{DynamicResource Categories.Field.Kind}" />
                            <ComboBox
                                ItemsSource="{Binding KindOptions}"
                                SelectedItem="{Binding AddKind}"
                                Style="{StaticResource SheetComboBox}">
                                <ComboBox.ItemTemplate>
                                    <DataTemplate>
                                        <TextBlock>
                                            <TextBlock.Style>
                                                <Style TargetType="TextBlock">
                                                    <Setter Property="Text" Value="{DynamicResource Categories.Expense}" />
                                                    <Style.Triggers>
                                                        <DataTrigger Binding="{Binding}" Value="Income">
                                                            <Setter Property="Text" Value="{DynamicResource Categories.Income}" />
                                                        </DataTrigger>
                                                    </Style.Triggers>
                                                </Style>
                                            </TextBlock.Style>
                                        </TextBlock>
                                    </DataTemplate>
                                </ComboBox.ItemTemplate>
                            </ComboBox>
                        </StackPanel>

                        <StackPanel Grid.Row="0" Grid.Column="2" Margin="0,0,0,14">
                            <TextBlock Style="{StaticResource SheetFieldLabel}" Text="{DynamicResource Categories.Field.Icon}" />
                            <ComboBox
                                ItemsSource="{Binding IconOptions}"
                                SelectedValue="{Binding AddIcon}"
                                SelectedValuePath="Value"
                                Style="{StaticResource SheetComboBox}"
                                ToolTip="{DynamicResource Categories.IconHint}">
                                <ComboBox.ItemTemplate>
                                    <DataTemplate>
                                        <StackPanel Orientation="Horizontal">
                                            <TextBlock
                                                Margin="0,0,8,0"
                                                VerticalAlignment="Center"
                                                FontSize="{StaticResource Font.Size.Md}"
                                                Text="{Binding Value}" />
                                            <TextBlock
                                                VerticalAlignment="Center"
                                                FontSize="{StaticResource Font.Size.Sm}"
                                                Foreground="{DynamicResource AppTextSecondary}"
                                                Text="{Binding Label}" />
                                        </StackPanel>
                                    </DataTemplate>
                                </ComboBox.ItemTemplate>
                            </ComboBox>
                        </StackPanel>

                        <StackPanel Grid.Row="1" Grid.Column="0">
                            <TextBlock Style="{StaticResource SheetFieldLabel}" Text="{DynamicResource Categories.Field.Name}" />
                            <TextBox
                                Text="{Binding AddName, UpdateSourceTrigger=PropertyChanged}"
                                ToolTip="{DynamicResource Categories.NameHint}" />
                        </StackPanel>

                        <StackPanel Grid.Row="1" Grid.Column="2">
                            <TextBlock Style="{StaticResource SheetFieldLabel}" Text="{DynamicResource Categories.Field.Color}" />
                            <ctrl:HexColorPicker
                                MinHeight="40"
                                Presets="{Binding ColorOptions}"
                                SelectedColorHex="{Binding AddColorHex, Mode=TwoWay}"
                                ToolTip="{DynamicResource Categories.ColorHint}" />
                        </StackPanel>
                    </Grid>
                </Border>

                <TextBlock
                    Grid.Row="2"
                    Margin="24,10,24,0"
                    FontSize="{StaticResource Font.Size.Xs}"
                    Foreground="{DynamicResource AppDown}"
                    Text="{Binding AddError}"
                    Visibility="{Binding AddError, Converter={StaticResource StringToVisibilityConverter}}" />

                <Border
                    Grid.Row="3"
                    Margin="0,16,0,0"
                    Padding="0"
                    BorderBrush="{DynamicResource AppBorder}"
                    BorderThickness="0">
                    <StackPanel Style="{StaticResource AppDialogFooter}">
                        <Button
                            Margin="0,0,8,0"
                            Command="{Binding CloseAddCategoryCommand}"
                            Content="{DynamicResource Common.Cancel}"
                            Style="{StaticResource AppSecondaryButton}" />
                        <Button
                            Command="{Binding AddCategoryCommand}"
                            Content="{DynamicResource Categories.Add}"
                            Style="{StaticResource AppPrimaryButton}" />
                    </StackPanel>
                </Border>
            </Grid>
        </Border>

        <Grid
            Grid.Row="0"
            Grid.RowSpan="2"
            Margin="-24"
            Panel.ZIndex="182"
            Style="{StaticResource AppDialogOverlay}"
            Visibility="{Binding IsAddRuleOpen, Converter={StaticResource BooleanToVisibilityConverter}}" />

        <Border
            Grid.Row="0"
            Grid.RowSpan="2"
            Style="{StaticResource AppDialogShell}"
            Width="760"
            MaxWidth="820"
            MaxHeight="720"
            HorizontalAlignment="Center"
            VerticalAlignment="Center"
            Panel.ZIndex="183"
            behaviors:EscapeKeyCommandBehavior.Command="{Binding CloseAddRuleCommand}"
            SnapsToDevicePixels="True"
            Visibility="{Binding IsAddRuleOpen, Converter={StaticResource BooleanToVisibilityConverter}}">
            <Grid>
                <Grid.RowDefinitions>
                    <RowDefinition Height="Auto" />
                    <RowDefinition Height="*" />
                    <RowDefinition Height="Auto" />
                    <RowDefinition Height="Auto" />
                </Grid.RowDefinitions>

                <StackPanel Style="{StaticResource AppDialogHeader}">
                    <TextBlock
                        Style="{StaticResource AppDialogTitle}"
                        Text="{DynamicResource Categories.Rule.AddForm.Title}" />
                    <TextBlock
                        Style="{StaticResource AppDialogSubtitle}"
                        Text="{DynamicResource Categories.Rule.AddForm.Hint}"
                        TextWrapping="Wrap" />
                </StackPanel>

                <ScrollViewer
                    Grid.Row="1"
                    MaxHeight="500"
                    HorizontalScrollBarVisibility="Disabled"
                    VerticalScrollBarVisibility="Auto">
                    <StackPanel>
                        <Border Style="{StaticResource FormSection}">
                            <Grid>
                                <Grid.RowDefinitions>
                                    <RowDefinition Height="Auto" />
                                    <RowDefinition Height="Auto" />
                                </Grid.RowDefinitions>
                                <Grid.ColumnDefinitions>
                                    <ColumnDefinition Width="*" />
                                    <ColumnDefinition Width="16" />
                                    <ColumnDefinition Width="*" />
                                    <ColumnDefinition Width="16" />
                                    <ColumnDefinition Width="120" />
                                </Grid.ColumnDefinitions>

                                <StackPanel Grid.Row="0" Grid.Column="0" Margin="0,0,0,14">
                                    <TextBlock Style="{StaticResource FormFieldLabel}" Text="{DynamicResource Categories.Field.Keyword}" />
                                    <TextBox
                                        Style="{StaticResource AppTextBox}"
                                        Text="{Binding AddRuleKeyword, UpdateSourceTrigger=PropertyChanged}"
                                        ToolTip="{DynamicResource Categories.Rule.KeywordHint}" />
                                </StackPanel>

                                <StackPanel Grid.Row="0" Grid.Column="2" Margin="0,0,0,14">
                                    <TextBlock Style="{StaticResource FormFieldLabel}" Text="{DynamicResource Categories.Field.Category}" />
                                    <ComboBox
                                        ItemsSource="{Binding AvailableCategories}"
                                        SelectedItem="{Binding AddRuleCategory}"
                                        Style="{StaticResource AppComboBox}"
                                        ToolTip="{DynamicResource Categories.Rule.CategoryHint}">
                                        <ComboBox.ItemTemplate>
                                            <DataTemplate>
                                                <TextBlock Text="{Binding Name}" />
                                            </DataTemplate>
                                        </ComboBox.ItemTemplate>
                                    </ComboBox>
                                </StackPanel>

                                <StackPanel Grid.Row="0" Grid.Column="4" Margin="0,0,0,14">
                                    <TextBlock Style="{StaticResource FormFieldLabel}" Text="{DynamicResource Categories.Field.Priority}" />
                                    <TextBox
                                        Style="{StaticResource AppNumberTextBox}"
                                        Text="{Binding AddRulePriority, UpdateSourceTrigger=PropertyChanged}"
                                        ToolTip="{DynamicResource Categories.Rule.PriorityHint}" />
                                </StackPanel>

                                <StackPanel Grid.Row="1" Grid.Column="0">
                                    <TextBlock Style="{StaticResource FormFieldLabel}" Text="{DynamicResource Categories.Field.CaseSensitive}" />
                                    <CheckBox
                                        Content="{DynamicResource Categories.Rule.CaseSensitive}"
                                        Foreground="{DynamicResource AppTextSecondary}"
                                        IsChecked="{Binding AddRuleCaseSensitive}" />
                                </StackPanel>
                            </Grid>
                        </Border>

                        <Expander
                            Margin="0,12,0,0"
                            Header="{DynamicResource Categories.Rule.Advanced}"
                            Style="{StaticResource AppExpander}">
                            <Border
                                Margin="0,10,0,0"
                                Style="{StaticResource FormSection}">
                                <StackPanel>
                                    <StackPanel Margin="0,0,0,14">
                                        <TextBlock Style="{StaticResource FormFieldLabel}" Text="{DynamicResource Categories.Rule.Name}" />
                                        <TextBox
                                            Style="{StaticResource AppTextBox}"
                                            Text="{Binding AddRuleName, UpdateSourceTrigger=PropertyChanged}" />
                                    </StackPanel>

                                    <TextBlock Style="{StaticResource FormFieldLabel}" Text="{DynamicResource Categories.Rule.MatchField}" />
                                    <WrapPanel Margin="0,0,0,14">
                                        <RadioButton
                                            Margin="0,0,12,8"
                                            Content="{DynamicResource Categories.Rule.MatchField.Counterparty}"
                                            GroupName="AddRuleField"
                                            IsChecked="{Binding AddRuleMatchField, Converter={StaticResource EnumToBoolConverter}, ConverterParameter=Counterparty}"
                                            Style="{StaticResource AppRadioButton}" />
                                        <RadioButton
                                            Margin="0,0,12,8"
                                            Content="{DynamicResource Categories.Rule.MatchField.Memo}"
                                            GroupName="AddRuleField"
                                            IsChecked="{Binding AddRuleMatchField, Converter={StaticResource EnumToBoolConverter}, ConverterParameter=Memo}"
                                            Style="{StaticResource AppRadioButton}" />
                                        <RadioButton
                                            Margin="0,0,12,8"
                                            Content="{DynamicResource Categories.Rule.MatchField.Either}"
                                            GroupName="AddRuleField"
                                            IsChecked="{Binding AddRuleMatchField, Converter={StaticResource EnumToBoolConverter}, ConverterParameter=Either}"
                                            Style="{StaticResource AppRadioButton}" />
                                        <RadioButton
                                            Margin="0,0,12,8"
                                            Content="{DynamicResource Categories.Rule.MatchField.AnyText}"
                                            GroupName="AddRuleField"
                                            IsChecked="{Binding AddRuleMatchField, Converter={StaticResource EnumToBoolConverter}, ConverterParameter=AnyText}"
                                            Style="{StaticResource AppRadioButton}" />
                                    </WrapPanel>

                                    <TextBlock Style="{StaticResource FormFieldLabel}" Text="{DynamicResource Categories.Rule.MatchType}" />
                                    <WrapPanel Margin="0,0,0,14">
                                        <RadioButton
                                            Margin="0,0,12,8"
                                            Content="{DynamicResource Categories.Rule.MatchType.Contains}"
                                            GroupName="AddRuleType"
                                            IsChecked="{Binding AddRuleMatchType, Converter={StaticResource EnumToBoolConverter}, ConverterParameter=Contains}"
                                            Style="{StaticResource AppRadioButton}" />
                                        <RadioButton
                                            Margin="0,0,12,8"
                                            Content="{DynamicResource Categories.Rule.MatchType.Equals}"
                                            GroupName="AddRuleType"
                                            IsChecked="{Binding AddRuleMatchType, Converter={StaticResource EnumToBoolConverter}, ConverterParameter=Equals}"
                                            Style="{StaticResource AppRadioButton}" />
                                        <RadioButton
                                            Margin="0,0,12,8"
                                            Content="{DynamicResource Categories.Rule.MatchType.StartsWith}"
                                            GroupName="AddRuleType"
                                            IsChecked="{Binding AddRuleMatchType, Converter={StaticResource EnumToBoolConverter}, ConverterParameter=StartsWith}"
                                            Style="{StaticResource AppRadioButton}" />
                                        <RadioButton
                                            Margin="0,0,12,8"
                                            Content="{DynamicResource Categories.Rule.MatchType.Regex}"
                                            GroupName="AddRuleType"
                                            IsChecked="{Binding AddRuleMatchType, Converter={StaticResource EnumToBoolConverter}, ConverterParameter=Regex}"
                                            Style="{StaticResource AppRadioButton}" />
                                    </WrapPanel>

                                    <TextBlock Style="{StaticResource FormFieldLabel}" Text="{DynamicResource Categories.Rule.AppliesTo}" />
                                    <StackPanel Orientation="Horizontal">
                                        <CheckBox
                                            Margin="0,0,12,0"
                                            Content="{DynamicResource Categories.Rule.AppliesTo.Manual}"
                                            IsChecked="{Binding AddRuleAppliesToManual}" />
                                        <CheckBox
                                            Content="{DynamicResource Categories.Rule.AppliesTo.Import}"
                                            IsChecked="{Binding AddRuleAppliesToImport}" />
                                    </StackPanel>
                                </StackPanel>
                            </Border>
                        </Expander>
                    </StackPanel>
                </ScrollViewer>

                <TextBlock
                    Grid.Row="2"
                    Margin="24,10,24,0"
                    Style="{StaticResource FormFieldError}"
                    Text="{Binding AddRuleError}"
                    Visibility="{Binding AddRuleError, Converter={StaticResource StringToVisibilityConverter}}" />

                <StackPanel Grid.Row="3" Style="{StaticResource AppDialogFooter}">
                    <Button
                        Margin="0,0,8,0"
                        Command="{Binding CloseAddRuleCommand}"
                        Content="{DynamicResource Common.Cancel}"
                        Style="{StaticResource AppSecondaryButton}" />
                    <Button
                        Command="{Binding AddRuleCommand}"
                        Content="{DynamicResource Categories.Rule.Add}"
                        Style="{StaticResource AppPrimaryButton}" />
                </StackPanel>
            </Grid>
        </Border>

        <Grid
            Grid.Row="0"
            Grid.RowSpan="2"
            Margin="-24"
            Panel.ZIndex="184"
            Style="{StaticResource AppDialogOverlay}"
            Visibility="{Binding IsAddBudgetOpen, Converter={StaticResource BooleanToVisibilityConverter}}" />

        <Border
            Grid.Row="0"
            Grid.RowSpan="2"
            Style="{StaticResource AppDialogShell}"
            Width="720"
            MaxWidth="780"
            MaxHeight="620"
            HorizontalAlignment="Center"
            VerticalAlignment="Center"
            Panel.ZIndex="185"
            behaviors:EscapeKeyCommandBehavior.Command="{Binding CloseAddBudgetCommand}"
            SnapsToDevicePixels="True"
            Visibility="{Binding IsAddBudgetOpen, Converter={StaticResource BooleanToVisibilityConverter}}">
            <Grid>
                <Grid.RowDefinitions>
                    <RowDefinition Height="Auto" />
                    <RowDefinition Height="Auto" />
                    <RowDefinition Height="Auto" />
                    <RowDefinition Height="Auto" />
                </Grid.RowDefinitions>

                <StackPanel Style="{StaticResource AppDialogHeader}">
                    <TextBlock
                        Style="{StaticResource AppDialogTitle}"
                        Text="{DynamicResource Categories.Budget.AddForm.Title}" />
                    <TextBlock
                        Style="{StaticResource AppDialogSubtitle}"
                        Text="{DynamicResource Categories.Budget.AddForm.Hint}"
                        TextWrapping="Wrap" />
                </StackPanel>

                <Border
                    Grid.Row="1"
                    Style="{StaticResource FormSection}">
                    <Grid>
                        <Grid.RowDefinitions>
                            <RowDefinition Height="Auto" />
                            <RowDefinition Height="Auto" />
                            <RowDefinition Height="Auto" />
                        </Grid.RowDefinitions>
                        <Grid.ColumnDefinitions>
                            <ColumnDefinition Width="*" />
                            <ColumnDefinition Width="16" />
                            <ColumnDefinition Width="*" />
                            <ColumnDefinition Width="16" />
                            <ColumnDefinition Width="*" />
                        </Grid.ColumnDefinitions>

                        <StackPanel Grid.Row="0" Grid.Column="0" Margin="0,0,0,14">
                            <TextBlock Style="{StaticResource FormFieldLabel}" Text="{DynamicResource Categories.Field.BudgetMode}" />
                            <ComboBox
                                ItemsSource="{Binding BudgetModeOptions}"
                                SelectedItem="{Binding AddBudgetMode}"
                                Style="{StaticResource AppComboBox}">
                                <ComboBox.ItemTemplate>
                                    <DataTemplate>
                                        <TextBlock>
                                            <TextBlock.Style>
                                                <Style TargetType="TextBlock">
                                                    <Setter Property="Text" Value="{DynamicResource Categories.Budget.Mode.Monthly}" />
                                                    <Style.Triggers>
                                                        <DataTrigger Binding="{Binding}" Value="Yearly">
                                                            <Setter Property="Text" Value="{DynamicResource Categories.Budget.Mode.Yearly}" />
                                                        </DataTrigger>
                                                    </Style.Triggers>
                                                </Style>
                                            </TextBlock.Style>
                                        </TextBlock>
                                    </DataTemplate>
                                </ComboBox.ItemTemplate>
                            </ComboBox>
                        </StackPanel>

                        <StackPanel Grid.Row="0" Grid.Column="2" Margin="0,0,0,14">
                            <TextBlock Style="{StaticResource FormFieldLabel}" Text="{DynamicResource Categories.Field.Year}" />
                            <TextBox
                                Style="{StaticResource AppNumberTextBox}"
                                Text="{Binding AddBudgetYear, UpdateSourceTrigger=PropertyChanged}"
                                ToolTip="{DynamicResource Categories.Budget.YearHint}" />
                        </StackPanel>

                        <StackPanel Grid.Row="0" Grid.Column="4" Margin="0,0,0,14">
                            <TextBlock Style="{StaticResource FormFieldLabel}" Text="{DynamicResource Categories.Field.Month}" />
                            <TextBox
                                Style="{StaticResource AppNumberTextBox}"
                                Text="{Binding AddBudgetMonth, UpdateSourceTrigger=PropertyChanged}"
                                ToolTip="{DynamicResource Categories.Budget.MonthHint}" />
                        </StackPanel>

                        <StackPanel Grid.Row="1" Grid.Column="0" Grid.ColumnSpan="3" Margin="0,0,0,14">
                            <TextBlock Style="{StaticResource FormFieldLabel}" Text="{DynamicResource Categories.Field.Category}" />
                            <ComboBox
                                ItemsSource="{Binding AvailableCategories}"
                                SelectedItem="{Binding AddBudgetCategory}"
                                Style="{StaticResource AppComboBox}"
                                ToolTip="{DynamicResource Categories.Budget.CategoryHint}">
                                <ComboBox.ItemTemplate>
                                    <DataTemplate>
                                        <TextBlock Text="{Binding Name}" />
                                    </DataTemplate>
                                </ComboBox.ItemTemplate>
                            </ComboBox>
                        </StackPanel>

                        <StackPanel Grid.Row="1" Grid.Column="4" Margin="0,0,0,14">
                            <TextBlock Style="{StaticResource FormFieldLabel}" Text="{DynamicResource Categories.Field.Amount}" />
                            <TextBox
                                Style="{StaticResource AppMoneyTextBox}"
                                Text="{Binding AddBudgetAmount, UpdateSourceTrigger=PropertyChanged}"
                                ToolTip="{DynamicResource Categories.Budget.AmountHint}" />
                        </StackPanel>

                        <StackPanel Grid.Row="2" Grid.Column="0" Grid.ColumnSpan="5">
                            <TextBlock Style="{StaticResource FormFieldLabel}" Text="{DynamicResource Categories.Field.Note}" />
                            <TextBox
                                Style="{StaticResource AppTextBox}"
                                Text="{Binding AddBudgetNote, UpdateSourceTrigger=PropertyChanged}"
                                ToolTip="{DynamicResource Categories.Budget.NoteHint}" />
                        </StackPanel>
                    </Grid>
                </Border>

                <TextBlock
                    Grid.Row="2"
                    Margin="24,10,24,0"
                    Style="{StaticResource FormFieldError}"
                    Text="{Binding AddBudgetError}"
                    Visibility="{Binding AddBudgetError, Converter={StaticResource StringToVisibilityConverter}}" />

                <StackPanel Grid.Row="3" Style="{StaticResource AppDialogFooter}">
                    <Button
                        Margin="0,0,8,0"
                        Command="{Binding CloseAddBudgetCommand}"
                        Content="{DynamicResource Common.Cancel}"
                        Style="{StaticResource AppSecondaryButton}" />
                    <Button
                        Command="{Binding AddBudgetCommand}"
                        Content="{DynamicResource Categories.Budget.Add}"
                        Style="{StaticResource AppPrimaryButton}" />
                </StackPanel>
            </Grid>
        </Border>

        <Grid
            Grid.RowSpan="2"
            Panel.ZIndex="190"
            Style="{StaticResource AppDialogOverlay}"
            Visibility="{Binding IsDeleteConfirmOpen, Converter={StaticResource BooleanToVisibilityConverter}}" />

        <Border
            Grid.RowSpan="2"
            HorizontalAlignment="Center"
            VerticalAlignment="Center"
            Panel.ZIndex="191"
            behaviors:EscapeKeyCommandBehavior.Command="{Binding CancelDeleteCommand}"
            Style="{StaticResource AppDestructiveDialogShell}"
            Visibility="{Binding IsDeleteConfirmOpen, Converter={StaticResource BooleanToVisibilityConverter}}">
            <Grid>
                <Grid.RowDefinitions>
                    <RowDefinition Height="Auto" />
                    <RowDefinition Height="Auto" />
                    <RowDefinition Height="Auto" />
                </Grid.RowDefinitions>

                <TextBlock Style="{StaticResource AppDialogTitle}" Text="{DynamicResource Common.DeleteConfirmTitle}" />
                <TextBlock
                    Grid.Row="1"
                    Style="{StaticResource AppDialogSubtitle}">
                    <Run Text="{DynamicResource Common.DeleteConfirmPrefix}" />
                    <Run Text="{Binding DeleteTargetName}" />
                    <Run Text="{DynamicResource Common.DeleteConfirmSuffix}" />
                </TextBlock>

                <StackPanel Grid.Row="2" Style="{StaticResource AppDialogFooter}">
                    <Button
                        Margin="0,0,8,0"
                        Command="{Binding CancelDeleteCommand}"
                        Content="{DynamicResource Common.Cancel}"
                        Style="{StaticResource AppSecondaryButton}" />
                    <Button
                        Command="{Binding ConfirmDeleteCommand}"
                        Content="{DynamicResource Common.Delete}"
                        Style="{StaticResource AppDangerButton}" />
                </StackPanel>
            </Grid>
        </Border>
    </Grid>
</UserControl>
