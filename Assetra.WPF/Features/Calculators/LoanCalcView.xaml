<UserControl
    x:Class="Assetra.WPF.Features.Calculators.LoanCalcView"
    xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
    xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
    xmlns:behaviors="clr-namespace:Assetra.WPF.Infrastructure.Behaviors"
    xmlns:d="http://schemas.microsoft.com/expression/blend/2008"
    xmlns:mc="http://schemas.openxmlformats.org/markup-compatibility/2006"
    xmlns:vm="clr-namespace:Assetra.WPF.Features.Calculators"
    d:DataContext="{d:DesignInstance Type={x:Type vm:LoanCalcViewModel}, IsDesignTimeCreatable=False}"
    mc:Ignorable="d">

    <ScrollViewer
        HorizontalScrollBarVisibility="Disabled"
        VerticalScrollBarVisibility="Auto">
        <Grid Style="{StaticResource PageRootGrid}">
        <Grid.RowDefinitions>
            <RowDefinition Height="Auto" />
            <RowDefinition Height="Auto" />
            <RowDefinition Height="Auto" />
            <RowDefinition Height="Auto" />
            <RowDefinition Height="Auto" />
        </Grid.RowDefinitions>

        <!-- Subtitle -->
        <TextBlock Grid.Row="0"
                   Margin="0,0,0,12"
                   Foreground="{DynamicResource AppTextSecondary}"
                   FontSize="{StaticResource Font.Size.Sm}"
                   Text="{DynamicResource Calc.Loan.Subtitle}"
                   TextWrapping="Wrap" />

        <!-- Input card -->
        <Border Grid.Row="1" Padding="20" Style="{StaticResource FormCard}">
            <StackPanel>
                <UniformGrid Columns="3" Style="{StaticResource PageFormGrid}">
                    <StackPanel Style="{StaticResource FormField}">
                        <TextBlock Style="{StaticResource FormFieldLabel}" Text="{DynamicResource Calc.Loan.Input.Principal}" />
                        <TextBox
                            behaviors:ThousandSeparatorBehavior.IsEnabled="True"
                            Style="{StaticResource AppTextBox}"
                            Text="{Binding Principal, UpdateSourceTrigger=PropertyChanged}" />
                    </StackPanel>
                    <StackPanel Style="{StaticResource FormField}">
                        <TextBlock Style="{StaticResource FormFieldLabel}" Text="{DynamicResource Calc.Loan.Input.Rate}" />
                        <TextBox
                            Style="{StaticResource AppTextBox}"
                            Text="{Binding AnnualRatePercent, UpdateSourceTrigger=PropertyChanged}" />
                    </StackPanel>
                    <StackPanel Style="{StaticResource FormFieldLast}">
                        <TextBlock Style="{StaticResource FormFieldLabel}" Text="{DynamicResource Calc.Loan.Input.Months}" />
                        <TextBox
                            Style="{StaticResource AppTextBox}"
                            Text="{Binding Months, UpdateSourceTrigger=PropertyChanged}" />
                    </StackPanel>
                </UniformGrid>
                <StackPanel Style="{StaticResource PageActionBar}">
                    <Button
                        Command="{Binding CalculateCommand}"
                        Content="{DynamicResource Calc.Calculate}"
                        Style="{StaticResource AppPrimaryButton}" />
                </StackPanel>
            </StackPanel>
        </Border>

        <!-- Error -->
        <TextBlock
            Grid.Row="2"
            Style="{StaticResource PageErrorText}"
            Text="{Binding ErrorMessage}"
            Visibility="{Binding ErrorMessage, Converter={StaticResource NullToVisibilityConverter}}" />

        <!-- Results -->
        <Grid Grid.Row="3" Margin="{StaticResource PageContentTopGapMargin}" Style="{StaticResource PageContentGrid}">
            <!-- Empty state -->
            <StackPanel
                Style="{StaticResource EmptyStatePanel}"
                Visibility="{Binding HasResult, Converter={StaticResource InverseBooleanToVisibilityConverter}}">
                <TextBlock Style="{StaticResource EmptyStateHint}" Text="{DynamicResource Calc.Empty.Hint}" />
                <Button
                    Command="{Binding CalculateCommand}"
                    Content="{DynamicResource Calc.Calculate}"
                    HorizontalAlignment="Center"
                    Style="{StaticResource AppEmptyStatePrimaryAction}" />
            </StackPanel>

            <!-- Result content -->
            <StackPanel Visibility="{Binding HasResult, Converter={StaticResource BooleanToVisibilityConverter}}">
                <StackPanel>
                    <!-- Summary metrics -->
                    <UniformGrid Columns="3">
                        <Border Margin="0,0,12,0" Style="{StaticResource MetricCard}">
                            <StackPanel>
                                <TextBlock Style="{StaticResource MetricLabel}" Text="{DynamicResource Calc.Loan.Result.Monthly}" />
                                <TextBlock
                                    Style="{StaticResource MetricValue}"
                                    Text="{Binding MonthlyPayment}"
                                    Typography.NumeralAlignment="Tabular" />
                            </StackPanel>
                        </Border>
                        <Border Margin="0,0,12,0" Style="{StaticResource MetricCard}">
                            <StackPanel>
                                <TextBlock Style="{StaticResource MetricLabel}" Text="{DynamicResource Calc.Loan.Result.TotalPayment}" />
                                <TextBlock
                                    Style="{StaticResource MetricValue}"
                                    Text="{Binding TotalPayment}"
                                    Typography.NumeralAlignment="Tabular" />
                            </StackPanel>
                        </Border>
                        <Border Style="{StaticResource MetricCard}">
                            <StackPanel>
                                <TextBlock Style="{StaticResource MetricLabel}" Text="{DynamicResource Calc.Loan.Result.TotalInterest}" />
                                <TextBlock
                                    Style="{StaticResource MetricValue}"
                                    Text="{Binding TotalInterest}"
                                    Typography.NumeralAlignment="Tabular" />
                            </StackPanel>
                        </Border>
                    </UniformGrid>

                    <!-- Amortization schedule -->
                    <Expander
                        Margin="0,12,0,0"
                        Header="{DynamicResource Calc.Loan.Result.Schedule}"
                        Style="{StaticResource AppExpander}">
                        <DataGrid
                            Margin="12,0,12,12"
                            AutoGenerateColumns="False"
                            IsReadOnly="True"
                            ItemsSource="{Binding Schedule}">
                            <DataGrid.Columns>
                                <DataGridTextColumn Binding="{Binding Month}" Width="60">
                                    <DataGridTextColumn.Header>
                                        <TextBlock Text="{DynamicResource Calc.Loan.Col.Month}" />
                                    </DataGridTextColumn.Header>
                                </DataGridTextColumn>
                                <DataGridTextColumn Binding="{Binding BeginBalance, StringFormat=N0}" Width="*">
                                    <DataGridTextColumn.Header>
                                        <TextBlock Text="{DynamicResource Calc.Loan.Col.BeginBalance}" />
                                    </DataGridTextColumn.Header>
                                </DataGridTextColumn>
                                <DataGridTextColumn Binding="{Binding Payment, StringFormat=N0}" Width="*">
                                    <DataGridTextColumn.Header>
                                        <TextBlock Text="{DynamicResource Calc.Loan.Col.Payment}" />
                                    </DataGridTextColumn.Header>
                                </DataGridTextColumn>
                                <DataGridTextColumn Binding="{Binding Principal, StringFormat=N0}" Width="*">
                                    <DataGridTextColumn.Header>
                                        <TextBlock Text="{DynamicResource Calc.Loan.Col.Principal}" />
                                    </DataGridTextColumn.Header>
                                </DataGridTextColumn>
                                <DataGridTextColumn Binding="{Binding Interest, StringFormat=N0}" Width="*">
                                    <DataGridTextColumn.Header>
                                        <TextBlock Text="{DynamicResource Calc.Loan.Col.Interest}" />
                                    </DataGridTextColumn.Header>
                                </DataGridTextColumn>
                                <DataGridTextColumn Binding="{Binding EndBalance, StringFormat=N0}" Width="*">
                                    <DataGridTextColumn.Header>
                                        <TextBlock Text="{DynamicResource Calc.Loan.Col.EndBalance}" />
                                    </DataGridTextColumn.Header>
                                </DataGridTextColumn>
                            </DataGrid.Columns>
                        </DataGrid>
                    </Expander>
                </StackPanel>
            </StackPanel>
        </Grid>
        <Border Grid.Row="4" Height="32" />
        </Grid>
    </ScrollViewer>
</UserControl>
