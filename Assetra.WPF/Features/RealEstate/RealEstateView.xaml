<UserControl
    x:Class="Assetra.WPF.Features.RealEstate.RealEstateView"
    xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
    xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
    xmlns:d="http://schemas.microsoft.com/expression/blend/2008"
    xmlns:mc="http://schemas.openxmlformats.org/markup-compatibility/2006"
    xmlns:ui="http://schemas.lepo.co/wpfui/2022/xaml"
    xmlns:vm="clr-namespace:Assetra.WPF.Features.RealEstate"
    d:DataContext="{d:DesignInstance Type={x:Type vm:RealEstateViewModel}, IsDesignTimeCreatable=False}"
    d:DesignHeight="800"
    d:DesignWidth="1200"
    Background="{DynamicResource AppBackground}"
    mc:Ignorable="d">

    <Grid Margin="20">
        <Grid.RowDefinitions>
            <RowDefinition Height="Auto" />
            <RowDefinition Height="Auto" />
            <RowDefinition Height="Auto" />
            <RowDefinition Height="Auto" />
        </Grid.RowDefinitions>

        <!--  Header  -->
        <StackPanel Grid.Row="0" Margin="0,0,0,16" Orientation="Horizontal">
            <TextBlock
                Margin="16,0,0,0"
                VerticalAlignment="Bottom"
                FontSize="{DynamicResource FontSizeBase}"
                Foreground="{DynamicResource AppTextSecondary}">
                <Run Text="{DynamicResource RealEstate.TotalEquity}" />
                <Run Text="{Binding TotalEquity, StringFormat=N0}" />
            </TextBlock>
        </StackPanel>

        <!--  Error  -->
        <TextBlock
            Grid.Row="1"
            Margin="0,0,0,8"
            Foreground="{DynamicResource AppDanger}"
            Text="{Binding ErrorMessage}"
            Visibility="{Binding ErrorMessage, Converter={StaticResource NullToVisibilityConverter}}" />

        <!--  Property list  -->
        <ui:Card
            Grid.Row="2"
            Padding="0">
            <ui:DataGrid
                MaxHeight="500"
                AutoGenerateColumns="False"
                CanUserAddRows="False"
                CanUserDeleteRows="False"
                GridLinesVisibility="Horizontal"
                HeadersVisibility="Column"
                IsReadOnly="True"
                ItemsSource="{Binding Properties}"
                RowBackground="Transparent"
                SelectionMode="Single">
                <DataGrid.Columns>
                    <DataGridTextColumn
                        Width="*"
                        Binding="{Binding Name}"
                        Header="{DynamicResource RealEstate.Column.Name}" />
                    <DataGridTextColumn
                        Width="2*"
                        Binding="{Binding Address}"
                        Header="{DynamicResource RealEstate.Column.Address}" />
                    <DataGridTextColumn
                        Width="120"
                        Binding="{Binding CurrentValue, StringFormat=N0}"
                        Header="{DynamicResource RealEstate.Column.CurrentValue}" />
                    <DataGridTextColumn
                        Width="120"
                        Binding="{Binding MortgageBalance, StringFormat=N0}"
                        Header="{DynamicResource RealEstate.Column.Mortgage}" />
                    <DataGridTextColumn
                        Width="120"
                        Binding="{Binding Equity, StringFormat=N0}"
                        Header="{DynamicResource RealEstate.Column.Equity}" />
                    <DataGridTextColumn
                        Width="80"
                        Binding="{Binding Currency}"
                        Header="{DynamicResource RealEstate.Column.Currency}" />
                    <DataGridTemplateColumn Width="120" Header="{DynamicResource Common.Actions}">
                        <DataGridTemplateColumn.CellTemplate>
                            <DataTemplate>
                                <StackPanel Orientation="Horizontal">
                                    <ui:Button
                                        Margin="0,0,4,0"
                                        Padding="6"
                                        Appearance="Transparent"
                                        Command="{Binding DataContext.EditCommand, RelativeSource={RelativeSource AncestorType=DataGrid}}"
                                        CommandParameter="{Binding}"
                                        ToolTip="{DynamicResource Common.Edit}">
                    <ui:SymbolIcon Symbol="Edit24" />
                  </ui:Button>
                                    <ui:Button
                                        Padding="6"
                                        Appearance="Transparent"
                                        Command="{Binding DataContext.DeleteCommand, RelativeSource={RelativeSource AncestorType=DataGrid}}"
                                        CommandParameter="{Binding}"
                                        ToolTip="{DynamicResource Common.Delete}">
                    <ui:SymbolIcon Foreground="{DynamicResource AppDanger}" Symbol="Delete24" />
                  </ui:Button>
                                </StackPanel>
                            </DataTemplate>
                        </DataGridTemplateColumn.CellTemplate>
                    </DataGridTemplateColumn>
                </DataGrid.Columns>
            </ui:DataGrid>
        </ui:Card>

        <!--  Add/Edit form  -->
        <Border
            Grid.Row="3"
            Margin="0,16,0,0"
            Style="{StaticResource FormCard}">
            <StackPanel>
                <TextBlock
                    Style="{StaticResource FormSectionTitle}"
                    Text="{DynamicResource RealEstate.Form.Title}" />

                <UniformGrid Columns="4" Rows="2">
                    <StackPanel Margin="0,0,8,8">
                        <TextBlock Foreground="{DynamicResource AppTextSecondary}" Text="{DynamicResource RealEstate.Form.Name}" />
                        <ui:TextBox Text="{Binding FormName, UpdateSourceTrigger=PropertyChanged}" />
                    </StackPanel>
                    <StackPanel Margin="0,0,8,8">
                        <TextBlock Foreground="{DynamicResource AppTextSecondary}" Text="{DynamicResource RealEstate.Form.Address}" />
                        <ui:TextBox Text="{Binding FormAddress, UpdateSourceTrigger=PropertyChanged}" />
                    </StackPanel>
                    <StackPanel Margin="0,0,8,8">
                        <TextBlock Foreground="{DynamicResource AppTextSecondary}" Text="{DynamicResource RealEstate.Form.PurchasePrice}" />
                        <ui:TextBox Text="{Binding FormPurchasePrice, UpdateSourceTrigger=PropertyChanged}" />
                    </StackPanel>
                    <StackPanel Margin="0,0,0,8">
                        <TextBlock Foreground="{DynamicResource AppTextSecondary}" Text="{DynamicResource RealEstate.Form.CurrentValue}" />
                        <ui:TextBox Text="{Binding FormCurrentValue, UpdateSourceTrigger=PropertyChanged}" />
                    </StackPanel>
                    <StackPanel Margin="0,0,8,0">
                        <TextBlock Foreground="{DynamicResource AppTextSecondary}" Text="{DynamicResource RealEstate.Form.MortgageBalance}" />
                        <ui:TextBox Text="{Binding FormMortgageBalance, UpdateSourceTrigger=PropertyChanged}" />
                    </StackPanel>
                    <StackPanel Margin="0,0,8,0">
                        <TextBlock Foreground="{DynamicResource AppTextSecondary}" Text="{DynamicResource RealEstate.Form.Currency}" />
                        <ui:TextBox Text="{Binding FormCurrency, UpdateSourceTrigger=PropertyChanged}" />
                    </StackPanel>
                    <StackPanel Margin="0,0,8,0">
                        <!--  Spacer matches sibling label height so checkbox aligns with neighbouring TextBox row.  -->
                        <TextBlock Text=" " Visibility="Hidden" />
                        <CheckBox
                            Margin="0,4,0,0"
                            VerticalAlignment="Center"
                            Content="{DynamicResource RealEstate.Form.IsRental}"
                            IsChecked="{Binding FormIsRental}" />
                    </StackPanel>
                    <StackPanel Margin="0,0,0,0">
                        <TextBlock Foreground="{DynamicResource AppTextSecondary}" Text="{DynamicResource RealEstate.Form.Notes}" />
                        <ui:TextBox Text="{Binding FormNotes, UpdateSourceTrigger=PropertyChanged}" />
                    </StackPanel>
                </UniformGrid>

                <TextBlock
                    Margin="0,8,0,0"
                    Foreground="{DynamicResource AppDanger}"
                    Text="{Binding FormError}"
                    Visibility="{Binding FormError, Converter={StaticResource NullToVisibilityConverter}}" />

                <StackPanel Margin="0,12,0,0" HorizontalAlignment="Right" Orientation="Horizontal">
                    <ui:Button
                        Margin="0,0,8,0"
                        Command="{Binding CancelEditCommand}"
                        Content="{DynamicResource Common.Cancel}"
                        Appearance="Secondary"
                        Visibility="{Binding IsEditing, Converter={StaticResource BoolToVisibilityConverter}}" />
                    <ui:Button Command="{Binding SaveCommand}" Content="{DynamicResource Common.Save}" />
                </StackPanel>
            </StackPanel>
        </Border>
    </Grid>
</UserControl>
