<UserControl
    x:Class="Assetra.WPF.Features.Insurance.InsurancePolicyView"
    xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
    xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
    xmlns:behaviors="clr-namespace:Assetra.WPF.Infrastructure.Behaviors"
    xmlns:d="http://schemas.microsoft.com/expression/blend/2008"
    xmlns:mc="http://schemas.openxmlformats.org/markup-compatibility/2006"
    xmlns:ui="http://schemas.lepo.co/wpfui/2022/xaml"
    xmlns:vm="clr-namespace:Assetra.WPF.Features.Insurance"
    d:DataContext="{d:DesignInstance Type={x:Type vm:InsurancePolicyViewModel}, IsDesignTimeCreatable=False}"
    d:DesignHeight="800"
    d:DesignWidth="1200"
    Background="{DynamicResource AppBackground}"
    mc:Ignorable="d">

    <UserControl.Resources>
        <!-- Native WPF ComboBox keeps FormComboBox styling; Wpf.Ui doesn't ship a ComboBox. -->
        <Style BasedOn="{StaticResource FormComboBox}" TargetType="ComboBox" />
    </UserControl.Resources>

    <Grid Margin="24">
        <Grid.RowDefinitions>
            <RowDefinition Height="Auto" />
            <RowDefinition Height="Auto" />
            <RowDefinition Height="Auto" />
            <RowDefinition Height="*" />
        </Grid.RowDefinitions>

        <DockPanel Grid.Row="0" Margin="0,0,0,16" LastChildFill="True">
            <ui:Button
                DockPanel.Dock="Right"
                VerticalAlignment="Center"
                Command="{Binding OpenAddFormCommand}"
                Appearance="Primary"
                Visibility="{Binding IsFormOpen, Converter={StaticResource InverseBooleanToVisibilityConverter}}">
                <StackPanel Orientation="Horizontal">
                    <ui:SymbolIcon
                        Margin="0,0,4,0"
                        VerticalAlignment="Center"
                        FontSize="{StaticResource FontSizeXs}"
                        Foreground="{Binding Foreground, RelativeSource={RelativeSource AncestorType=Button}}"
                        Symbol="Add24" />
                    <TextBlock
                        VerticalAlignment="Center"
                        Foreground="{Binding Foreground, RelativeSource={RelativeSource AncestorType=Button}}"
                        Text="{DynamicResource Insurance.Action.Add}" />
                </StackPanel>
            </ui:Button>

            <TextBlock
                VerticalAlignment="Center"
                FontSize="{StaticResource FontSizeXl}"
                FontWeight="SemiBold"
                Foreground="{DynamicResource AppTextPrimary}"
                Text="{DynamicResource Insurance.Title}" />
        </DockPanel>

        <UniformGrid Grid.Row="1" Margin="0,0,0,16" Columns="3">
            <ui:Card Margin="0,0,12,0" Padding="16">
                <StackPanel>
                    <StackPanel Orientation="Horizontal">
                        <ui:SymbolIcon
                            Margin="0,0,8,0"
                            Foreground="{DynamicResource AppTextMuted}"
                            Symbol="Shield24" />
                        <TextBlock
                            FontSize="{StaticResource FontSizeXs}"
                            Foreground="{DynamicResource AppTextSecondary}"
                            Text="{DynamicResource Insurance.TotalCashValue}" />
                    </StackPanel>
                    <TextBlock
                        Margin="0,8,0,0"
                        FontSize="{StaticResource FontSizeXl}"
                        FontWeight="SemiBold"
                        Foreground="{DynamicResource AppTextPrimary}"
                        Text="{Binding TotalCashValue, StringFormat=N0}"
                        Typography.NumeralAlignment="Tabular" />
                </StackPanel>
            </ui:Card>

            <ui:Card Margin="0,0,12,0" Padding="16">
                <StackPanel>
                    <TextBlock
                        FontSize="{StaticResource FontSizeXs}"
                        Foreground="{DynamicResource AppTextSecondary}"
                        Text="{DynamicResource Insurance.TotalAnnualPremium}" />
                    <TextBlock
                        Margin="0,8,0,0"
                        FontSize="{StaticResource FontSizeXl}"
                        FontWeight="SemiBold"
                        Foreground="{DynamicResource AppTextPrimary}"
                        Text="{Binding TotalAnnualPremium, StringFormat=N0}"
                        Typography.NumeralAlignment="Tabular" />
                </StackPanel>
            </ui:Card>

            <ui:Card Padding="16">
                <StackPanel>
                    <TextBlock
                        FontSize="{StaticResource FontSizeXs}"
                        Foreground="{DynamicResource AppTextSecondary}"
                        Text="{DynamicResource Insurance.Count}" />
                    <TextBlock
                        Margin="0,8,0,0"
                        FontSize="{StaticResource FontSizeXl}"
                        FontWeight="SemiBold"
                        Foreground="{DynamicResource AppTextPrimary}"
                        Text="{Binding PolicyCount}" />
                </StackPanel>
            </ui:Card>
        </UniformGrid>

        <TextBlock
            Grid.Row="2"
            Margin="0,0,0,8"
            Foreground="{DynamicResource AppDanger}"
            Text="{Binding ErrorMessage}"
            Visibility="{Binding ErrorMessage, Converter={StaticResource NullToVisibilityConverter}}" />

        <Grid Grid.Row="3">
            <ScrollViewer
                VerticalScrollBarVisibility="Auto"
                Visibility="{Binding HasPolicies, Converter={StaticResource BooleanToVisibilityConverter}}">
                <ItemsControl ItemsSource="{Binding Policies}">
                    <ItemsControl.ItemTemplate>
                        <DataTemplate DataType="{x:Type vm:InsurancePolicyRowViewModel}">
                            <Border
                                Margin="0,0,0,12"
                                Padding="16"
                                Background="{DynamicResource AppSurface}"
                                BorderBrush="{DynamicResource AppBorder}"
                                BorderThickness="1"
                                CornerRadius="{StaticResource RadiusMd}">
                                <Grid>
                                    <Grid.RowDefinitions>
                                        <RowDefinition Height="Auto" />
                                        <RowDefinition Height="Auto" />
                                    </Grid.RowDefinitions>
                                    <Grid.ColumnDefinitions>
                                        <ColumnDefinition Width="*" />
                                        <ColumnDefinition Width="Auto" />
                                    </Grid.ColumnDefinitions>

                                    <StackPanel Grid.Row="0" Grid.Column="0">
                                        <StackPanel Orientation="Horizontal">
                                            <TextBlock
                                                FontSize="{StaticResource FontSizeMd}"
                                                FontWeight="SemiBold"
                                                Foreground="{DynamicResource AppTextPrimary}"
                                                Text="{Binding Name}" />
                                            <Border
                                                Margin="8,0,0,0"
                                                Padding="8,2"
                                                VerticalAlignment="Center"
                                                Background="{DynamicResource AppHover}"
                                                CornerRadius="{StaticResource RadiusSm}">
                                                <TextBlock
                                                    FontSize="{StaticResource FontSizeXs}"
                                                    Foreground="{DynamicResource AppTextSecondary}"
                                                    Text="{Binding TypeDisplay}" />
                                            </Border>
                                        </StackPanel>
                                        <TextBlock
                                            Margin="0,4,0,0"
                                            FontSize="{StaticResource FontSizeSm}"
                                            Foreground="{DynamicResource AppTextSecondary}"
                                            TextTrimming="CharacterEllipsis">
                                            <Run Text="{Binding Insurer}" />
                                            <Run Text=" · " />
                                            <Run Text="{Binding PolicyNumber}" />
                                        </TextBlock>
                                    </StackPanel>

                                    <StackPanel
                                        Grid.Row="0"
                                        Grid.Column="1"
                                        Orientation="Horizontal">
                                        <ui:Button
                                            Width="32"
                                            Height="32"
                                            Margin="0,0,4,0"
                                            Padding="0"
                                            Appearance="Transparent"
                                            Command="{Binding DataContext.EditCommand, RelativeSource={RelativeSource AncestorType=ItemsControl}}"
                                            CommandParameter="{Binding}"
                                            ToolTip="{DynamicResource Common.Edit}">
                                            <ui:SymbolIcon FontSize="14" Symbol="Edit24" />
                                        </ui:Button>
                                        <ui:Button
                                            Width="32"
                                            Height="32"
                                            Padding="0"
                                            Appearance="Transparent"
                                            Command="{Binding DataContext.DeleteCommand, RelativeSource={RelativeSource AncestorType=ItemsControl}}"
                                            CommandParameter="{Binding}"
                                            ToolTip="{DynamicResource Common.Delete}">
                                            <ui:SymbolIcon
                                                FontSize="14"
                                                Foreground="{DynamicResource AppDanger}"
                                                Symbol="Delete24" />
                                        </ui:Button>
                                    </StackPanel>

                                    <UniformGrid
                                        Grid.Row="1"
                                        Grid.Column="0"
                                        Grid.ColumnSpan="2"
                                        Margin="0,16,0,0"
                                        Columns="5">
                                        <StackPanel Margin="0,0,16,0">
                                            <TextBlock
                                                FontSize="{StaticResource FontSizeXs}"
                                                Foreground="{DynamicResource AppTextSecondary}"
                                                Text="{DynamicResource Insurance.Column.CashValue}" />
                                            <TextBlock
                                                Margin="0,4,0,0"
                                                Foreground="{DynamicResource AppTextPrimary}"
                                                Text="{Binding CashValue, StringFormat=N0}"
                                                Typography.NumeralAlignment="Tabular" />
                                        </StackPanel>
                                        <StackPanel Margin="0,0,16,0">
                                            <TextBlock
                                                FontSize="{StaticResource FontSizeXs}"
                                                Foreground="{DynamicResource AppTextSecondary}"
                                                Text="{DynamicResource Insurance.Column.AnnualPremium}" />
                                            <TextBlock
                                                Margin="0,4,0,0"
                                                Foreground="{DynamicResource AppTextPrimary}"
                                                Text="{Binding AnnualPremium, StringFormat=N0}"
                                                Typography.NumeralAlignment="Tabular" />
                                        </StackPanel>
                                        <StackPanel Margin="0,0,16,0">
                                            <TextBlock
                                                FontSize="{StaticResource FontSizeXs}"
                                                Foreground="{DynamicResource AppTextSecondary}"
                                                Text="{DynamicResource Insurance.Form.FaceValue}" />
                                            <TextBlock
                                                Margin="0,4,0,0"
                                                Foreground="{DynamicResource AppTextPrimary}"
                                                Text="{Binding FaceValue, StringFormat=N0}"
                                                Typography.NumeralAlignment="Tabular" />
                                        </StackPanel>
                                        <StackPanel Margin="0,0,16,0">
                                            <TextBlock
                                                FontSize="{StaticResource FontSizeXs}"
                                                Foreground="{DynamicResource AppTextSecondary}"
                                                Text="{DynamicResource Insurance.Form.StartDate}" />
                                            <TextBlock
                                                Margin="0,4,0,0"
                                                Foreground="{DynamicResource AppTextPrimary}"
                                                Text="{Binding StartDate}" />
                                        </StackPanel>
                                        <StackPanel>
                                            <TextBlock
                                                FontSize="{StaticResource FontSizeXs}"
                                                Foreground="{DynamicResource AppTextSecondary}"
                                                Text="{DynamicResource Insurance.Column.Currency}" />
                                            <TextBlock
                                                Margin="0,4,0,0"
                                                Foreground="{DynamicResource AppTextPrimary}"
                                                Text="{Binding Currency}" />
                                        </StackPanel>
                                    </UniformGrid>
                                </Grid>
                            </Border>
                        </DataTemplate>
                    </ItemsControl.ItemTemplate>
                </ItemsControl>
            </ScrollViewer>

            <ui:Card
                MinHeight="240"
                Padding="32"
                Visibility="{Binding HasNoPolicies, Converter={StaticResource BooleanToVisibilityConverter}}">
                <StackPanel HorizontalAlignment="Center" VerticalAlignment="Center">
                    <ui:SymbolIcon
                        HorizontalAlignment="Center"
                        FontSize="44"
                        Foreground="{DynamicResource AppTextMuted}"
                        Symbol="Shield24" />
                    <TextBlock
                        Margin="0,12,0,0"
                        HorizontalAlignment="Center"
                        FontSize="{StaticResource FontSizeMd}"
                        FontWeight="SemiBold"
                        Foreground="{DynamicResource AppTextPrimary}"
                        Text="{DynamicResource Insurance.Empty.Title}" />
                    <TextBlock
                        Margin="0,6,0,0"
                        HorizontalAlignment="Center"
                        Foreground="{DynamicResource AppTextSecondary}"
                        Text="{DynamicResource Insurance.Empty.Hint}"
                        TextAlignment="Center"
                        TextWrapping="Wrap" />
                    <ui:Button
                        Margin="0,16,0,0"
                        HorizontalAlignment="Center"
                        Command="{Binding OpenAddFormCommand}"
                        Appearance="Primary"
                        Visibility="{Binding IsFormOpen, Converter={StaticResource InverseBooleanToVisibilityConverter}}">
                        <StackPanel Orientation="Horizontal">
                            <ui:SymbolIcon
                                Margin="0,0,4,0"
                                VerticalAlignment="Center"
                                FontSize="{StaticResource FontSizeXs}"
                                Foreground="{Binding Foreground, RelativeSource={RelativeSource AncestorType=Button}}"
                                Symbol="Add24" />
                            <TextBlock
                                VerticalAlignment="Center"
                                Foreground="{Binding Foreground, RelativeSource={RelativeSource AncestorType=Button}}"
                                Text="{DynamicResource Insurance.Action.Add}" />
                        </StackPanel>
                    </ui:Button>
                </StackPanel>
            </ui:Card>
        </Grid>

        <Border
            Grid.Row="0"
            Grid.RowSpan="4"
            Margin="-24"
            Panel.ZIndex="180"
            Background="{DynamicResource AppModalOverlay}"
            Visibility="{Binding IsFormOpen, Converter={StaticResource BooleanToVisibilityConverter}}" />

        <Border
            Grid.Row="0"
            Grid.RowSpan="4"
            Width="920"
            MaxHeight="680"
            HorizontalAlignment="Center"
            VerticalAlignment="Center"
            Panel.ZIndex="181"
            Style="{StaticResource FormCard}"
            Visibility="{Binding IsFormOpen, Converter={StaticResource BooleanToVisibilityConverter}}">
            <Grid>
                <Grid.RowDefinitions>
                    <RowDefinition Height="Auto" />
                    <RowDefinition Height="Auto" />
                    <RowDefinition Height="Auto" />
                    <RowDefinition Height="Auto" />
                </Grid.RowDefinitions>

                <DockPanel Grid.Row="0" Margin="0,0,0,16">
                    <ui:Button
                        Width="32"
                        Height="32"
                        Padding="0"
                        Command="{Binding CancelEditCommand}"
                        DockPanel.Dock="Right"
                        Appearance="Transparent"
                        ToolTip="{DynamicResource Common.Close}">
                        <ui:SymbolIcon FontSize="12" Symbol="Dismiss24" />
                    </ui:Button>
                    <TextBlock
                        VerticalAlignment="Center"
                        Style="{StaticResource FormSectionTitle}"
                        Text="{DynamicResource Insurance.Form.Title}" />
                </DockPanel>

                <UniformGrid Grid.Row="1" Columns="2" Rows="6">
                    <StackPanel Margin="0,0,12,12">
                        <TextBlock Foreground="{DynamicResource AppTextSecondary}" Text="{DynamicResource Insurance.Form.Name}" />
                        <ui:TextBox Text="{Binding FormName, UpdateSourceTrigger=PropertyChanged}" />
                    </StackPanel>
                    <StackPanel Margin="0,0,0,12">
                        <TextBlock Foreground="{DynamicResource AppTextSecondary}" Text="{DynamicResource Insurance.Form.PolicyNumber}" />
                        <ui:TextBox Text="{Binding FormPolicyNumber, UpdateSourceTrigger=PropertyChanged}" />
                    </StackPanel>
                    <StackPanel Margin="0,0,12,12">
                        <TextBlock Foreground="{DynamicResource AppTextSecondary}" Text="{DynamicResource Insurance.Form.Insurer}" />
                        <ui:TextBox Text="{Binding FormInsurer, UpdateSourceTrigger=PropertyChanged}" />
                    </StackPanel>
                    <StackPanel Margin="0,0,0,12">
                        <TextBlock Foreground="{DynamicResource AppTextSecondary}" Text="{DynamicResource Insurance.Form.Type}" />
                        <ComboBox
                            DisplayMemberPath="DisplayName"
                            ItemsSource="{Binding InsuranceTypeOptions}"
                            SelectedValue="{Binding FormType, Mode=TwoWay}"
                            SelectedValuePath="Value" />
                    </StackPanel>
                    <StackPanel Margin="0,0,12,12">
                        <TextBlock Foreground="{DynamicResource AppTextSecondary}" Text="{DynamicResource Insurance.Form.FaceValue}" />
                        <ui:TextBox
                            behaviors:ThousandSeparatorBehavior.IsEnabled="True"
                            Text="{Binding FormFaceValue, UpdateSourceTrigger=PropertyChanged}" />
                    </StackPanel>
                    <StackPanel Margin="0,0,0,12">
                        <TextBlock Foreground="{DynamicResource AppTextSecondary}" Text="{DynamicResource Insurance.Form.CashValue}" />
                        <ui:TextBox
                            behaviors:ThousandSeparatorBehavior.IsEnabled="True"
                            Text="{Binding FormCurrentCashValue, UpdateSourceTrigger=PropertyChanged}" />
                    </StackPanel>
                    <StackPanel Margin="0,0,12,12">
                        <TextBlock Foreground="{DynamicResource AppTextSecondary}" Text="{DynamicResource Insurance.Form.AnnualPremium}" />
                        <ui:TextBox
                            behaviors:ThousandSeparatorBehavior.IsEnabled="True"
                            Text="{Binding FormAnnualPremium, UpdateSourceTrigger=PropertyChanged}" />
                    </StackPanel>
                    <StackPanel Margin="0,0,0,12">
                        <TextBlock Foreground="{DynamicResource AppTextSecondary}" Text="{DynamicResource Insurance.Form.Currency}" />
                        <ui:TextBox Text="{Binding FormCurrency, UpdateSourceTrigger=PropertyChanged}" />
                    </StackPanel>
                    <StackPanel Margin="0,0,12,12">
                        <TextBlock Foreground="{DynamicResource AppTextSecondary}" Text="{DynamicResource Insurance.Form.StartDate}" />
                        <ui:CalendarDatePicker Date="{Binding FormStartDate, Mode=TwoWay}" />
                    </StackPanel>
                    <StackPanel Margin="0,0,0,12">
                        <TextBlock Foreground="{DynamicResource AppTextSecondary}" Text="{DynamicResource Insurance.Form.MaturityDate}" />
                        <ui:CalendarDatePicker Date="{Binding FormMaturityDate, Mode=TwoWay}" />
                    </StackPanel>
                    <StackPanel Margin="0,0,12,0">
                        <TextBlock Foreground="{DynamicResource AppTextSecondary}" Text="{DynamicResource Insurance.Form.Notes}" />
                        <ui:TextBox Text="{Binding FormNotes, UpdateSourceTrigger=PropertyChanged}" />
                    </StackPanel>
                </UniformGrid>

                <TextBlock
                    Grid.Row="2"
                    Margin="0,8,0,0"
                    Foreground="{DynamicResource AppDanger}"
                    Text="{Binding FormError}"
                    Visibility="{Binding FormError, Converter={StaticResource NullToVisibilityConverter}}" />

                <StackPanel
                    Grid.Row="3"
                    Margin="0,16,0,0"
                    HorizontalAlignment="Right"
                    Orientation="Horizontal">
                    <ui:Button
                        Margin="0,0,8,0"
                        Command="{Binding CancelEditCommand}"
                        Content="{DynamicResource Common.Cancel}"
                        Appearance="Secondary" />
                    <ui:Button Command="{Binding SaveCommand}" Appearance="Primary">
                        <TextBlock
                            Foreground="{Binding Foreground, RelativeSource={RelativeSource AncestorType=Button}}"
                            Text="{DynamicResource Common.Save}" />
                    </ui:Button>
                </StackPanel>
            </Grid>
        </Border>
    </Grid>
</UserControl>
