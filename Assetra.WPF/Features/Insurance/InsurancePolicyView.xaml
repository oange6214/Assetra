<UserControl
    x:Class="Assetra.WPF.Features.Insurance.InsurancePolicyView"
    xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
    xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
    xmlns:behaviors="clr-namespace:Assetra.WPF.Infrastructure.Behaviors"
    xmlns:d="http://schemas.microsoft.com/expression/blend/2008"
    xmlns:mc="http://schemas.openxmlformats.org/markup-compatibility/2006"
    xmlns:ds="clr-namespace:Assetra.WPF.DesignSystem.Controls"
    xmlns:vm="clr-namespace:Assetra.WPF.Features.Insurance"
    d:DataContext="{d:DesignInstance Type={x:Type vm:InsurancePolicyViewModel}, IsDesignTimeCreatable=False}"
    d:DesignHeight="800"
    d:DesignWidth="1200"
    Background="{DynamicResource AppBackground}"
    mc:Ignorable="d">

    <UserControl.Resources>
        <Style BasedOn="{StaticResource AppComboBox}" TargetType="ComboBox" />
    </UserControl.Resources>

    <Grid Style="{StaticResource PageRootGrid}">
        <Grid.RowDefinitions>
            <RowDefinition Height="Auto" />
            <RowDefinition Height="Auto" />
            <RowDefinition Height="Auto" />
            <RowDefinition Height="*" />
        </Grid.RowDefinitions>

        <DockPanel Grid.Row="0" Style="{StaticResource PageHeaderDock}">
            <Button
                DockPanel.Dock="Right"
                Command="{Binding OpenAddFormCommand}"
                Style="{StaticResource AppPrimaryButton}"
                Visibility="{Binding IsFormOpen, Converter={StaticResource InverseBooleanToVisibilityConverter}}">
                <StackPanel Orientation="Horizontal">
                    <ds:AppIcon
                        Margin="0,0,4,0"
                        VerticalAlignment="Center"
                        FontSize="{StaticResource Font.Size.Xs}"
                        Foreground="{Binding Foreground, RelativeSource={RelativeSource AncestorType=Button}}"
                        Symbol="Add24" />
                    <TextBlock
                        VerticalAlignment="Center"
                        Foreground="{Binding Foreground, RelativeSource={RelativeSource AncestorType=Button}}"
                        Text="{DynamicResource Insurance.Action.Add}" />
                </StackPanel>
            </Button>

            <TextBlock
                Style="{StaticResource PageTitleText}"
                Text="{DynamicResource Insurance.Title}" />
        </DockPanel>

        <UniformGrid Grid.Row="1" Columns="3" Style="{StaticResource PageMetricsGrid}">
            <Border Style="{StaticResource FormCard}" Margin="0,0,12,0" Padding="16">
                <StackPanel>
                    <StackPanel Orientation="Horizontal">
                        <ds:AppIcon
                            Margin="0,0,8,0"
                            Foreground="{DynamicResource AppTextMuted}"
                            Symbol="Shield24" />
                        <TextBlock
                            FontSize="{StaticResource Font.Size.Xs}"
                            Foreground="{DynamicResource AppTextSecondary}"
                            Text="{DynamicResource Insurance.TotalCashValue}" />
                    </StackPanel>
                    <TextBlock
                        Margin="0,8,0,0"
                        FontSize="{StaticResource Font.Size.Xl}"
                        FontWeight="SemiBold"
                        Foreground="{DynamicResource AppTextPrimary}"
                        Text="{Binding TotalCashValue, StringFormat=N0}"
                        Typography.NumeralAlignment="Tabular" />
                </StackPanel>
            </Border>

            <Border Style="{StaticResource FormCard}" Margin="0,0,12,0" Padding="16">
                <StackPanel>
                    <TextBlock
                        FontSize="{StaticResource Font.Size.Xs}"
                        Foreground="{DynamicResource AppTextSecondary}"
                        Text="{DynamicResource Insurance.TotalAnnualPremium}" />
                    <TextBlock
                        Margin="0,8,0,0"
                        FontSize="{StaticResource Font.Size.Xl}"
                        FontWeight="SemiBold"
                        Foreground="{DynamicResource AppTextPrimary}"
                        Text="{Binding TotalAnnualPremium, StringFormat=N0}"
                        Typography.NumeralAlignment="Tabular" />
                </StackPanel>
            </Border>

            <Border Style="{StaticResource FormCard}" Padding="16">
                <StackPanel>
                    <TextBlock
                        FontSize="{StaticResource Font.Size.Xs}"
                        Foreground="{DynamicResource AppTextSecondary}"
                        Text="{DynamicResource Insurance.Count}" />
                    <TextBlock
                        Margin="0,8,0,0"
                        FontSize="{StaticResource Font.Size.Xl}"
                        FontWeight="SemiBold"
                        Foreground="{DynamicResource AppTextPrimary}"
                        Text="{Binding PolicyCount}" />
                </StackPanel>
            </Border>
        </UniformGrid>

        <TextBlock
            Grid.Row="2"
            Style="{StaticResource PageErrorText}"
            Text="{Binding ErrorMessage}"
            Visibility="{Binding ErrorMessage, Converter={StaticResource NullToVisibilityConverter}}" />

        <Grid Grid.Row="3" Style="{StaticResource PageContentGrid}">
            <ScrollViewer
                VerticalScrollBarVisibility="Auto"
                Visibility="{Binding HasPolicies, Converter={StaticResource BooleanToVisibilityConverter}}">
                <ItemsControl ItemsSource="{Binding Policies}">
                    <ItemsControl.ItemTemplate>
                        <DataTemplate DataType="{x:Type vm:InsurancePolicyRowViewModel}">
                            <Border
                                Margin="0,0,0,12"
                                Padding="16"
                                Background="{DynamicResource AppSurface}"
                                BorderBrush="{DynamicResource AppBorder}"
                                BorderThickness="1"
                                CornerRadius="{StaticResource Radius.Md}">
                                <Grid>
                                    <Grid.RowDefinitions>
                                        <RowDefinition Height="Auto" />
                                        <RowDefinition Height="Auto" />
                                    </Grid.RowDefinitions>
                                    <Grid.ColumnDefinitions>
                                        <ColumnDefinition Width="*" />
                                        <ColumnDefinition Width="Auto" />
                                    </Grid.ColumnDefinitions>

                                    <StackPanel Grid.Row="0" Grid.Column="0">
                                        <StackPanel Orientation="Horizontal">
                                            <TextBlock
                                                FontSize="{StaticResource Font.Size.Md}"
                                                FontWeight="SemiBold"
                                                Foreground="{DynamicResource AppTextPrimary}"
                                                Text="{Binding Name}" />
                                            <Border
                                                Margin="8,0,0,0"
                                                Padding="8,2"
                                                VerticalAlignment="Center"
                                                Background="{DynamicResource AppHover}"
                                                CornerRadius="{StaticResource Radius.Sm}">
                                                <TextBlock
                                                    FontSize="{StaticResource Font.Size.Xs}"
                                                    Foreground="{DynamicResource AppTextSecondary}"
                                                    Text="{Binding TypeDisplay}" />
                                            </Border>
                                        </StackPanel>
                                        <TextBlock
                                            Margin="0,4,0,0"
                                            FontSize="{StaticResource Font.Size.Sm}"
                                            Foreground="{DynamicResource AppTextSecondary}"
                                            TextTrimming="CharacterEllipsis">
                                            <Run Text="{Binding Insurer}" />
                                            <Run Text=" · " />
                                            <Run Text="{Binding PolicyNumber}" />
                                        </TextBlock>
                                    </StackPanel>

                                    <StackPanel
                                        Grid.Row="0"
                                        Grid.Column="1"
                                        Orientation="Horizontal">
                                        <Button
                                            Width="32"
                                            Height="32"
                                            Margin="0,0,4,0"
                                            Padding="0"
                                            Style="{StaticResource AppIconButton}"
                                            Command="{Binding DataContext.EditCommand, RelativeSource={RelativeSource AncestorType=ItemsControl}}"
                                            CommandParameter="{Binding}"
                                            ToolTip="{DynamicResource Common.Edit}">
                                            <ds:AppIcon FontSize="14" Symbol="Edit24" />
                                        </Button>
                                        <Button
                                            Width="32"
                                            Height="32"
                                            Padding="0"
                                            Style="{StaticResource AppIconButton}"
                                            Command="{Binding DataContext.DeleteCommand, RelativeSource={RelativeSource AncestorType=ItemsControl}}"
                                            CommandParameter="{Binding}"
                                            ToolTip="{DynamicResource Common.Delete}">
                                            <ds:AppIcon
                                                FontSize="14"
                                                Foreground="{DynamicResource AppDanger}"
                                                Symbol="Delete24" />
                                        </Button>
                                    </StackPanel>

                                    <UniformGrid
                                        Grid.Row="1"
                                        Grid.Column="0"
                                        Grid.ColumnSpan="2"
                                        Margin="0,16,0,0"
                                        Columns="5">
                                        <StackPanel Margin="0,0,16,0">
                                            <TextBlock
                                                FontSize="{StaticResource Font.Size.Xs}"
                                                Foreground="{DynamicResource AppTextSecondary}"
                                                Text="{DynamicResource Insurance.Column.CashValue}" />
                                            <TextBlock
                                                Margin="0,4,0,0"
                                                Foreground="{DynamicResource AppTextPrimary}"
                                                Text="{Binding CashValue, StringFormat=N0}"
                                                Typography.NumeralAlignment="Tabular" />
                                        </StackPanel>
                                        <StackPanel Margin="0,0,16,0">
                                            <TextBlock
                                                FontSize="{StaticResource Font.Size.Xs}"
                                                Foreground="{DynamicResource AppTextSecondary}"
                                                Text="{DynamicResource Insurance.Column.AnnualPremium}" />
                                            <TextBlock
                                                Margin="0,4,0,0"
                                                Foreground="{DynamicResource AppTextPrimary}"
                                                Text="{Binding AnnualPremium, StringFormat=N0}"
                                                Typography.NumeralAlignment="Tabular" />
                                        </StackPanel>
                                        <StackPanel Margin="0,0,16,0">
                                            <TextBlock
                                                FontSize="{StaticResource Font.Size.Xs}"
                                                Foreground="{DynamicResource AppTextSecondary}"
                                                Text="{DynamicResource Insurance.Form.FaceValue}" />
                                            <TextBlock
                                                Margin="0,4,0,0"
                                                Foreground="{DynamicResource AppTextPrimary}"
                                                Text="{Binding FaceValue, StringFormat=N0}"
                                                Typography.NumeralAlignment="Tabular" />
                                        </StackPanel>
                                        <StackPanel Margin="0,0,16,0">
                                            <TextBlock
                                                FontSize="{StaticResource Font.Size.Xs}"
                                                Foreground="{DynamicResource AppTextSecondary}"
                                                Text="{DynamicResource Insurance.Form.StartDate}" />
                                            <TextBlock
                                                Margin="0,4,0,0"
                                                Foreground="{DynamicResource AppTextPrimary}"
                                                Text="{Binding StartDate}" />
                                        </StackPanel>
                                        <StackPanel>
                                            <TextBlock
                                                FontSize="{StaticResource Font.Size.Xs}"
                                                Foreground="{DynamicResource AppTextSecondary}"
                                                Text="{DynamicResource Insurance.Column.Currency}" />
                                            <TextBlock
                                                Margin="0,4,0,0"
                                                Foreground="{DynamicResource AppTextPrimary}"
                                                Text="{Binding Currency}" />
                                        </StackPanel>
                                    </UniformGrid>
                                </Grid>
                            </Border>
                        </DataTemplate>
                    </ItemsControl.ItemTemplate>
                </ItemsControl>
            </ScrollViewer>

            <StackPanel
                Style="{StaticResource EmptyStatePanel}"
                Visibility="{Binding HasNoPolicies, Converter={StaticResource BooleanToVisibilityConverter}}">
                <ds:AppIcon Style="{StaticResource EmptyStateIcon}" Symbol="Shield24" />
                <TextBlock Style="{StaticResource EmptyStateTitle}" Text="{DynamicResource Insurance.Empty.Title}" />
                <TextBlock Style="{StaticResource EmptyStateHint}" Text="{DynamicResource Insurance.Empty.Hint}" />
                <Button
                    Command="{Binding OpenAddFormCommand}"
                    HorizontalAlignment="Center"
                    Style="{StaticResource AppEmptyStatePrimaryAction}"
                    Visibility="{Binding IsFormOpen, Converter={StaticResource InverseBooleanToVisibilityConverter}}">
                    <StackPanel Style="{StaticResource AppButtonContent}">
                        <ds:AppIcon
                            Style="{StaticResource AppButtonLeadingIcon}"
                            VerticalAlignment="Center"
                            FontSize="{StaticResource Font.Size.Xs}"
                            Foreground="{Binding Foreground, RelativeSource={RelativeSource AncestorType=Button}}"
                            Symbol="Add24" />
                        <TextBlock
                            VerticalAlignment="Center"
                            Foreground="{Binding Foreground, RelativeSource={RelativeSource AncestorType=Button}}"
                            Text="{DynamicResource Insurance.Action.Add}" />
                    </StackPanel>
                </Button>
            </StackPanel>
        </Grid>

        <Grid
            Grid.Row="0"
            Grid.RowSpan="4"
            Margin="-24"
            Panel.ZIndex="180"
            Style="{StaticResource AppDialogOverlay}"
            Visibility="{Binding IsFormOpen, Converter={StaticResource BooleanToVisibilityConverter}}" />

        <Border
            Grid.Row="0"
            Grid.RowSpan="4"
            Width="920"
            MaxHeight="680"
            HorizontalAlignment="Center"
            VerticalAlignment="Center"
            Panel.ZIndex="181"
            behaviors:EscapeKeyCommandBehavior.Command="{Binding CancelEditCommand}"
            Style="{StaticResource AppDialogShell}"
            Visibility="{Binding IsFormOpen, Converter={StaticResource BooleanToVisibilityConverter}}">
            <Grid>
                <Grid.RowDefinitions>
                    <RowDefinition Height="Auto" />
                    <RowDefinition Height="Auto" />
                    <RowDefinition Height="Auto" />
                    <RowDefinition Height="Auto" />
                </Grid.RowDefinitions>

                <Grid Grid.Row="0" Margin="0,0,0,16">
                    <TextBlock
                        Margin="0,4,40,0"
                        VerticalAlignment="Center"
                        Style="{StaticResource FormSectionTitle}"
                        Text="{DynamicResource Insurance.Form.Title}" />
                    <Button
                        Width="32"
                        Height="32"
                        Margin="0,-4,-4,0"
                        Padding="0"
                        HorizontalAlignment="Right"
                        VerticalAlignment="Top"
                        Command="{Binding CancelEditCommand}"
                        Style="{StaticResource AppIconButton}"
                        ToolTip="{DynamicResource Common.Close}">
                        <ds:AppIcon FontSize="13" Symbol="Dismiss24" />
                    </Button>
                </Grid>

                <UniformGrid Grid.Row="1" Columns="2" Rows="6">
                    <StackPanel Margin="0,0,12,12">
                        <TextBlock Foreground="{DynamicResource AppTextSecondary}" Text="{DynamicResource Insurance.Form.Name}" />
                        <TextBox Style="{StaticResource AppTextBox}" Text="{Binding FormName, UpdateSourceTrigger=PropertyChanged}" />
                    </StackPanel>
                    <StackPanel Margin="0,0,0,12">
                        <TextBlock Foreground="{DynamicResource AppTextSecondary}" Text="{DynamicResource Insurance.Form.PolicyNumber}" />
                        <TextBox Style="{StaticResource AppTextBox}" Text="{Binding FormPolicyNumber, UpdateSourceTrigger=PropertyChanged}" />
                    </StackPanel>
                    <StackPanel Margin="0,0,12,12">
                        <TextBlock Foreground="{DynamicResource AppTextSecondary}" Text="{DynamicResource Insurance.Form.Insurer}" />
                        <TextBox Style="{StaticResource AppTextBox}" Text="{Binding FormInsurer, UpdateSourceTrigger=PropertyChanged}" />
                    </StackPanel>
                    <StackPanel Margin="0,0,0,12">
                        <TextBlock Foreground="{DynamicResource AppTextSecondary}" Text="{DynamicResource Insurance.Form.Type}" />
                        <ComboBox
                            DisplayMemberPath="DisplayName"
                            ItemsSource="{Binding InsuranceTypeOptions}"
                            SelectedValue="{Binding FormType, Mode=TwoWay}"
                            SelectedValuePath="Value"
                            Style="{StaticResource AppComboBox}" />
                    </StackPanel>
                    <StackPanel Margin="0,0,12,12">
                        <TextBlock Foreground="{DynamicResource AppTextSecondary}" Text="{DynamicResource Insurance.Form.FaceValue}" />
                        <TextBox Style="{StaticResource AppTextBox}"
                            behaviors:ThousandSeparatorBehavior.IsEnabled="True"
                            Text="{Binding FormFaceValue, UpdateSourceTrigger=PropertyChanged}" />
                    </StackPanel>
                    <StackPanel Margin="0,0,0,12">
                        <TextBlock Foreground="{DynamicResource AppTextSecondary}" Text="{DynamicResource Insurance.Form.CashValue}" />
                        <TextBox Style="{StaticResource AppTextBox}"
                            behaviors:ThousandSeparatorBehavior.IsEnabled="True"
                            Text="{Binding FormCurrentCashValue, UpdateSourceTrigger=PropertyChanged}" />
                    </StackPanel>
                    <StackPanel Margin="0,0,12,12">
                        <TextBlock Foreground="{DynamicResource AppTextSecondary}" Text="{DynamicResource Insurance.Form.AnnualPremium}" />
                        <TextBox Style="{StaticResource AppTextBox}"
                            behaviors:ThousandSeparatorBehavior.IsEnabled="True"
                            Text="{Binding FormAnnualPremium, UpdateSourceTrigger=PropertyChanged}" />
                    </StackPanel>
                    <StackPanel Margin="0,0,0,12">
                        <TextBlock Foreground="{DynamicResource AppTextSecondary}" Text="{DynamicResource Insurance.Form.Currency}" />
                        <TextBox Style="{StaticResource AppTextBox}" Text="{Binding FormCurrency, UpdateSourceTrigger=PropertyChanged}" />
                    </StackPanel>
                    <StackPanel Margin="0,0,12,12">
                        <TextBlock Foreground="{DynamicResource AppTextSecondary}" Text="{DynamicResource Insurance.Form.StartDate}" />
                        <DatePicker
                            MinWidth="132"
                            HorizontalContentAlignment="Left"
                            SelectedDate="{Binding FormStartDate, Mode=TwoWay}"
                            Style="{StaticResource AppDatePicker}" />
                    </StackPanel>
                    <StackPanel Margin="0,0,0,12">
                        <TextBlock Foreground="{DynamicResource AppTextSecondary}" Text="{DynamicResource Insurance.Form.MaturityDate}" />
                        <DatePicker
                            MinWidth="132"
                            HorizontalContentAlignment="Left"
                            SelectedDate="{Binding FormMaturityDate, Mode=TwoWay}"
                            Style="{StaticResource AppDatePicker}" />
                    </StackPanel>
                    <StackPanel Margin="0,0,12,0">
                        <TextBlock Foreground="{DynamicResource AppTextSecondary}" Text="{DynamicResource Insurance.Form.Notes}" />
                        <TextBox Style="{StaticResource AppTextBox}" Text="{Binding FormNotes, UpdateSourceTrigger=PropertyChanged}" />
                    </StackPanel>
                </UniformGrid>

                <TextBlock
                    Grid.Row="2"
                    Margin="0,8,0,0"
                    Foreground="{DynamicResource AppDanger}"
                    Text="{Binding FormError}"
                    Visibility="{Binding FormError, Converter={StaticResource NullToVisibilityConverter}}" />

                <StackPanel
                    Grid.Row="3"
                    Margin="0,16,0,0"
                    HorizontalAlignment="Right"
                    Orientation="Horizontal">
                    <Button
                        Margin="0,0,8,0"
                        Command="{Binding CancelEditCommand}"
                        Content="{DynamicResource Common.Cancel}"
                        Style="{StaticResource AppSecondaryButton}" />
                    <Button Command="{Binding SaveCommand}" Style="{StaticResource AppPrimaryButton}">
                        <TextBlock
                            Foreground="{Binding Foreground, RelativeSource={RelativeSource AncestorType=Button}}"
                            Text="{DynamicResource Common.Save}" />
                    </Button>
                </StackPanel>
            </Grid>
        </Border>

        <Grid
            Grid.Row="0"
            Grid.RowSpan="4"
            Margin="-24"
            Panel.ZIndex="190"
            Style="{StaticResource AppDialogOverlay}"
            Visibility="{Binding IsDeleteConfirmOpen, Converter={StaticResource BooleanToVisibilityConverter}}" />

        <Border
            Grid.Row="0"
            Grid.RowSpan="4"
            HorizontalAlignment="Center"
            VerticalAlignment="Center"
            Panel.ZIndex="191"
            behaviors:EscapeKeyCommandBehavior.Command="{Binding CancelDeleteCommand}"
            Style="{StaticResource AppDestructiveDialogShell}"
            Visibility="{Binding IsDeleteConfirmOpen, Converter={StaticResource BooleanToVisibilityConverter}}">
            <Grid>
                <Grid.RowDefinitions>
                    <RowDefinition Height="Auto" />
                    <RowDefinition Height="Auto" />
                    <RowDefinition Height="Auto" />
                </Grid.RowDefinitions>

                <TextBlock Style="{StaticResource AppDialogTitle}" Text="{DynamicResource Common.DeleteConfirmTitle}" />
                <TextBlock
                    Grid.Row="1"
                    Style="{StaticResource AppDialogSubtitle}">
                    <Run Text="{DynamicResource Common.DeleteConfirmPrefix}" />
                    <Run Text="{Binding DeleteTargetName}" />
                    <Run Text="{DynamicResource Common.DeleteConfirmSuffix}" />
                </TextBlock>

                <StackPanel Grid.Row="2" Style="{StaticResource AppDialogFooter}">
                    <Button
                        Margin="0,0,8,0"
                        Command="{Binding CancelDeleteCommand}"
                        Content="{DynamicResource Common.Cancel}"
                        Style="{StaticResource AppSecondaryButton}" />
                    <Button
                        Command="{Binding ConfirmDeleteCommand}"
                        Content="{DynamicResource Common.Delete}"
                        Style="{StaticResource AppDangerButton}" />
                </StackPanel>
            </Grid>
        </Border>
    </Grid>
</UserControl>
