<ResourceDictionary
    xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
    xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
    xmlns:models="clr-namespace:Assetra.Core.Models;assembly=Assetra.Core">

    <Style x:Key="StockSuggestionListBoxItemStyle" TargetType="ListBoxItem">
        <Setter Property="Padding" Value="10,7" />
        <Setter Property="Background" Value="Transparent" />
        <Setter Property="BorderThickness" Value="0" />
        <Setter Property="HorizontalContentAlignment" Value="Stretch" />
        <Setter Property="FocusVisualStyle" Value="{x:Null}" />
        <Style.Triggers>
            <Trigger Property="IsMouseOver" Value="True">
                <Setter Property="Background" Value="{DynamicResource AppHover}" />
            </Trigger>
        </Style.Triggers>
    </Style>

    <DataTemplate x:Key="StockSuggestionItemTemplate" DataType="{x:Type models:StockSearchResult}">
        <Grid>
            <Grid.ColumnDefinitions>
                <ColumnDefinition Width="64" />
                <ColumnDefinition Width="40" />
                <ColumnDefinition Width="*" />
            </Grid.ColumnDefinitions>

            <TextBlock
                Grid.Column="0"
                VerticalAlignment="Center"
                FontFamily="{DynamicResource FontTabular}"
                FontSize="{DynamicResource FontSizeSm}"
                FontWeight="SemiBold"
                Foreground="{DynamicResource AppTextPrimary}"
                Text="{Binding Symbol}" />

            <Border
                Grid.Column="1"
                Width="28"
                Height="20"
                Margin="0,0,8,0"
                HorizontalAlignment="Left"
                VerticalAlignment="Center"
                Background="{DynamicResource AppAccent}"
                CornerRadius="5">
                <TextBlock
                    HorizontalAlignment="Center"
                    VerticalAlignment="Center"
                    FontSize="{DynamicResource FontSizeXs}"
                    FontWeight="SemiBold"
                    Foreground="White"
                    Text="股">
                    <TextBlock.Style>
                        <Style TargetType="TextBlock">
                            <Setter Property="Text" Value="股" />
                            <Style.Triggers>
                                <DataTrigger Binding="{Binding IsEtf}" Value="True">
                                    <Setter Property="Text" Value="ETF" />
                                </DataTrigger>
                            </Style.Triggers>
                        </Style>
                    </TextBlock.Style>
                </TextBlock>
            </Border>

            <StackPanel Grid.Column="2">
                <TextBlock
                    FontSize="{DynamicResource FontSizeSm}"
                    Foreground="{DynamicResource AppTextPrimary}"
                    Text="{Binding Name}"
                    TextTrimming="CharacterEllipsis" />
                <TextBlock
                    Margin="0,2,0,0"
                    FontSize="{DynamicResource FontSizeXs}"
                    Foreground="{DynamicResource AppTextMuted}"
                    Text="{Binding Exchange}"
                    TextTrimming="CharacterEllipsis" />
            </StackPanel>
        </Grid>
    </DataTemplate>

</ResourceDictionary>
