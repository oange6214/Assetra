<ResourceDictionary
    xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
    xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
    xmlns:models="clr-namespace:Assetra.Core.Models;assembly=Assetra.Core">

    <Style x:Key="PortfolioBadgeText" TargetType="TextBlock">
        <Setter Property="HorizontalAlignment" Value="Center" />
        <Setter Property="VerticalAlignment" Value="Center" />
        <Setter Property="FontSize" Value="{DynamicResource Font.Size.Xs}" />
        <Setter Property="FontWeight" Value="SemiBold" />
        <Setter Property="Foreground" Value="{DynamicResource AppTextOnAccent}" />
    </Style>

    <Style x:Key="PortfolioBadgeBase" TargetType="Border">
        <Setter Property="Height" Value="20" />
        <Setter Property="MinWidth" Value="38" />
        <Setter Property="Padding" Value="8,0" />
        <Setter Property="HorizontalAlignment" Value="Left" />
        <Setter Property="VerticalAlignment" Value="Center" />
        <Setter Property="CornerRadius" Value="{DynamicResource Radius.Sm}" />
    </Style>

    <Style
        x:Key="PortfolioAssetTypeBadge"
        BasedOn="{StaticResource PortfolioBadgeBase}"
        TargetType="Border">
        <Setter Property="Background" Value="#0062AD" />
        <Setter Property="MinWidth" Value="34" />
        <Style.Triggers>
            <DataTrigger Binding="{Binding AssetType}" Value="{x:Static models:AssetType.Fund}">
                <Setter Property="Background" Value="#0A7A55" />
            </DataTrigger>
            <DataTrigger Binding="{Binding AssetType}" Value="{x:Static models:AssetType.PreciousMetal}">
                <Setter Property="Background" Value="#966300" />
            </DataTrigger>
            <DataTrigger Binding="{Binding AssetType}" Value="{x:Static models:AssetType.Bond}">
                <Setter Property="Background" Value="#374151" />
            </DataTrigger>
            <DataTrigger Binding="{Binding AssetType}" Value="{x:Static models:AssetType.Crypto}">
                <Setter Property="Background" Value="#5B21B6" />
            </DataTrigger>
        </Style.Triggers>
    </Style>

    <Style
        x:Key="PortfolioDefaultBadge"
        BasedOn="{StaticResource PortfolioBadgeBase}"
        TargetType="Border">
        <Setter Property="Background" Value="{DynamicResource AppAccent}" />
    </Style>

    <!--
        資金帳戶細分類 chip（銀行活存 / 數位活存 / 證券交割戶 / etc）。
        v0.28+ 修正：原本用 AppSurfaceAlt 背景與頁面 SoftWhite 幾乎一樣
        導致 chip 透明看不見。改用 accent-subtle 帶色背景 + accent 邊框，
        在 light/dark theme 兩邊都明顯可辨識，仍保持「metadata 不是 status」
        的視覺層級（與 PortfolioDefaultBadge 的滿色 accent 區別）。
    -->
    <Style
        x:Key="PortfolioSubtypeChip"
        BasedOn="{StaticResource PortfolioBadgeBase}"
        TargetType="Border">
        <Setter Property="Background" Value="{DynamicResource AppAccentSubtle}" />
        <Setter Property="BorderBrush" Value="{DynamicResource AppAccent}" />
        <Setter Property="BorderThickness" Value="1" />
        <Setter Property="MinWidth" Value="0" />
        <Setter Property="Padding" Value="8,0" />
        <Setter Property="Height" Value="20" />
    </Style>

    <Style x:Key="PortfolioSubtypeChipText" TargetType="TextBlock">
        <Setter Property="HorizontalAlignment" Value="Center" />
        <Setter Property="VerticalAlignment" Value="Center" />
        <Setter Property="FontSize" Value="{DynamicResource Font.Size.Xs}" />
        <Setter Property="FontWeight" Value="SemiBold" />
        <Setter Property="Foreground" Value="{DynamicResource AppAccent}" />
    </Style>

    <Style
        x:Key="PortfolioLiabilityBadge"
        BasedOn="{StaticResource PortfolioBadgeBase}"
        TargetType="Border">
        <Setter Property="Background" Value="#374151" />
        <Setter Property="MinWidth" Value="42" />
        <Style.Triggers>
            <DataTrigger Binding="{Binding IsCreditCard}" Value="True">
                <Setter Property="Background" Value="#8A6A1F" />
            </DataTrigger>
        </Style.Triggers>
    </Style>

</ResourceDictionary>
