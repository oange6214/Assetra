<UserControl
    x:Class="Assetra.WPF.Features.Portfolio.PortfolioView"
    xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
    xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
    xmlns:beh="clr-namespace:Assetra.WPF.Infrastructure.Behaviors"
    xmlns:conv="clr-namespace:Assetra.WPF.Infrastructure.Converters"
    xmlns:d="http://schemas.microsoft.com/expression/blend/2008"
    xmlns:mc="http://schemas.openxmlformats.org/markup-compatibility/2006"
    xmlns:models="clr-namespace:Assetra.Core.Models;assembly=Assetra.Core"
    xmlns:pcontrols="clr-namespace:Assetra.WPF.Features.Portfolio.Controls"
    xmlns:ds="clr-namespace:Assetra.WPF.DesignSystem.Controls"
    xmlns:vm="clr-namespace:Assetra.WPF.Features.Portfolio"
    x:Name="Root"
    d:DataContext="{d:DesignInstance Type={x:Type vm:PortfolioViewModel}}"
    d:DesignHeight="776"
    d:DesignWidth="1100"
    Background="{DynamicResource AppBackground}"
    mc:Ignorable="d">
    <UserControl.Resources>
        <conv:PercentToWidthConverter x:Key="PercentToWidthConverter" />
    </UserControl.Resources>

    <Grid>
        <Grid.RowDefinitions>
            <RowDefinition Height="Auto" />
            <!--  Row 0: Setup notice  -->
            <RowDefinition Height="*" />
            <!--  Row 1: TabControl (header + content)  -->
        </Grid.RowDefinitions>

        <pcontrols:PortfolioSetupNoticePanel Grid.Row="0" />

        <!--  ── Row 1: TabControl with floating Add Record button ──  -->
        <Grid Grid.Row="1">
            <TabControl
                HorizontalAlignment="Stretch"
                VerticalAlignment="Stretch"
                HorizontalContentAlignment="Stretch"
                VerticalContentAlignment="Stretch"
                Background="Transparent"
                BorderThickness="0"
                SelectedValue="{Binding SelectedTab, Mode=TwoWay}"
                SelectedValuePath="Tag">
                <TabItem Header="{DynamicResource Portfolio.Tab.Overview}" Tag="{x:Static vm:PortfolioTab.Dashboard}">
                    <pcontrols:DashboardTabPanel DataContext="{Binding Dashboard}" />
                </TabItem>

                <TabItem Header="{DynamicResource Portfolio.Tab.Allocation}" Tag="{x:Static vm:PortfolioTab.AllocationAnalysis}">
                    <pcontrols:AllocationView DataContext="{Binding AllocationAnalysis}" />
                </TabItem>

                <TabItem Header="{DynamicResource Portfolio.Tab.Positions}" Tag="{x:Static vm:PortfolioTab.Positions}">
                    <pcontrols:PositionsTabPanel />
                </TabItem>

                <TabItem Header="{DynamicResource Portfolio.Tab.Cash}" Tag="{x:Static vm:PortfolioTab.Accounts}">
                    <pcontrols:AccountsTabPanel />
                </TabItem>

                <TabItem Header="{DynamicResource Portfolio.Tab.Liability}" Tag="{x:Static vm:PortfolioTab.Liability}">
                    <pcontrols:LiabilityTabPanel />
                </TabItem>

                <TabItem Header="{DynamicResource Portfolio.Tab.Trades}" Tag="{x:Static vm:PortfolioTab.Trades}">
                    <pcontrols:TradesTabPanel />
                </TabItem>
            </TabControl>

            <!--
                Floating "新增紀錄" button removed — promoted to MainWindow
                title bar so the high-frequency action stays reachable from
                every page (Portfolio / Cash / Liabilities / TransactionLog /
                FinancialOverview / …) instead of only when the user is on
                this page. Ctrl+N is the global keyboard twin.
            -->
        </Grid>


        <!--
            Cash detail overlay moved to MainWindow shell so it renders
            regardless of which top-level page is active (Portfolio,
            CashAccounts, ...). See MainWindow.xaml.
        -->


        <!--
            Liability detail overlay moved to MainWindow shell. See
            MainWindow.xaml > "Shell-level Liability detail overlay".
        -->


        <!--  ── Position detail overlay (investment) ──  -->
        <Grid
            Grid.RowSpan="2"
            Panel.ZIndex="180"
            Visibility="{Binding HasSelectedPositionRow, Converter={StaticResource BooleanToVisibilityConverter}}">
            <Border beh:BackdropClickToCloseBehavior.Command="{Binding ClosePositionDetailCommand}" Style="{StaticResource AppDialogOverlayBorder}" />
            <Border
                HorizontalAlignment="Right"
                Background="{DynamicResource AppSurface}"
                BorderBrush="{DynamicResource AppBorder}"
                BorderThickness="1,0,0,0">
                <Border.Width>
                    <MultiBinding Converter="{StaticResource AdaptivePanelWidthConverter}" ConverterParameter="0.44|420|620">
                        <Binding ElementName="Root" Path="ActualWidth" />
                        <Binding Path="DataContext.Settings.UiScale" RelativeSource="{RelativeSource AncestorType=Window}" />
                    </MultiBinding>
                </Border.Width>
                <Grid>
                    <Grid.RowDefinitions>
                        <RowDefinition Height="Auto" />
                        <!--  Header (symbol + name + actions)  -->
                        <RowDefinition Height="Auto" />
                        <!--  Tab bar  -->
                        <RowDefinition Height="*" />
                        <!--  Tab content  -->
                        <RowDefinition Height="Auto" />
                        <!--  Danger zone  -->
                    </Grid.RowDefinitions>

                    <!--  ── Header ──  -->
                    <Border
                        Grid.Row="0"
                        Padding="16,14"
                        BorderBrush="{DynamicResource AppBorder}"
                        BorderThickness="0,0,0,1">
                        <StackPanel>
                            <DockPanel LastChildFill="True">
                                <!--  Close  -->
                                <Button
                                    Width="30"
                                    Height="36"
                                    Margin="6,0,0,0"
                                    Padding="0"
                                    VerticalAlignment="Center"
                                    Command="{Binding ClosePositionDetailCommand}"
                                    DockPanel.Dock="Right"
                                    Style="{StaticResource AppIconButton}"
                                    ToolTip="{DynamicResource Common.Close}">
                                    <ds:AppIcon
                                        FontSize="11"
                                        Foreground="{DynamicResource AppTextSecondary}"
                                        Symbol="Dismiss24" />
                                </Button>
                                <!--  Edit pencil → opens shared EditAssetDialog  -->
                                <Button
                                    Width="30"
                                    Height="36"
                                    Padding="0"
                                    VerticalAlignment="Center"
                                    Command="{Binding Account.OpenEditPositionCommand}"
                                    CommandParameter="{Binding SelectedPositionRow}"
                                    DockPanel.Dock="Right"
                                    Style="{StaticResource AppIconButton}"
                                    ToolTip="{DynamicResource Common.Edit}">
                                    <ds:AppIcon
                                        FontSize="12"
                                        Foreground="{DynamicResource AppTextPrimary}"
                                        Symbol="Edit24" />
                                </Button>
                                <!--  Symbol + Name (left-fill)  -->
                                <StackPanel Orientation="Horizontal">
                                    <TextBlock
                                        VerticalAlignment="Center"
                                        FontFamily="{StaticResource Font.Family.Base}"
                                        FontSize="{StaticResource Font.Size.Xl}"
                                        FontWeight="Bold"
                                        Foreground="{DynamicResource AppAccent}"
                                        Text="{Binding SelectedPositionRow.Symbol, FallbackValue=''}"
                                        Typography.NumeralAlignment="Tabular" />
                                    <TextBlock
                                        Margin="10,0,0,0"
                                        VerticalAlignment="Center"
                                        FontSize="{StaticResource Font.Size.Sm}"
                                        Foreground="{DynamicResource AppTextSecondary}"
                                        Text="{Binding SelectedPositionRow.Name, FallbackValue=''}"
                                        TextTrimming="CharacterEllipsis" />
                                </StackPanel>
                            </DockPanel>
                            <TextBlock
                                Margin="0,8,0,8"
                                FontSize="{StaticResource Font.Size.Xs}"
                                Foreground="{DynamicResource AppTextMuted}"
                                Text="{DynamicResource Portfolio.Detail.Subtitle}" />
                            <!--
                                Asset-type badges — 一律實色填充 + 白字，無 border，
                                統一高度 & 視覺語法（跟 DataGrid 資產欄的徽章風格一致）
                            -->
                            <StackPanel Orientation="Horizontal">
                                <!--  主要類型徽章（股 / 基 / 金 / 債 / 密）— 顏色依資產類型  -->
                                <Border Padding="8,2" CornerRadius="{StaticResource Radius.Sm}">
                                    <Border.Style>
                                        <Style TargetType="Border">
                                            <Setter Property="Background" Value="#0062AD" />
                                            <Style.Triggers>
                                                <DataTrigger Binding="{Binding SelectedPositionRow.AssetType, FallbackValue={x:Null}}" Value="{x:Static models:AssetType.Fund}">
                                                    <Setter Property="Background" Value="#0A7A55" />
                                                </DataTrigger>
                                                <DataTrigger Binding="{Binding SelectedPositionRow.AssetType, FallbackValue={x:Null}}" Value="{x:Static models:AssetType.PreciousMetal}">
                                                    <Setter Property="Background" Value="#966300" />
                                                </DataTrigger>
                                                <DataTrigger Binding="{Binding SelectedPositionRow.AssetType, FallbackValue={x:Null}}" Value="{x:Static models:AssetType.Bond}">
                                                    <Setter Property="Background" Value="{DynamicResource Brush.Neutral}" />
                                                </DataTrigger>
                                                <DataTrigger Binding="{Binding SelectedPositionRow.AssetType, FallbackValue={x:Null}}" Value="{x:Static models:AssetType.Crypto}">
                                                    <Setter Property="Background" Value="{DynamicResource Brush.Special}" />
                                                </DataTrigger>
                                            </Style.Triggers>
                                        </Style>
                                    </Border.Style>
                                    <TextBlock
                                        FontSize="{StaticResource Font.Size.Xs}"
                                        FontWeight="SemiBold"
                                        Foreground="{DynamicResource AppTextOnAccent}"
                                        Text="{Binding SelectedPositionRow.AssetTypeBadgeLabel, FallbackValue=''}" />
                                </Border>
                                <!--  ETF 副徽章 — 僅股票型 ETF 顯示（非債券 ETF）  -->
                                <Border
                                    Margin="6,0,0,0"
                                    Padding="8,2"
                                    Background="{DynamicResource Brush.Info}"
                                    CornerRadius="{StaticResource Radius.Sm}"
                                    ToolTip="證交稅 0.1%">
                                    <Border.Style>
                                        <Style TargetType="Border">
                                            <Setter Property="Visibility" Value="Collapsed" />
                                            <Style.Triggers>
                                                <MultiDataTrigger>
                                                    <MultiDataTrigger.Conditions>
                                                        <Condition Binding="{Binding SelectedPositionRow.IsEtf, FallbackValue=False}" Value="True" />
                                                        <Condition Binding="{Binding SelectedPositionRow.IsBondEtf, FallbackValue=False}" Value="False" />
                                                    </MultiDataTrigger.Conditions>
                                                    <Setter Property="Visibility" Value="Visible" />
                                                </MultiDataTrigger>
                                            </Style.Triggers>
                                        </Style>
                                    </Border.Style>
                                    <TextBlock
                                        FontSize="{StaticResource Font.Size.Xs}"
                                        FontWeight="SemiBold"
                                        Foreground="{DynamicResource AppTextOnAccent}"
                                        Text="ETF" />
                                </Border>
                                <!--  債券 ETF 副徽章 — 深灰提示免徵證交稅  -->
                                <Border
                                    Margin="6,0,0,0"
                                    Padding="8,2"
                                    Background="{DynamicResource Brush.Neutral}"
                                    CornerRadius="{StaticResource Radius.Sm}"
                                    ToolTip="{DynamicResource Portfolio.AssetType.BondEtf.Tooltip}"
                                    Visibility="{Binding SelectedPositionRow.IsBondEtf, Converter={StaticResource BooleanToVisibilityConverter}, FallbackValue=Collapsed}">
                                    <TextBlock
                                        FontSize="{StaticResource Font.Size.Xs}"
                                        FontWeight="SemiBold"
                                        Foreground="{DynamicResource AppTextOnAccent}"
                                        Text="{DynamicResource Portfolio.AssetType.BondEtf}" />
                                </Border>
                            </StackPanel>
                        </StackPanel>
                    </Border>

                    <!--  ── Tab bar ──  -->
                    <Border
                        Grid.Row="1"
                        BorderBrush="{DynamicResource AppBorder}"
                        BorderThickness="0,0,0,1">
                        <StackPanel Orientation="Horizontal">
                            <RadioButton
                                Command="{Binding SwitchDetailTabCommand}"
                                CommandParameter="overview"
                                Content="{DynamicResource Portfolio.Detail.Overview}"
                                GroupName="PositionDetailTab"
                                IsChecked="{Binding IsDetailOverviewTab, Mode=OneWay}"
                                Style="{StaticResource NavTabBtn}" />
                            <RadioButton
                                Command="{Binding SwitchDetailTabCommand}"
                                CommandParameter="trades"
                                Content="{DynamicResource Portfolio.Detail.Trades}"
                                GroupName="PositionDetailTab"
                                IsChecked="{Binding IsDetailTradesTab, Mode=OneWay}"
                                Style="{StaticResource NavTabBtn}" />
                        </StackPanel>
                    </Border>

                    <!--  ── Tab content ──  -->
                    <ScrollViewer Grid.Row="2" VerticalScrollBarVisibility="Auto">
                        <Grid>
                            <!--  Overview tab  -->
                            <StackPanel Margin="20,16,20,12" Visibility="{Binding IsDetailOverviewTab, Converter={StaticResource BooleanToVisibilityConverter}}">
                                <!--  View mode: 2x2 stats grid + realized P&L section  -->
                                <StackPanel>
                                    <!--  🆕 快速動作列：從 Detail 直接發起交易（現代 UX: reduce navigation friction）  -->
                                    <UniformGrid
                                        Margin="0,0,0,14"
                                        Columns="3"
                                        Visibility="{Binding SelectedPositionRow.IsStock, Converter={StaticResource BooleanToVisibilityConverter}}">
                                        <Button
                                            Height="32"
                                            Margin="0,0,4,0"
                                            Command="{Binding BeginBuyForSelectedPositionCommand}"
                                            Style="{StaticResource AppSecondaryButton}">
                                            <StackPanel Orientation="Horizontal">
                                                <ds:AppIcon
                                                    Margin="0,0,6,0"
                                                    VerticalAlignment="Center"
                                                    FontSize="10"
                                                    Foreground="{DynamicResource AppUp}"
                                                    Symbol="Add24" />
                                                <TextBlock
                                                    VerticalAlignment="Center"
                                                    FontSize="{StaticResource Font.Size.Xs}"
                                                    Text="{DynamicResource Portfolio.Detail.Action.Buy}" />
                                            </StackPanel>
                                        </Button>
                                        <Button
                                            Height="32"
                                            Margin="2,0,2,0"
                                            Command="{Binding BeginSellForSelectedPositionCommand}"
                                            Style="{StaticResource AppSecondaryButton}">
                                            <StackPanel Orientation="Horizontal">
                                                <ds:AppIcon
                                                    Margin="0,0,6,0"
                                                    VerticalAlignment="Center"
                                                    FontSize="10"
                                                    Foreground="{DynamicResource AppDown}"
                                                    Symbol="Cut24" />
                                                <TextBlock
                                                    VerticalAlignment="Center"
                                                    FontSize="{StaticResource Font.Size.Xs}"
                                                    Text="{DynamicResource Portfolio.Detail.Action.Sell}" />
                                            </StackPanel>
                                        </Button>
                                        <Button
                                            Height="32"
                                            Margin="4,0,0,0"
                                            Command="{Binding BeginDividendForSelectedPositionCommand}"
                                            Style="{StaticResource AppSecondaryButton}">
                                            <StackPanel Orientation="Horizontal">
                                                <ds:AppIcon
                                                    Margin="0,0,6,0"
                                                    VerticalAlignment="Center"
                                                    FontSize="10"
                                                    Foreground="{DynamicResource AppAccent}"
                                                    Symbol="People24" />
                                                <TextBlock
                                                    VerticalAlignment="Center"
                                                    FontSize="{StaticResource Font.Size.Xs}"
                                                    Text="{DynamicResource Portfolio.Detail.Action.Dividend}" />
                                            </StackPanel>
                                        </Button>
                                    </UniformGrid>

                                    <!--  Stats grid (2x2)  -->
                                    <Grid>
                                        <Grid.RowDefinitions>
                                            <RowDefinition Height="Auto" />
                                            <RowDefinition Height="10" />
                                            <RowDefinition Height="Auto" />
                                        </Grid.RowDefinitions>
                                        <Grid.ColumnDefinitions>
                                            <ColumnDefinition Width="*" />
                                            <ColumnDefinition Width="10" />
                                            <ColumnDefinition Width="*" />
                                        </Grid.ColumnDefinitions>

                                        <!--  Card: 現價 / 均價  -->
                                        <Border
                                            Grid.Row="0"
                                            Grid.Column="0"
                                            Padding="14,12"
                                            Background="{DynamicResource AppBackground}"
                                            BorderBrush="{DynamicResource AppBorder}"
                                            BorderThickness="1"
                                            CornerRadius="{StaticResource Radius.Sm}">
                                            <StackPanel>
                                                <TextBlock
                                                    FontSize="{StaticResource Font.Size.Xs}"
                                                    Foreground="{DynamicResource AppTextSecondary}"
                                                    Text="{DynamicResource Portfolio.Detail.PriceAvg}" />
                                                <StackPanel Margin="0,4,0,2" Orientation="Horizontal">
                                                    <TextBlock
                                                        FontFamily="{StaticResource Font.Family.Base}"
                                                        FontSize="{StaticResource Font.Size.Xl}"
                                                        FontWeight="SemiBold"
                                                        Foreground="{DynamicResource AppTextPrimary}"
                                                        Text="{Binding SelectedPositionRow.CurrentPrice, Converter={StaticResource CurrencyConverter}, ConverterParameter=price, FallbackValue=''}"
                                                        Typography.NumeralAlignment="Tabular" />
                                                    <TextBlock
                                                        Margin="6,0,0,0"
                                                        VerticalAlignment="Bottom"
                                                        FontFamily="{StaticResource Font.Family.Base}"
                                                        FontSize="{StaticResource Font.Size.Xs}"
                                                        Text="{Binding SelectedPositionRow.DayChangePercent, StringFormat={}{0:+0.00;-0.00;0.00}%, FallbackValue=''}"
                                                        Typography.NumeralAlignment="Tabular">
                                                        <TextBlock.Style>
                                                            <Style TargetType="TextBlock">
                                                                <Setter Property="Foreground" Value="{DynamicResource AppDown}" />
                                                                <Style.Triggers>
                                                                    <DataTrigger Binding="{Binding SelectedPositionRow.IsDayChangePositive}" Value="True">
                                                                        <Setter Property="Foreground" Value="{DynamicResource AppUp}" />
                                                                    </DataTrigger>
                                                                </Style.Triggers>
                                                            </Style>
                                                        </TextBlock.Style>
                                                    </TextBlock>
                                                </StackPanel>
                                                <!--  成交均價（交易記錄加總）— 對照側面板的交易記錄可直接手算  -->
                                                <TextBlock
                                                    FontFamily="{StaticResource Font.Family.Base}"
                                                    FontSize="{StaticResource Font.Size.Xs}"
                                                    Foreground="{DynamicResource AppTextMuted}"
                                                    Typography.NumeralAlignment="Tabular">
                                                    <Run Text="{DynamicResource Portfolio.Detail.TradeAvgPrice}" />
                                                    <Run Text=":" />
                                                    <Run Text="{Binding SelectedPositionTradeAvgPrice, Converter={StaticResource CurrencyConverter}, ConverterParameter=price, Mode=OneWay, FallbackValue=''}" />
                                                </TextBlock>
                                                <!--  成本均價（含買入手續費攤平）— 等於持倉 DataGrid 上的數字  -->
                                                <TextBlock
                                                    FontFamily="{StaticResource Font.Family.Base}"
                                                    FontSize="{StaticResource Font.Size.Xs}"
                                                    Foreground="{DynamicResource AppTextMuted}"
                                                    Typography.NumeralAlignment="Tabular">
                                                    <Run Text="{DynamicResource Portfolio.Detail.CostAvgPrice}" />
                                                    <Run Text=":" />
                                                    <Run Text="{Binding SelectedPositionRow.BuyPrice, Converter={StaticResource CurrencyConverter}, ConverterParameter=price, Mode=OneWay, FallbackValue=''}" />
                                                </TextBlock>
                                            </StackPanel>
                                        </Border>

                                        <!--  Card: 持有數量  -->
                                        <Border
                                            Grid.Row="0"
                                            Grid.Column="2"
                                            Padding="14,12"
                                            Background="{DynamicResource AppBackground}"
                                            BorderBrush="{DynamicResource AppBorder}"
                                            BorderThickness="1"
                                            CornerRadius="{StaticResource Radius.Sm}">
                                            <StackPanel>
                                                <TextBlock
                                                    FontSize="{StaticResource Font.Size.Xs}"
                                                    Foreground="{DynamicResource AppTextSecondary}"
                                                    Text="{DynamicResource Portfolio.Detail.Holdings}" />
                                                <TextBlock
                                                    Margin="0,4,0,0"
                                                    FontFamily="{StaticResource Font.Family.Base}"
                                                    FontSize="{StaticResource Font.Size.Xl}"
                                                    FontWeight="SemiBold"
                                                    Foreground="{DynamicResource AppTextPrimary}"
                                                    Text="{Binding SelectedPositionRow.QuantityDisplay, FallbackValue=''}"
                                                    Typography.NumeralAlignment="Tabular" />
                                            </StackPanel>
                                        </Border>

                                        <!--  Card: 市值 / 成本  -->
                                        <Border
                                            Grid.Row="2"
                                            Grid.Column="0"
                                            Padding="14,12"
                                            Background="{DynamicResource AppBackground}"
                                            BorderBrush="{DynamicResource AppBorder}"
                                            BorderThickness="1"
                                            CornerRadius="{StaticResource Radius.Sm}">
                                            <StackPanel>
                                                <TextBlock
                                                    FontSize="{StaticResource Font.Size.Xs}"
                                                    Foreground="{DynamicResource AppTextSecondary}"
                                                    Text="{DynamicResource Portfolio.Detail.MarketValueCost}" />
                                                <!--  淨值（與 DataGrid 一致；已扣預估賣出費與證交稅）  -->
                                                <TextBlock
                                                    Margin="0,4,0,2"
                                                    FontFamily="{StaticResource Font.Family.Base}"
                                                    FontSize="{StaticResource Font.Size.Xl}"
                                                    FontWeight="SemiBold"
                                                    Foreground="{DynamicResource AppTextPrimary}"
                                                    Text="{Binding SelectedPositionRow.NetValue, Converter={StaticResource CurrencyConverter}, ConverterParameter=amount, FallbackValue=''}"
                                                    Typography.NumeralAlignment="Tabular" />
                                                <!--  市值（毛）  -->
                                                <TextBlock
                                                    FontFamily="{StaticResource Font.Family.Base}"
                                                    FontSize="{StaticResource Font.Size.Xs}"
                                                    Foreground="{DynamicResource AppTextMuted}"
                                                    Typography.NumeralAlignment="Tabular">
                                                    <Run Text="{DynamicResource Portfolio.Detail.MarketValue}" />
                                                    <Run Text=":" />
                                                    <Run Text="{Binding SelectedPositionRow.MarketValue, Converter={StaticResource CurrencyConverter}, ConverterParameter=amount, Mode=OneWay, FallbackValue=''}" />
                                                </TextBlock>
                                                <!--  成本（實付含買入手續費）  -->
                                                <TextBlock
                                                    FontFamily="{StaticResource Font.Family.Base}"
                                                    FontSize="{StaticResource Font.Size.Xs}"
                                                    Foreground="{DynamicResource AppTextMuted}"
                                                    Typography.NumeralAlignment="Tabular">
                                                    <Run Text="{DynamicResource Portfolio.Detail.Cost}" />
                                                    <Run Text=":" />
                                                    <Run Text="{Binding SelectedPositionRow.Cost, Converter={StaticResource CurrencyConverter}, ConverterParameter=amount, Mode=OneWay, FallbackValue=''}" />
                                                </TextBlock>
                                            </StackPanel>
                                        </Border>

                                        <!--  Card: 總損益 + %  -->
                                        <Border
                                            Grid.Row="2"
                                            Grid.Column="2"
                                            Padding="14,12"
                                            Background="{DynamicResource AppBackground}"
                                            BorderBrush="{DynamicResource AppBorder}"
                                            BorderThickness="1"
                                            CornerRadius="{StaticResource Radius.Sm}">
                                            <StackPanel>
                                                <TextBlock
                                                    FontSize="{StaticResource Font.Size.Xs}"
                                                    Foreground="{DynamicResource AppTextSecondary}"
                                                    Text="{DynamicResource Common.TotalPnL}" />
                                                <TextBlock
                                                    Margin="0,4,0,2"
                                                    FontFamily="{StaticResource Font.Family.Base}"
                                                    FontSize="{StaticResource Font.Size.Xl}"
                                                    FontWeight="SemiBold"
                                                    Text="{Binding SelectedPositionRow.Pnl, Converter={StaticResource CurrencyConverter}, ConverterParameter=signed, FallbackValue=''}"
                                                    Typography.NumeralAlignment="Tabular">
                                                    <TextBlock.Style>
                                                        <Style TargetType="TextBlock">
                                                            <Setter Property="Foreground" Value="{DynamicResource AppDown}" />
                                                            <Style.Triggers>
                                                                <DataTrigger Binding="{Binding SelectedPositionRow.IsPnlPositive}" Value="True">
                                                                    <Setter Property="Foreground" Value="{DynamicResource AppUp}" />
                                                                </DataTrigger>
                                                            </Style.Triggers>
                                                        </Style>
                                                    </TextBlock.Style>
                                                </TextBlock>
                                                <TextBlock
                                                    FontFamily="{StaticResource Font.Family.Base}"
                                                    FontSize="{StaticResource Font.Size.Xs}"
                                                    Text="{Binding SelectedPositionRow.PnlPercent, StringFormat={}{0:+0.00;-0.00;0.00}%, FallbackValue=''}"
                                                    Typography.NumeralAlignment="Tabular">
                                                    <TextBlock.Style>
                                                        <Style TargetType="TextBlock">
                                                            <Setter Property="Foreground" Value="{DynamicResource AppDown}" />
                                                            <Style.Triggers>
                                                                <DataTrigger Binding="{Binding SelectedPositionRow.IsPnlPositive}" Value="True">
                                                                    <Setter Property="Foreground" Value="{DynamicResource AppUp}" />
                                                                </DataTrigger>
                                                            </Style.Triggers>
                                                        </Style>
                                                    </TextBlock.Style>
                                                </TextBlock>
                                            </StackPanel>
                                        </Border>
                                    </Grid>

                                    <!--  Realized P&L section — 只在有資料時顯示，避免 3 行 NT$0 雜訊  -->
                                    <Border
                                        Margin="0,16,0,0"
                                        Background="{DynamicResource AppBackground}"
                                        BorderBrush="{DynamicResource AppBorder}"
                                        BorderThickness="1"
                                        CornerRadius="{StaticResource Radius.Sm}"
                                        Visibility="{Binding HasSelectedPositionRealized, Converter={StaticResource BooleanToVisibilityConverter}, FallbackValue=Collapsed}">
                                        <StackPanel>
                                            <Border
                                                Padding="14,10"
                                                BorderBrush="{DynamicResource AppBorder}"
                                                BorderThickness="0,0,0,1">
                                                <TextBlock
                                                    FontSize="{StaticResource Font.Size.Sm}"
                                                    FontWeight="SemiBold"
                                                    Foreground="{DynamicResource AppTextPrimary}"
                                                    Text="{DynamicResource Portfolio.Detail.RealizedPnL}" />
                                            </Border>
                                            <Grid Margin="14,8">
                                                <Grid.ColumnDefinitions>
                                                    <ColumnDefinition Width="*" />
                                                    <ColumnDefinition Width="Auto" />
                                                </Grid.ColumnDefinitions>
                                                <TextBlock
                                                    Grid.Column="0"
                                                    VerticalAlignment="Center"
                                                    FontSize="{StaticResource Font.Size.Sm}"
                                                    FontWeight="SemiBold"
                                                    Foreground="{DynamicResource AppTextPrimary}"
                                                    Text="{DynamicResource Portfolio.Detail.TotalRealized}" />
                                                <TextBlock
                                                    Grid.Column="1"
                                                    VerticalAlignment="Center"
                                                    FontFamily="{StaticResource Font.Family.Base}"
                                                    FontSize="{StaticResource Font.Size.Sm}"
                                                    FontWeight="SemiBold"
                                                    Foreground="{DynamicResource AppUp}"
                                                    Text="{Binding SelectedPositionRealizedTotal, Converter={StaticResource CurrencyConverter}, ConverterParameter=amount}"
                                                    Typography.NumeralAlignment="Tabular" />
                                            </Grid>
                                            <Grid Margin="14,6">
                                                <Grid.ColumnDefinitions>
                                                    <ColumnDefinition Width="*" />
                                                    <ColumnDefinition Width="Auto" />
                                                </Grid.ColumnDefinitions>
                                                <TextBlock
                                                    Grid.Column="0"
                                                    VerticalAlignment="Center"
                                                    FontSize="{StaticResource Font.Size.Xs}"
                                                    Foreground="{DynamicResource AppTextSecondary}"
                                                    Text="{DynamicResource Portfolio.Detail.CapitalGain}" />
                                                <TextBlock
                                                    Grid.Column="1"
                                                    VerticalAlignment="Center"
                                                    FontFamily="{StaticResource Font.Family.Base}"
                                                    FontSize="{StaticResource Font.Size.Xs}"
                                                    Foreground="{DynamicResource AppTextMuted}"
                                                    Text="{Binding SelectedPositionCapitalGain, Converter={StaticResource CurrencyConverter}, ConverterParameter=amount}"
                                                    Typography.NumeralAlignment="Tabular" />
                                            </Grid>
                                            <Grid Margin="14,6,14,12">
                                                <Grid.ColumnDefinitions>
                                                    <ColumnDefinition Width="*" />
                                                    <ColumnDefinition Width="Auto" />
                                                </Grid.ColumnDefinitions>
                                                <TextBlock
                                                    Grid.Column="0"
                                                    VerticalAlignment="Center"
                                                    FontSize="{StaticResource Font.Size.Xs}"
                                                    Foreground="{DynamicResource AppTextSecondary}"
                                                    Text="{DynamicResource Portfolio.Detail.DividendIncome}" />
                                                <TextBlock
                                                    Grid.Column="1"
                                                    VerticalAlignment="Center"
                                                    FontFamily="{StaticResource Font.Family.Base}"
                                                    FontSize="{StaticResource Font.Size.Xs}"
                                                    Foreground="{DynamicResource AppUp}"
                                                    Text="{Binding SelectedPositionDividendIncome, Converter={StaticResource CurrencyConverter}, ConverterParameter=amount}"
                                                    Typography.NumeralAlignment="Tabular" />
                                            </Grid>
                                        </StackPanel>
                                    </Border>
                                </StackPanel>

                            </StackPanel>

                            <!--  Trades tab  -->
                            <Grid Margin="20,12" Visibility="{Binding IsDetailTradesTab, Converter={StaticResource BooleanToVisibilityConverter}}">
                                <TextBlock
                                    Margin="0,24,0,0"
                                    HorizontalAlignment="Center"
                                    VerticalAlignment="Top"
                                    FontSize="{StaticResource Font.Size.Sm}"
                                    Foreground="{DynamicResource AppTextMuted}"
                                    Text="{DynamicResource Portfolio.Detail.NoTrades}">
                                    <TextBlock.Style>
                                        <Style TargetType="TextBlock">
                                            <Setter Property="Visibility" Value="Collapsed" />
                                            <Style.Triggers>
                                                <DataTrigger Binding="{Binding SelectedPositionTrades.Count, FallbackValue=0}" Value="0">
                                                    <Setter Property="Visibility" Value="Visible" />
                                                </DataTrigger>
                                            </Style.Triggers>
                                        </Style>
                                    </TextBlock.Style>
                                </TextBlock>
                                <ItemsControl ItemsSource="{Binding SelectedPositionTrades}">
                                    <ItemsControl.ItemTemplate>
                                        <DataTemplate>
                                            <Border Margin="0,0,0,10" Padding="12" Style="{StaticResource FormCard}">
                                                <StackPanel>
                                                    <Grid>
                                                        <Grid.ColumnDefinitions>
                                                            <ColumnDefinition Width="Auto" />
                                                            <ColumnDefinition Width="*" />
                                                            <ColumnDefinition Width="Auto" />
                                                        </Grid.ColumnDefinitions>
                                                        <TextBlock
                                                            Grid.Column="0"
                                                            VerticalAlignment="Center"
                                                            FontFamily="{StaticResource Font.Family.Base}"
                                                            FontSize="{StaticResource Font.Size.Xs}"
                                                            Foreground="{DynamicResource AppTextSecondary}"
                                                            Text="{Binding TradeDateLocal, StringFormat=yyyy/MM/dd}"
                                                            Typography.NumeralAlignment="Tabular" />
                                                        <Border
                                                            Grid.Column="1"
                                                            Margin="10,0,0,0"
                                                            Padding="6,2"
                                                            HorizontalAlignment="Left"
                                                            VerticalAlignment="Center"
                                                            Background="{Binding TypeBadgeColor, Converter={StaticResource HexToBrushConverter}}"
                                                            CornerRadius="{StaticResource Radius.Sm}">
                                                            <TextBlock
                                                                FontSize="{StaticResource Font.Size.Xs}"
                                                                FontWeight="SemiBold"
                                                                Foreground="{DynamicResource AppTextOnAccent}"
                                                                Text="{Binding Type, Converter={StaticResource TradeTypeConverter}}" />
                                                        </Border>
                                                        <Button
                                                            Grid.Column="2"
                                                            Width="32"
                                                            Height="32"
                                                            Padding="0"
                                                            HorizontalAlignment="Right"
                                                            VerticalAlignment="Center"
                                                            Command="{Binding DataContext.Transaction.EditTradeCommand, RelativeSource={RelativeSource AncestorType=ItemsControl}}"
                                                            CommandParameter="{Binding}"
                                                            Style="{StaticResource AppIconButton}"
                                                            ToolTip="{DynamicResource Common.Edit}">
                                                            <ds:AppIcon
                                                                FontSize="11"
                                                                Foreground="{DynamicResource AppTextMuted}"
                                                                Symbol="Edit24" />
                                                        </Button>
                                                    </Grid>

                                                    <WrapPanel Margin="0,8,0,0">
                                                        <StackPanel MinWidth="116" Margin="0,0,20,4">
                                                            <TextBlock
                                                                FontSize="{StaticResource Font.Size.Xs}"
                                                                Foreground="{DynamicResource AppTextSecondary}"
                                                                Text="{DynamicResource Portfolio.Shares}" />
                                                            <TextBlock
                                                                Margin="0,2,0,0"
                                                                FontFamily="{StaticResource Font.Family.Base}"
                                                                FontSize="{StaticResource Font.Size.Sm}"
                                                                FontWeight="SemiBold"
                                                                Text="{Binding DisplayQuantityText}"
                                                                Typography.NumeralAlignment="Tabular" />
                                                        </StackPanel>
                                                        <StackPanel MinWidth="116" Margin="0,0,20,4">
                                                            <TextBlock
                                                                FontSize="{StaticResource Font.Size.Xs}"
                                                                Foreground="{DynamicResource AppTextSecondary}"
                                                                Text="{DynamicResource Portfolio.TradeHistory.UnitPrice}" />
                                                            <TextBlock
                                                                Margin="0,2,0,0"
                                                                FontFamily="{StaticResource Font.Family.Base}"
                                                                FontSize="{StaticResource Font.Size.Sm}"
                                                                FontWeight="SemiBold"
                                                                Text="{Binding Price, Converter={StaticResource CurrencyConverter}, ConverterParameter=price-dash}"
                                                                Typography.NumeralAlignment="Tabular" />
                                                        </StackPanel>
                                                        <StackPanel MinWidth="140" Margin="0,0,20,4">
                                                            <TextBlock
                                                                FontSize="{StaticResource Font.Size.Xs}"
                                                                Foreground="{DynamicResource AppTextSecondary}"
                                                                Text="{DynamicResource Portfolio.TradeHistory.GrossAmount}" />
                                                            <TextBlock
                                                                Margin="0,2,0,0"
                                                                FontFamily="{StaticResource Font.Family.Base}"
                                                                FontSize="{StaticResource Font.Size.Sm}"
                                                                FontWeight="SemiBold"
                                                                Text="{Binding TotalAmount, Converter={StaticResource CurrencyConverter}, ConverterParameter=signed-dash}"
                                                                Typography.NumeralAlignment="Tabular">
                                                                <TextBlock.Style>
                                                                    <Style BasedOn="{StaticResource {x:Type TextBlock}}" TargetType="TextBlock">
                                                                        <Setter Property="Foreground" Value="{DynamicResource AppDown}" />
                                                                        <Style.Triggers>
                                                                            <DataTrigger Binding="{Binding IsAmountPositive}" Value="True">
                                                                                <Setter Property="Foreground" Value="{DynamicResource AppUp}" />
                                                                            </DataTrigger>
                                                                            <DataTrigger Binding="{Binding TotalAmount}" Value="0">
                                                                                <Setter Property="Foreground" Value="{DynamicResource AppTextSecondary}" />
                                                                            </DataTrigger>
                                                                        </Style.Triggers>
                                                                    </Style>
                                                                </TextBlock.Style>
                                                            </TextBlock>
                                                        </StackPanel>
                                                    </WrapPanel>

                                                    <TextBlock
                                                        Margin="0,2,0,0"
                                                        FontSize="{StaticResource Font.Size.Xs}"
                                                        Foreground="{DynamicResource AppTextMuted}"
                                                        Text="{Binding Note}"
                                                        TextWrapping="Wrap"
                                                        Visibility="{Binding Note, Converter={StaticResource StringToVisibilityConverter}}" />
                                                </StackPanel>
                                            </Border>
                                        </DataTemplate>
                                    </ItemsControl.ItemTemplate>
                                </ItemsControl>
                            </Grid>
                        </Grid>
                    </ScrollViewer>

                    <!--  ── Danger zone ──  -->
                    <Border
                        Grid.Row="3"
                        Margin="20,0,20,16"
                        Padding="14,12"
                        Background="{DynamicResource AppBackground}"
                        BorderBrush="{DynamicResource AppDanger}"
                        BorderThickness="1"
                        CornerRadius="{StaticResource Radius.Sm}">
                        <Grid>
                            <Grid.ColumnDefinitions>
                                <ColumnDefinition Width="*" />
                                <ColumnDefinition Width="Auto" />
                            </Grid.ColumnDefinitions>
                            <StackPanel Grid.Column="0" VerticalAlignment="Center">
                                <StackPanel Margin="0,0,0,2" Orientation="Horizontal">
                                    <ds:AppIcon
                                        Margin="0,0,6,0"
                                        VerticalAlignment="Center"
                                        FontSize="11"
                                        Foreground="{DynamicResource AppDanger}"
                                        Symbol="Delete24" />
                                    <TextBlock
                                        FontSize="{StaticResource Font.Size.Xs}"
                                        FontWeight="SemiBold"
                                        Foreground="{DynamicResource AppDanger}"
                                        Text="{DynamicResource Portfolio.Detail.DeleteAsset}" />
                                </StackPanel>
                                <TextBlock
                                    FontSize="{StaticResource Font.Size.Xs}"
                                    Foreground="{DynamicResource AppTextSecondary}"
                                    Text="{DynamicResource Portfolio.Detail.DeleteWarning}"
                                    TextWrapping="Wrap" />
                            </StackPanel>
                            <Button
                                Grid.Column="1"
                                Height="32"
                                Margin="12,0,0,0"
                                Padding="14,0"
                                VerticalAlignment="Center"
                                Command="{Binding RemovePositionCommand}"
                                CommandParameter="{Binding SelectedPositionRow}"
                                Style="{StaticResource AppDangerButton}">
                                <TextBlock
                                    FontSize="{StaticResource Font.Size.Xs}"
                                    Foreground="{Binding Foreground, RelativeSource={RelativeSource AncestorType=Button}}"
                                    Text="{DynamicResource Portfolio.Detail.DeleteAsset}" />
                            </Button>
                        </Grid>
                    </Border>
                </Grid>
            </Border>
        </Grid>

        <!--  ── Dialog overlays ──  -->
        <!--  AddRecordDialog moved to MainWindow shell so it renders on every page.  -->
        <pcontrols:AddAssetDialog Grid.RowSpan="2" Panel.ZIndex="200" />
        <pcontrols:EditAssetDialog
            Grid.RowSpan="2"
            Panel.ZIndex="205"
            DataContext="{Binding Account}" />
        <!--  ── Confirm dialog ──  -->
        <Grid
            Grid.RowSpan="2"
            Panel.ZIndex="220"
            Style="{StaticResource AppDialogOverlay}"
            Visibility="{Binding IsConfirmDialogOpen, Converter={StaticResource BooleanToVisibilityConverter}}">
            <Border
                Style="{StaticResource AppDestructiveDialogShell}"
                HorizontalAlignment="Center"
                VerticalAlignment="Center"
                beh:EscapeKeyCommandBehavior.Command="{Binding ConfirmDialogNoCommand}">
                <StackPanel Margin="24,20">
                    <TextBlock
                        Margin="0,0,0,4"
                        Style="{StaticResource AppDialogTitle}"
                        Text="{DynamicResource Portfolio.Confirm.Title}" />
                    <TextBlock
                        Margin="0,0,0,20"
                        Style="{StaticResource AppDialogSubtitle}"
                        Text="{Binding ConfirmDialogMessage}"
                        TextWrapping="Wrap" />
                    <StackPanel HorizontalAlignment="Right" Orientation="Horizontal">
                        <Button
                            Height="36"
                            Margin="0,0,8,0"
                            Padding="14,0"
                            Command="{Binding ConfirmDialogNoCommand}"
                            Style="{StaticResource AppSecondaryButton}">
                            <TextBlock Text="{DynamicResource Common.Cancel}" />
                        </Button>
                        <Button
                            Height="36"
                            Padding="14,0"
                            Command="{Binding ConfirmDialogYesCommand}"
                            Style="{StaticResource AppDangerButton}">
                            <TextBlock Foreground="{Binding Foreground, RelativeSource={RelativeSource AncestorType=Button}}" Text="{DynamicResource Portfolio.Confirm.Delete}" />
                        </Button>
                    </StackPanel>
                </StackPanel>
            </Border>
        </Grid>
    </Grid>
</UserControl>
