<UserControl
    x:Class="Assetra.WPF.Features.Portfolio.PortfolioView"
    xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
    xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
    xmlns:beh="clr-namespace:Assetra.WPF.Infrastructure.Behaviors"
    xmlns:conv="clr-namespace:Assetra.WPF.Infrastructure.Converters"
    xmlns:d="http://schemas.microsoft.com/expression/blend/2008"
    xmlns:ds="clr-namespace:Assetra.WPF.DesignSystem.Controls"
    xmlns:mc="http://schemas.openxmlformats.org/markup-compatibility/2006"
    xmlns:models="clr-namespace:Assetra.Core.Models;assembly=Assetra.Core"
    xmlns:pcontrols="clr-namespace:Assetra.WPF.Features.Portfolio.Controls"
    xmlns:vm="clr-namespace:Assetra.WPF.Features.Portfolio"
    x:Name="Root"
    d:DataContext="{d:DesignInstance Type={x:Type vm:PortfolioViewModel}}"
    d:DesignHeight="776"
    d:DesignWidth="1100"
    Background="{DynamicResource AppBackground}"
    mc:Ignorable="d">
    <UserControl.Resources>
        <conv:PercentToWidthConverter x:Key="PercentToWidthConverter" />
    </UserControl.Resources>

    <Grid>
        <Grid.RowDefinitions>
            <RowDefinition Height="Auto" />
            <!--  Row 0: Setup notice  -->
            <RowDefinition Height="*" />
            <!--  Row 1: TabControl (header + content)  -->
        </Grid.RowDefinitions>

        <pcontrols:PortfolioSetupNoticePanel Grid.Row="0" />

        <!--
            ── Row 1: Positions panel（直接渲染，不再包 TabControl）──

            Long-term refactor 後 Portfolio 頁只剩單一工作面 = 持倉明細：
            - Dashboard tab 搬到「投資焦點卡」（全域財務儀表板總覽）
            - Allocation tab 搬到「配置」tab（全域財務儀表板）
            - Cash / Liability / Trades 早期已搬到各自的 navrail leaf
            單一 TabControl + 單一 TabItem 是 anti-pattern，直接展開 PositionsTabPanel
            節省 ~32px tab bar 並消除「為什麼只有一個 tab」的疑惑。

            保留的事：
            - PortfolioTab enum / SelectedTab observable property 仍存在，
              避免破壞舊持久化與 OpenAddAccountFromTab 等內部呼叫。
            - DashboardViewModel / AllocationViewModel 子 VM 仍存活於 PortfolioVM，
              供全域儀表板「投資焦點卡」與「配置 tab」綁定使用。
            - 未來如要加投資專屬的次要 view（例：配息日曆／績效歸因），
              再回頭包 TabControl 即可。
        -->
        <pcontrols:PositionsTabPanel Grid.Row="1" />


        <!--
            Cash detail overlay moved to MainWindow shell so it renders
            regardless of which top-level page is active (Portfolio,
            CashAccounts, ...). See MainWindow.xaml.
        -->


        <!--
            Liability detail overlay moved to MainWindow shell. See
            MainWindow.xaml > "Shell-level Liability detail overlay".
        -->


        <!--  ── Position detail overlay (investment) ──  -->
        <Grid
            Grid.RowSpan="2"
            Panel.ZIndex="180"
            Visibility="{Binding HasSelectedPositionRow, Converter={StaticResource BooleanToVisibilityConverter}}">
            <Border beh:BackdropClickToCloseBehavior.Command="{Binding ClosePositionDetailCommand}" Style="{StaticResource AppDialogOverlayBorder}" />
            <Border
                HorizontalAlignment="Right"
                Background="{DynamicResource AppSurface}"
                BorderBrush="{DynamicResource AppBorder}"
                BorderThickness="1,0,0,0">
                <Border.Width>
                    <MultiBinding Converter="{StaticResource AdaptivePanelWidthConverter}" ConverterParameter="0.44|420|620">
                        <Binding ElementName="Root" Path="ActualWidth" />
                        <Binding Path="DataContext.Settings.UiScale" RelativeSource="{RelativeSource AncestorType=Window}" />
                    </MultiBinding>
                </Border.Width>
                <Grid>
                    <Grid.RowDefinitions>
                        <RowDefinition Height="Auto" />
                        <!--  Header (symbol + name + actions)  -->
                        <RowDefinition Height="Auto" />
                        <!--  Tab bar  -->
                        <RowDefinition Height="*" />
                        <!--  Tab content  -->
                        <RowDefinition Height="Auto" />
                        <!--  Danger zone  -->
                    </Grid.RowDefinitions>

                    <!--  ── Header ──  -->
                    <Border
                        Grid.Row="0"
                        Padding="16,14"
                        BorderBrush="{DynamicResource AppBorder}"
                        BorderThickness="0,0,0,1">
                        <StackPanel>
                            <DockPanel LastChildFill="True">
                                <!--  Close  -->
                                <Button
                                    Width="30"
                                    Height="36"
                                    Margin="6,0,0,0"
                                    Padding="0"
                                    VerticalAlignment="Center"
                                    Command="{Binding ClosePositionDetailCommand}"
                                    DockPanel.Dock="Right"
                                    Style="{StaticResource AppIconButton}"
                                    ToolTip="{DynamicResource Common.Close}">
                                    <ds:AppIcon
                                        FontSize="11"
                                        Foreground="{DynamicResource AppTextSecondary}"
                                        Symbol="Dismiss24" />
                                </Button>
                                <!--  Edit pencil → opens shared EditAssetDialog  -->
                                <Button
                                    Width="30"
                                    Height="36"
                                    Padding="0"
                                    VerticalAlignment="Center"
                                    Command="{Binding Account.OpenEditPositionCommand}"
                                    CommandParameter="{Binding SelectedPositionRow}"
                                    DockPanel.Dock="Right"
                                    Style="{StaticResource AppIconButton}"
                                    ToolTip="{DynamicResource Common.Edit}">
                                    <ds:AppIcon
                                        FontSize="12"
                                        Foreground="{DynamicResource AppTextPrimary}"
                                        Symbol="Edit24" />
                                </Button>
                                <!--  Symbol + Name (left-fill)  -->
                                <StackPanel Orientation="Horizontal">
                                    <TextBlock
                                        VerticalAlignment="Center"
                                        FontFamily="{StaticResource Font.Family.Base}"
                                        FontSize="{StaticResource Font.Size.Xl}"
                                        FontWeight="Bold"
                                        Foreground="{DynamicResource AppAccent}"
                                        Text="{Binding SelectedPositionRow.Symbol, FallbackValue=''}"
                                        Typography.NumeralAlignment="Tabular" />
                                    <TextBlock
                                        Margin="10,0,0,0"
                                        VerticalAlignment="Center"
                                        FontSize="{StaticResource Font.Size.Sm}"
                                        Foreground="{DynamicResource AppTextSecondary}"
                                        Text="{Binding SelectedPositionRow.Name, FallbackValue=''}"
                                        TextTrimming="CharacterEllipsis" />
                                </StackPanel>
                            </DockPanel>
                            <TextBlock
                                Margin="0,8,0,8"
                                FontSize="{StaticResource Font.Size.Xs}"
                                Foreground="{DynamicResource AppTextMuted}"
                                Text="{DynamicResource Portfolio.Detail.Subtitle}" />
                            <!--
                                Asset-type badges — 一律實色填充 + 白字，無 border，
                                統一高度 & 視覺語法（跟 DataGrid 資產欄的徽章風格一致）
                            -->
                            <StackPanel Orientation="Horizontal">
                                <!--  主要類型徽章（股 / 基 / 金 / 債 / 密）— 顏色依資產類型  -->
                                <Border Padding="8,2" CornerRadius="{StaticResource Radius.Sm}">
                                    <Border.Style>
                                        <Style TargetType="Border">
                                            <Setter Property="Background" Value="#0062AD" />
                                            <Style.Triggers>
                                                <DataTrigger Binding="{Binding SelectedPositionRow.AssetType, FallbackValue={x:Null}}" Value="{x:Static models:AssetType.Fund}">
                                                    <Setter Property="Background" Value="#0A7A55" />
                                                </DataTrigger>
                                                <DataTrigger Binding="{Binding SelectedPositionRow.AssetType, FallbackValue={x:Null}}" Value="{x:Static models:AssetType.PreciousMetal}">
                                                    <Setter Property="Background" Value="#966300" />
                                                </DataTrigger>
                                                <DataTrigger Binding="{Binding SelectedPositionRow.AssetType, FallbackValue={x:Null}}" Value="{x:Static models:AssetType.Bond}">
                                                    <Setter Property="Background" Value="{DynamicResource Brush.Neutral}" />
                                                </DataTrigger>
                                                <DataTrigger Binding="{Binding SelectedPositionRow.AssetType, FallbackValue={x:Null}}" Value="{x:Static models:AssetType.Crypto}">
                                                    <Setter Property="Background" Value="{DynamicResource Brush.Special}" />
                                                </DataTrigger>
                                            </Style.Triggers>
                                        </Style>
                                    </Border.Style>
                                    <TextBlock
                                        FontSize="{StaticResource Font.Size.Xs}"
                                        FontWeight="SemiBold"
                                        Foreground="{DynamicResource AppTextOnAccent}"
                                        Text="{Binding SelectedPositionRow.AssetTypeBadgeLabel, FallbackValue=''}" />
                                </Border>
                                <!--  ETF 副徽章 — 僅股票型 ETF 顯示（非債券 ETF）  -->
                                <Border
                                    Margin="6,0,0,0"
                                    Padding="8,2"
                                    Background="{DynamicResource Brush.Info}"
                                    CornerRadius="{StaticResource Radius.Sm}"
                                    ToolTip="證交稅 0.1%">
                                    <Border.Style>
                                        <Style TargetType="Border">
                                            <Setter Property="Visibility" Value="Collapsed" />
                                            <Style.Triggers>
                                                <MultiDataTrigger>
                                                    <MultiDataTrigger.Conditions>
                                                        <Condition Binding="{Binding SelectedPositionRow.IsEtf, FallbackValue=False}" Value="True" />
                                                        <Condition Binding="{Binding SelectedPositionRow.IsBondEtf, FallbackValue=False}" Value="False" />
                                                    </MultiDataTrigger.Conditions>
                                                    <Setter Property="Visibility" Value="Visible" />
                                                </MultiDataTrigger>
                                            </Style.Triggers>
                                        </Style>
                                    </Border.Style>
                                    <TextBlock
                                        FontSize="{StaticResource Font.Size.Xs}"
                                        FontWeight="SemiBold"
                                        Foreground="{DynamicResource AppTextOnAccent}"
                                        Text="ETF" />
                                </Border>
                                <!--  債券 ETF 副徽章 — 深灰提示免徵證交稅  -->
                                <Border
                                    Margin="6,0,0,0"
                                    Padding="8,2"
                                    Background="{DynamicResource Brush.Neutral}"
                                    CornerRadius="{StaticResource Radius.Sm}"
                                    ToolTip="{DynamicResource Portfolio.AssetType.BondEtf.Tooltip}"
                                    Visibility="{Binding SelectedPositionRow.IsBondEtf, Converter={StaticResource BooleanToVisibilityConverter}, FallbackValue=Collapsed}">
                                    <TextBlock
                                        FontSize="{StaticResource Font.Size.Xs}"
                                        FontWeight="SemiBold"
                                        Foreground="{DynamicResource AppTextOnAccent}"
                                        Text="{DynamicResource Portfolio.AssetType.BondEtf}" />
                                </Border>
                            </StackPanel>
                        </StackPanel>
                    </Border>

                    <!--  ── Tab bar ──  -->
                    <Border
                        Grid.Row="1"
                        BorderBrush="{DynamicResource AppBorder}"
                        BorderThickness="0,0,0,1">
                        <StackPanel Orientation="Horizontal">
                            <RadioButton
                                Command="{Binding SwitchDetailTabCommand}"
                                CommandParameter="overview"
                                Content="{DynamicResource Portfolio.Detail.Overview}"
                                GroupName="PositionDetailTab"
                                IsChecked="{Binding IsDetailOverviewTab, Mode=OneWay}"
                                Style="{StaticResource NavTabBtn}" />
                            <RadioButton
                                Command="{Binding SwitchDetailTabCommand}"
                                CommandParameter="trades"
                                Content="{DynamicResource Portfolio.Detail.Trades}"
                                GroupName="PositionDetailTab"
                                IsChecked="{Binding IsDetailTradesTab, Mode=OneWay}"
                                Style="{StaticResource NavTabBtn}" />
                        </StackPanel>
                    </Border>

                    <!--  ── Tab content ──  -->
                    <ScrollViewer Grid.Row="2" VerticalScrollBarVisibility="Auto">
                        <Grid>
                            <!--  Overview tab  -->
                            <StackPanel Margin="20,16,20,12" Visibility="{Binding IsDetailOverviewTab, Converter={StaticResource BooleanToVisibilityConverter}}">
                                <!--  View mode: 2x2 stats grid + realized P&L section  -->
                                <StackPanel>
                                    <!--  🆕 快速動作列：從 Detail 直接發起交易（現代 UX: reduce navigation friction）  -->
                                    <UniformGrid
                                        Margin="0,0,0,14"
                                        Columns="3"
                                        Visibility="{Binding SelectedPositionRow.IsStock, Converter={StaticResource BooleanToVisibilityConverter}}">
                                        <Button
                                            Height="32"
                                            Margin="0,0,4,0"
                                            Command="{Binding BeginBuyForSelectedPositionCommand}"
                                            Style="{StaticResource AppSecondaryButton}">
                                            <StackPanel Orientation="Horizontal">
                                                <ds:AppIcon
                                                    Margin="0,0,6,0"
                                                    VerticalAlignment="Center"
                                                    FontSize="10"
                                                    Foreground="{DynamicResource AppUp}"
                                                    Symbol="Add24" />
                                                <TextBlock
                                                    VerticalAlignment="Center"
                                                    FontSize="{StaticResource Font.Size.Xs}"
                                                    Text="{DynamicResource Portfolio.Detail.Action.Buy}" />
                                            </StackPanel>
                                        </Button>
                                        <Button
                                            Height="32"
                                            Margin="2,0,2,0"
                                            Command="{Binding BeginSellForSelectedPositionCommand}"
                                            Style="{StaticResource AppSecondaryButton}">
                                            <StackPanel Orientation="Horizontal">
                                                <ds:AppIcon
                                                    Margin="0,0,6,0"
                                                    VerticalAlignment="Center"
                                                    FontSize="10"
                                                    Foreground="{DynamicResource AppDown}"
                                                    Symbol="Cut24" />
                                                <TextBlock
                                                    VerticalAlignment="Center"
                                                    FontSize="{StaticResource Font.Size.Xs}"
                                                    Text="{DynamicResource Portfolio.Detail.Action.Sell}" />
                                            </StackPanel>
                                        </Button>
                                        <Button
                                            Height="32"
                                            Margin="4,0,0,0"
                                            Command="{Binding BeginDividendForSelectedPositionCommand}"
                                            Style="{StaticResource AppSecondaryButton}">
                                            <StackPanel Orientation="Horizontal">
                                                <ds:AppIcon
                                                    Margin="0,0,6,0"
                                                    VerticalAlignment="Center"
                                                    FontSize="10"
                                                    Foreground="{DynamicResource AppAccent}"
                                                    Symbol="People24" />
                                                <TextBlock
                                                    VerticalAlignment="Center"
                                                    FontSize="{StaticResource Font.Size.Xs}"
                                                    Text="{DynamicResource Portfolio.Detail.Action.Dividend}" />
                                            </StackPanel>
                                        </Button>
                                    </UniformGrid>

                                    <!--  Stats grid: formula order  -->
                                    <Grid>
                                        <Grid.RowDefinitions>
                                            <RowDefinition Height="Auto" />
                                            <RowDefinition Height="10" />
                                            <RowDefinition Height="Auto" />
                                            <RowDefinition Height="10" />
                                            <RowDefinition Height="Auto" />
                                            <RowDefinition Height="10" />
                                            <RowDefinition Height="Auto" />
                                        </Grid.RowDefinitions>
                                        <Grid.ColumnDefinitions>
                                            <ColumnDefinition Width="*" />
                                            <ColumnDefinition Width="10" />
                                            <ColumnDefinition Width="*" />
                                        </Grid.ColumnDefinitions>

                                        <!--  Card: 持有數量  -->
                                        <Border
                                            Grid.Row="0"
                                            Grid.Column="0"
                                            Padding="14,12"
                                            Background="{DynamicResource AppBackground}"
                                            BorderBrush="{DynamicResource AppBorder}"
                                            BorderThickness="1"
                                            CornerRadius="{StaticResource Radius.Sm}">
                                            <StackPanel>
                                                <TextBlock
                                                    FontSize="{StaticResource Font.Size.Xs}"
                                                    Foreground="{DynamicResource AppTextSecondary}"
                                                    Text="{DynamicResource Portfolio.Detail.Holdings}" />
                                                <TextBlock
                                                    Margin="0,4,0,0"
                                                    FontFamily="{StaticResource Font.Family.Base}"
                                                    FontSize="{StaticResource Font.Size.Xl}"
                                                    FontWeight="SemiBold"
                                                    Foreground="{DynamicResource AppTextPrimary}"
                                                    Text="{Binding SelectedPositionRow.QuantityDisplay, FallbackValue=''}"
                                                    Typography.NumeralAlignment="Tabular" />
                                            </StackPanel>
                                        </Border>

                                        <!--  Card: 成本均價  -->
                                        <Border
                                            Grid.Row="0"
                                            Grid.Column="2"
                                            Padding="14,12"
                                            Background="{DynamicResource AppBackground}"
                                            BorderBrush="{DynamicResource AppBorder}"
                                            BorderThickness="1"
                                            CornerRadius="{StaticResource Radius.Sm}">
                                            <StackPanel>
                                                <TextBlock
                                                    FontSize="{StaticResource Font.Size.Xs}"
                                                    Foreground="{DynamicResource AppTextSecondary}"
                                                    Text="{DynamicResource Portfolio.Detail.CostAvgPrice}" />
                                                <TextBlock
                                                    Margin="0,4,0,2"
                                                    FontFamily="{StaticResource Font.Family.Base}"
                                                    FontSize="{StaticResource Font.Size.Xl}"
                                                    FontWeight="SemiBold"
                                                    Foreground="{DynamicResource AppTextPrimary}"
                                                    Text="{Binding SelectedPositionRow.BuyPriceAsMoney, Converter={StaticResource CurrencyConverter}, ConverterParameter=price, Mode=OneWay, FallbackValue=''}"
                                                    Typography.NumeralAlignment="Tabular" />
                                                <TextBlock
                                                    FontFamily="{StaticResource Font.Family.Base}"
                                                    FontSize="{StaticResource Font.Size.Xs}"
                                                    Foreground="{DynamicResource AppTextMuted}"
                                                    Typography.NumeralAlignment="Tabular">
                                                    <Run Text="{DynamicResource Portfolio.Detail.TradeAvgPrice}" />
                                                    <Run Text=":" />
                                                    <Run Text="{Binding SelectedPositionTradeAvgPriceAsMoney, Converter={StaticResource CurrencyConverter}, ConverterParameter=price, Mode=OneWay, FallbackValue=''}" />
                                                </TextBlock>
                                            </StackPanel>
                                        </Border>

                                        <!--  Card: 付出成本  -->
                                        <Border
                                            Grid.Row="2"
                                            Grid.Column="0"
                                            Padding="14,12"
                                            Background="{DynamicResource AppBackground}"
                                            BorderBrush="{DynamicResource AppBorder}"
                                            BorderThickness="1"
                                            CornerRadius="{StaticResource Radius.Sm}">
                                            <StackPanel>
                                                <TextBlock
                                                    FontSize="{StaticResource Font.Size.Xs}"
                                                    Foreground="{DynamicResource AppTextSecondary}"
                                                    Text="{DynamicResource Portfolio.TotalCostPaid}" />
                                                <TextBlock
                                                    Margin="0,4,0,2"
                                                    FontFamily="{StaticResource Font.Family.Base}"
                                                    FontSize="{StaticResource Font.Size.Xl}"
                                                    FontWeight="SemiBold"
                                                    Foreground="{DynamicResource AppTextPrimary}"
                                                    Text="{Binding SelectedPositionRow.CostAsMoney, Converter={StaticResource CurrencyConverter}, ConverterParameter=amount, Mode=OneWay, FallbackValue=''}"
                                                    Typography.NumeralAlignment="Tabular" />
                                                <TextBlock
                                                    FontFamily="{StaticResource Font.Family.Base}"
                                                    FontSize="{StaticResource Font.Size.Xs}"
                                                    Foreground="{DynamicResource AppTextMuted}"
                                                    Text="{Binding SelectedPositionRow.CostBaseAsMoney, Converter={StaticResource CurrencyConverter}, ConverterParameter=amount-approx, Mode=OneWay, FallbackValue=''}"
                                                    Typography.NumeralAlignment="Tabular"
                                                    Visibility="{Binding SelectedPositionRow.IsCrossCurrency, Converter={StaticResource BooleanToVisibilityConverter}, FallbackValue=Collapsed}" />
                                                <TextBlock
                                                    FontFamily="{StaticResource Font.Family.Base}"
                                                    FontSize="{StaticResource Font.Size.Xs}"
                                                    Foreground="{DynamicResource AppTextMuted}"
                                                    Text="{DynamicResource Portfolio.TotalCostPaid.Hint}"
                                                    TextTrimming="CharacterEllipsis" />
                                            </StackPanel>
                                        </Border>

                                        <!--  Card: 現價  -->
                                        <Border
                                            Grid.Row="2"
                                            Grid.Column="2"
                                            Padding="14,12"
                                            Background="{DynamicResource AppBackground}"
                                            BorderBrush="{DynamicResource AppBorder}"
                                            BorderThickness="1"
                                            CornerRadius="{StaticResource Radius.Sm}">
                                            <StackPanel>
                                                <TextBlock
                                                    FontSize="{StaticResource Font.Size.Xs}"
                                                    Foreground="{DynamicResource AppTextSecondary}"
                                                    Text="{DynamicResource Portfolio.Price}" />
                                                <StackPanel Margin="0,4,0,2" Orientation="Horizontal">
                                                    <TextBlock
                                                        FontFamily="{StaticResource Font.Family.Base}"
                                                        FontSize="{StaticResource Font.Size.Xl}"
                                                        FontWeight="SemiBold"
                                                        Foreground="{DynamicResource AppTextPrimary}"
                                                        Text="{Binding SelectedPositionRow.CurrentPriceAsMoney, Converter={StaticResource CurrencyConverter}, ConverterParameter=price, FallbackValue=''}"
                                                        Typography.NumeralAlignment="Tabular" />
                                                    <TextBlock
                                                        Margin="6,0,0,0"
                                                        VerticalAlignment="Bottom"
                                                        FontFamily="{StaticResource Font.Family.Base}"
                                                        FontSize="{StaticResource Font.Size.Xs}"
                                                        Text="{Binding SelectedPositionRow.DayChangePercent, StringFormat={}{0:+0.00;-0.00;0.00}%, FallbackValue=''}"
                                                        Typography.NumeralAlignment="Tabular">
                                                        <TextBlock.Style>
                                                            <Style TargetType="TextBlock">
                                                                <Setter Property="Foreground" Value="{DynamicResource AppDown}" />
                                                                <Style.Triggers>
                                                                    <DataTrigger Binding="{Binding SelectedPositionRow.IsDayChangePositive}" Value="True">
                                                                        <Setter Property="Foreground" Value="{DynamicResource AppUp}" />
                                                                    </DataTrigger>
                                                                </Style.Triggers>
                                                            </Style>
                                                        </TextBlock.Style>
                                                    </TextBlock>
                                                </StackPanel>
                                                <TextBlock
                                                    FontFamily="{StaticResource Font.Family.Base}"
                                                    FontSize="{StaticResource Font.Size.Xs}"
                                                    Foreground="{DynamicResource AppTextMuted}"
                                                    Text="{Binding SelectedPositionRow.CurrentPriceBaseAsMoney, Converter={StaticResource CurrencyConverter}, ConverterParameter=price-approx, Mode=OneWay, FallbackValue=''}"
                                                    Typography.NumeralAlignment="Tabular"
                                                    Visibility="{Binding SelectedPositionRow.IsCrossCurrency, Converter={StaticResource BooleanToVisibilityConverter}, FallbackValue=Collapsed}" />
                                                <Border
                                                    Margin="0,6,0,0"
                                                    Style="{StaticResource StatusBadge.Info}"
                                                    ToolTip="{Binding SelectedPositionRow.QuoteProviderStateMessage}"
                                                    Visibility="{Binding SelectedPositionRow.ShowQuoteProviderState, Converter={StaticResource BooleanToVisibilityConverter}, FallbackValue=Collapsed}">
                                                    <TextBlock Style="{StaticResource StatusBadge.Text}" Text="{DynamicResource Portfolio.QuoteState.Stale}" />
                                                </Border>
                                            </StackPanel>
                                        </Border>

                                        <!--  Card: 市值  -->
                                        <Border
                                            Grid.Row="4"
                                            Grid.Column="0"
                                            Padding="14,12"
                                            Background="{DynamicResource AppBackground}"
                                            BorderBrush="{DynamicResource AppBorder}"
                                            BorderThickness="1"
                                            CornerRadius="{StaticResource Radius.Sm}">
                                            <StackPanel>
                                                <TextBlock
                                                    FontSize="{StaticResource Font.Size.Xs}"
                                                    Foreground="{DynamicResource AppTextSecondary}"
                                                    Text="{DynamicResource Portfolio.Detail.MarketValue}" />
                                                <TextBlock
                                                    Margin="0,4,0,0"
                                                    FontFamily="{StaticResource Font.Family.Base}"
                                                    FontSize="{StaticResource Font.Size.Xl}"
                                                    FontWeight="SemiBold"
                                                    Foreground="{DynamicResource AppTextPrimary}"
                                                    Text="{Binding SelectedPositionRow.MarketValueAsMoney, Converter={StaticResource CurrencyConverter}, ConverterParameter=amount, Mode=OneWay, FallbackValue=''}"
                                                    Typography.NumeralAlignment="Tabular" />
                                                <TextBlock
                                                    FontFamily="{StaticResource Font.Family.Base}"
                                                    FontSize="{StaticResource Font.Size.Xs}"
                                                    Foreground="{DynamicResource AppTextMuted}"
                                                    Text="{Binding SelectedPositionRow.MarketValueBaseAsMoney, Converter={StaticResource CurrencyConverter}, ConverterParameter=amount-approx, Mode=OneWay, FallbackValue=''}"
                                                    Typography.NumeralAlignment="Tabular"
                                                    Visibility="{Binding SelectedPositionRow.IsCrossCurrency, Converter={StaticResource BooleanToVisibilityConverter}, FallbackValue=Collapsed}" />
                                            </StackPanel>
                                        </Border>

                                        <!--  Card: 淨值  -->
                                        <Border
                                            Grid.Row="4"
                                            Grid.Column="2"
                                            Padding="14,12"
                                            Background="{DynamicResource AppBackground}"
                                            BorderBrush="{DynamicResource AppBorder}"
                                            BorderThickness="1"
                                            CornerRadius="{StaticResource Radius.Sm}"
                                            ToolTip="{DynamicResource Portfolio.NetVal.Tooltip}">
                                            <StackPanel>
                                                <TextBlock
                                                    FontSize="{StaticResource Font.Size.Xs}"
                                                    Foreground="{DynamicResource AppTextSecondary}"
                                                    Text="{DynamicResource Portfolio.NetVal}" />
                                                <TextBlock
                                                    Margin="0,4,0,2"
                                                    FontFamily="{StaticResource Font.Family.Base}"
                                                    FontSize="{StaticResource Font.Size.Xl}"
                                                    FontWeight="SemiBold"
                                                    Foreground="{DynamicResource AppTextPrimary}"
                                                    Text="{Binding SelectedPositionRow.NetValueAsMoney, Converter={StaticResource CurrencyConverter}, ConverterParameter=amount, FallbackValue=''}"
                                                    Typography.NumeralAlignment="Tabular" />
                                                <TextBlock
                                                    FontFamily="{StaticResource Font.Family.Base}"
                                                    FontSize="{StaticResource Font.Size.Xs}"
                                                    Foreground="{DynamicResource AppTextMuted}"
                                                    Text="{Binding SelectedPositionRow.NetValueBaseAsMoney, Converter={StaticResource CurrencyConverter}, ConverterParameter=amount-approx, Mode=OneWay, FallbackValue=''}"
                                                    Typography.NumeralAlignment="Tabular"
                                                    Visibility="{Binding SelectedPositionRow.IsCrossCurrency, Converter={StaticResource BooleanToVisibilityConverter}, FallbackValue=Collapsed}" />
                                                <TextBlock
                                                    FontFamily="{StaticResource Font.Family.Base}"
                                                    FontSize="{StaticResource Font.Size.Xs}"
                                                    Foreground="{DynamicResource AppTextMuted}"
                                                    Typography.NumeralAlignment="Tabular">
                                                    <Run Text="{DynamicResource Portfolio.Detail.EstimatedSellFee}" />
                                                    <Run Text=":" />
                                                    <Run Text="{Binding SelectedPositionRow.EstimatedSellFeeAsMoney, Converter={StaticResource CurrencyConverter}, ConverterParameter=amount, Mode=OneWay, FallbackValue=''}" />
                                                </TextBlock>
                                            </StackPanel>
                                        </Border>

                                        <!--  Card: 淨損益試算 + %  -->
                                        <Border
                                            Grid.Row="6"
                                            Grid.Column="0"
                                            Grid.ColumnSpan="3"
                                            Padding="14,12"
                                            Background="{DynamicResource AppBackground}"
                                            BorderBrush="{DynamicResource AppBorder}"
                                            BorderThickness="1"
                                            CornerRadius="{StaticResource Radius.Sm}"
                                            ToolTip="{DynamicResource Portfolio.PnL.NetTooltip}">
                                            <StackPanel>
                                                <TextBlock
                                                    FontSize="{StaticResource Font.Size.Xs}"
                                                    Foreground="{DynamicResource AppTextSecondary}"
                                                    Text="{DynamicResource Portfolio.PnL}" />
                                                <TextBlock
                                                    Margin="0,4,0,2"
                                                    FontFamily="{StaticResource Font.Family.Base}"
                                                    FontSize="{StaticResource Font.Size.Xl}"
                                                    FontWeight="SemiBold"
                                                    Text="{Binding SelectedPositionRow.PnlAsMoney, Converter={StaticResource CurrencyConverter}, ConverterParameter=signed, FallbackValue=''}"
                                                    Typography.NumeralAlignment="Tabular">
                                                    <TextBlock.Style>
                                                        <Style TargetType="TextBlock">
                                                            <Setter Property="Foreground" Value="{DynamicResource AppDown}" />
                                                            <Style.Triggers>
                                                                <DataTrigger Binding="{Binding SelectedPositionRow.IsPnlPositive}" Value="True">
                                                                    <Setter Property="Foreground" Value="{DynamicResource AppUp}" />
                                                                </DataTrigger>
                                                            </Style.Triggers>
                                                        </Style>
                                                    </TextBlock.Style>
                                                </TextBlock>
                                                <TextBlock
                                                    FontFamily="{StaticResource Font.Family.Base}"
                                                    FontSize="{StaticResource Font.Size.Xs}"
                                                    Text="{Binding SelectedPositionRow.PnlPercent, StringFormat={}{0:+0.00;-0.00;0.00}%, FallbackValue=''}"
                                                    Typography.NumeralAlignment="Tabular">
                                                    <TextBlock.Style>
                                                        <Style TargetType="TextBlock">
                                                            <Setter Property="Foreground" Value="{DynamicResource AppDown}" />
                                                            <Style.Triggers>
                                                                <DataTrigger Binding="{Binding SelectedPositionRow.IsPnlPositive}" Value="True">
                                                                    <Setter Property="Foreground" Value="{DynamicResource AppUp}" />
                                                                </DataTrigger>
                                                            </Style.Triggers>
                                                        </Style>
                                                    </TextBlock.Style>
                                                </TextBlock>
                                                <TextBlock
                                                    FontFamily="{StaticResource Font.Family.Base}"
                                                    FontSize="{StaticResource Font.Size.Xs}"
                                                    Foreground="{DynamicResource AppTextMuted}"
                                                    Text="{Binding SelectedPositionRow.PnlBaseAsMoney, Converter={StaticResource CurrencyConverter}, ConverterParameter=signed-approx, Mode=OneWay, FallbackValue=''}"
                                                    Typography.NumeralAlignment="Tabular"
                                                    Visibility="{Binding SelectedPositionRow.IsCrossCurrency, Converter={StaticResource BooleanToVisibilityConverter}, FallbackValue=Collapsed}" />
                                            </StackPanel>
                                        </Border>
                                    </Grid>

                                    <!--  P4.1 Asset KPI matrix — ROI / XIRR × 1Y / 3Y / 累積 (2×3 grid + label row)  -->
                                    <Border
                                        Margin="0,16,0,0"
                                        Background="{DynamicResource AppBackground}"
                                        BorderBrush="{DynamicResource AppBorder}"
                                        BorderThickness="1"
                                        CornerRadius="{StaticResource Radius.Sm}">
                                        <StackPanel>
                                            <Border
                                                Padding="14,10"
                                                BorderBrush="{DynamicResource AppBorder}"
                                                BorderThickness="0,0,0,1">
                                                <TextBlock
                                                    FontSize="{StaticResource Font.Size.Sm}"
                                                    FontWeight="SemiBold"
                                                    Foreground="{DynamicResource AppTextPrimary}"
                                                    Text="{DynamicResource Portfolio.Detail.ReturnsMatrix.Title}" />
                                            </Border>
                                            <Grid Margin="14,10,14,12">
                                                <Grid.ColumnDefinitions>
                                                    <ColumnDefinition Width="*" />
                                                    <ColumnDefinition Width="Auto" />
                                                    <ColumnDefinition Width="Auto" />
                                                    <ColumnDefinition Width="Auto" />
                                                </Grid.ColumnDefinitions>
                                                <Grid.RowDefinitions>
                                                    <RowDefinition Height="Auto" />
                                                    <RowDefinition Height="Auto" />
                                                    <RowDefinition Height="Auto" />
                                                </Grid.RowDefinitions>
                                                <!--  Header row: window labels  -->
                                                <TextBlock
                                                    Grid.Row="0"
                                                    Grid.Column="1"
                                                    Margin="16,0,0,6"
                                                    HorizontalAlignment="Right"
                                                    FontSize="{StaticResource Font.Size.Xs}"
                                                    Foreground="{DynamicResource AppTextSecondary}"
                                                    Text="{DynamicResource Portfolio.Detail.ReturnsMatrix.Window1Y}" />
                                                <TextBlock
                                                    Grid.Row="0"
                                                    Grid.Column="2"
                                                    Margin="16,0,0,6"
                                                    HorizontalAlignment="Right"
                                                    FontSize="{StaticResource Font.Size.Xs}"
                                                    Foreground="{DynamicResource AppTextSecondary}"
                                                    Text="{DynamicResource Portfolio.Detail.ReturnsMatrix.Window3Y}" />
                                                <TextBlock
                                                    Grid.Row="0"
                                                    Grid.Column="3"
                                                    Margin="16,0,0,6"
                                                    HorizontalAlignment="Right"
                                                    FontSize="{StaticResource Font.Size.Xs}"
                                                    Foreground="{DynamicResource AppTextSecondary}"
                                                    Text="{DynamicResource Portfolio.Detail.ReturnsMatrix.WindowCum}" />
                                                <!--  ROI row  -->
                                                <TextBlock
                                                    Grid.Row="1"
                                                    Grid.Column="0"
                                                    Margin="0,6,0,4"
                                                    VerticalAlignment="Center"
                                                    FontSize="{StaticResource Font.Size.Sm}"
                                                    FontWeight="SemiBold"
                                                    Foreground="{DynamicResource AppTextPrimary}"
                                                    Text="{DynamicResource Portfolio.Detail.ReturnsMatrix.Roi}" />
                                                <TextBlock
                                                    Grid.Row="1"
                                                    Grid.Column="1"
                                                    Margin="16,6,0,4"
                                                    HorizontalAlignment="Right"
                                                    VerticalAlignment="Center"
                                                    FontFamily="{StaticResource Font.Family.Base}"
                                                    FontSize="{StaticResource Font.Size.Sm}"
                                                    FontWeight="SemiBold"
                                                    Text="{Binding SelectedPositionRoi1YDisplay, FallbackValue='—'}"
                                                    Typography.NumeralAlignment="Tabular">
                                                    <TextBlock.Style>
                                                        <Style TargetType="TextBlock">
                                                            <Setter Property="Foreground" Value="{DynamicResource AppDown}" />
                                                            <Style.Triggers>
                                                                <DataTrigger Binding="{Binding SelectedPositionRoi1YIsPositive}" Value="True">
                                                                    <Setter Property="Foreground" Value="{DynamicResource AppUp}" />
                                                                </DataTrigger>
                                                            </Style.Triggers>
                                                        </Style>
                                                    </TextBlock.Style>
                                                </TextBlock>
                                                <TextBlock
                                                    Grid.Row="1"
                                                    Grid.Column="2"
                                                    Margin="16,6,0,4"
                                                    HorizontalAlignment="Right"
                                                    VerticalAlignment="Center"
                                                    FontFamily="{StaticResource Font.Family.Base}"
                                                    FontSize="{StaticResource Font.Size.Sm}"
                                                    FontWeight="SemiBold"
                                                    Text="{Binding SelectedPositionRoi3YDisplay, FallbackValue='—'}"
                                                    Typography.NumeralAlignment="Tabular">
                                                    <TextBlock.Style>
                                                        <Style TargetType="TextBlock">
                                                            <Setter Property="Foreground" Value="{DynamicResource AppDown}" />
                                                            <Style.Triggers>
                                                                <DataTrigger Binding="{Binding SelectedPositionRoi3YIsPositive}" Value="True">
                                                                    <Setter Property="Foreground" Value="{DynamicResource AppUp}" />
                                                                </DataTrigger>
                                                            </Style.Triggers>
                                                        </Style>
                                                    </TextBlock.Style>
                                                </TextBlock>
                                                <TextBlock
                                                    Grid.Row="1"
                                                    Grid.Column="3"
                                                    Margin="16,6,0,4"
                                                    HorizontalAlignment="Right"
                                                    VerticalAlignment="Center"
                                                    FontFamily="{StaticResource Font.Family.Base}"
                                                    FontSize="{StaticResource Font.Size.Sm}"
                                                    FontWeight="SemiBold"
                                                    Text="{Binding SelectedPositionRoiCumDisplay, FallbackValue='—'}"
                                                    Typography.NumeralAlignment="Tabular">
                                                    <TextBlock.Style>
                                                        <Style TargetType="TextBlock">
                                                            <Setter Property="Foreground" Value="{DynamicResource AppDown}" />
                                                            <Style.Triggers>
                                                                <DataTrigger Binding="{Binding SelectedPositionRoiCumIsPositive}" Value="True">
                                                                    <Setter Property="Foreground" Value="{DynamicResource AppUp}" />
                                                                </DataTrigger>
                                                            </Style.Triggers>
                                                        </Style>
                                                    </TextBlock.Style>
                                                </TextBlock>
                                                <!--  XIRR row  -->
                                                <TextBlock
                                                    Grid.Row="2"
                                                    Grid.Column="0"
                                                    Margin="0,4,0,0"
                                                    VerticalAlignment="Center"
                                                    FontSize="{StaticResource Font.Size.Sm}"
                                                    FontWeight="SemiBold"
                                                    Foreground="{DynamicResource AppTextPrimary}"
                                                    Text="{DynamicResource Portfolio.Detail.ReturnsMatrix.Xirr}" />
                                                <TextBlock
                                                    Grid.Row="2"
                                                    Grid.Column="1"
                                                    Margin="16,4,0,0"
                                                    HorizontalAlignment="Right"
                                                    VerticalAlignment="Center"
                                                    FontFamily="{StaticResource Font.Family.Base}"
                                                    FontSize="{StaticResource Font.Size.Sm}"
                                                    FontWeight="SemiBold"
                                                    Text="{Binding SelectedPositionXirr1YDisplay, FallbackValue='—'}"
                                                    Typography.NumeralAlignment="Tabular">
                                                    <TextBlock.Style>
                                                        <Style TargetType="TextBlock">
                                                            <Setter Property="Foreground" Value="{DynamicResource AppDown}" />
                                                            <Style.Triggers>
                                                                <DataTrigger Binding="{Binding SelectedPositionXirr1YIsPositive}" Value="True">
                                                                    <Setter Property="Foreground" Value="{DynamicResource AppUp}" />
                                                                </DataTrigger>
                                                            </Style.Triggers>
                                                        </Style>
                                                    </TextBlock.Style>
                                                </TextBlock>
                                                <TextBlock
                                                    Grid.Row="2"
                                                    Grid.Column="2"
                                                    Margin="16,4,0,0"
                                                    HorizontalAlignment="Right"
                                                    VerticalAlignment="Center"
                                                    FontFamily="{StaticResource Font.Family.Base}"
                                                    FontSize="{StaticResource Font.Size.Sm}"
                                                    FontWeight="SemiBold"
                                                    Text="{Binding SelectedPositionXirr3YDisplay, FallbackValue='—'}"
                                                    Typography.NumeralAlignment="Tabular">
                                                    <TextBlock.Style>
                                                        <Style TargetType="TextBlock">
                                                            <Setter Property="Foreground" Value="{DynamicResource AppDown}" />
                                                            <Style.Triggers>
                                                                <DataTrigger Binding="{Binding SelectedPositionXirr3YIsPositive}" Value="True">
                                                                    <Setter Property="Foreground" Value="{DynamicResource AppUp}" />
                                                                </DataTrigger>
                                                            </Style.Triggers>
                                                        </Style>
                                                    </TextBlock.Style>
                                                </TextBlock>
                                                <TextBlock
                                                    Grid.Row="2"
                                                    Grid.Column="3"
                                                    Margin="16,4,0,0"
                                                    HorizontalAlignment="Right"
                                                    VerticalAlignment="Center"
                                                    FontFamily="{StaticResource Font.Family.Base}"
                                                    FontSize="{StaticResource Font.Size.Sm}"
                                                    FontWeight="SemiBold"
                                                    Text="{Binding SelectedPositionXirrCumDisplay, FallbackValue='—'}"
                                                    Typography.NumeralAlignment="Tabular">
                                                    <TextBlock.Style>
                                                        <Style TargetType="TextBlock">
                                                            <Setter Property="Foreground" Value="{DynamicResource AppDown}" />
                                                            <Style.Triggers>
                                                                <DataTrigger Binding="{Binding SelectedPositionXirrCumIsPositive}" Value="True">
                                                                    <Setter Property="Foreground" Value="{DynamicResource AppUp}" />
                                                                </DataTrigger>
                                                            </Style.Triggers>
                                                        </Style>
                                                    </TextBlock.Style>
                                                </TextBlock>
                                            </Grid>
                                        </StackPanel>
                                    </Border>

                                    <!--  Realized P&L section — 只在有資料時顯示，避免 3 行 NT$0 雜訊  -->
                                    <Border
                                        Margin="0,16,0,0"
                                        Background="{DynamicResource AppBackground}"
                                        BorderBrush="{DynamicResource AppBorder}"
                                        BorderThickness="1"
                                        CornerRadius="{StaticResource Radius.Sm}"
                                        Visibility="{Binding HasSelectedPositionRealized, Converter={StaticResource BooleanToVisibilityConverter}, FallbackValue=Collapsed}">
                                        <StackPanel>
                                            <Border
                                                Padding="14,10"
                                                BorderBrush="{DynamicResource AppBorder}"
                                                BorderThickness="0,0,0,1">
                                                <TextBlock
                                                    FontSize="{StaticResource Font.Size.Sm}"
                                                    FontWeight="SemiBold"
                                                    Foreground="{DynamicResource AppTextPrimary}"
                                                    Text="{DynamicResource Portfolio.Detail.RealizedPnL}" />
                                            </Border>
                                            <Grid Margin="14,8">
                                                <Grid.ColumnDefinitions>
                                                    <ColumnDefinition Width="*" />
                                                    <ColumnDefinition Width="Auto" />
                                                </Grid.ColumnDefinitions>
                                                <TextBlock
                                                    Grid.Column="0"
                                                    VerticalAlignment="Center"
                                                    FontSize="{StaticResource Font.Size.Sm}"
                                                    FontWeight="SemiBold"
                                                    Foreground="{DynamicResource AppTextPrimary}"
                                                    Text="{DynamicResource Portfolio.Detail.TotalRealized}" />
                                                <TextBlock
                                                    Grid.Column="1"
                                                    VerticalAlignment="Center"
                                                    FontFamily="{StaticResource Font.Family.Base}"
                                                    FontSize="{StaticResource Font.Size.Sm}"
                                                    FontWeight="SemiBold"
                                                    Foreground="{DynamicResource AppUp}"
                                                    Text="{Binding SelectedPositionRealizedTotal, Converter={StaticResource CurrencyConverter}, ConverterParameter=amount}"
                                                    Typography.NumeralAlignment="Tabular" />
                                            </Grid>
                                            <Grid Margin="14,6">
                                                <Grid.ColumnDefinitions>
                                                    <ColumnDefinition Width="*" />
                                                    <ColumnDefinition Width="Auto" />
                                                </Grid.ColumnDefinitions>
                                                <TextBlock
                                                    Grid.Column="0"
                                                    VerticalAlignment="Center"
                                                    FontSize="{StaticResource Font.Size.Xs}"
                                                    Foreground="{DynamicResource AppTextSecondary}"
                                                    Text="{DynamicResource Portfolio.Detail.CapitalGain}" />
                                                <TextBlock
                                                    Grid.Column="1"
                                                    VerticalAlignment="Center"
                                                    FontFamily="{StaticResource Font.Family.Base}"
                                                    FontSize="{StaticResource Font.Size.Xs}"
                                                    Foreground="{DynamicResource AppTextMuted}"
                                                    Text="{Binding SelectedPositionCapitalGain, Converter={StaticResource CurrencyConverter}, ConverterParameter=amount}"
                                                    Typography.NumeralAlignment="Tabular" />
                                            </Grid>
                                            <Grid Margin="14,6,14,12">
                                                <Grid.ColumnDefinitions>
                                                    <ColumnDefinition Width="*" />
                                                    <ColumnDefinition Width="Auto" />
                                                </Grid.ColumnDefinitions>
                                                <TextBlock
                                                    Grid.Column="0"
                                                    VerticalAlignment="Center"
                                                    FontSize="{StaticResource Font.Size.Xs}"
                                                    Foreground="{DynamicResource AppTextSecondary}"
                                                    Text="{DynamicResource Portfolio.Detail.DividendIncome}" />
                                                <TextBlock
                                                    Grid.Column="1"
                                                    VerticalAlignment="Center"
                                                    FontFamily="{StaticResource Font.Family.Base}"
                                                    FontSize="{StaticResource Font.Size.Xs}"
                                                    Foreground="{DynamicResource AppUp}"
                                                    Text="{Binding SelectedPositionDividendIncome, Converter={StaticResource CurrencyConverter}, ConverterParameter=amount}"
                                                    Typography.NumeralAlignment="Tabular" />
                                            </Grid>
                                        </StackPanel>
                                    </Border>
                                </StackPanel>

                            </StackPanel>

                            <!--  Trades tab  -->
                            <Grid Margin="20,12" Visibility="{Binding IsDetailTradesTab, Converter={StaticResource BooleanToVisibilityConverter}}">
                                <Grid.RowDefinitions>
                                    <RowDefinition Height="Auto" />
                                    <RowDefinition Height="*" />
                                </Grid.RowDefinitions>

                                <UniformGrid Margin="0,0,0,12" Columns="2">
                                    <Border
                                        Margin="0,0,5,0"
                                        Padding="12,10"
                                        Background="{DynamicResource AppBackground}"
                                        BorderBrush="{DynamicResource AppBorder}"
                                        BorderThickness="1"
                                        CornerRadius="{StaticResource Radius.Sm}">
                                        <StackPanel>
                                            <TextBlock
                                                FontSize="{StaticResource Font.Size.Xs}"
                                                Foreground="{DynamicResource AppTextSecondary}"
                                                Text="{DynamicResource Portfolio.Position.Summary.MarketValue}" />
                                            <TextBlock
                                                Margin="0,4,0,0"
                                                FontFamily="{StaticResource Font.Family.Base}"
                                                FontSize="{StaticResource Font.Size.Lg}"
                                                FontWeight="SemiBold"
                                                Foreground="{DynamicResource AppTextPrimary}"
                                                Text="{Binding SelectedPositionRow.MarketValueAsMoney, Converter={StaticResource CurrencyConverter}, ConverterParameter=amount, FallbackValue=''}"
                                                Typography.NumeralAlignment="Tabular" />
                                            <TextBlock
                                                FontFamily="{StaticResource Font.Family.Base}"
                                                FontSize="{StaticResource Font.Size.Xs}"
                                                Foreground="{DynamicResource AppTextMuted}"
                                                Text="{Binding SelectedPositionRow.MarketValueBaseAsMoney, Converter={StaticResource CurrencyConverter}, ConverterParameter=amount-approx, Mode=OneWay, FallbackValue=''}"
                                                Typography.NumeralAlignment="Tabular"
                                                Visibility="{Binding SelectedPositionRow.IsCrossCurrency, Converter={StaticResource BooleanToVisibilityConverter}, FallbackValue=Collapsed}" />
                                        </StackPanel>
                                    </Border>

                                    <Border
                                        Margin="5,0,0,0"
                                        Padding="12,10"
                                        Background="{DynamicResource AppBackground}"
                                        BorderBrush="{DynamicResource AppBorder}"
                                        BorderThickness="1"
                                        CornerRadius="{StaticResource Radius.Sm}"
                                        ToolTip="{DynamicResource Portfolio.PnL.NetTooltip}">
                                        <StackPanel>
                                            <TextBlock
                                                FontSize="{StaticResource Font.Size.Xs}"
                                                Foreground="{DynamicResource AppTextSecondary}"
                                                Text="{DynamicResource Portfolio.PnL}" />
                                            <TextBlock
                                                Margin="0,4,0,0"
                                                FontFamily="{StaticResource Font.Family.Base}"
                                                FontSize="{StaticResource Font.Size.Lg}"
                                                FontWeight="SemiBold"
                                                Text="{Binding SelectedPositionRow.PnlAsMoney, Converter={StaticResource CurrencyConverter}, ConverterParameter=signed, FallbackValue=''}"
                                                Typography.NumeralAlignment="Tabular">
                                                <TextBlock.Style>
                                                    <Style TargetType="TextBlock">
                                                        <Setter Property="Foreground" Value="{DynamicResource AppDown}" />
                                                        <Style.Triggers>
                                                            <DataTrigger Binding="{Binding SelectedPositionRow.IsPnlPositive}" Value="True">
                                                                <Setter Property="Foreground" Value="{DynamicResource AppUp}" />
                                                            </DataTrigger>
                                                            <DataTrigger Binding="{Binding SelectedPositionRow.Pnl}" Value="0">
                                                                <Setter Property="Foreground" Value="{DynamicResource AppTextMuted}" />
                                                            </DataTrigger>
                                                        </Style.Triggers>
                                                    </Style>
                                                </TextBlock.Style>
                                            </TextBlock>
                                            <TextBlock
                                                FontFamily="{StaticResource Font.Family.Base}"
                                                FontSize="{StaticResource Font.Size.Xs}"
                                                Foreground="{DynamicResource AppTextMuted}"
                                                Typography.NumeralAlignment="Tabular">
                                                <Run Text="{DynamicResource Portfolio.Detail.EstimatedSellFee}" />
                                                <Run Text=":" />
                                                <Run Text="{Binding SelectedPositionRow.EstimatedSellFeeAsMoney, Converter={StaticResource CurrencyConverter}, ConverterParameter=amount, Mode=OneWay, FallbackValue=''}" />
                                            </TextBlock>
                                            <TextBlock
                                                FontFamily="{StaticResource Font.Family.Base}"
                                                FontSize="{StaticResource Font.Size.Xs}"
                                                Foreground="{DynamicResource AppTextMuted}"
                                                Text="{Binding SelectedPositionRow.PnlBaseAsMoney, Converter={StaticResource CurrencyConverter}, ConverterParameter=signed-approx, Mode=OneWay, FallbackValue=''}"
                                                Typography.NumeralAlignment="Tabular"
                                                Visibility="{Binding SelectedPositionRow.IsCrossCurrency, Converter={StaticResource BooleanToVisibilityConverter}, FallbackValue=Collapsed}" />
                                        </StackPanel>
                                    </Border>
                                </UniformGrid>

                                <TextBlock
                                    Grid.Row="1"
                                    Margin="0,24,0,0"
                                    HorizontalAlignment="Center"
                                    VerticalAlignment="Top"
                                    FontSize="{StaticResource Font.Size.Sm}"
                                    Foreground="{DynamicResource AppTextMuted}"
                                    Text="{DynamicResource Portfolio.Detail.NoTrades}">
                                    <TextBlock.Style>
                                        <Style TargetType="TextBlock">
                                            <Setter Property="Visibility" Value="Collapsed" />
                                            <Style.Triggers>
                                                <DataTrigger Binding="{Binding SelectedPositionTrades.Count, FallbackValue=0}" Value="0">
                                                    <Setter Property="Visibility" Value="Visible" />
                                                </DataTrigger>
                                            </Style.Triggers>
                                        </Style>
                                    </TextBlock.Style>
                                </TextBlock>
                                <ItemsControl Grid.Row="1" ItemsSource="{Binding SelectedPositionTrades}">
                                    <ItemsControl.ItemTemplate>
                                        <DataTemplate>
                                            <Border
                                                Margin="0,0,0,10"
                                                Padding="12"
                                                Style="{StaticResource FormCard}">
                                                <StackPanel>
                                                    <Grid>
                                                        <Grid.ColumnDefinitions>
                                                            <ColumnDefinition Width="Auto" />
                                                            <ColumnDefinition Width="*" />
                                                            <ColumnDefinition Width="Auto" />
                                                        </Grid.ColumnDefinitions>
                                                        <TextBlock
                                                            Grid.Column="0"
                                                            VerticalAlignment="Center"
                                                            FontFamily="{StaticResource Font.Family.Base}"
                                                            FontSize="{StaticResource Font.Size.Xs}"
                                                            Foreground="{DynamicResource AppTextSecondary}"
                                                            Text="{Binding TradeDateLocal, StringFormat=yyyy/MM/dd}"
                                                            Typography.NumeralAlignment="Tabular" />
                                                        <Border
                                                            Grid.Column="1"
                                                            Margin="10,0,0,0"
                                                            Padding="6,2"
                                                            HorizontalAlignment="Left"
                                                            VerticalAlignment="Center"
                                                            Background="{Binding TypeBadgeColor, Converter={StaticResource HexToBrushConverter}}"
                                                            CornerRadius="{StaticResource Radius.Sm}">
                                                            <TextBlock
                                                                FontSize="{StaticResource Font.Size.Xs}"
                                                                FontWeight="SemiBold"
                                                                Foreground="{DynamicResource AppTextOnAccent}"
                                                                Text="{Binding Type, Converter={StaticResource TradeTypeConverter}}" />
                                                        </Border>
                                                        <Button
                                                            Grid.Column="2"
                                                            Width="32"
                                                            Height="32"
                                                            Padding="0"
                                                            HorizontalAlignment="Right"
                                                            VerticalAlignment="Center"
                                                            Command="{Binding DataContext.Transaction.EditTradeCommand, RelativeSource={RelativeSource AncestorType=ItemsControl}}"
                                                            CommandParameter="{Binding}"
                                                            Style="{StaticResource AppIconButton}"
                                                            ToolTip="{DynamicResource Common.Edit}">
                                                            <ds:AppIcon
                                                                FontSize="11"
                                                                Foreground="{DynamicResource AppTextMuted}"
                                                                Symbol="Edit24" />
                                                        </Button>
                                                    </Grid>

                                                    <WrapPanel Margin="0,8,0,0">
                                                        <StackPanel MinWidth="116" Margin="0,0,20,4">
                                                            <TextBlock
                                                                FontSize="{StaticResource Font.Size.Xs}"
                                                                Foreground="{DynamicResource AppTextSecondary}"
                                                                Text="{DynamicResource Portfolio.Shares}" />
                                                            <TextBlock
                                                                Margin="0,2,0,0"
                                                                FontFamily="{StaticResource Font.Family.Base}"
                                                                FontSize="{StaticResource Font.Size.Sm}"
                                                                FontWeight="SemiBold"
                                                                Text="{Binding DisplayQuantityText}"
                                                                Typography.NumeralAlignment="Tabular" />
                                                        </StackPanel>
                                                        <StackPanel MinWidth="116" Margin="0,0,20,4">
                                                            <TextBlock
                                                                FontSize="{StaticResource Font.Size.Xs}"
                                                                Foreground="{DynamicResource AppTextSecondary}"
                                                                Text="{DynamicResource Portfolio.TradeHistory.UnitPrice}" />
                                                            <TextBlock
                                                                Margin="0,2,0,0"
                                                                FontFamily="{StaticResource Font.Family.Base}"
                                                                FontSize="{StaticResource Font.Size.Sm}"
                                                                FontWeight="SemiBold"
                                                                Text="{Binding Price, Converter={StaticResource CurrencyConverter}, ConverterParameter=price-dash}"
                                                                Typography.NumeralAlignment="Tabular" />
                                                        </StackPanel>
                                                        <StackPanel MinWidth="140" Margin="0,0,20,4">
                                                            <TextBlock
                                                                FontSize="{StaticResource Font.Size.Xs}"
                                                                Foreground="{DynamicResource AppTextSecondary}"
                                                                Text="{DynamicResource Portfolio.TradeHistory.GrossAmount}" />
                                                            <TextBlock
                                                                Margin="0,2,0,0"
                                                                FontFamily="{StaticResource Font.Family.Base}"
                                                                FontSize="{StaticResource Font.Size.Sm}"
                                                                FontWeight="SemiBold"
                                                                Text="{Binding TotalAmount, Converter={StaticResource CurrencyConverter}, ConverterParameter=signed-dash}"
                                                                Typography.NumeralAlignment="Tabular">
                                                                <TextBlock.Style>
                                                                    <Style BasedOn="{StaticResource {x:Type TextBlock}}" TargetType="TextBlock">
                                                                        <Setter Property="Foreground" Value="{DynamicResource AppDown}" />
                                                                        <Style.Triggers>
                                                                            <DataTrigger Binding="{Binding IsAmountPositive}" Value="True">
                                                                                <Setter Property="Foreground" Value="{DynamicResource AppUp}" />
                                                                            </DataTrigger>
                                                                            <DataTrigger Binding="{Binding TotalAmount}" Value="0">
                                                                                <Setter Property="Foreground" Value="{DynamicResource AppTextSecondary}" />
                                                                            </DataTrigger>
                                                                        </Style.Triggers>
                                                                    </Style>
                                                                </TextBlock.Style>
                                                            </TextBlock>
                                                        </StackPanel>
                                                    </WrapPanel>

                                                    <TextBlock
                                                        Margin="0,2,0,0"
                                                        FontSize="{StaticResource Font.Size.Xs}"
                                                        Foreground="{DynamicResource AppTextMuted}"
                                                        Text="{Binding Note}"
                                                        TextWrapping="Wrap"
                                                        Visibility="{Binding Note, Converter={StaticResource StringToVisibilityConverter}}" />
                                                </StackPanel>
                                            </Border>
                                        </DataTemplate>
                                    </ItemsControl.ItemTemplate>
                                </ItemsControl>
                            </Grid>
                        </Grid>
                    </ScrollViewer>

                    <!--  ── Danger zone ──  -->
                    <Border
                        Grid.Row="3"
                        Margin="20,0,20,16"
                        Padding="14,12"
                        Background="{DynamicResource AppBackground}"
                        BorderBrush="{DynamicResource AppDanger}"
                        BorderThickness="1"
                        CornerRadius="{StaticResource Radius.Sm}">
                        <Grid>
                            <Grid.ColumnDefinitions>
                                <ColumnDefinition Width="*" />
                                <ColumnDefinition Width="Auto" />
                            </Grid.ColumnDefinitions>
                            <StackPanel Grid.Column="0" VerticalAlignment="Center">
                                <StackPanel Margin="0,0,0,2" Orientation="Horizontal">
                                    <ds:AppIcon
                                        Margin="0,0,6,0"
                                        VerticalAlignment="Center"
                                        FontSize="11"
                                        Foreground="{DynamicResource AppDanger}"
                                        Symbol="Delete24" />
                                    <TextBlock
                                        FontSize="{StaticResource Font.Size.Xs}"
                                        FontWeight="SemiBold"
                                        Foreground="{DynamicResource AppDanger}"
                                        Text="{DynamicResource Portfolio.Detail.DeleteAsset}" />
                                </StackPanel>
                                <TextBlock
                                    FontSize="{StaticResource Font.Size.Xs}"
                                    Foreground="{DynamicResource AppTextSecondary}"
                                    Text="{DynamicResource Portfolio.Detail.DeleteWarning}"
                                    TextWrapping="Wrap" />
                            </StackPanel>
                            <Button
                                Grid.Column="1"
                                Height="32"
                                Margin="12,0,0,0"
                                Padding="14,0"
                                VerticalAlignment="Center"
                                Command="{Binding RemovePositionCommand}"
                                CommandParameter="{Binding SelectedPositionRow}"
                                Style="{StaticResource AppDangerButton}">
                                <TextBlock
                                    FontSize="{StaticResource Font.Size.Xs}"
                                    Foreground="{Binding Foreground, RelativeSource={RelativeSource AncestorType=Button}}"
                                    Text="{DynamicResource Portfolio.Detail.DeleteAsset}" />
                            </Button>
                        </Grid>
                    </Border>
                </Grid>
            </Border>
        </Grid>

        <!--
            AddAssetDialog / EditAssetDialog / ConfirmDialog moved to
            MainWindow shell so they render on every page. AddRecordDialog
            was already moved earlier.
        -->
    </Grid>
</UserControl>
