<UserControl
    x:Class="Assetra.WPF.Features.Portfolio.Controls.EditAssetDialog"
    xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
    xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
    xmlns:behaviors="clr-namespace:Assetra.WPF.Infrastructure.Behaviors"
    xmlns:d="http://schemas.microsoft.com/expression/blend/2008"
    xmlns:ds="clr-namespace:Assetra.WPF.DesignSystem.Controls"
    xmlns:mc="http://schemas.openxmlformats.org/markup-compatibility/2006"
    xmlns:subvm="clr-namespace:Assetra.WPF.Features.Portfolio.SubViewModels"
    xmlns:vm="clr-namespace:Assetra.WPF.Features.Portfolio"
    d:DataContext="{d:DesignInstance Type={x:Type subvm:AccountDialogViewModel}}"
    Visibility="{Binding IsEditAssetDialogOpen, Converter={StaticResource BooleanToVisibilityConverter}}"
    mc:Ignorable="d">

    <Grid>
        <!--  半透明背景幕  -->
        <Grid Style="{StaticResource AppDialogOverlay}" />

        <!--  Dialog card  -->
        <Border
            Width="{StaticResource DialogWidth}"
            Padding="0"
            HorizontalAlignment="Center"
            VerticalAlignment="Center"
            behaviors:EscapeKeyCommandBehavior.Command="{Binding CloseEditAssetCommand}"
            Style="{StaticResource AppDialogShell}">
            <Grid>
                <Grid.RowDefinitions>
                    <RowDefinition Height="Auto" />
                    <RowDefinition Height="Auto" />
                    <RowDefinition Height="Auto" />
                    <RowDefinition Height="Auto" />
                </Grid.RowDefinitions>

                <!--  Title  -->
                <Border
                    Grid.Row="0"
                    Padding="20,14"
                    BorderBrush="{DynamicResource AppBorder}"
                    BorderThickness="0,0,0,1">
                    <DockPanel>
                        <Button
                            Width="28"
                            Height="28"
                            Padding="0"
                            HorizontalAlignment="Right"
                            Command="{Binding CloseEditAssetCommand}"
                            DockPanel.Dock="Right"
                            Style="{StaticResource AppIconButton}"
                            ToolTip="{DynamicResource Common.Close}">
                            <ds:AppIcon
                                FontSize="12"
                                Foreground="{DynamicResource AppTextMuted}"
                                Symbol="Dismiss24" />
                        </Button>
                        <StackPanel VerticalAlignment="Center">
                            <TextBlock
                                FontSize="{StaticResource Font.Size.Sm}"
                                FontWeight="SemiBold"
                                Foreground="{DynamicResource AppTextPrimary}"
                                Text="{Binding EditAssetDialogTitle}" />
                            <TextBlock
                                Margin="0,2,0,0"
                                FontSize="{StaticResource Font.Size.Xs}"
                                Foreground="{DynamicResource AppTextMuted}"
                                Text="{Binding EditAssetDialogSubtitle}" />
                        </StackPanel>
                    </DockPanel>
                </Border>

                <!--  Fields  -->
                <StackPanel Grid.Row="1" Margin="20,16,20,0">

                    <!--  Type (read-only badge)  -->
                    <TextBlock
                        Margin="0,0,0,6"
                        FontSize="{StaticResource Font.Size.Xs}"
                        FontWeight="SemiBold"
                        Foreground="{DynamicResource AppTextSecondary}"
                        Text="{DynamicResource Portfolio.EditAsset.TypeLabel}" />
                    <Border
                        Padding="10,5"
                        HorizontalAlignment="Left"
                        Background="{DynamicResource AppBorder}"
                        CornerRadius="{StaticResource Radius.Sm}">
                        <TextBlock
                            FontSize="{StaticResource Font.Size.Sm}"
                            Foreground="{DynamicResource AppTextSecondary}"
                            Text="{Binding EditAssetTypeLabel}" />
                    </Border>

                    <!--  Subtype (cash accounts only) — 改細分類會自動更新財務總覽分組  -->
                    <StackPanel Visibility="{Binding EditAssetIsCash, Converter={StaticResource BooleanToVisibilityConverter}}">
                        <TextBlock
                            Margin="0,14,0,6"
                            FontSize="{StaticResource Font.Size.Xs}"
                            FontWeight="SemiBold"
                            Foreground="{DynamicResource AppTextSecondary}"
                            Text="{DynamicResource Portfolio.EditAsset.SubtypeLabel}" />
                        <ComboBox
                            ItemsSource="{x:Static subvm:AccountDialogViewModel.CashSubtypeOptions}"
                            SelectedItem="{Binding EditAssetSubtype}"
                            Style="{StaticResource FormComboBox}" />
                        <TextBlock
                            Margin="0,4,0,0"
                            FontSize="{StaticResource Font.Size.Xs}"
                            Foreground="{DynamicResource AppTextMuted}"
                            Text="{DynamicResource Portfolio.EditAsset.SubtypeHint}"
                            TextWrapping="Wrap" />
                    </StackPanel>

                    <!--  Symbol (read-only, stock positions only)  -->
                    <StackPanel Visibility="{Binding EditAssetIsStock, Converter={StaticResource BooleanToVisibilityConverter}}">
                        <TextBlock
                            Margin="0,14,0,6"
                            FontSize="{StaticResource Font.Size.Xs}"
                            FontWeight="SemiBold"
                            Foreground="{DynamicResource AppTextSecondary}"
                            Text="{DynamicResource Portfolio.EditAsset.Symbol}" />
                        <Border
                            Padding="10,7"
                            Background="{DynamicResource AppBorder}"
                            CornerRadius="{StaticResource Radius.Sm}">
                            <TextBlock
                                FontFamily="{StaticResource Font.Family.Base}"
                                FontSize="{StaticResource Font.Size.Sm}"
                                Foreground="{DynamicResource AppTextSecondary}"
                                Text="{Binding EditAssetSymbol}"
                                Typography.NumeralAlignment="Tabular" />
                        </Border>
                    </StackPanel>

                    <!--  Investment group (positions only)  -->
                    <StackPanel Visibility="{Binding CanEditPositionGroup, Converter={StaticResource BooleanToVisibilityConverter}}">
                        <TextBlock
                            Margin="0,14,0,6"
                            FontSize="{StaticResource Font.Size.Xs}"
                            FontWeight="SemiBold"
                            Foreground="{DynamicResource AppTextSecondary}"
                            Text="{DynamicResource Portfolio.Tx.Group}" />
                        <Border
                            Margin="0,0,0,8"
                            Padding="10,8"
                            Background="{DynamicResource AppWarningSubtle}"
                            BorderBrush="{DynamicResource AppWarning}"
                            BorderThickness="1"
                            CornerRadius="{StaticResource Radius.Md}"
                            Visibility="{Binding EditAssetHasPortfolioGroupConflict, Converter={StaticResource BooleanToVisibilityConverter}}">
                            <DockPanel>
                                <ds:AppIcon
                                    Margin="0,1,8,0"
                                    DockPanel.Dock="Left"
                                    FontSize="14"
                                    Foreground="{DynamicResource AppWarning}"
                                    Symbol="Warning24" />
                                <StackPanel>
                                    <TextBlock
                                        FontSize="{StaticResource Font.Size.Xs}"
                                        FontWeight="SemiBold"
                                        Foreground="{DynamicResource AppTextPrimary}"
                                        Text="{DynamicResource Portfolio.EditAsset.GroupConflictTitle}" />
                                    <TextBlock
                                        Margin="0,2,0,0"
                                        FontSize="{StaticResource Font.Size.Xs}"
                                        Foreground="{DynamicResource AppTextSecondary}"
                                        Text="{DynamicResource Portfolio.EditAsset.GroupConflictDescription}"
                                        TextWrapping="Wrap" />
                                </StackPanel>
                            </DockPanel>
                        </Border>
                        <ComboBox
                            DisplayMemberPath="Name"
                            ItemsSource="{Binding PortfolioGroupOptions}"
                            SelectedValue="{Binding EditAssetPortfolioGroupId}"
                            SelectedValuePath="Id"
                            Style="{StaticResource FormComboBox}" />
                        <TextBlock
                            Margin="0,4,0,0"
                            FontSize="{StaticResource Font.Size.Xs}"
                            Foreground="{DynamicResource AppTextMuted}"
                            Text="{DynamicResource Portfolio.EditAsset.GroupHint}"
                            TextWrapping="Wrap" />
                    </StackPanel>

                    <!--  Name  -->
                    <TextBlock
                        Margin="0,14,0,6"
                        FontSize="{StaticResource Font.Size.Xs}"
                        FontWeight="SemiBold"
                        Foreground="{DynamicResource AppTextSecondary}"
                        Text="{DynamicResource Common.Name}" />
                    <TextBox Text="{Binding EditAssetName, UpdateSourceTrigger=PropertyChanged}" />

                    <!--  Currency  -->
                    <TextBlock
                        Margin="0,14,0,6"
                        FontSize="{StaticResource Font.Size.Xs}"
                        FontWeight="SemiBold"
                        Foreground="{DynamicResource AppTextSecondary}"
                        Text="{DynamicResource Portfolio.EditAsset.Currency}" />
                    <TextBlock
                        Margin="0,0,0,6"
                        FontSize="{StaticResource Font.Size.Xs}"
                        Foreground="{DynamicResource AppTextMuted}"
                        Text="{DynamicResource Portfolio.EditAsset.CurrencyHint}"
                        TextWrapping="Wrap" />
                    <ComboBox
                        DisplayMemberPath="Display"
                        ItemsSource="{x:Static vm:PortfolioViewModel.SupportedCurrencies}"
                        SelectedValue="{Binding EditAssetCurrency}"
                        SelectedValuePath="Code"
                        Style="{StaticResource FormComboBox}" />

                </StackPanel>

                <!--  Error  -->
                <TextBlock
                    Grid.Row="2"
                    Margin="20,8,20,0"
                    FontSize="{StaticResource Font.Size.Xs}"
                    Foreground="{DynamicResource AppDown}"
                    Text="{Binding EditAssetError}"
                    Visibility="{Binding EditAssetError, Converter={StaticResource StringToVisibilityConverter}}" />

                <!--  Footer  -->
                <Border
                    Grid.Row="3"
                    Margin="0,16,0,0"
                    Padding="20,12"
                    BorderBrush="{DynamicResource AppBorder}"
                    BorderThickness="0,1,0,0">
                    <StackPanel HorizontalAlignment="Right" Orientation="Horizontal">
                        <Button
                            Height="30"
                            Margin="0,0,8,0"
                            Padding="14,0"
                            Command="{Binding CloseEditAssetCommand}"
                            Style="{StaticResource AppSecondaryButton}">
                            <TextBlock Foreground="{DynamicResource AppTextSecondary}" Text="{DynamicResource Common.Cancel}" />
                        </Button>
                        <Button
                            Height="30"
                            Padding="14,0"
                            Command="{Binding SaveEditAssetCommand}"
                            Style="{StaticResource AppPrimaryButton}">
                            <TextBlock Foreground="{Binding Foreground, RelativeSource={RelativeSource AncestorType=Button}}" Text="{DynamicResource Portfolio.EditAsset.Update}" />
                        </Button>
                    </StackPanel>
                </Border>

            </Grid>
        </Border>
    </Grid>
</UserControl>
