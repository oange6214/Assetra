<UserControl
    x:Class="Assetra.WPF.Features.Portfolio.Controls.AssetSections.AccountCreateSection"
    x:Name="Root"
    xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
    xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
    xmlns:d="http://schemas.microsoft.com/expression/blend/2008"
    xmlns:mc="http://schemas.openxmlformats.org/markup-compatibility/2006"
    mc:Ignorable="d">

    <StackPanel>
        <TextBlock
            Margin="0,0,0,4"
            FontSize="{StaticResource FontSizeSm}"
            FontWeight="SemiBold"
            Foreground="{DynamicResource AppTextPrimary}"
            Text="{DynamicResource Portfolio.AssetDialog.SectionInfo}" />
        <TextBlock
            Margin="0,0,0,12"
            FontSize="{StaticResource FontSizeXs}"
            Foreground="{DynamicResource AppTextMuted}"
            Text="{DynamicResource Portfolio.AssetDialog.AccountInfoHint}"
            TextWrapping="Wrap" />
        <TextBlock
            Margin="0,0,0,4"
            FontSize="{StaticResource FontSizeXs}"
            FontWeight="SemiBold"
            Foreground="{DynamicResource AppTextSecondary}"
            Text="{DynamicResource Portfolio.Account.Subtype}" />
        <TextBox
            Margin="0,0,0,10"
            Style="{StaticResource FormTextBox}"
            ToolTip="{DynamicResource Portfolio.Account.SubtypeHint}"
            Text="{Binding AddSubtype, UpdateSourceTrigger=PropertyChanged}" />

        <TextBlock
            Margin="0,0,0,4"
            FontSize="{StaticResource FontSizeXs}"
            FontWeight="SemiBold"
            Foreground="{DynamicResource AppTextSecondary}"
            Text="{DynamicResource Portfolio.Cash.Name}" />
        <TextBox
            Margin="0,0,0,8"
            Style="{StaticResource FormTextBox}"
            Text="{Binding AddAccountName, UpdateSourceTrigger=PropertyChanged}" />

        <TextBlock
            Margin="0,0,0,12"
            FontSize="{StaticResource FontSizeXs}"
            Foreground="{DynamicResource AppTextMuted}"
            Text="{DynamicResource Portfolio.Cash.AddHint}"
            TextWrapping="Wrap" />

        <Border
            Margin="0,4,0,0"
            Padding="14,12"
            Background="{DynamicResource AppBackground}"
            BorderBrush="{DynamicResource AppBorder}"
            BorderThickness="1"
            CornerRadius="{StaticResource RadiusSm}">
            <StackPanel>
                <TextBlock
                    Margin="0,0,0,2"
                    FontSize="{StaticResource FontSizeSm}"
                    FontWeight="SemiBold"
                    Foreground="{DynamicResource AppTextPrimary}"
                    Text="{DynamicResource Portfolio.AssetDialog.InitialRecord}" />
                <TextBlock
                    Margin="0,0,0,10"
                    FontSize="{StaticResource FontSizeXs}"
                    Foreground="{DynamicResource AppTextMuted}"
                    Text="{DynamicResource Portfolio.AssetDialog.InitialRecordOptionalHint}"
                    TextWrapping="Wrap" />
                <CheckBox IsChecked="{Binding AddInitialDepositEnabled, Mode=TwoWay}">
                    <TextBlock
                        FontSize="{StaticResource FontSizeXs}"
                        Foreground="{DynamicResource AppTextPrimary}"
                        Text="{DynamicResource Portfolio.Cash.InitialDeposit.Toggle}" />
                </CheckBox>
                <StackPanel
                    Margin="0,12,0,0"
                    Visibility="{Binding AddInitialDepositEnabled, Converter={StaticResource BooleanToVisibilityConverter}}">
                    <TextBlock
                        Margin="0,0,0,4"
                        FontSize="{StaticResource FontSizeXs}"
                        FontWeight="SemiBold"
                        Foreground="{DynamicResource AppTextSecondary}"
                        Text="{DynamicResource Portfolio.Cash.InitialDeposit.Amount}" />
                    <TextBox
                        Margin="0,0,0,10"
                        Style="{StaticResource FormTextBox}"
                        Text="{Binding AddInitialDepositAmount, UpdateSourceTrigger=PropertyChanged}" />

                    <TextBlock
                        Margin="0,0,0,4"
                        FontSize="{StaticResource FontSizeXs}"
                        FontWeight="SemiBold"
                        Foreground="{DynamicResource AppTextSecondary}"
                        Text="{DynamicResource Portfolio.Cash.InitialDeposit.Date}" />
                    <DatePicker
                        Margin="0,0,0,10"
                        FontSize="{StaticResource FontSizeSm}"
                        Foreground="{DynamicResource AppTextPrimary}"
                        SelectedDate="{Binding AddInitialDepositDate}" />

                    <TextBlock
                        Margin="0,0,0,4"
                        FontSize="{StaticResource FontSizeXs}"
                        FontWeight="SemiBold"
                        Foreground="{DynamicResource AppTextSecondary}"
                        Text="{DynamicResource Portfolio.Tx.Note}" />
                    <TextBox
                        Height="64"
                        AcceptsReturn="True"
                        Style="{StaticResource FormTextBox}"
                        Text="{Binding AddInitialDepositNote, UpdateSourceTrigger=PropertyChanged}"
                        TextWrapping="Wrap"
                        VerticalScrollBarVisibility="Auto" />
                </StackPanel>
            </StackPanel>
        </Border>
    </StackPanel>
</UserControl>
