<UserControl
    x:Class="Assetra.WPF.Features.Portfolio.Controls.AssetSections.AccountCreateSection"
    xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
    xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
    xmlns:behaviors="clr-namespace:Assetra.WPF.Infrastructure.Behaviors"
    xmlns:d="http://schemas.microsoft.com/expression/blend/2008"
    xmlns:mc="http://schemas.openxmlformats.org/markup-compatibility/2006"
    xmlns:portfolio="clr-namespace:Assetra.WPF.Features.Portfolio"
    x:Name="Root"
    mc:Ignorable="d">

    <StackPanel>
        <TextBlock
            Margin="0,0,0,4"
            FontSize="{StaticResource Font.Size.Sm}"
            FontWeight="SemiBold"
            Foreground="{DynamicResource AppTextPrimary}"
            Text="{DynamicResource Portfolio.AssetDialog.SectionInfo}" />
        <TextBlock
            Margin="0,0,0,12"
            FontSize="{StaticResource Font.Size.Xs}"
            Foreground="{DynamicResource AppTextMuted}"
            Text="{DynamicResource Portfolio.AssetDialog.AccountInfoHint}"
            TextWrapping="Wrap" />
        <TextBlock
            Margin="0,0,0,4"
            FontSize="{StaticResource Font.Size.Xs}"
            FontWeight="SemiBold"
            Foreground="{DynamicResource AppTextSecondary}"
            Text="{DynamicResource Portfolio.Account.Subtype}" />
        <TextBox
            Margin="0,0,0,10"
            Text="{Binding AddSubtype, UpdateSourceTrigger=PropertyChanged}"
            ToolTip="{DynamicResource Portfolio.Account.SubtypeHint}" />

        <TextBlock
            Margin="0,0,0,4"
            FontSize="{StaticResource Font.Size.Xs}"
            FontWeight="SemiBold"
            Foreground="{DynamicResource AppTextSecondary}"
            Text="{DynamicResource Portfolio.Cash.Name}" />
        <TextBox Margin="0,0,0,8" Text="{Binding AddAccountName, UpdateSourceTrigger=PropertyChanged}" />

        <!--
            Currency picker for multi-currency users. Defaults to the user's
            primary currency (Settings → PrimaryCurrency) when the dialog
            opens; was previously hard-coded "TWD" with no UI.
        -->
        <TextBlock
            Margin="0,0,0,4"
            FontSize="{StaticResource Font.Size.Xs}"
            FontWeight="SemiBold"
            Foreground="{DynamicResource AppTextSecondary}"
            Text="{DynamicResource Portfolio.Cash.Currency}" />
        <ComboBox
            Margin="0,0,0,12"
            DisplayMemberPath="Display"
            ItemsSource="{x:Static portfolio:PortfolioViewModel.SupportedCurrencies}"
            SelectedValue="{Binding AddAccountCurrency, Mode=TwoWay}"
            SelectedValuePath="Code"
            Style="{StaticResource FormComboBox}" />

        <TextBlock
            Margin="0,0,0,12"
            FontSize="{StaticResource Font.Size.Xs}"
            Foreground="{DynamicResource AppTextMuted}"
            Text="{DynamicResource Portfolio.Cash.AddHint}"
            TextWrapping="Wrap" />

        <Border
            Margin="0,4,0,0"
            Padding="14,12"
            Background="{DynamicResource AppBackground}"
            BorderBrush="{DynamicResource AppBorder}"
            BorderThickness="1"
            CornerRadius="{StaticResource Radius.Sm}">
            <StackPanel>
                <TextBlock
                    Margin="0,0,0,2"
                    FontSize="{StaticResource Font.Size.Sm}"
                    FontWeight="SemiBold"
                    Foreground="{DynamicResource AppTextPrimary}"
                    Text="{DynamicResource Portfolio.AssetDialog.InitialRecord}" />
                <TextBlock
                    Margin="0,0,0,10"
                    FontSize="{StaticResource Font.Size.Xs}"
                    Foreground="{DynamicResource AppTextMuted}"
                    Text="{DynamicResource Portfolio.AssetDialog.InitialRecordOptionalHint}"
                    TextWrapping="Wrap" />
                <CheckBox IsChecked="{Binding AddInitialDepositEnabled, Mode=TwoWay}">
                    <TextBlock
                        FontSize="{StaticResource Font.Size.Xs}"
                        Foreground="{DynamicResource AppTextPrimary}"
                        Text="{DynamicResource Portfolio.Cash.InitialDeposit.Toggle}" />
                </CheckBox>
                <StackPanel Margin="0,12,0,0" Visibility="{Binding AddInitialDepositEnabled, Converter={StaticResource BooleanToVisibilityConverter}}">
                    <TextBlock
                        Margin="0,0,0,4"
                        FontSize="{StaticResource Font.Size.Xs}"
                        FontWeight="SemiBold"
                        Foreground="{DynamicResource AppTextSecondary}"
                        Text="{DynamicResource Portfolio.Cash.InitialDeposit.Amount}" />
                    <TextBox
                        Margin="0,0,0,10"
                        behaviors:ThousandSeparatorBehavior.IsEnabled="True"
                        Text="{Binding AddInitialDepositAmount, UpdateSourceTrigger=PropertyChanged}" />

                    <TextBlock
                        Margin="0,0,0,4"
                        FontSize="{StaticResource Font.Size.Xs}"
                        FontWeight="SemiBold"
                        Foreground="{DynamicResource AppTextSecondary}"
                        Text="{DynamicResource Portfolio.Cash.InitialDeposit.Date}" />
                    <DatePicker
                        MinWidth="132"
                        Margin="0,0,0,10"
                        HorizontalContentAlignment="Left"
                        SelectedDate="{Binding AddInitialDepositDate, Mode=TwoWay, UpdateSourceTrigger=PropertyChanged}"
                        Style="{StaticResource AppDatePicker}" />

                    <TextBlock
                        Margin="0,0,0,4"
                        FontSize="{StaticResource Font.Size.Xs}"
                        FontWeight="SemiBold"
                        Foreground="{DynamicResource AppTextSecondary}"
                        Text="{DynamicResource Portfolio.Tx.Note}" />
                    <TextBox
                        Height="64"
                        AcceptsReturn="True"
                        Text="{Binding AddInitialDepositNote, UpdateSourceTrigger=PropertyChanged}"
                        TextWrapping="Wrap"
                        VerticalScrollBarVisibility="Auto" />
                </StackPanel>
            </StackPanel>
        </Border>
    </StackPanel>
</UserControl>
