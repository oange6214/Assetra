<UserControl
    x:Class="Assetra.WPF.Features.Portfolio.Controls.AssetSections.CreditCardCreateSection"
    x:Name="Root"
    xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
    xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
    xmlns:d="http://schemas.microsoft.com/expression/blend/2008"
    xmlns:mc="http://schemas.openxmlformats.org/markup-compatibility/2006"
    mc:Ignorable="d">

    <StackPanel>
        <TextBlock
            Margin="0,0,0,4"
            FontSize="{StaticResource FontSizeSm}"
            FontWeight="SemiBold"
            Foreground="{DynamicResource AppTextPrimary}"
            Text="{DynamicResource Portfolio.AssetDialog.SectionInfo}" />
        <TextBlock
            Margin="0,0,0,12"
            FontSize="{StaticResource FontSizeXs}"
            Foreground="{DynamicResource AppTextMuted}"
            Text="{DynamicResource Portfolio.AssetDialog.CreditCardInfoHint}"
            TextWrapping="Wrap" />
        <TextBlock
            Margin="0,0,0,4"
            FontSize="{StaticResource FontSizeXs}"
            FontWeight="SemiBold"
            Foreground="{DynamicResource AppTextSecondary}"
            Text="{DynamicResource Portfolio.CreditCard.Name}" />
        <TextBox
            Margin="0,0,0,10"
            Style="{StaticResource FormTextBox}"
            Text="{Binding AddCreditCardName, UpdateSourceTrigger=PropertyChanged}" />

        <TextBlock
            Margin="0,0,0,4"
            FontSize="{StaticResource FontSizeXs}"
            FontWeight="SemiBold"
            Foreground="{DynamicResource AppTextSecondary}"
            Text="{DynamicResource Portfolio.CreditCard.Issuer}" />
        <TextBox
            Margin="0,0,0,10"
            Style="{StaticResource FormTextBox}"
            Text="{Binding AddCreditCardIssuer, UpdateSourceTrigger=PropertyChanged}" />

        <Expander Margin="0,0,0,10" IsExpanded="False">
            <Expander.Header>
                <TextBlock
                    FontSize="{StaticResource FontSizeXs}"
                    FontWeight="SemiBold"
                    Foreground="{DynamicResource AppTextSecondary}"
                    Text="{DynamicResource Portfolio.AssetDialog.Advanced}" />
            </Expander.Header>
            <StackPanel Margin="0,8,0,0">
                <Grid Margin="0,0,0,10">
            <Grid.Style>
                <Style TargetType="Grid">
                    <Setter Property="Visibility" Value="Visible" />
                    <Style.Triggers>
                        <DataTrigger Value="True">
                            <DataTrigger.Binding>
                                <MultiBinding Converter="{StaticResource WidthScaleThresholdToBooleanConverter}" ConverterParameter="860">
                                    <Binding ElementName="Root" Path="ActualWidth" />
                                    <Binding RelativeSource="{RelativeSource AncestorType=Window}" Path="DataContext.Settings.UiScale" />
                                </MultiBinding>
                            </DataTrigger.Binding>
                            <Setter Property="Visibility" Value="Collapsed" />
                        </DataTrigger>
                    </Style.Triggers>
                </Style>
            </Grid.Style>
            <Grid.ColumnDefinitions>
                <ColumnDefinition Width="*" />
                <ColumnDefinition Width="12" />
                <ColumnDefinition Width="*" />
            </Grid.ColumnDefinitions>
            <StackPanel Grid.Column="0">
                <TextBlock
                    Margin="0,0,0,4"
                    FontSize="{StaticResource FontSizeXs}"
                    FontWeight="SemiBold"
                    Foreground="{DynamicResource AppTextSecondary}"
                    Text="{DynamicResource Portfolio.CreditCard.BillingDay}" />
                <TextBox
                    Style="{StaticResource FormTextBox}"
                    Text="{Binding AddCreditCardBillingDay, UpdateSourceTrigger=PropertyChanged}" />
            </StackPanel>
            <StackPanel Grid.Column="2">
                <TextBlock
                    Margin="0,0,0,4"
                    FontSize="{StaticResource FontSizeXs}"
                    FontWeight="SemiBold"
                    Foreground="{DynamicResource AppTextSecondary}"
                    Text="{DynamicResource Portfolio.CreditCard.DueDay}" />
                <TextBox
                    Style="{StaticResource FormTextBox}"
                    Text="{Binding AddCreditCardDueDay, UpdateSourceTrigger=PropertyChanged}" />
            </StackPanel>
        </Grid>

        <StackPanel Margin="0,0,0,10">
            <StackPanel.Style>
                <Style TargetType="StackPanel">
                    <Setter Property="Visibility" Value="Collapsed" />
                    <Style.Triggers>
                        <DataTrigger Value="True">
                            <DataTrigger.Binding>
                                <MultiBinding Converter="{StaticResource WidthScaleThresholdToBooleanConverter}" ConverterParameter="860">
                                    <Binding ElementName="Root" Path="ActualWidth" />
                                    <Binding RelativeSource="{RelativeSource AncestorType=Window}" Path="DataContext.Settings.UiScale" />
                                </MultiBinding>
                            </DataTrigger.Binding>
                            <Setter Property="Visibility" Value="Visible" />
                        </DataTrigger>
                    </Style.Triggers>
                </Style>
            </StackPanel.Style>
            <TextBlock
                Margin="0,0,0,4"
                FontSize="{StaticResource FontSizeXs}"
                FontWeight="SemiBold"
                Foreground="{DynamicResource AppTextSecondary}"
                Text="{DynamicResource Portfolio.CreditCard.BillingDay}" />
            <TextBox
                Margin="0,0,0,10"
                Style="{StaticResource FormTextBox}"
                Text="{Binding AddCreditCardBillingDay, UpdateSourceTrigger=PropertyChanged}" />
            <TextBlock
                Margin="0,0,0,4"
                FontSize="{StaticResource FontSizeXs}"
                FontWeight="SemiBold"
                Foreground="{DynamicResource AppTextSecondary}"
                Text="{DynamicResource Portfolio.CreditCard.DueDay}" />
            <TextBox
                Style="{StaticResource FormTextBox}"
                Text="{Binding AddCreditCardDueDay, UpdateSourceTrigger=PropertyChanged}" />
        </StackPanel>

        <TextBlock
            Margin="0,0,0,4"
            FontSize="{StaticResource FontSizeXs}"
            FontWeight="SemiBold"
            Foreground="{DynamicResource AppTextSecondary}"
            Text="{DynamicResource Portfolio.CreditCard.CreditLimit}" />
        <TextBox
            Margin="0,0,0,8"
            Style="{StaticResource FormTextBox}"
            Text="{Binding AddCreditCardLimit, UpdateSourceTrigger=PropertyChanged}" />
            </StackPanel>
        </Expander>

        <TextBlock
            Margin="0,0,0,12"
            FontSize="{StaticResource FontSizeXs}"
            Foreground="{DynamicResource AppTextMuted}"
            Text="{DynamicResource Portfolio.CreditCard.AddHint}"
            TextWrapping="Wrap" />

        <Border
            Margin="0,4,0,0"
            Padding="14,12"
            Background="{DynamicResource AppBackground}"
            BorderBrush="{DynamicResource AppBorder}"
            BorderThickness="1"
            CornerRadius="{StaticResource RadiusSm}">
            <StackPanel>
                <TextBlock
                    Margin="0,0,0,2"
                    FontSize="{StaticResource FontSizeSm}"
                    FontWeight="SemiBold"
                    Foreground="{DynamicResource AppTextPrimary}"
                    Text="{DynamicResource Portfolio.AssetDialog.InitialRecord}" />
                <TextBlock
                    Margin="0,0,0,10"
                    FontSize="{StaticResource FontSizeXs}"
                    Foreground="{DynamicResource AppTextMuted}"
                    Text="{DynamicResource Portfolio.AssetDialog.InitialRecordOptionalHint}"
                    TextWrapping="Wrap" />
                <CheckBox IsChecked="{Binding AddInitialCreditCardBalanceEnabled, Mode=TwoWay}">
                    <TextBlock
                        FontSize="{StaticResource FontSizeXs}"
                        Foreground="{DynamicResource AppTextPrimary}"
                        Text="{DynamicResource Portfolio.CreditCard.InitialBalance.Toggle}" />
                </CheckBox>
                <StackPanel
                    Margin="0,12,0,0"
                    Visibility="{Binding AddInitialCreditCardBalanceEnabled, Converter={StaticResource BooleanToVisibilityConverter}}">
                    <TextBlock
                        Margin="0,0,0,4"
                        FontSize="{StaticResource FontSizeXs}"
                        FontWeight="SemiBold"
                        Foreground="{DynamicResource AppTextSecondary}"
                        Text="{DynamicResource Portfolio.CreditCard.InitialBalance.Amount}" />
                    <TextBox
                        Margin="0,0,0,10"
                        Style="{StaticResource FormTextBox}"
                        Text="{Binding AddInitialCreditCardBalanceAmount, UpdateSourceTrigger=PropertyChanged}" />

                    <TextBlock
                        Margin="0,0,0,4"
                        FontSize="{StaticResource FontSizeXs}"
                        FontWeight="SemiBold"
                        Foreground="{DynamicResource AppTextSecondary}"
                        Text="{DynamicResource Portfolio.CreditCard.InitialBalance.Date}" />
                    <DatePicker
                        Margin="0,0,0,10"
                        FontSize="{StaticResource FontSizeSm}"
                        Foreground="{DynamicResource AppTextPrimary}"
                        SelectedDate="{Binding AddInitialCreditCardBalanceDate}" />

                    <TextBlock
                        Margin="0,0,0,4"
                        FontSize="{StaticResource FontSizeXs}"
                        FontWeight="SemiBold"
                        Foreground="{DynamicResource AppTextSecondary}"
                        Text="{DynamicResource Portfolio.Tx.Note}" />
                    <TextBox
                        Height="64"
                        AcceptsReturn="True"
                        Style="{StaticResource FormTextBox}"
                        Text="{Binding AddInitialCreditCardBalanceNote, UpdateSourceTrigger=PropertyChanged}"
                        TextWrapping="Wrap"
                        VerticalScrollBarVisibility="Auto" />
                </StackPanel>
            </StackPanel>
        </Border>
    </StackPanel>
</UserControl>
