<UserControl
    x:Class="Assetra.WPF.Features.Portfolio.Controls.AssetSections.LoanCreateSection"
    x:Name="Root"
    xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
    xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
    xmlns:d="http://schemas.microsoft.com/expression/blend/2008"
    xmlns:mc="http://schemas.openxmlformats.org/markup-compatibility/2006"
    mc:Ignorable="d">

    <StackPanel>
        <TextBlock
            Margin="0,0,0,4"
            FontSize="{StaticResource FontSizeSm}"
            FontWeight="SemiBold"
            Foreground="{DynamicResource AppTextPrimary}"
            Text="{DynamicResource Portfolio.AssetDialog.SectionInfo}" />
        <TextBlock
            Margin="0,0,0,12"
            FontSize="{StaticResource FontSizeXs}"
            Foreground="{DynamicResource AppTextMuted}"
            Text="{DynamicResource Portfolio.AssetDialog.LoanInfoHint}"
            TextWrapping="Wrap" />
        <TextBlock
            Margin="0,0,0,4"
            FontSize="{StaticResource FontSizeXs}"
            FontWeight="SemiBold"
            Foreground="{DynamicResource AppTextSecondary}"
            Text="{DynamicResource Portfolio.Liability.Subtype}" />
        <TextBox
            Margin="0,0,0,10"
            Style="{StaticResource FormTextBox}"
            ToolTip="{DynamicResource Portfolio.Liability.SubtypeHint}"
            Text="{Binding AddSubtype, UpdateSourceTrigger=PropertyChanged}" />

        <TextBlock
            Margin="0,0,0,4"
            FontSize="{StaticResource FontSizeXs}"
            FontWeight="SemiBold"
            Foreground="{DynamicResource AppTextSecondary}"
            Text="{DynamicResource Portfolio.Loan.Name}" />
        <TextBox
            Margin="0,0,0,10"
            Style="{StaticResource FormTextBox}"
            Text="{Binding AddLoanName, UpdateSourceTrigger=PropertyChanged}" />

        <TextBlock
            Margin="0,0,0,4"
            FontSize="{StaticResource FontSizeXs}"
            FontWeight="SemiBold"
            Foreground="{DynamicResource AppTextSecondary}"
            Text="{DynamicResource Portfolio.Loan.Amount}" />
        <TextBox
            Margin="0,0,0,10"
            Style="{StaticResource FormTextBox}"
            Text="{Binding AddLoanAmount, UpdateSourceTrigger=PropertyChanged}" />

        <Grid Margin="0,0,0,10">
            <Grid.Style>
                <Style TargetType="Grid">
                    <Setter Property="Visibility" Value="Visible" />
                    <Style.Triggers>
                        <DataTrigger Value="True">
                            <DataTrigger.Binding>
                                <MultiBinding Converter="{StaticResource WidthScaleThresholdToBooleanConverter}" ConverterParameter="860">
                                    <Binding ElementName="Root" Path="ActualWidth" />
                                    <Binding RelativeSource="{RelativeSource AncestorType=Window}" Path="DataContext.Settings.UiScale" />
                                </MultiBinding>
                            </DataTrigger.Binding>
                            <Setter Property="Visibility" Value="Collapsed" />
                        </DataTrigger>
                    </Style.Triggers>
                </Style>
            </Grid.Style>
            <Grid.ColumnDefinitions>
                <ColumnDefinition Width="*" />
                <ColumnDefinition Width="12" />
                <ColumnDefinition Width="*" />
            </Grid.ColumnDefinitions>
            <StackPanel Grid.Column="0">
                <TextBlock
                    Margin="0,0,0,4"
                    FontSize="{StaticResource FontSizeXs}"
                    FontWeight="SemiBold"
                    Foreground="{DynamicResource AppTextSecondary}"
                    Text="{DynamicResource Portfolio.Loan.AnnualRate}" />
                <TextBox
                    Style="{StaticResource FormTextBox}"
                    Text="{Binding AddLoanAnnualRate, UpdateSourceTrigger=PropertyChanged}" />
            </StackPanel>
            <StackPanel Grid.Column="2">
                <TextBlock
                    Margin="0,0,0,4"
                    FontSize="{StaticResource FontSizeXs}"
                    FontWeight="SemiBold"
                    Foreground="{DynamicResource AppTextSecondary}"
                    Text="{DynamicResource Portfolio.Loan.TermMonths}" />
                <TextBox
                    Style="{StaticResource FormTextBox}"
                    Text="{Binding AddLoanTermMonths, UpdateSourceTrigger=PropertyChanged}" />
            </StackPanel>
        </Grid>

        <StackPanel Margin="0,0,0,10">
            <StackPanel.Style>
                <Style TargetType="StackPanel">
                    <Setter Property="Visibility" Value="Collapsed" />
                    <Style.Triggers>
                        <DataTrigger Value="True">
                            <DataTrigger.Binding>
                                <MultiBinding Converter="{StaticResource WidthScaleThresholdToBooleanConverter}" ConverterParameter="860">
                                    <Binding ElementName="Root" Path="ActualWidth" />
                                    <Binding RelativeSource="{RelativeSource AncestorType=Window}" Path="DataContext.Settings.UiScale" />
                                </MultiBinding>
                            </DataTrigger.Binding>
                            <Setter Property="Visibility" Value="Visible" />
                        </DataTrigger>
                    </Style.Triggers>
                </Style>
            </StackPanel.Style>
            <TextBlock
                Margin="0,0,0,4"
                FontSize="{StaticResource FontSizeXs}"
                FontWeight="SemiBold"
                Foreground="{DynamicResource AppTextSecondary}"
                Text="{DynamicResource Portfolio.Loan.AnnualRate}" />
            <TextBox
                Margin="0,0,0,10"
                Style="{StaticResource FormTextBox}"
                Text="{Binding AddLoanAnnualRate, UpdateSourceTrigger=PropertyChanged}" />
            <TextBlock
                Margin="0,0,0,4"
                FontSize="{StaticResource FontSizeXs}"
                FontWeight="SemiBold"
                Foreground="{DynamicResource AppTextSecondary}"
                Text="{DynamicResource Portfolio.Loan.TermMonths}" />
            <TextBox
                Style="{StaticResource FormTextBox}"
                Text="{Binding AddLoanTermMonths, UpdateSourceTrigger=PropertyChanged}" />
        </StackPanel>

        <TextBlock
            Margin="0,0,0,4"
            FontSize="{StaticResource FontSizeXs}"
            FontWeight="SemiBold"
            Foreground="{DynamicResource AppTextSecondary}"
            Text="{DynamicResource Portfolio.Loan.StartDate}" />
        <DatePicker
            Margin="0,0,0,10"
            FontSize="{StaticResource FontSizeSm}"
            Foreground="{DynamicResource AppTextPrimary}"
            SelectedDate="{Binding AddLoanStartDate}" />

        <TextBlock
            Margin="0,0,0,4"
            FontSize="{StaticResource FontSizeXs}"
            FontWeight="SemiBold"
            Foreground="{DynamicResource AppTextSecondary}"
            Text="{DynamicResource Portfolio.Loan.CashAccount}" />
        <ComboBox
            Margin="0,0,0,10"
            DisplayMemberPath="Name"
            ItemsSource="{Binding LoanCashAccountOptions}"
            SelectedItem="{Binding SelectedLoanCashAccount, Mode=TwoWay}"
            Style="{StaticResource FormComboBox}" />

        <TextBlock
            Margin="0,0,0,4"
            FontSize="{StaticResource FontSizeXs}"
            FontWeight="SemiBold"
            Foreground="{DynamicResource AppTextSecondary}"
            Text="{DynamicResource Portfolio.Loan.HandlingFee}" />
        <TextBox
            Margin="0,0,0,8"
            Style="{StaticResource FormTextBox}"
            Text="{Binding AddLoanHandlingFee, UpdateSourceTrigger=PropertyChanged}" />

        <Border
            Margin="0,4,0,0"
            Padding="14,12"
            Background="{DynamicResource AppBackground}"
            BorderBrush="{DynamicResource AppBorder}"
            BorderThickness="1"
            CornerRadius="{StaticResource RadiusSm}">
            <StackPanel>
                <DockPanel Margin="0,0,0,8" LastChildFill="False">
                    <TextBlock
                        VerticalAlignment="Center"
                        FontSize="{StaticResource FontSizeSm}"
                        FontWeight="SemiBold"
                        Foreground="{DynamicResource AppTextPrimary}"
                        Text="{DynamicResource Portfolio.AssetDialog.LoanBorrowRecord}" />
                    <Border
                        Margin="8,0,0,0"
                        Padding="6,2"
                        Background="{DynamicResource AppAccentSoft}"
                        BorderBrush="{DynamicResource AppAccent}"
                        BorderThickness="1"
                        CornerRadius="{StaticResource RadiusLg}"
                        DockPanel.Dock="Right">
                        <TextBlock
                            FontSize="{StaticResource FontSizeXs}"
                            FontWeight="SemiBold"
                            Foreground="{DynamicResource AppAccentText}"
                            Text="{DynamicResource Portfolio.AssetDialog.Required}" />
                    </Border>
                </DockPanel>
                <TextBlock
                    Margin="0,0,0,8"
                    FontSize="{StaticResource FontSizeXs}"
                    Foreground="{DynamicResource AppTextMuted}"
                    Text="{DynamicResource Portfolio.AssetDialog.LoanBorrowRecordHint}"
                    TextWrapping="Wrap" />
                <TextBlock
                    FontSize="{StaticResource FontSizeXs}"
                    Foreground="{DynamicResource AppTextMuted}"
                    Text="{DynamicResource Portfolio.Liability.AddHint}"
                    TextWrapping="Wrap" />
            </StackPanel>
        </Border>
    </StackPanel>
</UserControl>
