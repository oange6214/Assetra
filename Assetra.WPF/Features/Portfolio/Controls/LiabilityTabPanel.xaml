<UserControl
    x:Class="Assetra.WPF.Features.Portfolio.Controls.LiabilityTabPanel"
    xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
    xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
    xmlns:behaviors="clr-namespace:Assetra.WPF.Infrastructure.Behaviors"
    xmlns:controls="clr-namespace:Assetra.WPF.Controls"
    xmlns:conv="clr-namespace:Assetra.WPF.Infrastructure.Converters"
    xmlns:d="http://schemas.microsoft.com/expression/blend/2008"
    xmlns:mc="http://schemas.openxmlformats.org/markup-compatibility/2006"
    xmlns:ds="clr-namespace:Assetra.WPF.DesignSystem.Controls"
    xmlns:vm="clr-namespace:Assetra.WPF.Features.Portfolio"
    d:DataContext="{d:DesignInstance Type={x:Type vm:PortfolioViewModel}}"
    mc:Ignorable="d">

    <UserControl.Resources>
        <conv:PercentToWidthConverter x:Key="PercentToWidthConverter" />
        <conv:StatusTagToBrushConverter x:Key="StatusTagToBrush" />
    </UserControl.Resources>

    <Grid>
        <Grid.RowDefinitions>
            <RowDefinition Height="Auto" />
            <RowDefinition Height="Auto" />
            <RowDefinition Height="*" />
            <RowDefinition Height="Auto" />
            <!--  Filter summary footer  -->
        </Grid.RowDefinitions>

        <!--
            ═══ Row 0: Debt Health Summary ═══
            v3 layout (2026-05-13)：
            - 外層 Background AppSurface (白) → AppBackground (灰 #F7F8FA)，跟下方
              datagrid 同色，符合「card 外底色 ≠ card 本身」的設計慣例。
            - 內部 WrapPanel ItemWidth="372" 限死寬度導致兩個 card 永遠 372px，
              改用 Grid 2 等寬 column 讓 card 自動水平延展填滿寬度。
        -->
        <Border
            Grid.Row="0"
            Padding="{StaticResource Padding.SectionStrip}"
            Background="{DynamicResource AppBackground}"
            BorderBrush="{DynamicResource AppBorder}"
            BorderThickness="0,0,0,1">
            <Grid Margin="0,0,0,2">
                <Grid.ColumnDefinitions>
                    <ColumnDefinition Width="*" />
                    <ColumnDefinition Width="*" />
                </Grid.ColumnDefinitions>

                <!--
                    Left: Remaining + paid progress.
                    v2 重設計（依設計稿 2026-05-13）：
                    - 大金額後加 TWD 幣別 chip（小灰字）
                    - 大金額顏色從紅色 AppDown 改為主文字色（中性、不過度警示）
                    - 進度條從綠色 AppUp 改為主題 accent
                    - 底部「已繳 18%」「總借款 NT$xxx」改為 inline 文字（左右對齊），
                      移除原本的兩個有邊框 sub-card——畫面更乾淨、視覺密度更低
                -->
                <Border
                    Grid.Column="0"
                    Margin="{StaticResource CardMarginLeft}"
                    Padding="{StaticResource Padding.Card}"
                    Background="{DynamicResource AppCardBackground}"
                    BorderBrush="{DynamicResource AppBorder}"
                    BorderThickness="1"
                    CornerRadius="{StaticResource Radius.Sm}">
                    <StackPanel>
                        <TextBlock
                            Margin="0,0,0,8"
                            FontSize="{StaticResource Font.Size.Xs}"
                            Foreground="{DynamicResource AppTextMuted}"
                            Text="{DynamicResource Portfolio.Liability.TotalRemaining}" />

                        <!--  大金額 + TWD chip — 用 StackPanel 水平排，底部對齊  -->
                        <StackPanel
                            Margin="0,0,0,12"
                            Orientation="Horizontal"
                            VerticalAlignment="Bottom">
                            <TextBlock
                                FontFamily="{StaticResource Font.Family.Base}"
                                FontSize="{StaticResource Font.Size.Xl}"
                                FontWeight="Bold"
                                Foreground="{DynamicResource AppTextPrimary}"
                                Text="{Binding TotalLiabilities, Converter={StaticResource CurrencyConverter}, ConverterParameter=amount}"
                                Typography.NumeralAlignment="Tabular"
                                VerticalAlignment="Bottom" />
                            <TextBlock
                                Margin="8,0,0,4"
                                FontFamily="{StaticResource Font.Family.Base}"
                                FontSize="{StaticResource Font.Size.Xs}"
                                Foreground="{DynamicResource AppTextMuted}"
                                Text="TWD"
                                VerticalAlignment="Bottom" />
                        </StackPanel>

                        <!--  Progress bar — 改為 accent 色  -->
                        <Grid Margin="0,0,0,10">
                            <Border
                                Height="7"
                                Background="{DynamicResource AppBorder}"
                                CornerRadius="{StaticResource Radius.Sm}" />
                            <Border
                                Height="7"
                                HorizontalAlignment="Left"
                                Background="{DynamicResource AppAccent}"
                                CornerRadius="{StaticResource Radius.Sm}">
                                <Border.Width>
                                    <MultiBinding Converter="{StaticResource PercentToWidthConverter}">
                                        <Binding Path="Financial.PaidPercentValue" />
                                        <Binding Path="ActualWidth" RelativeSource="{RelativeSource AncestorType=Grid}" />
                                    </MultiBinding>
                                </Border.Width>
                            </Border>
                        </Grid>

                        <!--
                            底部 footer：已繳 18%（左）、總借款 NT$2,367,000（右）。
                            DockPanel LastChildFill=False 讓兩端各靠邊；中間自動空隙。
                        -->
                        <DockPanel LastChildFill="False">
                            <StackPanel DockPanel.Dock="Left" Orientation="Horizontal">
                                <TextBlock
                                    FontSize="{StaticResource Font.Size.Xs}"
                                    Foreground="{DynamicResource AppTextMuted}"
                                    Text="{DynamicResource Portfolio.Liability.PaidPercent}" />
                                <TextBlock
                                    Margin="6,0,0,0"
                                    FontFamily="{StaticResource Font.Family.Base}"
                                    FontSize="{StaticResource Font.Size.Xs}"
                                    FontWeight="SemiBold"
                                    Foreground="{DynamicResource AppTextPrimary}"
                                    Text="{Binding Financial.PaidPercentDisplay, Mode=OneWay}"
                                    Typography.NumeralAlignment="Tabular" />
                            </StackPanel>
                            <StackPanel DockPanel.Dock="Right" Orientation="Horizontal">
                                <TextBlock
                                    FontSize="{StaticResource Font.Size.Xs}"
                                    Foreground="{DynamicResource AppTextMuted}"
                                    Text="{DynamicResource Portfolio.Liability.TotalLoan}" />
                                <TextBlock
                                    Margin="6,0,0,0"
                                    FontFamily="{StaticResource Font.Family.Base}"
                                    FontSize="{StaticResource Font.Size.Xs}"
                                    FontWeight="SemiBold"
                                    Foreground="{DynamicResource AppTextPrimary}"
                                    Text="{Binding Financial.TotalOriginalDisplay, Mode=OneWay}"
                                    Typography.NumeralAlignment="Tabular" />
                            </StackPanel>
                        </DockPanel>
                    </StackPanel>
                </Border>

                <!--
                    Right: Leverage health (v2 redesign 2026-05-13).
                    依設計稿改：
                    - 標題後加 ⓘ icon（保留 ToolTip 解釋）
                    - 健康 badge 改成主題化的色塊（綠 / 黃 / 紅 隨 DebtStatusTag）
                    - 移除「負債比率」「槓桿比」兩個有邊框 sub-card → 改成 inline：
                      「14.5% 負債比率   1.17 槓桿比」直接平排
                    - 進度條移除 30% / 50% tick marks（保留純色填充）
                    - 底部標籤從「0% / 30% / 50% / 100%」精簡為「0% / 負債比率 / 100%」
                -->
                <Border
                    Grid.Column="1"
                    Margin="{StaticResource CardMarginRight}"
                    Padding="{StaticResource Padding.Card}"
                    Background="{DynamicResource AppCardBackground}"
                    BorderBrush="{DynamicResource AppBorder}"
                    BorderThickness="1"
                    CornerRadius="{StaticResource Radius.Sm}"
                    ToolTip="{DynamicResource Portfolio.Liability.Health.Tooltip}"
                    ToolTipService.InitialShowDelay="300"
                    ToolTipService.ShowDuration="20000">
                    <StackPanel>
                        <!--  Header: title + ⓘ icon (left), 健康 status badge (right)  -->
                        <DockPanel Margin="0,0,0,10">
                            <StackPanel DockPanel.Dock="Left" Orientation="Horizontal" VerticalAlignment="Center">
                                <TextBlock
                                    VerticalAlignment="Center"
                                    FontSize="{StaticResource Font.Size.Xs}"
                                    Foreground="{DynamicResource AppTextMuted}"
                                    Text="{DynamicResource Portfolio.Liability.Health.Label}" />
                                <ds:AppIcon
                                    Margin="4,0,0,0"
                                    VerticalAlignment="Center"
                                    FontSize="{StaticResource Font.Size.Xs}"
                                    Foreground="{DynamicResource AppTextMuted}"
                                    Symbol="Info24" />
                            </StackPanel>
                            <Border
                                Padding="8,2"
                                HorizontalAlignment="Right"
                                Background="{DynamicResource AppSurface}"
                                BorderBrush="{DynamicResource AppBorder}"
                                BorderThickness="1"
                                CornerRadius="{StaticResource Radius.Lg}"
                                DockPanel.Dock="Right">
                                <TextBlock
                                    FontSize="{StaticResource Font.Size.Xs}"
                                    FontWeight="SemiBold"
                                    Foreground="{Binding Financial.DebtStatusTag, Converter={StaticResource StatusTagToBrush}}">
                                    <TextBlock.Style>
                                        <Style TargetType="TextBlock">
                                            <Setter Property="Text" Value="{DynamicResource Portfolio.Liability.Health.Healthy}" />
                                            <Style.Triggers>
                                                <DataTrigger Binding="{Binding Financial.DebtStatusTag}" Value="warning">
                                                    <Setter Property="Text" Value="{DynamicResource Portfolio.Liability.Health.Warning}" />
                                                </DataTrigger>
                                                <DataTrigger Binding="{Binding Financial.DebtStatusTag}" Value="danger">
                                                    <Setter Property="Text" Value="{DynamicResource Portfolio.Liability.Health.Danger}" />
                                                </DataTrigger>
                                            </Style.Triggers>
                                        </Style>
                                    </TextBlock.Style>
                                </TextBlock>
                            </Border>
                        </DockPanel>

                        <!--
                            Inline metrics — 大數字 + 小灰字 label 平排，免去原本兩個 sub-card 的邊框。
                            14.5%   負債比率   ·   1.17   槓桿比
                        -->
                        <StackPanel Margin="0,0,0,12" Orientation="Horizontal" VerticalAlignment="Bottom">
                            <TextBlock
                                FontFamily="{StaticResource Font.Family.Base}"
                                FontSize="{StaticResource Font.Size.Base}"
                                FontWeight="Bold"
                                Foreground="{DynamicResource AppTextPrimary}"
                                Text="{Binding Financial.DebtRatioDisplay}"
                                Typography.NumeralAlignment="Tabular"
                                VerticalAlignment="Bottom" />
                            <TextBlock
                                Margin="6,0,0,0"
                                FontSize="{StaticResource Font.Size.Xs}"
                                Foreground="{DynamicResource AppTextMuted}"
                                Text="{DynamicResource Portfolio.Liability.DebtRatio}"
                                VerticalAlignment="Bottom" />
                            <TextBlock
                                Margin="16,0,0,0"
                                FontFamily="{StaticResource Font.Family.Base}"
                                FontSize="{StaticResource Font.Size.Base}"
                                FontWeight="Bold"
                                Foreground="{DynamicResource AppTextPrimary}"
                                Text="{Binding Financial.LeverageRatioDisplay}"
                                Typography.NumeralAlignment="Tabular"
                                VerticalAlignment="Bottom" />
                            <TextBlock
                                Margin="6,0,0,0"
                                FontSize="{StaticResource Font.Size.Xs}"
                                Foreground="{DynamicResource AppTextMuted}"
                                Text="{DynamicResource Portfolio.Liability.LeverageRatio}"
                                VerticalAlignment="Bottom" />
                        </StackPanel>

                        <!--  Progress bar — 色階仍跟著 DebtStatusTag (健康綠 / 警告黃 / 危險紅)，但去掉 tick marks  -->
                        <Grid Margin="0,0,0,4">
                            <Border
                                Height="6"
                                Background="{DynamicResource AppBorder}"
                                CornerRadius="{StaticResource Radius.Sm}" />
                            <Border
                                Height="6"
                                HorizontalAlignment="Left"
                                Background="{Binding Financial.DebtStatusTag, Converter={StaticResource StatusTagToBrush}}"
                                CornerRadius="{StaticResource Radius.Sm}">
                                <Border.Width>
                                    <MultiBinding Converter="{StaticResource PercentToWidthConverter}">
                                        <Binding Path="Financial.DebtRatioValue" />
                                        <Binding Path="ActualWidth" RelativeSource="{RelativeSource AncestorType=Grid}" />
                                    </MultiBinding>
                                </Border.Width>
                            </Border>
                        </Grid>

                        <!--  Bottom labels: 0% | 負債比率 (center) | 100%  -->
                        <Grid>
                            <Grid.ColumnDefinitions>
                                <ColumnDefinition Width="*" />
                                <ColumnDefinition Width="*" />
                                <ColumnDefinition Width="*" />
                            </Grid.ColumnDefinitions>
                            <TextBlock
                                Grid.Column="0"
                                HorizontalAlignment="Left"
                                FontSize="{StaticResource Font.Size.Xs}"
                                Foreground="{DynamicResource AppTextMuted}"
                                Text="0%" />
                            <TextBlock
                                Grid.Column="1"
                                HorizontalAlignment="Center"
                                FontSize="{StaticResource Font.Size.Xs}"
                                Foreground="{DynamicResource AppTextMuted}"
                                Text="{DynamicResource Portfolio.Liability.DebtRatio}" />
                            <TextBlock
                                Grid.Column="2"
                                HorizontalAlignment="Right"
                                FontSize="{StaticResource Font.Size.Xs}"
                                Foreground="{DynamicResource AppTextMuted}"
                                Text="100%" />
                        </Grid>
                    </StackPanel>
                </Border>
            </Grid>
        </Border>

        <controls:SearchBox
            Grid.Row="1"
            Placeholder="{DynamicResource Portfolio.Filter.SearchLiabilities}"
            Text="{Binding LiabilityFilterText}">
            <controls:SearchBox.RightContent>
                <Button
                    MinHeight="32"
                    Padding="10,0"
                    Command="{Binding OpenAddLiabilityDialogCommand}"
                    Style="{StaticResource AppSecondaryButton}">
                    <StackPanel Orientation="Horizontal">
                        <ds:AppIcon
                            Margin="0,0,6,0"
                            VerticalAlignment="Center"
                            FontSize="{StaticResource Font.Size.Xs}"
                            Symbol="Add24" />
                        <TextBlock VerticalAlignment="Center" Text="{DynamicResource Portfolio.AddLiability}" />
                    </StackPanel>
                </Button>
            </controls:SearchBox.RightContent>
        </controls:SearchBox>

        <!--  ═══ Liabilities DataGrid ═══  -->
        <Grid Grid.Row="2">
            <!--  Empty state  -->
            <Border
                Padding="32"
                Background="{DynamicResource AppBackground}"
                Visibility="{Binding HasNoLiabilities, Converter={StaticResource BooleanToVisibilityConverter}}">
                <StackPanel HorizontalAlignment="Center" VerticalAlignment="Center">
                    <StackPanel HorizontalAlignment="Center" Opacity="0.4">
                        <TextBlock
                            Margin="0,0,0,6"
                            HorizontalAlignment="Center"
                            FontSize="{StaticResource Font.Size.2xl}"
                            Text="&#x1F4C4;" />
                        <TextBlock
                            HorizontalAlignment="Center"
                            FontSize="{StaticResource Font.Size.Sm}"
                            Foreground="{DynamicResource AppTextSecondary}"
                            Text="{DynamicResource Portfolio.Liability.Empty}" />
                    </StackPanel>
                    <Button
                        Height="36"
                        Margin="0,16,0,0"
                        Padding="20,0"
                        HorizontalAlignment="Center"
                        Command="{Binding OpenAddLiabilityDialogCommand}"
                        Style="{StaticResource AppPrimaryButton}">
                        <TextBlock Foreground="{Binding Foreground, RelativeSource={RelativeSource AncestorType=Button}}" Text="{DynamicResource Portfolio.AddLiability.Full}" />
                    </Button>
                </StackPanel>
            </Border>

            <DataGrid
                x:Name="LiabilityGrid"
                AlternationCount="2"
                AutoGenerateColumns="False"
                Background="{DynamicResource AppBackground}"
                BorderThickness="0"
                CanUserAddRows="False"
                CanUserDeleteRows="False"
                CanUserReorderColumns="False"
                CanUserResizeColumns="False"
                CanUserSortColumns="True"
                ColumnHeaderHeight="{StaticResource DataGrid.HeaderHeight}"
                EnableRowVirtualization="True"
                FontFamily="{StaticResource Font.Family.Base}"
                FontSize="{StaticResource Font.Size.Sm}"
                Foreground="{DynamicResource AppTextPrimary}"
                GridLinesVisibility="None"
                HeadersVisibility="Column"
                HorizontalScrollBarVisibility="Auto"
                IsReadOnly="True"
                ItemsSource="{Binding LiabilitiesView}"
                PreviewMouseDown="OnGridPreviewMouseDown"
                RowHeight="{StaticResource DataGrid.RowHeight}"
                SelectedItem="{Binding SelectedLiabilityRow, Mode=TwoWay}"
                SelectionMode="Single"
                VirtualizingPanel.IsVirtualizing="True"
                VirtualizingPanel.VirtualizationMode="Recycling">

                <DataGrid.ColumnHeaderStyle>
                    <Style BasedOn="{StaticResource AppDataGridColHeader}" TargetType="DataGridColumnHeader" />
                </DataGrid.ColumnHeaderStyle>
                <DataGrid.CellStyle>
                    <Style BasedOn="{StaticResource AppDataGridCell}" TargetType="DataGridCell" />
                </DataGrid.CellStyle>
                <DataGrid.RowStyle>
                    <Style BasedOn="{StaticResource AppDataGridRowSelectable}" TargetType="DataGridRow" />
                </DataGrid.RowStyle>

                <DataGrid.Columns>
                    <DataGridTemplateColumn Width="*" SortMemberPath="Name">
                        <DataGridTemplateColumn.Header>
                            <TextBlock Text="{DynamicResource Common.Name}" />
                        </DataGridTemplateColumn.Header>
                        <DataGridTemplateColumn.CellTemplate>
                            <DataTemplate>
                                <Grid VerticalAlignment="Center">
                                    <Grid.ColumnDefinitions>
                                        <ColumnDefinition Width="*" />
                                        <ColumnDefinition Width="Auto" />
                                    </Grid.ColumnDefinitions>

                                    <StackPanel Grid.Column="0">
                                        <TextBlock
                                            FontWeight="SemiBold"
                                            Foreground="{DynamicResource AppTextPrimary}"
                                            Text="{Binding Name}"
                                            TextTrimming="CharacterEllipsis" />
                                        <!--
                                            次行（meta line）：
                                            - 貸款：年利率 + 剩餘期數（e.g.「2.50% · 剩 65 期 / 84」）
                                            - 信用卡：發卡行 + 結帳/到期日（e.g.「台新 · 結帳 25 / 到期 10」）
                                        -->
                                        <StackPanel Margin="0,4,0,0" Orientation="Horizontal">
                                            <!--  Loan: rate  -->
                                            <TextBlock
                                                FontFamily="{StaticResource Font.Family.Base}"
                                                FontSize="{StaticResource Font.Size.Xs}"
                                                Foreground="{DynamicResource AppTextMuted}"
                                                Text="{Binding RateDisplay}"
                                                Typography.NumeralAlignment="Tabular">
                                                <TextBlock.Style>
                                                    <Style TargetType="TextBlock">
                                                        <Setter Property="Visibility" Value="Visible" />
                                                        <Style.Triggers>
                                                            <DataTrigger Binding="{Binding IsCreditCard}" Value="True">
                                                                <Setter Property="Visibility" Value="Collapsed" />
                                                            </DataTrigger>
                                                        </Style.Triggers>
                                                    </Style>
                                                </TextBlock.Style>
                                            </TextBlock>
                                            <TextBlock
                                                Margin="6,0,6,0"
                                                FontSize="{StaticResource Font.Size.Xs}"
                                                Foreground="{DynamicResource AppTextMuted}"
                                                Text="·"
                                                Visibility="{Binding HasSchedule, Converter={StaticResource BooleanToVisibilityConverter}}" />
                                            <TextBlock
                                                FontSize="{StaticResource Font.Size.Xs}"
                                                Foreground="{DynamicResource AppTextMuted}"
                                                Text="{Binding RemainingPeriodsDisplay}"
                                                Visibility="{Binding HasSchedule, Converter={StaticResource BooleanToVisibilityConverter}}" />
                                            <!--  Credit card: issuer + cycle  -->
                                            <TextBlock
                                                FontSize="{StaticResource Font.Size.Xs}"
                                                Foreground="{DynamicResource AppTextMuted}"
                                                Text="{Binding IssuerName, FallbackValue=''}"
                                                Visibility="{Binding IsCreditCard, Converter={StaticResource BooleanToVisibilityConverter}}" />
                                            <TextBlock
                                                Margin="6,0,6,0"
                                                FontSize="{StaticResource Font.Size.Xs}"
                                                Foreground="{DynamicResource AppTextMuted}"
                                                Text="·">
                                                <TextBlock.Style>
                                                    <Style TargetType="TextBlock">
                                                        <Setter Property="Visibility" Value="Collapsed" />
                                                        <Style.Triggers>
                                                            <MultiDataTrigger>
                                                                <MultiDataTrigger.Conditions>
                                                                    <Condition Binding="{Binding IsCreditCard}" Value="True" />
                                                                </MultiDataTrigger.Conditions>
                                                                <Setter Property="Visibility" Value="Visible" />
                                                            </MultiDataTrigger>
                                                        </Style.Triggers>
                                                    </Style>
                                                </TextBlock.Style>
                                            </TextBlock>
                                            <TextBlock
                                                FontSize="{StaticResource Font.Size.Xs}"
                                                Foreground="{DynamicResource AppTextMuted}"
                                                Text="{Binding CardCycleDisplay}"
                                                Visibility="{Binding IsCreditCard, Converter={StaticResource BooleanToVisibilityConverter}}" />
                                        </StackPanel>
                                    </StackPanel>

                                    <Border
                                        Grid.Column="1"
                                        Margin="10,0,0,0"
                                        HorizontalAlignment="Right"
                                        VerticalAlignment="Center"
                                        Style="{StaticResource PortfolioLiabilityBadge}">
                                        <TextBlock>
                                            <TextBlock.Style>
                                                <Style BasedOn="{StaticResource PortfolioBadgeText}" TargetType="TextBlock">
                                                    <Setter Property="Text" Value="{DynamicResource Portfolio.Dialog.TypeLoan}" />
                                                    <Style.Triggers>
                                                        <DataTrigger Binding="{Binding IsCreditCard}" Value="True">
                                                            <Setter Property="Text" Value="{DynamicResource Portfolio.Dialog.TypeCreditCard}" />
                                                        </DataTrigger>
                                                    </Style.Triggers>
                                                </Style>
                                            </TextBlock.Style>
                                        </TextBlock>
                                    </Border>
                                </Grid>
                            </DataTemplate>
                        </DataGridTemplateColumn.CellTemplate>
                    </DataGridTemplateColumn>

                    <!--  Remaining Balance  -->
                    <DataGridTemplateColumn Width="200" SortMemberPath="Balance">
                        <DataGridTemplateColumn.HeaderStyle>
                            <Style BasedOn="{StaticResource AppDataGridColHeader}" TargetType="DataGridColumnHeader">
                                <Setter Property="HorizontalContentAlignment" Value="Right" />
                            </Style>
                        </DataGridTemplateColumn.HeaderStyle>
                        <DataGridTemplateColumn.Header>
                            <TextBlock Text="{DynamicResource Portfolio.Liability.Amount}" />
                        </DataGridTemplateColumn.Header>
                        <DataGridTemplateColumn.CellTemplate>
                            <DataTemplate>
                                <TextBlock
                                    VerticalAlignment="Center"
                                    FontFamily="{StaticResource Font.Family.Base}"
                                    FontWeight="SemiBold"
                                    Foreground="{DynamicResource AppDown}"
                                    Text="{Binding Balance, Converter={StaticResource CurrencyConverter}, ConverterParameter=amount}"
                                    TextAlignment="Right"
                                    Typography.NumeralAlignment="Tabular" />
                            </DataTemplate>
                        </DataGridTemplateColumn.CellTemplate>
                    </DataGridTemplateColumn>

                    <!--  Original Amount  -->
                    <DataGridTemplateColumn Width="200" SortMemberPath="OriginalAmount">
                        <DataGridTemplateColumn.HeaderStyle>
                            <Style BasedOn="{StaticResource AppDataGridColHeader}" TargetType="DataGridColumnHeader">
                                <Setter Property="HorizontalContentAlignment" Value="Right" />
                            </Style>
                        </DataGridTemplateColumn.HeaderStyle>
                        <DataGridTemplateColumn.Header>
                            <TextBlock Text="{DynamicResource Portfolio.Liability.OriginalAmount}" />
                        </DataGridTemplateColumn.Header>
                        <DataGridTemplateColumn.CellTemplate>
                            <DataTemplate>
                                <TextBlock
                                    VerticalAlignment="Center"
                                    FontFamily="{StaticResource Font.Family.Base}"
                                    Foreground="{DynamicResource AppTextSecondary}"
                                    Text="{Binding OriginalAmount, Converter={StaticResource CurrencyConverter}, ConverterParameter=amount-dash}"
                                    TextAlignment="Right"
                                    Typography.NumeralAlignment="Tabular" />
                            </DataTemplate>
                        </DataGridTemplateColumn.CellTemplate>
                    </DataGridTemplateColumn>

                    <!--
                        月付（NextPaymentAmount） — 下次月本息合計，僅 loan + 已載入 schedule 時有值。
                        信用卡與尚未載 schedule 顯示「—」（dash 由 amount-dash 處理）。
                    -->
                    <DataGridTemplateColumn Width="120" SortMemberPath="NextPaymentAmount">
                        <DataGridTemplateColumn.HeaderStyle>
                            <Style BasedOn="{StaticResource AppDataGridColHeader}" TargetType="DataGridColumnHeader">
                                <Setter Property="HorizontalContentAlignment" Value="Right" />
                            </Style>
                        </DataGridTemplateColumn.HeaderStyle>
                        <DataGridTemplateColumn.Header>
                            <TextBlock Text="{DynamicResource Portfolio.Liability.MonthlyPayment}" />
                        </DataGridTemplateColumn.Header>
                        <DataGridTemplateColumn.CellTemplate>
                            <DataTemplate>
                                <TextBlock
                                    VerticalAlignment="Center"
                                    FontFamily="{StaticResource Font.Family.Base}"
                                    Foreground="{DynamicResource AppTextPrimary}"
                                    Text="{Binding NextPaymentAmount, Converter={StaticResource CurrencyConverter}, ConverterParameter=amount-dash}"
                                    TextAlignment="Right"
                                    Typography.NumeralAlignment="Tabular" />
                            </DataTemplate>
                        </DataGridTemplateColumn.CellTemplate>
                    </DataGridTemplateColumn>

                    <!--  下次到期 MM/dd  -->
                    <DataGridTemplateColumn Width="90">
                        <DataGridTemplateColumn.HeaderStyle>
                            <Style BasedOn="{StaticResource AppDataGridColHeader}" TargetType="DataGridColumnHeader">
                                <Setter Property="HorizontalContentAlignment" Value="Right" />
                            </Style>
                        </DataGridTemplateColumn.HeaderStyle>
                        <DataGridTemplateColumn.Header>
                            <TextBlock Text="{DynamicResource Portfolio.Liability.NextDue}" />
                        </DataGridTemplateColumn.Header>
                        <DataGridTemplateColumn.CellTemplate>
                            <DataTemplate>
                                <TextBlock
                                    VerticalAlignment="Center"
                                    FontFamily="{StaticResource Font.Family.Base}"
                                    Foreground="{DynamicResource AppTextSecondary}"
                                    Text="{Binding NextPaymentDateDisplay}"
                                    TextAlignment="Right"
                                    Typography.NumeralAlignment="Tabular" />
                            </DataTemplate>
                        </DataGridTemplateColumn.CellTemplate>
                    </DataGridTemplateColumn>

                    <!--
                        已繳% — 改成「文字 + mini bar」雙層視覺：bar 用 AppUp 色階填充
                        PaidPercentValue (0–100)，比純文字更直觀看出進度。
                    -->
                    <DataGridTemplateColumn Width="140" SortMemberPath="PaidPercent">
                        <DataGridTemplateColumn.HeaderStyle>
                            <Style BasedOn="{StaticResource AppDataGridColHeader}" TargetType="DataGridColumnHeader">
                                <Setter Property="HorizontalContentAlignment" Value="Right" />
                            </Style>
                        </DataGridTemplateColumn.HeaderStyle>
                        <DataGridTemplateColumn.Header>
                            <TextBlock Text="{DynamicResource Portfolio.Liability.PaidPercent}" />
                        </DataGridTemplateColumn.Header>
                        <DataGridTemplateColumn.CellTemplate>
                            <DataTemplate>
                                <StackPanel Margin="0,0,8,0" VerticalAlignment="Center">
                                    <TextBlock
                                        HorizontalAlignment="Right"
                                        FontFamily="{StaticResource Font.Family.Base}"
                                        FontSize="{StaticResource Font.Size.Sm}"
                                        Foreground="{DynamicResource AppUp}"
                                        Text="{Binding PaidPercentDisplay}"
                                        Typography.NumeralAlignment="Tabular" />
                                    <Grid Height="3" Margin="0,3,0,0">
                                        <Border Background="{DynamicResource AppBorder}" CornerRadius="1.5" />
                                        <Border
                                            HorizontalAlignment="Left"
                                            Background="{DynamicResource AppUp}"
                                            CornerRadius="1.5">
                                            <Border.Width>
                                                <MultiBinding Converter="{StaticResource PercentToWidthConverter}">
                                                    <Binding Path="PaidPercentValue" />
                                                    <Binding Path="ActualWidth" RelativeSource="{RelativeSource AncestorType=Grid}" />
                                                </MultiBinding>
                                            </Border.Width>
                                        </Border>
                                    </Grid>
                                </StackPanel>
                            </DataTemplate>
                        </DataGridTemplateColumn.CellTemplate>
                    </DataGridTemplateColumn>
                </DataGrid.Columns>
            </DataGrid>
        </Grid>

        <!--
            ═══ Row 3: Filter Summary Footer ═══
            篩選作用中才顯示（搜尋有字）。顯示「筆數 / 剩餘總額 / 月付總額」。
        -->
        <!--  永遠顯示總和（搜尋無字時也是「全部」這個篩選結果）  -->
        <Border Grid.Row="3"
                Padding="12,6"
                Background="{DynamicResource AppSurface}"
                BorderBrush="{DynamicResource AppBorder}"
                BorderThickness="0,1,0,0">
            <StackPanel Orientation="Horizontal">
                <StackPanel Margin="0,0,24,0" Orientation="Horizontal">
                    <TextBlock Margin="0,0,6,0" VerticalAlignment="Center"
                               FontSize="{StaticResource Font.Size.Xs}"
                               Foreground="{DynamicResource AppTextMuted}"
                               Text="{DynamicResource Portfolio.Filter.Summary.Count}" />
                    <TextBlock VerticalAlignment="Center"
                               FontFamily="{StaticResource Font.Family.Base}"
                               FontSize="{StaticResource Font.Size.Sm}"
                               FontWeight="SemiBold"
                               Foreground="{DynamicResource AppTextPrimary}"
                               Text="{Binding LiabilitiesFilteredCount, StringFormat={}{0:N0}}"
                               Typography.NumeralAlignment="Tabular" />
                </StackPanel>
                <StackPanel Margin="0,0,24,0" Orientation="Horizontal">
                    <TextBlock Margin="0,0,6,0" VerticalAlignment="Center"
                               FontSize="{StaticResource Font.Size.Xs}"
                               Foreground="{DynamicResource AppTextMuted}"
                               Text="{DynamicResource Portfolio.Filter.Summary.Remaining}" />
                    <TextBlock VerticalAlignment="Center"
                               FontFamily="{StaticResource Font.Family.Base}"
                               FontSize="{StaticResource Font.Size.Sm}"
                               FontWeight="SemiBold"
                               Foreground="{DynamicResource AppDown}"
                               Text="{Binding LiabilitiesFilteredBalance, Converter={StaticResource CurrencyConverter}, ConverterParameter=amount}"
                               Typography.NumeralAlignment="Tabular" />
                </StackPanel>
                <StackPanel Orientation="Horizontal">
                    <TextBlock Margin="0,0,6,0" VerticalAlignment="Center"
                               FontSize="{StaticResource Font.Size.Xs}"
                               Foreground="{DynamicResource AppTextMuted}"
                               Text="{DynamicResource Portfolio.Filter.Summary.MonthlyTotal}" />
                    <TextBlock VerticalAlignment="Center"
                               FontFamily="{StaticResource Font.Family.Base}"
                               FontSize="{StaticResource Font.Size.Sm}"
                               Foreground="{DynamicResource AppTextSecondary}"
                               Text="{Binding LiabilitiesFilteredMonthlyPayment, Converter={StaticResource CurrencyConverter}, ConverterParameter=amount-dash}"
                               Typography.NumeralAlignment="Tabular" />
                </StackPanel>
            </StackPanel>
        </Border>

        <!--
            P4.9i — Liability detail overlay 從 MainWindow shell 搬到 LiabilityTabPanel 內，
            跟 Position 一樣 page-scoped — 切到別 nav 區段時自動隨 panel unload 消失。
            DataContext = PortfolioViewModel (panel root)；HasSelectedLiabilityRow gate
            走 SelectedLiabilityRow，沒選不會渲染。RowSpan=4 覆蓋 panel 全部 4 個 row。
        -->
        <Grid Grid.RowSpan="4" Panel.ZIndex="180" Visibility="{Binding HasSelectedLiabilityRow, Converter={StaticResource BooleanToVisibilityConverter}}">
            <Border behaviors:BackdropClickToCloseBehavior.Command="{Binding CloseLiabilityDetailCommand}" Style="{StaticResource AppDialogOverlayBorder}" />
            <Border
                HorizontalAlignment="Right"
                Background="{DynamicResource AppSurface}"
                BorderBrush="{DynamicResource AppBorder}"
                BorderThickness="1,0,0,0">
                <Border.Width>
                    <!--  P4.9 — Position / Cash / Liability detail panel 統一寬度 `0.55/520/820`  -->
                    <MultiBinding Converter="{StaticResource AdaptivePanelWidthConverter}" ConverterParameter="0.55|520|820">
                        <Binding Path="ActualWidth" RelativeSource="{RelativeSource AncestorType=Window}" />
                        <Binding Path="DataContext.Settings.UiScale" RelativeSource="{RelativeSource AncestorType=Window}" />
                    </MultiBinding>
                </Border.Width>
                <Grid>
                    <Grid.RowDefinitions>
                        <RowDefinition Height="Auto" />
                        <RowDefinition Height="Auto" />
                        <RowDefinition Height="*" />
                        <RowDefinition Height="Auto" />
                    </Grid.RowDefinitions>

                    <Border
                        Grid.Row="0"
                        Padding="16,14"
                        BorderBrush="{DynamicResource AppBorder}"
                        BorderThickness="0,0,0,1">
                        <StackPanel>
                        <DockPanel LastChildFill="True">
                            <!--  Close  -->
                            <Button
                                Width="30"
                                Height="36"
                                Margin="6,0,0,0"
                                Padding="0"
                                VerticalAlignment="Center"
                                Command="{Binding CloseLiabilityDetailCommand}"
                                DockPanel.Dock="Right"
                                Style="{StaticResource AppIconButton}"
                                ToolTip="{DynamicResource Common.Close}">
                                <ds:AppIcon
                                    FontSize="11"
                                    Foreground="{DynamicResource AppTextSecondary}"
                                    Symbol="Dismiss24" />
                            </Button>
                            <!--
                                Edit pencil — same icon-only pattern as
                                Cash / Position panels for visual parity.
                                Hidden for legacy label-only liabilities
                                (AssetId == null) since they have no
                                AssetItem to edit.
                            -->
                            <Button
                                Width="30"
                                Height="36"
                                Padding="0"
                                VerticalAlignment="Center"
                                Command="{Binding OpenEditLiabilityCommand}"
                                CommandParameter="{Binding SelectedLiabilityRow}"
                                DockPanel.Dock="Right"
                                Style="{StaticResource AppIconButton}"
                                ToolTip="{DynamicResource Common.Edit}"
                                Visibility="{Binding SelectedLiabilityRow.AssetId, Converter={StaticResource NullToVisibilityConverter}, FallbackValue=Collapsed}">
                                <ds:AppIcon
                                    FontSize="12"
                                    Foreground="{DynamicResource AppTextPrimary}"
                                    Symbol="Edit24" />
                            </Button>
                            <TextBlock
                                VerticalAlignment="Center"
                                FontSize="{StaticResource Font.Size.Lg}"
                                FontWeight="SemiBold"
                                Foreground="{DynamicResource AppTextPrimary}"
                                Text="{Binding SelectedLiabilityRow.Name, FallbackValue=''}"
                                TextTrimming="CharacterEllipsis" />
                        </DockPanel>
                        <!--  P4.9e — subtitle + currency chip 對齊 Position / Cash header  -->
                        <StackPanel>
                            <TextBlock
                                Margin="0,8,0,8"
                                FontSize="{StaticResource Font.Size.Xs}"
                                Foreground="{DynamicResource AppTextMuted}"
                                Text="{DynamicResource Portfolio.Detail.Liability.Subtitle}" />
                            <StackPanel Orientation="Horizontal">
                                <Border Padding="8,2" CornerRadius="{StaticResource Radius.Sm}">
                                    <Border.Style>
                                        <Style TargetType="Border">
                                            <Setter Property="Background" Value="{DynamicResource Brush.Neutral}" />
                                            <Style.Triggers>
                                                <DataTrigger Binding="{Binding SelectedLiabilityRow.Currency, FallbackValue=''}" Value="USD">
                                                    <Setter Property="Background" Value="{DynamicResource Brush.Special}" />
                                                </DataTrigger>
                                            </Style.Triggers>
                                        </Style>
                                    </Border.Style>
                                    <TextBlock
                                        FontSize="{StaticResource Font.Size.Xs}"
                                        FontWeight="SemiBold"
                                        Foreground="{DynamicResource AppTextOnAccent}"
                                        Text="{Binding SelectedLiabilityRow.Currency, FallbackValue='TWD'}" />
                                </Border>
                            </StackPanel>
                        </StackPanel>
                        </StackPanel>
                    </Border>

                    <!--  Tab bar — P4.9e DockPanel + pill tab + primary CTA  -->
                    <Border
                        Grid.Row="1"
                        Padding="14,8"
                        BorderBrush="{DynamicResource AppBorder}"
                        BorderThickness="0,0,0,1">
                        <DockPanel LastChildFill="True">
                            <Button
                                Height="32"
                                MinWidth="120"
                                Padding="14,0"
                                Click="AddMenuButton_Click"
                                DockPanel.Dock="Right"
                                Style="{StaticResource AppPrimaryButton}"
                                TextElement.Foreground="{DynamicResource Brush.Text.OnAccent}">
                                <StackPanel Orientation="Horizontal" TextElement.Foreground="{DynamicResource Brush.Text.OnAccent}">
                                    <ds:AppIcon
                                        Margin="0,0,6,0"
                                        VerticalAlignment="Center"
                                        FontSize="10"
                                        Foreground="{DynamicResource Brush.Text.OnAccent}"
                                        Symbol="Add24" />
                                    <TextBlock
                                        VerticalAlignment="Center"
                                        FontSize="{StaticResource Font.Size.Sm}"
                                        Foreground="{DynamicResource Brush.Text.OnAccent}"
                                        Text="{DynamicResource Portfolio.Detail.AddRecord}" />
                                </StackPanel>
                                <Button.ContextMenu>
                                    <ContextMenu>
                                        <!--  Loan：借款 / 還款  -->
                                        <MenuItem
                                            Command="{Binding BeginTxForSelectedLiabilityCommand}"
                                            CommandParameter="loanBorrow"
                                            Header="{DynamicResource Portfolio.Detail.Liability.Action.LoanBorrow}"
                                            Visibility="{Binding SelectedLiabilityRow.IsLoan, Converter={StaticResource BooleanToVisibilityConverter}, FallbackValue=Collapsed}" />
                                        <MenuItem
                                            Command="{Binding BeginTxForSelectedLiabilityCommand}"
                                            CommandParameter="loanRepay"
                                            Header="{DynamicResource Portfolio.Detail.Liability.Action.LoanRepay}"
                                            Visibility="{Binding SelectedLiabilityRow.IsLoan, Converter={StaticResource BooleanToVisibilityConverter}, FallbackValue=Collapsed}" />
                                    </ContextMenu>
                                </Button.ContextMenu>
                            </Button>
                            <StackPanel Orientation="Horizontal">
                                <RadioButton
                                    Command="{Binding SwitchDetailTabCommand}"
                                    CommandParameter="overview"
                                    Content="{DynamicResource Portfolio.Detail.Overview}"
                                    GroupName="LiabilityDetailTab"
                                    IsChecked="{Binding IsDetailOverviewTab, Mode=OneWay}"
                                    Style="{StaticResource AppPillTab}" />
                                <RadioButton
                                    Command="{Binding SwitchDetailTabCommand}"
                                    CommandParameter="trades"
                                    Content="{DynamicResource Portfolio.Detail.Trades}"
                                    GroupName="LiabilityDetailTab"
                                    IsChecked="{Binding IsDetailTradesTab, Mode=OneWay}"
                                    Style="{StaticResource AppPillTab}" />
                                <RadioButton
                                    Command="{Binding SwitchDetailTabCommand}"
                                    CommandParameter="schedule"
                                    Content="{DynamicResource Portfolio.Loan.Schedule}"
                                    GroupName="LiabilityDetailTab"
                                    IsChecked="{Binding IsDetailScheduleTab, Mode=OneWay}"
                                    Style="{StaticResource AppPillTab}"
                                    Visibility="{Binding SelectedLiabilityRow.IsLoan, Converter={StaticResource BooleanToVisibilityConverter}, FallbackValue=Collapsed}" />
                            </StackPanel>
                        </DockPanel>
                    </Border>

                    <ScrollViewer Grid.Row="2" VerticalScrollBarVisibility="Auto">
                        <Grid>
                            <StackPanel Margin="16,16,16,12" Visibility="{Binding IsDetailOverviewTab, Converter={StaticResource BooleanToVisibilityConverter}}">
                                <StackPanel>
                                    <!--  Two stat cards: 總借款 + 剩餘債務 (with paid progress)  -->
                                    <Grid>
                                        <Grid.ColumnDefinitions>
                                            <ColumnDefinition Width="*" />
                                            <ColumnDefinition Width="10" />
                                            <ColumnDefinition Width="*" />
                                        </Grid.ColumnDefinitions>

                                        <!--  Left: 總借款 (sum of LoanBorrow trades — what was actually borrowed)  -->
                                        <Border
                                            Grid.Column="0"
                                            Padding="14,12"
                                            Background="{DynamicResource AppBackground}"
                                            BorderBrush="{DynamicResource AppBorder}"
                                            BorderThickness="1"
                                            CornerRadius="{StaticResource Radius.Sm}">
                                            <StackPanel>
                                                <TextBlock
                                                    FontSize="{StaticResource Font.Size.Xs}"
                                                    Foreground="{DynamicResource AppTextSecondary}"
                                                    Text="{DynamicResource Portfolio.Detail.TotalBorrows}" />
                                                <TextBlock
                                                    Margin="0,6,0,0"
                                                    FontFamily="{StaticResource Font.Family.Base}"
                                                    FontSize="{StaticResource Font.Size.Xl}"
                                                    FontWeight="SemiBold"
                                                    Foreground="{DynamicResource AppTextPrimary}"
                                                    Text="{Binding SelectedLiabilityTotalBorrows, Converter={StaticResource CurrencyConverter}, ConverterParameter=amount}"
                                                    Typography.NumeralAlignment="Tabular" />
                                            </StackPanel>
                                        </Border>

                                        <!--  Right: 貸款顯示本金餘額；信用卡顯示剩餘債務  -->
                                        <Border
                                            Grid.Column="2"
                                            Padding="14,12"
                                            Background="{DynamicResource AppBackground}"
                                            BorderBrush="{DynamicResource AppBorder}"
                                            BorderThickness="1"
                                            CornerRadius="{StaticResource Radius.Sm}">
                                            <StackPanel>
                                                <TextBlock
                                                    FontSize="{StaticResource Font.Size.Xs}"
                                                    Foreground="{DynamicResource AppTextSecondary}">
                                                    <TextBlock.Style>
                                                        <Style TargetType="TextBlock">
                                                            <Setter Property="Text" Value="{DynamicResource Portfolio.Detail.RemainingDebt}" />
                                                            <Style.Triggers>
                                                                <DataTrigger Binding="{Binding SelectedLiabilityRow.IsLoan, FallbackValue=False}" Value="True">
                                                                    <Setter Property="Text" Value="{DynamicResource Portfolio.Detail.PrincipalBalance}" />
                                                                </DataTrigger>
                                                            </Style.Triggers>
                                                        </Style>
                                                    </TextBlock.Style>
                                                </TextBlock>
                                                <TextBlock
                                                    Margin="0,6,0,10"
                                                    FontFamily="{StaticResource Font.Family.Base}"
                                                    FontSize="{StaticResource Font.Size.Xl}"
                                                    FontWeight="SemiBold"
                                                    Foreground="{DynamicResource AppDown}"
                                                    Text="{Binding SelectedLiabilityRow.Balance, Converter={StaticResource CurrencyConverter}, ConverterParameter=amount, FallbackValue=''}"
                                                    Typography.NumeralAlignment="Tabular" />
                                                <Grid Margin="0,0,0,4">
                                                    <Border
                                                        Height="6"
                                                        Background="{DynamicResource AppBorder}"
                                                        CornerRadius="{StaticResource Radius.Sm}" />
                                                    <Border
                                                        Height="6"
                                                        HorizontalAlignment="Left"
                                                        Background="{DynamicResource AppUp}"
                                                        CornerRadius="{StaticResource Radius.Sm}">
                                                        <Border.Width>
                                                            <MultiBinding Converter="{StaticResource PercentToWidthConverter}">
                                                                <Binding FallbackValue="0" Path="SelectedLiabilityRow.PaidPercent" />
                                                                <Binding Path="ActualWidth" RelativeSource="{RelativeSource AncestorType=Grid}" />
                                                            </MultiBinding>
                                                        </Border.Width>
                                                    </Border>
                                                </Grid>
                                                <TextBlock
                                                    HorizontalAlignment="Right"
                                                    FontFamily="{StaticResource Font.Family.Base}"
                                                    FontSize="{StaticResource Font.Size.Xs}"
                                                    Foreground="{DynamicResource AppTextMuted}"
                                                    Text="{Binding SelectedLiabilityRow.PaidPercentDisplay, FallbackValue=''}"
                                                    Typography.NumeralAlignment="Tabular" />
                                            </StackPanel>
                                        </Border>
                                    </Grid>
                                </StackPanel>
                            </StackPanel>

                            <!--
                                Liability trades tab — P4.9b 對齊 Position / Cash table-style：
                                4 欄 (日期 / 類型 / 價值 / Edit)。沿用 CashAmount + signed-dash
                                保留既有顯示語意（不換成 TotalAmount，避免 sign 變動需逐筆驗證）。
                            -->
                            <Grid Margin="16,12" Visibility="{Binding IsDetailTradesTab, Converter={StaticResource BooleanToVisibilityConverter}}">
                                <Grid.RowDefinitions>
                                    <RowDefinition Height="Auto" />
                                    <RowDefinition Height="*" />
                                </Grid.RowDefinitions>

                                <!--  Column header — P4.9c Note 欄移除  -->
                                <Border
                                    Grid.Row="0"
                                    Padding="0,0,0,8"
                                    BorderBrush="{DynamicResource AppBorder}"
                                    BorderThickness="0,0,0,1">
                                    <Grid>
                                        <Grid.ColumnDefinitions>
                                            <ColumnDefinition Width="92" />
                                            <ColumnDefinition Width="80" />
                                            <ColumnDefinition Width="*" />
                                        </Grid.ColumnDefinitions>
                                        <TextBlock
                                            Grid.Column="0"
                                            FontSize="{StaticResource Font.Size.Xs}"
                                            Foreground="{DynamicResource AppTextSecondary}"
                                            Text="{DynamicResource Portfolio.TradeHistory.Date}" />
                                        <TextBlock
                                            Grid.Column="1"
                                            FontSize="{StaticResource Font.Size.Xs}"
                                            Foreground="{DynamicResource AppTextSecondary}"
                                            Text="{DynamicResource Portfolio.TradeHistory.Type}" />
                                        <TextBlock
                                            Grid.Column="2"
                                            HorizontalAlignment="Right"
                                            FontSize="{StaticResource Font.Size.Xs}"
                                            Foreground="{DynamicResource AppTextSecondary}"
                                            Text="{DynamicResource Portfolio.TradeHistory.GrossAmount}" />
                                    </Grid>
                                </Border>

                                <TextBlock
                                    Grid.Row="1"
                                    Margin="0,24,0,0"
                                    HorizontalAlignment="Center"
                                    VerticalAlignment="Top"
                                    FontSize="{StaticResource Font.Size.Sm}"
                                    Foreground="{DynamicResource AppTextMuted}"
                                    Text="{DynamicResource Portfolio.Detail.NoTrades}">
                                    <TextBlock.Style>
                                        <Style TargetType="TextBlock">
                                            <Setter Property="Visibility" Value="Collapsed" />
                                            <Style.Triggers>
                                                <DataTrigger Binding="{Binding SelectedLiabilityTrades.Count, FallbackValue=0}" Value="0">
                                                    <Setter Property="Visibility" Value="Visible" />
                                                </DataTrigger>
                                            </Style.Triggers>
                                        </Style>
                                    </TextBlock.Style>
                                </TextBlock>

                                <ItemsControl Grid.Row="1" ItemsSource="{Binding SelectedLiabilityTrades}">
                                    <ItemsControl.ItemTemplate>
                                        <DataTemplate>
                                            <Border
                                                Padding="6,10"
                                                BorderThickness="0,0,0,1"
                                                Cursor="Hand"
                                                ToolTip="{Binding Note}">
                                                <Border.Style>
                                                    <Style TargetType="Border">
                                                        <Setter Property="BorderBrush" Value="{DynamicResource AppBorderLight}" />
                                                        <Setter Property="Background" Value="Transparent" />
                                                        <Style.Triggers>
                                                            <Trigger Property="IsMouseOver" Value="True">
                                                                <Setter Property="Background" Value="{DynamicResource AppHover}" />
                                                            </Trigger>
                                                        </Style.Triggers>
                                                    </Style>
                                                </Border.Style>
                                                <Border.InputBindings>
                                                    <MouseBinding
                                                        Command="{Binding DataContext.Transaction.EditTradeCommand, RelativeSource={RelativeSource AncestorType=ItemsControl}}"
                                                        CommandParameter="{Binding}"
                                                        MouseAction="LeftClick" />
                                                </Border.InputBindings>
                                                <Grid>
                                                    <Grid.ColumnDefinitions>
                                                        <ColumnDefinition Width="92" />
                                                        <ColumnDefinition Width="80" />
                                                        <ColumnDefinition Width="*" />
                                                    </Grid.ColumnDefinitions>
                                                    <!--  日期  -->
                                                    <TextBlock
                                                        Grid.Column="0"
                                                        VerticalAlignment="Center"
                                                        FontFamily="{StaticResource Font.Family.Base}"
                                                        FontSize="{StaticResource Font.Size.Sm}"
                                                        Foreground="{DynamicResource AppTextPrimary}"
                                                        Text="{Binding TradeDateLocal, StringFormat=yyyy-MM-dd}"
                                                        Typography.NumeralAlignment="Tabular" />
                                                    <!--  類型 badge  -->
                                                    <Border
                                                        Grid.Column="1"
                                                        Padding="6,2"
                                                        HorizontalAlignment="Left"
                                                        VerticalAlignment="Center"
                                                        Background="{Binding TypeBadgeColor, Converter={StaticResource HexToBrushConverter}}"
                                                        CornerRadius="{StaticResource Radius.Sm}">
                                                        <TextBlock
                                                            FontSize="{StaticResource Font.Size.Xs}"
                                                            FontWeight="SemiBold"
                                                            Foreground="{DynamicResource AppTextOnAccent}"
                                                            Text="{Binding Type, Converter={StaticResource TradeTypeConverter}}" />
                                                    </Border>
                                                    <!--  價值 (沿用 CashAmount + signed-dash 既有語意)  -->
                                                    <TextBlock
                                                        Grid.Column="2"
                                                        HorizontalAlignment="Right"
                                                        VerticalAlignment="Center"
                                                        FontFamily="{StaticResource Font.Family.Base}"
                                                        FontSize="{StaticResource Font.Size.Sm}"
                                                        FontWeight="SemiBold"
                                                        Foreground="{DynamicResource AppTextPrimary}"
                                                        Text="{Binding CashAmount, Converter={StaticResource CurrencyConverter}, ConverterParameter=signed-dash}"
                                                        Typography.NumeralAlignment="Tabular" />
                                                </Grid>
                                            </Border>
                                        </DataTemplate>
                                    </ItemsControl.ItemTemplate>
                                </ItemsControl>
                            </Grid>

                            <!--  ── 攤還表 tab ──  -->
                            <StackPanel Margin="16,12,16,16" Visibility="{Binding IsDetailScheduleTab, Converter={StaticResource BooleanToVisibilityConverter}}">

                                <!--  Loan metadata  -->
                                <DockPanel Margin="0,0,0,8">
                                    <TextBlock
                                        VerticalAlignment="Center"
                                        FontSize="{StaticResource Font.Size.Xs}"
                                        Foreground="{DynamicResource AppTextMuted}">
                                        <Run Text="{DynamicResource Portfolio.Loan.Rate}" />
                                        <Run Text=":" />
                                        <Run
                                            FontFamily="{StaticResource Font.Family.Base}"
                                            Text="{Binding SelectedLiabilityRow.RateDisplay, FallbackValue='—', Mode=OneWay}"
                                            Typography.NumeralAlignment="Tabular" />
                                        <Run Text="  " />
                                        <Run Text="{DynamicResource Portfolio.Loan.Term}" />
                                        <Run Text=":" />
                                        <Run
                                            FontFamily="{StaticResource Font.Family.Base}"
                                            Text="{Binding SelectedLiabilityRow.TermDisplay, FallbackValue='—', Mode=OneWay}"
                                            Typography.NumeralAlignment="Tabular" />
                                    </TextBlock>
                                </DockPanel>

                                <!--  3 summary cards  -->
                                <WrapPanel Margin="0,0,0,14" ItemWidth="152">
                                    <Border
                                        Margin="0,0,12,12"
                                        Padding="12,10"
                                        Background="{DynamicResource AppBackground}"
                                        BorderBrush="{DynamicResource AppBorder}"
                                        BorderThickness="1"
                                        CornerRadius="{StaticResource Radius.Sm}">
                                        <StackPanel>
                                            <TextBlock
                                                FontSize="{StaticResource Font.Size.Xs}"
                                                Foreground="{DynamicResource AppTextSecondary}"
                                                Text="{DynamicResource Portfolio.Loan.PaidPrincipal}" />
                                            <TextBlock
                                                Margin="0,4,0,0"
                                                FontFamily="{StaticResource Font.Family.Base}"
                                                FontSize="{StaticResource Font.Size.Sm}"
                                                FontWeight="SemiBold"
                                                Foreground="{DynamicResource AppUp}"
                                                Text="{Binding SelectedLiabilityRow.PaidPrincipal, Converter={StaticResource CurrencyConverter}, ConverterParameter=amount, FallbackValue='—'}"
                                                Typography.NumeralAlignment="Tabular" />
                                        </StackPanel>
                                    </Border>
                                    <Border
                                        Margin="0,0,12,12"
                                        Padding="12,10"
                                        Background="{DynamicResource AppBackground}"
                                        BorderBrush="{DynamicResource AppBorder}"
                                        BorderThickness="1"
                                        CornerRadius="{StaticResource Radius.Sm}">
                                        <StackPanel>
                                            <TextBlock
                                                FontSize="{StaticResource Font.Size.Xs}"
                                                Foreground="{DynamicResource AppTextSecondary}"
                                                Text="{DynamicResource Portfolio.Loan.PaidInterest}" />
                                            <TextBlock
                                                Margin="0,4,0,0"
                                                FontFamily="{StaticResource Font.Family.Base}"
                                                FontSize="{StaticResource Font.Size.Sm}"
                                                FontWeight="SemiBold"
                                                Foreground="{DynamicResource AppTextPrimary}"
                                                Text="{Binding SelectedLiabilityRow.PaidInterest, Converter={StaticResource CurrencyConverter}, ConverterParameter=amount, FallbackValue='—'}"
                                                Typography.NumeralAlignment="Tabular" />
                                        </StackPanel>
                                    </Border>
                                    <Border
                                        Margin="0,0,12,12"
                                        Padding="12,10"
                                        Background="{DynamicResource AppBackground}"
                                        BorderBrush="{DynamicResource AppBorder}"
                                        BorderThickness="1"
                                        CornerRadius="{StaticResource Radius.Sm}">
                                        <StackPanel>
                                            <TextBlock
                                                FontSize="{StaticResource Font.Size.Xs}"
                                                Foreground="{DynamicResource AppTextSecondary}"
                                                Text="{DynamicResource Portfolio.Loan.RemainingBalance}" />
                                            <TextBlock
                                                Margin="0,4,0,0"
                                                FontFamily="{StaticResource Font.Family.Base}"
                                                FontSize="{StaticResource Font.Size.Sm}"
                                                FontWeight="SemiBold"
                                                Foreground="{DynamicResource AppDown}"
                                                Text="{Binding SelectedLiabilityRow.RemainingFromSchedule, Converter={StaticResource CurrencyConverter}, ConverterParameter=amount, FallbackValue='—'}"
                                                Typography.NumeralAlignment="Tabular" />
                                        </StackPanel>
                                    </Border>
                                </WrapPanel>

                                <!--  Empty state  -->
                                <TextBlock
                                    Margin="0,16,0,0"
                                    HorizontalAlignment="Center"
                                    FontSize="{StaticResource Font.Size.Sm}"
                                    Foreground="{DynamicResource AppTextMuted}"
                                    Text="{DynamicResource Portfolio.Loan.NoSchedule}">
                                    <TextBlock.Style>
                                        <Style TargetType="TextBlock">
                                            <Setter Property="Visibility" Value="Collapsed" />
                                            <Style.Triggers>
                                                <DataTrigger Binding="{Binding SelectedLiabilityRow.HasSchedule, FallbackValue=False}" Value="False">
                                                    <Setter Property="Visibility" Value="Visible" />
                                                </DataTrigger>
                                            </Style.Triggers>
                                        </Style>
                                    </TextBlock.Style>
                                </TextBlock>

                                <ItemsControl ItemsSource="{Binding SelectedLiabilityRow.ScheduleEntries}" Visibility="{Binding SelectedLiabilityRow.HasSchedule, Converter={StaticResource BooleanToVisibilityConverter}, FallbackValue=Collapsed}">
                                    <ItemsControl.ItemTemplate>
                                        <DataTemplate>
                                            <Border Margin="0,0,0,10" Padding="12">
                                                <Border.Style>
                                                    <Style BasedOn="{StaticResource FormCard}" TargetType="{x:Type Border}">
                                                        <Setter Property="Opacity" Value="1" />
                                                        <Style.Triggers>
                                                            <DataTrigger Binding="{Binding IsPaid}" Value="True">
                                                                <Setter Property="Opacity" Value="0.55" />
                                                            </DataTrigger>
                                                        </Style.Triggers>
                                                    </Style>
                                                </Border.Style>
                                                <StackPanel>
                                                    <DockPanel LastChildFill="True">
                                                        <Border
                                                            Margin="0,0,10,0"
                                                            Padding="8,3"
                                                            Background="{DynamicResource AppBackground}"
                                                            BorderBrush="{DynamicResource AppBorder}"
                                                            BorderThickness="1"
                                                            CornerRadius="{StaticResource Radius.Sm}"
                                                            DockPanel.Dock="Left">
                                                            <TextBlock
                                                                FontFamily="{StaticResource Font.Family.Base}"
                                                                FontSize="{StaticResource Font.Size.Xs}"
                                                                FontWeight="SemiBold"
                                                                Foreground="{DynamicResource AppTextPrimary}"
                                                                Text="{Binding Period, StringFormat={}{0:00}}"
                                                                Typography.NumeralAlignment="Tabular" />
                                                        </Border>
                                                        <TextBlock
                                                            DockPanel.Dock="Right"
                                                            FontFamily="{StaticResource Font.Family.Base}"
                                                            FontSize="{StaticResource Font.Size.Xs}"
                                                            Foreground="{DynamicResource AppTextMuted}"
                                                            Text="{Binding DueDateDisplay}"
                                                            Typography.NumeralAlignment="Tabular" />
                                                        <TextBlock
                                                            FontSize="{StaticResource Font.Size.Sm}"
                                                            FontWeight="SemiBold"
                                                            Foreground="{DynamicResource AppTextPrimary}">
                                                            <TextBlock.Style>
                                                                <Style TargetType="TextBlock">
                                                                    <Setter Property="Text" Value="{DynamicResource Portfolio.Loan.PaymentPending}" />
                                                                    <Style.Triggers>
                                                                        <DataTrigger Binding="{Binding IsPaid}" Value="True">
                                                                            <Setter Property="Text" Value="{DynamicResource Portfolio.Loan.PaymentConfirmed}" />
                                                                        </DataTrigger>
                                                                    </Style.Triggers>
                                                                </Style>
                                                            </TextBlock.Style>
                                                        </TextBlock>
                                                    </DockPanel>

                                                    <WrapPanel Margin="0,8,0,0">
                                                        <StackPanel Margin="0,0,20,4">
                                                            <TextBlock
                                                                FontSize="{StaticResource Font.Size.Xs}"
                                                                Foreground="{DynamicResource AppTextSecondary}"
                                                                Text="{DynamicResource Portfolio.Loan.Principal}" />
                                                            <TextBlock
                                                                Margin="0,2,0,0"
                                                                FontFamily="{StaticResource Font.Family.Base}"
                                                                FontSize="{StaticResource Font.Size.Sm}"
                                                                FontWeight="SemiBold"
                                                                Foreground="{DynamicResource AppTextPrimary}"
                                                                Text="{Binding PrincipalAmount, Converter={StaticResource CurrencyConverter}, ConverterParameter=amount}"
                                                                Typography.NumeralAlignment="Tabular" />
                                                        </StackPanel>
                                                        <StackPanel Margin="0,0,20,4">
                                                            <TextBlock
                                                                FontSize="{StaticResource Font.Size.Xs}"
                                                                Foreground="{DynamicResource AppTextSecondary}"
                                                                Text="{DynamicResource Portfolio.Loan.Interest}" />
                                                            <TextBlock
                                                                Margin="0,2,0,0"
                                                                FontFamily="{StaticResource Font.Family.Base}"
                                                                FontSize="{StaticResource Font.Size.Sm}"
                                                                FontWeight="SemiBold"
                                                                Foreground="{DynamicResource AppTextPrimary}"
                                                                Text="{Binding InterestAmount, Converter={StaticResource CurrencyConverter}, ConverterParameter=amount}"
                                                                Typography.NumeralAlignment="Tabular" />
                                                        </StackPanel>
                                                        <StackPanel Margin="0,0,20,4">
                                                            <TextBlock
                                                                FontSize="{StaticResource Font.Size.Xs}"
                                                                Foreground="{DynamicResource AppTextSecondary}"
                                                                Text="{DynamicResource Portfolio.Loan.PaymentAmount}" />
                                                            <TextBlock
                                                                Margin="0,2,0,0"
                                                                FontFamily="{StaticResource Font.Family.Base}"
                                                                FontSize="{StaticResource Font.Size.Sm}"
                                                                FontWeight="SemiBold"
                                                                Foreground="{DynamicResource AppTextPrimary}"
                                                                Text="{Binding TotalAmount, Converter={StaticResource CurrencyConverter}, ConverterParameter=amount}"
                                                                Typography.NumeralAlignment="Tabular" />
                                                        </StackPanel>
                                                    </WrapPanel>

                                                    <Button
                                                        Height="28"
                                                        Margin="0,2,0,0"
                                                        Padding="10,0"
                                                        HorizontalAlignment="Left"
                                                        Command="{Binding DataContext.Loan.ConfirmLoanPaymentCommand, RelativeSource={RelativeSource AncestorType=ItemsControl}}"
                                                        CommandParameter="{Binding}">
                                                        <Button.Style>
                                                            <Style BasedOn="{StaticResource AppPrimaryButton}" TargetType="{x:Type Button}">
                                                                <Setter Property="Visibility" Value="Visible" />
                                                                <Style.Triggers>
                                                                    <DataTrigger Binding="{Binding IsPaid}" Value="True">
                                                                        <Setter Property="Visibility" Value="Collapsed" />
                                                                    </DataTrigger>
                                                                </Style.Triggers>
                                                            </Style>
                                                        </Button.Style>
                                                        <TextBlock
                                                            FontSize="{StaticResource Font.Size.Xs}"
                                                            Foreground="{Binding Foreground, RelativeSource={RelativeSource AncestorType=Button}}"
                                                            Text="{DynamicResource Portfolio.Loan.ConfirmPayment}" />
                                                    </Button>
                                                </StackPanel>
                                            </Border>
                                        </DataTemplate>
                                    </ItemsControl.ItemTemplate>
                                </ItemsControl>
                            </StackPanel>

                        </Grid>
                    </ScrollViewer>

                    <!--  Danger zone  -->
                    <Border
                        Grid.Row="3"
                        Margin="16,0,16,16"
                        Padding="14,12"
                        Background="{DynamicResource AppBackground}"
                        BorderBrush="{DynamicResource AppDanger}"
                        BorderThickness="1"
                        CornerRadius="{StaticResource Radius.Sm}">
                        <Grid>
                            <Grid.ColumnDefinitions>
                                <ColumnDefinition Width="*" />
                                <ColumnDefinition Width="Auto" />
                            </Grid.ColumnDefinitions>
                            <StackPanel Grid.Column="0" VerticalAlignment="Center">
                                <StackPanel Margin="0,0,0,2" Orientation="Horizontal">
                                    <ds:AppIcon
                                        Margin="0,0,6,0"
                                        VerticalAlignment="Center"
                                        FontSize="11"
                                        Foreground="{DynamicResource AppDanger}"
                                        Symbol="Delete24" />
                                    <TextBlock
                                        FontSize="{StaticResource Font.Size.Xs}"
                                        FontWeight="SemiBold"
                                        Foreground="{DynamicResource AppDanger}"
                                        Text="{DynamicResource Portfolio.Detail.DeleteLiability}" />
                                </StackPanel>
                                <TextBlock
                                    FontSize="{StaticResource Font.Size.Xs}"
                                    Foreground="{DynamicResource AppTextSecondary}"
                                    Text="{DynamicResource Portfolio.Detail.DeleteWarning}"
                                    TextWrapping="Wrap" />
                            </StackPanel>
                            <Button
                                Grid.Column="1"
                                Height="32"
                                Margin="12,0,0,0"
                                Padding="14,0"
                                VerticalAlignment="Center"
                                Command="{Binding RemoveLiabilityCommand}"
                                CommandParameter="{Binding SelectedLiabilityRow}"
                                Style="{StaticResource AppDangerButton}">
                                <TextBlock
                                    FontSize="{StaticResource Font.Size.Xs}"
                                    Foreground="{Binding Foreground, RelativeSource={RelativeSource AncestorType=Button}}"
                                    Text="{DynamicResource Portfolio.Detail.DeleteLiability}" />
                            </Button>
                        </Grid>
                    </Border>

                </Grid>
            </Border>
        </Grid>
    </Grid>
</UserControl>
