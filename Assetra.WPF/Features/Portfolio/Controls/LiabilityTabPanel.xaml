<UserControl
    x:Class="Assetra.WPF.Features.Portfolio.Controls.LiabilityTabPanel"
    xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
    xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
    xmlns:controls="clr-namespace:Assetra.WPF.Controls"
    xmlns:conv="clr-namespace:Assetra.WPF.Infrastructure.Converters"
    xmlns:d="http://schemas.microsoft.com/expression/blend/2008"
    xmlns:mc="http://schemas.openxmlformats.org/markup-compatibility/2006"
    xmlns:vm="clr-namespace:Assetra.WPF.Features.Portfolio"
    d:DataContext="{d:DesignInstance Type={x:Type vm:PortfolioViewModel},
                                     IsDesignTimeCreatable=False}"
    mc:Ignorable="d">

    <UserControl.Resources>
        <conv:PercentToWidthConverter x:Key="PercentToWidthConverter" />
        <conv:StatusTagToBrushConverter x:Key="StatusTagToBrush" />
    </UserControl.Resources>

    <Grid>
        <Grid.RowDefinitions>
            <RowDefinition Height="Auto" />
            <RowDefinition Height="Auto" />
            <RowDefinition Height="*" />
        </Grid.RowDefinitions>

        <!--  ═══ Row 0: Debt Health Summary ═══  -->
        <Border
            Grid.Row="0"
            Padding="16,12"
            Background="{DynamicResource AppSurface}"
            BorderBrush="{DynamicResource AppBorder}"
            BorderThickness="0,0,0,1">
            <WrapPanel
                Margin="0,0,0,2"
                ItemHeight="Auto"
                ItemWidth="372">

                <!--  Left: Remaining + paid progress  -->
                <Border
                    Margin="0,0,12,12"
                    Padding="18,16"
                    Background="{DynamicResource AppBackground}"
                    BorderBrush="{DynamicResource AppBorder}"
                    BorderThickness="1"
                    CornerRadius="{StaticResource RadiusSm}">
                    <StackPanel>
                        <TextBlock
                            Margin="0,0,0,8"
                            FontSize="{StaticResource FontSizeXs}"
                            Foreground="{DynamicResource AppTextMuted}"
                            Text="{DynamicResource Portfolio.Liability.TotalRemaining}" />
                        <TextBlock
                            Margin="0,0,0,16"
                            FontFamily="{StaticResource FontTabular}"
                            FontSize="{StaticResource FontSizeXl}"
                            FontWeight="Bold"
                            Foreground="{DynamicResource AppDown}"
                            Text="{Binding TotalLiabilities, Converter={StaticResource CurrencyConverter}, ConverterParameter=amount}" />

                        <Grid Margin="0,0,0,12">
                            <Border
                                Height="7"
                                Background="{DynamicResource AppBorder}"
                                CornerRadius="{StaticResource RadiusSm}" />
                            <Border
                                Height="7"
                                HorizontalAlignment="Left"
                                Background="{DynamicResource AppUp}"
                                CornerRadius="{StaticResource RadiusSm}">
                                <Border.Width>
                                    <MultiBinding Converter="{StaticResource PercentToWidthConverter}">
                                        <Binding Path="PaidPercentValue" />
                                        <Binding Path="ActualWidth" RelativeSource="{RelativeSource AncestorType=Grid}" />
                                    </MultiBinding>
                                </Border.Width>
                            </Border>
                        </Grid>

                        <UniformGrid Columns="2">
                            <Border
                                Margin="0,0,6,0"
                                Padding="10,8"
                                Background="{DynamicResource AppSurface}"
                                BorderBrush="{DynamicResource AppBorder}"
                                BorderThickness="1"
                                CornerRadius="{StaticResource RadiusSm}">
                                <StackPanel>
                                    <TextBlock
                                        FontSize="{StaticResource FontSizeXs}"
                                        Foreground="{DynamicResource AppTextMuted}"
                                        Text="{DynamicResource Portfolio.Liability.PaidPercent}" />
                                    <TextBlock
                                        Margin="0,4,0,0"
                                        FontFamily="{StaticResource FontTabular}"
                                        FontSize="{StaticResource FontSizeBase}"
                                        FontWeight="SemiBold"
                                        Foreground="{DynamicResource AppUp}"
                                        Text="{Binding PaidPercentDisplay, Mode=OneWay}" />
                                </StackPanel>
                            </Border>
                            <Border
                                Margin="6,0,0,0"
                                Padding="10,8"
                                Background="{DynamicResource AppSurface}"
                                BorderBrush="{DynamicResource AppBorder}"
                                BorderThickness="1"
                                CornerRadius="{StaticResource RadiusSm}">
                                <StackPanel>
                                    <TextBlock
                                        FontSize="{StaticResource FontSizeXs}"
                                        Foreground="{DynamicResource AppTextMuted}"
                                        Text="{DynamicResource Portfolio.Liability.TotalLoan}" />
                                    <TextBlock
                                        Margin="0,4,0,0"
                                        FontFamily="{StaticResource FontTabular}"
                                        FontSize="{StaticResource FontSizeBase}"
                                        FontWeight="SemiBold"
                                        Foreground="{DynamicResource AppTextPrimary}"
                                        Text="{Binding TotalOriginalDisplay, Mode=OneWay}" />
                                </StackPanel>
                            </Border>
                        </UniformGrid>
                    </StackPanel>
                </Border>

                <!--  Right: Leverage health  -->
                <Border
                    Margin="0,0,12,12"
                    Padding="18,16"
                    Background="{DynamicResource AppBackground}"
                    BorderBrush="{DynamicResource AppBorder}"
                    BorderThickness="1"
                    CornerRadius="{StaticResource RadiusSm}"
                    ToolTip="{DynamicResource Portfolio.Liability.Health.Tooltip}"
                    ToolTipService.InitialShowDelay="300"
                    ToolTipService.ShowDuration="20000">
                    <StackPanel>
                        <DockPanel Margin="0,0,0,12">
                            <TextBlock
                                VerticalAlignment="Center"
                                FontSize="{StaticResource FontSizeXs}"
                                Foreground="{DynamicResource AppTextMuted}"
                                Text="{DynamicResource Portfolio.Liability.Health.Label}" />
                            <Border
                                Padding="8,2"
                                HorizontalAlignment="Right"
                                Background="{DynamicResource AppSurface}"
                                BorderBrush="{DynamicResource AppBorder}"
                                BorderThickness="1"
                                CornerRadius="{StaticResource RadiusSm}"
                                DockPanel.Dock="Right">
                                <TextBlock
                                    FontSize="{StaticResource FontSizeXs}"
                                    FontWeight="SemiBold"
                                    Foreground="{Binding DebtStatusTag, Converter={StaticResource StatusTagToBrush}}">
                                    <TextBlock.Style>
                                        <Style TargetType="TextBlock">
                                            <Setter Property="Text" Value="{DynamicResource Portfolio.Liability.Health.Healthy}" />
                                            <Style.Triggers>
                                                <DataTrigger Binding="{Binding DebtStatusTag}" Value="warning">
                                                    <Setter Property="Text" Value="{DynamicResource Portfolio.Liability.Health.Warning}" />
                                                </DataTrigger>
                                                <DataTrigger Binding="{Binding DebtStatusTag}" Value="danger">
                                                    <Setter Property="Text" Value="{DynamicResource Portfolio.Liability.Health.Danger}" />
                                                </DataTrigger>
                                            </Style.Triggers>
                                        </Style>
                                    </TextBlock.Style>
                                </TextBlock>
                            </Border>
                        </DockPanel>

                        <UniformGrid Margin="0,0,0,14" Columns="2">
                            <Border
                                Margin="0,0,6,0"
                                Padding="10,8"
                                Background="{DynamicResource AppSurface}"
                                BorderBrush="{DynamicResource AppBorder}"
                                BorderThickness="1"
                                CornerRadius="{StaticResource RadiusSm}">
                                <StackPanel>
                                    <TextBlock
                                        FontSize="{StaticResource FontSizeXs}"
                                        Foreground="{DynamicResource AppTextMuted}"
                                        Text="{DynamicResource Portfolio.Liability.DebtRatio}" />
                                    <TextBlock
                                        Margin="0,4,0,0"
                                        FontFamily="{StaticResource FontTabular}"
                                        FontSize="{StaticResource FontSizeBase}"
                                        FontWeight="SemiBold"
                                        Foreground="{DynamicResource AppTextPrimary}"
                                        Text="{Binding DebtRatioDisplay}" />
                                </StackPanel>
                            </Border>
                            <Border
                                Margin="6,0,0,0"
                                Padding="10,8"
                                Background="{DynamicResource AppSurface}"
                                BorderBrush="{DynamicResource AppBorder}"
                                BorderThickness="1"
                                CornerRadius="{StaticResource RadiusSm}">
                                <StackPanel>
                                    <TextBlock
                                        FontSize="{StaticResource FontSizeXs}"
                                        Foreground="{DynamicResource AppTextMuted}"
                                        Text="{DynamicResource Portfolio.Liability.LeverageRatio}" />
                                    <TextBlock
                                        Margin="0,4,0,0"
                                        FontFamily="{StaticResource FontTabular}"
                                        FontSize="{StaticResource FontSizeBase}"
                                        FontWeight="SemiBold"
                                        Foreground="{DynamicResource AppTextPrimary}"
                                        Text="{Binding LeverageRatioDisplay}" />
                                </StackPanel>
                            </Border>
                        </UniformGrid>

                        <!--  Progress bar with 30% / 50% threshold tick marks  -->
                        <Grid Margin="0,0,0,4">
                            <!--  Background track  -->
                            <Border
                                Height="6"
                                Background="{DynamicResource AppBorder}"
                                CornerRadius="{StaticResource RadiusSm}" />
                            <!--  Filled portion  -->
                            <Border
                                Height="6"
                                HorizontalAlignment="Left"
                                Background="{Binding DebtStatusTag, Converter={StaticResource StatusTagToBrush}}"
                                CornerRadius="{StaticResource RadiusSm}">
                                <Border.Width>
                                    <MultiBinding Converter="{StaticResource PercentToWidthConverter}">
                                        <Binding Path="DebtRatioValue" />
                                        <Binding Path="ActualWidth" RelativeSource="{RelativeSource AncestorType=Grid}" />
                                    </MultiBinding>
                                </Border.Width>
                            </Border>
                            <!--  Tick marks at 30% (right edge of col 0) and 50% (right edge of col 1)  -->
                            <Grid IsHitTestVisible="False">
                                <Grid.ColumnDefinitions>
                                    <ColumnDefinition Width="3*" />
                                    <ColumnDefinition Width="2*" />
                                    <ColumnDefinition Width="5*" />
                                </Grid.ColumnDefinitions>
                                <Border
                                    Grid.Column="0"
                                    Width="1"
                                    Height="10"
                                    HorizontalAlignment="Right"
                                    Background="{DynamicResource AppBackground}" />
                                <Border
                                    Grid.Column="1"
                                    Width="1"
                                    Height="10"
                                    HorizontalAlignment="Right"
                                    Background="{DynamicResource AppBackground}" />
                            </Grid>
                        </Grid>

                        <!--  Threshold labels: 0% | 30% | 50% | 100%  -->
                        <Grid>
                            <Grid.ColumnDefinitions>
                                <ColumnDefinition Width="3*" />
                                <ColumnDefinition Width="2*" />
                                <ColumnDefinition Width="5*" />
                            </Grid.ColumnDefinitions>
                            <TextBlock
                                Grid.Column="0"
                                HorizontalAlignment="Left"
                                FontSize="{StaticResource FontSizeXs}"
                                Foreground="{DynamicResource AppTextMuted}"
                                Text="0%" />
                            <TextBlock
                                Grid.Column="0"
                                HorizontalAlignment="Right"
                                FontSize="{StaticResource FontSizeXs}"
                                Foreground="{DynamicResource AppTextMuted}"
                                Text="30%" />
                            <TextBlock
                                Grid.Column="1"
                                HorizontalAlignment="Right"
                                FontSize="{StaticResource FontSizeXs}"
                                Foreground="{DynamicResource AppTextMuted}"
                                Text="50%" />
                            <TextBlock
                                Grid.Column="2"
                                HorizontalAlignment="Right"
                                FontSize="{StaticResource FontSizeXs}"
                                Foreground="{DynamicResource AppTextMuted}"
                                Text="100%" />
                        </Grid>
                    </StackPanel>
                </Border>
            </WrapPanel>
        </Border>

        <controls:SearchBox
            Grid.Row="1"
            Placeholder="{DynamicResource Portfolio.Filter.SearchLiabilities}"
            Text="{Binding LiabilityFilterText}">
            <controls:SearchBox.RightContent>
                <Button
                    MinHeight="32"
                    Padding="10,0"
                    Command="{Binding OpenAddLiabilityDialogCommand}"
                    Style="{StaticResource BtnGhost}">
                    <StackPanel Orientation="Horizontal">
                        <TextBlock
                            Margin="0,0,6,0"
                            VerticalAlignment="Center"
                            FontFamily="Segoe MDL2 Assets"
                            FontSize="{StaticResource FontSizeXs}"
                            Text="&#xE710;" />
                        <TextBlock VerticalAlignment="Center" Text="{DynamicResource Portfolio.AddLiability}" />
                    </StackPanel>
                </Button>
            </controls:SearchBox.RightContent>
        </controls:SearchBox>

        <!--  ═══ Liabilities DataGrid ═══  -->
        <Grid Grid.Row="2">
            <!--  Empty state  -->
            <Border
                Padding="32"
                Background="{DynamicResource AppBackground}"
                Visibility="{Binding HasNoLiabilities, Converter={StaticResource BooleanToVisibilityConverter}}">
                <StackPanel HorizontalAlignment="Center" VerticalAlignment="Center">
                    <StackPanel HorizontalAlignment="Center" Opacity="0.4">
                        <TextBlock
                            Margin="0,0,0,6"
                            HorizontalAlignment="Center"
                            FontSize="{StaticResource FontSize2xl}"
                            Text="&#x1F4C4;" />
                        <TextBlock
                            HorizontalAlignment="Center"
                            FontSize="{StaticResource FontSizeSm}"
                            Foreground="{DynamicResource AppTextSecondary}"
                            Text="{DynamicResource Portfolio.Liability.Empty}" />
                    </StackPanel>
                    <Button
                        Height="34"
                        Margin="0,16,0,0"
                        Padding="20,0"
                        HorizontalAlignment="Center"
                        Command="{Binding OpenAddLiabilityDialogCommand}"
                        Style="{StaticResource BtnPrimary}">
                        <TextBlock Foreground="{Binding Foreground, RelativeSource={RelativeSource AncestorType=Button}}" Text="{DynamicResource Portfolio.AddLiability}" />
                    </Button>
                </StackPanel>
            </Border>

            <DataGrid
                x:Name="LiabilityGrid"
                AlternationCount="2"
                AutoGenerateColumns="False"
                Background="{DynamicResource AppBackground}"
                BorderThickness="0"
                CanUserAddRows="False"
                CanUserDeleteRows="False"
                CanUserReorderColumns="False"
                CanUserResizeColumns="False"
                CanUserSortColumns="True"
                ColumnHeaderHeight="{StaticResource DataGridHeaderHeight}"
                EnableRowVirtualization="True"
                FontFamily="{StaticResource FontBase}"
                FontSize="{StaticResource FontSizeSm}"
                Foreground="{DynamicResource AppTextPrimary}"
                GridLinesVisibility="None"
                HeadersVisibility="Column"
                HorizontalScrollBarVisibility="Auto"
                IsReadOnly="True"
                ItemsSource="{Binding LiabilitiesView}"
                PreviewMouseDown="OnGridPreviewMouseDown"
                RowHeight="{StaticResource DataGridRowHeight}"
                SelectedItem="{Binding SelectedLiabilityRow, Mode=TwoWay}"
                SelectionMode="Single"
                VirtualizingPanel.IsVirtualizing="True"
                VirtualizingPanel.VirtualizationMode="Recycling">

                <DataGrid.ColumnHeaderStyle>
                    <Style BasedOn="{StaticResource AppDataGridColHeader}" TargetType="DataGridColumnHeader" />
                </DataGrid.ColumnHeaderStyle>
                <DataGrid.CellStyle>
                    <Style BasedOn="{StaticResource AppDataGridCell}" TargetType="DataGridCell" />
                </DataGrid.CellStyle>
                <DataGrid.RowStyle>
                    <Style BasedOn="{StaticResource AppDataGridRowSelectable}" TargetType="DataGridRow" />
                </DataGrid.RowStyle>

                <DataGrid.Columns>
                    <!--  資產 (原「負債名稱」— 統一三個分頁的首欄為「資產」)  -->
                    <DataGridTemplateColumn Width="*" SortMemberPath="Name">
                        <DataGridTemplateColumn.Header>
                            <TextBlock Text="{DynamicResource Common.Asset}" />
                        </DataGridTemplateColumn.Header>
                        <DataGridTemplateColumn.CellTemplate>
                            <DataTemplate>
                                <Grid VerticalAlignment="Center">
                                    <Grid.RowDefinitions>
                                        <RowDefinition Height="Auto" />
                                        <RowDefinition Height="Auto" />
                                    </Grid.RowDefinitions>
                                    <Grid.ColumnDefinitions>
                                        <ColumnDefinition Width="*" />
                                        <ColumnDefinition Width="Auto" />
                                    </Grid.ColumnDefinitions>

                                    <TextBlock
                                        Grid.Row="0"
                                        Grid.Column="0"
                                        VerticalAlignment="Center"
                                        FontWeight="SemiBold"
                                        Foreground="{DynamicResource AppTextPrimary}"
                                        Text="{Binding Name}"
                                        TextTrimming="CharacterEllipsis" />

                                    <Border
                                        Grid.Row="0"
                                        Grid.Column="1"
                                        Margin="10,0,0,0"
                                        HorizontalAlignment="Right"
                                        Style="{StaticResource PortfolioLiabilityBadge}">
                                        <TextBlock>
                                            <TextBlock.Style>
                                                <Style BasedOn="{StaticResource PortfolioBadgeText}" TargetType="TextBlock">
                                                    <Setter Property="Text" Value="{DynamicResource Portfolio.Dialog.TypeLoan}" />
                                                    <Style.Triggers>
                                                        <DataTrigger Binding="{Binding IsCreditCard}" Value="True">
                                                            <Setter Property="Text" Value="{DynamicResource Portfolio.Dialog.TypeCreditCard}" />
                                                        </DataTrigger>
                                                    </Style.Triggers>
                                                </Style>
                                            </TextBlock.Style>
                                        </TextBlock>
                                    </Border>

                                    <TextBlock
                                        Grid.Row="1"
                                        Grid.Column="0"
                                        Grid.ColumnSpan="2"
                                        Margin="0,4,0,0"
                                        FontSize="{StaticResource FontSizeXs}"
                                        Foreground="{DynamicResource AppTextMuted}"
                                        TextTrimming="CharacterEllipsis">
                                        <TextBlock.Style>
                                            <Style TargetType="TextBlock">
                                                <Setter Property="Text" Value="{Binding RateDisplay}" />
                                                <Style.Triggers>
                                                    <DataTrigger Binding="{Binding IsCreditCard}" Value="True">
                                                        <Setter Property="Text" Value="{Binding IssuerName, FallbackValue=''}" />
                                                    </DataTrigger>
                                                </Style.Triggers>
                                            </Style>
                                        </TextBlock.Style>
                                    </TextBlock>
                                </Grid>
                            </DataTemplate>
                        </DataGridTemplateColumn.CellTemplate>
                    </DataGridTemplateColumn>

                    <!--  Remaining Balance  -->
                    <DataGridTemplateColumn Width="200" SortMemberPath="Balance">
                        <DataGridTemplateColumn.HeaderStyle>
                            <Style BasedOn="{StaticResource AppDataGridColHeader}" TargetType="DataGridColumnHeader">
                                <Setter Property="HorizontalContentAlignment" Value="Right" />
                            </Style>
                        </DataGridTemplateColumn.HeaderStyle>
                        <DataGridTemplateColumn.Header>
                            <TextBlock Text="{DynamicResource Portfolio.Liability.Amount}" />
                        </DataGridTemplateColumn.Header>
                        <DataGridTemplateColumn.CellTemplate>
                            <DataTemplate>
                                <TextBlock
                                    VerticalAlignment="Center"
                                    FontFamily="{StaticResource FontTabular}"
                                    FontWeight="SemiBold"
                                    Foreground="{DynamicResource AppDown}"
                                    Text="{Binding Balance, Converter={StaticResource CurrencyConverter}, ConverterParameter=amount}"
                                    TextAlignment="Right" />
                            </DataTemplate>
                        </DataGridTemplateColumn.CellTemplate>
                    </DataGridTemplateColumn>

                    <!--  Original Amount  -->
                    <DataGridTemplateColumn Width="200" SortMemberPath="OriginalAmount">
                        <DataGridTemplateColumn.HeaderStyle>
                            <Style BasedOn="{StaticResource AppDataGridColHeader}" TargetType="DataGridColumnHeader">
                                <Setter Property="HorizontalContentAlignment" Value="Right" />
                            </Style>
                        </DataGridTemplateColumn.HeaderStyle>
                        <DataGridTemplateColumn.Header>
                            <TextBlock Text="{DynamicResource Portfolio.Liability.OriginalAmount}" />
                        </DataGridTemplateColumn.Header>
                        <DataGridTemplateColumn.CellTemplate>
                            <DataTemplate>
                                <TextBlock
                                    VerticalAlignment="Center"
                                    FontFamily="{StaticResource FontTabular}"
                                    Foreground="{DynamicResource AppTextSecondary}"
                                    Text="{Binding OriginalAmount, Converter={StaticResource CurrencyConverter}, ConverterParameter=amount-dash}"
                                    TextAlignment="Right" />
                            </DataTemplate>
                        </DataGridTemplateColumn.CellTemplate>
                    </DataGridTemplateColumn>

                    <!--  Paid %  -->
                    <DataGridTemplateColumn Width="100" SortMemberPath="PaidPercent">
                        <DataGridTemplateColumn.HeaderStyle>
                            <Style BasedOn="{StaticResource AppDataGridColHeader}" TargetType="DataGridColumnHeader">
                                <Setter Property="HorizontalContentAlignment" Value="Right" />
                            </Style>
                        </DataGridTemplateColumn.HeaderStyle>
                        <DataGridTemplateColumn.Header>
                            <TextBlock Text="{DynamicResource Portfolio.Liability.PaidPercent}" />
                        </DataGridTemplateColumn.Header>
                        <DataGridTemplateColumn.CellTemplate>
                            <DataTemplate>
                                <TextBlock
                                    VerticalAlignment="Center"
                                    FontFamily="{StaticResource FontTabular}"
                                    Foreground="{DynamicResource AppUp}"
                                    Text="{Binding PaidPercentDisplay}"
                                    TextAlignment="Right" />
                            </DataTemplate>
                        </DataGridTemplateColumn.CellTemplate>
                    </DataGridTemplateColumn>
                </DataGrid.Columns>
            </DataGrid>
        </Grid>
    </Grid>
</UserControl>
