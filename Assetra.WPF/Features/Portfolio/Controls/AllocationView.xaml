<UserControl
    x:Class="Assetra.WPF.Features.Portfolio.Controls.AllocationView"
    xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
    xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
    xmlns:alloccontrols="clr-namespace:Assetra.WPF.Features.Portfolio.Controls"
    xmlns:behaviors="clr-namespace:Assetra.WPF.Infrastructure.Behaviors"
    xmlns:controls="clr-namespace:Assetra.WPF.Infrastructure.Controls"
    xmlns:conv="clr-namespace:Assetra.WPF.Infrastructure.Converters"
    xmlns:d="http://schemas.microsoft.com/expression/blend/2008"
    xmlns:mc="http://schemas.openxmlformats.org/markup-compatibility/2006"
    xmlns:vm="clr-namespace:Assetra.WPF.Features.Portfolio.Controls"
    x:Name="Root"
    d:DataContext="{d:DesignInstance Type={x:Type vm:AllocationViewModel}}"
    d:DesignHeight="776"
    d:DesignWidth="1100"
    Background="{DynamicResource AppBackground}"
    mc:Ignorable="d">

    <UserControl.Resources>
        <BooleanToVisibilityConverter x:Key="BoolToVis" />
        <conv:PercentToWidthConverter x:Key="PctToWidth" />
    </UserControl.Resources>

    <Grid>
        <Grid.RowDefinitions>
            <RowDefinition Height="Auto" />
            <!--  tab bar  -->
            <RowDefinition Height="*" />
            <!--  content  -->
        </Grid.RowDefinitions>

        <!--  ── Tab bar ───────────────────────────────────────────────────  -->
        <Border
            Grid.Row="0"
            Background="{DynamicResource AppSurface}"
            BorderBrush="{DynamicResource AppBorder}"
            BorderThickness="0,0,0,1">
            <StackPanel Margin="16,0" Orientation="Horizontal">
                <RadioButton
                    Command="{Binding SwitchToOverviewCommand}"
                    Content="{DynamicResource Allocation.Tab.Overview}"
                    GroupName="AllocTabs"
                    IsChecked="{Binding IsOverviewTab, Mode=OneWay}"
                    Style="{StaticResource NavTabBtn}" />
                <RadioButton
                    Command="{Binding SwitchToRebalanceCommand}"
                    Content="{DynamicResource Allocation.Tab.Rebalance}"
                    GroupName="AllocTabs"
                    IsChecked="{Binding IsRebalanceTab, Mode=OneWay}"
                    Style="{StaticResource NavTabBtn}" />
            </StackPanel>
        </Border>

        <!--  ── 配置概覽 tab ───────────────────────────────────────────────  -->
        <Grid
            Grid.Row="1"
            d:Visibility="Visible"
            Visibility="{Binding IsOverviewTab, Converter={StaticResource BoolToVis}}">
            <Grid>
                <Grid.ColumnDefinitions>
                    <ColumnDefinition Width="*" MinWidth="320" />
                    <ColumnDefinition Width="*" MinWidth="360" />
                </Grid.ColumnDefinitions>

                <!--  Left: treemap  -->
                <Border Style="{StaticResource FormCard}"
                    Grid.Column="0"
                    Margin="24,24,8,24"
                    Padding="16">
                    <Grid>
                        <Grid.RowDefinitions>
                            <RowDefinition Height="Auto" />
                            <RowDefinition Height="*" />
                        </Grid.RowDefinitions>

                        <DockPanel Grid.Row="0" Margin="0,0,0,10" LastChildFill="True">
                            <CheckBox
                                VerticalAlignment="Center"
                                DockPanel.Dock="Right"
                                IsChecked="{Binding IncludeCashInAllocation}"
                                ToolTip="{DynamicResource Allocation.IncludeCash.Hint}">
                                <TextBlock
                                    FontSize="{StaticResource Font.Size.Xs}"
                                    Foreground="{DynamicResource AppTextSecondary}"
                                    Text="{DynamicResource Allocation.IncludeCash}" />
                            </CheckBox>
                            <TextBlock
                                FontSize="{StaticResource Font.Size.Md}"
                                FontWeight="SemiBold"
                                Foreground="{DynamicResource AppTextPrimary}"
                                Text="{DynamicResource Allocation.Overview.Title}" />
                        </DockPanel>

                        <ItemsControl
                            Grid.Row="1"
                            ItemsSource="{Binding AllocationRows}"
                            UseLayoutRounding="True">
                            <ItemsControl.ItemsPanel>
                                <ItemsPanelTemplate>
                                    <controls:TreemapPanel />
                                </ItemsPanelTemplate>
                            </ItemsControl.ItemsPanel>
                            <ItemsControl.ItemContainerStyle>
                                <Style TargetType="ContentPresenter">
                                    <Setter Property="controls:TreemapPanel.Weight" Value="{Binding ActualPercentWeight}" />
                                </Style>
                            </ItemsControl.ItemContainerStyle>
                            <ItemsControl.ItemTemplate>
                                <DataTemplate DataType="{x:Type vm:AllocationRowViewModel}">
                                    <Border
                                        controls:ToolTipBehavior.FollowMouse="True"
                                        Background="{Binding PnlColorBrush}"
                                        ClipToBounds="True">
                                        <Border.ToolTip>
                                            <ToolTip>
                                                <StackPanel MinWidth="160">
                                                    <TextBlock
                                                        FontSize="{StaticResource Font.Size.Sm}"
                                                        FontWeight="SemiBold"
                                                        Text="{Binding Symbol}" />
                                                    <TextBlock
                                                        Margin="0,1,0,6"
                                                        FontSize="{StaticResource Font.Size.Xs}"
                                                        Foreground="{DynamicResource AppTextMuted}"
                                                        Text="{Binding Name}" />
                                                    <DockPanel Margin="0,2,0,0">
                                                        <TextBlock
                                                            DockPanel.Dock="Left"
                                                            FontSize="{StaticResource Font.Size.Xs}"
                                                            Text="{DynamicResource Portfolio.Allocation.Header.MarketValue}" />
                                                        <TextBlock
                                                            HorizontalAlignment="Right"
                                                            FontFamily="{StaticResource Font.Family.Base}"
                                                            FontSize="{StaticResource Font.Size.Xs}"
                                                            FontWeight="SemiBold"
                                                            Text="{Binding MarketValue, StringFormat='NT\${0:N0}'}"
                                                            Typography.NumeralAlignment="Tabular" />
                                                    </DockPanel>
                                                    <DockPanel Margin="0,2,0,0">
                                                        <TextBlock
                                                            DockPanel.Dock="Left"
                                                            FontSize="{StaticResource Font.Size.Xs}"
                                                            Text="{DynamicResource Portfolio.Allocation.Header.ActualWeight}" />
                                                        <TextBlock
                                                            HorizontalAlignment="Right"
                                                            FontFamily="{StaticResource Font.Family.Base}"
                                                            FontSize="{StaticResource Font.Size.Xs}"
                                                            FontWeight="SemiBold"
                                                            Text="{Binding ActualPercentDisplay}"
                                                            Typography.NumeralAlignment="Tabular" />
                                                    </DockPanel>
                                                    <DockPanel Margin="0,2,0,0">
                                                        <TextBlock
                                                            DockPanel.Dock="Left"
                                                            FontSize="{StaticResource Font.Size.Xs}"
                                                            Text="{DynamicResource Portfolio.Allocation.Header.Pnl}" />
                                                        <TextBlock
                                                            HorizontalAlignment="Right"
                                                            FontFamily="{StaticResource Font.Family.Base}"
                                                            FontSize="{StaticResource Font.Size.Xs}"
                                                            FontWeight="SemiBold"
                                                            Text="{Binding PnlDisplay}"
                                                            Typography.NumeralAlignment="Tabular" />
                                                    </DockPanel>
                                                    <DockPanel Margin="0,2,0,0">
                                                        <TextBlock
                                                            DockPanel.Dock="Left"
                                                            FontSize="{StaticResource Font.Size.Xs}"
                                                            Text="{DynamicResource Portfolio.Allocation.Header.PnlRate}" />
                                                        <TextBlock
                                                            HorizontalAlignment="Right"
                                                            FontFamily="{StaticResource Font.Family.Base}"
                                                            FontSize="{StaticResource Font.Size.Xs}"
                                                            FontWeight="SemiBold"
                                                            Text="{Binding PnlPercentDisplay}"
                                                            Typography.NumeralAlignment="Tabular" />
                                                    </DockPanel>
                                                </StackPanel>
                                            </ToolTip>
                                        </Border.ToolTip>
                                        <StackPanel
                                            Margin="4"
                                            HorizontalAlignment="Center"
                                            VerticalAlignment="Center">
                                            <TextBlock
                                                HorizontalAlignment="Center"
                                                FontSize="{StaticResource Font.Size.Sm}"
                                                FontWeight="SemiBold"
                                                Foreground="{DynamicResource AppTextOnAccent}"
                                                Text="{Binding Symbol}"
                                                TextTrimming="CharacterEllipsis" />
                                            <TextBlock
                                                HorizontalAlignment="Center"
                                                FontSize="{StaticResource Font.Size.Xs}"
                                                Foreground="{DynamicResource AppTextOnAccent}"
                                                Text="{Binding ActualPercentDisplay}" />
                                            <TextBlock
                                                HorizontalAlignment="Center"
                                                FontSize="{StaticResource Font.Size.Xs}"
                                                FontWeight="SemiBold"
                                                Foreground="{DynamicResource AppTextOnAccent}"
                                                Text="{Binding PnlPercentTreemap}" />
                                        </StackPanel>
                                    </Border>
                                </DataTemplate>
                            </ItemsControl.ItemTemplate>
                        </ItemsControl>
                    </Grid>
                </Border>

                <!--  Right: asset list DataGrid wrapped in FormCard for visual consistency with the left treemap card  -->
                <Border
                    Grid.Column="1"
                    Margin="8,24,24,24"
                    Padding="0"
                    Style="{StaticResource FormCard}"
                    ClipToBounds="True">
                <DataGrid
                    AutoGenerateColumns="False"
                    Background="Transparent"
                    BorderThickness="0"
                    CanUserAddRows="False"
                    CanUserDeleteRows="False"
                    CanUserReorderColumns="False"
                    CanUserResizeColumns="False"
                    CanUserSortColumns="True"
                    ColumnHeaderHeight="{StaticResource DataGrid.HeaderHeight}"
                    EnableRowVirtualization="True"
                    FontFamily="{StaticResource Font.Family.Base}"
                    FontSize="{StaticResource Font.Size.Sm}"
                    Foreground="{DynamicResource AppTextPrimary}"
                    GridLinesVisibility="None"
                    HeadersVisibility="Column"
                    HorizontalScrollBarVisibility="Auto"
                    IsReadOnly="True"
                    ItemsSource="{Binding AllocationRows}"
                    RowHeight="{StaticResource DataGrid.RowHeight}"
                    SelectionMode="Single"
                    VirtualizingPanel.IsVirtualizing="True"
                    VirtualizingPanel.VirtualizationMode="Recycling">

                    <DataGrid.ColumnHeaderStyle>
                        <Style BasedOn="{StaticResource AppDataGridColHeader}" TargetType="DataGridColumnHeader" />
                    </DataGrid.ColumnHeaderStyle>
                    <DataGrid.CellStyle>
                        <Style BasedOn="{StaticResource AppDataGridCell}" TargetType="DataGridCell" />
                    </DataGrid.CellStyle>
                    <DataGrid.RowStyle>
                        <Style BasedOn="{StaticResource AppDataGridRow}" TargetType="DataGridRow" />
                    </DataGrid.RowStyle>

                    <DataGrid.Columns>

                        <!--  資產 (Symbol + Name)  -->
                        <DataGridTemplateColumn
                            Width="*"
                            MinWidth="100"
                            SortMemberPath="Symbol">
                            <DataGridTemplateColumn.Header>
                                <TextBlock Text="{DynamicResource Allocation.Col.Asset}" />
                            </DataGridTemplateColumn.Header>
                            <DataGridTemplateColumn.CellTemplate>
                                <DataTemplate DataType="{x:Type vm:AllocationRowViewModel}">
                                    <StackPanel Margin="8,0" VerticalAlignment="Center">
                                        <DockPanel>
                                            <Border
                                                Width="10"
                                                Height="10"
                                                Margin="0,0,6,0"
                                                VerticalAlignment="Center"
                                                Background="{Binding ColorBrush}"
                                                CornerRadius="{StaticResource Radius.Xs}" />
                                            <TextBlock
                                                FontSize="{StaticResource Font.Size.Sm}"
                                                FontWeight="SemiBold"
                                                Foreground="{DynamicResource AppTextPrimary}"
                                                Text="{Binding Symbol}" />
                                        </DockPanel>
                                        <TextBlock
                                            Margin="16,1,0,0"
                                            FontSize="{StaticResource Font.Size.Xs}"
                                            Foreground="{DynamicResource AppTextMuted}"
                                            Text="{Binding Name}"
                                            TextTrimming="CharacterEllipsis" />
                                    </StackPanel>
                                </DataTemplate>
                            </DataGridTemplateColumn.CellTemplate>
                        </DataGridTemplateColumn>

                        <!--  現價  -->
                        <DataGridTemplateColumn Width="80" SortMemberPath="CurrentPrice">
                            <DataGridTemplateColumn.HeaderStyle>
                                <Style BasedOn="{StaticResource AppDataGridColHeader}" TargetType="DataGridColumnHeader">
                                    <Setter Property="HorizontalContentAlignment" Value="Right" />
                                </Style>
                            </DataGridTemplateColumn.HeaderStyle>
                            <DataGridTemplateColumn.Header>
                                <TextBlock Text="{DynamicResource Allocation.Col.Price}" />
                            </DataGridTemplateColumn.Header>
                            <DataGridTemplateColumn.CellTemplate>
                                <DataTemplate DataType="{x:Type vm:AllocationRowViewModel}">
                                    <TextBlock
                                        Margin="0,0,8,0"
                                        HorizontalAlignment="Right"
                                        VerticalAlignment="Center"
                                        FontFamily="{StaticResource Font.Family.Base}"
                                        FontSize="{StaticResource Font.Size.Xs}"
                                        Foreground="{DynamicResource AppTextSecondary}"
                                        Text="{Binding CurrentPrice, StringFormat='NT\${0:N0}'}"
                                        Typography.NumeralAlignment="Tabular" />
                                </DataTemplate>
                            </DataGridTemplateColumn.CellTemplate>
                        </DataGridTemplateColumn>

                        <!--  市值 + allocation bar  -->
                        <DataGridTemplateColumn Width="140" SortMemberPath="MarketValue">
                            <DataGridTemplateColumn.HeaderStyle>
                                <Style BasedOn="{StaticResource AppDataGridColHeader}" TargetType="DataGridColumnHeader">
                                    <Setter Property="HorizontalContentAlignment" Value="Right" />
                                </Style>
                            </DataGridTemplateColumn.HeaderStyle>
                            <DataGridTemplateColumn.Header>
                                <TextBlock Text="{DynamicResource Allocation.Col.Value}" />
                            </DataGridTemplateColumn.Header>
                            <DataGridTemplateColumn.CellTemplate>
                                <DataTemplate DataType="{x:Type vm:AllocationRowViewModel}">
                                    <TextBlock
                                        Margin="0,0,8,0"
                                        HorizontalAlignment="Right"
                                        VerticalAlignment="Center"
                                        FontFamily="{StaticResource Font.Family.Base}"
                                        FontSize="{StaticResource Font.Size.Sm}"
                                        FontWeight="SemiBold"
                                        Foreground="{DynamicResource AppTextPrimary}"
                                        Text="{Binding MarketValue, StringFormat='NT\${0:N0}'}"
                                        Typography.NumeralAlignment="Tabular" />
                                </DataTemplate>
                            </DataGridTemplateColumn.CellTemplate>
                        </DataGridTemplateColumn>

                        <!--  實際比例%  -->
                        <DataGridTemplateColumn Width="72" SortMemberPath="ActualPercent">
                            <DataGridTemplateColumn.HeaderStyle>
                                <Style BasedOn="{StaticResource AppDataGridColHeader}" TargetType="DataGridColumnHeader">
                                    <Setter Property="HorizontalContentAlignment" Value="Right" />
                                </Style>
                            </DataGridTemplateColumn.HeaderStyle>
                            <DataGridTemplateColumn.Header>
                                <TextBlock Text="{DynamicResource Allocation.Col.ActualPct}" />
                            </DataGridTemplateColumn.Header>
                            <DataGridTemplateColumn.CellTemplate>
                                <DataTemplate DataType="{x:Type vm:AllocationRowViewModel}">
                                    <TextBlock
                                        Margin="0,0,8,0"
                                        HorizontalAlignment="Right"
                                        VerticalAlignment="Center"
                                        FontFamily="{StaticResource Font.Family.Base}"
                                        FontSize="{StaticResource Font.Size.Sm}"
                                        FontWeight="SemiBold"
                                        Foreground="{DynamicResource AppTextPrimary}"
                                        Text="{Binding ActualPercentDisplay}"
                                        Typography.NumeralAlignment="Tabular" />
                                </DataTemplate>
                            </DataGridTemplateColumn.CellTemplate>
                        </DataGridTemplateColumn>

                        <!--  淨損益  -->
                        <DataGridTemplateColumn Width="130" SortMemberPath="Pnl">
                            <DataGridTemplateColumn.HeaderStyle>
                                <Style BasedOn="{StaticResource AppDataGridColHeader}" TargetType="DataGridColumnHeader">
                                    <Setter Property="HorizontalContentAlignment" Value="Right" />
                                </Style>
                            </DataGridTemplateColumn.HeaderStyle>
                            <DataGridTemplateColumn.Header>
                                <TextBlock Text="{DynamicResource Allocation.Col.TotalPnl}" />
                            </DataGridTemplateColumn.Header>
                            <DataGridTemplateColumn.CellTemplate>
                                <DataTemplate DataType="{x:Type vm:AllocationRowViewModel}">
                                    <StackPanel
                                        Margin="0,0,8,0"
                                        HorizontalAlignment="Right"
                                        VerticalAlignment="Center">
                                        <TextBlock
                                            HorizontalAlignment="Right"
                                            FontFamily="{StaticResource Font.Family.Base}"
                                            FontSize="{StaticResource Font.Size.Sm}"
                                            FontWeight="SemiBold"
                                            Typography.NumeralAlignment="Tabular">
                                            <TextBlock.Style>
                                                <Style TargetType="TextBlock">
                                                    <Setter Property="Foreground" Value="{DynamicResource AppDown}" />
                                                    <Style.Triggers>
                                                        <DataTrigger Binding="{Binding IsPnlPositive}" Value="True">
                                                            <Setter Property="Foreground" Value="{DynamicResource AppUp}" />
                                                        </DataTrigger>
                                                    </Style.Triggers>
                                                </Style>
                                            </TextBlock.Style>
                                            <Run Text="{Binding PnlDisplay, Mode=OneWay}" />
                                        </TextBlock>
                                        <TextBlock
                                            HorizontalAlignment="Right"
                                            FontSize="{StaticResource Font.Size.Xs}"
                                            Foreground="{DynamicResource AppTextMuted}"
                                            Text="{Binding PnlPercentDisplay}" />
                                    </StackPanel>
                                </DataTemplate>
                            </DataGridTemplateColumn.CellTemplate>
                        </DataGridTemplateColumn>

                    </DataGrid.Columns>
                </DataGrid>
                </Border>
            </Grid>

            <!-- Keep one allocation overview layout active. The previous width-based
                 alternate layout could oscillate near the breakpoint as scrollbars
                 changed the measured width. -->
            <ScrollViewer
                Visibility="Collapsed"
                HorizontalScrollBarVisibility="Disabled"
                VerticalScrollBarVisibility="Auto">
                <StackPanel Margin="16">
                    <StackPanel.Style>
                        <Style TargetType="StackPanel">
                            <Setter Property="Visibility" Value="Collapsed" />
                            <Style.Triggers>
                                <DataTrigger Value="True">
                                    <DataTrigger.Binding>
                                        <MultiBinding Converter="{StaticResource WidthScaleThresholdToBooleanConverter}" ConverterParameter="1260">
                                            <Binding ElementName="Root" Path="ActualWidth" />
                                            <Binding Path="DataContext.Settings.UiScale" RelativeSource="{RelativeSource AncestorType=Window}" />
                                        </MultiBinding>
                                    </DataTrigger.Binding>
                                    <Setter Property="Visibility" Value="Visible" />
                                </DataTrigger>
                            </Style.Triggers>
                        </Style>
                    </StackPanel.Style>

                    <Border Style="{StaticResource FormCard}" Margin="0,0,0,12" Padding="12">
                        <Grid>
                            <Grid.RowDefinitions>
                                <RowDefinition Height="Auto" />
                                <RowDefinition Height="340" />
                            </Grid.RowDefinitions>

                            <TextBlock
                                Grid.Row="0"
                                Margin="0,0,0,10"
                                FontSize="{StaticResource Font.Size.Md}"
                                FontWeight="SemiBold"
                                Foreground="{DynamicResource AppTextPrimary}"
                                Text="{DynamicResource Allocation.Overview.Title}" />

                            <ItemsControl
                                Grid.Row="1"
                                ItemsSource="{Binding AllocationRows}"
                                UseLayoutRounding="True">
                                <ItemsControl.ItemsPanel>
                                    <ItemsPanelTemplate>
                                        <controls:TreemapPanel />
                                    </ItemsPanelTemplate>
                                </ItemsControl.ItemsPanel>
                                <ItemsControl.ItemContainerStyle>
                                    <Style TargetType="ContentPresenter">
                                        <Setter Property="controls:TreemapPanel.Weight" Value="{Binding ActualPercentWeight}" />
                                    </Style>
                                </ItemsControl.ItemContainerStyle>
                                <ItemsControl.ItemTemplate>
                                    <DataTemplate DataType="{x:Type vm:AllocationRowViewModel}">
                                        <Border
                                            controls:ToolTipBehavior.FollowMouse="True"
                                            Background="{Binding PnlColorBrush}"
                                            ClipToBounds="True">
                                            <StackPanel
                                                Margin="4"
                                                HorizontalAlignment="Center"
                                                VerticalAlignment="Center">
                                                <TextBlock
                                                    HorizontalAlignment="Center"
                                                    FontSize="{StaticResource Font.Size.Sm}"
                                                    FontWeight="SemiBold"
                                                    Foreground="{DynamicResource AppTextOnAccent}"
                                                    Text="{Binding Symbol}"
                                                    TextTrimming="CharacterEllipsis" />
                                                <TextBlock
                                                    HorizontalAlignment="Center"
                                                    FontSize="{StaticResource Font.Size.Xs}"
                                                    Foreground="{DynamicResource AppTextOnAccent}"
                                                    Text="{Binding ActualPercentDisplay}" />
                                                <TextBlock
                                                    HorizontalAlignment="Center"
                                                    FontSize="{StaticResource Font.Size.Xs}"
                                                    FontWeight="SemiBold"
                                                    Foreground="{DynamicResource AppTextOnAccent}"
                                                    Text="{Binding PnlPercentTreemap}" />
                                            </StackPanel>
                                        </Border>
                                    </DataTemplate>
                                </ItemsControl.ItemTemplate>
                            </ItemsControl>
                        </Grid>
                    </Border>

                    <ItemsControl ItemsSource="{Binding AllocationRows}">
                        <ItemsControl.ItemTemplate>
                            <DataTemplate DataType="{x:Type vm:AllocationRowViewModel}">
                                <Border Style="{StaticResource FormCard}" Margin="0,0,0,10" Padding="14,12">
                                    <StackPanel>
                                        <DockPanel LastChildFill="True">
                                            <TextBlock
                                                Margin="0,0,6,0"
                                                DockPanel.Dock="Left"
                                                FontFamily="{StaticResource Font.Family.Base}"
                                                FontSize="{StaticResource Font.Size.Sm}"
                                                FontWeight="SemiBold"
                                                Foreground="{DynamicResource AppTextPrimary}"
                                                Text="{Binding Symbol}"
                                                Typography.NumeralAlignment="Tabular" />
                                            <TextBlock
                                                DockPanel.Dock="Right"
                                                FontFamily="{StaticResource Font.Family.Base}"
                                                FontSize="{StaticResource Font.Size.Sm}"
                                                FontWeight="SemiBold"
                                                Foreground="{DynamicResource AppTextPrimary}"
                                                Text="{Binding MarketValue, StringFormat='NT\${0:N0}'}"
                                                Typography.NumeralAlignment="Tabular" />
                                            <TextBlock
                                                FontSize="{StaticResource Font.Size.Sm}"
                                                Foreground="{DynamicResource AppTextSecondary}"
                                                Text="{Binding Name}"
                                                TextTrimming="CharacterEllipsis" />
                                        </DockPanel>

                                        <WrapPanel Margin="0,10,0,0">
                                            <Border
                                                Margin="0,0,8,8"
                                                Padding="8,6"
                                                Background="{DynamicResource AppBackground}"
                                                BorderBrush="{DynamicResource AppBorder}"
                                                BorderThickness="1"
                                                CornerRadius="{StaticResource Radius.Sm}">
                                                <StackPanel>
                                                    <TextBlock
                                                        FontSize="{StaticResource Font.Size.Xs}"
                                                        Foreground="{DynamicResource AppTextMuted}"
                                                        Text="{DynamicResource Portfolio.Allocation.Header.CurrentPrice}" />
                                                    <TextBlock
                                                        FontFamily="{StaticResource Font.Family.Base}"
                                                        FontSize="{StaticResource Font.Size.Sm}"
                                                        FontWeight="SemiBold"
                                                        Foreground="{DynamicResource AppTextPrimary}"
                                                        Text="{Binding CurrentPrice, StringFormat='NT\${0:N0}'}"
                                                        Typography.NumeralAlignment="Tabular" />
                                                </StackPanel>
                                            </Border>
                                            <Border
                                                Margin="0,0,8,8"
                                                Padding="8,6"
                                                Background="{DynamicResource AppBackground}"
                                                BorderBrush="{DynamicResource AppBorder}"
                                                BorderThickness="1"
                                                CornerRadius="{StaticResource Radius.Sm}">
                                                <StackPanel>
                                                    <TextBlock
                                                        FontSize="{StaticResource Font.Size.Xs}"
                                                        Foreground="{DynamicResource AppTextMuted}"
                                                        Text="{DynamicResource Portfolio.Allocation.Header.ActualVsTarget}" />
                                                    <TextBlock
                                                        FontFamily="{StaticResource Font.Family.Base}"
                                                        FontSize="{StaticResource Font.Size.Sm}"
                                                        FontWeight="SemiBold"
                                                        Foreground="{DynamicResource AppTextPrimary}"
                                                        Typography.NumeralAlignment="Tabular">
                                                        <Run Text="{Binding ActualPercentDisplay, Mode=OneWay}" />
                                                        <Run Text=" / " />
                                                        <Run Text="{Binding TargetPercent, StringFormat={}{0:F1}%, Mode=OneWay}" />
                                                    </TextBlock>
                                                </StackPanel>
                                            </Border>
                                            <Border
                                                Margin="0,0,8,8"
                                                Padding="8,6"
                                                Background="{DynamicResource AppBackground}"
                                                BorderBrush="{DynamicResource AppBorder}"
                                                BorderThickness="1"
                                                CornerRadius="{StaticResource Radius.Sm}">
                                                <StackPanel>
                                                    <TextBlock
                                                        FontSize="{StaticResource Font.Size.Xs}"
                                                        Foreground="{DynamicResource AppTextMuted}"
                                                        Text="{DynamicResource Portfolio.Allocation.Header.Deviation}" />
                                                    <TextBlock
                                                        FontFamily="{StaticResource Font.Family.Base}"
                                                        FontSize="{StaticResource Font.Size.Sm}"
                                                        FontWeight="SemiBold"
                                                        Text="{Binding DeviationDisplay}"
                                                        Typography.NumeralAlignment="Tabular">
                                                        <TextBlock.Style>
                                                            <Style TargetType="TextBlock">
                                                                <Setter Property="Foreground" Value="{DynamicResource AppTextMuted}" />
                                                                <Style.Triggers>
                                                                    <DataTrigger Binding="{Binding IsBuy}" Value="True">
                                                                        <Setter Property="Foreground" Value="{DynamicResource AppUp}" />
                                                                    </DataTrigger>
                                                                    <DataTrigger Binding="{Binding IsSell}" Value="True">
                                                                        <Setter Property="Foreground" Value="{DynamicResource AppDown}" />
                                                                    </DataTrigger>
                                                                </Style.Triggers>
                                                            </Style>
                                                        </TextBlock.Style>
                                                    </TextBlock>
                                                </StackPanel>
                                            </Border>
                                            <Border
                                                Margin="0,0,0,8"
                                                Padding="8,6"
                                                Background="{DynamicResource AppBackground}"
                                                BorderBrush="{DynamicResource AppBorder}"
                                                BorderThickness="1"
                                                CornerRadius="{StaticResource Radius.Sm}">
                                                <StackPanel>
                                                    <TextBlock
                                                        FontSize="{StaticResource Font.Size.Xs}"
                                                        Foreground="{DynamicResource AppTextMuted}"
                                                        Text="{DynamicResource Portfolio.Allocation.Header.Action}" />
                                                    <TextBlock
                                                        FontFamily="{StaticResource Font.Family.Base}"
                                                        FontSize="{StaticResource Font.Size.Sm}"
                                                        FontWeight="SemiBold"
                                                        Text="{Binding BuySellDisplay}"
                                                        Typography.NumeralAlignment="Tabular">
                                                        <TextBlock.Style>
                                                            <Style TargetType="TextBlock">
                                                                <Setter Property="Foreground" Value="{DynamicResource AppTextMuted}" />
                                                                <Style.Triggers>
                                                                    <DataTrigger Binding="{Binding IsBuy}" Value="True">
                                                                        <Setter Property="Foreground" Value="{DynamicResource AppUp}" />
                                                                    </DataTrigger>
                                                                    <DataTrigger Binding="{Binding IsSell}" Value="True">
                                                                        <Setter Property="Foreground" Value="{DynamicResource AppDown}" />
                                                                    </DataTrigger>
                                                                </Style.Triggers>
                                                            </Style>
                                                        </TextBlock.Style>
                                                    </TextBlock>
                                                </StackPanel>
                                            </Border>
                                        </WrapPanel>
                                    </StackPanel>
                                </Border>
                            </DataTemplate>
                        </ItemsControl.ItemTemplate>
                    </ItemsControl>
                </StackPanel>
            </ScrollViewer>
        </Grid>

        <!--  ── 再平衡 tab ──────────────────────────────────────────────────  -->
        <Grid
            Grid.Row="1"
            d:Visibility="Collapsed"
            Visibility="{Binding IsRebalanceTab, Converter={StaticResource BoolToVis}}">
            <Grid.RowDefinitions>
                <RowDefinition Height="Auto" />
                <!--  header card  -->
                <RowDefinition Height="Auto" />
                <!--  cash-flow info bar  -->
                <RowDefinition Height="Auto" />
                <!--  column headers  -->
                <RowDefinition Height="*" />
                <!--  rows  -->
            </Grid.RowDefinitions>

            <!--  Header card  -->
            <Border Style="{StaticResource FormCard}"
                Grid.Row="0"
                Margin="24,24,24,16"
                Padding="16">
                <StackPanel>
                    <TextBlock
                        FontSize="{StaticResource Font.Size.Md}"
                        FontWeight="SemiBold"
                        Foreground="{DynamicResource AppTextPrimary}"
                        Text="{DynamicResource Allocation.Rebalance.Title}" />
                    <TextBlock
                        Margin="0,2,0,10"
                        FontSize="{StaticResource Font.Size.Xs}"
                        Foreground="{DynamicResource AppTextMuted}"
                        Text="{DynamicResource Allocation.Rebalance.Subtitle}"
                        TextWrapping="Wrap" />
                    <WrapPanel>
                        <Border
                            Margin="0,0,12,8"
                            Padding="2"
                            Background="{DynamicResource AppBackground}"
                            BorderBrush="{DynamicResource AppBorder}"
                            BorderThickness="1"
                            CornerRadius="{StaticResource Radius.Sm}">
                            <WrapPanel>
                                <RadioButton
                                    Command="{Binding SetFullRebalanceCommand}"
                                    Content="{DynamicResource Allocation.Rebalance.Full}"
                                    GroupName="RebalanceMode"
                                    IsChecked="{Binding IsFullRebalance}"
                                    Style="{StaticResource NavTabBtn}" />
                                <RadioButton
                                    Command="{Binding SetCashRebalanceCommand}"
                                    Content="{DynamicResource Allocation.Rebalance.CashFlow}"
                                    GroupName="RebalanceMode"
                                    IsChecked="{Binding IsCashRebalance}"
                                    Style="{StaticResource NavTabBtn}" />
                            </WrapPanel>
                        </Border>
                        <Button
                            MinHeight="30"
                            Margin="0,0,0,8"
                            Padding="10,0"
                            Style="{StaticResource AppSecondaryButton}"
                            Command="{Binding BeginEditTargetsCommand}">
                            <TextBlock Text="{DynamicResource Allocation.Rebalance.EditTargets}" />
                        </Button>
                    </WrapPanel>
                </StackPanel>
            </Border>

            <!--  Cash-flow info bar (only when IsCashRebalance)  -->
            <Border Style="{StaticResource FormCard}"
                Grid.Row="1"
                Margin="24,0,24,16"
                Padding="16"
                Visibility="{Binding IsCashRebalance, Converter={StaticResource BoolToVis}}">
                <StackPanel>
                    <StackPanel Orientation="Horizontal">
                        <TextBlock
                            Margin="0,0,6,0"
                            VerticalAlignment="Center"
                            FontSize="{StaticResource Font.Size.Base}"
                            Text="💰" />
                        <StackPanel>
                            <TextBlock
                                FontSize="{StaticResource Font.Size.Sm}"
                                FontWeight="SemiBold"
                                Foreground="{DynamicResource AppTextPrimary}"
                                Text="{DynamicResource Allocation.Rebalance.CashFlow}" />
                            <TextBlock
                                FontSize="{StaticResource Font.Size.Xs}"
                                Foreground="{DynamicResource AppTextMuted}"
                                Text="{DynamicResource Allocation.CashFlow.Desc}"
                                TextWrapping="Wrap" />
                        </StackPanel>
                    </StackPanel>
                    <WrapPanel Margin="0,10,0,0">
                        <Border
                            Margin="0,0,8,8"
                            Padding="10,4"
                            Background="{DynamicResource AppAccent}"
                            CornerRadius="{StaticResource Radius.Sm}">
                            <TextBlock
                                VerticalAlignment="Center"
                                FontFamily="{StaticResource Font.Family.Base}"
                                FontSize="{StaticResource Font.Size.Sm}"
                                FontWeight="SemiBold"
                                Foreground="{DynamicResource AppTextOnAccent}"
                                Typography.NumeralAlignment="Tabular">
                                <Run Text="{DynamicResource Allocation.CashFlow.Total}" />
                                <Run Text="{Binding CashFlowTotal, Mode=OneWay, Converter={StaticResource CurrencyConverter}, ConverterParameter=amount}" />
                            </TextBlock>
                        </Border>
                        <Border
                            Margin="0,0,8,8"
                            Padding="8,4"
                            Background="{DynamicResource AppBackground}"
                            BorderBrush="{DynamicResource AppBorder}"
                            BorderThickness="1"
                            CornerRadius="{StaticResource Radius.Sm}">
                            <TextBlock
                                VerticalAlignment="Center"
                                FontSize="{StaticResource Font.Size.Xs}"
                                Foreground="{DynamicResource AppTextSecondary}"
                                Text="TWD" />
                        </Border>
                        <TextBlock
                            Margin="0,6,8,0"
                            VerticalAlignment="Center"
                            FontSize="{StaticResource Font.Size.Xs}"
                            Foreground="{DynamicResource AppTextSecondary}"
                            Text="{DynamicResource Allocation.CashFlow.InputLabel}" />
                        <TextBox
                            Width="100"
                            Margin="0,0,0,8"
                            HorizontalContentAlignment="Right"
                            FontFamily="{StaticResource Font.Family.Base}"
                            behaviors:ThousandSeparatorBehavior.IsEnabled="True"
                            Text="{Binding CashFlowInput, UpdateSourceTrigger=PropertyChanged}"
                            Typography.NumeralAlignment="Tabular" />
                    </WrapPanel>
                </StackPanel>
            </Border>

            <!--  Rebalance DataGrid (extracted)  -->
            <alloccontrols:RebalanceDataGrid Grid.Row="2" Grid.RowSpan="2" />
        </Grid>

        <!--  ── 編輯目標配置 overlay ────────────────────────────────────────  -->
        <alloccontrols:EditTargetsOverlay Grid.Row="0" Grid.RowSpan="2" />
    </Grid>
</UserControl>
