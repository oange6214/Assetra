<UserControl
    x:Class="Assetra.WPF.Features.Portfolio.Controls.AllocationView"
    xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
    xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
    xmlns:alloccontrols="clr-namespace:Assetra.WPF.Features.Portfolio.Controls"
    xmlns:behaviors="clr-namespace:Assetra.WPF.Infrastructure.Behaviors"
    xmlns:controls="clr-namespace:Assetra.WPF.Infrastructure.Controls"
    xmlns:conv="clr-namespace:Assetra.WPF.Infrastructure.Converters"
    xmlns:ds="clr-namespace:Assetra.WPF.DesignSystem.Controls"
    xmlns:d="http://schemas.microsoft.com/expression/blend/2008"
    xmlns:mc="http://schemas.openxmlformats.org/markup-compatibility/2006"
    xmlns:vm="clr-namespace:Assetra.WPF.Features.Portfolio.Controls"
    x:Name="Root"
    d:DataContext="{d:DesignInstance Type={x:Type vm:AllocationViewModel}}"
    d:DesignHeight="776"
    d:DesignWidth="1100"
    Background="{DynamicResource AppBackground}"
    mc:Ignorable="d">

    <UserControl.Resources>
        <BooleanToVisibilityConverter x:Key="BoolToVis" />
        <conv:PercentToWidthConverter x:Key="PctToWidth" />
    </UserControl.Resources>

    <!--
        套用 PageRootGrid 樣式統一頁面 padding（與其他財務概覽 tab 一致：總覽 / 資產趨勢 / 報酬日曆）。
        修前是裸 Grid 沒外邊距，內部卡片用 Margin="24" 個別控制，造成頁面跟其他 tab 視覺不齊。
    -->
    <Grid Style="{StaticResource PageRootGrid}">
        <Grid.RowDefinitions>
            <RowDefinition Height="Auto" />
            <!--  tab bar  -->
            <RowDefinition Height="*" />
            <!--  content  -->
        </Grid.RowDefinitions>

        <Border
            Grid.Row="0"
            Margin="0,0,0,12"
            Padding="2"
            HorizontalAlignment="Left"
            Background="{DynamicResource AppSurface}"
            BorderBrush="{DynamicResource AppBorder}"
            BorderThickness="1"
            CornerRadius="{StaticResource Radius.Md}">
            <StackPanel Orientation="Horizontal">
                <RadioButton
                    Command="{Binding SwitchToOverviewCommand}"
                    Content="{DynamicResource Allocation.Tab.Overview}"
                    GroupName="AllocTabs"
                    IsChecked="{Binding IsOverviewTab, Mode=OneWay}"
                    Style="{StaticResource AppSegmentButton}" />
                <RadioButton
                    Command="{Binding SwitchToRebalanceCommand}"
                    Content="{DynamicResource Allocation.Tab.Rebalance}"
                    GroupName="AllocTabs"
                    IsChecked="{Binding IsRebalanceTab, Mode=OneWay}"
                    Style="{StaticResource AppSegmentButton}" />
            </StackPanel>
        </Border>

        <!--  ── 配置概覽 tab ───────────────────────────────────────────────  -->
        <Grid
            Grid.Row="1"
            d:Visibility="Visible"
            Visibility="{Binding IsOverviewTab, Converter={StaticResource BoolToVis}}">
            <Grid>
                <Grid.ColumnDefinitions>
                    <ColumnDefinition Width="0.8*" MinWidth="360" />
                    <ColumnDefinition Width="1.2*" MinWidth="520" />
                </Grid.ColumnDefinitions>

                <!--  Left: ranked allocation list. Treemap hides tiny positions such as DRAM.  -->
                <Border
                    Grid.Column="0"
                    Margin="0,0,8,0"
                    Padding="16"
                    Style="{StaticResource FormCard}">
                    <Grid>
                        <Grid.RowDefinitions>
                            <RowDefinition Height="Auto" />
                            <RowDefinition Height="*" />
                        </Grid.RowDefinitions>

                        <DockPanel Grid.Row="0" Margin="0,0,0,10" LastChildFill="True">
                            <!--
                                Allocation grouping toggle — 三模式 radio：
                                  Symbol   (default; Portfolio-Groups P4)
                                  Group    (Portfolio-Groups P4，HasPortfolioGroups=false 時退化成只有 Symbol/Currency)
                                  Currency (MultiCurrency-Reporting P4.2 tail)
                                Group radio 只在 catalog 有群組時顯示；Currency radio 永遠顯示
                                (跨幣別持倉是多基準幣場景的核心 view)。
                            -->
                            <StackPanel
                                DockPanel.Dock="Right"
                                Orientation="Horizontal">
                                <RadioButton
                                    Margin="0,0,12,0"
                                    Content="{DynamicResource Allocation.GroupBy.Symbol}"
                                    GroupName="AllocGroupBy"
                                    IsChecked="{Binding IsBySymbolMode, Mode=OneWay}"
                                    Command="{Binding SetGroupingModeCommand}"
                                    CommandParameter="Symbol" />
                                <RadioButton
                                    Margin="0,0,12,0"
                                    Content="{DynamicResource Allocation.GroupBy.Group}"
                                    GroupName="AllocGroupBy"
                                    IsChecked="{Binding IsByGroupMode, Mode=OneWay}"
                                    Command="{Binding SetGroupingModeCommand}"
                                    CommandParameter="Group"
                                    Visibility="{Binding HasPortfolioGroups, Converter={StaticResource BooleanToVisibilityConverter}, FallbackValue=Collapsed}" />
                                <RadioButton
                                    Content="{DynamicResource Allocation.GroupBy.Currency}"
                                    GroupName="AllocGroupBy"
                                    IsChecked="{Binding IsByCurrencyMode, Mode=OneWay}"
                                    Command="{Binding SetGroupingModeCommand}"
                                    CommandParameter="Currency" />
                            </StackPanel>
                            <TextBlock
                                FontSize="{StaticResource Font.Size.Md}"
                                FontWeight="SemiBold"
                                Foreground="{DynamicResource AppTextPrimary}"
                                Text="{DynamicResource Allocation.Overview.Title}" />
                        </DockPanel>

                        <ScrollViewer
                            Grid.Row="1"
                            HorizontalScrollBarVisibility="Disabled"
                            VerticalScrollBarVisibility="Auto">
                            <ItemsControl ItemsSource="{Binding AllocationRows}">
                                <ItemsControl.ItemTemplate>
                                    <DataTemplate DataType="{x:Type vm:AllocationRowViewModel}">
                                        <Border
                                            Margin="0,0,0,10"
                                            Padding="0,0,0,10"
                                            BorderBrush="{DynamicResource AppBorderLight}"
                                            BorderThickness="0,0,0,1">
                                            <Grid>
                                                <Grid.RowDefinitions>
                                                    <RowDefinition Height="Auto" />
                                                    <RowDefinition Height="Auto" />
                                                    <RowDefinition Height="Auto" />
                                                </Grid.RowDefinitions>

                                                <Grid Grid.Row="0">
                                                    <Grid.ColumnDefinitions>
                                                        <ColumnDefinition Width="*" />
                                                        <ColumnDefinition Width="Auto" />
                                                    </Grid.ColumnDefinitions>

                                                    <StackPanel Grid.Column="0" Orientation="Horizontal">
                                                        <Border
                                                            Width="10"
                                                            Height="10"
                                                            Margin="0,4,8,0"
                                                            VerticalAlignment="Top"
                                                            Background="{Binding ColorBrush}"
                                                            CornerRadius="{StaticResource Radius.Xs}" />
                                                        <StackPanel>
                                                            <TextBlock
                                                                FontFamily="{StaticResource Font.Family.Base}"
                                                                FontSize="{StaticResource Font.Size.Sm}"
                                                                FontWeight="SemiBold"
                                                                Foreground="{DynamicResource AppTextPrimary}"
                                                                Text="{Binding Symbol}"
                                                                Typography.NumeralAlignment="Tabular" />
                                                            <TextBlock
                                                                Margin="0,1,8,0"
                                                                FontSize="{StaticResource Font.Size.Xs}"
                                                                Foreground="{DynamicResource AppTextMuted}"
                                                                Text="{Binding Name}"
                                                                TextTrimming="CharacterEllipsis" />
                                                        </StackPanel>
                                                    </StackPanel>

                                                    <StackPanel Grid.Column="1" HorizontalAlignment="Right">
                                                        <TextBlock
                                                            HorizontalAlignment="Right"
                                                            FontFamily="{StaticResource Font.Family.Base}"
                                                            FontSize="{StaticResource Font.Size.Sm}"
                                                            FontWeight="SemiBold"
                                                            Foreground="{DynamicResource AppTextPrimary}"
                                                            Text="{Binding MarketValue, StringFormat='NT\${0:N0}'}"
                                                            Typography.NumeralAlignment="Tabular" />
                                                        <TextBlock
                                                            HorizontalAlignment="Right"
                                                            FontFamily="{StaticResource Font.Family.Base}"
                                                            FontSize="{StaticResource Font.Size.Xs}"
                                                            Foreground="{DynamicResource AppTextSecondary}"
                                                            Text="{Binding ActualPercentDisplay}"
                                                            Typography.NumeralAlignment="Tabular" />
                                                    </StackPanel>
                                                </Grid>

                                                <Grid Grid.Row="1" Height="5" Margin="0,8,0,0">
                                                    <Border Background="{DynamicResource AppBorderLight}" CornerRadius="2.5" />
                                                    <Border
                                                        MinWidth="3"
                                                        HorizontalAlignment="Left"
                                                        Background="{Binding ColorBrush}"
                                                        CornerRadius="2.5">
                                                        <Border.Width>
                                                            <MultiBinding Converter="{StaticResource PctToWidth}">
                                                                <Binding Path="ActualPercent" />
                                                                <Binding Path="ActualWidth" RelativeSource="{RelativeSource AncestorType=Grid}" />
                                                            </MultiBinding>
                                                        </Border.Width>
                                                    </Border>
                                                </Grid>

                                                <DockPanel Grid.Row="2" Margin="0,6,0,0" LastChildFill="False">
                                                    <TextBlock
                                                        DockPanel.Dock="Left"
                                                        FontSize="{StaticResource Font.Size.Xs}"
                                                        Foreground="{DynamicResource AppTextMuted}"
                                                        Text="{DynamicResource Portfolio.Allocation.Header.Pnl}" />
                                                    <StackPanel DockPanel.Dock="Right" Orientation="Horizontal">
                                                        <TextBlock
                                                            FontFamily="{StaticResource Font.Family.Base}"
                                                            FontSize="{StaticResource Font.Size.Xs}"
                                                            FontWeight="SemiBold"
                                                            Text="{Binding PnlDisplay}"
                                                            Typography.NumeralAlignment="Tabular">
                                                            <TextBlock.Style>
                                                                <Style TargetType="TextBlock">
                                                                    <Setter Property="Foreground" Value="{DynamicResource AppDown}" />
                                                                    <Style.Triggers>
                                                                        <DataTrigger Binding="{Binding IsPnlPositive}" Value="True">
                                                                            <Setter Property="Foreground" Value="{DynamicResource AppUp}" />
                                                                        </DataTrigger>
                                                                    </Style.Triggers>
                                                                </Style>
                                                            </TextBlock.Style>
                                                        </TextBlock>
                                                        <TextBlock
                                                            Margin="4,0,0,0"
                                                            FontFamily="{StaticResource Font.Family.Base}"
                                                            FontSize="{StaticResource Font.Size.Xs}"
                                                            Foreground="{DynamicResource AppTextSecondary}"
                                                            Text="{Binding PnlPercentDisplay}"
                                                            Typography.NumeralAlignment="Tabular" />
                                                    </StackPanel>
                                                </DockPanel>
                                            </Grid>
                                        </Border>
                                    </DataTemplate>
                                </ItemsControl.ItemTemplate>
                            </ItemsControl>
                        </ScrollViewer>
                    </Grid>
                </Border>

                <!--  Right: precise asset table for sorting and numeric comparison.  -->
                <Border
                    Grid.Column="1"
                    Margin="8,0,0,0"
                    Padding="0"
                    Style="{StaticResource FormCard}"
                    ClipToBounds="True">
                <DataGrid
                    AutoGenerateColumns="False"
                    Background="Transparent"
                    BorderThickness="0"
                    CanUserAddRows="False"
                    CanUserDeleteRows="False"
                    CanUserReorderColumns="False"
                    CanUserResizeColumns="False"
                    CanUserSortColumns="True"
                    ColumnHeaderHeight="{StaticResource DataGrid.HeaderHeight}"
                    EnableRowVirtualization="True"
                    FontFamily="{StaticResource Font.Family.Base}"
                    FontSize="{StaticResource Font.Size.Sm}"
                    Foreground="{DynamicResource AppTextPrimary}"
                    GridLinesVisibility="None"
                    HeadersVisibility="Column"
                    HorizontalScrollBarVisibility="Auto"
                    IsReadOnly="True"
                    ItemsSource="{Binding AllocationRows}"
                    RowHeight="{StaticResource DataGrid.RowHeight}"
                    SelectionMode="Single"
                    VirtualizingPanel.IsVirtualizing="True"
                    VirtualizingPanel.VirtualizationMode="Recycling">

                    <DataGrid.ColumnHeaderStyle>
                        <Style BasedOn="{StaticResource AppDataGridColHeader}" TargetType="DataGridColumnHeader" />
                    </DataGrid.ColumnHeaderStyle>
                    <DataGrid.CellStyle>
                        <Style BasedOn="{StaticResource AppDataGridCell}" TargetType="DataGridCell" />
                    </DataGrid.CellStyle>
                    <DataGrid.RowStyle>
                        <Style BasedOn="{StaticResource AppDataGridRow}" TargetType="DataGridRow" />
                    </DataGrid.RowStyle>

                    <DataGrid.Columns>

                        <!--  資產 (Symbol + Name)  -->
                        <DataGridTemplateColumn
                            Width="*"
                            MinWidth="100"
                            SortMemberPath="Symbol">
                            <DataGridTemplateColumn.Header>
                                <TextBlock Text="{DynamicResource Allocation.Col.Asset}" />
                            </DataGridTemplateColumn.Header>
                            <DataGridTemplateColumn.CellTemplate>
                                <DataTemplate DataType="{x:Type vm:AllocationRowViewModel}">
                                    <StackPanel Margin="8,0" VerticalAlignment="Center">
                                        <DockPanel>
                                            <Border
                                                Width="10"
                                                Height="10"
                                                Margin="0,0,6,0"
                                                VerticalAlignment="Center"
                                                Background="{Binding ColorBrush}"
                                                CornerRadius="{StaticResource Radius.Xs}" />
                                            <TextBlock
                                                FontSize="{StaticResource Font.Size.Sm}"
                                                FontWeight="SemiBold"
                                                Foreground="{DynamicResource AppTextPrimary}"
                                                Text="{Binding Symbol}" />
                                        </DockPanel>
                                        <TextBlock
                                            Margin="16,1,0,0"
                                            FontSize="{StaticResource Font.Size.Xs}"
                                            Foreground="{DynamicResource AppTextMuted}"
                                            Text="{Binding Name}"
                                            TextTrimming="CharacterEllipsis" />
                                    </StackPanel>
                                </DataTemplate>
                            </DataGridTemplateColumn.CellTemplate>
                        </DataGridTemplateColumn>

                        <!--  現價  -->
                        <DataGridTemplateColumn Width="80" SortMemberPath="CurrentPrice">
                            <DataGridTemplateColumn.HeaderStyle>
                                <Style BasedOn="{StaticResource AppDataGridColHeader}" TargetType="DataGridColumnHeader">
                                    <Setter Property="HorizontalContentAlignment" Value="Right" />
                                </Style>
                            </DataGridTemplateColumn.HeaderStyle>
                            <DataGridTemplateColumn.Header>
                                <TextBlock Text="{DynamicResource Allocation.Col.Price}" />
                            </DataGridTemplateColumn.Header>
                            <DataGridTemplateColumn.CellTemplate>
                                <DataTemplate DataType="{x:Type vm:AllocationRowViewModel}">
                                    <TextBlock
                                        Margin="0,0,8,0"
                                        HorizontalAlignment="Right"
                                        VerticalAlignment="Center"
                                        FontFamily="{StaticResource Font.Family.Base}"
                                        FontSize="{StaticResource Font.Size.Xs}"
                                        Foreground="{DynamicResource AppTextSecondary}"
                                        Text="{Binding CurrentPrice, StringFormat='NT\${0:N0}'}"
                                        Typography.NumeralAlignment="Tabular" />
                                </DataTemplate>
                            </DataGridTemplateColumn.CellTemplate>
                        </DataGridTemplateColumn>

                        <!--  市值 + allocation bar  -->
                        <DataGridTemplateColumn Width="140" SortMemberPath="MarketValue">
                            <DataGridTemplateColumn.HeaderStyle>
                                <Style BasedOn="{StaticResource AppDataGridColHeader}" TargetType="DataGridColumnHeader">
                                    <Setter Property="HorizontalContentAlignment" Value="Right" />
                                </Style>
                            </DataGridTemplateColumn.HeaderStyle>
                            <DataGridTemplateColumn.Header>
                                <TextBlock Text="{DynamicResource Allocation.Col.Value}" />
                            </DataGridTemplateColumn.Header>
                            <DataGridTemplateColumn.CellTemplate>
                                <DataTemplate DataType="{x:Type vm:AllocationRowViewModel}">
                                    <TextBlock
                                        Margin="0,0,8,0"
                                        HorizontalAlignment="Right"
                                        VerticalAlignment="Center"
                                        FontFamily="{StaticResource Font.Family.Base}"
                                        FontSize="{StaticResource Font.Size.Sm}"
                                        FontWeight="SemiBold"
                                        Foreground="{DynamicResource AppTextPrimary}"
                                        Text="{Binding MarketValue, StringFormat='NT\${0:N0}'}"
                                        Typography.NumeralAlignment="Tabular" />
                                </DataTemplate>
                            </DataGridTemplateColumn.CellTemplate>
                        </DataGridTemplateColumn>

                        <!--  實際比例%  -->
                        <DataGridTemplateColumn Width="72" SortMemberPath="ActualPercent">
                            <DataGridTemplateColumn.HeaderStyle>
                                <Style BasedOn="{StaticResource AppDataGridColHeader}" TargetType="DataGridColumnHeader">
                                    <Setter Property="HorizontalContentAlignment" Value="Right" />
                                </Style>
                            </DataGridTemplateColumn.HeaderStyle>
                            <DataGridTemplateColumn.Header>
                                <TextBlock Text="{DynamicResource Allocation.Col.ActualPct}" />
                            </DataGridTemplateColumn.Header>
                            <DataGridTemplateColumn.CellTemplate>
                                <DataTemplate DataType="{x:Type vm:AllocationRowViewModel}">
                                    <TextBlock
                                        Margin="0,0,8,0"
                                        HorizontalAlignment="Right"
                                        VerticalAlignment="Center"
                                        FontFamily="{StaticResource Font.Family.Base}"
                                        FontSize="{StaticResource Font.Size.Sm}"
                                        FontWeight="SemiBold"
                                        Foreground="{DynamicResource AppTextPrimary}"
                                        Text="{Binding ActualPercentDisplay}"
                                        Typography.NumeralAlignment="Tabular" />
                                </DataTemplate>
                            </DataGridTemplateColumn.CellTemplate>
                        </DataGridTemplateColumn>

                        <!--  淨損益  -->
                        <DataGridTemplateColumn Width="130" SortMemberPath="Pnl">
                            <DataGridTemplateColumn.HeaderStyle>
                                <Style BasedOn="{StaticResource AppDataGridColHeader}" TargetType="DataGridColumnHeader">
                                    <Setter Property="HorizontalContentAlignment" Value="Right" />
                                </Style>
                            </DataGridTemplateColumn.HeaderStyle>
                            <DataGridTemplateColumn.Header>
                                <TextBlock Text="{DynamicResource Allocation.Col.TotalPnl}" />
                            </DataGridTemplateColumn.Header>
                            <DataGridTemplateColumn.CellTemplate>
                                <DataTemplate DataType="{x:Type vm:AllocationRowViewModel}">
                                    <StackPanel
                                        Margin="0,0,8,0"
                                        HorizontalAlignment="Right"
                                        VerticalAlignment="Center">
                                        <TextBlock
                                            HorizontalAlignment="Right"
                                            FontFamily="{StaticResource Font.Family.Base}"
                                            FontSize="{StaticResource Font.Size.Sm}"
                                            FontWeight="SemiBold"
                                            Typography.NumeralAlignment="Tabular">
                                            <TextBlock.Style>
                                                <Style TargetType="TextBlock">
                                                    <Setter Property="Foreground" Value="{DynamicResource AppDown}" />
                                                    <Style.Triggers>
                                                        <DataTrigger Binding="{Binding IsPnlPositive}" Value="True">
                                                            <Setter Property="Foreground" Value="{DynamicResource AppUp}" />
                                                        </DataTrigger>
                                                    </Style.Triggers>
                                                </Style>
                                            </TextBlock.Style>
                                            <Run Text="{Binding PnlDisplay, Mode=OneWay}" />
                                        </TextBlock>
                                        <TextBlock
                                            HorizontalAlignment="Right"
                                            FontSize="{StaticResource Font.Size.Xs}"
                                            Foreground="{DynamicResource AppTextMuted}"
                                            Text="{Binding PnlPercentDisplay}" />
                                    </StackPanel>
                                </DataTemplate>
                            </DataGridTemplateColumn.CellTemplate>
                        </DataGridTemplateColumn>

                    </DataGrid.Columns>
                </DataGrid>
                </Border>
            </Grid>

            <!-- Keep one allocation overview layout active. The previous width-based
                 alternate layout could oscillate near the breakpoint as scrollbars
                 changed the measured width. -->
            <ScrollViewer
                Visibility="Collapsed"
                HorizontalScrollBarVisibility="Disabled"
                VerticalScrollBarVisibility="Auto">
                <StackPanel Margin="16">
                    <StackPanel.Style>
                        <Style TargetType="StackPanel">
                            <Setter Property="Visibility" Value="Collapsed" />
                            <Style.Triggers>
                                <DataTrigger Value="True">
                                    <DataTrigger.Binding>
                                        <MultiBinding Converter="{StaticResource WidthScaleThresholdToBooleanConverter}" ConverterParameter="1260">
                                            <Binding ElementName="Root" Path="ActualWidth" />
                                            <Binding Path="DataContext.Settings.UiScale" RelativeSource="{RelativeSource AncestorType=Window}" />
                                        </MultiBinding>
                                    </DataTrigger.Binding>
                                    <Setter Property="Visibility" Value="Visible" />
                                </DataTrigger>
                            </Style.Triggers>
                        </Style>
                    </StackPanel.Style>

                    <Border Style="{StaticResource FormCard}" Margin="0,0,0,12" Padding="12">
                        <Grid>
                            <Grid.RowDefinitions>
                                <RowDefinition Height="Auto" />
                                <RowDefinition Height="340" />
                            </Grid.RowDefinitions>

                            <TextBlock
                                Grid.Row="0"
                                Margin="0,0,0,10"
                                FontSize="{StaticResource Font.Size.Md}"
                                FontWeight="SemiBold"
                                Foreground="{DynamicResource AppTextPrimary}"
                                Text="{DynamicResource Allocation.Overview.Title}" />

                            <ItemsControl
                                Grid.Row="1"
                                ItemsSource="{Binding AllocationRows}"
                                UseLayoutRounding="True">
                                <ItemsControl.ItemsPanel>
                                    <ItemsPanelTemplate>
                                        <controls:TreemapPanel />
                                    </ItemsPanelTemplate>
                                </ItemsControl.ItemsPanel>
                                <ItemsControl.ItemContainerStyle>
                                    <Style TargetType="ContentPresenter">
                                        <Setter Property="controls:TreemapPanel.Weight" Value="{Binding ActualPercentWeight}" />
                                    </Style>
                                </ItemsControl.ItemContainerStyle>
                                <ItemsControl.ItemTemplate>
                                    <DataTemplate DataType="{x:Type vm:AllocationRowViewModel}">
                                        <Border
                                            controls:ToolTipBehavior.FollowMouse="True"
                                            Background="{Binding PnlColorBrush}"
                                            ClipToBounds="True">
                                            <StackPanel
                                                Margin="4"
                                                HorizontalAlignment="Center"
                                                VerticalAlignment="Center">
                                                <TextBlock
                                                    HorizontalAlignment="Center"
                                                    FontSize="{StaticResource Font.Size.Sm}"
                                                    FontWeight="SemiBold"
                                                    Foreground="{DynamicResource AppTextOnAccent}"
                                                    Text="{Binding Symbol}"
                                                    TextTrimming="CharacterEllipsis" />
                                                <TextBlock
                                                    HorizontalAlignment="Center"
                                                    FontSize="{StaticResource Font.Size.Xs}"
                                                    Foreground="{DynamicResource AppTextOnAccent}"
                                                    Text="{Binding ActualPercentDisplay}" />
                                                <TextBlock
                                                    HorizontalAlignment="Center"
                                                    FontSize="{StaticResource Font.Size.Xs}"
                                                    FontWeight="SemiBold"
                                                    Foreground="{DynamicResource AppTextOnAccent}"
                                                    Text="{Binding PnlPercentTreemap}" />
                                            </StackPanel>
                                        </Border>
                                    </DataTemplate>
                                </ItemsControl.ItemTemplate>
                            </ItemsControl>
                        </Grid>
                    </Border>

                    <ItemsControl ItemsSource="{Binding AllocationRows}">
                        <ItemsControl.ItemTemplate>
                            <DataTemplate DataType="{x:Type vm:AllocationRowViewModel}">
                                <Border Style="{StaticResource FormCard}" Margin="0,0,0,10" Padding="14,12">
                                    <StackPanel>
                                        <DockPanel LastChildFill="True">
                                            <TextBlock
                                                Margin="0,0,6,0"
                                                DockPanel.Dock="Left"
                                                FontFamily="{StaticResource Font.Family.Base}"
                                                FontSize="{StaticResource Font.Size.Sm}"
                                                FontWeight="SemiBold"
                                                Foreground="{DynamicResource AppTextPrimary}"
                                                Text="{Binding Symbol}"
                                                Typography.NumeralAlignment="Tabular" />
                                            <TextBlock
                                                DockPanel.Dock="Right"
                                                FontFamily="{StaticResource Font.Family.Base}"
                                                FontSize="{StaticResource Font.Size.Sm}"
                                                FontWeight="SemiBold"
                                                Foreground="{DynamicResource AppTextPrimary}"
                                                Text="{Binding MarketValue, StringFormat='NT\${0:N0}'}"
                                                Typography.NumeralAlignment="Tabular" />
                                            <TextBlock
                                                FontSize="{StaticResource Font.Size.Sm}"
                                                Foreground="{DynamicResource AppTextSecondary}"
                                                Text="{Binding Name}"
                                                TextTrimming="CharacterEllipsis" />
                                        </DockPanel>

                                        <WrapPanel Margin="0,10,0,0">
                                            <Border
                                                Margin="0,0,8,8"
                                                Padding="8,6"
                                                Background="{DynamicResource AppBackground}"
                                                BorderBrush="{DynamicResource AppBorder}"
                                                BorderThickness="1"
                                                CornerRadius="{StaticResource Radius.Sm}">
                                                <StackPanel>
                                                    <TextBlock
                                                        FontSize="{StaticResource Font.Size.Xs}"
                                                        Foreground="{DynamicResource AppTextMuted}"
                                                        Text="{DynamicResource Portfolio.Allocation.Header.CurrentPrice}" />
                                                    <TextBlock
                                                        FontFamily="{StaticResource Font.Family.Base}"
                                                        FontSize="{StaticResource Font.Size.Sm}"
                                                        FontWeight="SemiBold"
                                                        Foreground="{DynamicResource AppTextPrimary}"
                                                        Text="{Binding CurrentPrice, StringFormat='NT\${0:N0}'}"
                                                        Typography.NumeralAlignment="Tabular" />
                                                </StackPanel>
                                            </Border>
                                            <Border
                                                Margin="0,0,8,8"
                                                Padding="8,6"
                                                Background="{DynamicResource AppBackground}"
                                                BorderBrush="{DynamicResource AppBorder}"
                                                BorderThickness="1"
                                                CornerRadius="{StaticResource Radius.Sm}">
                                                <StackPanel>
                                                    <TextBlock
                                                        FontSize="{StaticResource Font.Size.Xs}"
                                                        Foreground="{DynamicResource AppTextMuted}"
                                                        Text="{DynamicResource Portfolio.Allocation.Header.ActualVsTarget}" />
                                                    <TextBlock
                                                        FontFamily="{StaticResource Font.Family.Base}"
                                                        FontSize="{StaticResource Font.Size.Sm}"
                                                        FontWeight="SemiBold"
                                                        Foreground="{DynamicResource AppTextPrimary}"
                                                        Typography.NumeralAlignment="Tabular">
                                                        <Run Text="{Binding ActualPercentDisplay, Mode=OneWay}" />
                                                        <Run Text=" / " />
                                                        <Run Text="{Binding TargetPercent, StringFormat={}{0:F1}%, Mode=OneWay}" />
                                                    </TextBlock>
                                                </StackPanel>
                                            </Border>
                                            <Border
                                                Margin="0,0,8,8"
                                                Padding="8,6"
                                                Background="{DynamicResource AppBackground}"
                                                BorderBrush="{DynamicResource AppBorder}"
                                                BorderThickness="1"
                                                CornerRadius="{StaticResource Radius.Sm}">
                                                <StackPanel>
                                                    <TextBlock
                                                        FontSize="{StaticResource Font.Size.Xs}"
                                                        Foreground="{DynamicResource AppTextMuted}"
                                                        Text="{DynamicResource Portfolio.Allocation.Header.Deviation}" />
                                                    <TextBlock
                                                        FontFamily="{StaticResource Font.Family.Base}"
                                                        FontSize="{StaticResource Font.Size.Sm}"
                                                        FontWeight="SemiBold"
                                                        Text="{Binding DeviationDisplay}"
                                                        Typography.NumeralAlignment="Tabular">
                                                        <TextBlock.Style>
                                                            <Style TargetType="TextBlock">
                                                                <Setter Property="Foreground" Value="{DynamicResource AppTextMuted}" />
                                                                <Style.Triggers>
                                                                    <DataTrigger Binding="{Binding IsBuy}" Value="True">
                                                                        <Setter Property="Foreground" Value="{DynamicResource AppUp}" />
                                                                    </DataTrigger>
                                                                    <DataTrigger Binding="{Binding IsSell}" Value="True">
                                                                        <Setter Property="Foreground" Value="{DynamicResource AppDown}" />
                                                                    </DataTrigger>
                                                                </Style.Triggers>
                                                            </Style>
                                                        </TextBlock.Style>
                                                    </TextBlock>
                                                </StackPanel>
                                            </Border>
                                            <Border
                                                Margin="0,0,0,8"
                                                Padding="8,6"
                                                Background="{DynamicResource AppBackground}"
                                                BorderBrush="{DynamicResource AppBorder}"
                                                BorderThickness="1"
                                                CornerRadius="{StaticResource Radius.Sm}">
                                                <StackPanel>
                                                    <TextBlock
                                                        FontSize="{StaticResource Font.Size.Xs}"
                                                        Foreground="{DynamicResource AppTextMuted}"
                                                        Text="{DynamicResource Portfolio.Allocation.Header.Action}" />
                                                    <TextBlock
                                                        FontFamily="{StaticResource Font.Family.Base}"
                                                        FontSize="{StaticResource Font.Size.Sm}"
                                                        FontWeight="SemiBold"
                                                        Text="{Binding BuySellDisplay}"
                                                        Typography.NumeralAlignment="Tabular">
                                                        <TextBlock.Style>
                                                            <Style TargetType="TextBlock">
                                                                <Setter Property="Foreground" Value="{DynamicResource AppTextMuted}" />
                                                                <Style.Triggers>
                                                                    <DataTrigger Binding="{Binding IsBuy}" Value="True">
                                                                        <Setter Property="Foreground" Value="{DynamicResource AppUp}" />
                                                                    </DataTrigger>
                                                                    <DataTrigger Binding="{Binding IsSell}" Value="True">
                                                                        <Setter Property="Foreground" Value="{DynamicResource AppDown}" />
                                                                    </DataTrigger>
                                                                </Style.Triggers>
                                                            </Style>
                                                        </TextBlock.Style>
                                                    </TextBlock>
                                                </StackPanel>
                                            </Border>
                                        </WrapPanel>
                                    </StackPanel>
                                </Border>
                            </DataTemplate>
                        </ItemsControl.ItemTemplate>
                    </ItemsControl>
                </StackPanel>
            </ScrollViewer>
        </Grid>

        <!--  ── 再平衡 tab ──────────────────────────────────────────────────  -->
        <Grid
            Grid.Row="1"
            d:Visibility="Collapsed"
            Visibility="{Binding IsRebalanceTab, Converter={StaticResource BoolToVis}}">
            <Grid.RowDefinitions>
                <RowDefinition Height="Auto" />
                <!--  header card  -->
                <RowDefinition Height="Auto" />
                <!--  cash-flow info bar  -->
                <RowDefinition Height="Auto" />
                <!--  column headers  -->
                <RowDefinition Height="*" />
                <!--  rows  -->
            </Grid.RowDefinitions>

            <!--  Compact command bar  -->
            <Border
                Grid.Row="0"
                Margin="0,0,0,12"
                Padding="14,12"
                Style="{StaticResource FormCard}">
                <Grid>
                    <Grid.ColumnDefinitions>
                        <ColumnDefinition Width="*" />
                        <ColumnDefinition Width="Auto" />
                        <ColumnDefinition Width="Auto" />
                    </Grid.ColumnDefinitions>

                    <StackPanel Grid.Column="0" Margin="0,0,16,0">
                        <TextBlock
                            FontSize="{StaticResource Font.Size.Md}"
                            FontWeight="SemiBold"
                            Foreground="{DynamicResource AppTextPrimary}"
                            Text="{DynamicResource Allocation.Rebalance.Title}" />
                        <TextBlock
                            Margin="0,2,0,0"
                            FontSize="{StaticResource Font.Size.Xs}"
                            Foreground="{DynamicResource AppTextMuted}"
                            Text="{DynamicResource Allocation.Rebalance.Subtitle}"
                            TextWrapping="Wrap" />
                    </StackPanel>

                    <StackPanel
                        Grid.Column="1"
                        Margin="0,0,12,0"
                        VerticalAlignment="Center"
                        Orientation="Horizontal">
                        <Border
                            Padding="2"
                            Background="{DynamicResource AppBackground}"
                            BorderBrush="{DynamicResource AppBorder}"
                            BorderThickness="1"
                            CornerRadius="{StaticResource Radius.Md}">
                            <StackPanel Orientation="Horizontal">
                                <RadioButton
                                    Command="{Binding SetFullRebalanceCommand}"
                                    Content="{DynamicResource Allocation.Rebalance.Full}"
                                    GroupName="RebalanceMode"
                                    IsChecked="{Binding IsFullRebalance}"
                                    Style="{StaticResource AppSegmentButton}" />
                                <RadioButton
                                    Command="{Binding SetCashRebalanceCommand}"
                                    Content="{DynamicResource Allocation.Rebalance.CashFlow}"
                                    GroupName="RebalanceMode"
                                    IsChecked="{Binding IsCashRebalance}"
                                    Style="{StaticResource AppSegmentButton}" />
                            </StackPanel>
                        </Border>
                    </StackPanel>

                    <Button
                        Grid.Column="2"
                        MinHeight="34"
                        Padding="12,0"
                        VerticalAlignment="Center"
                        Command="{Binding BeginEditTargetsCommand}"
                        Style="{StaticResource AppSecondaryButton}">
                        <TextBlock Text="{DynamicResource Allocation.Rebalance.EditTargets}" />
                    </Button>
                </Grid>
            </Border>

            <!--  Cash-flow info bar (only when IsCashRebalance)  -->
            <Border Style="{StaticResource FormCard}"
                Grid.Row="1"
                Margin="0,0,0,16"
                Padding="16"
                Visibility="{Binding IsCashRebalance, Converter={StaticResource BoolToVis}}">
                <StackPanel>
                    <StackPanel Orientation="Horizontal">
                        <ds:AppIcon
                            Margin="0,0,6,0"
                            VerticalAlignment="Center"
                            FontSize="16"
                            Foreground="{DynamicResource AppAccent}"
                            Symbol="Money24" />
                        <StackPanel>
                            <TextBlock
                                FontSize="{StaticResource Font.Size.Sm}"
                                FontWeight="SemiBold"
                                Foreground="{DynamicResource AppTextPrimary}"
                                Text="{DynamicResource Allocation.Rebalance.CashFlow}" />
                            <TextBlock
                                FontSize="{StaticResource Font.Size.Xs}"
                                Foreground="{DynamicResource AppTextMuted}"
                                Text="{DynamicResource Allocation.CashFlow.Desc}"
                                TextWrapping="Wrap" />
                        </StackPanel>
                    </StackPanel>
                    <WrapPanel Margin="0,10,0,0">
                        <Border
                            Margin="0,0,8,8"
                            Padding="10,4"
                            Background="{DynamicResource AppAccent}"
                            CornerRadius="{StaticResource Radius.Sm}">
                            <TextBlock
                                VerticalAlignment="Center"
                                FontFamily="{StaticResource Font.Family.Base}"
                                FontSize="{StaticResource Font.Size.Sm}"
                                FontWeight="SemiBold"
                                Foreground="{DynamicResource AppTextOnAccent}"
                                Typography.NumeralAlignment="Tabular">
                                <Run Text="{DynamicResource Allocation.CashFlow.Total}" />
                                <Run Text="{Binding CashFlowTotal, Mode=OneWay, Converter={StaticResource CurrencyConverter}, ConverterParameter=amount}" />
                            </TextBlock>
                        </Border>
                        <Border
                            Margin="0,0,8,8"
                            Padding="8,4"
                            Background="{DynamicResource AppBackground}"
                            BorderBrush="{DynamicResource AppBorder}"
                            BorderThickness="1"
                            CornerRadius="{StaticResource Radius.Sm}">
                            <TextBlock
                                VerticalAlignment="Center"
                                FontSize="{StaticResource Font.Size.Xs}"
                                Foreground="{DynamicResource AppTextSecondary}"
                                Text="TWD" />
                        </Border>
                        <TextBlock
                            Margin="0,6,8,0"
                            VerticalAlignment="Center"
                            FontSize="{StaticResource Font.Size.Xs}"
                            Foreground="{DynamicResource AppTextSecondary}"
                            Text="{DynamicResource Allocation.CashFlow.InputLabel}" />
                        <TextBox
                            Width="100"
                            Margin="0,0,0,8"
                            HorizontalContentAlignment="Right"
                            FontFamily="{StaticResource Font.Family.Base}"
                            behaviors:ThousandSeparatorBehavior.IsEnabled="True"
                            Text="{Binding CashFlowInput, UpdateSourceTrigger=PropertyChanged}"
                            Typography.NumeralAlignment="Tabular" />
                    </WrapPanel>
                </StackPanel>
            </Border>

            <!--  Rebalance DataGrid (extracted)  -->
            <alloccontrols:RebalanceDataGrid Grid.Row="2" Grid.RowSpan="2" />
        </Grid>

        <!--  ── 編輯目標配置 overlay ────────────────────────────────────────  -->
        <alloccontrols:EditTargetsOverlay Grid.Row="0" Grid.RowSpan="2" />
    </Grid>
</UserControl>
