<UserControl
    x:Class="Assetra.WPF.Features.Portfolio.Controls.AddLoanDialog"
    xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
    xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
    xmlns:d="http://schemas.microsoft.com/expression/blend/2008"
    xmlns:mc="http://schemas.openxmlformats.org/markup-compatibility/2006"
    xmlns:vm="clr-namespace:Assetra.WPF.Features.Portfolio"
    d:DataContext="{d:DesignInstance Type={x:Type vm:PortfolioViewModel},
                                     IsDesignTimeCreatable=False}"
    Visibility="{Binding IsAddLoanDialogOpen, Converter={StaticResource BooleanToVisibilityConverter}}"
    mc:Ignorable="d">

    <Grid>
        <!--  Overlay  -->
        <Border Background="{DynamicResource AppModalOverlay}" />

        <!--  Dialog card  -->
        <Border
            Width="420"
            MaxHeight="600"
            HorizontalAlignment="Center"
            VerticalAlignment="Center"
            Background="{DynamicResource AppSurface}"
            BorderBrush="{DynamicResource AppBorder}"
            BorderThickness="1"
            CornerRadius="{StaticResource RadiusMd}">
            <Grid>
                <Grid.RowDefinitions>
                    <RowDefinition Height="Auto" />
                    <RowDefinition Height="*" />
                    <RowDefinition Height="Auto" />
                    <RowDefinition Height="Auto" />
                </Grid.RowDefinitions>

                <!--  Title  -->
                <Border
                    Grid.Row="0"
                    Padding="20,14"
                    BorderBrush="{DynamicResource AppBorder}"
                    BorderThickness="0,0,0,1">
                    <DockPanel>
                        <Button
                            Width="28"
                            Height="28"
                            HorizontalAlignment="Right"
                            Command="{Binding CloseAddLoanDialogCommand}"
                            DockPanel.Dock="Right"
                            Style="{StaticResource BtnIcon}">
                            <TextBlock
                                FontFamily="Segoe MDL2 Assets"
                                FontSize="12"
                                Foreground="{DynamicResource AppTextMuted}"
                                Text="&#xE8BB;" />
                        </Button>
                        <TextBlock
                            VerticalAlignment="Center"
                            FontSize="{StaticResource FontSizeSm}"
                            FontWeight="SemiBold"
                            Foreground="{DynamicResource AppTextPrimary}"
                            Text="{DynamicResource Portfolio.Loan.DialogTitle}" />
                    </DockPanel>
                </Border>

                <!--  Scrollable fields  -->
                <ScrollViewer
                    Grid.Row="1"
                    Padding="20,16,20,0"
                    VerticalScrollBarVisibility="Auto">
                    <StackPanel>

                        <!--  Loan name  -->
                        <TextBlock
                            Margin="0,0,0,6"
                            FontSize="{StaticResource FontSizeXs}"
                            FontWeight="SemiBold"
                            Foreground="{DynamicResource AppTextSecondary}"
                            Text="{DynamicResource Portfolio.Loan.Name}" />
                        <TextBox Style="{StaticResource FormTextBox}" Text="{Binding AddLoanName, UpdateSourceTrigger=PropertyChanged}" />

                        <!--  Principal amount  -->
                        <TextBlock
                            Margin="0,14,0,6"
                            FontSize="{StaticResource FontSizeXs}"
                            FontWeight="SemiBold"
                            Foreground="{DynamicResource AppTextSecondary}"
                            Text="{DynamicResource Portfolio.Loan.Amount}" />
                        <TextBox Style="{StaticResource FormTextBox}" Text="{Binding AddLoanAmount, UpdateSourceTrigger=PropertyChanged}" />

                        <!--  Annual rate  -->
                        <TextBlock
                            Margin="0,14,0,6"
                            FontSize="{StaticResource FontSizeXs}"
                            FontWeight="SemiBold"
                            Foreground="{DynamicResource AppTextSecondary}"
                            Text="{DynamicResource Portfolio.Loan.AnnualRate}" />
                        <TextBox Style="{StaticResource FormTextBox}" Text="{Binding AddLoanRate, UpdateSourceTrigger=PropertyChanged}" />

                        <!--  Term months  -->
                        <TextBlock
                            Margin="0,14,0,6"
                            FontSize="{StaticResource FontSizeXs}"
                            FontWeight="SemiBold"
                            Foreground="{DynamicResource AppTextSecondary}"
                            Text="{DynamicResource Portfolio.Loan.TermMonths}" />
                        <TextBox Style="{StaticResource FormTextBox}" Text="{Binding AddLoanTermMonths, UpdateSourceTrigger=PropertyChanged}" />

                        <!--  First payment date  -->
                        <TextBlock
                            Margin="0,14,0,6"
                            FontSize="{StaticResource FontSizeXs}"
                            FontWeight="SemiBold"
                            Foreground="{DynamicResource AppTextSecondary}"
                            Text="{DynamicResource Portfolio.Loan.StartDate}" />
                        <DatePicker
                            FontSize="{StaticResource FontSizeSm}"
                            Foreground="{DynamicResource AppTextPrimary}"
                            SelectedDate="{Binding AddLoanStartDate}" />

                        <!--  Handling fee  -->
                        <TextBlock
                            Margin="0,14,0,6"
                            FontSize="{StaticResource FontSizeXs}"
                            FontWeight="SemiBold"
                            Foreground="{DynamicResource AppTextSecondary}"
                            Text="{DynamicResource Portfolio.Loan.HandlingFee}" />
                        <TextBox Style="{StaticResource FormTextBox}" Text="{Binding AddLoanHandlingFee, UpdateSourceTrigger=PropertyChanged}" />

                        <TextBlock
                            Margin="0,6,0,0"
                            FontSize="{StaticResource FontSizeXs}"
                            Foreground="{DynamicResource AppTextMuted}"
                            Text="手續費將從撥入金額中扣除（不影響還款計算）"
                            TextWrapping="Wrap" />

                        <Rectangle Height="16" />
                    </StackPanel>
                </ScrollViewer>

                <!--  Error  -->
                <TextBlock
                    Grid.Row="2"
                    Margin="20,8,20,0"
                    FontSize="{StaticResource FontSizeXs}"
                    Foreground="{DynamicResource AppDown}"
                    Text="{Binding AddLoanError}"
                    Visibility="{Binding AddLoanError, Converter={StaticResource StringToVisibilityConverter}}" />

                <!--  Footer  -->
                <Border
                    Grid.Row="3"
                    Margin="0,8,0,0"
                    Padding="20,12"
                    BorderBrush="{DynamicResource AppBorder}"
                    BorderThickness="0,1,0,0">
                    <StackPanel HorizontalAlignment="Right" Orientation="Horizontal">
                        <Button
                            Height="30"
                            Margin="0,0,8,0"
                            Padding="14,0"
                            Command="{Binding CloseAddLoanDialogCommand}"
                            Style="{StaticResource BtnGhost}">
                            <TextBlock Foreground="{DynamicResource AppTextSecondary}" Text="{DynamicResource Common.Cancel}" />
                        </Button>
                        <Button
                            Height="30"
                            Padding="14,0"
                            Command="{Binding ConfirmAddLoanCommand}"
                            Style="{StaticResource BtnPrimary}">
                            <TextBlock Foreground="{Binding Foreground, RelativeSource={RelativeSource AncestorType=Button}}" Text="{DynamicResource Common.Confirm}" />
                        </Button>
                    </StackPanel>
                </Border>

            </Grid>
        </Border>
    </Grid>
</UserControl>
