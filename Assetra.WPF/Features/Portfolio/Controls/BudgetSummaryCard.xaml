<UserControl
    x:Class="Assetra.WPF.Features.Portfolio.Controls.BudgetSummaryCard"
    xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
    xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
    xmlns:d="http://schemas.microsoft.com/expression/blend/2008"
    xmlns:mc="http://schemas.openxmlformats.org/markup-compatibility/2006"
    xmlns:vm="clr-namespace:Assetra.WPF.Features.Portfolio"
    d:DataContext="{d:DesignInstance Type={x:Type vm:BudgetSummaryCardViewModel}}"
    mc:Ignorable="d">

    <Border Padding="16,12" Style="{StaticResource FormCard}">
        <StackPanel>
            <DockPanel Margin="0,0,0,10">
                <TextBlock
                    DockPanel.Dock="Left"
                    FontSize="{StaticResource Font.Size.Md}"
                    FontWeight="SemiBold"
                    Foreground="{DynamicResource AppTextPrimary}"
                    Text="{DynamicResource Dashboard.Budget.Title}" />
                <TextBlock
                    HorizontalAlignment="Right"
                    DockPanel.Dock="Right"
                    FontSize="{StaticResource Font.Size.Sm}"
                    Foreground="{DynamicResource AppTextMuted}"
                    Text="{Binding PeriodDisplay}" />
            </DockPanel>

            <!--  KPI row — 預算欄位（col 6）僅在 HasBudget=true 時佔欄寬 -->
            <Grid Margin="0,0,0,10">
                <Grid.ColumnDefinitions>
                    <ColumnDefinition Width="*" />
                    <ColumnDefinition Width="8" />
                    <ColumnDefinition Width="*" />
                    <ColumnDefinition Width="8" />
                    <ColumnDefinition Width="*" />
                    <ColumnDefinition>
                        <ColumnDefinition.Style>
                            <Style TargetType="ColumnDefinition">
                                <Setter Property="Width" Value="8" />
                                <Style.Triggers>
                                    <DataTrigger Binding="{Binding HasBudget}" Value="False">
                                        <Setter Property="Width" Value="0" />
                                    </DataTrigger>
                                </Style.Triggers>
                            </Style>
                        </ColumnDefinition.Style>
                    </ColumnDefinition>
                    <ColumnDefinition>
                        <ColumnDefinition.Style>
                            <Style TargetType="ColumnDefinition">
                                <Setter Property="Width" Value="*" />
                                <Style.Triggers>
                                    <DataTrigger Binding="{Binding HasBudget}" Value="False">
                                        <Setter Property="Width" Value="0" />
                                    </DataTrigger>
                                </Style.Triggers>
                            </Style>
                        </ColumnDefinition.Style>
                    </ColumnDefinition>
                </Grid.ColumnDefinitions>

                <StackPanel Grid.Column="0">
                    <TextBlock
                        FontSize="{StaticResource Font.Size.Xs}"
                        Foreground="{DynamicResource AppTextMuted}"
                        Text="{DynamicResource Dashboard.Budget.Income}" />
                    <TextBlock
                        FontSize="{StaticResource Font.Size.Lg}"
                        FontWeight="SemiBold"
                        Foreground="{DynamicResource AppUp}"
                        Text="{Binding TotalIncomeDisplay}" />
                </StackPanel>

                <StackPanel Grid.Column="2">
                    <TextBlock
                        FontSize="{StaticResource Font.Size.Xs}"
                        Foreground="{DynamicResource AppTextMuted}"
                        Text="{DynamicResource Dashboard.Budget.Expense}" />
                    <TextBlock
                        FontSize="{StaticResource Font.Size.Lg}"
                        FontWeight="SemiBold"
                        Foreground="{DynamicResource AppDown}"
                        Text="{Binding TotalExpenseDisplay}" />
                </StackPanel>

                <StackPanel Grid.Column="4">
                    <TextBlock
                        FontSize="{StaticResource Font.Size.Xs}"
                        Foreground="{DynamicResource AppTextMuted}"
                        Text="{DynamicResource Dashboard.Budget.Net}" />
                    <TextBlock
                        FontSize="{StaticResource Font.Size.Lg}"
                        FontWeight="SemiBold"
                        Text="{Binding NetCashFlowDisplay}">
                        <TextBlock.Style>
                            <Style BasedOn="{StaticResource {x:Type TextBlock}}" TargetType="TextBlock">
                                <Setter Property="Foreground" Value="{DynamicResource AppDown}" />
                                <Style.Triggers>
                                    <DataTrigger Binding="{Binding IsNetPositive}" Value="True">
                                        <Setter Property="Foreground" Value="{DynamicResource AppUp}" />
                                    </DataTrigger>
                                </Style.Triggers>
                            </Style>
                        </TextBlock.Style>
                    </TextBlock>
                </StackPanel>

                <StackPanel Grid.Column="6" Visibility="{Binding HasBudget, Converter={StaticResource BooleanToVisibilityConverter}}">
                    <TextBlock
                        FontSize="{StaticResource Font.Size.Xs}"
                        Foreground="{DynamicResource AppTextMuted}"
                        Text="{DynamicResource Dashboard.Budget.Budget}" />
                    <TextBlock
                        FontSize="{StaticResource Font.Size.Lg}"
                        FontWeight="SemiBold"
                        Foreground="{DynamicResource AppTextPrimary}"
                        Text="{Binding TotalBudgetDisplay}" />
                </StackPanel>
            </Grid>

            <!--  Budget bar — 僅在已設預算時顯示，避免空進度條混淆  -->
            <Grid Height="6" Margin="0,0,0,10" Visibility="{Binding HasBudget, Converter={StaticResource BooleanToVisibilityConverter}}">
                <Border Background="{DynamicResource AppBorderLight}" CornerRadius="{StaticResource Radius.Xs}" />
                <ProgressBar
                    Background="Transparent"
                    BorderThickness="0"
                    Foreground="{DynamicResource AppAccent}"
                    Maximum="1.0"
                    Minimum="0"
                    Value="{Binding BudgetUsageRatio, Mode=OneWay}" />
            </Grid>

            <TextBlock
                Margin="0,0,0,2"
                FontSize="{StaticResource Font.Size.Xs}"
                Foreground="{DynamicResource AppTextMuted}"
                Text="{DynamicResource Dashboard.Budget.Empty}"
                TextWrapping="Wrap">
                <TextBlock.Style>
                    <Style BasedOn="{StaticResource {x:Type TextBlock}}" TargetType="TextBlock">
                        <Setter Property="Visibility" Value="Collapsed" />
                        <Style.Triggers>
                            <DataTrigger Binding="{Binding HasData}" Value="False">
                                <Setter Property="Visibility" Value="Visible" />
                            </DataTrigger>
                        </Style.Triggers>
                    </Style>
                </TextBlock.Style>
            </TextBlock>

            <!--  Top categories  -->
            <ItemsControl ItemsSource="{Binding TopCategories}">
                <ItemsControl.ItemTemplate>
                    <DataTemplate>
                        <Grid Margin="0,2,0,2">
                            <Grid.ColumnDefinitions>
                                <ColumnDefinition Width="*" />
                                <ColumnDefinition Width="Auto" />
                                <ColumnDefinition Width="Auto" />
                            </Grid.ColumnDefinitions>
                            <TextBlock
                                Grid.Column="0"
                                FontSize="{StaticResource Font.Size.Sm}"
                                Foreground="{DynamicResource AppTextSecondary}"
                                Text="{Binding CategoryName}"
                                TextTrimming="CharacterEllipsis" />
                            <TextBlock
                                Grid.Column="1"
                                Margin="8,0,0,0"
                                FontFamily="{StaticResource Font.Family.Base}"
                                FontSize="{StaticResource Font.Size.Sm}"
                                Foreground="{DynamicResource AppTextPrimary}"
                                Text="{Binding Spent, StringFormat=NT$\{0:N0\}}"
                                Typography.NumeralAlignment="Tabular" />
                            <!--  預算（僅在分類有設預算時顯示，避免空字串「/NT」）  -->
                            <TextBlock
                                Grid.Column="2"
                                Margin="8,0,0,0"
                                FontFamily="{StaticResource Font.Family.Base}"
                                FontSize="{StaticResource Font.Size.Xs}"
                                Foreground="{DynamicResource AppTextMuted}"
                                Text="{Binding BudgetAmount, StringFormat=/ NT$\{0:N0\}}"
                                Typography.NumeralAlignment="Tabular"
                                Visibility="{Binding HasBudget, Converter={StaticResource BooleanToVisibilityConverter}}" />
                        </Grid>
                    </DataTemplate>
                </ItemsControl.ItemTemplate>
            </ItemsControl>
        </StackPanel>
    </Border>
</UserControl>
