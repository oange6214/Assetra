<UserControl
    x:Class="Assetra.WPF.Features.Portfolio.Controls.BudgetSummaryCard"
    xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
    xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
    xmlns:d="http://schemas.microsoft.com/expression/blend/2008"
    xmlns:mc="http://schemas.openxmlformats.org/markup-compatibility/2006"
    xmlns:vm="clr-namespace:Assetra.WPF.Features.Portfolio"
    d:DataContext="{d:DesignInstance Type={x:Type vm:BudgetSummaryCardViewModel}}"
    mc:Ignorable="d">

    <Border
        Padding="16,12"
        Background="{DynamicResource AppSurface}"
        BorderBrush="{DynamicResource AppBorderLight}"
        BorderThickness="1"
        CornerRadius="{StaticResource RadiusLg}">
        <StackPanel>
            <DockPanel Margin="0,0,0,10">
                <TextBlock
                    DockPanel.Dock="Left"
                    FontSize="{StaticResource FontSizeMd}"
                    FontWeight="SemiBold"
                    Foreground="{DynamicResource AppTextPrimary}"
                    Text="{DynamicResource Dashboard.Budget.Title}" />
                <TextBlock
                    HorizontalAlignment="Right"
                    DockPanel.Dock="Right"
                    FontSize="{StaticResource FontSizeSm}"
                    Foreground="{DynamicResource AppTextMuted}"
                    Text="{Binding PeriodDisplay}" />
            </DockPanel>

            <!--  KPI row  -->
            <Grid Margin="0,0,0,10">
                <Grid.ColumnDefinitions>
                    <ColumnDefinition Width="*" />
                    <ColumnDefinition Width="8" />
                    <ColumnDefinition Width="*" />
                    <ColumnDefinition Width="8" />
                    <ColumnDefinition Width="*" />
                    <ColumnDefinition Width="8" />
                    <ColumnDefinition Width="*" />
                </Grid.ColumnDefinitions>

                <StackPanel Grid.Column="0">
                    <TextBlock
                        FontSize="{StaticResource FontSizeXs}"
                        Foreground="{DynamicResource AppTextMuted}"
                        Text="{DynamicResource Dashboard.Budget.Income}" />
                    <TextBlock
                        FontSize="{StaticResource FontSizeLg}"
                        FontWeight="SemiBold"
                        Foreground="{DynamicResource AppUp}"
                        Text="{Binding TotalIncomeDisplay}" />
                </StackPanel>

                <StackPanel Grid.Column="2">
                    <TextBlock
                        FontSize="{StaticResource FontSizeXs}"
                        Foreground="{DynamicResource AppTextMuted}"
                        Text="{DynamicResource Dashboard.Budget.Expense}" />
                    <TextBlock
                        FontSize="{StaticResource FontSizeLg}"
                        FontWeight="SemiBold"
                        Foreground="{DynamicResource AppDown}"
                        Text="{Binding TotalExpenseDisplay}" />
                </StackPanel>

                <StackPanel Grid.Column="4">
                    <TextBlock
                        FontSize="{StaticResource FontSizeXs}"
                        Foreground="{DynamicResource AppTextMuted}"
                        Text="{DynamicResource Dashboard.Budget.Net}" />
                    <TextBlock
                        FontSize="{StaticResource FontSizeLg}"
                        FontWeight="SemiBold"
                        Text="{Binding NetCashFlowDisplay}">
                        <TextBlock.Style>
                            <Style BasedOn="{StaticResource {x:Type TextBlock}}" TargetType="TextBlock">
                                <Setter Property="Foreground" Value="{DynamicResource AppDown}" />
                                <Style.Triggers>
                                    <DataTrigger Binding="{Binding IsNetPositive}" Value="True">
                                        <Setter Property="Foreground" Value="{DynamicResource AppUp}" />
                                    </DataTrigger>
                                </Style.Triggers>
                            </Style>
                        </TextBlock.Style>
                    </TextBlock>
                </StackPanel>

                <StackPanel Grid.Column="6">
                    <TextBlock
                        FontSize="{StaticResource FontSizeXs}"
                        Foreground="{DynamicResource AppTextMuted}"
                        Text="{DynamicResource Dashboard.Budget.Budget}" />
                    <TextBlock
                        FontSize="{StaticResource FontSizeLg}"
                        FontWeight="SemiBold"
                        Foreground="{DynamicResource AppTextPrimary}"
                        Text="{Binding TotalBudgetDisplay}" />
                </StackPanel>
            </Grid>

            <!--  Budget bar  -->
            <Grid Height="6" Margin="0,0,0,10">
                <Border Background="{DynamicResource AppBorderLight}" CornerRadius="{StaticResource RadiusXs}" />
                <ProgressBar
                    Background="Transparent"
                    BorderThickness="0"
                    Foreground="{DynamicResource AppAccent}"
                    Maximum="1.0"
                    Minimum="0"
                    Value="{Binding BudgetUsageRatio, Mode=OneWay}" />
            </Grid>

            <!--  Top categories  -->
            <ItemsControl ItemsSource="{Binding TopCategories}">
                <ItemsControl.ItemTemplate>
                    <DataTemplate>
                        <Grid Margin="0,2,0,2">
                            <Grid.ColumnDefinitions>
                                <ColumnDefinition Width="*" />
                                <ColumnDefinition Width="Auto" />
                                <ColumnDefinition Width="Auto" />
                            </Grid.ColumnDefinitions>
                            <TextBlock
                                Grid.Column="0"
                                FontSize="{StaticResource FontSizeSm}"
                                Foreground="{DynamicResource AppTextSecondary}"
                                Text="{Binding CategoryName}"
                                TextTrimming="CharacterEllipsis" />
                            <TextBlock
                                Grid.Column="1"
                                Margin="8,0,0,0"
                                FontFamily="{StaticResource FontBase}"
                                FontSize="{StaticResource FontSizeSm}"
                                Foreground="{DynamicResource AppTextPrimary}"
                                Text="{Binding Spent, StringFormat=NT\{0:N0\}}"
                                Typography.NumeralAlignment="Tabular" />
                            <TextBlock
                                Grid.Column="2"
                                Margin="8,0,0,0"
                                FontSize="{StaticResource FontSizeXs}"
                                Foreground="{DynamicResource AppTextMuted}"
                                Text="{Binding BudgetAmount, StringFormat=/NT\{0:N0\}}" />
                        </Grid>
                    </DataTemplate>
                </ItemsControl.ItemTemplate>
            </ItemsControl>
        </StackPanel>
    </Border>
</UserControl>
