<UserControl
    x:Class="Assetra.WPF.Features.Portfolio.Controls.PortfolioHeaderPanel"
    xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
    xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
    xmlns:d="http://schemas.microsoft.com/expression/blend/2008"
    xmlns:mc="http://schemas.openxmlformats.org/markup-compatibility/2006"
    xmlns:vm="clr-namespace:Assetra.WPF.Features.Portfolio"
    d:DataContext="{d:DesignInstance Type={x:Type vm:PortfolioViewModel},
                                     IsDesignTimeCreatable=False}"
    mc:Ignorable="d">

    <Border
        Padding="16,12,16,14"
        Background="{DynamicResource AppSurface}"
        BorderBrush="{DynamicResource AppBorder}"
        BorderThickness="0,0,0,1">

        <Grid>
            <Grid.RowDefinitions>
                <RowDefinition Height="Auto" />
                <!--  Title + chart toggle  -->
                <RowDefinition Height="Auto" />
                <!--  Hero card  -->
                <RowDefinition Height="10" />
                <!--  Spacer  -->
                <RowDefinition Height="Auto" />
                <!--  Metric cards  -->
            </Grid.RowDefinitions>

            <!--  ── Row 0: (empty — title moved to PortfolioView) ──  -->

            <!--  ── Row 1: Hero card — 淨資產 + 本日盈虧 ──  -->
            <Border
                Grid.Row="1"
                Padding="16,12"
                Background="{DynamicResource AppBackground}"
                BorderBrush="{DynamicResource AppBorder}"
                BorderThickness="1"
                CornerRadius="{StaticResource RadiusMd}">
                <Grid>
                    <Grid.ColumnDefinitions>
                        <ColumnDefinition Width="*" />
                        <ColumnDefinition Width="Auto" />
                    </Grid.ColumnDefinitions>

                    <!--  Left: 淨資產  -->
                    <StackPanel Grid.Column="0">
                        <TextBlock
                            FontSize="{StaticResource FontSizeXs}"
                            Foreground="{DynamicResource AppTextMuted}"
                            Text="{DynamicResource Portfolio.Header.NetWorth}" />
                        <TextBlock
                            Margin="0,4,0,0"
                            FontFamily="{StaticResource FontTabular}"
                            FontSize="{StaticResource FontSize2xl}"
                            FontWeight="Bold"
                            Foreground="{DynamicResource AppTextPrimary}"
                            Text="{Binding NetWorth, Converter={StaticResource CurrencyConverter}, ConverterParameter=amount}" />
                        <!--  總資產 sub-line  -->
                        <StackPanel Margin="0,4,0,0" Orientation="Horizontal">
                            <TextBlock
                                FontSize="{StaticResource FontSizeXs}"
                                Foreground="{DynamicResource AppTextMuted}"
                                Text="{DynamicResource Portfolio.TotalAssets}" />
                            <TextBlock
                                Margin="6,0,0,0"
                                FontFamily="{StaticResource FontTabular}"
                                FontSize="{StaticResource FontSizeXs}"
                                Foreground="{DynamicResource AppTextSecondary}"
                                Text="{Binding TotalAssets, Converter={StaticResource CurrencyConverter}, ConverterParameter=amount}" />
                        </StackPanel>
                    </StackPanel>

                    <!--  Right: 本日盈虧  -->
                    <StackPanel
                        Grid.Column="1"
                        HorizontalAlignment="Right"
                        VerticalAlignment="Center">
                        <TextBlock
                            HorizontalAlignment="Right"
                            FontSize="{StaticResource FontSizeXs}"
                            Foreground="{DynamicResource AppTextMuted}"
                            Text="{DynamicResource Portfolio.Header.DailyPnL}" />

                        <!--  No data state  -->
                        <TextBlock
                            Margin="0,4,0,0"
                            HorizontalAlignment="Right"
                            d:Visibility="Visible"
                            FontFamily="{StaticResource FontTabular}"
                            FontSize="{StaticResource FontSizeLg}"
                            FontWeight="SemiBold"
                            Foreground="{DynamicResource AppTextMuted}"
                            Text="--"
                            Visibility="{Binding HasDayPnl, Converter={StaticResource InverseBooleanToVisibilityConverter}}" />

                        <!--  Amount  -->
                        <TextBlock
                            Margin="0,4,0,0"
                            HorizontalAlignment="Right"
                            d:Visibility="Collapsed"
                            FontFamily="{StaticResource FontTabular}"
                            FontSize="{StaticResource FontSizeLg}"
                            FontWeight="SemiBold"
                            Text="{Binding DayPnl, Converter={StaticResource CurrencyConverter}, ConverterParameter=signed}"
                            Visibility="{Binding HasDayPnl, Converter={StaticResource BooleanToVisibilityConverter}}">
                            <TextBlock.Style>
                                <Style TargetType="TextBlock">
                                    <Setter Property="Foreground" Value="{DynamicResource AppDown}" />
                                    <Style.Triggers>
                                        <DataTrigger Binding="{Binding IsDayPnlPositive}" Value="True">
                                            <Setter Property="Foreground" Value="{DynamicResource AppUp}" />
                                        </DataTrigger>
                                    </Style.Triggers>
                                </Style>
                            </TextBlock.Style>
                        </TextBlock>

                        <!--  Percentage  -->
                        <TextBlock
                            Margin="0,2,0,0"
                            HorizontalAlignment="Right"
                            FontFamily="{StaticResource FontTabular}"
                            FontSize="{StaticResource FontSizeSm}"
                            Text="{Binding DayPnlPercentDisplay}"
                            Visibility="{Binding HasDayPnl, Converter={StaticResource BooleanToVisibilityConverter}}">
                            <TextBlock.Style>
                                <Style TargetType="TextBlock">
                                    <Setter Property="Foreground" Value="{DynamicResource AppDown}" />
                                    <Style.Triggers>
                                        <DataTrigger Binding="{Binding IsDayPnlPositive}" Value="True">
                                            <Setter Property="Foreground" Value="{DynamicResource AppUp}" />
                                        </DataTrigger>
                                    </Style.Triggers>
                                </Style>
                            </TextBlock.Style>
                        </TextBlock>
                    </StackPanel>
                </Grid>
            </Border>

            <!--  ── Row 3: Three metric cards ──  -->
            <UniformGrid Grid.Row="3" Columns="3">

                <!--  Card 1: 總市值  -->
                <Border
                    Margin="{StaticResource CardMarginLeft}"
                    Padding="12,10"
                    Background="{DynamicResource AppBackground}"
                    BorderBrush="{DynamicResource AppBorder}"
                    BorderThickness="1"
                    CornerRadius="{StaticResource RadiusMd}">
                    <StackPanel>
                        <TextBlock
                            FontSize="{StaticResource FontSizeXs}"
                            Foreground="{DynamicResource AppTextMuted}"
                            Text="{DynamicResource Portfolio.Header.MarketValue}" />
                        <TextBlock
                            Margin="0,4,0,0"
                            FontFamily="{StaticResource FontTabular}"
                            FontSize="{StaticResource FontSizeLg}"
                            FontWeight="SemiBold"
                            Foreground="{DynamicResource AppTextPrimary}"
                            Text="{Binding TotalMarketValue, Converter={StaticResource CurrencyConverter}, ConverterParameter=amount}" />
                    </StackPanel>
                </Border>

                <!--  Card 2: 現金  -->
                <Border
                    Margin="{StaticResource CardMarginCenter}"
                    Padding="12,10"
                    Background="{DynamicResource AppBackground}"
                    BorderBrush="{DynamicResource AppBorder}"
                    BorderThickness="1"
                    CornerRadius="{StaticResource RadiusMd}">
                    <StackPanel>
                        <TextBlock
                            FontSize="{StaticResource FontSizeXs}"
                            Foreground="{DynamicResource AppTextMuted}"
                            Text="{DynamicResource Portfolio.Header.Cash}" />
                        <TextBlock
                            Margin="0,4,0,0"
                            FontFamily="{StaticResource FontTabular}"
                            FontSize="{StaticResource FontSizeLg}"
                            FontWeight="SemiBold"
                            Foreground="{DynamicResource AppTextPrimary}"
                            Text="{Binding TotalCash, Converter={StaticResource CurrencyConverter}, ConverterParameter=amount}" />
                    </StackPanel>
                </Border>

                <!--  Card 3: 負債  -->
                <Border
                    Margin="{StaticResource CardMarginRight}"
                    Padding="12,10"
                    Background="{DynamicResource AppBackground}"
                    BorderBrush="{DynamicResource AppBorder}"
                    BorderThickness="1"
                    CornerRadius="{StaticResource RadiusMd}">
                    <StackPanel>
                        <TextBlock
                            FontSize="{StaticResource FontSizeXs}"
                            Foreground="{DynamicResource AppTextMuted}"
                            Text="{DynamicResource Portfolio.Header.Liabilities}" />
                        <TextBlock
                            Margin="0,4,0,0"
                            FontFamily="{StaticResource FontTabular}"
                            FontSize="{StaticResource FontSizeLg}"
                            FontWeight="SemiBold"
                            Text="{Binding TotalLiabilities, Converter={StaticResource CurrencyConverter}, ConverterParameter=amount}">
                            <TextBlock.Style>
                                <Style TargetType="TextBlock">
                                    <Setter Property="Foreground" Value="{DynamicResource AppTextPrimary}" />
                                    <Style.Triggers>
                                        <DataTrigger Binding="{Binding HasNoLiabilities}" Value="False">
                                            <Setter Property="Foreground" Value="{DynamicResource AppDown}" />
                                        </DataTrigger>
                                    </Style.Triggers>
                                </Style>
                            </TextBlock.Style>
                        </TextBlock>
                    </StackPanel>
                </Border>
            </UniformGrid>
        </Grid>
    </Border>
</UserControl>
