<UserControl
    x:Class="Assetra.WPF.Features.Portfolio.Controls.SellPanel"
    xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
    xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
    xmlns:d="http://schemas.microsoft.com/expression/blend/2008"
    xmlns:mc="http://schemas.openxmlformats.org/markup-compatibility/2006"
    xmlns:vm="clr-namespace:Assetra.WPF.Features.Portfolio.SubViewModels"
    x:Name="Root"
    d:DataContext="{d:DesignInstance Type={x:Type vm:SellPanelViewModel},
                                     IsDesignTimeCreatable=False}"
    mc:Ignorable="d">
    <Grid>
        <Grid>
            <Grid.Visibility>
                <MultiBinding Converter="{StaticResource InverseWidthScaleThresholdToVisibilityConverter}" ConverterParameter="980">
                    <Binding ElementName="Root" Path="ActualWidth" />
                    <Binding Path="DataContext.Settings.UiScale" RelativeSource="{RelativeSource AncestorType=Window}" />
                </MultiBinding>
            </Grid.Visibility>
            <Grid.ColumnDefinitions>
                <ColumnDefinition Width="Auto" MinWidth="140" />
                <!--  Symbol + cost  -->
                <ColumnDefinition Width="Auto" />
                <!--  Price input  -->
                <ColumnDefinition Width="Auto" MinWidth="120" />
                <!--  Fee breakdown  -->
                <ColumnDefinition Width="Auto" MinWidth="140" />
                <!--  Cash account  -->
                <ColumnDefinition Width="*" />
                <!--  Spacer  -->
                <ColumnDefinition Width="Auto" />
                <!--  Buttons  -->
            </Grid.ColumnDefinitions>

            <!--  Symbol + cost info  -->
            <StackPanel
                Grid.Column="0"
                Margin="0,0,24,0"
                VerticalAlignment="Center">
                <TextBlock
                    FontFamily="{StaticResource FontTabular}"
                    FontSize="{StaticResource FontSizeMd}"
                    FontWeight="Bold"
                    Foreground="{DynamicResource AppDown}"
                    Text="{Binding SellingRow.Symbol}" />
                <TextBlock
                    Margin="0,2,0,0"
                    FontFamily="{StaticResource FontTabular}"
                    FontSize="{StaticResource FontSizeXs}"
                    Foreground="{DynamicResource AppTextMuted}">
                    <Run Text="{DynamicResource Portfolio.Sell.CostLabel}" /><Run Text=" " /><Run Text="{Binding SellingRow.BuyPrice, Converter={StaticResource CurrencyConverter}, ConverterParameter=price}" />
                </TextBlock>
            </StackPanel>

            <!--  Sell price input  -->
            <StackPanel
                Grid.Column="1"
                Margin="0,0,24,0"
                VerticalAlignment="Center">
                <TextBlock
                    Margin="0,0,0,4"
                    FontSize="{StaticResource FontSizeXs}"
                    FontWeight="SemiBold"
                    Foreground="{DynamicResource AppTextSecondary}"
                    Text="{DynamicResource Portfolio.SellConfirmLabel}" />
                <TextBox
                    Width="110"
                    Style="{StaticResource FormTextBox}"
                    Text="{Binding SellPriceInput, UpdateSourceTrigger=PropertyChanged}" />
            </StackPanel>

            <!--  Fee breakdown + Estimated P&L  -->
            <Grid
                Grid.Column="2"
                Margin="0,0,16,0"
                VerticalAlignment="Center">
                <Grid.ColumnDefinitions>
                    <ColumnDefinition Width="Auto" />
                    <ColumnDefinition Width="72" />
                </Grid.ColumnDefinitions>
                <Grid.RowDefinitions>
                    <RowDefinition Height="Auto" />
                    <RowDefinition Height="Auto" />
                    <RowDefinition Height="Auto" />
                    <RowDefinition Height="2" />
                    <RowDefinition Height="Auto" />
                </Grid.RowDefinitions>

                <!--  成交金額 label  -->
                <TextBlock
                    Grid.Row="0"
                    Grid.Column="0"
                    Margin="0,0,12,2"
                    FontSize="{StaticResource FontSizeXs}"
                    Foreground="{DynamicResource AppTextMuted}"
                    Text="{DynamicResource Portfolio.Sell.GrossAmount}" />
                <TextBlock
                    Grid.Row="0"
                    Grid.Column="1"
                    HorizontalAlignment="Right"
                    FontFamily="{StaticResource FontTabular}"
                    FontSize="{StaticResource FontSizeXs}"
                    Foreground="{DynamicResource AppTextSecondary}"
                    Text="{Binding SellGrossAmount, Converter={StaticResource CurrencyConverter}, ConverterParameter=amount}" />

                <!--  手續費  -->
                <TextBlock
                    Grid.Row="1"
                    Grid.Column="0"
                    Margin="0,0,12,2"
                    FontSize="{StaticResource FontSizeXs}"
                    Foreground="{DynamicResource AppTextMuted}"
                    Text="{DynamicResource Portfolio.Sell.Commission}" />
                <TextBlock
                    Grid.Row="1"
                    Grid.Column="1"
                    HorizontalAlignment="Right"
                    FontFamily="{StaticResource FontTabular}"
                    FontSize="{StaticResource FontSizeXs}"
                    Foreground="{DynamicResource AppDown}"
                    Text="{Binding SellCommission, Converter={StaticResource CurrencyConverter}, ConverterParameter=deduct}" />

                <!--  證交稅  -->
                <TextBlock
                    Grid.Row="2"
                    Grid.Column="0"
                    Margin="0,0,12,2"
                    FontSize="{StaticResource FontSizeXs}"
                    Foreground="{DynamicResource AppTextMuted}"
                    Text="{DynamicResource Portfolio.Sell.TransactionTax}" />
                <TextBlock
                    Grid.Row="2"
                    Grid.Column="1"
                    HorizontalAlignment="Right"
                    FontFamily="{StaticResource FontTabular}"
                    FontSize="{StaticResource FontSizeXs}"
                    Foreground="{DynamicResource AppDown}"
                    Text="{Binding SellTransactionTax, Converter={StaticResource CurrencyConverter}, ConverterParameter=deduct}" />

                <!--  Divider  -->
                <Rectangle
                    Grid.Row="3"
                    Grid.Column="0"
                    Grid.ColumnSpan="2"
                    Margin="0,4"
                    Fill="{DynamicResource AppBorder}" />

                <!--  淨所得 / 預估損益  -->
                <StackPanel
                    Grid.Row="4"
                    Grid.Column="0"
                    Margin="0,0,12,0"
                    VerticalAlignment="Center">
                    <TextBlock
                        FontSize="{StaticResource FontSizeXs}"
                        FontWeight="SemiBold"
                        Foreground="{DynamicResource AppTextSecondary}"
                        Text="{DynamicResource Portfolio.Sell.EstPnL}" />
                </StackPanel>
                <TextBlock
                    Grid.Row="4"
                    Grid.Column="1"
                    HorizontalAlignment="Right"
                    VerticalAlignment="Center"
                    FontFamily="{StaticResource FontTabular}"
                    FontSize="{StaticResource FontSizeSm}"
                    FontWeight="SemiBold"
                    Text="{Binding SellEstimatedPnl, Converter={StaticResource CurrencyConverter}, ConverterParameter=signed}">
                    <TextBlock.Style>
                        <Style TargetType="TextBlock">
                            <Setter Property="Foreground" Value="{DynamicResource AppDown}" />
                            <Style.Triggers>
                                <DataTrigger Binding="{Binding IsSellEstimatedPositive}" Value="True">
                                    <Setter Property="Foreground" Value="{DynamicResource AppUp}" />
                                </DataTrigger>
                            </Style.Triggers>
                        </Style>
                    </TextBlock.Style>
                </TextBlock>
            </Grid>

            <!--  入帳帳戶選擇  -->
            <StackPanel
                Grid.Column="3"
                Margin="0,0,16,0"
                VerticalAlignment="Center">
                <TextBlock
                    Margin="0,0,0,4"
                    FontSize="{StaticResource FontSizeXs}"
                    FontWeight="SemiBold"
                    Foreground="{DynamicResource AppTextSecondary}"
                    Text="{DynamicResource Portfolio.Sell.CashAccount}" />
                <ComboBox
                    Width="140"
                    DisplayMemberPath="Name"
                    ItemsSource="{Binding CashAccounts}"
                    SelectedItem="{Binding SellCashAccount, Mode=TwoWay}"
                    Style="{StaticResource FormComboBox}">
                    <ComboBox.Resources>
                        <Style BasedOn="{StaticResource FormComboBoxItem}" TargetType="ComboBoxItem" />
                    </ComboBox.Resources>
                </ComboBox>
                <TextBlock
                    Margin="0,2,0,0"
                    FontSize="{StaticResource FontSizeXs}"
                    Foreground="{DynamicResource AppTextMuted}"
                    Text="{DynamicResource Portfolio.Sell.NoCashLink}" />
            </StackPanel>

            <!--  Spacer  -->
            <Grid Grid.Column="4" />

            <!--  Action buttons  -->
            <StackPanel
                Grid.Column="5"
                VerticalAlignment="Center"
                Orientation="Horizontal">
                <StackPanel
                    Margin="0,0,10,0"
                    VerticalAlignment="Center"
                    Orientation="Horizontal"
                    Visibility="{Binding SellPanelError, Converter={StaticResource StringToVisibilityConverter}}">
                    <TextBlock
                        Margin="0,0,4,0"
                        VerticalAlignment="Center"
                        FontFamily="Segoe MDL2 Assets"
                        FontSize="11"
                        Foreground="{DynamicResource AppDown}"
                        Text="&#xE7BA;" />
                    <TextBlock
                        FontSize="{StaticResource FontSizeXs}"
                        Foreground="{DynamicResource AppDown}"
                        Text="{Binding SellPanelError}" />
                </StackPanel>
                <Button
                    Height="30"
                    Margin="0,0,8,0"
                    Padding="14,0"
                    VerticalAlignment="Center"
                    Command="{Binding ConfirmSellCommand}"
                    Style="{StaticResource BtnDanger}">
                    <TextBlock Foreground="{Binding Foreground, RelativeSource={RelativeSource AncestorType=Button}}" Text="{DynamicResource Portfolio.SellConfirm}" />
                </Button>
                <Button
                    Height="30"
                    Padding="10,0"
                    VerticalAlignment="Center"
                    Command="{Binding CancelSellCommand}"
                    Style="{StaticResource BtnGhost}">
                    <TextBlock Foreground="{Binding Foreground, RelativeSource={RelativeSource AncestorType=Button}}" Text="{DynamicResource Portfolio.Cancel}" />
                </Button>
            </StackPanel>
        </Grid>

        <StackPanel Margin="0,0,0,4">
            <StackPanel.Visibility>
                <MultiBinding Converter="{StaticResource WidthScaleThresholdToVisibilityConverter}" ConverterParameter="980">
                    <Binding ElementName="Root" Path="ActualWidth" />
                    <Binding Path="DataContext.Settings.UiScale" RelativeSource="{RelativeSource AncestorType=Window}" />
                </MultiBinding>
            </StackPanel.Visibility>

            <Border
                Padding="14,12"
                Background="{DynamicResource AppSurface}"
                BorderBrush="{DynamicResource AppBorder}"
                BorderThickness="1"
                CornerRadius="{StaticResource RadiusMd}">
                <StackPanel>
                    <TextBlock
                        FontFamily="{StaticResource FontTabular}"
                        FontSize="{StaticResource FontSizeLg}"
                        FontWeight="Bold"
                        Foreground="{DynamicResource AppDown}"
                        Text="{Binding SellingRow.Symbol}" />
                    <TextBlock
                        Margin="0,4,0,0"
                        FontSize="{StaticResource FontSizeXs}"
                        Foreground="{DynamicResource AppTextMuted}"
                        Text="{Binding SellingRow.Name}" />
                    <TextBlock
                        Margin="0,2,0,0"
                        FontFamily="{StaticResource FontTabular}"
                        FontSize="{StaticResource FontSizeXs}"
                        Foreground="{DynamicResource AppTextMuted}">
                        <Run Text="{DynamicResource Portfolio.Sell.CostLabel}" /><Run Text=" " /><Run Text="{Binding SellingRow.BuyPrice, Converter={StaticResource CurrencyConverter}, ConverterParameter=price}" />
                    </TextBlock>

                    <Grid Margin="0,14,0,0">
                        <Grid.ColumnDefinitions>
                            <ColumnDefinition Width="*" />
                            <ColumnDefinition Width="12" />
                            <ColumnDefinition Width="*" />
                        </Grid.ColumnDefinitions>
                        <StackPanel Grid.Column="0">
                            <TextBlock
                                Margin="0,0,0,4"
                                FontSize="{StaticResource FontSizeXs}"
                                FontWeight="SemiBold"
                                Foreground="{DynamicResource AppTextSecondary}"
                                Text="{DynamicResource Portfolio.SellConfirmLabel}" />
                            <TextBox Style="{StaticResource FormTextBox}" Text="{Binding SellPriceInput, UpdateSourceTrigger=PropertyChanged}" />
                        </StackPanel>
                        <StackPanel Grid.Column="2">
                            <TextBlock
                                Margin="0,0,0,4"
                                FontSize="{StaticResource FontSizeXs}"
                                FontWeight="SemiBold"
                                Foreground="{DynamicResource AppTextSecondary}"
                                Text="{DynamicResource Portfolio.Sell.CashAccount}" />
                            <ComboBox
                                DisplayMemberPath="Name"
                                ItemsSource="{Binding CashAccounts}"
                                SelectedItem="{Binding SellCashAccount, Mode=TwoWay}"
                                Style="{StaticResource FormComboBox}">
                                <ComboBox.Resources>
                                    <Style BasedOn="{StaticResource FormComboBoxItem}" TargetType="ComboBoxItem" />
                                </ComboBox.Resources>
                            </ComboBox>
                        </StackPanel>
                    </Grid>

                    <WrapPanel Margin="0,14,0,0" ItemWidth="160">
                        <Border
                            Margin="0,0,10,10"
                            Padding="10,8"
                            Background="{DynamicResource AppBackground}"
                            BorderBrush="{DynamicResource AppBorder}"
                            BorderThickness="1"
                            CornerRadius="{StaticResource RadiusSm}">
                            <StackPanel>
                                <TextBlock
                                    FontSize="{StaticResource FontSizeXs}"
                                    Foreground="{DynamicResource AppTextMuted}"
                                    Text="{DynamicResource Portfolio.Sell.GrossAmount}" />
                                <TextBlock
                                    Margin="0,2,0,0"
                                    FontFamily="{StaticResource FontTabular}"
                                    FontWeight="SemiBold"
                                    Text="{Binding SellGrossAmount, Converter={StaticResource CurrencyConverter}, ConverterParameter=amount}" />
                            </StackPanel>
                        </Border>
                        <Border
                            Margin="0,0,10,10"
                            Padding="10,8"
                            Background="{DynamicResource AppBackground}"
                            BorderBrush="{DynamicResource AppBorder}"
                            BorderThickness="1"
                            CornerRadius="{StaticResource RadiusSm}">
                            <StackPanel>
                                <TextBlock
                                    FontSize="{StaticResource FontSizeXs}"
                                    Foreground="{DynamicResource AppTextMuted}"
                                    Text="{DynamicResource Portfolio.Sell.Commission}" />
                                <TextBlock
                                    Margin="0,2,0,0"
                                    FontFamily="{StaticResource FontTabular}"
                                    FontWeight="SemiBold"
                                    Foreground="{DynamicResource AppDown}"
                                    Text="{Binding SellCommission, Converter={StaticResource CurrencyConverter}, ConverterParameter=deduct}" />
                            </StackPanel>
                        </Border>
                        <Border
                            Margin="0,0,10,10"
                            Padding="10,8"
                            Background="{DynamicResource AppBackground}"
                            BorderBrush="{DynamicResource AppBorder}"
                            BorderThickness="1"
                            CornerRadius="{StaticResource RadiusSm}">
                            <StackPanel>
                                <TextBlock
                                    FontSize="{StaticResource FontSizeXs}"
                                    Foreground="{DynamicResource AppTextMuted}"
                                    Text="{DynamicResource Portfolio.Sell.TransactionTax}" />
                                <TextBlock
                                    Margin="0,2,0,0"
                                    FontFamily="{StaticResource FontTabular}"
                                    FontWeight="SemiBold"
                                    Foreground="{DynamicResource AppDown}"
                                    Text="{Binding SellTransactionTax, Converter={StaticResource CurrencyConverter}, ConverterParameter=deduct}" />
                            </StackPanel>
                        </Border>
                        <Border
                            Margin="0,0,10,10"
                            Padding="10,8"
                            Background="{DynamicResource AppBackground}"
                            BorderBrush="{DynamicResource AppBorder}"
                            BorderThickness="1"
                            CornerRadius="{StaticResource RadiusSm}">
                            <StackPanel>
                                <TextBlock
                                    FontSize="{StaticResource FontSizeXs}"
                                    Foreground="{DynamicResource AppTextMuted}"
                                    Text="{DynamicResource Portfolio.Sell.EstPnL}" />
                                <TextBlock
                                    Margin="0,2,0,0"
                                    FontFamily="{StaticResource FontTabular}"
                                    FontWeight="SemiBold"
                                    Text="{Binding SellEstimatedPnl, Converter={StaticResource CurrencyConverter}, ConverterParameter=signed}">
                                    <TextBlock.Style>
                                        <Style TargetType="TextBlock">
                                            <Setter Property="Foreground" Value="{DynamicResource AppDown}" />
                                            <Style.Triggers>
                                                <DataTrigger Binding="{Binding IsSellEstimatedPositive}" Value="True">
                                                    <Setter Property="Foreground" Value="{DynamicResource AppUp}" />
                                                </DataTrigger>
                                            </Style.Triggers>
                                        </Style>
                                    </TextBlock.Style>
                                </TextBlock>
                            </StackPanel>
                        </Border>
                    </WrapPanel>

                    <TextBlock
                        Margin="0,2,0,0"
                        FontSize="{StaticResource FontSizeXs}"
                        Foreground="{DynamicResource AppTextMuted}"
                        Text="{DynamicResource Portfolio.Sell.NoCashLink}" />

                    <StackPanel
                        Margin="0,12,0,0"
                        Orientation="Vertical"
                        Visibility="{Binding SellPanelError, Converter={StaticResource StringToVisibilityConverter}}">
                        <StackPanel Orientation="Horizontal">
                            <TextBlock
                                Margin="0,0,4,0"
                                VerticalAlignment="Center"
                                FontFamily="Segoe MDL2 Assets"
                                FontSize="11"
                                Foreground="{DynamicResource AppDown}"
                                Text="&#xE7BA;" />
                            <TextBlock
                                FontSize="{StaticResource FontSizeXs}"
                                Foreground="{DynamicResource AppDown}"
                                Text="{Binding SellPanelError}" />
                        </StackPanel>
                    </StackPanel>

                    <StackPanel Margin="0,14,0,0">
                        <Button
                            Height="34"
                            Command="{Binding ConfirmSellCommand}"
                            Style="{StaticResource BtnDanger}">
                            <TextBlock Foreground="{Binding Foreground, RelativeSource={RelativeSource AncestorType=Button}}" Text="{DynamicResource Portfolio.SellConfirm}" />
                        </Button>
                        <Button
                            Height="34"
                            Margin="0,8,0,0"
                            Command="{Binding CancelSellCommand}"
                            Style="{StaticResource BtnGhost}">
                            <TextBlock Foreground="{Binding Foreground, RelativeSource={RelativeSource AncestorType=Button}}" Text="{DynamicResource Portfolio.Cancel}" />
                        </Button>
                    </StackPanel>
                </StackPanel>
            </Border>
        </StackPanel>
    </Grid>
</UserControl>
