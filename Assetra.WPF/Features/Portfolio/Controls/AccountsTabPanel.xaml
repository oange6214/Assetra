<UserControl
    x:Class="Assetra.WPF.Features.Portfolio.Controls.AccountsTabPanel"
    xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
    xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
    xmlns:behaviors="clr-namespace:Assetra.WPF.Infrastructure.Behaviors"
    xmlns:controls="clr-namespace:Assetra.WPF.Controls"
    xmlns:conv="clr-namespace:Assetra.WPF.Infrastructure.Converters"
    xmlns:d="http://schemas.microsoft.com/expression/blend/2008"
    xmlns:mc="http://schemas.openxmlformats.org/markup-compatibility/2006"
    xmlns:ds="clr-namespace:Assetra.WPF.DesignSystem.Controls"
    xmlns:vm="clr-namespace:Assetra.WPF.Features.Portfolio"
    d:DataContext="{d:DesignInstance Type={x:Type vm:PortfolioViewModel}}"
    mc:Ignorable="d">
    <UserControl.Resources>
        <conv:PercentToWidthConverter x:Key="PercentToWidthConverter" />
        <conv:StatusTagToBrushConverter x:Key="StatusTagToBrush" />
    </UserControl.Resources>

    <Grid>
        <Grid.RowDefinitions>
            <RowDefinition Height="Auto" />
            <!--  Emergency fund summary  -->
            <RowDefinition Height="Auto" />
            <!--  Text search  -->
            <RowDefinition Height="*" />
            <!--  DataGrid  -->
            <RowDefinition Height="Auto" />
            <!--  Filter summary footer  -->
        </Grid.RowDefinitions>

        <!--
            ═══ Row 0: Emergency Fund Summary ═══
            v3 redesign (2026-05-13)：
            - Outer bg AppSurface (白) → AppBackground (灰)，跟 datagrid 同色，符合
              card-on-background 設計慣例（跟負債 page 同步）。
            - 從 3 個 card 縮成 **2 個**：合併「緊急預備金 (月數)」+「安全等級 badge」
              成 1 個 card，仿照「槓桿健康度」layout：badge 在 card 右上角、月數 + 進度條 inline。
            - UniformGrid → Grid 2 等寬 column 自動延展填滿。
        -->
        <Border
            Grid.Row="0"
            Padding="{StaticResource Padding.SectionStrip}"
            Background="{DynamicResource AppBackground}"
            BorderBrush="{DynamicResource AppBorder}"
            BorderThickness="0,0,0,1">
            <Grid>
                <Grid.ColumnDefinitions>
                    <ColumnDefinition Width="*" />
                    <ColumnDefinition Width="*" />
                </Grid.ColumnDefinitions>

                <!--  Card 1: 每月預估開銷 (input)  -->
                <Border
                    Grid.Column="0"
                    MinHeight="80"
                    Margin="{StaticResource CardMarginLeft}"
                    Padding="{StaticResource Padding.Card}"
                    Background="{DynamicResource AppCardBackground}"
                    BorderBrush="{DynamicResource AppBorder}"
                    BorderThickness="1"
                    CornerRadius="{StaticResource Radius.Sm}">
                    <StackPanel>
                        <TextBlock
                            Margin="0,0,0,6"
                            FontSize="{StaticResource Font.Size.Xs}"
                            Foreground="{DynamicResource AppTextSecondary}"
                            Text="{DynamicResource Portfolio.Cash.Emergency.MonthlyExpense}" />
                        <TextBox
                            behaviors:ThousandSeparatorBehavior.IsEnabled="True"
                            Text="{Binding Financial.MonthlyExpense, UpdateSourceTrigger=PropertyChanged, StringFormat='{}{0:N0}'}" />
                        <TextBlock
                            Margin="0,6,0,0"
                            FontSize="{StaticResource Font.Size.Xs}"
                            Foreground="{DynamicResource AppTextMuted}"
                            Text="{DynamicResource Portfolio.Cash.Emergency.MonthlyExpenseHint}"
                            TextWrapping="Wrap"
                            Visibility="{Binding Financial.IsMonthlyExpenseSet, Converter={StaticResource InverseBooleanToVisibilityConverter}}" />
                    </StackPanel>
                </Border>

                <!--
                    Card 2 (merged): 緊急預備金 + 安全等級 badge.
                    結構鏡 LiabilityTabPanel 的「槓桿健康度」card：
                      - 標題列：title + ⓘ icon (left), 狀態 badge (right)
                      - 數值列：「8.5 個月」inline (大字 + 灰小字 label)
                      - 進度條：依 EmergencyStatusTag 著色
                      - 底部標籤：0個月 / 緊急預備金 / 12個月（建議水準）
                -->
                <Border
                    Grid.Column="1"
                    MinHeight="80"
                    Margin="{StaticResource CardMarginRight}"
                    Padding="{StaticResource Padding.Card}"
                    Background="{DynamicResource AppCardBackground}"
                    BorderBrush="{DynamicResource AppBorder}"
                    BorderThickness="1"
                    CornerRadius="{StaticResource Radius.Sm}">
                    <StackPanel>
                        <!--  Header: title + ⓘ (left) / status badge (right)  -->
                        <DockPanel Margin="0,0,0,8">
                            <StackPanel DockPanel.Dock="Left" Orientation="Horizontal" VerticalAlignment="Center">
                                <TextBlock
                                    VerticalAlignment="Center"
                                    FontSize="{StaticResource Font.Size.Xs}"
                                    Foreground="{DynamicResource AppTextSecondary}"
                                    Text="{DynamicResource Portfolio.Cash.Emergency.Title}" />
                                <ds:AppIcon
                                    Margin="4,0,0,0"
                                    VerticalAlignment="Center"
                                    FontSize="{StaticResource Font.Size.Xs}"
                                    Foreground="{DynamicResource AppTextMuted}"
                                    Symbol="Info24"
                                    ToolTip="{DynamicResource Portfolio.Cash.Emergency.MonthlyExpenseHint}" />
                            </StackPanel>
                            <!--
                                安全等級 badge — 只在 MonthlyExpense 已設定時顯示，否則
                                沒參考值，徽章內容毫無意義就乾脆隱藏。
                            -->
                            <Border
                                Padding="8,2"
                                HorizontalAlignment="Right"
                                Background="{DynamicResource AppSurface}"
                                BorderBrush="{DynamicResource AppBorder}"
                                BorderThickness="1"
                                CornerRadius="{StaticResource Radius.Lg}"
                                DockPanel.Dock="Right"
                                Visibility="{Binding Financial.IsMonthlyExpenseSet, Converter={StaticResource BooleanToVisibilityConverter}}">
                                <TextBlock
                                    FontSize="{StaticResource Font.Size.Xs}"
                                    FontWeight="SemiBold"
                                    Foreground="{Binding Financial.EmergencyStatusTag, Converter={StaticResource StatusTagToBrush}}">
                                    <TextBlock.Style>
                                        <Style TargetType="TextBlock">
                                            <Setter Property="Text" Value="{DynamicResource Portfolio.Cash.Emergency.Safe}" />
                                            <Style.Triggers>
                                                <DataTrigger Binding="{Binding Financial.EmergencyStatusTag}" Value="warning">
                                                    <Setter Property="Text" Value="{DynamicResource Portfolio.Cash.Emergency.Warning}" />
                                                </DataTrigger>
                                                <DataTrigger Binding="{Binding Financial.EmergencyStatusTag}" Value="danger">
                                                    <Setter Property="Text" Value="{DynamicResource Portfolio.Cash.Emergency.Danger}" />
                                                </DataTrigger>
                                            </Style.Triggers>
                                        </Style>
                                    </TextBlock.Style>
                                </TextBlock>
                            </Border>
                        </DockPanel>

                        <!--  Inline metric：「8.5」(big) 「個月」(small)  -->
                        <StackPanel Margin="0,0,0,10" Orientation="Horizontal" VerticalAlignment="Bottom">
                            <TextBlock
                                FontFamily="{StaticResource Font.Family.Base}"
                                FontSize="{StaticResource Font.Size.Lg}"
                                FontWeight="Bold"
                                Foreground="{Binding Financial.EmergencyStatusTag, Converter={StaticResource StatusTagToBrush}}"
                                Text="{Binding Financial.EmergencyFundMonthsDisplay, Mode=OneWay}"
                                Typography.NumeralAlignment="Tabular"
                                VerticalAlignment="Bottom" />
                            <TextBlock
                                Margin="6,0,0,0"
                                FontSize="{StaticResource Font.Size.Xs}"
                                Foreground="{DynamicResource AppTextMuted}"
                                Text="{DynamicResource Portfolio.Cash.Emergency.Months}"
                                Visibility="{Binding Financial.IsMonthlyExpenseSet, Converter={StaticResource BooleanToVisibilityConverter}}"
                                VerticalAlignment="Bottom" />
                            <TextBlock
                                Margin="6,0,0,0"
                                FontSize="{StaticResource Font.Size.Xs}"
                                Foreground="{DynamicResource AppTextMuted}"
                                Text="{DynamicResource Portfolio.Cash.Emergency.NotSet}"
                                Visibility="{Binding Financial.IsMonthlyExpenseSet, Converter={StaticResource InverseBooleanToVisibilityConverter}}"
                                VerticalAlignment="Bottom" />
                        </StackPanel>

                        <!--  Progress bar — 純色填充（status-coloured），無 tick marks  -->
                        <Grid Margin="0,0,0,4">
                            <Border
                                Height="6"
                                Background="{DynamicResource AppBorder}"
                                CornerRadius="{StaticResource Radius.Sm}" />
                            <Border
                                Height="6"
                                HorizontalAlignment="Left"
                                Background="{Binding Financial.EmergencyStatusTag, Converter={StaticResource StatusTagToBrush}}"
                                CornerRadius="{StaticResource Radius.Sm}">
                                <Border.Width>
                                    <MultiBinding Converter="{StaticResource PercentToWidthConverter}">
                                        <Binding Path="Financial.EmergencyFundBarValue" />
                                        <Binding Path="ActualWidth" RelativeSource="{RelativeSource AncestorType=Grid}" />
                                    </MultiBinding>
                                </Border.Width>
                            </Border>
                        </Grid>

                        <!--  Bottom labels — 仿槓桿健康度的「0% / 名稱 / 100%」三段式  -->
                        <Grid>
                            <Grid.ColumnDefinitions>
                                <ColumnDefinition Width="*" />
                                <ColumnDefinition Width="*" />
                                <ColumnDefinition Width="*" />
                            </Grid.ColumnDefinitions>
                            <TextBlock
                                Grid.Column="0"
                                HorizontalAlignment="Left"
                                FontSize="{StaticResource Font.Size.Xs}"
                                Foreground="{DynamicResource AppTextMuted}"
                                Text="0" />
                            <TextBlock
                                Grid.Column="1"
                                HorizontalAlignment="Center"
                                FontSize="{StaticResource Font.Size.Xs}"
                                Foreground="{DynamicResource AppTextMuted}"
                                Text="{DynamicResource Portfolio.Cash.Emergency.Title}" />
                            <TextBlock
                                Grid.Column="2"
                                HorizontalAlignment="Right"
                                FontSize="{StaticResource Font.Size.Xs}"
                                Foreground="{DynamicResource AppTextMuted}"
                                Text="12+" />
                        </Grid>
                    </StackPanel>
                </Border>
            </Grid>
        </Border>

        <controls:SearchBox
            Grid.Row="1"
            Placeholder="{DynamicResource Portfolio.Filter.SearchAccounts}"
            Text="{Binding CashFilterText}">
            <controls:SearchBox.RightContent>
                <StackPanel VerticalAlignment="Center" Orientation="Horizontal">
                    <CheckBox
                        Margin="0,0,8,0"
                        VerticalAlignment="Center"
                        IsChecked="{Binding Account.ShowArchivedAccounts}">
                        <TextBlock
                            FontSize="{StaticResource Font.Size.Xs}"
                            Foreground="{DynamicResource AppTextSecondary}"
                            Text="{DynamicResource Portfolio.Account.ShowArchived}" />
                    </CheckBox>
                    <Button
                        MinHeight="32"
                        Padding="10,0"
                        Command="{Binding OpenAddAccountDialogCommand}"
                        Style="{StaticResource AppSecondaryButton}">
                        <StackPanel Orientation="Horizontal">
                            <ds:AppIcon
                                Margin="0,0,6,0"
                                VerticalAlignment="Center"
                                FontSize="{StaticResource Font.Size.Xs}"
                                Symbol="Add24" />
                            <TextBlock VerticalAlignment="Center" Text="{DynamicResource Portfolio.AddCash}" />
                        </StackPanel>
                    </Button>
                </StackPanel>
            </controls:SearchBox.RightContent>
        </controls:SearchBox>

        <!--  ═══ Cash Accounts DataGrid ═══  -->
        <Grid Grid.Row="2">
            <!--  Empty state  -->
            <Border
                Padding="32"
                Background="{DynamicResource AppBackground}"
                Visibility="{Binding HasNoCashAccounts, Converter={StaticResource BooleanToVisibilityConverter}}">
                <StackPanel HorizontalAlignment="Center" VerticalAlignment="Center">
                    <StackPanel HorizontalAlignment="Center" Opacity="0.4">
                        <TextBlock
                            Margin="0,0,0,6"
                            HorizontalAlignment="Center"
                            FontSize="{StaticResource Font.Size.2xl}"
                            Text="&#x1F4B0;" />
                        <TextBlock
                            HorizontalAlignment="Center"
                            FontSize="{StaticResource Font.Size.Sm}"
                            Foreground="{DynamicResource AppTextSecondary}"
                            Text="{DynamicResource Portfolio.Cash.Empty}" />
                    </StackPanel>
                    <Button
                        Height="36"
                        Margin="0,16,0,0"
                        Padding="20,0"
                        HorizontalAlignment="Center"
                        Command="{Binding OpenAddAccountDialogCommand}"
                        Style="{StaticResource AppPrimaryButton}">
                        <TextBlock Foreground="{Binding Foreground, RelativeSource={RelativeSource AncestorType=Button}}" Text="{DynamicResource Portfolio.AddCash.Full}" />
                    </Button>
                </StackPanel>
            </Border>

            <DataGrid
                x:Name="CashGrid"
                AlternationCount="2"
                AutoGenerateColumns="False"
                Background="{DynamicResource AppBackground}"
                BorderThickness="0"
                CanUserAddRows="False"
                CanUserDeleteRows="False"
                CanUserReorderColumns="False"
                CanUserResizeColumns="False"
                CanUserSortColumns="True"
                ColumnHeaderHeight="{StaticResource DataGrid.HeaderHeight}"
                EnableRowVirtualization="True"
                FontFamily="{StaticResource Font.Family.Base}"
                FontSize="{StaticResource Font.Size.Sm}"
                Foreground="{DynamicResource AppTextPrimary}"
                GridLinesVisibility="None"
                HeadersVisibility="Column"
                HorizontalScrollBarVisibility="Auto"
                IsReadOnly="True"
                ItemsSource="{Binding CashAccountsView}"
                PreviewMouseDown="OnGridPreviewMouseDown"
                RowHeight="{StaticResource DataGrid.RowHeight}"
                SelectedItem="{Binding SelectedCashRow, Mode=TwoWay}"
                SelectionMode="Single"
                VirtualizingPanel.IsVirtualizing="True"
                VirtualizingPanel.VirtualizationMode="Recycling">

                <DataGrid.ColumnHeaderStyle>
                    <Style BasedOn="{StaticResource AppDataGridColHeader}" TargetType="DataGridColumnHeader" />
                </DataGrid.ColumnHeaderStyle>
                <DataGrid.CellStyle>
                    <Style BasedOn="{StaticResource AppDataGridCell}" TargetType="DataGridCell" />
                </DataGrid.CellStyle>
                <DataGrid.RowStyle>
                    <Style BasedOn="{StaticResource AppDataGridRowSelectable}" TargetType="DataGridRow">
                        <!--
                            Tag 傳遞父 VM 給 ContextMenu（visual tree 之外的 popup）。
                            ContextMenu 為「右鍵備援」: 主動作集中側邊面板，但 power user
                            可右鍵直接觸發編輯/封存/永久刪除三項。
                        -->
                        <Setter Property="Tag" Value="{Binding DataContext, RelativeSource={RelativeSource AncestorType=DataGrid}}" />
                        <Setter Property="ContextMenu">
                            <Setter.Value>
                                <ContextMenu>
                                    <MenuItem
                                        Command="{Binding PlacementTarget.Tag.Account.OpenEditCashCommand, RelativeSource={RelativeSource AncestorType=ContextMenu}}"
                                        CommandParameter="{Binding}"
                                        Header="{DynamicResource Common.Edit}" />
                                    <MenuItem
                                        Command="{Binding PlacementTarget.Tag.Account.ToggleArchiveCommand, RelativeSource={RelativeSource AncestorType=ContextMenu}}"
                                        CommandParameter="{Binding}">
                                        <MenuItem.Style>
                                            <Style TargetType="MenuItem">
                                                <Setter Property="Header" Value="{DynamicResource Portfolio.Account.Archive}" />
                                                <Style.Triggers>
                                                    <DataTrigger Binding="{Binding IsActive}" Value="False">
                                                        <Setter Property="Header" Value="{DynamicResource Portfolio.Account.Unarchive}" />
                                                    </DataTrigger>
                                                </Style.Triggers>
                                            </Style>
                                        </MenuItem.Style>
                                    </MenuItem>
                                    <Separator />
                                    <MenuItem
                                        Command="{Binding PlacementTarget.Tag.Account.RemoveCashAccountCommand, RelativeSource={RelativeSource AncestorType=ContextMenu}}"
                                        CommandParameter="{Binding}"
                                        Header="{DynamicResource Portfolio.Account.PermanentDelete}" />
                                </ContextMenu>
                            </Setter.Value>
                        </Setter>
                    </Style>
                </DataGrid.RowStyle>

                <DataGrid.Columns>
                    <!--
                        名稱欄 — 改為純名稱（搭幣別小字 + 預設星號），不再內嵌類別 chip。
                        類別獨立成下方「類別」欄，更易掃讀與排序。
                    -->
                    <DataGridTemplateColumn Width="*" SortMemberPath="Name">
                        <DataGridTemplateColumn.Header>
                            <TextBlock Text="{DynamicResource Common.Name}" />
                        </DataGridTemplateColumn.Header>
                        <DataGridTemplateColumn.CellTemplate>
                            <DataTemplate>
                                <StackPanel VerticalAlignment="Center" Orientation="Horizontal">
                                    <!--  預設帳戶以星號圖示前置；非預設不佔空間  -->
                                    <ds:AppIcon Margin="0,0,6,0" VerticalAlignment="Center"
                                                FontSize="13"
                                                Foreground="{DynamicResource AppAccent}"
                                                Symbol="Star24"
                                                ToolTip="{DynamicResource Portfolio.Cash.DefaultHint}"
                                                Visibility="{Binding IsDefault, Converter={StaticResource BooleanToVisibilityConverter}}" />
                                    <StackPanel>
                                        <TextBlock
                                            FontWeight="SemiBold"
                                            Foreground="{DynamicResource AppTextPrimary}"
                                            Text="{Binding Name}"
                                            TextTrimming="CharacterEllipsis" />
                                        <TextBlock
                                            Margin="0,2,0,0"
                                            FontFamily="{StaticResource Font.Family.Base}"
                                            FontSize="{StaticResource Font.Size.Xs}"
                                            Foreground="{DynamicResource AppTextMuted}"
                                            Text="{Binding Currency}"
                                            Typography.NumeralAlignment="Tabular" />
                                    </StackPanel>
                                </StackPanel>
                            </DataTemplate>
                        </DataGridTemplateColumn.CellTemplate>
                    </DataGridTemplateColumn>

                    <!--  類別 — 細分類（手邊現金 / 銀行活存 / 數位活存 / 證券交割戶 / ...）  -->
                    <DataGridTemplateColumn Width="140" SortMemberPath="Subtype">
                        <DataGridTemplateColumn.Header>
                            <TextBlock Text="{DynamicResource Portfolio.Cash.Subtype}" />
                        </DataGridTemplateColumn.Header>
                        <DataGridTemplateColumn.CellTemplate>
                            <DataTemplate>
                                <TextBlock
                                    VerticalAlignment="Center"
                                    FontSize="{StaticResource Font.Size.Sm}"
                                    Foreground="{DynamicResource AppTextSecondary}"
                                    Text="{Binding Subtype, FallbackValue='—'}"
                                    TextTrimming="CharacterEllipsis" />
                            </DataTemplate>
                        </DataGridTemplateColumn.CellTemplate>
                    </DataGridTemplateColumn>

                    <!--  市值 (原「餘額」— 與投資/負債分頁統一)  -->
                    <DataGridTemplateColumn Width="200" SortMemberPath="Balance">
                        <DataGridTemplateColumn.HeaderStyle>
                            <Style BasedOn="{StaticResource AppDataGridColHeader}" TargetType="DataGridColumnHeader">
                                <Setter Property="HorizontalContentAlignment" Value="Right" />
                            </Style>
                        </DataGridTemplateColumn.HeaderStyle>
                        <DataGridTemplateColumn.Header>
                            <TextBlock Text="{DynamicResource Common.MarketValue}" />
                        </DataGridTemplateColumn.Header>
                        <DataGridTemplateColumn.CellTemplate>
                            <DataTemplate>
                                <TextBlock
                                    VerticalAlignment="Center"
                                    FontFamily="{StaticResource Font.Family.Base}"
                                    FontWeight="SemiBold"
                                    Foreground="{DynamicResource AppTextPrimary}"
                                    Text="{Binding Balance, Converter={StaticResource CurrencyConverter}, ConverterParameter=amount}"
                                    TextAlignment="Right"
                                    Typography.NumeralAlignment="Tabular" />
                            </DataTemplate>
                        </DataGridTemplateColumn.CellTemplate>
                    </DataGridTemplateColumn>

                    <!--
                        佔比欄取代「建立日期」 — 後者屬於冷資訊（一次性，使用者鮮少回頭看）。
                        百分比由 PortfolioViewModel.RebuildTotals 統一回寫到 row.PercentOfTotal。
                    -->
                    <DataGridTemplateColumn Width="140" SortMemberPath="PercentOfTotal">
                        <DataGridTemplateColumn.HeaderStyle>
                            <Style BasedOn="{StaticResource AppDataGridColHeader}" TargetType="DataGridColumnHeader">
                                <Setter Property="HorizontalContentAlignment" Value="Right" />
                            </Style>
                        </DataGridTemplateColumn.HeaderStyle>
                        <DataGridTemplateColumn.Header>
                            <TextBlock Text="{DynamicResource Portfolio.PercentOfPortfolio}" />
                        </DataGridTemplateColumn.Header>
                        <DataGridTemplateColumn.CellTemplate>
                            <DataTemplate>
                                <StackPanel Margin="0,0,8,0" VerticalAlignment="Center">
                                    <TextBlock
                                        HorizontalAlignment="Right"
                                        FontFamily="{StaticResource Font.Family.Base}"
                                        FontSize="{StaticResource Font.Size.Sm}"
                                        Foreground="{DynamicResource AppTextSecondary}"
                                        Text="{Binding PercentOfTotal, StringFormat={}{0:F1}%}"
                                        Typography.NumeralAlignment="Tabular" />
                                    <Grid Height="3" Margin="0,3,0,0">
                                        <Border Background="{DynamicResource AppBorder}" CornerRadius="1.5" />
                                        <Border
                                            HorizontalAlignment="Left"
                                            Background="{DynamicResource AppAccent}"
                                            CornerRadius="1.5">
                                            <Border.Width>
                                                <MultiBinding Converter="{StaticResource PercentToWidthConverter}">
                                                    <Binding Path="PercentOfTotal" />
                                                    <Binding Path="ActualWidth" RelativeSource="{RelativeSource AncestorType=Grid}" />
                                                </MultiBinding>
                                            </Border.Width>
                                        </Border>
                                    </Grid>
                                </StackPanel>
                            </DataTemplate>
                        </DataGridTemplateColumn.CellTemplate>
                    </DataGridTemplateColumn>

                    <!--
                        Row actions column removed (v0.28+): all account operations
                        consolidated into the side detail panel toolbar (⭐ ✏ 📦 ✕)
                        and the right-click context menu (編輯 / 封存 / 永久刪除).
                        Permanent delete intentionally stays in right-click only —
                        destructive action should not have a constant primary-UI footprint.
                    -->
                </DataGrid.Columns>
            </DataGrid>
        </Grid>

        <!--
            ═══ Row 3: Filter Summary Footer ═══
            篩選作用中才顯示（搜尋有字）。顯示「筆數 + 篩選後總餘額」。
        -->
        <!--  永遠顯示總和（搜尋無字時也是「全部」這個篩選結果）  -->
        <Border Grid.Row="3"
                Padding="12,6"
                Background="{DynamicResource AppSurface}"
                BorderBrush="{DynamicResource AppBorder}"
                BorderThickness="0,1,0,0">
            <StackPanel Orientation="Horizontal">
                <StackPanel Margin="0,0,24,0" Orientation="Horizontal">
                    <TextBlock Margin="0,0,6,0" VerticalAlignment="Center"
                               FontSize="{StaticResource Font.Size.Xs}"
                               Foreground="{DynamicResource AppTextMuted}"
                               Text="{DynamicResource Portfolio.Filter.Summary.Count}" />
                    <TextBlock VerticalAlignment="Center"
                               FontFamily="{StaticResource Font.Family.Base}"
                               FontSize="{StaticResource Font.Size.Sm}"
                               FontWeight="SemiBold"
                               Foreground="{DynamicResource AppTextPrimary}"
                               Text="{Binding CashAccountsFilteredCount, StringFormat={}{0:N0}}"
                               Typography.NumeralAlignment="Tabular" />
                </StackPanel>
                <StackPanel Orientation="Horizontal">
                    <TextBlock Margin="0,0,6,0" VerticalAlignment="Center"
                               FontSize="{StaticResource Font.Size.Xs}"
                               Foreground="{DynamicResource AppTextMuted}"
                               Text="{DynamicResource Portfolio.Filter.Summary.Balance}" />
                    <TextBlock VerticalAlignment="Center"
                               FontFamily="{StaticResource Font.Family.Base}"
                               FontSize="{StaticResource Font.Size.Sm}"
                               FontWeight="SemiBold"
                               Foreground="{DynamicResource AppTextPrimary}"
                               Text="{Binding CashAccountsFilteredBalance, Converter={StaticResource CurrencyConverter}, ConverterParameter=amount}"
                               Typography.NumeralAlignment="Tabular" />
                </StackPanel>
            </StackPanel>
        </Border>

        <!--
            P4.9i — Cash detail overlay 從 MainWindow shell 搬到 AccountsTabPanel 內，
            跟 Position 一樣 page-scoped — 切到別 nav 區段時自動隨 panel unload 消失。
            DataContext = PortfolioViewModel (panel root)；HasSelectedCashRow gate
            走 SelectedCashRow，沒選不會渲染。RowSpan=4 覆蓋 panel 全部 4 個 row。
        -->
        <Grid Grid.RowSpan="4" Panel.ZIndex="180" Visibility="{Binding HasSelectedCashRow, Converter={StaticResource BooleanToVisibilityConverter}}">
            <!--  Click-to-close backdrop  -->
            <Border behaviors:BackdropClickToCloseBehavior.Command="{Binding CloseCashDetailCommand}" Style="{StaticResource AppDialogOverlayBorder}" />

            <!--  Floating panel anchored right  -->
            <Border
                HorizontalAlignment="Right"
                Background="{DynamicResource AppSurface}"
                BorderBrush="{DynamicResource AppBorder}"
                BorderThickness="1,0,0,0">
                <Border.Width>
                    <!--  P4.9 — Position / Cash / Liability detail panel 統一寬度 `0.55/520/820`  -->
                    <MultiBinding Converter="{StaticResource AdaptivePanelWidthConverter}" ConverterParameter="0.55|520|820">
                        <Binding Path="ActualWidth" RelativeSource="{RelativeSource AncestorType=Window}" />
                        <Binding Path="DataContext.Settings.UiScale" RelativeSource="{RelativeSource AncestorType=Window}" />
                    </MultiBinding>
                </Border.Width>
                <Grid>
                    <Grid.RowDefinitions>
                        <RowDefinition Height="Auto" />
                        <RowDefinition Height="Auto" />
                        <RowDefinition Height="*" />
                        <RowDefinition Height="Auto" />
                    </Grid.RowDefinitions>

                    <!--  Header  -->
                    <Border
                        Grid.Row="0"
                        Padding="16,14"
                        BorderBrush="{DynamicResource AppBorder}"
                        BorderThickness="0,0,0,1">
                        <StackPanel>
                        <DockPanel LastChildFill="True">
                            <!--  Close  -->
                            <Button
                                Width="30"
                                Height="36"
                                Margin="6,0,0,0"
                                Padding="0"
                                VerticalAlignment="Center"
                                Command="{Binding CloseCashDetailCommand}"
                                DockPanel.Dock="Right"
                                Style="{StaticResource AppIconButton}"
                                ToolTip="{DynamicResource Common.Close}">
                                <ds:AppIcon
                                    FontSize="11"
                                    Foreground="{DynamicResource AppTextSecondary}"
                                    Symbol="Dismiss24" />
                            </Button>
                            <!--  Edit pencil → opens shared EditAssetDialog  -->
                            <Button
                                Width="30"
                                Height="36"
                                Padding="0"
                                VerticalAlignment="Center"
                                Command="{Binding Account.OpenEditCashCommand}"
                                CommandParameter="{Binding SelectedCashRow}"
                                DockPanel.Dock="Right"
                                Style="{StaticResource AppIconButton}"
                                ToolTip="{DynamicResource Common.Edit}">
                                <ds:AppIcon
                                    FontSize="12"
                                    Foreground="{DynamicResource AppTextPrimary}"
                                    Symbol="Edit24" />
                            </Button>
                            <!--  設為預設 / 取消預設 toggle  -->
                            <Button
                                Width="30"
                                Height="36"
                                Margin="0,0,4,0"
                                VerticalAlignment="Center"
                                Command="{Binding Account.ToggleDefaultCashAccountCommand}"
                                CommandParameter="{Binding SelectedCashRow}"
                                DockPanel.Dock="Right">
                                <Button.Style>
                                    <Style BasedOn="{StaticResource AppIconButton}" TargetType="{x:Type Button}">
                                        <Setter Property="ToolTip" Value="{DynamicResource Portfolio.Cash.SetDefault}" />
                                        <Style.Triggers>
                                            <DataTrigger Binding="{Binding SelectedCashRow.IsDefault}" Value="True">
                                                <Setter Property="ToolTip" Value="{DynamicResource Portfolio.Cash.UnsetDefault}" />
                                            </DataTrigger>
                                        </Style.Triggers>
                                    </Style>
                                </Button.Style>
                                <ds:AppIcon FontSize="12" Symbol="Star24">
                                    <ds:AppIcon.Style>
                                        <Style BasedOn="{StaticResource AppIcon}" TargetType="{x:Type ds:AppIcon}">
                                            <Setter Property="Foreground" Value="{DynamicResource AppTextSecondary}" />
                                            <Setter Property="Filled" Value="False" />
                                            <Style.Triggers>
                                                <DataTrigger Binding="{Binding SelectedCashRow.IsDefault}" Value="True">
                                                    <Setter Property="Filled" Value="True" />
                                                    <Setter Property="Foreground" Value="{DynamicResource AppAccent}" />
                                                </DataTrigger>
                                            </Style.Triggers>
                                        </Style>
                                    </ds:AppIcon.Style>
                                </ds:AppIcon>
                            </Button>
                            <!--  封存 / 取消封存 toggle (依 IsActive 切標籤與圖示)  -->
                            <Button
                                Width="30"
                                Height="36"
                                Margin="0,0,4,0"
                                VerticalAlignment="Center"
                                Command="{Binding Account.ToggleArchiveCommand}"
                                CommandParameter="{Binding SelectedCashRow}"
                                DockPanel.Dock="Right">
                                <Button.Style>
                                    <Style BasedOn="{StaticResource AppIconButton}" TargetType="{x:Type Button}">
                                        <Setter Property="ToolTip" Value="{DynamicResource Portfolio.Account.Archive}" />
                                        <Style.Triggers>
                                            <DataTrigger Binding="{Binding SelectedCashRow.IsActive}" Value="False">
                                                <Setter Property="ToolTip" Value="{DynamicResource Portfolio.Account.Unarchive}" />
                                            </DataTrigger>
                                        </Style.Triggers>
                                    </Style>
                                </Button.Style>
                                <ds:AppIcon
                                    FontSize="12"
                                    Foreground="{DynamicResource AppTextSecondary}"
                                    Symbol="Archive24">
                                    <ds:AppIcon.Style>
                                        <Style BasedOn="{StaticResource AppIcon}" TargetType="{x:Type ds:AppIcon}">
                                            <Setter Property="Symbol" Value="Archive24" />
                                            <Style.Triggers>
                                                <DataTrigger Binding="{Binding SelectedCashRow.IsActive}" Value="False">
                                                    <Setter Property="Symbol" Value="ArchiveArrowBack24" />
                                                    <Setter Property="Foreground" Value="{DynamicResource AppAccent}" />
                                                </DataTrigger>
                                            </Style.Triggers>
                                        </Style>
                                    </ds:AppIcon.Style>
                                </ds:AppIcon>
                            </Button>
                            <TextBlock
                                VerticalAlignment="Center"
                                FontSize="{StaticResource Font.Size.Lg}"
                                FontWeight="SemiBold"
                                Foreground="{DynamicResource AppTextPrimary}"
                                Text="{Binding SelectedCashRow.Name, FallbackValue=''}"
                                TextTrimming="CharacterEllipsis" />
                        </DockPanel>
                        <!--  P4.9e — subtitle + currency chip 對齊 Position header  -->
                        <StackPanel>
                            <TextBlock
                                Margin="0,8,0,8"
                                FontSize="{StaticResource Font.Size.Xs}"
                                Foreground="{DynamicResource AppTextMuted}"
                                Text="{DynamicResource Portfolio.Detail.Cash.Subtitle}" />
                            <StackPanel Orientation="Horizontal">
                                <Border Padding="8,2" CornerRadius="{StaticResource Radius.Sm}">
                                    <Border.Style>
                                        <Style TargetType="Border">
                                            <Setter Property="Background" Value="{DynamicResource Brush.Neutral}" />
                                            <Style.Triggers>
                                                <DataTrigger Binding="{Binding SelectedCashRow.Currency, FallbackValue=''}" Value="USD">
                                                    <Setter Property="Background" Value="{DynamicResource Brush.Special}" />
                                                </DataTrigger>
                                            </Style.Triggers>
                                        </Style>
                                    </Border.Style>
                                    <TextBlock
                                        FontSize="{StaticResource Font.Size.Xs}"
                                        FontWeight="SemiBold"
                                        Foreground="{DynamicResource AppTextOnAccent}"
                                        Text="{Binding SelectedCashRow.Currency, FallbackValue='TWD'}" />
                                </Border>
                            </StackPanel>
                        </StackPanel>
                        </StackPanel>
                    </Border>

                    <!--  Tab bar — P4.9e DockPanel + pill tab + primary CTA  -->
                    <Border
                        Grid.Row="1"
                        Padding="14,8"
                        BorderBrush="{DynamicResource AppBorder}"
                        BorderThickness="0,0,0,1">
                        <DockPanel LastChildFill="True">
                            <Button
                                Height="32"
                                MinWidth="120"
                                Padding="14,0"
                                Click="AddMenuButton_Click"
                                DockPanel.Dock="Right"
                                Style="{StaticResource AppPrimaryButton}"
                                TextElement.Foreground="{DynamicResource Brush.Text.OnAccent}">
                                <StackPanel Orientation="Horizontal" TextElement.Foreground="{DynamicResource Brush.Text.OnAccent}">
                                    <ds:AppIcon
                                        Margin="0,0,6,0"
                                        VerticalAlignment="Center"
                                        FontSize="10"
                                        Foreground="{DynamicResource Brush.Text.OnAccent}"
                                        Symbol="Add24" />
                                    <TextBlock
                                        VerticalAlignment="Center"
                                        FontSize="{StaticResource Font.Size.Sm}"
                                        Foreground="{DynamicResource Brush.Text.OnAccent}"
                                        Text="{DynamicResource Portfolio.Detail.AddRecord}" />
                                </StackPanel>
                                <Button.ContextMenu>
                                    <ContextMenu>
                                        <MenuItem
                                            Command="{Binding BeginTxForSelectedCashCommand}"
                                            CommandParameter="income"
                                            Header="{DynamicResource Portfolio.Detail.Cash.Action.Income}" />
                                        <MenuItem
                                            Command="{Binding BeginTxForSelectedCashCommand}"
                                            CommandParameter="deposit"
                                            Header="{DynamicResource Portfolio.Detail.Cash.Action.Deposit}" />
                                        <MenuItem
                                            Command="{Binding BeginTxForSelectedCashCommand}"
                                            CommandParameter="withdrawal"
                                            Header="{DynamicResource Portfolio.Detail.Cash.Action.Withdrawal}" />
                                        <MenuItem
                                            Command="{Binding BeginTxForSelectedCashCommand}"
                                            CommandParameter="transfer"
                                            Header="{DynamicResource Portfolio.Detail.Cash.Action.Transfer}" />
                                    </ContextMenu>
                                </Button.ContextMenu>
                            </Button>
                            <StackPanel Orientation="Horizontal">
                                <RadioButton
                                    Command="{Binding SwitchDetailTabCommand}"
                                    CommandParameter="overview"
                                    Content="{DynamicResource Portfolio.Detail.Overview}"
                                    GroupName="CashDetailTab"
                                    IsChecked="{Binding IsDetailOverviewTab, Mode=OneWay}"
                                    Style="{StaticResource AppPillTab}" />
                                <RadioButton
                                    Command="{Binding SwitchDetailTabCommand}"
                                    CommandParameter="trades"
                                    Content="{DynamicResource Portfolio.Detail.Trades}"
                                    GroupName="CashDetailTab"
                                    IsChecked="{Binding IsDetailTradesTab, Mode=OneWay}"
                                    Style="{StaticResource AppPillTab}" />
                            </StackPanel>
                        </DockPanel>
                    </Border>

                    <!--  Tab content  -->
                    <ScrollViewer Grid.Row="2" VerticalScrollBarVisibility="Auto">
                        <Grid>
                            <StackPanel Margin="16,16,16,12" Visibility="{Binding IsDetailOverviewTab, Converter={StaticResource BooleanToVisibilityConverter}}">
                                <StackPanel>
                                    <TextBlock
                                        FontSize="{StaticResource Font.Size.Xs}"
                                        Foreground="{DynamicResource AppTextSecondary}"
                                        Text="{DynamicResource Portfolio.Cash.Amount}" />
                                    <TextBlock
                                        Margin="0,2,0,14"
                                        FontFamily="{StaticResource Font.Family.Base}"
                                        FontSize="{StaticResource Font.Size.2xl}"
                                        FontWeight="SemiBold"
                                        Foreground="{DynamicResource AppTextPrimary}"
                                        Text="{Binding SelectedCashRow.Balance, Converter={StaticResource CurrencyConverter}, ConverterParameter=amount, FallbackValue=''}"
                                        Typography.NumeralAlignment="Tabular" />
                                    <DockPanel Margin="0,0,0,14">
                                        <TextBlock
                                            DockPanel.Dock="Left"
                                            FontSize="{StaticResource Font.Size.Xs}"
                                            Foreground="{DynamicResource AppTextSecondary}"
                                            Text="{DynamicResource Common.CreatedDate}" />
                                        <TextBlock
                                            HorizontalAlignment="Right"
                                            DockPanel.Dock="Right"
                                            FontFamily="{StaticResource Font.Family.Base}"
                                            FontSize="{StaticResource Font.Size.Xs}"
                                            Foreground="{DynamicResource AppTextPrimary}"
                                            Text="{Binding SelectedCashRow.CreatedDate, StringFormat=yyyy/MM/dd, FallbackValue=''}"
                                            Typography.NumeralAlignment="Tabular" />
                                    </DockPanel>
                                    <Grid>
                                        <Grid.ColumnDefinitions>
                                            <ColumnDefinition Width="*" />
                                            <ColumnDefinition Width="10" />
                                            <ColumnDefinition Width="*" />
                                        </Grid.ColumnDefinitions>
                                        <Border
                                            Grid.Column="0"
                                            Padding="12,10"
                                            Background="{DynamicResource AppBackground}"
                                            BorderBrush="{DynamicResource AppBorder}"
                                            BorderThickness="1"
                                            CornerRadius="{StaticResource Radius.Sm}">
                                            <StackPanel>
                                                <TextBlock
                                                    FontSize="{StaticResource Font.Size.Xs}"
                                                    Foreground="{DynamicResource AppTextSecondary}"
                                                    Text="{DynamicResource Portfolio.Detail.TotalDeposits}" />
                                                <TextBlock
                                                    Margin="0,4,0,0"
                                                    FontFamily="{StaticResource Font.Family.Base}"
                                                    FontSize="{StaticResource Font.Size.Sm}"
                                                    FontWeight="SemiBold"
                                                    Foreground="{DynamicResource AppUp}"
                                                    Text="{Binding SelectedCashTotalDeposits, Converter={StaticResource CurrencyConverter}, ConverterParameter=amount}"
                                                    Typography.NumeralAlignment="Tabular" />
                                            </StackPanel>
                                        </Border>
                                        <Border
                                            Grid.Column="2"
                                            Padding="12,10"
                                            Background="{DynamicResource AppBackground}"
                                            BorderBrush="{DynamicResource AppBorder}"
                                            BorderThickness="1"
                                            CornerRadius="{StaticResource Radius.Sm}">
                                            <StackPanel>
                                                <TextBlock
                                                    FontSize="{StaticResource Font.Size.Xs}"
                                                    Foreground="{DynamicResource AppTextSecondary}"
                                                    Text="{DynamicResource Portfolio.Detail.TotalWithdrawals}" />
                                                <TextBlock
                                                    Margin="0,4,0,0"
                                                    FontFamily="{StaticResource Font.Family.Base}"
                                                    FontSize="{StaticResource Font.Size.Sm}"
                                                    FontWeight="SemiBold"
                                                    Foreground="{DynamicResource AppDown}"
                                                    Text="{Binding SelectedCashTotalWithdrawals, Converter={StaticResource CurrencyConverter}, ConverterParameter=amount}"
                                                    Typography.NumeralAlignment="Tabular" />
                                            </StackPanel>
                                        </Border>
                                    </Grid>
                                </StackPanel>
                            </StackPanel>

                            <!--
                                Cash trades tab — P4.9b 對齊 Position panel table-style：4 欄
                                (日期 / 類型 / 價值 / Edit)。Cash trade 沒有 Qty / Price 欄。
                                Note 不為空時當 row ToolTip。
                            -->
                            <Grid Margin="16,12" Visibility="{Binding IsDetailTradesTab, Converter={StaticResource BooleanToVisibilityConverter}}">
                                <Grid.RowDefinitions>
                                    <RowDefinition Height="Auto" />
                                    <RowDefinition Height="*" />
                                </Grid.RowDefinitions>

                                <!--  Column header — P4.9c Note 欄移除  -->
                                <Border
                                    Grid.Row="0"
                                    Padding="0,0,0,8"
                                    BorderBrush="{DynamicResource AppBorder}"
                                    BorderThickness="0,0,0,1">
                                    <Grid>
                                        <Grid.ColumnDefinitions>
                                            <ColumnDefinition Width="92" />
                                            <ColumnDefinition Width="80" />
                                            <ColumnDefinition Width="*" />
                                        </Grid.ColumnDefinitions>
                                        <TextBlock
                                            Grid.Column="0"
                                            FontSize="{StaticResource Font.Size.Xs}"
                                            Foreground="{DynamicResource AppTextSecondary}"
                                            Text="{DynamicResource Portfolio.TradeHistory.Date}" />
                                        <TextBlock
                                            Grid.Column="1"
                                            FontSize="{StaticResource Font.Size.Xs}"
                                            Foreground="{DynamicResource AppTextSecondary}"
                                            Text="{DynamicResource Portfolio.TradeHistory.Type}" />
                                        <TextBlock
                                            Grid.Column="2"
                                            HorizontalAlignment="Right"
                                            FontSize="{StaticResource Font.Size.Xs}"
                                            Foreground="{DynamicResource AppTextSecondary}"
                                            Text="{DynamicResource Portfolio.TradeHistory.GrossAmount}" />
                                    </Grid>
                                </Border>

                                <TextBlock
                                    Grid.Row="1"
                                    Margin="0,24,0,0"
                                    HorizontalAlignment="Center"
                                    VerticalAlignment="Top"
                                    FontSize="{StaticResource Font.Size.Sm}"
                                    Foreground="{DynamicResource AppTextMuted}"
                                    Text="{DynamicResource Portfolio.Detail.NoTrades}">
                                    <TextBlock.Style>
                                        <Style TargetType="TextBlock">
                                            <Setter Property="Visibility" Value="Collapsed" />
                                            <Style.Triggers>
                                                <DataTrigger Binding="{Binding SelectedCashTrades.Count, FallbackValue=0}" Value="0">
                                                    <Setter Property="Visibility" Value="Visible" />
                                                </DataTrigger>
                                            </Style.Triggers>
                                        </Style>
                                    </TextBlock.Style>
                                </TextBlock>

                                <ItemsControl Grid.Row="1" ItemsSource="{Binding SelectedCashTrades}">
                                    <ItemsControl.ItemTemplate>
                                        <DataTemplate>
                                            <Border
                                                Padding="6,10"
                                                BorderThickness="0,0,0,1"
                                                Cursor="Hand"
                                                ToolTip="{Binding Note}">
                                                <Border.Style>
                                                    <Style TargetType="Border">
                                                        <Setter Property="BorderBrush" Value="{DynamicResource AppBorderLight}" />
                                                        <Setter Property="Background" Value="Transparent" />
                                                        <Style.Triggers>
                                                            <Trigger Property="IsMouseOver" Value="True">
                                                                <Setter Property="Background" Value="{DynamicResource AppHover}" />
                                                            </Trigger>
                                                        </Style.Triggers>
                                                    </Style>
                                                </Border.Style>
                                                <Border.InputBindings>
                                                    <MouseBinding
                                                        Command="{Binding DataContext.Transaction.EditTradeCommand, RelativeSource={RelativeSource AncestorType=ItemsControl}}"
                                                        CommandParameter="{Binding}"
                                                        MouseAction="LeftClick" />
                                                </Border.InputBindings>
                                                <Grid>
                                                    <Grid.ColumnDefinitions>
                                                        <ColumnDefinition Width="92" />
                                                        <ColumnDefinition Width="80" />
                                                        <ColumnDefinition Width="*" />
                                                    </Grid.ColumnDefinitions>
                                                    <!--  日期  -->
                                                    <TextBlock
                                                        Grid.Column="0"
                                                        VerticalAlignment="Center"
                                                        FontFamily="{StaticResource Font.Family.Base}"
                                                        FontSize="{StaticResource Font.Size.Sm}"
                                                        Foreground="{DynamicResource AppTextPrimary}"
                                                        Text="{Binding TradeDateLocal, StringFormat=yyyy-MM-dd}"
                                                        Typography.NumeralAlignment="Tabular" />
                                                    <!--  類型 badge  -->
                                                    <Border
                                                        Grid.Column="1"
                                                        Padding="6,2"
                                                        HorizontalAlignment="Left"
                                                        VerticalAlignment="Center"
                                                        Background="{Binding TypeBadgeColor, Converter={StaticResource HexToBrushConverter}}"
                                                        CornerRadius="{StaticResource Radius.Sm}">
                                                        <TextBlock
                                                            FontSize="{StaticResource Font.Size.Xs}"
                                                            FontWeight="SemiBold"
                                                            Foreground="{DynamicResource AppTextOnAccent}"
                                                            Text="{Binding Type, Converter={StaticResource TradeTypeConverter}}" />
                                                    </Border>
                                                    <!--  價值 (TotalAmount 已含 sign)  -->
                                                    <TextBlock
                                                        Grid.Column="2"
                                                        HorizontalAlignment="Right"
                                                        VerticalAlignment="Center"
                                                        FontFamily="{StaticResource Font.Family.Base}"
                                                        FontSize="{StaticResource Font.Size.Sm}"
                                                        FontWeight="SemiBold"
                                                        Text="{Binding TotalAmount, Converter={StaticResource CurrencyConverter}, ConverterParameter=signed-dash}"
                                                        Typography.NumeralAlignment="Tabular">
                                                        <TextBlock.Style>
                                                            <Style BasedOn="{StaticResource {x:Type TextBlock}}" TargetType="TextBlock">
                                                                <Setter Property="Foreground" Value="{DynamicResource AppDown}" />
                                                                <Style.Triggers>
                                                                    <DataTrigger Binding="{Binding IsAmountPositive}" Value="True">
                                                                        <Setter Property="Foreground" Value="{DynamicResource AppUp}" />
                                                                    </DataTrigger>
                                                                    <DataTrigger Binding="{Binding TotalAmount}" Value="0">
                                                                        <Setter Property="Foreground" Value="{DynamicResource AppTextSecondary}" />
                                                                    </DataTrigger>
                                                                </Style.Triggers>
                                                            </Style>
                                                        </TextBlock.Style>
                                                    </TextBlock>
                                                </Grid>
                                            </Border>
                                        </DataTemplate>
                                    </ItemsControl.ItemTemplate>
                                </ItemsControl>
                            </Grid>
                        </Grid>
                    </ScrollViewer>

                    <!--  Danger zone  -->
                    <Border
                        Grid.Row="3"
                        Margin="16,0,16,16"
                        Padding="14,12"
                        Background="{DynamicResource AppBackground}"
                        BorderBrush="{DynamicResource AppDanger}"
                        BorderThickness="1"
                        CornerRadius="{StaticResource Radius.Sm}">
                        <Grid>
                            <Grid.ColumnDefinitions>
                                <ColumnDefinition Width="*" />
                                <ColumnDefinition Width="Auto" />
                            </Grid.ColumnDefinitions>
                            <StackPanel Grid.Column="0" VerticalAlignment="Center">
                                <StackPanel Margin="0,0,0,2" Orientation="Horizontal">
                                    <ds:AppIcon
                                        Margin="0,0,6,0"
                                        VerticalAlignment="Center"
                                        FontSize="11"
                                        Foreground="{DynamicResource AppDanger}"
                                        Symbol="Delete24" />
                                    <TextBlock
                                        FontSize="{StaticResource Font.Size.Xs}"
                                        FontWeight="SemiBold"
                                        Foreground="{DynamicResource AppDanger}"
                                        Text="{DynamicResource Portfolio.Detail.DeleteAccount}" />
                                </StackPanel>
                                <TextBlock
                                    FontSize="{StaticResource Font.Size.Xs}"
                                    Foreground="{DynamicResource AppTextSecondary}"
                                    Text="{DynamicResource Portfolio.Detail.DeleteWarning}"
                                    TextWrapping="Wrap" />
                            </StackPanel>
                            <Button
                                Grid.Column="1"
                                Height="32"
                                Margin="12,0,0,0"
                                Padding="14,0"
                                VerticalAlignment="Center"
                                Command="{Binding Account.RemoveCashAccountCommand}"
                                CommandParameter="{Binding SelectedCashRow}"
                                Style="{StaticResource AppDangerButton}">
                                <TextBlock
                                    FontSize="{StaticResource Font.Size.Xs}"
                                    Foreground="{Binding Foreground, RelativeSource={RelativeSource AncestorType=Button}}"
                                    Text="{DynamicResource Portfolio.Detail.DeleteAccount}" />
                            </Button>
                        </Grid>
                    </Border>
                </Grid>
            </Border>
        </Grid>
    </Grid>
</UserControl>
