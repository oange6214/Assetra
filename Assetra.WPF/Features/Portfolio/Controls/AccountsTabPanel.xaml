<UserControl
    x:Class="Assetra.WPF.Features.Portfolio.Controls.AccountsTabPanel"
    xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
    xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
    xmlns:controls="clr-namespace:Assetra.WPF.Controls"
    xmlns:conv="clr-namespace:Assetra.WPF.Infrastructure.Converters"
    xmlns:d="http://schemas.microsoft.com/expression/blend/2008"
    xmlns:mc="http://schemas.openxmlformats.org/markup-compatibility/2006"
    xmlns:vm="clr-namespace:Assetra.WPF.Features.Portfolio"
    d:DataContext="{d:DesignInstance Type={x:Type vm:PortfolioViewModel},
                                     IsDesignTimeCreatable=False}"
    mc:Ignorable="d">
    <UserControl.Resources>
        <conv:PercentToWidthConverter x:Key="PercentToWidthConverter" />
        <conv:StatusTagToBrushConverter x:Key="StatusTagToBrush" />
    </UserControl.Resources>

    <Grid>
        <Grid.RowDefinitions>
            <RowDefinition Height="Auto" />
            <!--  Emergency fund summary  -->
            <RowDefinition Height="Auto" />
            <!--  Text search  -->
            <RowDefinition Height="*" />
            <!--  DataGrid  -->
        </Grid.RowDefinitions>

        <!--  ═══ Row 0: Emergency Fund Summary ═══  -->
        <Border
            Grid.Row="0"
            Padding="12,8"
            Background="{DynamicResource AppSurface}"
            BorderBrush="{DynamicResource AppBorder}"
            BorderThickness="0,0,0,1">
            <StackPanel>
                <WrapPanel ItemWidth="320" ItemHeight="Auto">
                    <!--  Card 1: Emergency fund months + progress  -->
                    <Border
                        MinHeight="80"
                        Margin="{StaticResource CardMarginLeft}"
                        Padding="12,10"
                        Background="{DynamicResource AppBackground}"
                        BorderBrush="{DynamicResource AppBorder}"
                        BorderThickness="1"
                        CornerRadius="{StaticResource RadiusSm}">
                        <StackPanel>
                            <TextBlock
                                FontSize="{StaticResource FontSizeXs}"
                                Foreground="{DynamicResource AppTextSecondary}"
                                Text="{DynamicResource Portfolio.Cash.Emergency.Title}" />
                            <StackPanel Margin="0,4,0,6" Orientation="Horizontal">
                                <TextBlock
                                    FontFamily="{StaticResource FontTabular}"
                                    FontSize="{StaticResource FontSizeLg}"
                                    FontWeight="SemiBold"
                                    Foreground="{Binding EmergencyStatusTag, Converter={StaticResource StatusTagToBrush}}">
                                    <Run Text="{Binding EmergencyFundMonthsDisplay, Mode=OneWay}" />
                                </TextBlock>
                                <TextBlock
                                    Margin="4,0,0,0"
                                    VerticalAlignment="Bottom"
                                    FontSize="{StaticResource FontSizeXs}"
                                    Foreground="{DynamicResource AppTextSecondary}"
                                    Text="{DynamicResource Portfolio.Cash.Emergency.Months}"
                                    Visibility="{Binding IsMonthlyExpenseSet, Converter={StaticResource BooleanToVisibilityConverter}}" />
                            </StackPanel>
                            <Grid>
                                <Border
                                    Height="4"
                                    Background="{DynamicResource AppBorder}"
                                    CornerRadius="2" />
                                <Border
                                    Height="4"
                                    HorizontalAlignment="Left"
                                    Background="{Binding EmergencyStatusTag, Converter={StaticResource StatusTagToBrush}}"
                                    CornerRadius="2">
                                    <Border.Width>
                                        <MultiBinding Converter="{StaticResource PercentToWidthConverter}">
                                            <Binding Path="EmergencyFundBarValue" />
                                            <Binding Path="ActualWidth" RelativeSource="{RelativeSource AncestorType=Grid}" />
                                        </MultiBinding>
                                    </Border.Width>
                                </Border>
                            </Grid>
                        </StackPanel>
                    </Border>

                    <!--  Card 2: Monthly expense input  -->
                    <Border
                        MinHeight="80"
                        Margin="{StaticResource CardMarginCenter}"
                        Padding="12,10"
                        Background="{DynamicResource AppBackground}"
                        BorderBrush="{DynamicResource AppBorder}"
                        BorderThickness="1"
                        CornerRadius="{StaticResource RadiusSm}">
                        <StackPanel>
                            <TextBlock
                                Margin="0,0,0,4"
                                FontSize="{StaticResource FontSizeXs}"
                                Foreground="{DynamicResource AppTextSecondary}"
                                Text="{DynamicResource Portfolio.Cash.Emergency.MonthlyExpense}" />
                            <TextBox Style="{StaticResource FormTextBox}" Text="{Binding MonthlyExpense, UpdateSourceTrigger=PropertyChanged, StringFormat='{}{0:0.##}'}" />
                        </StackPanel>
                    </Border>

                    <!--  Card 3: Safety status  -->
                    <Border
                        MinHeight="80"
                        Margin="{StaticResource CardMarginRight}"
                        Padding="12,10"
                        Background="{DynamicResource AppBackground}"
                        BorderBrush="{DynamicResource AppBorder}"
                        BorderThickness="1"
                        CornerRadius="{StaticResource RadiusSm}">
                        <StackPanel>
                            <TextBlock
                                FontSize="{StaticResource FontSizeXs}"
                                Foreground="{DynamicResource AppTextSecondary}"
                                Text="{DynamicResource Portfolio.Cash.Emergency.MonthlyExpenseHint}" />
                            <TextBlock
                                Margin="0,4,0,0"
                                FontSize="{StaticResource FontSizeLg}"
                                FontWeight="SemiBold"
                                Foreground="{Binding EmergencyStatusTag, Converter={StaticResource StatusTagToBrush}}"
                                Visibility="{Binding IsMonthlyExpenseSet, Converter={StaticResource BooleanToVisibilityConverter}}">
                                <TextBlock.Style>
                                    <Style TargetType="TextBlock">
                                        <Setter Property="Text" Value="{DynamicResource Portfolio.Cash.Emergency.Safe}" />
                                        <Style.Triggers>
                                            <DataTrigger Binding="{Binding EmergencyStatusTag}" Value="warning">
                                                <Setter Property="Text" Value="{DynamicResource Portfolio.Cash.Emergency.Warning}" />
                                            </DataTrigger>
                                            <DataTrigger Binding="{Binding EmergencyStatusTag}" Value="danger">
                                                <Setter Property="Text" Value="{DynamicResource Portfolio.Cash.Emergency.Danger}" />
                                            </DataTrigger>
                                        </Style.Triggers>
                                    </Style>
                                </TextBlock.Style>
                            </TextBlock>
                            <TextBlock
                                Margin="0,4,0,0"
                                FontSize="{StaticResource FontSizeXs}"
                                Foreground="{DynamicResource AppTextMuted}"
                                Text="{DynamicResource Portfolio.Cash.Emergency.NotSet}"
                                Visibility="{Binding IsMonthlyExpenseSet, Converter={StaticResource InverseBooleanToVisibilityConverter}}" />
                        </StackPanel>
                    </Border>
                </WrapPanel>
            </StackPanel>
        </Border>

        <controls:SearchBox
            Grid.Row="1"
            Placeholder="{DynamicResource Portfolio.Filter.SearchAccounts}"
            Text="{Binding CashFilterText}">
            <controls:SearchBox.RightContent>
                <StackPanel VerticalAlignment="Center" Orientation="Horizontal">
                    <CheckBox
                        Margin="0,0,8,0"
                        VerticalAlignment="Center"
                        IsChecked="{Binding Account.ShowArchivedAccounts}">
                        <TextBlock
                            FontSize="{StaticResource FontSizeXs}"
                            Foreground="{DynamicResource AppTextSecondary}"
                            Text="{DynamicResource Portfolio.Account.ShowArchived}" />
                    </CheckBox>
                    <Button
                        MinHeight="32"
                        Padding="10,0"
                        Command="{Binding OpenAddAccountDialogCommand}"
                        Style="{StaticResource BtnGhost}">
                        <StackPanel Orientation="Horizontal">
                            <TextBlock
                                Margin="0,0,6,0"
                                VerticalAlignment="Center"
                                FontFamily="Segoe MDL2 Assets"
                                FontSize="{StaticResource FontSizeXs}"
                                Text="&#xE710;" />
                            <TextBlock VerticalAlignment="Center" Text="{DynamicResource Portfolio.AddCash}" />
                        </StackPanel>
                    </Button>
                </StackPanel>
            </controls:SearchBox.RightContent>
        </controls:SearchBox>

        <!--  ═══ Cash Accounts DataGrid ═══  -->
        <Grid Grid.Row="2">
            <!--  Empty state  -->
            <Border
                Padding="32"
                Background="{DynamicResource AppBackground}"
                Visibility="{Binding HasNoCashAccounts, Converter={StaticResource BooleanToVisibilityConverter}}">
                <StackPanel
                    HorizontalAlignment="Center"
                    VerticalAlignment="Center"
                    Opacity="0.4">
                    <TextBlock
                        Margin="0,0,0,6"
                        HorizontalAlignment="Center"
                        FontSize="{StaticResource FontSize2xl}"
                        Text="&#x1F4B0;" />
                    <TextBlock
                        HorizontalAlignment="Center"
                        FontSize="{StaticResource FontSizeSm}"
                        Foreground="{DynamicResource AppTextSecondary}"
                        Text="{DynamicResource Portfolio.Cash.Empty}" />
                </StackPanel>
            </Border>

            <DataGrid
                x:Name="CashGrid"
                AlternationCount="2"
                AutoGenerateColumns="False"
                Background="{DynamicResource AppBackground}"
                BorderThickness="0"
                CanUserAddRows="False"
                CanUserDeleteRows="False"
                CanUserReorderColumns="False"
                CanUserResizeColumns="False"
                CanUserSortColumns="True"
                ColumnHeaderHeight="{StaticResource DataGridHeaderHeight}"
                EnableRowVirtualization="True"
                FontFamily="{StaticResource FontBase}"
                FontSize="{StaticResource FontSizeSm}"
                Foreground="{DynamicResource AppTextPrimary}"
                GridLinesVisibility="None"
                HeadersVisibility="Column"
                HorizontalScrollBarVisibility="Auto"
                IsReadOnly="True"
                ItemsSource="{Binding CashAccountsView}"
                PreviewMouseDown="OnGridPreviewMouseDown"
                RowHeight="{StaticResource DataGridRowHeight}"
                SelectedItem="{Binding SelectedCashRow, Mode=TwoWay}"
                SelectionMode="Single"
                VirtualizingPanel.IsVirtualizing="True"
                VirtualizingPanel.VirtualizationMode="Recycling">

                <DataGrid.ColumnHeaderStyle>
                    <Style BasedOn="{StaticResource AppDataGridColHeader}" TargetType="DataGridColumnHeader" />
                </DataGrid.ColumnHeaderStyle>
                <DataGrid.CellStyle>
                    <Style BasedOn="{StaticResource AppDataGridCell}" TargetType="DataGridCell" />
                </DataGrid.CellStyle>
                <DataGrid.RowStyle>
                    <Style BasedOn="{StaticResource AppDataGridRowSelectable}" TargetType="DataGridRow">
                        <!--
                            Tag carries the parent ViewModel so the ContextMenu (which lives
                            outside the visual tree) can reach it via PlacementTarget.Tag.
                            Using x:Reference CashGrid here would create a cyclical dependency
                            because the RowStyle is defined on CashGrid itself.
                        -->
                        <Setter Property="Tag" Value="{Binding DataContext, RelativeSource={RelativeSource AncestorType=DataGrid}}" />
                        <Setter Property="ContextMenu">
                            <Setter.Value>
                                <ContextMenu>
                                    <MenuItem
                                        Command="{Binding PlacementTarget.Tag.Account.RemoveCashAccountCommand, RelativeSource={RelativeSource AncestorType=ContextMenu}}"
                                        CommandParameter="{Binding}"
                                        Header="{DynamicResource Portfolio.Account.PermanentDelete}" />
                                </ContextMenu>
                            </Setter.Value>
                        </Setter>
                    </Style>
                </DataGrid.RowStyle>

                <DataGrid.Columns>
                    <!--  資產 (原「名稱」— 統一三個分頁的首欄為「資產」)  -->
                    <DataGridTemplateColumn Width="*" SortMemberPath="Name">
                        <DataGridTemplateColumn.Header>
                            <TextBlock Text="{DynamicResource Common.Asset}" />
                        </DataGridTemplateColumn.Header>
                    <DataGridTemplateColumn.CellTemplate>
                        <DataTemplate>
                            <Grid VerticalAlignment="Center">
                                <Grid.RowDefinitions>
                                    <RowDefinition Height="Auto" />
                                    <RowDefinition Height="Auto" />
                                </Grid.RowDefinitions>
                                <Grid.ColumnDefinitions>
                                    <ColumnDefinition Width="*" />
                                    <ColumnDefinition Width="Auto" />
                                </Grid.ColumnDefinitions>

                                <TextBlock
                                    Grid.Row="0"
                                    Grid.Column="0"
                                    VerticalAlignment="Center"
                                    FontWeight="SemiBold"
                                    Foreground="{DynamicResource AppTextPrimary}"
                                    Text="{Binding Name}"
                                    TextTrimming="CharacterEllipsis" />

                                <Border
                                    Grid.Row="0"
                                    Grid.Column="1"
                                    Margin="10,0,0,0"
                                    HorizontalAlignment="Right"
                                    ToolTip="{DynamicResource Portfolio.Cash.DefaultHint}"
                                    Style="{StaticResource PortfolioDefaultBadge}"
                                    Visibility="{Binding IsDefault, Converter={StaticResource BooleanToVisibilityConverter}}">
                                    <TextBlock
                                        Style="{StaticResource PortfolioBadgeText}"
                                        Text="{DynamicResource Portfolio.Cash.Default}" />
                                </Border>

                                <TextBlock
                                    Grid.Row="1"
                                    Grid.Column="0"
                                    Grid.ColumnSpan="2"
                                    Margin="0,4,0,0"
                                    FontFamily="{StaticResource FontTabular}"
                                    FontSize="{StaticResource FontSizeXs}"
                                    Foreground="{DynamicResource AppTextMuted}"
                                    Text="{Binding Currency}" />
                            </Grid>
                        </DataTemplate>
                    </DataGridTemplateColumn.CellTemplate>
                </DataGridTemplateColumn>

                    <!--  市值 (原「餘額」— 與投資/負債分頁統一)  -->
                    <DataGridTemplateColumn Width="200" SortMemberPath="Balance">
                        <DataGridTemplateColumn.HeaderStyle>
                            <Style BasedOn="{StaticResource AppDataGridColHeader}" TargetType="DataGridColumnHeader">
                                <Setter Property="HorizontalContentAlignment" Value="Right" />
                            </Style>
                        </DataGridTemplateColumn.HeaderStyle>
                        <DataGridTemplateColumn.Header>
                            <TextBlock Text="{DynamicResource Common.MarketValue}" />
                        </DataGridTemplateColumn.Header>
                        <DataGridTemplateColumn.CellTemplate>
                            <DataTemplate>
                                <TextBlock
                                    VerticalAlignment="Center"
                                    FontFamily="{StaticResource FontTabular}"
                                    FontWeight="SemiBold"
                                    Foreground="{DynamicResource AppTextPrimary}"
                                    Text="{Binding Balance, Converter={StaticResource CurrencyConverter}, ConverterParameter=amount}"
                                    TextAlignment="Right" />
                            </DataTemplate>
                        </DataGridTemplateColumn.CellTemplate>
                    </DataGridTemplateColumn>

                    <!--  Created Date  -->
                    <DataGridTemplateColumn Width="120" SortMemberPath="CreatedDate">
                        <DataGridTemplateColumn.Header>
                            <TextBlock Text="{DynamicResource Common.CreatedDate}" />
                        </DataGridTemplateColumn.Header>
                        <DataGridTemplateColumn.CellTemplate>
                            <DataTemplate>
                                <TextBlock
                                    VerticalAlignment="Center"
                                    FontFamily="{StaticResource FontTabular}"
                                    FontSize="{StaticResource FontSizeSm}"
                                    Foreground="{DynamicResource AppTextSecondary}"
                                    Text="{Binding CreatedDate, StringFormat=yyyy/MM/dd}" />
                            </DataTemplate>
                        </DataGridTemplateColumn.CellTemplate>
                    </DataGridTemplateColumn>

                    <!--  Row actions: Archive (permanent-delete via row context menu)  -->
                    <DataGridTemplateColumn Width="50">
                        <DataGridTemplateColumn.Header>
                            <TextBlock Text="" />
                        </DataGridTemplateColumn.Header>
                        <DataGridTemplateColumn.CellTemplate>
                            <DataTemplate>
                                <Button
                                    Width="32"
                                    Height="28"
                                    Padding="0"
                                    HorizontalAlignment="Center"
                                    VerticalAlignment="Center"
                                    Background="Transparent"
                                    BorderThickness="0"
                                    Command="{Binding DataContext.Account.ArchiveAccountCommand, RelativeSource={RelativeSource AncestorType=UserControl}}"
                                    CommandParameter="{Binding}"
                                    Style="{StaticResource BtnGhost}"
                                    ToolTip="{DynamicResource Portfolio.Account.Archive}">
                                    <TextBlock
                                        VerticalAlignment="Center"
                                        FontFamily="Segoe MDL2 Assets"
                                        FontSize="{StaticResource FontSizeXs}"
                                        Foreground="{DynamicResource AppTextSecondary}"
                                        Text="&#xE7B3;" />
                                </Button>
                            </DataTemplate>
                        </DataGridTemplateColumn.CellTemplate>
                    </DataGridTemplateColumn>
                </DataGrid.Columns>
            </DataGrid>
        </Grid>
    </Grid>
</UserControl>
