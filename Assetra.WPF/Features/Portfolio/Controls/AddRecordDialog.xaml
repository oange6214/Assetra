<UserControl
    x:Class="Assetra.WPF.Features.Portfolio.Controls.AddRecordDialog"
    xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
    xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
    xmlns:d="http://schemas.microsoft.com/expression/blend/2008"
    xmlns:mc="http://schemas.openxmlformats.org/markup-compatibility/2006"
    xmlns:txforms="clr-namespace:Assetra.WPF.Features.Portfolio.Controls.TxForms"
    xmlns:ui="http://schemas.lepo.co/wpfui/2022/xaml"
    xmlns:vm="clr-namespace:Assetra.WPF.Features.Portfolio.SubViewModels"
    x:Name="Root"
    d:DataContext="{d:DesignInstance Type={x:Type vm:TransactionDialogViewModel}}"
    Visibility="{Binding IsTxDialogOpen, Converter={StaticResource BooleanToVisibilityConverter}}"
    mc:Ignorable="d">

    <Grid>
        <!--  半透明背景幕  -->
        <Border Background="{DynamicResource AppModalOverlay}" />

        <!--  Dialog card：固定舒適閱讀寬度 + 內容滾動。  -->
        <!--  寬度跟隨視窗易讓表單欄位過寬難讀；採固定 600px 配合 ScrollViewer 高度上限。  -->
        <Border
            Width="600"
            MaxHeight="{StaticResource DialogMaxHeight}"
            HorizontalAlignment="Center"
            VerticalAlignment="Center"
            Background="{DynamicResource AppSurface}"
            BorderBrush="{DynamicResource AppBorder}"
            BorderThickness="1"
            CornerRadius="{StaticResource RadiusMd}">
            <Grid>
                <Grid.RowDefinitions>
                    <RowDefinition Height="Auto" />
                    <!--  Header  -->
                    <RowDefinition Height="*" />
                    <!--  Content (scroll)  -->
                    <RowDefinition Height="Auto" />
                    <!--  Footer  -->
                </Grid.RowDefinitions>

                <!--  Header  -->
                <Border
                    Grid.Row="0"
                    Padding="20,14"
                    BorderBrush="{DynamicResource AppBorder}"
                    BorderThickness="0,0,0,1">
                    <DockPanel>
                        <StackPanel>
                            <TextBlock
                                VerticalAlignment="Center"
                                FontSize="{StaticResource FontSizeSm}"
                                FontWeight="SemiBold"
                                Foreground="{DynamicResource AppTextPrimary}">
                                <TextBlock.Style>
                                    <Style TargetType="TextBlock">
                                        <Setter Property="Text" Value="{DynamicResource Portfolio.Record.Title}" />
                                        <Style.Triggers>
                                            <DataTrigger Binding="{Binding IsRevisionReplacePromptOpen}" Value="True">
                                                <Setter Property="Text" Value="{DynamicResource Portfolio.Record.ReplacePromptTitle}" />
                                            </DataTrigger>
                                            <DataTrigger Binding="{Binding IsRevisionMode}" Value="True">
                                                <Setter Property="Text" Value="{DynamicResource Portfolio.Record.ReviseTitle}" />
                                            </DataTrigger>
                                            <DataTrigger Binding="{Binding IsEditMode}" Value="True">
                                                <Setter Property="Text" Value="{DynamicResource Portfolio.Tx.EditTitle}" />
                                            </DataTrigger>
                                        </Style.Triggers>
                                    </Style>
                                </TextBlock.Style>
                            </TextBlock>
                            <TextBlock
                                Margin="0,2,0,0"
                                FontSize="{StaticResource FontSizeXs}"
                                Foreground="{DynamicResource AppTextMuted}"
                                TextWrapping="Wrap">
                                <TextBlock.Style>
                                    <Style TargetType="TextBlock">
                                        <Setter Property="Visibility" Value="Collapsed" />
                                        <Style.Triggers>
                                            <DataTrigger Binding="{Binding IsEditMode}" Value="True">
                                                <Setter Property="Visibility" Value="Visible" />
                                                <Setter Property="Text" Value="{DynamicResource Portfolio.Record.EditSubtitle}" />
                                            </DataTrigger>
                                            <DataTrigger Binding="{Binding IsRevisionMode}" Value="True">
                                                <Setter Property="Visibility" Value="Visible" />
                                                <Setter Property="Text" Value="{DynamicResource Portfolio.Record.RevisionSubtitle}" />
                                            </DataTrigger>
                                            <DataTrigger Binding="{Binding IsRevisionReplacePromptOpen}" Value="True">
                                                <Setter Property="Visibility" Value="Visible" />
                                                <Setter Property="Text" Value="{DynamicResource Portfolio.Record.ReplaceSubtitle}" />
                                            </DataTrigger>
                                        </Style.Triggers>
                                    </Style>
                                </TextBlock.Style>
                            </TextBlock>
                        </StackPanel>
                        <ui:Button
                            Width="28"
                            Height="28"
                            HorizontalAlignment="Right"
                            Command="{Binding CloseTxDialogCommand}"
                            DockPanel.Dock="Right"
                            Padding="0"
                            Appearance="Transparent">
                            <ui:SymbolIcon Symbol="Dismiss24" FontSize="12" Foreground="{DynamicResource AppTextMuted}" />
                        </ui:Button>
                    </DockPanel>
                </Border>

                <!--  Scrollable content  -->
                <ScrollViewer
                    x:Name="ContentScrollViewer"
                    Grid.Row="1"
                    Padding="20,16"
                    VerticalScrollBarVisibility="Auto">
                    <StackPanel>

                        <!--  Edit-mode summary and guardrail  -->
                        <Border
                            Margin="0,0,0,12"
                            Padding="12"
                            Background="{DynamicResource AppBackground}"
                            BorderBrush="{DynamicResource AppBorder}"
                            BorderThickness="1"
                            CornerRadius="{StaticResource RadiusSm}"
                            Visibility="{Binding ShowEditLockedSummary, Converter={StaticResource BooleanToVisibilityConverter}}">
                            <StackPanel>
                                <TextBlock
                                    Margin="0,0,0,8"
                                    FontSize="{StaticResource FontSizeXs}"
                                    Foreground="{DynamicResource AppTextSecondary}"
                                    Text="{DynamicResource Portfolio.Record.CoreLocked}"
                                    TextWrapping="Wrap" />
                                <Grid>
                                    <Grid.ColumnDefinitions>
                                        <ColumnDefinition Width="Auto" />
                                        <ColumnDefinition Width="*" />
                                    </Grid.ColumnDefinitions>
                                    <Grid.RowDefinitions>
                                        <RowDefinition Height="Auto" />
                                        <RowDefinition Height="Auto" />
                                        <RowDefinition Height="Auto" />
                                        <RowDefinition Height="Auto" />
                                    </Grid.RowDefinitions>

                                    <TextBlock
                                        Grid.Row="0"
                                        Grid.Column="0"
                                        Margin="0,0,10,6"
                                        FontSize="{StaticResource FontSizeXs}"
                                        Foreground="{DynamicResource AppTextMuted}"
                                        Text="{DynamicResource Portfolio.Record.Summary.Type}" />
                                    <TextBlock
                                        Grid.Row="0"
                                        Grid.Column="1"
                                        Margin="0,0,0,6"
                                        FontSize="{StaticResource FontSizeXs}"
                                        FontWeight="SemiBold"
                                        Foreground="{DynamicResource AppTextPrimary}"
                                        Text="{Binding EditSummaryType}" />

                                    <TextBlock
                                        Grid.Row="1"
                                        Grid.Column="0"
                                        Margin="0,0,10,6"
                                        FontSize="{StaticResource FontSizeXs}"
                                        Foreground="{DynamicResource AppTextMuted}"
                                        Text="{DynamicResource Portfolio.Record.Summary.Target}" />
                                    <TextBlock
                                        Grid.Row="1"
                                        Grid.Column="1"
                                        Margin="0,0,0,6"
                                        FontSize="{StaticResource FontSizeXs}"
                                        FontWeight="SemiBold"
                                        Foreground="{DynamicResource AppTextPrimary}"
                                        Text="{Binding EditSummaryTarget}"
                                        TextWrapping="Wrap" />

                                    <TextBlock
                                        Grid.Row="2"
                                        Grid.Column="0"
                                        Margin="0,0,10,6"
                                        FontSize="{StaticResource FontSizeXs}"
                                        Foreground="{DynamicResource AppTextMuted}"
                                        Text="{DynamicResource Portfolio.Record.Summary.Amount}" />
                                    <TextBlock
                                        Grid.Row="2"
                                        Grid.Column="1"
                                        Margin="0,0,0,6"
                                        FontFamily="{StaticResource FontBase}"
                                        FontSize="{StaticResource FontSizeXs}"
                                        Foreground="{DynamicResource AppTextPrimary}"
                                        Text="{Binding EditSummaryAmount}"
                                        Typography.NumeralAlignment="Tabular" />

                                    <TextBlock
                                        Grid.Row="3"
                                        Grid.Column="0"
                                        Margin="0,0,10,0"
                                        FontSize="{StaticResource FontSizeXs}"
                                        Foreground="{DynamicResource AppTextMuted}"
                                        Text="{DynamicResource Portfolio.Record.Summary.Quantity}" />
                                    <TextBlock
                                        Grid.Row="3"
                                        Grid.Column="1"
                                        FontFamily="{StaticResource FontBase}"
                                        FontSize="{StaticResource FontSizeXs}"
                                        Foreground="{DynamicResource AppTextPrimary}"
                                        Text="{Binding EditSummaryQuantity}"
                                        Typography.NumeralAlignment="Tabular" />
                                </Grid>
                            </StackPanel>
                        </Border>

                        <Border
                            Margin="0,0,0,12"
                            Padding="10,8"
                            Background="{DynamicResource AppSurface}"
                            BorderBrush="{DynamicResource AppAccent}"
                            BorderThickness="3,0,0,0"
                            CornerRadius="{StaticResource RadiusSm}"
                            Visibility="{Binding ShowEditLockedSummary, Converter={StaticResource BooleanToVisibilityConverter}}">
                            <TextBlock
                                FontSize="{StaticResource FontSizeXs}"
                                Foreground="{DynamicResource AppTextSecondary}"
                                Text="{DynamicResource Portfolio.Record.ReviseHint}"
                                TextWrapping="Wrap" />
                        </Border>

                        <Border
                            Margin="0,0,0,12"
                            Padding="10,8"
                            Background="{DynamicResource AppBackground}"
                            BorderBrush="{DynamicResource AppBorder}"
                            BorderThickness="1"
                            CornerRadius="{StaticResource RadiusSm}"
                            Visibility="{Binding IsRevisionMode, Converter={StaticResource BooleanToVisibilityConverter}}">
                            <TextBlock
                                FontSize="{StaticResource FontSizeXs}"
                                Foreground="{DynamicResource AppTextSecondary}"
                                Text="{DynamicResource Portfolio.Record.RevisionModeHint}"
                                TextWrapping="Wrap" />
                        </Border>

                        <!--  Meta-only edit banner: shown for Sell / legacy-unlinked Buy/StockDiv  -->
                        <Border
                            Margin="0,0,0,12"
                            Padding="10,8"
                            Background="{DynamicResource AppSurface}"
                            BorderBrush="{DynamicResource AppAccent}"
                            BorderThickness="3,0,0,0"
                            CornerRadius="{StaticResource RadiusSm}"
                            Visibility="{Binding IsEditingMetaOnly, Converter={StaticResource BooleanToVisibilityConverter}}">
                            <TextBlock
                                FontSize="{StaticResource FontSizeXs}"
                                Foreground="{DynamicResource AppTextSecondary}"
                                Text="{DynamicResource Portfolio.Tx.MetaOnlyHint}"
                                TextWrapping="Wrap" />
                        </Border>

                        <StackPanel Visibility="{Binding IsRevisionReplacePromptOpen, Converter={StaticResource InverseBooleanToVisibilityConverter}}">
                            <Border
                                Margin="0,0,0,12"
                                Padding="14,12"
                                Background="{DynamicResource AppBackground}"
                                BorderBrush="{DynamicResource AppBorder}"
                                BorderThickness="1"
                                CornerRadius="{StaticResource RadiusSm}">
                                <DockPanel LastChildFill="True">
                                    <TextBlock
                                        DockPanel.Dock="Top"
                                        FontSize="{StaticResource FontSizeSm}"
                                        FontWeight="SemiBold"
                                        Foreground="{DynamicResource AppTextPrimary}"
                                        Text="{DynamicResource Portfolio.Record.Section.Basic}" />
                                    <TextBlock
                                        Margin="0,4,0,12"
                                        DockPanel.Dock="Top"
                                        FontSize="{StaticResource FontSizeXs}"
                                        Foreground="{DynamicResource AppTextMuted}"
                                        Text="{DynamicResource Portfolio.Record.Section.BasicHint}"
                                        TextWrapping="Wrap"
                                        Visibility="{Binding IsEditMode, Converter={StaticResource InverseBooleanToVisibilityConverter}}" />
                                    <Border
                                        Width="172"
                                        Margin="0,0,12,0"
                                        Padding="0"
                                        Background="Transparent"
                                        DockPanel.Dock="Left">
                                        <StackPanel>
                                            <TextBlock
                                                Margin="0,0,0,4"
                                                FontSize="{StaticResource FontSizeXs}"
                                                FontWeight="SemiBold"
                                                Foreground="{DynamicResource AppTextSecondary}"
                                                Text="{DynamicResource Portfolio.Tx.Date}" />
                                            <ui:CalendarDatePicker Date="{Binding TxDate, Mode=TwoWay}" />
                                        </StackPanel>
                                    </Border>

                                    <StackPanel Visibility="{Binding IsEditMode, Converter={StaticResource InverseBooleanToVisibilityConverter}}">
                                        <TextBlock
                                            Margin="0,0,0,4"
                                            FontSize="{StaticResource FontSizeXs}"
                                            FontWeight="SemiBold"
                                            Foreground="{DynamicResource AppTextSecondary}"
                                            Text="{DynamicResource Portfolio.TradeHistory.Type}" />
                                        <Border
                                            Padding="10"
                                            Background="{DynamicResource AppSurface}"
                                            BorderBrush="{DynamicResource AppBorder}"
                                            BorderThickness="1"
                                            CornerRadius="{StaticResource RadiusSm}">
                                            <StackPanel>
                                                <Border
                                                    Padding="8"
                                                    Background="Transparent"
                                                    BorderBrush="{DynamicResource AppBorder}"
                                                    BorderThickness="1"
                                                    CornerRadius="{StaticResource RadiusSm}">
                                                    <StackPanel>
                                                        <TextBlock
                                                            FontSize="{StaticResource FontSizeXs}"
                                                            FontWeight="SemiBold"
                                                            Foreground="{DynamicResource AppTextMuted}"
                                                            Text="{DynamicResource Portfolio.Record.Group.Investment}" />
                                                        <WrapPanel Margin="0,6,0,0">
                                                            <RadioButton
                                                                Content="{DynamicResource Portfolio.Tx.Buy}"
                                                                GroupName="TxType"
                                                                IsChecked="{Binding TxType, Converter={StaticResource EqualityConverter}, ConverterParameter=buy, Mode=TwoWay}"
                                                                Style="{StaticResource SegmentBtn}" />
                                                            <RadioButton
                                                                Content="{DynamicResource Portfolio.Tx.Sell}"
                                                                GroupName="TxType"
                                                                IsChecked="{Binding TxType, Converter={StaticResource EqualityConverter}, ConverterParameter=sell, Mode=TwoWay}"
                                                                Style="{StaticResource SegmentBtn}" />
                                                            <RadioButton
                                                                Content="{DynamicResource Portfolio.Tx.Income}"
                                                                GroupName="TxType"
                                                                IsChecked="{Binding TxType, Converter={StaticResource EqualityConverter}, ConverterParameter=income, Mode=TwoWay}"
                                                                Style="{StaticResource SegmentBtn}" />
                                                            <RadioButton
                                                                Content="{DynamicResource Portfolio.Tx.CashDiv}"
                                                                GroupName="TxType"
                                                                IsChecked="{Binding TxType, Converter={StaticResource EqualityConverter}, ConverterParameter=cashDiv, Mode=TwoWay}"
                                                                Style="{StaticResource SegmentBtn}" />
                                                            <RadioButton
                                                                Content="{DynamicResource Portfolio.Tx.StockDiv}"
                                                                GroupName="TxType"
                                                                IsChecked="{Binding TxType, Converter={StaticResource EqualityConverter}, ConverterParameter=stockDiv, Mode=TwoWay}"
                                                                Style="{StaticResource SegmentBtn}" />
                                                        </WrapPanel>
                                                    </StackPanel>
                                                </Border>

                                                <Border
                                                    Margin="0,6,0,0"
                                                    Padding="8"
                                                    Background="Transparent"
                                                    BorderBrush="{DynamicResource AppBorder}"
                                                    BorderThickness="1"
                                                    CornerRadius="{StaticResource RadiusSm}">
                                                    <StackPanel>
                                                        <TextBlock
                                                            FontSize="{StaticResource FontSizeXs}"
                                                            FontWeight="SemiBold"
                                                            Foreground="{DynamicResource AppTextMuted}"
                                                            Text="{DynamicResource Portfolio.Record.Group.Cash}" />
                                                        <WrapPanel Margin="0,6,0,0">
                                                            <RadioButton
                                                                Content="{DynamicResource Portfolio.TradeType.Deposit}"
                                                                GroupName="TxType"
                                                                IsChecked="{Binding TxType, Converter={StaticResource EqualityConverter}, ConverterParameter=deposit, Mode=TwoWay}"
                                                                Style="{StaticResource SegmentBtn}"
                                                                ToolTip="{DynamicResource Portfolio.Tx.DepositHint}" />
                                                            <RadioButton
                                                                Content="{DynamicResource Portfolio.Tx.WithdrawalAction}"
                                                                GroupName="TxType"
                                                                IsChecked="{Binding TxType, Converter={StaticResource EqualityConverter}, ConverterParameter=withdrawal, Mode=TwoWay}"
                                                                Style="{StaticResource SegmentBtn}"
                                                                ToolTip="{DynamicResource Portfolio.Tx.WithdrawalHint}" />
                                                            <RadioButton
                                                                Content="{DynamicResource Portfolio.Tx.TransferAction}"
                                                                GroupName="TxType"
                                                                IsChecked="{Binding TxType, Converter={StaticResource EqualityConverter}, ConverterParameter=transfer, Mode=TwoWay}"
                                                                Style="{StaticResource SegmentBtn}"
                                                                ToolTip="{DynamicResource Portfolio.Tx.TransferHint}" />
                                                        </WrapPanel>
                                                    </StackPanel>
                                                </Border>

                                                <Border
                                                    Margin="0,6,0,0"
                                                    Padding="8"
                                                    Background="Transparent"
                                                    BorderBrush="{DynamicResource AppBorder}"
                                                    BorderThickness="1"
                                                    CornerRadius="{StaticResource RadiusSm}">
                                                    <StackPanel>
                                                        <TextBlock
                                                            FontSize="{StaticResource FontSizeXs}"
                                                            FontWeight="SemiBold"
                                                            Foreground="{DynamicResource AppTextMuted}"
                                                            Text="{DynamicResource Portfolio.Record.Group.Liability}" />
                                                        <WrapPanel Margin="0,6,0,0">
                                                            <RadioButton
                                                                Content="{DynamicResource Portfolio.TradeType.LoanBorrow}"
                                                                GroupName="TxType"
                                                                IsChecked="{Binding TxType, Converter={StaticResource EqualityConverter}, ConverterParameter=loanBorrow, Mode=TwoWay}"
                                                                Style="{StaticResource SegmentBtn}" />
                                                            <RadioButton
                                                                Content="{DynamicResource Portfolio.TradeType.LoanRepay}"
                                                                GroupName="TxType"
                                                                IsChecked="{Binding TxType, Converter={StaticResource EqualityConverter}, ConverterParameter=loanRepay, Mode=TwoWay}"
                                                                Style="{StaticResource SegmentBtn}" />
                                                            <RadioButton
                                                                Content="{DynamicResource Portfolio.TradeType.CreditCardCharge}"
                                                                GroupName="TxType"
                                                                IsChecked="{Binding TxType, Converter={StaticResource EqualityConverter}, ConverterParameter=creditCardCharge, Mode=TwoWay}"
                                                                Style="{StaticResource SegmentBtn}" />
                                                            <RadioButton
                                                                Content="{DynamicResource Portfolio.TradeType.CreditCardPayment}"
                                                                GroupName="TxType"
                                                                IsChecked="{Binding TxType, Converter={StaticResource EqualityConverter}, ConverterParameter=creditCardPayment, Mode=TwoWay}"
                                                                Style="{StaticResource SegmentBtn}" />
                                                        </WrapPanel>
                                                    </StackPanel>
                                                </Border>
                                            </StackPanel>
                                        </Border>
                                    </StackPanel>
                                </DockPanel>
                            </Border>

                            <Border
                                Padding="14,12"
                                Background="{DynamicResource AppBackground}"
                                BorderBrush="{DynamicResource AppBorder}"
                                BorderThickness="1"
                                CornerRadius="{StaticResource RadiusSm}">
                                <StackPanel>
                                    <TextBlock
                                        FontSize="{StaticResource FontSizeSm}"
                                        FontWeight="SemiBold"
                                        Foreground="{DynamicResource AppTextPrimary}"
                                        Text="{DynamicResource Portfolio.Record.Section.Details}" />
                                    <TextBlock
                                        Margin="0,4,0,12"
                                        FontSize="{StaticResource FontSizeXs}"
                                        Foreground="{DynamicResource AppTextMuted}"
                                        Text="{DynamicResource Portfolio.Record.Section.DetailsHint}"
                                        TextWrapping="Wrap"
                                        Visibility="{Binding IsEditMode, Converter={StaticResource InverseBooleanToVisibilityConverter}}" />

                                    <StackPanel Visibility="{Binding IsEditMode, Converter={StaticResource InverseBooleanToVisibilityConverter}}">
                                        <Border Height="2" Background="Transparent" />
                                        <!--  ======== 買入欄位 ========  -->
                                        <txforms:BuyTxForm />

                                        <!--  ======== 賣出欄位 ========  -->
                                        <txforms:SellTxForm />

                                        <!--  ======== 收入欄位 ========  -->
                                        <txforms:IncomeTxForm />

                                        <!--  ======== 現金股利欄位 ========  -->
                                        <txforms:CashDividendTxForm />

                                        <!--  ======== 股票股利欄位 ========  -->
                                        <txforms:StockDividendTxForm />

                                        <!--  ======== 存入/提款欄位 ========  -->
                                        <txforms:CashFlowTxForm />

                                        <!--  ======== 借款/還款欄位 ========  -->
                                        <txforms:LoanTxForm />

                                        <!--  ======== 信用卡欄位 ========  -->
                                        <txforms:CreditCardTxForm />

                                        <!--  ======== 轉帳欄位 ========  -->
                                        <txforms:TransferTxForm />
                                    </StackPanel>

                                    <StackPanel Visibility="{Binding ShowEditLockedSummary, Converter={StaticResource BooleanToVisibilityConverter}}">
                                        <TextBlock
                                            Margin="0,0,0,4"
                                            FontSize="{StaticResource FontSizeXs}"
                                            FontWeight="SemiBold"
                                            Foreground="{DynamicResource AppTextSecondary}"
                                            Text="{DynamicResource Portfolio.Tx.Note}" />
                                        <ui:TextBox Text="{Binding TxNote, UpdateSourceTrigger=PropertyChanged}" />
                                    </StackPanel>

                                    <!--  Error  -->
                                    <TextBlock
                                        Margin="0,12,0,0"
                                        FontSize="{StaticResource FontSizeXs}"
                                        Foreground="{DynamicResource AppDown}"
                                        Text="{Binding TxError}"
                                        Visibility="{Binding TxError, Converter={StaticResource StringToVisibilityConverter}}" />
                                </StackPanel>
                            </Border>
                        </StackPanel>

                        <StackPanel Visibility="{Binding IsRevisionReplacePromptOpen, Converter={StaticResource BooleanToVisibilityConverter}}">
                            <Border
                                Margin="0,0,0,12"
                                Padding="12"
                                Background="{DynamicResource AppBackground}"
                                BorderBrush="{DynamicResource AppBorder}"
                                BorderThickness="1"
                                CornerRadius="{StaticResource RadiusSm}">
                                <StackPanel>
                                    <TextBlock
                                        Margin="0,0,0,8"
                                        FontSize="{StaticResource FontSizeSm}"
                                        FontWeight="SemiBold"
                                        Foreground="{DynamicResource AppTextPrimary}"
                                        Text="{DynamicResource Portfolio.Record.ReplacePromptTitle}" />
                                    <TextBlock
                                        FontSize="{StaticResource FontSizeXs}"
                                        Foreground="{DynamicResource AppTextSecondary}"
                                        Text="{DynamicResource Portfolio.Record.ReplacePrompt}"
                                        TextWrapping="Wrap" />
                                </StackPanel>
                            </Border>
                            <TextBlock
                                Margin="0,0,0,12"
                                FontSize="{StaticResource FontSizeXs}"
                                Foreground="{DynamicResource AppDown}"
                                Text="{Binding RevisionReplacePromptError}"
                                Visibility="{Binding RevisionReplacePromptError, Converter={StaticResource StringToVisibilityConverter}}" />
                        </StackPanel>
                    </StackPanel>
                </ScrollViewer>

                <!--  Footer  -->
                <Border
                    Grid.Row="2"
                    Padding="20,12"
                    BorderBrush="{DynamicResource AppBorder}"
                    BorderThickness="0,1,0,0">
                    <Grid>
                        <Grid>
                            <Grid.Style>
                                <Style TargetType="Grid">
                                    <Setter Property="Visibility" Value="Visible" />
                                    <Style.Triggers>
                                        <DataTrigger Value="True">
                                            <DataTrigger.Binding>
                                                <MultiBinding Converter="{StaticResource WidthScaleThresholdToBooleanConverter}" ConverterParameter="980">
                                                    <Binding ElementName="Root" Path="ActualWidth" />
                                                    <Binding Path="DataContext.Settings.UiScale" RelativeSource="{RelativeSource AncestorType=Window}" />
                                                </MultiBinding>
                                            </DataTrigger.Binding>
                                            <Setter Property="Visibility" Value="Collapsed" />
                                        </DataTrigger>
                                    </Style.Triggers>
                                </Style>
                            </Grid.Style>
                            <DockPanel>
                                <!--  刪除按鈕（僅編輯模式）  -->
                                <ui:Button
                                    Height="30"
                                    Padding="14,0"
                                    Command="{Binding DeleteTradeCommand}"
                                    DockPanel.Dock="Left"
                                    Appearance="Danger"
                                    Visibility="{Binding IsEditMode, Converter={StaticResource BooleanToVisibilityConverter}}">
                                    <TextBlock Foreground="{Binding Foreground, RelativeSource={RelativeSource AncestorType=Button}}" Text="{DynamicResource Portfolio.Tx.Delete}" />
                                </ui:Button>
                                <ui:Button
                                    Height="30"
                                    Margin="8,0,0,0"
                                    Padding="14,0"
                                    Command="{Binding CreateRevisionCommand}"
                                    DockPanel.Dock="Left"
                                    Appearance="Secondary"
                                    Visibility="{Binding IsEditMode, Converter={StaticResource BooleanToVisibilityConverter}}">
                                    <TextBlock Foreground="{Binding Foreground, RelativeSource={RelativeSource AncestorType=Button}}" Text="{DynamicResource Portfolio.Record.CreateRevision}" />
                                </ui:Button>
                                <!--  取消 / 儲存（靠右）  -->
                                <StackPanel HorizontalAlignment="Right" Orientation="Horizontal">
                                    <StackPanel Orientation="Horizontal" Visibility="{Binding IsRevisionReplacePromptOpen, Converter={StaticResource BooleanToVisibilityConverter}}">
                                        <ui:Button
                                            Height="30"
                                            Margin="0,0,8,0"
                                            Padding="14,0"
                                            Command="{Binding KeepBothRecordsCommand}"
                                            Appearance="Secondary">
                                            <TextBlock Foreground="{Binding Foreground, RelativeSource={RelativeSource AncestorType=Button}}" Text="{DynamicResource Portfolio.Record.KeepBoth}" />
                                        </ui:Button>
                                        <ui:Button
                                            Height="30"
                                            Padding="14,0"
                                            Command="{Binding ReplaceOriginalRecordCommand}"
                                            Appearance="Primary">
                                            <TextBlock Foreground="{Binding Foreground, RelativeSource={RelativeSource AncestorType=Button}}" Text="{DynamicResource Portfolio.Record.ReplaceAndDelete}" />
                                        </ui:Button>
                                    </StackPanel>
                                    <StackPanel Orientation="Horizontal" Visibility="{Binding IsRevisionReplacePromptOpen, Converter={StaticResource InverseBooleanToVisibilityConverter}}">
                                        <ui:Button
                                            Height="30"
                                            Margin="0,0,8,0"
                                            Padding="14,0"
                                            Command="{Binding CloseTxDialogCommand}"
                                            Appearance="Secondary">
                                            <TextBlock Foreground="{Binding Foreground, RelativeSource={RelativeSource AncestorType=Button}}" Text="{DynamicResource Portfolio.Cancel}" />
                                        </ui:Button>
                                        <ui:Button
                                            Height="30"
                                            Padding="14,0"
                                            Command="{Binding ConfirmTxCommand}"
                                            Appearance="Primary">
                                            <TextBlock Foreground="{Binding Foreground, RelativeSource={RelativeSource AncestorType=Button}}">
                                                <TextBlock.Style>
                                                    <Style TargetType="TextBlock">
                                                        <Setter Property="Text" Value="{DynamicResource Portfolio.Tx.Confirm}" />
                                                        <Style.Triggers>
                                                            <DataTrigger Binding="{Binding IsEditMode}" Value="True">
                                                                <Setter Property="Text" Value="{DynamicResource Portfolio.Tx.Save}" />
                                                            </DataTrigger>
                                                        </Style.Triggers>
                                                    </Style>
                                                </TextBlock.Style>
                                            </TextBlock>
                                        </ui:Button>
                                    </StackPanel>
                                </StackPanel>
                            </DockPanel>
                        </Grid>

                        <StackPanel>
                            <StackPanel.Style>
                                <Style TargetType="StackPanel">
                                    <Setter Property="Visibility" Value="Collapsed" />
                                    <Style.Triggers>
                                        <DataTrigger Value="True">
                                            <DataTrigger.Binding>
                                                <MultiBinding Converter="{StaticResource WidthScaleThresholdToBooleanConverter}" ConverterParameter="980">
                                                    <Binding ElementName="Root" Path="ActualWidth" />
                                                    <Binding Path="DataContext.Settings.UiScale" RelativeSource="{RelativeSource AncestorType=Window}" />
                                                </MultiBinding>
                                            </DataTrigger.Binding>
                                            <Setter Property="Visibility" Value="Visible" />
                                        </DataTrigger>
                                    </Style.Triggers>
                                </Style>
                            </StackPanel.Style>
                            <StackPanel Orientation="Horizontal" Visibility="{Binding IsEditMode, Converter={StaticResource BooleanToVisibilityConverter}}">
                                <ui:Button
                                    Height="30"
                                    Margin="0,0,8,8"
                                    Padding="14,0"
                                    Command="{Binding DeleteTradeCommand}"
                                    Appearance="Danger">
                                    <TextBlock Foreground="{Binding Foreground, RelativeSource={RelativeSource AncestorType=Button}}" Text="{DynamicResource Portfolio.Tx.Delete}" />
                                </ui:Button>
                                <ui:Button
                                    Height="30"
                                    Margin="0,0,0,8"
                                    Padding="14,0"
                                    Command="{Binding CreateRevisionCommand}"
                                    Appearance="Secondary">
                                    <TextBlock Foreground="{Binding Foreground, RelativeSource={RelativeSource AncestorType=Button}}" Text="{DynamicResource Portfolio.Record.CreateRevision}" />
                                </ui:Button>
                            </StackPanel>
                            <StackPanel Visibility="{Binding IsRevisionReplacePromptOpen, Converter={StaticResource BooleanToVisibilityConverter}}">
                                <ui:Button
                                    Height="30"
                                    Margin="0,0,0,8"
                                    Padding="14,0"
                                    Command="{Binding ReplaceOriginalRecordCommand}"
                                    Appearance="Primary">
                                    <TextBlock Foreground="{Binding Foreground, RelativeSource={RelativeSource AncestorType=Button}}" Text="{DynamicResource Portfolio.Record.ReplaceAndDelete}" />
                                </ui:Button>
                                <ui:Button
                                    Height="30"
                                    Padding="14,0"
                                    Command="{Binding KeepBothRecordsCommand}"
                                    Appearance="Secondary">
                                    <TextBlock Foreground="{Binding Foreground, RelativeSource={RelativeSource AncestorType=Button}}" Text="{DynamicResource Portfolio.Record.KeepBoth}" />
                                </ui:Button>
                            </StackPanel>
                            <StackPanel
                                HorizontalAlignment="Right"
                                Orientation="Horizontal"
                                Visibility="{Binding IsRevisionReplacePromptOpen, Converter={StaticResource InverseBooleanToVisibilityConverter}}">
                                <ui:Button
                                    Height="30"
                                    Margin="0,0,8,0"
                                    Padding="14,0"
                                    Command="{Binding CloseTxDialogCommand}"
                                    Appearance="Secondary">
                                    <TextBlock Foreground="{Binding Foreground, RelativeSource={RelativeSource AncestorType=Button}}" Text="{DynamicResource Portfolio.Cancel}" />
                                </ui:Button>
                                <ui:Button
                                    Height="30"
                                    Padding="14,0"
                                    Command="{Binding ConfirmTxCommand}"
                                    Appearance="Primary">
                                    <TextBlock Foreground="{Binding Foreground, RelativeSource={RelativeSource AncestorType=Button}}">
                                        <TextBlock.Style>
                                            <Style TargetType="TextBlock">
                                                <Setter Property="Text" Value="{DynamicResource Portfolio.Tx.Confirm}" />
                                                <Style.Triggers>
                                                    <DataTrigger Binding="{Binding IsEditMode}" Value="True">
                                                        <Setter Property="Text" Value="{DynamicResource Portfolio.Tx.Save}" />
                                                    </DataTrigger>
                                                </Style.Triggers>
                                            </Style>
                                        </TextBlock.Style>
                                    </TextBlock>
                                </ui:Button>
                            </StackPanel>
                        </StackPanel>
                    </Grid>
                </Border>
            </Grid>
        </Border>
    </Grid>
</UserControl>
