<UserControl
    x:Class="Assetra.WPF.Features.Portfolio.Controls.AddRecordDialog"
    xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
    xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
    xmlns:behaviors="clr-namespace:Assetra.WPF.Infrastructure.Behaviors"
    xmlns:d="http://schemas.microsoft.com/expression/blend/2008"
    xmlns:ds="clr-namespace:Assetra.WPF.DesignSystem.Controls"
    xmlns:mc="http://schemas.openxmlformats.org/markup-compatibility/2006"
    xmlns:txforms="clr-namespace:Assetra.WPF.Features.Portfolio.Controls.TxForms"
    xmlns:vm="clr-namespace:Assetra.WPF.Features.Portfolio.SubViewModels"
    x:Name="Root"
    d:DataContext="{d:DesignInstance Type={x:Type vm:TransactionDialogViewModel}}"
    Visibility="{Binding IsTxDialogOpen, Converter={StaticResource BooleanToVisibilityConverter}}"
    mc:Ignorable="d">

    <Grid>
        <!--  半透明背景幕  -->
        <Grid Style="{StaticResource AppDialogOverlay}" />

        <!--
            Dialog card：寬度固定 600px (表單欄位過寬難讀)，高度動態跟著視窗高度。
            MaxHeight = Window.ActualHeight - 80 (40 上下留白) — 大螢幕可一次顯示
            完所有欄位、小螢幕也能 fit。MinHeight=480 確保極端情境（迷你筆電視窗
            被壓很小）至少看得到 header + 幾個欄位 + footer。
        -->
        <Border
            Width="600"
            MinHeight="480"
            MaxHeight="{Binding ActualHeight, RelativeSource={RelativeSource AncestorType=Window}, Converter={StaticResource SubtractDoubleConverter}, ConverterParameter=80}"
            Padding="0"
            HorizontalAlignment="Center"
            VerticalAlignment="Center"
            behaviors:EscapeKeyCommandBehavior.Command="{Binding CloseTxDialogCommand}"
            Style="{StaticResource AppDialogShell}">
            <Grid>
                <Grid.RowDefinitions>
                    <RowDefinition Height="Auto" />
                    <!--  Header  -->
                    <RowDefinition Height="*" />
                    <!--  Content (scroll)  -->
                    <RowDefinition Height="Auto" />
                    <!--  Footer  -->
                </Grid.RowDefinitions>

                <!--  Header  -->
                <Border
                    Grid.Row="0"
                    Padding="20,14"
                    BorderBrush="{DynamicResource AppBorder}"
                    BorderThickness="0,0,0,1">
                    <DockPanel>
                        <StackPanel>
                            <TextBlock
                                VerticalAlignment="Center"
                                FontSize="{StaticResource Font.Size.Sm}"
                                FontWeight="SemiBold"
                                Foreground="{DynamicResource AppTextPrimary}">
                                <TextBlock.Style>
                                    <!--
                                        Title precedence (top wins):
                                        1. Replace prompt / Revision / Edit mode → fixed string
                                        2. Create mode → 動態依 TxDynamicTitleKey 切「新增買入交易」等
                                    -->
                                    <Style TargetType="TextBlock">
                                        <Setter Property="Text" Value="{Binding TxDynamicTitleKey, Converter={StaticResource ResourceKeyToStringConverter}}" />
                                        <Style.Triggers>
                                            <DataTrigger Binding="{Binding IsRevisionReplacePromptOpen}" Value="True">
                                                <Setter Property="Text" Value="{DynamicResource Portfolio.Record.ReplacePromptTitle}" />
                                            </DataTrigger>
                                            <DataTrigger Binding="{Binding IsRevisionMode}" Value="True">
                                                <Setter Property="Text" Value="{DynamicResource Portfolio.Record.ReviseTitle}" />
                                            </DataTrigger>
                                            <DataTrigger Binding="{Binding IsEditMode}" Value="True">
                                                <Setter Property="Text" Value="{DynamicResource Portfolio.Tx.EditTitle}" />
                                            </DataTrigger>
                                        </Style.Triggers>
                                    </Style>
                                </TextBlock.Style>
                            </TextBlock>
                            <TextBlock
                                Margin="0,2,0,0"
                                FontSize="{StaticResource Font.Size.Xs}"
                                Foreground="{DynamicResource AppTextMuted}"
                                TextWrapping="Wrap">
                                <TextBlock.Style>
                                    <!--
                                        Subtitle: default = create-mode guidance ("記錄您的買入、賣出..."),
                                        switches to mode-specific text when editing / revising / replacing.
                                        Create mode 預設顯示 — 使用者打開 dialog 第一眼就知道這裡做什麼。
                                    -->
                                    <Style TargetType="TextBlock">
                                        <Setter Property="Text" Value="{DynamicResource Portfolio.Record.CreateSubtitle}" />
                                        <Style.Triggers>
                                            <DataTrigger Binding="{Binding IsEditingMetaOnly}" Value="True">
                                                <Setter Property="Text" Value="{DynamicResource Portfolio.Record.EditSubtitle}" />
                                            </DataTrigger>
                                            <DataTrigger Binding="{Binding IsRevisionMode}" Value="True">
                                                <Setter Property="Text" Value="{DynamicResource Portfolio.Record.RevisionSubtitle}" />
                                            </DataTrigger>
                                            <DataTrigger Binding="{Binding IsRevisionReplacePromptOpen}" Value="True">
                                                <Setter Property="Text" Value="{DynamicResource Portfolio.Record.ReplaceSubtitle}" />
                                            </DataTrigger>
                                        </Style.Triggers>
                                    </Style>
                                </TextBlock.Style>
                            </TextBlock>
                        </StackPanel>
                        <Button
                            Width="28"
                            Height="28"
                            Padding="0"
                            HorizontalAlignment="Right"
                            Command="{Binding CloseTxDialogCommand}"
                            DockPanel.Dock="Right"
                            Style="{StaticResource AppIconButton}"
                            ToolTip="{DynamicResource Common.Close}">
                            <ds:AppIcon
                                FontSize="12"
                                Foreground="{DynamicResource AppTextMuted}"
                                Symbol="Dismiss24" />
                        </Button>
                    </DockPanel>
                </Border>

                <!--  Scrollable content  -->
                <ScrollViewer
                    x:Name="ContentScrollViewer"
                    Grid.Row="1"
                    Padding="20,16"
                    VerticalScrollBarVisibility="Auto">
                    <StackPanel>

                        <!--
                            Compact meta-only edit banner. Replaces the previous trio of
                            stacked banners (locked summary card + ReviseHint + MetaOnlyHint)
                            with a single inline lock-card. Shown ONLY for meta-only edits
                            (Sell / Transfer / legacy Buy/StockDiv); direct-editable types
                            see no banner — their fields are pre-filled and editable inline.
                            
                            Layout: 🔒 icon (left) | summary line + lock reason (right)
                        -->
                        <Border
                            Margin="0,0,0,12"
                            Padding="12,10"
                            Background="{DynamicResource AppSurfaceAlt}"
                            BorderBrush="{DynamicResource AppBorder}"
                            BorderThickness="1"
                            CornerRadius="{StaticResource Radius.Sm}"
                            Visibility="{Binding ShowEditLockedSummary, Converter={StaticResource BooleanToVisibilityConverter}}">
                            <Grid>
                                <Grid.ColumnDefinitions>
                                    <ColumnDefinition Width="Auto" />
                                    <ColumnDefinition Width="*" />
                                </Grid.ColumnDefinitions>
                                <ds:AppIcon
                                    Grid.Column="0"
                                    Margin="0,1,10,0"
                                    VerticalAlignment="Top"
                                    FontSize="14"
                                    Foreground="{DynamicResource AppTextMuted}"
                                    Symbol="LockClosed24" />
                                <StackPanel Grid.Column="1">
                                    <!--  Summary line: 類型 · 對象 · 金額 × 數量  -->
                                    <TextBlock
                                        FontSize="{StaticResource Font.Size.Sm}"
                                        FontWeight="SemiBold"
                                        Foreground="{DynamicResource AppTextPrimary}"
                                        TextWrapping="Wrap">
                                        <Run Text="{Binding EditSummaryType, Mode=OneWay}" />
                                        <Run Foreground="{DynamicResource AppTextMuted}" Text=" · " />
                                        <Run Text="{Binding EditSummaryTarget, Mode=OneWay}" />
                                    </TextBlock>
                                    <TextBlock
                                        Margin="0,2,0,0"
                                        FontFamily="{StaticResource Font.Family.Base}"
                                        FontSize="{StaticResource Font.Size.Xs}"
                                        Foreground="{DynamicResource AppTextSecondary}"
                                        Typography.NumeralAlignment="Tabular">
                                        <Run Text="{Binding EditSummaryAmount, Mode=OneWay}" />
                                        <Run Foreground="{DynamicResource AppTextMuted}" Text=" × " />
                                        <Run Text="{Binding EditSummaryQuantity, Mode=OneWay}" />
                                    </TextBlock>
                                    <!--  Lock reason — single line, replaces CoreLocked + MetaOnlyHint  -->
                                    <TextBlock
                                        Margin="0,8,0,0"
                                        FontSize="{StaticResource Font.Size.Xs}"
                                        Foreground="{DynamicResource AppTextSecondary}"
                                        Text="{DynamicResource Portfolio.Record.CoreLocked}"
                                        TextWrapping="Wrap" />
                                </StackPanel>
                            </Grid>
                        </Border>

                        <!--
                            Revision-mode hint — kept only for the legacy "建立修正版"
                            (now "刪除此筆並新增") flow on meta-only edits, where the user
                            explicitly clicked the recreate button.
                        -->
                        <Border
                            Margin="0,0,0,12"
                            Padding="10,8"
                            Background="{DynamicResource AppBackground}"
                            BorderBrush="{DynamicResource AppBorder}"
                            BorderThickness="1"
                            CornerRadius="{StaticResource Radius.Sm}"
                            Visibility="{Binding IsRevisionMode, Converter={StaticResource BooleanToVisibilityConverter}}">
                            <TextBlock
                                FontSize="{StaticResource Font.Size.Xs}"
                                Foreground="{DynamicResource AppTextSecondary}"
                                Text="{DynamicResource Portfolio.Record.RevisionModeHint}"
                                TextWrapping="Wrap" />
                        </Border>

                        <StackPanel Visibility="{Binding IsRevisionReplacePromptOpen, Converter={StaticResource InverseBooleanToVisibilityConverter}}">
                            <!--
                                P2.8 — 移除「基本資訊」 card border + 標題 + 提示文，flatten 整個表單。
                                Dialog header 已用 subtitle 提示用途，內部不再需要 section 標題。
                                所有欄位以一致的 vertical rhythm 排列：field block bottom margin = 14、
                                label → input margin = 6（從原本 4 加寬，給標籤更舒適的呼吸感）。
                            -->
                            <StackPanel>
                                <StackPanel>

                                    <!--
                                        AddRecordDialog Phase 2.1 — 「選擇資產」統一選擇器。
                                        本階段 (P2.1) 純展示：使用者選了沒有 cascade，只是 SelectedAsset
                                        observable 會 trigger PropertyChanged。P2.2 會接 OnSelectedAssetChanged
                                        → 自動帶幣別 + 推薦現金帳戶；P2.3 → 過濾 AvailableTradeTypes。
                                        編輯模式下擬作 read-only label，這版先讓它跟新增模式長一樣。
                                    -->
                                    <StackPanel
                                        Margin="0,0,0,14"
                                        Visibility="{Binding ShowEditLockedSummary, Converter={StaticResource InverseBooleanToVisibilityConverter}}">
                                        <TextBlock
                                            Margin="0,0,0,6"
                                            FontSize="{StaticResource Font.Size.Xs}"
                                            FontWeight="SemiBold"
                                            Foreground="{DynamicResource AppTextSecondary}"
                                            Text="{DynamicResource Portfolio.Tx.Asset.Label}" />
                                        <!--
                                            P2.5 fix — 直接綁 ItemTemplate（不用 DisplayMemberPath）解決
                                            「ComboBox SelectionBox 顯示成 record ToString」的 bug。
                                            兩行 layout：PrimaryName 大字、SecondaryLine 小字灰字。
                                            ItemsSource 走 ICollectionView (AvailableAssetsView) 帶分組。
                                            GroupStyle.HeaderTemplate 用 ResourceKeyToStringConverter 解析
                                            「投資 / 現金 / 負債」i18n keys。
                                        -->
                                        <!--
                                            P2.7 — 套 FormComboBoxWithSearch（頂部嵌搜尋框）。Tag 是 style 內
                                            search TextBox 的 TwoWay bridge — VM 收到 keystroke 後 Refresh
                                            ICollectionView 觸發 AssetMatchesSearch 過濾。IsTextSearchEnabled
                                            關掉 WPF 內建 type-ahead 避免跟 VM filter 互打。
                                        -->
                                        <ComboBox
                                            IsTextSearchEnabled="False"
                                            ItemsSource="{Binding AvailableAssetsView}"
                                            SelectedItem="{Binding SelectedAsset, Mode=TwoWay}"
                                            Style="{StaticResource FormComboBoxWithSearch}"
                                            Tag="{Binding AssetSearchText, Mode=TwoWay, UpdateSourceTrigger=PropertyChanged}"
                                            ToolTip="{DynamicResource Portfolio.Tx.Asset.Hint}">
                                            <ComboBox.ItemTemplate>
                                                <DataTemplate>
                                                    <StackPanel Margin="0,2,0,2">
                                                        <TextBlock
                                                            FontSize="{StaticResource Font.Size.Sm}"
                                                            Foreground="{DynamicResource AppTextPrimary}"
                                                            Text="{Binding PrimaryName}" />
                                                        <TextBlock
                                                            Margin="0,2,0,0"
                                                            FontSize="{StaticResource Font.Size.Xs}"
                                                            Foreground="{DynamicResource AppTextMuted}"
                                                            Text="{Binding SecondaryLine}" />
                                                    </StackPanel>
                                                </DataTemplate>
                                            </ComboBox.ItemTemplate>
                                            <ComboBox.GroupStyle>
                                                <GroupStyle>
                                                    <GroupStyle.HeaderTemplate>
                                                        <DataTemplate>
                                                            <Border
                                                                Padding="6,4,0,4"
                                                                BorderBrush="{DynamicResource AppBorder}"
                                                                BorderThickness="0,0,0,1">
                                                                <TextBlock
                                                                    FontSize="{StaticResource Font.Size.Xs}"
                                                                    FontWeight="SemiBold"
                                                                    Foreground="{DynamicResource AppTextMuted}"
                                                                    Text="{Binding Name, Converter={StaticResource ResourceKeyToStringConverter}}" />
                                                            </Border>
                                                        </DataTemplate>
                                                    </GroupStyle.HeaderTemplate>
                                                </GroupStyle>
                                            </ComboBox.GroupStyle>
                                        </ComboBox>
                                    </StackPanel>

                                    <!--
                                        P2.9 — 順序依使用者要求重排為 類型 | 日期 (paired) → 幣別 (own row)。
                                        類型 col 0 在前因 type picker 是「依資產推導」緊接 asset 後最自然；
                                        日期 col 2 在右。Currency 通常從資產自動帶，自己佔一行（窄控件 + 右側
                                        留白 = 呼吸感），不擠進類型/日期那 row 造成 3 欄擁擠。
                                    -->
                                    <Grid Margin="0,0,0,14">
                                        <Grid.ColumnDefinitions>
                                            <ColumnDefinition Width="*" />
                                            <ColumnDefinition Width="12" />
                                            <ColumnDefinition Width="*" />
                                        </Grid.ColumnDefinitions>

                                        <!--
                                            Type picker — meta-only 編輯時隱藏（鎖定卡裡已顯示
                                            type；改類型對 meta-only 沒意義）。
                                        -->
                                        <StackPanel
                                            Grid.Column="0"
                                            Visibility="{Binding ShowEditLockedSummary, Converter={StaticResource InverseBooleanToVisibilityConverter}}">
                                            <TextBlock
                                                Margin="0,0,0,6"
                                                FontSize="{StaticResource Font.Size.Xs}"
                                                FontWeight="SemiBold"
                                                Foreground="{DynamicResource AppTextSecondary}"
                                                Text="{DynamicResource Portfolio.TradeHistory.Type}" />
                                            <!--
                                                DisplayMemberPath 跟 ItemTemplate 互斥 (WPF 限制：
                                                同時設會丟 InvalidOperationException at runtime)。
                                                這裡用 ItemTemplate 是因為 DisplayKey 是 i18n
                                                resource key，需要走 Converter 解析成當下語系字串。
                                                Tag = placeholder「請選擇類型」，SelectedItem=null 時自動顯示。
                                            -->
                                            <ComboBox
                                                IsEnabled="{Binding CanSelectTxType}"
                                                ItemsSource="{Binding AvailableTradeTypes}"
                                                SelectedValuePath="Key"
                                                SelectedValue="{Binding TxType, Mode=TwoWay}"
                                                Style="{StaticResource FormComboBox}"
                                                Tag="{DynamicResource Portfolio.Tx.TypePicker.Placeholder}"
                                                ToolTip="{Binding TxTypePickerHintKey, Converter={StaticResource ResourceKeyToStringConverter}}"
                                                ToolTipService.ShowOnDisabled="True">
                                                <ComboBox.ItemTemplate>
                                                    <DataTemplate>
                                                        <TextBlock Text="{Binding DisplayKey, Converter={StaticResource ResourceKeyToStringConverter}}" />
                                                    </DataTemplate>
                                                </ComboBox.ItemTemplate>
                                            </ComboBox>
                                        </StackPanel>

                                        <StackPanel Grid.Column="2">
                                            <TextBlock
                                                Margin="0,0,0,6"
                                                FontSize="{StaticResource Font.Size.Xs}"
                                                FontWeight="SemiBold"
                                                Foreground="{DynamicResource AppTextSecondary}"
                                                Text="{DynamicResource Portfolio.Tx.Date}" />
                                            <DatePicker
                                                MinWidth="132"
                                                HorizontalContentAlignment="Left"
                                                SelectedDate="{Binding TxDate, Mode=TwoWay, UpdateSourceTrigger=PropertyChanged}"
                                                Style="{StaticResource AppDatePicker}" />
                                        </StackPanel>
                                    </Grid>

                                    <!--
                                        P2.2 — 通用「幣別」ComboBox。選了資產後自動帶值；使用者可手動覆寫
                                        (覆寫後 _userTouchedCurrency = true，後續切換資產不會被自動蓋掉)。
                                        SupportedCurrencies 走 ICurrencyService（跟 Settings 共用清單）。
                                    -->
                                    <StackPanel
                                        Margin="0,0,0,14"
                                        Visibility="{Binding ShowEditLockedSummary, Converter={StaticResource InverseBooleanToVisibilityConverter}}">
                                        <TextBlock
                                            Margin="0,0,0,6"
                                            FontSize="{StaticResource Font.Size.Xs}"
                                            FontWeight="SemiBold"
                                            Foreground="{DynamicResource AppTextSecondary}"
                                            Text="{DynamicResource Portfolio.Tx.Currency}" />
                                        <ComboBox
                                            HorizontalAlignment="Left"
                                            MinWidth="120"
                                            ItemsSource="{Binding SupportedCurrencies}"
                                            SelectedItem="{Binding TxCurrency, Mode=TwoWay}"
                                            Style="{StaticResource FormComboBox}" />
                                    </StackPanel>

                                    <!--
                                        顯示位置提示 — 選類型後告訴使用者這筆交易會出現在哪幾頁。
                                        解決「新增的資料去哪了」first-time 困惑。
                                        HasTxDestination 為 false（未選類型）時隱藏。
                                        Margin Top=0 因為 currency 區塊已有 14px bottom margin，不需重複。
                                    -->
                                    <Border
                                        Margin="0,0,0,0"
                                        Padding="10,8"
                                        Background="{DynamicResource AppAccentSubtle}"
                                        BorderBrush="{DynamicResource AppAccent}"
                                        BorderThickness="1"
                                        CornerRadius="{StaticResource Radius.Sm}"
                                        Visibility="{Binding HasTxDestination, Converter={StaticResource BooleanToVisibilityConverter}}">
                                        <StackPanel Orientation="Horizontal">
                                            <ds:AppIcon
                                                Margin="0,1,8,0"
                                                VerticalAlignment="Top"
                                                FontSize="12"
                                                Foreground="{DynamicResource AppAccent}"
                                                Symbol="Info24" />
                                            <StackPanel>
                                                <TextBlock
                                                    FontSize="{StaticResource Font.Size.Xs}"
                                                    Foreground="{DynamicResource AppTextSecondary}"
                                                    Text="{DynamicResource Portfolio.Record.Destination.Hint}" />
                                                <TextBlock
                                                    Margin="0,2,0,0"
                                                    FontSize="{StaticResource Font.Size.Xs}"
                                                    FontWeight="SemiBold"
                                                    Foreground="{DynamicResource AppAccent}"
                                                    Text="{Binding TxDestinationKey, Converter={StaticResource ResourceKeyToStringConverter}}"
                                                    TextWrapping="Wrap" />
                                            </StackPanel>
                                        </StackPanel>
                                    </Border>
                                </StackPanel>
                            </StackPanel>


                            <!--
                                P2.5 — 移除「紀錄內容」section 標題 + 副標題 + 卡片邊框，
                                跟參考設計對齊 (flat layout)。Per-type sub-panels 直接接在
                                基本資訊區下方，視覺上是同一段表單。
                            -->
                            <Border Padding="0">
                                <StackPanel>

                                    <!--
                                        Per-type form panel — shown for new records and
                                        direct-edit types so users can change economic
                                        fields. Hidden ONLY for meta-only edits where the
                                        compact lock card + note-only fallback below
                                        replaces it.
                                    -->
                                    <StackPanel Visibility="{Binding ShowEditLockedSummary, Converter={StaticResource InverseBooleanToVisibilityConverter}}">
                                        <Border Height="2" Background="Transparent" />

                                        <!--
                                            「所屬群組」selector 已移除 — 使用者反映此 dialog 應該專注
                                            在交易本身，bucket 分組屬於投資資產頁面的管理動作而不是
                                            每筆交易的決策點。SelectedPortfolioGroup 在 VM 仍保有預設
                                            值（DefaultId），所有 group filter / KPI 仍正常運作；只是
                                            不再從新增交易 dialog 暴露切換。
                                        -->

                                        <!--  ======== 買入欄位 ========  -->
                                        <txforms:BuyTxForm />

                                        <!--  ======== 賣出欄位 ========  -->
                                        <txforms:SellTxForm />

                                        <!--  ======== 收入欄位 ========  -->
                                        <txforms:IncomeTxForm />

                                        <!--  ======== 現金股利欄位 ========  -->
                                        <txforms:CashDividendTxForm />

                                        <!--  ======== 股票股利欄位 ========  -->
                                        <txforms:StockDividendTxForm />

                                        <!--  ======== 存入/提款欄位 ========  -->
                                        <txforms:CashFlowTxForm />

                                        <!--  ======== 借款/還款欄位 ========  -->
                                        <txforms:LoanTxForm />

                                        <!--  ======== 信用卡欄位 ========  -->
                                        <txforms:CreditCardTxForm />

                                        <!--  ======== 轉帳欄位 ========  -->
                                        <txforms:TransferTxForm />
                                    </StackPanel>

                                    <!--
                                        Impact preview — projects the post-save balance of
                                        the selected cash account so the user can sanity-check
                                        before clicking Save. Computed in
                                        TransactionDialogViewModel.Preview.cs; visible only
                                        when HasImpactPreview is true (i.e. supported type
                                        + parseable amount + balance actually changes).
                                        Hidden for meta-only edits since the form is hidden.
                                    -->
                                    <Border
                                        Margin="0,12,0,0"
                                        Padding="10,8"
                                        Background="{DynamicResource AppAccentSubtle}"
                                        BorderBrush="{DynamicResource AppAccent}"
                                        BorderThickness="3,0,0,0"
                                        CornerRadius="{StaticResource Radius.Sm}"
                                        Visibility="{Binding HasImpactPreview, Converter={StaticResource BooleanToVisibilityConverter}}">
                                        <StackPanel Orientation="Horizontal">
                                            <ds:AppIcon
                                                Margin="0,1,8,0"
                                                VerticalAlignment="Top"
                                                FontSize="13"
                                                Foreground="{DynamicResource AppAccent}"
                                                Symbol="DataPie24" />
                                            <TextBlock
                                                FontFamily="{StaticResource Font.Family.Base}"
                                                FontSize="{StaticResource Font.Size.Xs}"
                                                Foreground="{DynamicResource AppTextPrimary}"
                                                Text="{Binding ImpactPreviewText}"
                                                TextWrapping="Wrap"
                                                Typography.NumeralAlignment="Tabular" />
                                        </StackPanel>
                                    </Border>

                                    <!--
                                        P2.9 — 備註 unified at dialog level (was: only-visible for meta-only edit).
                                        所有 per-type forms 的 TxNote 欄位被刪除，這裡是 single source。
                                        Margin Top=14 跟其他 field block 一致；placeholder 走 Tag。
                                    -->
                                    <StackPanel Margin="0,14,0,0">
                                        <TextBlock
                                            Margin="0,0,0,6"
                                            FontSize="{StaticResource Font.Size.Xs}"
                                            FontWeight="SemiBold"
                                            Foreground="{DynamicResource AppTextSecondary}"
                                            Text="{DynamicResource Portfolio.Tx.Note}" />
                                        <TextBox
                                            MinHeight="64"
                                            AcceptsReturn="True"
                                            Style="{StaticResource AppTextBox}"
                                            Tag="{DynamicResource Portfolio.Tx.Note.Placeholder}"
                                            Text="{Binding TxNote, UpdateSourceTrigger=PropertyChanged}"
                                            TextWrapping="Wrap"
                                            VerticalContentAlignment="Top" />
                                    </StackPanel>

                                    <!--  Error  -->
                                    <TextBlock
                                        Margin="0,12,0,0"
                                        FontSize="{StaticResource Font.Size.Xs}"
                                        Foreground="{DynamicResource AppDown}"
                                        Text="{Binding TxError}"
                                        Visibility="{Binding TxError, Converter={StaticResource StringToVisibilityConverter}}" />
                                </StackPanel>
                            </Border>
                        </StackPanel>

                        <StackPanel Visibility="{Binding IsRevisionReplacePromptOpen, Converter={StaticResource BooleanToVisibilityConverter}}">
                            <Border
                                Margin="0,0,0,12"
                                Padding="12"
                                Background="{DynamicResource AppBackground}"
                                BorderBrush="{DynamicResource AppBorder}"
                                BorderThickness="1"
                                CornerRadius="{StaticResource Radius.Sm}">
                                <StackPanel>
                                    <TextBlock
                                        Margin="0,0,0,8"
                                        FontSize="{StaticResource Font.Size.Sm}"
                                        FontWeight="SemiBold"
                                        Foreground="{DynamicResource AppTextPrimary}"
                                        Text="{DynamicResource Portfolio.Record.ReplacePromptTitle}" />
                                    <TextBlock
                                        FontSize="{StaticResource Font.Size.Xs}"
                                        Foreground="{DynamicResource AppTextSecondary}"
                                        Text="{DynamicResource Portfolio.Record.ReplacePrompt}"
                                        TextWrapping="Wrap" />
                                </StackPanel>
                            </Border>
                            <TextBlock
                                Margin="0,0,0,12"
                                FontSize="{StaticResource Font.Size.Xs}"
                                Foreground="{DynamicResource AppDown}"
                                Text="{Binding RevisionReplacePromptError}"
                                Visibility="{Binding RevisionReplacePromptError, Converter={StaticResource StringToVisibilityConverter}}" />
                        </StackPanel>
                    </StackPanel>
                </ScrollViewer>

                <!--  Footer  -->
                <Border
                    Grid.Row="2"
                    Padding="20,12"
                    BorderBrush="{DynamicResource AppBorder}"
                    BorderThickness="0,1,0,0">
                    <Grid>
                        <Grid>
                            <Grid.Style>
                                <Style TargetType="Grid">
                                    <Setter Property="Visibility" Value="Visible" />
                                    <Style.Triggers>
                                        <DataTrigger Value="True">
                                            <DataTrigger.Binding>
                                                <MultiBinding Converter="{StaticResource WidthScaleThresholdToBooleanConverter}" ConverterParameter="980">
                                                    <Binding ElementName="Root" Path="ActualWidth" />
                                                    <Binding Path="DataContext.Settings.UiScale" RelativeSource="{RelativeSource AncestorType=Window}" />
                                                </MultiBinding>
                                            </DataTrigger.Binding>
                                            <Setter Property="Visibility" Value="Collapsed" />
                                        </DataTrigger>
                                    </Style.Triggers>
                                </Style>
                            </Grid.Style>
                            <DockPanel>
                                <!--  刪除按鈕（僅編輯模式）  -->
                                <Button
                                    Height="30"
                                    Padding="14,0"
                                    Command="{Binding RequestDeleteTradeCommand}"
                                    DockPanel.Dock="Left"
                                    Style="{StaticResource AppDangerButton}"
                                    Visibility="{Binding IsEditMode, Converter={StaticResource BooleanToVisibilityConverter}}">
                                    <TextBlock Foreground="{Binding Foreground, RelativeSource={RelativeSource AncestorType=Button}}" Text="{DynamicResource Portfolio.Tx.Delete}" />
                                </Button>
                                <!--
                                    「刪除此筆並新增」只在 meta-only 編輯（Sell / Transfer /
                                    legacy Buy/StockDiv）時才有意義 — 其他類型直接按「儲存」
                                    就會自動覆寫原紀錄，不需要二次選擇。
                                -->
                                <Button
                                    Height="30"
                                    Margin="8,0,0,0"
                                    Padding="14,0"
                                    Command="{Binding CreateRevisionCommand}"
                                    DockPanel.Dock="Left"
                                    Style="{StaticResource AppSecondaryButton}"
                                    Visibility="{Binding IsEditingMetaOnly, Converter={StaticResource BooleanToVisibilityConverter}}">
                                    <TextBlock Foreground="{Binding Foreground, RelativeSource={RelativeSource AncestorType=Button}}" Text="{DynamicResource Portfolio.Record.CreateRevision}" />
                                </Button>
                                <!--  取消 / 儲存（靠右）  -->
                                <StackPanel HorizontalAlignment="Right" Orientation="Horizontal">
                                    <StackPanel Orientation="Horizontal" Visibility="{Binding IsRevisionReplacePromptOpen, Converter={StaticResource BooleanToVisibilityConverter}}">
                                        <Button
                                            Height="30"
                                            Margin="0,0,8,0"
                                            Padding="14,0"
                                            Command="{Binding KeepBothRecordsCommand}"
                                            Style="{StaticResource AppSecondaryButton}">
                                            <TextBlock Foreground="{Binding Foreground, RelativeSource={RelativeSource AncestorType=Button}}" Text="{DynamicResource Portfolio.Record.KeepBoth}" />
                                        </Button>
                                        <Button
                                            Height="30"
                                            Padding="14,0"
                                            Command="{Binding ReplaceOriginalRecordCommand}"
                                            Style="{StaticResource AppPrimaryButton}">
                                            <TextBlock Foreground="{Binding Foreground, RelativeSource={RelativeSource AncestorType=Button}}" Text="{DynamicResource Portfolio.Record.ReplaceAndDelete}" />
                                        </Button>
                                    </StackPanel>
                                    <StackPanel Orientation="Horizontal" Visibility="{Binding IsRevisionReplacePromptOpen, Converter={StaticResource InverseBooleanToVisibilityConverter}}">
                                        <Button
                                            Height="30"
                                            Margin="0,0,8,0"
                                            Padding="14,0"
                                            Command="{Binding CloseTxDialogCommand}"
                                            Style="{StaticResource AppSecondaryButton}">
                                            <TextBlock Foreground="{Binding Foreground, RelativeSource={RelativeSource AncestorType=Button}}" Text="{DynamicResource Portfolio.Cancel}" />
                                        </Button>
                                        <Button
                                            Height="30"
                                            Padding="14,0"
                                            Command="{Binding ConfirmTxCommand}"
                                            Style="{StaticResource AppPrimaryButton}">
                                            <TextBlock>
                                                <TextBlock.Style>
                                                    <Style BasedOn="{StaticResource AppButtonText}" TargetType="TextBlock">
                                                        <Setter Property="Text" Value="{DynamicResource Portfolio.Tx.Confirm}" />
                                                        <Style.Triggers>
                                                            <DataTrigger Binding="{Binding IsEditMode}" Value="True">
                                                                <Setter Property="Text" Value="{DynamicResource Portfolio.Tx.Save}" />
                                                            </DataTrigger>
                                                        </Style.Triggers>
                                                    </Style>
                                                </TextBlock.Style>
                                            </TextBlock>
                                        </Button>
                                    </StackPanel>
                                </StackPanel>
                            </DockPanel>
                        </Grid>

                        <StackPanel>
                            <StackPanel.Style>
                                <Style TargetType="StackPanel">
                                    <Setter Property="Visibility" Value="Collapsed" />
                                    <Style.Triggers>
                                        <DataTrigger Value="True">
                                            <DataTrigger.Binding>
                                                <MultiBinding Converter="{StaticResource WidthScaleThresholdToBooleanConverter}" ConverterParameter="980">
                                                    <Binding ElementName="Root" Path="ActualWidth" />
                                                    <Binding Path="DataContext.Settings.UiScale" RelativeSource="{RelativeSource AncestorType=Window}" />
                                                </MultiBinding>
                                            </DataTrigger.Binding>
                                            <Setter Property="Visibility" Value="Visible" />
                                        </DataTrigger>
                                    </Style.Triggers>
                                </Style>
                            </StackPanel.Style>
                            <StackPanel Orientation="Horizontal" Visibility="{Binding IsEditMode, Converter={StaticResource BooleanToVisibilityConverter}}">
                                <Button
                                    Height="30"
                                    Margin="0,0,8,8"
                                    Padding="14,0"
                                    Command="{Binding RequestDeleteTradeCommand}"
                                    Style="{StaticResource AppDangerButton}">
                                    <TextBlock Foreground="{Binding Foreground, RelativeSource={RelativeSource AncestorType=Button}}" Text="{DynamicResource Portfolio.Tx.Delete}" />
                                </Button>
                                <!--  Same meta-only gate as the desktop layout above.  -->
                                <Button
                                    Height="30"
                                    Margin="0,0,0,8"
                                    Padding="14,0"
                                    Command="{Binding CreateRevisionCommand}"
                                    Style="{StaticResource AppSecondaryButton}"
                                    Visibility="{Binding IsEditingMetaOnly, Converter={StaticResource BooleanToVisibilityConverter}}">
                                    <TextBlock Foreground="{Binding Foreground, RelativeSource={RelativeSource AncestorType=Button}}" Text="{DynamicResource Portfolio.Record.CreateRevision}" />
                                </Button>
                            </StackPanel>
                            <StackPanel Visibility="{Binding IsRevisionReplacePromptOpen, Converter={StaticResource BooleanToVisibilityConverter}}">
                                <Button
                                    Height="30"
                                    Margin="0,0,0,8"
                                    Padding="14,0"
                                    Command="{Binding ReplaceOriginalRecordCommand}"
                                    Style="{StaticResource AppPrimaryButton}">
                                    <TextBlock Foreground="{Binding Foreground, RelativeSource={RelativeSource AncestorType=Button}}" Text="{DynamicResource Portfolio.Record.ReplaceAndDelete}" />
                                </Button>
                                <Button
                                    Height="30"
                                    Padding="14,0"
                                    Command="{Binding KeepBothRecordsCommand}"
                                    Style="{StaticResource AppSecondaryButton}">
                                    <TextBlock Foreground="{Binding Foreground, RelativeSource={RelativeSource AncestorType=Button}}" Text="{DynamicResource Portfolio.Record.KeepBoth}" />
                                </Button>
                            </StackPanel>
                            <StackPanel
                                HorizontalAlignment="Right"
                                Orientation="Horizontal"
                                Visibility="{Binding IsRevisionReplacePromptOpen, Converter={StaticResource InverseBooleanToVisibilityConverter}}">
                                <Button
                                    Height="30"
                                    Margin="0,0,8,0"
                                    Padding="14,0"
                                    Command="{Binding CloseTxDialogCommand}"
                                    Style="{StaticResource AppSecondaryButton}">
                                    <TextBlock Foreground="{Binding Foreground, RelativeSource={RelativeSource AncestorType=Button}}" Text="{DynamicResource Portfolio.Cancel}" />
                                </Button>
                                <Button
                                    Height="30"
                                    Padding="14,0"
                                    Command="{Binding ConfirmTxCommand}"
                                    Style="{StaticResource AppPrimaryButton}">
                                    <TextBlock>
                                        <TextBlock.Style>
                                            <Style BasedOn="{StaticResource AppButtonText}" TargetType="TextBlock">
                                                <Setter Property="Text" Value="{DynamicResource Portfolio.Tx.Confirm}" />
                                                <Style.Triggers>
                                                    <DataTrigger Binding="{Binding IsEditMode}" Value="True">
                                                        <Setter Property="Text" Value="{DynamicResource Portfolio.Tx.Save}" />
                                                    </DataTrigger>
                                                </Style.Triggers>
                                            </Style>
                                        </TextBlock.Style>
                                    </TextBlock>
                                </Button>
                            </StackPanel>
                        </StackPanel>
                    </Grid>
                </Border>
            </Grid>
        </Border>

        <Grid
            Panel.ZIndex="200"
            Style="{StaticResource AppDialogOverlay}"
            Visibility="{Binding IsDeleteConfirmOpen, Converter={StaticResource BooleanToVisibilityConverter}}" />

        <Border
            HorizontalAlignment="Center"
            VerticalAlignment="Center"
            Panel.ZIndex="201"
            behaviors:EscapeKeyCommandBehavior.Command="{Binding CancelDeleteTradeCommand}"
            Style="{StaticResource AppDestructiveDialogShell}"
            Visibility="{Binding IsDeleteConfirmOpen, Converter={StaticResource BooleanToVisibilityConverter}}">
            <Grid>
                <Grid.RowDefinitions>
                    <RowDefinition Height="Auto" />
                    <RowDefinition Height="Auto" />
                    <RowDefinition Height="Auto" />
                </Grid.RowDefinitions>

                <TextBlock Style="{StaticResource AppDialogTitle}" Text="{DynamicResource Common.DeleteConfirmTitle}" />
                <TextBlock Grid.Row="1" Style="{StaticResource AppDialogSubtitle}">
                    <Run Text="{DynamicResource Common.DeleteConfirmPrefix}" />
                    <Run Text="{Binding DeleteTargetName}" />
                    <Run Text="{DynamicResource Common.DeleteConfirmSuffix}" />
                </TextBlock>

                <StackPanel Grid.Row="2" Style="{StaticResource AppDialogFooter}">
                    <Button
                        Margin="0,0,8,0"
                        Command="{Binding CancelDeleteTradeCommand}"
                        Content="{DynamicResource Common.Cancel}"
                        Style="{StaticResource AppSecondaryButton}" />
                    <Button
                        Command="{Binding ConfirmDeleteTradeCommand}"
                        Content="{DynamicResource Common.Delete}"
                        Style="{StaticResource AppDangerButton}" />
                </StackPanel>
            </Grid>
        </Border>
    </Grid>
</UserControl>
