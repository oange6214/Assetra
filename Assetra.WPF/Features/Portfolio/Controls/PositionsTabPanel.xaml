<UserControl
    x:Class="Assetra.WPF.Features.Portfolio.Controls.PositionsTabPanel"
    xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
    xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
    xmlns:controls="clr-namespace:Assetra.WPF.Controls"
    xmlns:conv="clr-namespace:Assetra.WPF.Infrastructure.Converters"
    xmlns:d="http://schemas.microsoft.com/expression/blend/2008"
    xmlns:ds="clr-namespace:Assetra.WPF.DesignSystem.Controls"
    xmlns:lvc="clr-namespace:LiveChartsCore.SkiaSharpView.WPF;assembly=LiveChartsCore.SkiaSharpView.WPF"
    xmlns:lvcsk="clr-namespace:LiveChartsCore.SkiaSharpView;assembly=LiveChartsCore.SkiaSharpView"
    xmlns:mc="http://schemas.openxmlformats.org/markup-compatibility/2006"
    xmlns:models="clr-namespace:Assetra.Core.Models;assembly=Assetra.Core"
    xmlns:vm="clr-namespace:Assetra.WPF.Features.Portfolio"
    x:Name="Root"
    d:DataContext="{d:DesignInstance Type={x:Type vm:PortfolioViewModel}}"
    mc:Ignorable="d">
    <UserControl.Resources>
        <conv:PercentToWidthConverter x:Key="PercentToWidthConverter" />

        <DataTemplate x:Key="PositionGroupHeaderTemplate">
            <Border
                Margin="0,8,0,6"
                Padding="12,8"
                Background="{DynamicResource AppSurface}"
                BorderBrush="{DynamicResource AppBorderLight}"
                BorderThickness="1"
                CornerRadius="8">
                <Grid>
                    <Grid.ColumnDefinitions>
                        <ColumnDefinition Width="*" />
                        <ColumnDefinition Width="Auto" />
                    </Grid.ColumnDefinitions>

                    <TextBlock
                        VerticalAlignment="Center"
                        FontSize="{StaticResource Font.Size.Sm}"
                        FontWeight="SemiBold"
                        Foreground="{DynamicResource AppText}"
                        Text="{Binding Name}" />

                    <StackPanel
                        Grid.Column="1"
                        VerticalAlignment="Center"
                        Orientation="Horizontal">
                        <StackPanel Margin="16,0,0,0" Orientation="Horizontal">
                            <TextBlock
                                FontSize="{StaticResource Font.Size.Xs}"
                                Foreground="{DynamicResource AppTextMuted}"
                                Text="{DynamicResource Portfolio.Filter.Summary.Count}" />
                            <TextBlock
                                Margin="4,0,0,0"
                                FontSize="{StaticResource Font.Size.Xs}"
                                FontWeight="SemiBold"
                                Foreground="{DynamicResource AppTextSecondary}"
                                Text="{Binding Items[0].PositionViewGroupItemCount, StringFormat={}{0:N0}}" />
                        </StackPanel>

                        <StackPanel Margin="16,0,0,0" Orientation="Horizontal">
                            <TextBlock
                                FontSize="{StaticResource Font.Size.Xs}"
                                Foreground="{DynamicResource AppTextMuted}"
                                Text="{DynamicResource Portfolio.Filter.Summary.MarketValue}" />
                            <TextBlock
                                Margin="4,0,0,0"
                                FontSize="{StaticResource Font.Size.Xs}"
                                FontWeight="SemiBold"
                                Foreground="{DynamicResource AppTextSecondary}"
                                Text="{Binding Items[0].PositionViewGroupMarketValue, Converter={StaticResource CurrencyConverter}, ConverterParameter=amount}" />
                        </StackPanel>

                        <StackPanel Margin="16,0,0,0" Orientation="Horizontal">
                            <TextBlock
                                FontSize="{StaticResource Font.Size.Xs}"
                                Foreground="{DynamicResource AppTextMuted}"
                                Text="{DynamicResource Portfolio.Filter.Summary.Cost}" />
                            <TextBlock
                                Margin="4,0,0,0"
                                FontSize="{StaticResource Font.Size.Xs}"
                                FontWeight="SemiBold"
                                Foreground="{DynamicResource AppTextSecondary}"
                                Text="{Binding Items[0].PositionViewGroupCost, Converter={StaticResource CurrencyConverter}, ConverterParameter=amount}" />
                        </StackPanel>

                        <StackPanel Margin="16,0,0,0" Orientation="Horizontal">
                            <TextBlock
                                FontSize="{StaticResource Font.Size.Xs}"
                                Foreground="{DynamicResource AppTextMuted}"
                                Text="{DynamicResource Portfolio.Filter.Summary.Pnl}" />
                            <TextBlock
                                Margin="4,0,0,0"
                                FontSize="{StaticResource Font.Size.Xs}"
                                FontWeight="SemiBold"
                                Text="{Binding Items[0].PositionViewGroupPnl, Converter={StaticResource CurrencyConverter}, ConverterParameter=signed}">
                                <TextBlock.Style>
                                    <Style TargetType="TextBlock">
                                        <Setter Property="Foreground" Value="{DynamicResource AppDown}" />
                                        <Style.Triggers>
                                            <DataTrigger Binding="{Binding Items[0].IsPositionViewGroupPnlPositive}" Value="True">
                                                <Setter Property="Foreground" Value="{DynamicResource AppUp}" />
                                            </DataTrigger>
                                            <DataTrigger Binding="{Binding Items[0].PositionViewGroupPnl}" Value="0">
                                                <Setter Property="Foreground" Value="{DynamicResource AppTextSecondary}" />
                                            </DataTrigger>
                                        </Style.Triggers>
                                    </Style>
                                </TextBlock.Style>
                            </TextBlock>
                        </StackPanel>
                    </StackPanel>
                </Grid>
            </Border>
        </DataTemplate>


        <!--
            KPI 展開面板的關閉鈕 — 24×24 圓形、無框、hover 變淡背景。
            和 AppIconButton 的 32px 方框感分開，視覺更輕巧、配合面板頭部
            的小字標題等比例。
        -->
        <Style x:Key="PanelCloseButton" TargetType="Button">
            <Setter Property="Width" Value="24" />
            <Setter Property="Height" Value="24" />
            <Setter Property="MinHeight" Value="0" />
            <Setter Property="Padding" Value="0" />
            <Setter Property="Background" Value="Transparent" />
            <Setter Property="BorderThickness" Value="0" />
            <Setter Property="Cursor" Value="Hand" />
            <Setter Property="Template">
                <Setter.Value>
                    <ControlTemplate TargetType="Button">
                        <Border
                            x:Name="Bd"
                            Background="{TemplateBinding Background}"
                            CornerRadius="12">
                            <ContentPresenter HorizontalAlignment="Center" VerticalAlignment="Center" />
                        </Border>
                        <ControlTemplate.Triggers>
                            <Trigger Property="IsMouseOver" Value="True">
                                <Setter TargetName="Bd" Property="Background" Value="{DynamicResource AppHover}" />
                            </Trigger>
                        </ControlTemplate.Triggers>
                    </ControlTemplate>
                </Setter.Value>
            </Setter>
        </Style>

        <!--
            Base chip 樣式 — 灰底圓角，hover 變色。每個 chip 在 inline 加上自己的
            DataTrigger 比對 AssetTypeFilter，命中時把 Background 切到 AppAccent。
            參考 frontend「pill / segmented control」典型樣式。
        -->
        <Style x:Key="AssetTypeFilterChipBase" TargetType="Button">
            <Setter Property="Padding" Value="14,5" />
            <Setter Property="MinHeight" Value="28" />
            <Setter Property="Margin" Value="0,0,8,0" />
            <Setter Property="Background" Value="{DynamicResource AppSurface}" />
            <Setter Property="Foreground" Value="{DynamicResource AppTextSecondary}" />
            <Setter Property="BorderBrush" Value="{DynamicResource AppBorder}" />
            <Setter Property="BorderThickness" Value="1" />
            <Setter Property="Cursor" Value="Hand" />
            <Setter Property="FontSize" Value="{StaticResource Font.Size.Xs}" />
            <Setter Property="Template">
                <Setter.Value>
                    <ControlTemplate TargetType="Button">
                        <Border
                            Padding="{TemplateBinding Padding}"
                            Background="{TemplateBinding Background}"
                            BorderBrush="{TemplateBinding BorderBrush}"
                            BorderThickness="{TemplateBinding BorderThickness}"
                            CornerRadius="13"
                            SnapsToDevicePixels="True">
                            <!--
                                直接用 TextBlock + TemplateBinding Foreground 取代 ContentPresenter +
                                TextElement.Foreground — 後者在某些全域 Button style 下 Foreground
                                不會傳到 auto-wrapped TextBlock，導致選中時白字仍渲染為深色文字 + 深藍底
                                的不可讀組合。
                            -->
                            <TextBlock
                                HorizontalAlignment="Center"
                                VerticalAlignment="Center"
                                Foreground="{TemplateBinding Foreground}"
                                Text="{TemplateBinding Content}" />
                        </Border>
                    </ControlTemplate>
                </Setter.Value>
            </Setter>
            <Style.Triggers>
                <Trigger Property="IsMouseOver" Value="True">
                    <Setter Property="Background" Value="{DynamicResource AppHover}" />
                </Trigger>
            </Style.Triggers>
        </Style>
    </UserControl.Resources>

    <Grid>
        <Grid.RowDefinitions>
            <RowDefinition Height="Auto" />
            <!--  Investment summary cards  -->
            <RowDefinition Height="Auto" />
            <!--  KPI expand panel (持股佔比 donut / 每日損益 柱狀圖)  -->
            <RowDefinition Height="Auto" />
            <!--  Quote provider notice  -->
            <RowDefinition Height="Auto" />
            <!--  Asset-type filter chips  -->
            <RowDefinition Height="Auto" />
            <!--  Text search  -->
            <RowDefinition Height="*" />
            <!--  DataGrid (all asset types in one list; sort by Type column to group)  -->
            <RowDefinition Height="Auto" />
            <!--  Filter summary footer — only visible when 篩選作用中  -->
        </Grid.RowDefinitions>

        <!--
            ═══ Row 0: Investment Summary ═══
            v3 redesign：跟 LiabilityTabPanel / AccountsTabPanel 對齊—
            外層 background 改 AppBackground (灰，跟下方 datagrid 同色)，
            內 cards 用 AppCardBackground (白)，padding 統一 Padding.Card token。
        -->
        <Border
            Grid.Row="0"
            Padding="{StaticResource Padding.SectionStrip}"
            Background="{DynamicResource AppBackground}"
            BorderBrush="{DynamicResource AppBorder}"
            BorderThickness="0,0,0,1">
            <!--
                UniformGrid distributes width equally across 4 columns and
                stretches each cell to fill the parent. The previous
                WrapPanel ItemWidth="250" pinned each card to 250 px and
                left 380+ px of dead space on a 1600-wide window — visually
                reading as "content centered with margins on both sides."
            -->
            <UniformGrid Columns="4" Rows="1">

                <!--  Card 1: 總市值（右上 donut icon → 展開持股佔比圓環）  -->
                <Border
                    MinHeight="72"
                    Margin="{StaticResource CardMarginLeft}"
                    Padding="{StaticResource Padding.Card}"
                    Background="{DynamicResource AppCardBackground}"
                    BorderBrush="{DynamicResource AppBorder}"
                    BorderThickness="1"
                    CornerRadius="{StaticResource Radius.Sm}">
                    <Grid>
                        <StackPanel>
                            <TextBlock
                                FontSize="{StaticResource Font.Size.Xs}"
                                Foreground="{DynamicResource AppTextSecondary}"
                                Text="{DynamicResource Portfolio.Position.Summary.MarketValue}" />
                            <TextBlock
                                Margin="0,4,0,0"
                                FontFamily="{StaticResource Font.Family.Base}"
                                FontSize="{StaticResource Font.Size.Lg}"
                                FontWeight="SemiBold"
                                Foreground="{DynamicResource AppTextPrimary}"
                                Text="{Binding TotalMarketValue, Converter={StaticResource CurrencyConverter}, ConverterParameter=amount}"
                                Typography.NumeralAlignment="Tabular" />
                        </StackPanel>
                        <!--  右上展開鈕 — 點擊切換到「持股佔比」donut 面板  -->
                        <Button
                            Width="22"
                            Height="22"
                            Padding="0"
                            HorizontalAlignment="Right"
                            VerticalAlignment="Top"
                            Command="{Binding ToggleKpiPanelCommand}"
                            CommandParameter="marketvalue"
                            Style="{StaticResource AppIconButton}"
                            ToolTip="{DynamicResource Portfolio.Kpi.ShowAllocation}">
                            <ds:AppIcon FontSize="13" Symbol="DataPie24">
                                <ds:AppIcon.Style>
                                    <Style BasedOn="{StaticResource AppIcon}" TargetType="{x:Type ds:AppIcon}">
                                        <Setter Property="Foreground" Value="{DynamicResource AppTextMuted}" />
                                        <Style.Triggers>
                                            <DataTrigger Binding="{Binding IsKpiMarketValueExpanded}" Value="True">
                                                <Setter Property="Foreground" Value="{DynamicResource AppAccent}" />
                                            </DataTrigger>
                                        </Style.Triggers>
                                    </Style>
                                </ds:AppIcon.Style>
                            </ds:AppIcon>
                        </Button>
                    </Grid>
                </Border>

                <!--  Card 2: 總付出成本（右上 donut icon → 展開成本分布）  -->
                <Border
                    MinHeight="72"
                    Margin="{StaticResource CardMarginCenter}"
                    Padding="{StaticResource Padding.Card}"
                    Background="{DynamicResource AppCardBackground}"
                    BorderBrush="{DynamicResource AppBorder}"
                    BorderThickness="1"
                    CornerRadius="{StaticResource Radius.Sm}">
                    <Grid>
                        <StackPanel>
                            <TextBlock
                                FontSize="{StaticResource Font.Size.Xs}"
                                Foreground="{DynamicResource AppTextSecondary}"
                                Text="{DynamicResource Portfolio.Position.Summary.TotalCost}" />
                            <TextBlock
                                Margin="0,4,0,0"
                                FontFamily="{StaticResource Font.Family.Base}"
                                FontSize="{StaticResource Font.Size.Lg}"
                                FontWeight="SemiBold"
                                Foreground="{DynamicResource AppTextPrimary}"
                                Text="{Binding TotalCost, Converter={StaticResource CurrencyConverter}, ConverterParameter=amount}"
                                Typography.NumeralAlignment="Tabular" />
                        </StackPanel>
                        <Button
                            Width="22"
                            Height="22"
                            Padding="0"
                            HorizontalAlignment="Right"
                            VerticalAlignment="Top"
                            Command="{Binding ToggleKpiPanelCommand}"
                            CommandParameter="cost"
                            Style="{StaticResource AppIconButton}"
                            ToolTip="{DynamicResource Portfolio.Kpi.ShowCost}">
                            <ds:AppIcon FontSize="13" Symbol="DataPie24">
                                <ds:AppIcon.Style>
                                    <Style BasedOn="{StaticResource AppIcon}" TargetType="{x:Type ds:AppIcon}">
                                        <Setter Property="Foreground" Value="{DynamicResource AppTextMuted}" />
                                        <Style.Triggers>
                                            <DataTrigger Binding="{Binding IsKpiCostExpanded}" Value="True">
                                                <Setter Property="Foreground" Value="{DynamicResource AppAccent}" />
                                            </DataTrigger>
                                        </Style.Triggers>
                                    </Style>
                                </ds:AppIcon.Style>
                            </ds:AppIcon>
                        </Button>
                    </Grid>
                </Border>

                <!--  Card 3: 損益試算（右上 pie icon → 展開盈虧檔數）  -->
                <Border
                    MinHeight="72"
                    Margin="{StaticResource CardMarginCenter}"
                    Padding="{StaticResource Padding.Card}"
                    Background="{DynamicResource AppCardBackground}"
                    BorderBrush="{DynamicResource AppBorder}"
                    BorderThickness="1"
                    CornerRadius="{StaticResource Radius.Sm}">
                    <Grid>
                        <StackPanel>
                            <TextBlock
                                FontSize="{StaticResource Font.Size.Xs}"
                                Foreground="{DynamicResource AppTextSecondary}"
                                Text="{DynamicResource Portfolio.Position.Summary.Pnl}" />
                            <StackPanel Margin="0,4,0,0" Orientation="Horizontal">
                                <TextBlock
                                    FontFamily="{StaticResource Font.Family.Base}"
                                    FontSize="{StaticResource Font.Size.Lg}"
                                    FontWeight="SemiBold"
                                    Text="{Binding TotalPnl, Converter={StaticResource CurrencyConverter}, ConverterParameter=signed}"
                                    Typography.NumeralAlignment="Tabular">
                                    <TextBlock.Style>
                                        <Style TargetType="TextBlock">
                                            <Setter Property="Foreground" Value="{DynamicResource AppDown}" />
                                            <Style.Triggers>
                                                <DataTrigger Binding="{Binding IsTotalPositive}" Value="True">
                                                    <Setter Property="Foreground" Value="{DynamicResource AppUp}" />
                                                </DataTrigger>
                                            </Style.Triggers>
                                        </Style>
                                    </TextBlock.Style>
                                </TextBlock>
                                <TextBlock
                                    Margin="6,0,0,0"
                                    VerticalAlignment="Bottom"
                                    FontFamily="{StaticResource Font.Family.Base}"
                                    FontSize="{StaticResource Font.Size.Xs}"
                                    Text="{Binding TotalPnlPercent, StringFormat={}{0:+0.00;-0.00}%}"
                                    Typography.NumeralAlignment="Tabular">
                                    <TextBlock.Style>
                                        <Style TargetType="TextBlock">
                                            <Setter Property="Foreground" Value="{DynamicResource AppDown}" />
                                            <Style.Triggers>
                                                <DataTrigger Binding="{Binding IsTotalPositive}" Value="True">
                                                    <Setter Property="Foreground" Value="{DynamicResource AppUp}" />
                                                </DataTrigger>
                                            </Style.Triggers>
                                        </Style>
                                    </TextBlock.Style>
                                </TextBlock>
                            </StackPanel>
                        </StackPanel>
                        <Button
                            Width="22"
                            Height="22"
                            Padding="0"
                            HorizontalAlignment="Right"
                            VerticalAlignment="Top"
                            Command="{Binding ToggleKpiPanelCommand}"
                            CommandParameter="pnl"
                            Style="{StaticResource AppIconButton}"
                            ToolTip="{DynamicResource Portfolio.Kpi.ShowPnlBreakdown}">
                            <ds:AppIcon FontSize="13" Symbol="DataPie24">
                                <ds:AppIcon.Style>
                                    <Style BasedOn="{StaticResource AppIcon}" TargetType="{x:Type ds:AppIcon}">
                                        <Setter Property="Foreground" Value="{DynamicResource AppTextMuted}" />
                                        <Style.Triggers>
                                            <DataTrigger Binding="{Binding IsKpiPnlExpanded}" Value="True">
                                                <Setter Property="Foreground" Value="{DynamicResource AppAccent}" />
                                            </DataTrigger>
                                        </Style.Triggers>
                                    </Style>
                                </ds:AppIcon.Style>
                            </ds:AppIcon>
                        </Button>
                    </Grid>
                </Border>

                <!--  Card 4: 今日漲跌（右上 bar icon → 展開過去 30 天每日 PnL 柱）  -->
                <Border
                    MinHeight="72"
                    Margin="{StaticResource CardMarginRight}"
                    Padding="{StaticResource Padding.Card}"
                    Background="{DynamicResource AppCardBackground}"
                    BorderBrush="{DynamicResource AppBorder}"
                    BorderThickness="1"
                    CornerRadius="{StaticResource Radius.Sm}">
                    <Grid>
                        <StackPanel>
                            <TextBlock
                                FontSize="{StaticResource Font.Size.Xs}"
                                Foreground="{DynamicResource AppTextSecondary}"
                                Text="{DynamicResource Portfolio.Position.Summary.DayChange}" />
                            <!--  Shown only when quotes have loaded (HasDayPnl = true)  -->
                            <StackPanel
                                Margin="0,4,0,0"
                                Orientation="Horizontal"
                                Visibility="{Binding HasDayPnl, Converter={StaticResource BooleanToVisibilityConverter}}">
                                <TextBlock
                                    FontFamily="{StaticResource Font.Family.Base}"
                                    FontSize="{StaticResource Font.Size.Lg}"
                                    FontWeight="SemiBold"
                                    Text="{Binding DayPnl, Converter={StaticResource CurrencyConverter}, ConverterParameter=signed}"
                                    Typography.NumeralAlignment="Tabular">
                                    <TextBlock.Style>
                                        <Style TargetType="TextBlock">
                                            <Setter Property="Foreground" Value="{DynamicResource AppDown}" />
                                            <Style.Triggers>
                                                <DataTrigger Binding="{Binding IsDayPnlPositive}" Value="True">
                                                    <Setter Property="Foreground" Value="{DynamicResource AppUp}" />
                                                </DataTrigger>
                                            </Style.Triggers>
                                        </Style>
                                    </TextBlock.Style>
                                </TextBlock>
                                <TextBlock
                                    Margin="6,0,0,0"
                                    VerticalAlignment="Bottom"
                                    FontFamily="{StaticResource Font.Family.Base}"
                                    FontSize="{StaticResource Font.Size.Xs}"
                                    Text="{Binding DayPnlPercentDisplay}"
                                    Typography.NumeralAlignment="Tabular">
                                    <TextBlock.Style>
                                        <Style TargetType="TextBlock">
                                            <Setter Property="Foreground" Value="{DynamicResource AppDown}" />
                                            <Style.Triggers>
                                                <DataTrigger Binding="{Binding IsDayPnlPositive}" Value="True">
                                                    <Setter Property="Foreground" Value="{DynamicResource AppUp}" />
                                                </DataTrigger>
                                            </Style.Triggers>
                                        </Style>
                                    </TextBlock.Style>
                                </TextBlock>
                            </StackPanel>
                            <!--  Placeholder while quotes are loading  -->
                            <TextBlock
                                Margin="0,6,0,0"
                                FontSize="{StaticResource Font.Size.Xs}"
                                Foreground="{DynamicResource AppTextMuted}"
                                Text="{DynamicResource Portfolio.Position.Summary.Loading}"
                                Visibility="{Binding HasDayPnl, Converter={StaticResource InverseBooleanToVisibilityConverter}}" />
                        </StackPanel>
                        <!--  右上展開鈕 — 點擊切換到「每日損益」柱狀圖面板  -->
                        <Button
                            Width="22"
                            Height="22"
                            Padding="0"
                            HorizontalAlignment="Right"
                            VerticalAlignment="Top"
                            Command="{Binding ToggleKpiPanelCommand}"
                            CommandParameter="daychange"
                            Style="{StaticResource AppIconButton}"
                            ToolTip="{DynamicResource Portfolio.Kpi.ShowDailyPnl}">
                            <ds:AppIcon FontSize="13" Symbol="DataBarVertical24">
                                <ds:AppIcon.Style>
                                    <Style BasedOn="{StaticResource AppIcon}" TargetType="{x:Type ds:AppIcon}">
                                        <Setter Property="Foreground" Value="{DynamicResource AppTextMuted}" />
                                        <Style.Triggers>
                                            <DataTrigger Binding="{Binding IsKpiDayChangeExpanded}" Value="True">
                                                <Setter Property="Foreground" Value="{DynamicResource AppAccent}" />
                                            </DataTrigger>
                                        </Style.Triggers>
                                    </Style>
                                </ds:AppIcon.Style>
                            </ds:AppIcon>
                        </Button>
                    </Grid>
                </Border>

            </UniformGrid>
        </Border>

        <!--
            ═══ Row 1: KPI expand panel ═══
            點 KPI 卡右上小圖示後展開的圖表面板。三種狀態：
            - IsKpiMarketValueExpanded → 持股佔比 donut（沿用 AllocationMiniChart）
            - IsKpiDayChangeExpanded   → 過去 30 天每日 PnL 柱狀圖
            - 都未展開 → Visibility=Collapsed，row 高度為 0
            一次只能展開一個，由 ExpandedKpiPanel 單一 state 控制。
        -->
        <Border
            Grid.Row="1"
            Margin="12,10,12,0"
            Padding="14,12"
            Background="{DynamicResource AppSurface}"
            BorderBrush="{DynamicResource AppBorder}"
            BorderThickness="1"
            CornerRadius="{StaticResource Radius.Sm}"
            Visibility="{Binding IsAnyKpiPanelExpanded, Converter={StaticResource BooleanToVisibilityConverter}}">
            <Grid>
                <!--  持股佔比 donut + legend  -->
                <Grid Visibility="{Binding IsKpiMarketValueExpanded, Converter={StaticResource BooleanToVisibilityConverter}}">
                    <Grid.RowDefinitions>
                        <RowDefinition Height="Auto" />
                        <RowDefinition Height="*" />
                    </Grid.RowDefinitions>
                    <DockPanel
                        Grid.Row="0"
                        Margin="0,0,0,8"
                        LastChildFill="False">
                        <TextBlock
                            FontSize="{StaticResource Font.Size.Sm}"
                            FontWeight="SemiBold"
                            Foreground="{DynamicResource AppTextPrimary}"
                            Text="{DynamicResource Portfolio.Kpi.AllocationTitle}" />
                        <Button
                            Command="{Binding ToggleKpiPanelCommand}"
                            CommandParameter="marketvalue"
                            DockPanel.Dock="Right"
                            Style="{StaticResource PanelCloseButton}"
                            ToolTip="{DynamicResource Common.Close}">
                            <ds:AppIcon
                                FontSize="11"
                                Foreground="{DynamicResource AppTextMuted}"
                                Symbol="Dismiss24" />
                        </Button>
                    </DockPanel>
                    <Grid Grid.Row="1" Height="160">
                        <Grid.ColumnDefinitions>
                            <ColumnDefinition Width="Auto" />
                            <ColumnDefinition Width="*" />
                        </Grid.ColumnDefinitions>
                        <lvc:PieChart
                            Grid.Column="0"
                            Width="{Binding ActualHeight, RelativeSource={RelativeSource Self}}"
                            Background="Transparent"
                            InitialRotation="-90"
                            LegendPosition="Hidden"
                            Series="{Binding PositionAllocationSeries}"
                            TooltipPosition="Center"
                            TooltipTextSize="11" />
                        <ItemsControl
                            Grid.Column="1"
                            Margin="16,4,0,0"
                            VerticalAlignment="Center"
                            ItemsSource="{Binding PositionAllocationSlices}">
                            <ItemsControl.ItemTemplate>
                                <DataTemplate>
                                    <Grid Margin="0,2">
                                        <Grid.ColumnDefinitions>
                                            <ColumnDefinition Width="10" />
                                            <ColumnDefinition Width="*" />
                                            <ColumnDefinition Width="Auto" />
                                            <ColumnDefinition Width="Auto" />
                                        </Grid.ColumnDefinitions>
                                        <Ellipse
                                            Grid.Column="0"
                                            Width="10"
                                            Height="10"
                                            VerticalAlignment="Center">
                                            <Ellipse.Fill>
                                                <SolidColorBrush Color="{Binding ColorHex}" />
                                            </Ellipse.Fill>
                                        </Ellipse>
                                        <TextBlock
                                            Grid.Column="1"
                                            Margin="8,0,12,0"
                                            VerticalAlignment="Center"
                                            FontSize="{StaticResource Font.Size.Sm}"
                                            Foreground="{DynamicResource AppTextSecondary}"
                                            Text="{Binding Label}" />
                                        <TextBlock
                                            Grid.Column="2"
                                            Margin="0,0,8,0"
                                            VerticalAlignment="Center"
                                            FontFamily="{StaticResource Font.Family.Base}"
                                            FontSize="{StaticResource Font.Size.Sm}"
                                            FontWeight="SemiBold"
                                            Foreground="{DynamicResource AppTextPrimary}"
                                            Text="{Binding Percent, StringFormat={}{0:F1}%}"
                                            Typography.NumeralAlignment="Tabular" />
                                        <TextBlock
                                            Grid.Column="3"
                                            VerticalAlignment="Center"
                                            FontFamily="{StaticResource Font.Family.Base}"
                                            FontSize="{StaticResource Font.Size.Xs}"
                                            Foreground="{DynamicResource AppTextMuted}"
                                            Text="{Binding Value, StringFormat='NT\${0:N0}'}"
                                            Typography.NumeralAlignment="Tabular" />
                                    </Grid>
                                </DataTemplate>
                            </ItemsControl.ItemTemplate>
                        </ItemsControl>
                    </Grid>
                </Grid>

                <!--  付出成本分布 donut（per-position by Cost）  -->
                <Grid Visibility="{Binding IsKpiCostExpanded, Converter={StaticResource BooleanToVisibilityConverter}}">
                    <Grid.RowDefinitions>
                        <RowDefinition Height="Auto" />
                        <RowDefinition Height="*" />
                    </Grid.RowDefinitions>
                    <DockPanel
                        Grid.Row="0"
                        Margin="0,0,0,8"
                        LastChildFill="False">
                        <TextBlock
                            FontSize="{StaticResource Font.Size.Sm}"
                            FontWeight="SemiBold"
                            Foreground="{DynamicResource AppTextPrimary}"
                            Text="{DynamicResource Portfolio.Kpi.CostTitle}" />
                        <Button
                            Command="{Binding ToggleKpiPanelCommand}"
                            CommandParameter="cost"
                            DockPanel.Dock="Right"
                            Style="{StaticResource PanelCloseButton}"
                            ToolTip="{DynamicResource Common.Close}">
                            <ds:AppIcon
                                FontSize="11"
                                Foreground="{DynamicResource AppTextMuted}"
                                Symbol="Dismiss24" />
                        </Button>
                    </DockPanel>
                    <Grid Grid.Row="1" Height="160">
                        <Grid.ColumnDefinitions>
                            <ColumnDefinition Width="Auto" />
                            <ColumnDefinition Width="*" />
                        </Grid.ColumnDefinitions>
                        <lvc:PieChart
                            Grid.Column="0"
                            Width="{Binding ActualHeight, RelativeSource={RelativeSource Self}}"
                            Background="Transparent"
                            InitialRotation="-90"
                            LegendPosition="Hidden"
                            Series="{Binding PositionCostSeries}"
                            TooltipPosition="Center"
                            TooltipTextSize="11" />
                        <ItemsControl
                            Grid.Column="1"
                            Margin="16,4,0,0"
                            VerticalAlignment="Center"
                            ItemsSource="{Binding PositionCostSlices}">
                            <ItemsControl.ItemTemplate>
                                <DataTemplate>
                                    <Grid Margin="0,2">
                                        <Grid.ColumnDefinitions>
                                            <ColumnDefinition Width="10" />
                                            <ColumnDefinition Width="*" />
                                            <ColumnDefinition Width="Auto" />
                                            <ColumnDefinition Width="Auto" />
                                        </Grid.ColumnDefinitions>
                                        <Ellipse
                                            Grid.Column="0"
                                            Width="10"
                                            Height="10"
                                            VerticalAlignment="Center">
                                            <Ellipse.Fill>
                                                <SolidColorBrush Color="{Binding ColorHex}" />
                                            </Ellipse.Fill>
                                        </Ellipse>
                                        <TextBlock
                                            Grid.Column="1"
                                            Margin="8,0,12,0"
                                            VerticalAlignment="Center"
                                            FontSize="{StaticResource Font.Size.Sm}"
                                            Foreground="{DynamicResource AppTextSecondary}"
                                            Text="{Binding Label}"
                                            TextTrimming="CharacterEllipsis" />
                                        <TextBlock
                                            Grid.Column="2"
                                            Margin="0,0,8,0"
                                            VerticalAlignment="Center"
                                            FontFamily="{StaticResource Font.Family.Base}"
                                            FontSize="{StaticResource Font.Size.Sm}"
                                            FontWeight="SemiBold"
                                            Foreground="{DynamicResource AppTextPrimary}"
                                            Text="{Binding Percent, StringFormat={}{0:F1}%}"
                                            Typography.NumeralAlignment="Tabular" />
                                        <TextBlock
                                            Grid.Column="3"
                                            VerticalAlignment="Center"
                                            FontFamily="{StaticResource Font.Family.Base}"
                                            FontSize="{StaticResource Font.Size.Xs}"
                                            Foreground="{DynamicResource AppTextMuted}"
                                            Text="{Binding Value, StringFormat='NT\${0:N0}'}"
                                            Typography.NumeralAlignment="Tabular" />
                                    </Grid>
                                </DataTemplate>
                            </ItemsControl.ItemTemplate>
                        </ItemsControl>
                    </Grid>
                </Grid>

                <!--  盈虧檔數 pie（賺 / 賠 / 平 三色）  -->
                <Grid Visibility="{Binding IsKpiPnlExpanded, Converter={StaticResource BooleanToVisibilityConverter}}">
                    <Grid.RowDefinitions>
                        <RowDefinition Height="Auto" />
                        <RowDefinition Height="*" />
                    </Grid.RowDefinitions>
                    <DockPanel
                        Grid.Row="0"
                        Margin="0,0,0,8"
                        LastChildFill="False">
                        <TextBlock
                            FontSize="{StaticResource Font.Size.Sm}"
                            FontWeight="SemiBold"
                            Foreground="{DynamicResource AppTextPrimary}"
                            Text="{DynamicResource Portfolio.Kpi.PnlBreakdownTitle}" />
                        <Button
                            Command="{Binding ToggleKpiPanelCommand}"
                            CommandParameter="pnl"
                            DockPanel.Dock="Right"
                            Style="{StaticResource PanelCloseButton}"
                            ToolTip="{DynamicResource Common.Close}">
                            <ds:AppIcon
                                FontSize="11"
                                Foreground="{DynamicResource AppTextMuted}"
                                Symbol="Dismiss24" />
                        </Button>
                    </DockPanel>
                    <Grid Grid.Row="1" Height="160">
                        <Grid.ColumnDefinitions>
                            <ColumnDefinition Width="Auto" />
                            <ColumnDefinition Width="*" />
                        </Grid.ColumnDefinitions>
                        <lvc:PieChart
                            Grid.Column="0"
                            Width="{Binding ActualHeight, RelativeSource={RelativeSource Self}}"
                            Background="Transparent"
                            InitialRotation="-90"
                            LegendPosition="Hidden"
                            Series="{Binding PnlBreakdownSeries}"
                            TooltipPosition="Center"
                            TooltipTextSize="11" />
                        <ItemsControl
                            Grid.Column="1"
                            Margin="16,4,0,0"
                            VerticalAlignment="Center"
                            ItemsSource="{Binding PnlBreakdownSlices}">
                            <ItemsControl.ItemTemplate>
                                <DataTemplate>
                                    <Grid Margin="0,2">
                                        <Grid.ColumnDefinitions>
                                            <ColumnDefinition Width="10" />
                                            <ColumnDefinition Width="*" />
                                            <ColumnDefinition Width="Auto" />
                                            <ColumnDefinition Width="Auto" />
                                        </Grid.ColumnDefinitions>
                                        <Ellipse
                                            Grid.Column="0"
                                            Width="10"
                                            Height="10"
                                            VerticalAlignment="Center">
                                            <Ellipse.Fill>
                                                <SolidColorBrush Color="{Binding ColorHex}" />
                                            </Ellipse.Fill>
                                        </Ellipse>
                                        <TextBlock
                                            Grid.Column="1"
                                            Margin="8,0,12,0"
                                            VerticalAlignment="Center"
                                            FontSize="{StaticResource Font.Size.Sm}"
                                            Foreground="{DynamicResource AppTextSecondary}"
                                            Text="{Binding Label}" />
                                        <TextBlock
                                            Grid.Column="2"
                                            Margin="0,0,8,0"
                                            VerticalAlignment="Center"
                                            FontFamily="{StaticResource Font.Family.Base}"
                                            FontSize="{StaticResource Font.Size.Sm}"
                                            FontWeight="SemiBold"
                                            Foreground="{DynamicResource AppTextPrimary}"
                                            Text="{Binding Percent, StringFormat={}{0:F1}%}"
                                            Typography.NumeralAlignment="Tabular" />
                                        <TextBlock
                                            Grid.Column="3"
                                            VerticalAlignment="Center"
                                            FontFamily="{StaticResource Font.Family.Base}"
                                            FontSize="{StaticResource Font.Size.Xs}"
                                            Foreground="{DynamicResource AppTextMuted}"
                                            Text="{Binding Value, StringFormat='NT\${0:N0}'}"
                                            Typography.NumeralAlignment="Tabular" />
                                    </Grid>
                                </DataTemplate>
                            </ItemsControl.ItemTemplate>
                        </ItemsControl>
                    </Grid>
                </Grid>

                <!--  每日 PnL 柱狀圖（7/30/90 天可切換）  -->
                <Grid Visibility="{Binding IsKpiDayChangeExpanded, Converter={StaticResource BooleanToVisibilityConverter}}">
                    <Grid.RowDefinitions>
                        <RowDefinition Height="Auto" />
                        <RowDefinition Height="Auto" />
                        <RowDefinition Height="*" />
                    </Grid.RowDefinitions>
                    <DockPanel
                        Grid.Row="0"
                        Margin="0,0,0,8"
                        LastChildFill="False">
                        <TextBlock
                            FontSize="{StaticResource Font.Size.Sm}"
                            FontWeight="SemiBold"
                            Foreground="{DynamicResource AppTextPrimary}"
                            Text="{DynamicResource Portfolio.Kpi.DailyPnlTitle}" />
                        <Button
                            Command="{Binding ToggleKpiPanelCommand}"
                            CommandParameter="daychange"
                            DockPanel.Dock="Right"
                            Style="{StaticResource PanelCloseButton}"
                            ToolTip="{DynamicResource Common.Close}">
                            <ds:AppIcon
                                FontSize="11"
                                Foreground="{DynamicResource AppTextMuted}"
                                Symbol="Dismiss24" />
                        </Button>
                    </DockPanel>
                    <!--  週期切換 chip row：7 / 30 / 90 天  -->
                    <StackPanel
                        Grid.Row="1"
                        Margin="0,0,0,6"
                        Orientation="Horizontal">
                        <Button
                            Command="{Binding SetDailyPnlPeriodCommand}"
                            CommandParameter="7"
                            Content="7 天">
                            <Button.Style>
                                <Style BasedOn="{StaticResource AssetTypeFilterChipBase}" TargetType="Button">
                                    <Style.Triggers>
                                        <DataTrigger Binding="{Binding IsPeriod7}" Value="True">
                                            <Setter Property="Background" Value="{DynamicResource AppAccent}" />
                                            <Setter Property="Foreground" Value="White" />
                                            <Setter Property="BorderBrush" Value="{DynamicResource AppAccent}" />
                                        </DataTrigger>
                                    </Style.Triggers>
                                </Style>
                            </Button.Style>
                        </Button>
                        <Button
                            Command="{Binding SetDailyPnlPeriodCommand}"
                            CommandParameter="30"
                            Content="30 天">
                            <Button.Style>
                                <Style BasedOn="{StaticResource AssetTypeFilterChipBase}" TargetType="Button">
                                    <Style.Triggers>
                                        <DataTrigger Binding="{Binding IsPeriod30}" Value="True">
                                            <Setter Property="Background" Value="{DynamicResource AppAccent}" />
                                            <Setter Property="Foreground" Value="White" />
                                            <Setter Property="BorderBrush" Value="{DynamicResource AppAccent}" />
                                        </DataTrigger>
                                    </Style.Triggers>
                                </Style>
                            </Button.Style>
                        </Button>
                        <Button
                            Command="{Binding SetDailyPnlPeriodCommand}"
                            CommandParameter="90"
                            Content="90 天">
                            <Button.Style>
                                <Style BasedOn="{StaticResource AssetTypeFilterChipBase}" TargetType="Button">
                                    <Style.Triggers>
                                        <DataTrigger Binding="{Binding IsPeriod90}" Value="True">
                                            <Setter Property="Background" Value="{DynamicResource AppAccent}" />
                                            <Setter Property="Foreground" Value="White" />
                                            <Setter Property="BorderBrush" Value="{DynamicResource AppAccent}" />
                                        </DataTrigger>
                                    </Style.Triggers>
                                </Style>
                            </Button.Style>
                        </Button>
                    </StackPanel>
                    <lvc:CartesianChart
                        Grid.Row="2"
                        Height="140"
                        Background="Transparent"
                        Series="{Binding DailyPnlSeries}"
                        TooltipPosition="Top"
                        TooltipTextSize="10"
                        XAxes="{Binding DailyPnlXAxes}"
                        YAxes="{Binding DailyPnlYAxes}" />
                </Grid>
            </Grid>
        </Border>

        <!--  ═══ Row 2: Quote setup notice ═══  -->
        <Border
            Grid.Row="2"
            Margin="12,10,12,0"
            Padding="12,10"
            Background="{DynamicResource AppSurface}"
            BorderBrush="{DynamicResource AppBorder}"
            BorderThickness="1"
            CornerRadius="{StaticResource Radius.Sm}"
            Visibility="{Binding ShowQuoteProviderNotice, Converter={StaticResource BooleanToVisibilityConverter}}">
            <DockPanel LastChildFill="True">
                <ds:AppIcon
                    Margin="0,0,10,0"
                    VerticalAlignment="Top"
                    FontSize="16"
                    Foreground="{DynamicResource AppAccent}"
                    Symbol="Info24" />
                <StackPanel>
                    <TextBlock
                        FontSize="{StaticResource Font.Size.Sm}"
                        FontWeight="SemiBold"
                        Foreground="{DynamicResource AppTextPrimary}"
                        Text="{DynamicResource Portfolio.QuoteSetup.Title}" />
                    <TextBlock
                        Margin="0,2,0,0"
                        FontSize="{StaticResource Font.Size.Xs}"
                        Foreground="{DynamicResource AppTextSecondary}"
                        Text="{DynamicResource Portfolio.QuoteSetup.Message}"
                        TextWrapping="Wrap" />
                </StackPanel>
            </DockPanel>
        </Border>

        <!--
            ═══ Row 3: View mode + filters ═══
            上方是投資持倉的觀看方式（平面 / 群組 / 市場 / 類型），下方保留資產類型作為
            次要篩選。群組不再用可無限延展的 chip row，避免使用者建立多個策略群組後擠爆工具列。
        -->
        <StackPanel Grid.Row="3" Margin="12,14,12,6">
            <!--
                P5.13 (C2) — DockPanel：左側 view mode tabs / 右側群組管理 action buttons。
                舊版把「+新增群組」「管理群組」放在 IsGroupViewMode-gated Grid 內，使用者
                只能在依群組 mode 才能新建群組 — 不合理。Pull out 兩顆按鈕到 Row 1 右側，
                所有 view mode 下都可建立 / 管理群組。
            -->
            <DockPanel Margin="0,0,0,8">
                <StackPanel DockPanel.Dock="Right" Orientation="Horizontal">
                    <Button
                        Height="32"
                        Margin="0,0,8,0"
                        Padding="12,0"
                        Command="{Binding AddPortfolioGroupCommand}"
                        Style="{StaticResource AppPrimaryButton}">
                        <StackPanel Orientation="Horizontal">
                            <ds:AppIcon
                                Margin="0,0,6,0"
                                VerticalAlignment="Center"
                                FontSize="10"
                                Foreground="{DynamicResource Brush.Text.OnAccent}"
                                Symbol="Add24" />
                            <TextBlock
                                VerticalAlignment="Center"
                                Foreground="{DynamicResource Brush.Text.OnAccent}"
                                Text="{DynamicResource Portfolio.Filter.Group.Add}" />
                        </StackPanel>
                    </Button>
                    <Button
                        Height="32"
                        Padding="12,0"
                        Command="{Binding OpenPortfolioGroupsCommand}"
                        Content="{DynamicResource Portfolio.Filter.Group.Manage}"
                        Style="{StaticResource AppSecondaryButton}" />
                </StackPanel>
                <StackPanel Orientation="Horizontal">
                    <RadioButton
                        Command="{Binding SetPositionViewModeCommand}"
                        CommandParameter="{x:Static vm:InvestmentPositionViewMode.All}"
                        Content="{DynamicResource Portfolio.ViewMode.All}">
                        <RadioButton.Style>
                            <Style BasedOn="{StaticResource AppSubTab}" TargetType="RadioButton">
                                <Style.Triggers>
                                    <DataTrigger Binding="{Binding PositionViewMode}" Value="{x:Static vm:InvestmentPositionViewMode.All}">
                                        <Setter Property="IsChecked" Value="True" />
                                    </DataTrigger>
                                </Style.Triggers>
                            </Style>
                        </RadioButton.Style>
                    </RadioButton>
                    <RadioButton
                        Command="{Binding SetPositionViewModeCommand}"
                        CommandParameter="{x:Static vm:InvestmentPositionViewMode.Group}"
                        Content="{DynamicResource Portfolio.ViewMode.Group}">
                        <RadioButton.Style>
                            <Style BasedOn="{StaticResource AppSubTab}" TargetType="RadioButton">
                                <Style.Triggers>
                                    <DataTrigger Binding="{Binding PositionViewMode}" Value="{x:Static vm:InvestmentPositionViewMode.Group}">
                                        <Setter Property="IsChecked" Value="True" />
                                    </DataTrigger>
                                </Style.Triggers>
                            </Style>
                        </RadioButton.Style>
                    </RadioButton>
                    <RadioButton
                        Command="{Binding SetPositionViewModeCommand}"
                        CommandParameter="{x:Static vm:InvestmentPositionViewMode.Market}"
                        Content="{DynamicResource Portfolio.ViewMode.Market}">
                        <RadioButton.Style>
                            <Style BasedOn="{StaticResource AppSubTab}" TargetType="RadioButton">
                                <Style.Triggers>
                                    <DataTrigger Binding="{Binding PositionViewMode}" Value="{x:Static vm:InvestmentPositionViewMode.Market}">
                                        <Setter Property="IsChecked" Value="True" />
                                    </DataTrigger>
                                </Style.Triggers>
                            </Style>
                        </RadioButton.Style>
                    </RadioButton>
                    <RadioButton
                        Command="{Binding SetPositionViewModeCommand}"
                        CommandParameter="{x:Static vm:InvestmentPositionViewMode.Type}"
                        Content="{DynamicResource Portfolio.ViewMode.Type}">
                        <RadioButton.Style>
                            <Style BasedOn="{StaticResource AppSubTab}" TargetType="RadioButton">
                                <Style.Triggers>
                                    <DataTrigger Binding="{Binding PositionViewMode}" Value="{x:Static vm:InvestmentPositionViewMode.Type}">
                                        <Setter Property="IsChecked" Value="True" />
                                    </DataTrigger>
                                </Style.Triggers>
                            </Style>
                        </RadioButton.Style>
                    </RadioButton>
                </StackPanel>
            </DockPanel>

            <!--
                P5.13 (C1) — Row 2 整列拿掉。
                舊版 row 2 在「全部 / 依市場 / 依類型」mode 顯示資產類型 chips，
                「依群組」mode 改顯示群組 chips。對使用者來說兩列都像「歸類」，
                概念上看不出 row 1 是「視圖」、row 2 是「篩選」。
                
                改法：刪掉 row 2 chips 整列。
                - 想看 ETF / 個股 / 基金：切到「依類型」view mode 自動分組
                - 想看某個策略群組：切到「依群組」view mode 自動分組
                - 想找特定資產：用 Row 4 搜尋框（符號 / 名稱 contains 比對）
                
                VM 端 SetAssetTypeFilterCommand / SetPortfolioGroupFilterCommand /
                PortfolioGroupFilterChips collection 保留（unit test 覆蓋）— 只是
                沒 UI 入口。FilterPosition 的 AssetTypeFilter / PortfolioGroupFilter
                判斷仍存在但永遠 null = no-op，行為等於只走 view mode + FilterText。
            -->
        </StackPanel>

        <!--  ═══ Row 4: Text search ═══  -->
        <controls:SearchBox
            Grid.Row="4"
            Placeholder="{DynamicResource Portfolio.Filter.SearchPositions}"
            Text="{Binding FilterText}">
            <controls:SearchBox.RightContent>
                <StackPanel VerticalAlignment="Center" Orientation="Horizontal">
                    <CheckBox
                        Margin="0,0,8,0"
                        VerticalAlignment="Center"
                        IsChecked="{Binding HideEmptyPositions}">
                        <TextBlock
                            FontSize="{StaticResource Font.Size.Xs}"
                            Foreground="{DynamicResource AppTextSecondary}"
                            Text="{DynamicResource Portfolio.Position.HideEmpty}" />
                    </CheckBox>
                    <CheckBox
                        Margin="0,0,8,0"
                        VerticalAlignment="Center"
                        IsChecked="{Binding ShowArchivedPositions}">
                        <TextBlock
                            FontSize="{StaticResource Font.Size.Xs}"
                            Foreground="{DynamicResource AppTextSecondary}"
                            Text="{DynamicResource Portfolio.Position.ShowArchived}" />
                    </CheckBox>
                    <!--
                        +觀察：建立 PortfolioEntry 但不下單。對齊「先看一段時間再決定買」的
                        使用情境，呼應 broker app 的自選股 / 觀察清單入口。
                    -->
                    <Button
                        MinHeight="32"
                        Margin="0,0,6,0"
                        Padding="10,0"
                        Command="{Binding OpenAddWatchlistDialogCommand}"
                        Style="{StaticResource AppSecondaryButton}"
                        ToolTip="{DynamicResource Portfolio.Watchlist.AddCommand.Hint}">
                        <StackPanel Orientation="Horizontal">
                            <ds:AppIcon
                                Margin="0,0,6,0"
                                VerticalAlignment="Center"
                                FontSize="{StaticResource Font.Size.Xs}"
                                Symbol="Add24" />
                            <TextBlock VerticalAlignment="Center" Text="{DynamicResource Portfolio.Watchlist.AddCommand}" />
                        </StackPanel>
                    </Button>
                </StackPanel>
            </controls:SearchBox.RightContent>
        </controls:SearchBox>

        <!--  ═══ Row 5: Positions DataGrid ═══  -->
        <Grid Grid.Row="5">
            <!--  Empty state  -->
            <Border
                Padding="32"
                Background="{DynamicResource AppBackground}"
                Visibility="{Binding HasNoPositions, Converter={StaticResource BooleanToVisibilityConverter}}">
                <StackPanel HorizontalAlignment="Center" VerticalAlignment="Center">
                    <TextBlock
                        Margin="0,0,0,12"
                        HorizontalAlignment="Center"
                        FontSize="{StaticResource Font.Size.3xl}"
                        Opacity="0.45"
                        Text="&#x1F4BC;" />
                    <TextBlock
                        HorizontalAlignment="Center"
                        FontSize="{StaticResource Font.Size.Md}"
                        FontWeight="SemiBold"
                        Foreground="{DynamicResource AppTextPrimary}"
                        Text="{DynamicResource Portfolio.Empty}" />
                    <TextBlock
                        Margin="0,6,0,20"
                        HorizontalAlignment="Center"
                        FontSize="{StaticResource Font.Size.Sm}"
                        Foreground="{DynamicResource AppTextSecondary}"
                        Text="{DynamicResource Portfolio.Empty.Hint}" />
                    <Button
                        Height="36"
                        Padding="20,0"
                        HorizontalAlignment="Center"
                        Command="{Binding AddRecordCommand}"
                        Style="{StaticResource AppPrimaryButton}">
                        <TextBlock Foreground="{Binding Foreground, RelativeSource={RelativeSource AncestorType=Button}}" Text="{DynamicResource Portfolio.Empty.Cta}" />
                    </Button>
                </StackPanel>
            </Border>

            <ListBox
                Margin="0,8,0,12"
                HorizontalContentAlignment="Stretch"
                Background="Transparent"
                BorderThickness="0"
                ItemsSource="{Binding PositionsView}"
                ScrollViewer.HorizontalScrollBarVisibility="Disabled"
                ScrollViewer.VerticalScrollBarVisibility="Auto"
                SelectedItem="{Binding SelectedPositionRow, Mode=TwoWay}">
                <ListBox.GroupStyle>
                    <GroupStyle>
                        <GroupStyle.HeaderTemplate>
                            <StaticResource ResourceKey="PositionGroupHeaderTemplate" />
                        </GroupStyle.HeaderTemplate>
                    </GroupStyle>
                </ListBox.GroupStyle>
                <ListBox.ItemContainerStyle>
                    <Style TargetType="ListBoxItem">
                        <Setter Property="Padding" Value="0" />
                        <Setter Property="Margin" Value="0" />
                        <Setter Property="Background" Value="Transparent" />
                        <Setter Property="BorderThickness" Value="0" />
                        <Setter Property="HorizontalAlignment" Value="Stretch" />
                        <Setter Property="HorizontalContentAlignment" Value="Stretch" />
                        <Setter Property="FocusVisualStyle" Value="{x:Null}" />
                        <Setter Property="Template">
                            <Setter.Value>
                                <ControlTemplate TargetType="ListBoxItem">
                                    <ContentPresenter HorizontalAlignment="Stretch" VerticalAlignment="Stretch" />
                                </ControlTemplate>
                            </Setter.Value>
                        </Setter>
                    </Style>
                </ListBox.ItemContainerStyle>
                <ListBox.Style>
                    <Style TargetType="ListBox">
                        <Setter Property="Visibility" Value="Collapsed" />
                        <Style.Triggers>
                            <DataTrigger Value="True">
                                <DataTrigger.Binding>
                                    <MultiBinding Converter="{StaticResource WidthScaleThresholdToBooleanConverter}" ConverterParameter="1180">
                                        <Binding ElementName="Root" Path="ActualWidth" />
                                        <Binding Path="DataContext.Settings.UiScale" RelativeSource="{RelativeSource AncestorType=Window}" />
                                    </MultiBinding>
                                </DataTrigger.Binding>
                                <Setter Property="Visibility" Value="Visible" />
                            </DataTrigger>
                        </Style.Triggers>
                    </Style>
                </ListBox.Style>
                <ListBox.ItemTemplate>
                    <DataTemplate>
                        <Border
                            Margin="0,0,0,10"
                            Padding="14,12"
                            CornerRadius="{StaticResource Radius.Md}">
                            <Border.Style>
                                <Style TargetType="Border">
                                    <Setter Property="Background" Value="{DynamicResource AppSurface}" />
                                    <Setter Property="BorderBrush" Value="{DynamicResource AppBorder}" />
                                    <Setter Property="BorderThickness" Value="1" />
                                    <Style.Triggers>
                                        <DataTrigger Binding="{Binding IsMouseOver, RelativeSource={RelativeSource AncestorType=ListBoxItem}}" Value="True">
                                            <Setter Property="Background" Value="{DynamicResource AppHover}" />
                                            <Setter Property="BorderBrush" Value="{DynamicResource AppBorderStrong}" />
                                        </DataTrigger>
                                        <DataTrigger Binding="{Binding IsSelected, RelativeSource={RelativeSource AncestorType=ListBoxItem}}" Value="True">
                                            <Setter Property="Background" Value="{DynamicResource AppSelection}" />
                                            <Setter Property="BorderBrush" Value="{DynamicResource AppAccent}" />
                                            <Setter Property="BorderThickness" Value="1.5" />
                                        </DataTrigger>
                                    </Style.Triggers>
                                </Style>
                            </Border.Style>
                            <StackPanel>
                                <Grid>
                                    <Grid.RowDefinitions>
                                        <RowDefinition Height="Auto" />
                                        <RowDefinition Height="Auto" />
                                    </Grid.RowDefinitions>
                                    <Grid.ColumnDefinitions>
                                        <ColumnDefinition Width="72" />
                                        <ColumnDefinition Width="Auto" />
                                        <ColumnDefinition Width="*" />
                                        <ColumnDefinition Width="Auto" />
                                    </Grid.ColumnDefinitions>

                                    <TextBlock
                                        Grid.Row="0"
                                        Grid.Column="0"
                                        Margin="0,0,10,0"
                                        VerticalAlignment="Center"
                                        FontFamily="{StaticResource Font.Family.Base}"
                                        FontSize="{StaticResource Font.Size.Sm}"
                                        FontWeight="SemiBold"
                                        Foreground="{DynamicResource AppTextPrimary}"
                                        Text="{Binding Symbol}"
                                        Typography.NumeralAlignment="Tabular" />

                                    <Border
                                        Grid.Row="0"
                                        Grid.Column="1"
                                        Margin="0,0,10,0"
                                        Style="{StaticResource PortfolioAssetTypeBadge}">
                                        <TextBlock Style="{StaticResource PortfolioBadgeText}" Text="{Binding AssetTypeBadgeLabel}" />
                                    </Border>

                                    <!--
                                        P5.11 — card view 也拿掉 chip 背景，只剩純文字。
                                        用 AppTextSecondary 弱化讓視覺主軸落在 Symbol + Name 而非幣別代碼。
                                    -->
                                    <TextBlock
                                        Grid.Row="0"
                                        Grid.Column="2"
                                        Margin="0,0,10,0"
                                        VerticalAlignment="Center"
                                        FontFamily="{StaticResource Font.Family.Base}"
                                        FontSize="{StaticResource Font.Size.Xs}"
                                        Foreground="{DynamicResource AppTextSecondary}"
                                        Text="{Binding CurrencyDisplay}"
                                        Typography.NumeralAlignment="Tabular" />

                                    <TextBlock
                                        Grid.Row="1"
                                        Grid.Column="0"
                                        Grid.ColumnSpan="3"
                                        Margin="0,6,0,0"
                                        FontSize="{StaticResource Font.Size.Sm}"
                                        Foreground="{DynamicResource AppTextSecondary}"
                                        Text="{Binding Name}"
                                        TextTrimming="CharacterEllipsis" />
                                    <Button
                                        Grid.Row="0"
                                        Grid.RowSpan="2"
                                        Grid.Column="3"
                                        Height="28"
                                        MinWidth="0"
                                        Padding="10,0"
                                        Command="{Binding DataContext.Account.OpenEditPositionCommand, RelativeSource={RelativeSource AncestorType=ListBox}}"
                                        CommandParameter="{Binding}"
                                        Content="{DynamicResource Portfolio.Group.MoveToGroup}"
                                        Style="{StaticResource AppSecondaryButton}"
                                        ToolTip="{DynamicResource Portfolio.Group.MoveToGroup}"
                                        Visibility="{Binding DataContext.HasPortfolioGroups, RelativeSource={RelativeSource AncestorType=ListBox}, Converter={StaticResource BooleanToVisibilityConverter}, FallbackValue=Collapsed}" />
                                </Grid>

                                <Border
                                    Margin="0,10,0,0"
                                    BorderBrush="{DynamicResource AppBorder}"
                                    BorderThickness="0,1,0,0"
                                    Opacity="0.7" />

                                <UniformGrid
                                    Margin="0,10,0,0"
                                    Columns="3"
                                    Rows="3">
                                    <StackPanel Margin="0,0,12,4">
                                        <TextBlock
                                            FontSize="{StaticResource Font.Size.Xs}"
                                            Foreground="{DynamicResource AppTextMuted}"
                                            Text="{DynamicResource Portfolio.Shares}" />
                                        <TextBlock
                                            FontFamily="{StaticResource Font.Family.Base}"
                                            FontSize="{StaticResource Font.Size.Sm}"
                                            Foreground="{DynamicResource AppTextPrimary}"
                                            Text="{Binding QuantityDisplay}"
                                            Typography.NumeralAlignment="Tabular" />
                                    </StackPanel>
                                    <StackPanel Margin="0,0,12,4">
                                        <TextBlock
                                            FontSize="{StaticResource Font.Size.Xs}"
                                            Foreground="{DynamicResource AppTextMuted}"
                                            Text="{DynamicResource Portfolio.CostPerShare}" />
                                        <TextBlock
                                            FontFamily="{StaticResource Font.Family.Base}"
                                            FontSize="{StaticResource Font.Size.Sm}"
                                            Foreground="{DynamicResource AppTextSecondary}"
                                            Text="{Binding BuyPriceAsMoney, Converter={StaticResource CurrencyConverter}, ConverterParameter=price}"
                                            Typography.NumeralAlignment="Tabular" />
                                    </StackPanel>
                                    <StackPanel Margin="0,0,0,4">
                                        <TextBlock
                                            FontSize="{StaticResource Font.Size.Xs}"
                                            Foreground="{DynamicResource AppTextMuted}"
                                            Text="{DynamicResource Portfolio.TotalCostPaid}" />
                                        <TextBlock
                                            FontFamily="{StaticResource Font.Family.Base}"
                                            FontSize="{StaticResource Font.Size.Sm}"
                                            Foreground="{DynamicResource AppTextPrimary}"
                                            Text="{Binding CostAsMoney, Converter={StaticResource CurrencyConverter}, ConverterParameter=amount}"
                                            Typography.NumeralAlignment="Tabular" />
                                    </StackPanel>
                                    <StackPanel Margin="0,8,12,0">
                                        <TextBlock
                                            FontSize="{StaticResource Font.Size.Xs}"
                                            Foreground="{DynamicResource AppTextMuted}"
                                            Text="{DynamicResource Portfolio.Price}" />
                                        <TextBlock
                                            FontFamily="{StaticResource Font.Family.Base}"
                                            FontSize="{StaticResource Font.Size.Sm}"
                                            Foreground="{DynamicResource AppTextPrimary}"
                                            Text="{Binding CurrentPriceAsMoney, Converter={StaticResource CurrencyConverter}, ConverterParameter=price}"
                                            Typography.NumeralAlignment="Tabular" />
                                        <Border
                                            Margin="0,3,0,0"
                                            Style="{StaticResource StatusBadge.Info}"
                                            ToolTip="{Binding QuoteProviderStateMessage}"
                                            Visibility="{Binding ShowQuoteProviderState, Converter={StaticResource BooleanToVisibilityConverter}}">
                                            <TextBlock Style="{StaticResource StatusBadge.Text}" Text="{DynamicResource Portfolio.QuoteState.Stale}" />
                                        </Border>
                                    </StackPanel>
                                    <StackPanel Margin="0,8,12,0">
                                        <TextBlock
                                            FontSize="{StaticResource Font.Size.Xs}"
                                            Foreground="{DynamicResource AppTextMuted}"
                                            Text="{DynamicResource Common.MarketValue}" />
                                        <TextBlock
                                            FontFamily="{StaticResource Font.Family.Base}"
                                            FontSize="{StaticResource Font.Size.Sm}"
                                            Foreground="{DynamicResource AppTextPrimary}"
                                            Text="{Binding MarketValueAsMoney, Converter={StaticResource CurrencyConverter}, ConverterParameter=amount}"
                                            Typography.NumeralAlignment="Tabular" />
                                    </StackPanel>
                                    <StackPanel Margin="0,8,0,0">
                                        <TextBlock
                                            FontSize="{StaticResource Font.Size.Xs}"
                                            Foreground="{DynamicResource AppTextMuted}"
                                            Text="{DynamicResource Portfolio.NetVal}" />
                                        <TextBlock
                                            FontFamily="{StaticResource Font.Family.Base}"
                                            FontSize="{StaticResource Font.Size.Sm}"
                                            Foreground="{DynamicResource AppTextPrimary}"
                                            Text="{Binding NetValueAsMoney, Converter={StaticResource CurrencyConverter}, ConverterParameter=amount}"
                                            Typography.NumeralAlignment="Tabular" />
                                    </StackPanel>
                                    <StackPanel Margin="0,8,12,0">
                                        <TextBlock
                                            FontSize="{StaticResource Font.Size.Xs}"
                                            Foreground="{DynamicResource AppTextMuted}"
                                            Text="{DynamicResource Portfolio.PnL}" />
                                        <TextBlock
                                            FontFamily="{StaticResource Font.Family.Base}"
                                            FontSize="{StaticResource Font.Size.Sm}"
                                            FontWeight="SemiBold"
                                            Text="{Binding PnlAsMoney, Converter={StaticResource CurrencyConverter}, ConverterParameter=signed}"
                                            Typography.NumeralAlignment="Tabular">
                                            <TextBlock.Style>
                                                <Style TargetType="TextBlock">
                                                    <Setter Property="Foreground" Value="{DynamicResource AppDown}" />
                                                    <Style.Triggers>
                                                        <DataTrigger Binding="{Binding IsPnlPositive}" Value="True">
                                                            <Setter Property="Foreground" Value="{DynamicResource AppUp}" />
                                                        </DataTrigger>
                                                        <DataTrigger Binding="{Binding Pnl}" Value="0">
                                                            <Setter Property="Foreground" Value="{DynamicResource AppTextMuted}" />
                                                        </DataTrigger>
                                                    </Style.Triggers>
                                                </Style>
                                            </TextBlock.Style>
                                        </TextBlock>
                                    </StackPanel>
                                    <StackPanel Margin="0,8,0,0">
                                        <TextBlock
                                            FontSize="{StaticResource Font.Size.Xs}"
                                            Foreground="{DynamicResource AppTextMuted}"
                                            Text="{DynamicResource Portfolio.PercentOfPortfolio}" />
                                        <TextBlock
                                            FontFamily="{StaticResource Font.Family.Base}"
                                            FontSize="{StaticResource Font.Size.Sm}"
                                            Foreground="{DynamicResource AppTextSecondary}"
                                            Text="{Binding PercentOfPortfolio, StringFormat={}{0:F1}%}"
                                            Typography.NumeralAlignment="Tabular" />
                                    </StackPanel>
                                </UniformGrid>
                            </StackPanel>
                        </Border>
                    </DataTemplate>
                </ListBox.ItemTemplate>
            </ListBox>

            <DataGrid
                x:Name="PortfolioGrid"
                AlternationCount="2"
                AutoGenerateColumns="False"
                Background="{DynamicResource AppBackground}"
                BorderThickness="0"
                CanUserAddRows="False"
                CanUserDeleteRows="False"
                CanUserReorderColumns="False"
                CanUserResizeColumns="False"
                CanUserSortColumns="True"
                ColumnHeaderHeight="{StaticResource DataGrid.HeaderHeight}"
                EnableRowVirtualization="True"
                FontFamily="{StaticResource Font.Family.Base}"
                FontSize="{StaticResource Font.Size.Sm}"
                Foreground="{DynamicResource AppTextPrimary}"
                GridLinesVisibility="None"
                HeadersVisibility="Column"
                HorizontalScrollBarVisibility="Auto"
                IsReadOnly="True"
                ItemsSource="{Binding PositionsView}"
                PreviewMouseDown="OnGridPreviewMouseDown"
                RowHeight="{StaticResource DataGrid.RowHeight}"
                SelectedItem="{Binding SelectedPositionRow, Mode=TwoWay}"
                SelectionMode="Single"
                VirtualizingPanel.IsVirtualizing="True"
                VirtualizingPanel.VirtualizationMode="Recycling">
                <DataGrid.Style>
                    <Style TargetType="DataGrid">
                        <Setter Property="Visibility" Value="Visible" />
                        <Style.Triggers>
                            <DataTrigger Value="True">
                                <DataTrigger.Binding>
                                    <MultiBinding Converter="{StaticResource WidthScaleThresholdToBooleanConverter}" ConverterParameter="1180">
                                        <Binding ElementName="Root" Path="ActualWidth" />
                                        <Binding Path="DataContext.Settings.UiScale" RelativeSource="{RelativeSource AncestorType=Window}" />
                                    </MultiBinding>
                                </DataTrigger.Binding>
                                <Setter Property="Visibility" Value="Collapsed" />
                            </DataTrigger>
                        </Style.Triggers>
                    </Style>
                </DataGrid.Style>

                <DataGrid.ColumnHeaderStyle>
                    <Style BasedOn="{StaticResource AppDataGridColHeader}" TargetType="DataGridColumnHeader" />
                </DataGrid.ColumnHeaderStyle>
                <DataGrid.CellStyle>
                    <Style BasedOn="{StaticResource AppDataGridCell}" TargetType="DataGridCell" />
                </DataGrid.CellStyle>
                <DataGrid.RowStyle>
                    <Style BasedOn="{StaticResource AppDataGridRowSelectable}" TargetType="DataGridRow" />
                </DataGrid.RowStyle>
                <DataGrid.GroupStyle>
                    <GroupStyle>
                        <GroupStyle.HeaderTemplate>
                            <StaticResource ResourceKey="PositionGroupHeaderTemplate" />
                        </GroupStyle.HeaderTemplate>
                    </GroupStyle>
                </DataGrid.GroupStyle>

                <DataGrid.Columns>
                    <!--  資產 — 代號 + 類型 badge + 名稱（P5.11：幣別已拆到下一欄，這裡不再 inline）  -->
                    <DataGridTemplateColumn
                        Width="*"
                        MinWidth="200"
                        SortMemberPath="Symbol">
                        <DataGridTemplateColumn.Header>
                            <TextBlock Text="{DynamicResource Portfolio.AssetWithCurrency}" />
                        </DataGridTemplateColumn.Header>
                        <DataGridTemplateColumn.CellTemplate>
                            <DataTemplate>
                                <Grid VerticalAlignment="Center">
                                    <Grid.ColumnDefinitions>
                                        <ColumnDefinition Width="72" />
                                        <ColumnDefinition Width="42" />
                                        <ColumnDefinition Width="*" />
                                        <ColumnDefinition Width="Auto" />
                                    </Grid.ColumnDefinitions>
                                    <TextBlock
                                        Grid.Column="0"
                                        Margin="0,0,10,0"
                                        VerticalAlignment="Center"
                                        FontFamily="{StaticResource Font.Family.Base}"
                                        FontSize="{StaticResource Font.Size.Sm}"
                                        FontWeight="SemiBold"
                                        Foreground="{DynamicResource AppTextPrimary}"
                                        Text="{Binding Symbol}"
                                        Typography.NumeralAlignment="Tabular" />
                                    <Border
                                        Grid.Column="1"
                                        Margin="0,0,10,0"
                                        HorizontalAlignment="Center"
                                        Style="{StaticResource PortfolioAssetTypeBadge}">
                                        <TextBlock Style="{StaticResource PortfolioBadgeText}" Text="{Binding AssetTypeBadgeLabel}" />
                                    </Border>
                                    <TextBlock
                                        Grid.Column="2"
                                        VerticalAlignment="Center"
                                        FontFamily="{StaticResource Font.Family.Base}"
                                        FontSize="{StaticResource Font.Size.Sm}"
                                        Foreground="{DynamicResource AppTextPrimary}"
                                        Text="{Binding Name}"
                                        TextTrimming="CharacterEllipsis" />
                                    <Button
                                        Grid.Column="3"
                                        Height="28"
                                        MinWidth="0"
                                        Padding="10,0"
                                        Command="{Binding DataContext.Account.OpenEditPositionCommand, RelativeSource={RelativeSource AncestorType=DataGrid}}"
                                        CommandParameter="{Binding}"
                                        Content="{DynamicResource Portfolio.Group.MoveToGroup}"
                                        Style="{StaticResource AppSecondaryButton}"
                                        ToolTip="{DynamicResource Portfolio.Group.MoveToGroup}"
                                        Visibility="{Binding DataContext.HasPortfolioGroups, RelativeSource={RelativeSource AncestorType=DataGrid}, Converter={StaticResource BooleanToVisibilityConverter}, FallbackValue=Collapsed}" />
                                </Grid>
                            </DataTemplate>
                        </DataGridTemplateColumn.CellTemplate>
                    </DataGridTemplateColumn>

                    <!--
                        幣別 — P5.11 新獨立欄。原本 chip-style inline 在 Asset col 內，
                        現拆出純文字欄位（無背景無 chip border），用 AppTextSecondary 弱化
                        顏色不搶資料主視覺。固定窄寬 70px 對 3-char 幣別代碼足夠。
                    -->
                    <DataGridTemplateColumn Width="70" SortMemberPath="CurrencyDisplay">
                        <DataGridTemplateColumn.Header>
                            <TextBlock Text="{DynamicResource Portfolio.Currency}" />
                        </DataGridTemplateColumn.Header>
                        <DataGridTemplateColumn.CellTemplate>
                            <DataTemplate>
                                <TextBlock
                                    HorizontalAlignment="Center"
                                    VerticalAlignment="Center"
                                    FontFamily="{StaticResource Font.Family.Base}"
                                    FontSize="{StaticResource Font.Size.Sm}"
                                    Foreground="{DynamicResource AppTextSecondary}"
                                    Text="{Binding CurrencyDisplay}"
                                    Typography.NumeralAlignment="Tabular" />
                            </DataTemplate>
                        </DataGridTemplateColumn.CellTemplate>
                    </DataGridTemplateColumn>

                    <!--  股數  -->
                    <DataGridTemplateColumn Width="150" SortMemberPath="Quantity">
                        <DataGridTemplateColumn.HeaderStyle>
                            <Style BasedOn="{StaticResource AppDataGridColHeader}" TargetType="DataGridColumnHeader">
                                <Setter Property="HorizontalContentAlignment" Value="Right" />
                            </Style>
                        </DataGridTemplateColumn.HeaderStyle>
                        <DataGridTemplateColumn.Header>
                            <TextBlock Text="{DynamicResource Portfolio.Shares}" />
                        </DataGridTemplateColumn.Header>
                        <DataGridTemplateColumn.CellTemplate>
                            <DataTemplate>
                                <TextBlock
                                    HorizontalAlignment="Right"
                                    VerticalAlignment="Center"
                                    FontFamily="{StaticResource Font.Family.Base}"
                                    FontSize="{StaticResource Font.Size.Sm}"
                                    Text="{Binding QuantityDisplay}"
                                    Typography.NumeralAlignment="Tabular" />
                            </DataTemplate>
                        </DataGridTemplateColumn.CellTemplate>
                    </DataGridTemplateColumn>

                    <!--  成本/股（含手續費）  -->
                    <DataGridTemplateColumn Width="120" SortMemberPath="BuyPrice">
                        <DataGridTemplateColumn.HeaderStyle>
                            <Style BasedOn="{StaticResource AppDataGridColHeader}" TargetType="DataGridColumnHeader">
                                <Setter Property="HorizontalContentAlignment" Value="Right" />
                            </Style>
                        </DataGridTemplateColumn.HeaderStyle>
                        <DataGridTemplateColumn.Header>
                            <TextBlock Text="{DynamicResource Portfolio.CostPerShare.Native}" />
                        </DataGridTemplateColumn.Header>
                        <DataGridTemplateColumn.CellTemplate>
                            <DataTemplate>
                                <StackPanel HorizontalAlignment="Right" VerticalAlignment="Center">
                                    <TextBlock
                                        HorizontalAlignment="Right"
                                        FontFamily="{StaticResource Font.Family.Base}"
                                        FontSize="{StaticResource Font.Size.Sm}"
                                        Text="{Binding BuyPriceAsMoney, Converter={StaticResource CurrencyConverter}, ConverterParameter=price}"
                                        Typography.NumeralAlignment="Tabular" />
                                    <TextBlock
                                        HorizontalAlignment="Right"
                                        FontFamily="{StaticResource Font.Family.Base}"
                                        FontSize="{StaticResource Font.Size.Xs}"
                                        Foreground="{DynamicResource AppTextMuted}"
                                        Text="{Binding BuyPriceBaseAsMoney, Converter={StaticResource CurrencyConverter}, ConverterParameter=price-approx}"
                                        Typography.NumeralAlignment="Tabular"
                                        Visibility="{Binding IsCrossCurrency, Converter={StaticResource BooleanToVisibilityConverter}}" />
                                </StackPanel>
                            </DataTemplate>
                        </DataGridTemplateColumn.CellTemplate>
                    </DataGridTemplateColumn>

                    <!--  付出成本（含買入手續費）  -->
                    <DataGridTemplateColumn Width="150" SortMemberPath="Cost">
                        <DataGridTemplateColumn.HeaderStyle>
                            <Style BasedOn="{StaticResource AppDataGridColHeader}" TargetType="DataGridColumnHeader">
                                <Setter Property="HorizontalContentAlignment" Value="Right" />
                            </Style>
                        </DataGridTemplateColumn.HeaderStyle>
                        <DataGridTemplateColumn.Header>
                            <TextBlock Text="{DynamicResource Portfolio.TotalCostPaid.Native}" />
                        </DataGridTemplateColumn.Header>
                        <DataGridTemplateColumn.CellTemplate>
                            <DataTemplate>
                                <StackPanel HorizontalAlignment="Right" VerticalAlignment="Center">
                                    <TextBlock
                                        HorizontalAlignment="Right"
                                        FontFamily="{StaticResource Font.Family.Base}"
                                        FontSize="{StaticResource Font.Size.Sm}"
                                        Foreground="{DynamicResource AppTextPrimary}"
                                        Text="{Binding CostAsMoney, Converter={StaticResource CurrencyConverter}, ConverterParameter=amount}"
                                        Typography.NumeralAlignment="Tabular" />
                                    <TextBlock
                                        HorizontalAlignment="Right"
                                        FontFamily="{StaticResource Font.Family.Base}"
                                        FontSize="{StaticResource Font.Size.Xs}"
                                        Foreground="{DynamicResource AppTextMuted}"
                                        Text="{Binding CostBaseAsMoney, Converter={StaticResource CurrencyConverter}, ConverterParameter=amount-approx}"
                                        Typography.NumeralAlignment="Tabular"
                                        Visibility="{Binding IsCrossCurrency, Converter={StaticResource BooleanToVisibilityConverter}}" />
                                </StackPanel>
                            </DataTemplate>
                        </DataGridTemplateColumn.CellTemplate>
                    </DataGridTemplateColumn>

                    <!--  現價（合併今日漲跌% 小字）  -->
                    <DataGridTemplateColumn Width="120" SortMemberPath="CurrentPrice">
                        <DataGridTemplateColumn.HeaderStyle>
                            <Style BasedOn="{StaticResource AppDataGridColHeader}" TargetType="DataGridColumnHeader">
                                <Setter Property="HorizontalContentAlignment" Value="Right" />
                            </Style>
                        </DataGridTemplateColumn.HeaderStyle>
                        <DataGridTemplateColumn.Header>
                            <TextBlock Text="{DynamicResource Portfolio.Price.Native}" />
                        </DataGridTemplateColumn.Header>
                        <DataGridTemplateColumn.CellTemplate>
                            <DataTemplate>
                                <Grid>
                                    <StackPanel HorizontalAlignment="Right" VerticalAlignment="Center">
                                        <TextBlock
                                            HorizontalAlignment="Right"
                                            FontFamily="{StaticResource Font.Family.Base}"
                                            FontSize="{StaticResource Font.Size.Sm}"
                                            FontWeight="SemiBold"
                                            Foreground="{DynamicResource AppTextPrimary}"
                                            Text="{Binding CurrentPriceAsMoney, Converter={StaticResource CurrencyConverter}, ConverterParameter=price}"
                                            Typography.NumeralAlignment="Tabular">
                                            <TextBlock.Style>
                                                <Style TargetType="TextBlock">
                                                    <Setter Property="Visibility" Value="Visible" />
                                                    <Style.Triggers>
                                                        <DataTrigger Binding="{Binding CurrentPrice}" Value="0">
                                                            <Setter Property="Visibility" Value="Collapsed" />
                                                        </DataTrigger>
                                                    </Style.Triggers>
                                                </Style>
                                            </TextBlock.Style>
                                        </TextBlock>
                                        <TextBlock
                                            HorizontalAlignment="Right"
                                            FontFamily="{StaticResource Font.Family.Base}"
                                            FontSize="{StaticResource Font.Size.Xs}"
                                            Foreground="{DynamicResource AppTextMuted}"
                                            Text="{Binding CurrentPriceBaseAsMoney, Converter={StaticResource CurrencyConverter}, ConverterParameter=price-approx}"
                                            Typography.NumeralAlignment="Tabular"
                                            Visibility="{Binding IsCrossCurrency, Converter={StaticResource BooleanToVisibilityConverter}}" />
                                        <!--  今日 %（色彩跟漲跌連動）  -->
                                        <TextBlock
                                            HorizontalAlignment="Right"
                                            FontFamily="{StaticResource Font.Family.Base}"
                                            FontSize="{StaticResource Font.Size.Xs}"
                                            Text="{Binding DayChangePercent, StringFormat={}{0:+0.00;-0.00;0.00}%}"
                                            Typography.NumeralAlignment="Tabular">
                                            <TextBlock.Style>
                                                <Style TargetType="TextBlock">
                                                    <Setter Property="Foreground" Value="{DynamicResource AppDown}" />
                                                    <Style.Triggers>
                                                        <DataTrigger Binding="{Binding IsDayChangePositive}" Value="True">
                                                            <Setter Property="Foreground" Value="{DynamicResource AppUp}" />
                                                        </DataTrigger>
                                                        <DataTrigger Binding="{Binding DayChange}" Value="0">
                                                            <Setter Property="Foreground" Value="{DynamicResource AppTextMuted}" />
                                                        </DataTrigger>
                                                        <DataTrigger Binding="{Binding PrevClose}" Value="0">
                                                            <Setter Property="Visibility" Value="Collapsed" />
                                                        </DataTrigger>
                                                    </Style.Triggers>
                                                </Style>
                                            </TextBlock.Style>
                                        </TextBlock>
                                        <Border
                                            Margin="0,3,0,0"
                                            HorizontalAlignment="Right"
                                            Style="{StaticResource StatusBadge.Info}"
                                            ToolTip="{Binding QuoteProviderStateMessage}"
                                            Visibility="{Binding ShowQuoteProviderState, Converter={StaticResource BooleanToVisibilityConverter}}">
                                            <TextBlock Style="{StaticResource StatusBadge.Text}" Text="{DynamicResource Portfolio.QuoteState.Stale}" />
                                        </Border>
                                    </StackPanel>
                                    <TextBlock
                                        HorizontalAlignment="Right"
                                        VerticalAlignment="Center"
                                        FontFamily="{StaticResource Font.Family.Base}"
                                        FontSize="{StaticResource Font.Size.Sm}"
                                        Foreground="{DynamicResource AppTextMuted}"
                                        Text="…"
                                        Typography.NumeralAlignment="Tabular"
                                        Visibility="{Binding IsLoadingPrice, Converter={StaticResource BooleanToVisibilityConverter}}" />
                                </Grid>
                            </DataTemplate>
                        </DataGridTemplateColumn.CellTemplate>
                    </DataGridTemplateColumn>

                    <!--  淨值（市值扣預估賣出費/稅）  -->
                    <DataGridTemplateColumn Width="150" SortMemberPath="NetValue">
                        <DataGridTemplateColumn.HeaderStyle>
                            <Style BasedOn="{StaticResource AppDataGridColHeader}" TargetType="DataGridColumnHeader">
                                <Setter Property="HorizontalContentAlignment" Value="Right" />
                            </Style>
                        </DataGridTemplateColumn.HeaderStyle>
                        <DataGridTemplateColumn.Header>
                            <TextBlock
                                Text="{DynamicResource Portfolio.NetVal.Native}"
                                ToolTip="{DynamicResource Portfolio.NetVal.Tooltip}"
                                ToolTipService.InitialShowDelay="300"
                                ToolTipService.ShowDuration="20000" />
                        </DataGridTemplateColumn.Header>
                        <DataGridTemplateColumn.CellTemplate>
                            <DataTemplate>
                                <Grid ToolTip="{DynamicResource Portfolio.NetVal.Tooltip}" ToolTipService.InitialShowDelay="500">
                                    <StackPanel HorizontalAlignment="Right" VerticalAlignment="Center">
                                        <TextBlock
                                            HorizontalAlignment="Right"
                                            FontFamily="{StaticResource Font.Family.Base}"
                                            FontSize="{StaticResource Font.Size.Sm}"
                                            FontWeight="SemiBold"
                                            Foreground="{DynamicResource AppTextPrimary}"
                                            Text="{Binding NetValueAsMoney, Converter={StaticResource CurrencyConverter}, ConverterParameter=amount}"
                                            Typography.NumeralAlignment="Tabular" />
                                        <TextBlock
                                            HorizontalAlignment="Right"
                                            FontFamily="{StaticResource Font.Family.Base}"
                                            FontSize="{StaticResource Font.Size.Xs}"
                                            Foreground="{DynamicResource AppTextMuted}"
                                            Text="{Binding NetValueBaseAsMoney, Converter={StaticResource CurrencyConverter}, ConverterParameter=amount-approx}"
                                            Typography.NumeralAlignment="Tabular"
                                            Visibility="{Binding IsCrossCurrency, Converter={StaticResource BooleanToVisibilityConverter}}" />
                                    </StackPanel>
                                    <TextBlock
                                        HorizontalAlignment="Right"
                                        VerticalAlignment="Center"
                                        FontFamily="{StaticResource Font.Family.Base}"
                                        FontSize="{StaticResource Font.Size.Sm}"
                                        Foreground="{DynamicResource AppTextMuted}"
                                        Text="…"
                                        Typography.NumeralAlignment="Tabular"
                                        Visibility="{Binding IsLoadingPrice, Converter={StaticResource BooleanToVisibilityConverter}}" />
                                </Grid>
                            </DataTemplate>
                        </DataGridTemplateColumn.CellTemplate>
                    </DataGridTemplateColumn>

                    <!--  淨損益試算（淨值 - 付出成本）  -->
                    <DataGridTemplateColumn Width="180" SortMemberPath="Pnl">
                        <DataGridTemplateColumn.HeaderStyle>
                            <Style BasedOn="{StaticResource AppDataGridColHeader}" TargetType="DataGridColumnHeader">
                                <Setter Property="HorizontalContentAlignment" Value="Right" />
                            </Style>
                        </DataGridTemplateColumn.HeaderStyle>
                        <DataGridTemplateColumn.Header>
                            <TextBlock
                                Text="{DynamicResource Portfolio.PnL.Native}"
                                ToolTip="{DynamicResource Portfolio.PnL.NetTooltip}"
                                ToolTipService.InitialShowDelay="300"
                                ToolTipService.ShowDuration="20000" />
                        </DataGridTemplateColumn.Header>
                        <DataGridTemplateColumn.CellTemplate>
                            <DataTemplate>
                                <Grid ToolTip="{DynamicResource Portfolio.PnL.NetTooltip}" ToolTipService.InitialShowDelay="500">
                                    <StackPanel HorizontalAlignment="Right" VerticalAlignment="Center">
                                        <TextBlock
                                            HorizontalAlignment="Right"
                                            FontFamily="{StaticResource Font.Family.Base}"
                                            FontSize="{StaticResource Font.Size.Sm}"
                                            FontWeight="SemiBold"
                                            Text="{Binding PnlAsMoney, Converter={StaticResource CurrencyConverter}, ConverterParameter=signed}"
                                            Typography.NumeralAlignment="Tabular">
                                            <TextBlock.Style>
                                                <Style TargetType="TextBlock">
                                                    <Setter Property="Foreground" Value="{DynamicResource AppDown}" />
                                                    <Style.Triggers>
                                                        <DataTrigger Binding="{Binding IsPnlPositive}" Value="True">
                                                            <Setter Property="Foreground" Value="{DynamicResource AppUp}" />
                                                        </DataTrigger>
                                                        <DataTrigger Binding="{Binding Pnl}" Value="0">
                                                            <Setter Property="Foreground" Value="{DynamicResource AppTextMuted}" />
                                                        </DataTrigger>
                                                    </Style.Triggers>
                                                </Style>
                                            </TextBlock.Style>
                                        </TextBlock>
                                        <TextBlock
                                            HorizontalAlignment="Right"
                                            FontFamily="{StaticResource Font.Family.Base}"
                                            FontSize="{StaticResource Font.Size.Xs}"
                                            Text="{Binding PnlPercent, StringFormat={}{0:+0.00;-0.00;0.00}%}"
                                            Typography.NumeralAlignment="Tabular">
                                            <TextBlock.Style>
                                                <Style TargetType="TextBlock">
                                                    <Setter Property="Foreground" Value="{DynamicResource AppDown}" />
                                                    <Style.Triggers>
                                                        <DataTrigger Binding="{Binding IsPnlPositive}" Value="True">
                                                            <Setter Property="Foreground" Value="{DynamicResource AppUp}" />
                                                        </DataTrigger>
                                                        <DataTrigger Binding="{Binding Pnl}" Value="0">
                                                            <Setter Property="Foreground" Value="{DynamicResource AppTextMuted}" />
                                                        </DataTrigger>
                                                    </Style.Triggers>
                                                </Style>
                                            </TextBlock.Style>
                                        </TextBlock>
                                        <TextBlock
                                            HorizontalAlignment="Right"
                                            FontFamily="{StaticResource Font.Family.Base}"
                                            FontSize="{StaticResource Font.Size.Xs}"
                                            Foreground="{DynamicResource AppTextMuted}"
                                            Text="{Binding PnlBaseAsMoney, Converter={StaticResource CurrencyConverter}, ConverterParameter=signed-approx}"
                                            Typography.NumeralAlignment="Tabular"
                                            Visibility="{Binding IsCrossCurrency, Converter={StaticResource BooleanToVisibilityConverter}}" />
                                    </StackPanel>
                                    <TextBlock
                                        HorizontalAlignment="Right"
                                        VerticalAlignment="Center"
                                        FontFamily="{StaticResource Font.Family.Base}"
                                        FontSize="{StaticResource Font.Size.Sm}"
                                        Foreground="{DynamicResource AppTextMuted}"
                                        Text="…"
                                        Typography.NumeralAlignment="Tabular"
                                        Visibility="{Binding IsLoadingPrice, Converter={StaticResource BooleanToVisibilityConverter}}" />
                                </Grid>
                            </DataTemplate>
                        </DataGridTemplateColumn.CellTemplate>
                    </DataGridTemplateColumn>

                    <!--
                        市值（未扣預估賣出費/稅）— v2 移到最右側欄位。
                        移除原本 Sparkline (30 天走勢) + PercentOfPortfolio (佔比) 兩個欄位，
                        現在資產表只保留純財務欄位：資產 / 數量 / 成本均價 / 付出成本 / 現價 /
                        淨值 / 淨損益試算 / 市值。
                    -->
                    <DataGridTemplateColumn Width="150" SortMemberPath="MarketValue">
                        <DataGridTemplateColumn.HeaderStyle>
                            <Style BasedOn="{StaticResource AppDataGridColHeader}" TargetType="DataGridColumnHeader">
                                <Setter Property="HorizontalContentAlignment" Value="Right" />
                            </Style>
                        </DataGridTemplateColumn.HeaderStyle>
                        <DataGridTemplateColumn.Header>
                            <TextBlock Text="{DynamicResource Portfolio.MarketValue.Native}" />
                        </DataGridTemplateColumn.Header>
                        <DataGridTemplateColumn.CellTemplate>
                            <DataTemplate>
                                <Grid>
                                    <StackPanel HorizontalAlignment="Right" VerticalAlignment="Center">
                                        <TextBlock
                                            HorizontalAlignment="Right"
                                            FontFamily="{StaticResource Font.Family.Base}"
                                            FontSize="{StaticResource Font.Size.Sm}"
                                            FontWeight="SemiBold"
                                            Foreground="{DynamicResource AppTextPrimary}"
                                            Text="{Binding MarketValueAsMoney, Converter={StaticResource CurrencyConverter}, ConverterParameter=amount}"
                                            Typography.NumeralAlignment="Tabular" />
                                        <TextBlock
                                            HorizontalAlignment="Right"
                                            FontFamily="{StaticResource Font.Family.Base}"
                                            FontSize="{StaticResource Font.Size.Xs}"
                                            Foreground="{DynamicResource AppTextMuted}"
                                            Text="{Binding MarketValueBaseAsMoney, Converter={StaticResource CurrencyConverter}, ConverterParameter=amount-approx}"
                                            Typography.NumeralAlignment="Tabular"
                                            Visibility="{Binding IsCrossCurrency, Converter={StaticResource BooleanToVisibilityConverter}}" />
                                    </StackPanel>
                                    <TextBlock
                                        HorizontalAlignment="Right"
                                        VerticalAlignment="Center"
                                        FontFamily="{StaticResource Font.Family.Base}"
                                        FontSize="{StaticResource Font.Size.Sm}"
                                        Foreground="{DynamicResource AppTextMuted}"
                                        Text="…"
                                        Typography.NumeralAlignment="Tabular"
                                        Visibility="{Binding IsLoadingPrice, Converter={StaticResource BooleanToVisibilityConverter}}" />
                                </Grid>
                            </DataTemplate>
                        </DataGridTemplateColumn.CellTemplate>
                    </DataGridTemplateColumn>
                </DataGrid.Columns>
            </DataGrid>

            <!--  Empty state  -->
            <Border
                Padding="32"
                Background="{DynamicResource AppBackground}"
                Visibility="{Binding HasNoPositions, Converter={StaticResource BooleanToVisibilityConverter}}">
                <StackPanel HorizontalAlignment="Center" VerticalAlignment="Center">
                    <TextBlock
                        Margin="0,0,0,12"
                        HorizontalAlignment="Center"
                        FontSize="{StaticResource Font.Size.3xl}"
                        Opacity="0.45"
                        Text="&#x1F4BC;" />
                    <TextBlock
                        HorizontalAlignment="Center"
                        FontSize="{StaticResource Font.Size.Md}"
                        FontWeight="SemiBold"
                        Foreground="{DynamicResource AppTextPrimary}"
                        Text="{DynamicResource Portfolio.Empty}" />
                    <TextBlock
                        Margin="0,6,0,20"
                        HorizontalAlignment="Center"
                        FontSize="{StaticResource Font.Size.Sm}"
                        Foreground="{DynamicResource AppTextSecondary}"
                        Text="{DynamicResource Portfolio.Empty.Hint}" />
                    <Button
                        Height="36"
                        Padding="20,0"
                        HorizontalAlignment="Center"
                        Command="{Binding AddRecordCommand}"
                        Style="{StaticResource AppPrimaryButton}">
                        <TextBlock Foreground="{Binding Foreground, RelativeSource={RelativeSource AncestorType=Button}}" Text="{DynamicResource Portfolio.Empty.Cta}" />
                    </Button>
                </StackPanel>
            </Border>
        </Grid>

        <!--
            ═══ Row 6: Filter Summary Footer ═══
            篩選作用中才顯示（IsPositionsFiltered=true）。仿 TradesTabPanel 的「流入 /
            流出 / 淨額」footer pattern，讓使用者切資產類型 chip 後立即看到該類別
            的彙總（筆數 / 市值 / 成本 / 損益），不必心算。
        -->
        <!--
            Footer 永遠顯示 — 「全部」也是篩選的一種（無條件全留），看見整體合計
            跟切資產類型後的子集合計一樣有用，不該只在 chip 不是全部時才顯示。
        -->
        <Border
            Grid.Row="6"
            Padding="12,6"
            Background="{DynamicResource AppSurface}"
            BorderBrush="{DynamicResource AppBorder}"
            BorderThickness="0,1,0,0">
            <ScrollViewer HorizontalScrollBarVisibility="Auto" VerticalScrollBarVisibility="Disabled">
                <StackPanel Orientation="Horizontal">
                    <StackPanel Margin="0,0,24,0" Orientation="Horizontal">
                        <TextBlock
                            Margin="0,0,6,0"
                            VerticalAlignment="Center"
                            FontSize="{StaticResource Font.Size.Xs}"
                            Foreground="{DynamicResource AppTextMuted}"
                            Text="{DynamicResource Portfolio.Filter.Summary.Count}" />
                        <TextBlock
                            VerticalAlignment="Center"
                            FontFamily="{StaticResource Font.Family.Base}"
                            FontSize="{StaticResource Font.Size.Sm}"
                            FontWeight="SemiBold"
                            Foreground="{DynamicResource AppTextPrimary}"
                            Text="{Binding PositionsFilteredCount, StringFormat={}{0:N0}}"
                            Typography.NumeralAlignment="Tabular" />
                    </StackPanel>
                    <StackPanel Margin="0,0,24,0" Orientation="Horizontal">
                        <TextBlock
                            Margin="0,0,6,0"
                            VerticalAlignment="Center"
                            FontSize="{StaticResource Font.Size.Xs}"
                            Foreground="{DynamicResource AppTextMuted}"
                            Text="{DynamicResource Portfolio.Filter.Summary.MarketValue}" />
                        <TextBlock
                            VerticalAlignment="Center"
                            FontFamily="{StaticResource Font.Family.Base}"
                            FontSize="{StaticResource Font.Size.Sm}"
                            FontWeight="SemiBold"
                            Foreground="{DynamicResource AppTextPrimary}"
                            Text="{Binding PositionsFilteredMarketValue, Converter={StaticResource CurrencyConverter}, ConverterParameter=amount}"
                            Typography.NumeralAlignment="Tabular" />
                    </StackPanel>
                    <StackPanel Margin="0,0,24,0" Orientation="Horizontal">
                        <TextBlock
                            Margin="0,0,6,0"
                            VerticalAlignment="Center"
                            FontSize="{StaticResource Font.Size.Xs}"
                            Foreground="{DynamicResource AppTextMuted}"
                            Text="{DynamicResource Portfolio.Filter.Summary.Cost}" />
                        <TextBlock
                            VerticalAlignment="Center"
                            FontFamily="{StaticResource Font.Family.Base}"
                            FontSize="{StaticResource Font.Size.Sm}"
                            Foreground="{DynamicResource AppTextSecondary}"
                            Text="{Binding PositionsFilteredCost, Converter={StaticResource CurrencyConverter}, ConverterParameter=amount}"
                            Typography.NumeralAlignment="Tabular" />
                    </StackPanel>
                    <StackPanel Orientation="Horizontal">
                        <TextBlock
                            Margin="0,0,6,0"
                            VerticalAlignment="Center"
                            FontSize="{StaticResource Font.Size.Xs}"
                            Foreground="{DynamicResource AppTextMuted}"
                            Text="{DynamicResource Portfolio.Filter.Summary.Pnl}" />
                        <TextBlock
                            VerticalAlignment="Center"
                            FontFamily="{StaticResource Font.Family.Base}"
                            FontSize="{StaticResource Font.Size.Sm}"
                            FontWeight="SemiBold"
                            Text="{Binding PositionsFilteredPnl, Converter={StaticResource CurrencyConverter}, ConverterParameter=signed}"
                            Typography.NumeralAlignment="Tabular">
                            <TextBlock.Style>
                                <Style TargetType="TextBlock">
                                    <Setter Property="Foreground" Value="{DynamicResource AppDown}" />
                                    <Style.Triggers>
                                        <DataTrigger Binding="{Binding IsPositionsFilteredPnlPositive}" Value="True">
                                            <Setter Property="Foreground" Value="{DynamicResource AppUp}" />
                                        </DataTrigger>
                                        <DataTrigger Binding="{Binding PositionsFilteredPnl}" Value="0">
                                            <Setter Property="Foreground" Value="{DynamicResource AppTextSecondary}" />
                                        </DataTrigger>
                                    </Style.Triggers>
                                </Style>
                            </TextBlock.Style>
                        </TextBlock>
                    </StackPanel>
                </StackPanel>
            </ScrollViewer>
        </Border>

        <!--
            ═══ Watchlist Add Dialog ═══
            Promoted to MainWindow.xaml so the backdrop dims the entire window
            (含 NavRail / title bar)，跟 AddRecordDialog / AddAssetDialog 一致。
        -->
    </Grid>

</UserControl>
