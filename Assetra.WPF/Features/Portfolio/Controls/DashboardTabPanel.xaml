<UserControl
    x:Class="Assetra.WPF.Features.Portfolio.Controls.DashboardTabPanel"
    xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
    xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
    xmlns:ctrl="clr-namespace:Assetra.WPF.Features.Portfolio.Controls"
    xmlns:d="http://schemas.microsoft.com/expression/blend/2008"
    xmlns:lvc="clr-namespace:LiveChartsCore.SkiaSharpView.WPF;assembly=LiveChartsCore.SkiaSharpView.WPF"
    xmlns:mc="http://schemas.openxmlformats.org/markup-compatibility/2006"
    xmlns:vm="clr-namespace:Assetra.WPF.Features.Portfolio"
    d:DataContext="{d:DesignInstance Type={x:Type vm:DashboardViewModel}}"
    mc:Ignorable="d">

    <ScrollViewer HorizontalScrollBarVisibility="Disabled" VerticalScrollBarVisibility="Auto">
        <Grid Margin="24">
            <!--
                Slimmed dashboard (Portfolio Option A refactor): 10-day trend
                chart moved to Trends page; Recent Trades moved to top-level
                TransactionLog page. Dashboard keeps Hero + KPI metrics +
                Top Holdings + Budget Summary so it stays portfolio-focused.
            -->
            <Grid.RowDefinitions>
                <RowDefinition Height="Auto" />
                <RowDefinition Height="16" />
                <RowDefinition Height="Auto" />
                <RowDefinition Height="16" />
                <RowDefinition Height="Auto" />
            </Grid.RowDefinitions>

            <!--  ═══ Row 0: Hero card + 3 Metric cards ═══  -->
            <Grid Grid.Row="0">
                <Grid.ColumnDefinitions>
                    <ColumnDefinition Width="3*" />
                    <ColumnDefinition Width="16" />
                    <ColumnDefinition Width="2*" />
                    <ColumnDefinition Width="16" />
                    <ColumnDefinition Width="2*" />
                    <ColumnDefinition Width="16" />
                    <ColumnDefinition Width="2*" />
                </Grid.ColumnDefinitions>

                <!--  Hero: Net Worth  -->
                <Border
                    Grid.Column="0"
                    Style="{StaticResource FormCard}">
                    <StackPanel>
                        <TextBlock
                            FontSize="{StaticResource Font.Size.Sm}"
                            Foreground="{DynamicResource AppTextMuted}"
                            Text="{DynamicResource Portfolio.Header.NetWorth}" />
                        <TextBlock
                            Margin="0,4,0,0"
                            FontSize="{StaticResource Font.Size.2xl}"
                            FontWeight="SemiBold"
                            Foreground="{DynamicResource AppTextPrimary}"
                            Text="{Binding NetWorthDisplay}" />

                        <!--  Day P&L (hidden until live prices arrive)  -->
                        <StackPanel
                            Margin="0,4,0,0"
                            Orientation="Horizontal"
                            Visibility="{Binding HasDayPnl, Converter={StaticResource BooleanToVisibilityConverter}}">
                            <TextBlock
                                VerticalAlignment="Center"
                                FontSize="{StaticResource Font.Size.Sm}"
                                Foreground="{DynamicResource AppTextMuted}"
                                Text="{DynamicResource Portfolio.Header.DailyPnL}" />
                            <TextBlock
                                Margin="4,0,0,0"
                                VerticalAlignment="Center"
                                FontSize="{StaticResource Font.Size.Base}"
                                FontWeight="SemiBold">
                                <TextBlock.Style>
                                    <Style BasedOn="{StaticResource {x:Type TextBlock}}" TargetType="TextBlock">
                                        <Setter Property="Foreground" Value="{DynamicResource AppDown}" />
                                        <Style.Triggers>
                                            <DataTrigger Binding="{Binding IsDayPnlPositive}" Value="True">
                                                <Setter Property="Foreground" Value="{DynamicResource AppUp}" />
                                            </DataTrigger>
                                        </Style.Triggers>
                                    </Style>
                                </TextBlock.Style>
                                <Run Text="{Binding DayPnlDisplay, Mode=OneWay}" />
                                <Run Text=" " />
                                <Run Text="{Binding DayPnlPercentDisplay, Mode=OneWay}" />
                            </TextBlock>
                        </StackPanel>
                    </StackPanel>
                </Border>

                <!--  Metric: 淨損益  -->
                <Border
                    Grid.Column="2"
                    Style="{StaticResource FormCard}">
                    <StackPanel>
                        <TextBlock
                            FontSize="{StaticResource Font.Size.Sm}"
                            Foreground="{DynamicResource AppTextMuted}"
                            Text="{DynamicResource Portfolio.PnL}" />
                        <TextBlock
                            Margin="0,6,0,0"
                            FontSize="{StaticResource Font.Size.Xl}"
                            FontWeight="SemiBold"
                            Text="{Binding TotalPnlDisplay}">
                            <TextBlock.Style>
                                <Style BasedOn="{StaticResource {x:Type TextBlock}}" TargetType="TextBlock">
                                    <Setter Property="Foreground" Value="{DynamicResource AppDown}" />
                                    <Style.Triggers>
                                        <DataTrigger Binding="{Binding IsTotalPositive}" Value="True">
                                            <Setter Property="Foreground" Value="{DynamicResource AppUp}" />
                                        </DataTrigger>
                                    </Style.Triggers>
                                </Style>
                            </TextBlock.Style>
                        </TextBlock>
                        <TextBlock
                            Margin="0,2,0,0"
                            FontSize="{StaticResource Font.Size.Sm}"
                            Foreground="{DynamicResource AppTextMuted}"
                            Text="{Binding TotalPnlPercent, StringFormat={}{0:+0.00;-0.00}%}" />
                        <TextBlock
                            Margin="0,2,0,0"
                            FontSize="{StaticResource Font.Size.Xs}"
                            Foreground="{DynamicResource AppTextMuted}"
                            Text="{DynamicResource Dashboard.Pnl.Basis}" />
                    </StackPanel>
                </Border>

                <!--  Metric: 總資產  -->
                <Border
                    Grid.Column="4"
                    Style="{StaticResource FormCard}">
                    <StackPanel>
                        <TextBlock
                            FontSize="{StaticResource Font.Size.Sm}"
                            Foreground="{DynamicResource AppTextMuted}"
                            Text="{DynamicResource Portfolio.TotalAssets}" />
                        <TextBlock
                            Margin="0,6,0,0"
                            FontSize="{StaticResource Font.Size.Xl}"
                            FontWeight="SemiBold"
                            Foreground="{DynamicResource AppTextPrimary}"
                            Text="{Binding TotalAssetsDisplay}" />
                    </StackPanel>
                </Border>

                <!--  Metric: 負債（中性色 — 負債金額不是漲跌數字，避免綠/紅誤導）  -->
                <Border
                    Grid.Column="6"
                    Style="{StaticResource FormCard}">
                    <StackPanel>
                        <TextBlock
                            FontSize="{StaticResource Font.Size.Sm}"
                            Foreground="{DynamicResource AppTextMuted}"
                            Text="{DynamicResource Portfolio.Header.Liabilities}" />
                        <TextBlock
                            Margin="0,6,0,0"
                            FontSize="{StaticResource Font.Size.Xl}"
                            FontWeight="SemiBold"
                            Foreground="{DynamicResource AppTextPrimary}"
                            Text="{Binding TotalLiabilitiesDisplay}" />
                        <TextBlock
                            Margin="0,2,0,0"
                            FontSize="{StaticResource Font.Size.Xs}"
                            Foreground="{DynamicResource AppTextMuted}">
                            <Run Text="{DynamicResource Portfolio.Liability.DebtRatio}" />
                            <Run Text=" " />
                            <Run Text="{Binding DebtRatioValue, StringFormat={}{0:F1}%, Mode=OneWay}" />
                            <Run Text="  /  " />
                            <Run Text="{DynamicResource Portfolio.Liability.LeverageRatio}" />
                            <Run Text=" " />
                            <Run Text="{Binding LeverageRatio, StringFormat={}{0:F2}, Mode=OneWay}" />
                        </TextBlock>
                    </StackPanel>
                </Border>
            </Grid>

            <!--  ═══ Row 2: Top Holdings (full width) ═══  -->
            <Border
                Grid.Row="2"
                Style="{StaticResource FormCard}">
                    <StackPanel>
                        <DockPanel Margin="0,0,0,8">
                            <TextBlock
                                DockPanel.Dock="Left"
                                FontSize="{StaticResource Font.Size.Md}"
                                FontWeight="SemiBold"
                                Foreground="{DynamicResource AppTextPrimary}"
                                Text="{DynamicResource Dashboard.TopHoldings}" />
                            <Button
                                HorizontalAlignment="Right"
                                Command="{Binding NavigateToPositionsCommand}"
                                Content="{DynamicResource Dashboard.ViewDetail}"
                                DockPanel.Dock="Right"
                                Style="{StaticResource AppGhostButton}" />
                        </DockPanel>

                        <ItemsControl ItemsSource="{Binding TopPositions}">
                            <ItemsControl.ItemTemplate>
                                <DataTemplate>
                                    <Border
                                        Padding="0,6"
                                        BorderBrush="{DynamicResource AppBorderLight}"
                                        BorderThickness="0,0,0,1">
                                        <Grid>
                                            <Grid.ColumnDefinitions>
                                                <ColumnDefinition Width="*" />
                                                <ColumnDefinition Width="Auto" />
                                            </Grid.ColumnDefinitions>

                                            <StackPanel Grid.Column="0" VerticalAlignment="Center">
                                                <TextBlock
                                                    FontSize="{StaticResource Font.Size.Md}"
                                                    FontWeight="SemiBold"
                                                    Foreground="{DynamicResource AppTextPrimary}"
                                                    Text="{Binding Symbol}" />
                                                <TextBlock
                                                    FontSize="{StaticResource Font.Size.Sm}"
                                                    Foreground="{DynamicResource AppTextSecondary}"
                                                    Text="{Binding Name}"
                                                    TextTrimming="CharacterEllipsis" />
                                                <!--  成本均價（讓使用者快速看到買入成本，與右邊現價對照）  -->
                                                <TextBlock
                                                    FontSize="{StaticResource Font.Size.Xs}"
                                                    Foreground="{DynamicResource AppTextMuted}">
                                                    <Run Text="{DynamicResource Dashboard.TopHoldings.CostLabel}" />
                                                    <Run Text=" " />
                                                    <Run Text="{Binding BuyPrice, StringFormat=NT\{0:N2\}, Mode=OneWay}" />
                                                </TextBlock>
                                            </StackPanel>

                                            <StackPanel
                                                Grid.Column="1"
                                                HorizontalAlignment="Right"
                                                VerticalAlignment="Center">
                                                <TextBlock
                                                    HorizontalAlignment="Right"
                                                    FontSize="{StaticResource Font.Size.Sm}"
                                                    Text="{Binding DayChangePercent, StringFormat={}{0:+0.00;-0.00;0.00}%}">
                                                    <TextBlock.Style>
                                                        <Style BasedOn="{StaticResource {x:Type TextBlock}}" TargetType="TextBlock">
                                                            <Setter Property="Foreground" Value="{DynamicResource AppDown}" />
                                                            <Style.Triggers>
                                                                <DataTrigger Binding="{Binding IsDayChangePositive}" Value="True">
                                                                    <Setter Property="Foreground" Value="{DynamicResource AppUp}" />
                                                                </DataTrigger>
                                                                <DataTrigger Binding="{Binding CurrentPrice}" Value="0">
                                                                    <Setter Property="Foreground" Value="{DynamicResource AppTextMuted}" />
                                                                </DataTrigger>
                                                            </Style.Triggers>
                                                        </Style>
                                                    </TextBlock.Style>
                                                </TextBlock>
                                                <TextBlock
                                                    HorizontalAlignment="Right"
                                                    FontSize="{StaticResource Font.Size.Md}"
                                                    FontWeight="SemiBold"
                                                    Foreground="{DynamicResource AppTextPrimary}"
                                                    Text="{Binding MarketValue, StringFormat=NT\{0:N0\}}" />
                                                <!--  累積損益（取代原本的「現價」— 現價已可從 MarketValue / Quantity 推得）  -->
                                                <TextBlock
                                                    HorizontalAlignment="Right"
                                                    FontSize="{StaticResource Font.Size.Sm}"
                                                    FontWeight="SemiBold">
                                                    <TextBlock.Style>
                                                        <Style BasedOn="{StaticResource {x:Type TextBlock}}" TargetType="TextBlock">
                                                            <Setter Property="Foreground" Value="{DynamicResource AppDown}" />
                                                            <Style.Triggers>
                                                                <DataTrigger Binding="{Binding IsPnlPositive}" Value="True">
                                                                    <Setter Property="Foreground" Value="{DynamicResource AppUp}" />
                                                                </DataTrigger>
                                                            </Style.Triggers>
                                                        </Style>
                                                    </TextBlock.Style>
                                                    <Run Text="{Binding Pnl, StringFormat={}{0:+NT$#,##0;-NT$#,##0;NT$0}, Mode=OneWay}" />
                                                    <Run Text=" " />
                                                    <Run Text="{Binding PnlPercent, StringFormat={}{0:+0.00;-0.00;0.00}%, Mode=OneWay}" />
                                                </TextBlock>
                                            </StackPanel>
                                        </Grid>
                                    </Border>
                                </DataTemplate>
                            </ItemsControl.ItemTemplate>
                        </ItemsControl>
                    </StackPanel>
                </Border>

            <!--  ═══ Row 4: Budget Summary Card ═══  -->
            <ctrl:BudgetSummaryCard Grid.Row="4" DataContext="{Binding BudgetSummary}" />

        </Grid>
    </ScrollViewer>
</UserControl>
