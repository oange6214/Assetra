<UserControl
    x:Class="Assetra.WPF.Features.Portfolio.Controls.TradesTabPanel"
    xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
    xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
    xmlns:controls="clr-namespace:Assetra.WPF.Controls"
    xmlns:d="http://schemas.microsoft.com/expression/blend/2008"
    xmlns:mc="http://schemas.openxmlformats.org/markup-compatibility/2006"
    xmlns:pcontrols="clr-namespace:Assetra.WPF.Features.Portfolio.Controls"
    xmlns:ui="http://schemas.lepo.co/wpfui/2022/xaml"
    xmlns:vm="clr-namespace:Assetra.WPF.Features.Portfolio"
    x:Name="Root"
    d:DataContext="{d:DesignInstance Type={x:Type vm:PortfolioViewModel}}"
    mc:Ignorable="d">

  <UserControl.Resources>
    <Style x:Key="DividendCalendarToggleButtonStyle" TargetType="ToggleButton">
      <Setter Property="Background" Value="Transparent" />
      <Setter Property="BorderThickness" Value="0" />
      <Setter Property="Padding" Value="6" />
      <Setter Property="Cursor" Value="Hand" />
      <Setter Property="FocusVisualStyle" Value="{StaticResource FocusVisual}" />
      <Setter Property="Template">
        <Setter.Value>
          <ControlTemplate TargetType="ToggleButton">
            <Border
                x:Name="Bd"
                Padding="{TemplateBinding Padding}"
                Background="{TemplateBinding Background}"
                BorderBrush="Transparent"
                BorderThickness="1"
                CornerRadius="{StaticResource RadiusSm}">
              <ContentPresenter
                  x:Name="Icon"
                  HorizontalAlignment="Center"
                  VerticalAlignment="Center" />
            </Border>
            <ControlTemplate.Triggers>
              <Trigger Property="IsChecked" Value="True">
                <Setter TargetName="Bd" Property="Background" Value="{DynamicResource AppAccentSubtle}" />
                <Setter TargetName="Bd" Property="BorderBrush" Value="{DynamicResource AppAccent}" />
              </Trigger>
              <Trigger Property="IsMouseOver" Value="True">
                <Setter TargetName="Bd" Property="BorderBrush" Value="{DynamicResource AppAccent}" />
                <Setter TargetName="Bd" Property="Background" Value="{DynamicResource AppAccentSubtle}" />
              </Trigger>
              <Trigger Property="IsPressed" Value="True">
                <Setter TargetName="Bd" Property="BorderBrush" Value="{DynamicResource AppAccentHover}" />
                <Setter TargetName="Bd" Property="Background" Value="{DynamicResource AppAccentSubtle}" />
                <Setter TargetName="Icon" Property="Opacity" Value="0.6" />
              </Trigger>
            </ControlTemplate.Triggers>
          </ControlTemplate>
        </Setter.Value>
      </Setter>
    </Style>
  </UserControl.Resources>

  <Grid>
    <Grid.RowDefinitions>
      <RowDefinition Height="Auto" />
      <!--  0: Dividend calendar  -->
      <RowDefinition Height="Auto" />
      <!--  1: Filter bar (date / type / asset / search / count)  -->
      <RowDefinition Height="*" />
      <!--  2: DataGrid  -->
      <RowDefinition Height="Auto" />
      <!--  3: Pagination  -->
    </Grid.RowDefinitions>

    <!--  Dividend calendar (4×3 months, collapsible — hidden if no dividend trades)  -->
    <Border
            Grid.Row="0"
            Padding="12,6,12,0"
            Background="{DynamicResource AppSurface}"
            BorderBrush="{DynamicResource AppBorder}"
            BorderThickness="0,0,0,1"
            Visibility="{Binding HasAnyDividendTrades, Converter={StaticResource BooleanToVisibilityConverter}}">
      <StackPanel>
        <StackPanel Margin="0,0,0,4" Orientation="Horizontal">
          <ToggleButton
                        Width="24"
                        Height="24"
                        Padding="0"
                        VerticalAlignment="Center"
                        IsChecked="{Binding DivCalendar.IsExpanded, Mode=TwoWay}"
                        Style="{StaticResource DividendCalendarToggleButtonStyle}">
            <ui:SymbolIcon FontSize="10" Foreground="{DynamicResource AppTextMuted}">
              <ui:SymbolIcon.Style>
                <Style TargetType="ui:SymbolIcon">
                  <Setter Property="Symbol" Value="ChevronUp24" />
                  <Style.Triggers>
                    <DataTrigger Binding="{Binding DivCalendar.IsExpanded}" Value="False">
                      <Setter Property="Symbol" Value="ChevronDown24" />
                    </DataTrigger>
                  </Style.Triggers>
                </Style>
              </ui:SymbolIcon.Style>
            </ui:SymbolIcon>
          </ToggleButton>
          <TextBlock
                        Margin="4,0,0,0"
                        VerticalAlignment="Center"
                        FontSize="{StaticResource FontSizeSm}"
                        FontWeight="SemiBold"
                        Foreground="{DynamicResource AppTextSecondary}"
                        Text="{DynamicResource Portfolio.DivCalendar.Title}" />
        </StackPanel>
        <pcontrols:DividendCalendarPanel Visibility="{Binding DivCalendar.IsExpanded, Converter={StaticResource BooleanToVisibilityConverter}}" />
      </StackPanel>
    </Border>

    <!--  ═══ Row 1: Filter bar (date, type, asset, clear, add) ═══  -->
    <Border
            Grid.Row="1"
            Padding="12,7"
            Background="{DynamicResource AppSurface}"
            BorderBrush="{DynamicResource AppBorder}"
            BorderThickness="0,0,0,1">
      <!--
                視覺順序 (左→右)：[Search fills] [Date range] [Type] [Asset] [Clear] [Count]
                實作：DockPanel LastChildFill=True，Search 放最後吃剩餘空間；
                其他以 DockPanel.Dock="Right" 從右往左依序 dock，所以 XAML 中
                「最先寫」＝「視覺最右側」。全部 30px 高度統一。
            -->
      <ScrollViewer HorizontalScrollBarVisibility="Auto" VerticalScrollBarVisibility="Disabled">
        <DockPanel MinWidth="860" LastChildFill="True">
          <!--  筆數顯示（最右）  -->
          <TextBlock
                        Margin="12,0,0,0"
                        VerticalAlignment="Center"
                        DockPanel.Dock="Right"
                        FontFamily="{StaticResource FontBase}" Typography.NumeralAlignment="Tabular"
                        FontSize="{StaticResource FontSizeXs}"
                        Foreground="{DynamicResource AppTextMuted}"
                        Text="{Binding TradeFilter.TradePageDisplay}" />

          <!--  清除篩選（有啟用中篩選時才顯示）  -->
          <ui:Button
                        Height="30"
                        Margin="8,0,0,0"
                        Padding="8,0"
                        VerticalAlignment="Center"
                        VerticalContentAlignment="Center"
                        Command="{Binding TradeFilter.ClearTradeFiltersCommand}"
                        DockPanel.Dock="Right"
                        Appearance="Secondary"
                        Visibility="{Binding TradeFilter.HasActiveTradeFilter, Converter={StaticResource BooleanToVisibilityConverter}}">
            <StackPanel VerticalAlignment="Center" Orientation="Horizontal">
              <ui:SymbolIcon Symbol="Dismiss24" Margin="0,0,4,0" VerticalAlignment="Center" FontSize="10" Foreground="{DynamicResource AppTextMuted}" />
              <TextBlock
                                VerticalAlignment="Center"
                                FontSize="{StaticResource FontSizeXs}"
                                Foreground="{DynamicResource AppTextSecondary}"
                                Text="{DynamicResource Portfolio.Filter.Clear}" />
            </StackPanel>
          </ui:Button>

          <!--  資產 — ToggleButton + Popup 多選（依投資/現金/負債分組）  -->
          <Grid
                        Width="{StaticResource FilterComboWidth}"
                        Height="30"
                        Margin="8,0,0,0"
                        VerticalAlignment="Center"
                        DockPanel.Dock="Right">
            <ToggleButton
                            x:Name="TradeAssetPopupToggle"
                            Height="30"
                            Padding="10,0,28,0"
                            HorizontalAlignment="Stretch"
                            VerticalAlignment="Center"
                            HorizontalContentAlignment="Left"
                            VerticalContentAlignment="Center"
                            Background="{DynamicResource AppBackground}"
                            BorderBrush="{DynamicResource AppBorder}"
                            BorderThickness="1"
                            Content="{Binding TradeFilter.TradeAssetFiltersDisplay}"
                            Cursor="Hand"
                            FontSize="{StaticResource FontSizeSm}"
                            Foreground="{DynamicResource AppTextPrimary}" />
            <ui:SymbolIcon
                            Width="12"
                            Height="12"
                            Margin="0,0,10,0"
                            HorizontalAlignment="Right"
                            VerticalAlignment="Center"
                            FontSize="12"
                            Foreground="{DynamicResource AppTextMuted}"
                            IsHitTestVisible="False"
                            Symbol="ChevronDown24" />
            <Popup
                            AllowsTransparency="True"
                            IsOpen="{Binding IsChecked, ElementName=TradeAssetPopupToggle}"
                            Placement="Bottom"
                            PlacementTarget="{Binding ElementName=TradeAssetPopupToggle}"
                            StaysOpen="False">
              <Border
                                Width="260"
                                Margin="0,4,0,0"
                                Background="{DynamicResource AppSurface}"
                                BorderBrush="{DynamicResource AppBorder}"
                                BorderThickness="1"
                                CornerRadius="{StaticResource RadiusSm}">
                <Grid Margin="8">
                  <Grid.RowDefinitions>
                    <RowDefinition Height="Auto" />
                    <RowDefinition Height="Auto" />
                    <RowDefinition Height="*" />
                  </Grid.RowDefinitions>

                  <!--  Search  -->
                  <Border
                                        Grid.Row="0"
                                        Height="30"
                                        Margin="0,0,0,8"
                                        Background="{DynamicResource AppBackground}"
                                        BorderBrush="{DynamicResource AppBorder}"
                                        BorderThickness="1"
                                        CornerRadius="{StaticResource RadiusSm}">
                    <Grid>
                      <Grid.ColumnDefinitions>
                        <ColumnDefinition Width="Auto" />
                        <ColumnDefinition Width="*" />
                      </Grid.ColumnDefinitions>
                      <ui:SymbolIcon
                                                Grid.Column="0"
                                                Width="12"
                                                Height="12"
                                                Margin="8,0,4,0"
                                                VerticalAlignment="Center"
                                                FontSize="12"
                                                Foreground="{DynamicResource AppTextMuted}"
                                                Symbol="Search24" />
                      <ui:TextBox
                                                Grid.Column="1"
                                                Margin="4,0,8,0"
                                                VerticalContentAlignment="Center"
                                                Background="Transparent"
                                                BorderThickness="0"
                                                FontSize="{StaticResource FontSizeSm}"
                                                Foreground="{DynamicResource AppTextPrimary}"
                                                Text="{Binding TradeFilter.TradeAssetFiltersSearch, UpdateSourceTrigger=PropertyChanged}" />
                    </Grid>
                  </Border>

                  <ui:Button
                                        Grid.Row="1"
                                        Height="30"
                                        Margin="0,0,0,8"
                                        HorizontalContentAlignment="Center"
                                        Command="{Binding TradeFilter.ClearTradeAssetFiltersCommand}"
                                        Content="{DynamicResource Portfolio.Filter.ClearInPopup}"
                                        FontSize="{StaticResource FontSizeSm}"
                                        Appearance="Secondary" />

                  <!--  分組清單（投資/現金/負債 header + 勾選 item）  -->
                  <ScrollViewer
                                        Grid.Row="2"
                                        MaxHeight="320"
                                        VerticalScrollBarVisibility="Auto">
                    <ItemsControl ItemsSource="{Binding TradeFilter.TradeAssetFiltersView}">
                      <ItemsControl.Template>
                        <ControlTemplate TargetType="ItemsControl">
                          <ItemsPresenter />
                        </ControlTemplate>
                      </ItemsControl.Template>
                      <ItemsControl.ItemTemplate>
                        <DataTemplate>
                          <CheckBox
                                                        Margin="4,4"
                                                        Content="{Binding Symbol}"
                                                        FontSize="{StaticResource FontSizeSm}"
                                                        Foreground="{DynamicResource AppTextPrimary}"
                                                        IsChecked="{Binding IsChecked, Mode=TwoWay}" />
                        </DataTemplate>
                      </ItemsControl.ItemTemplate>
                      <ItemsControl.GroupStyle>
                        <GroupStyle>
                          <GroupStyle.HeaderTemplate>
                            <DataTemplate>
                              <TextBlock
                                                                Margin="4,8,4,2"
                                                                FontSize="{StaticResource FontSizeXs}"
                                                                FontWeight="SemiBold"
                                                                Foreground="{DynamicResource AppTextMuted}"
                                                                Text="{Binding Name}" />
                            </DataTemplate>
                          </GroupStyle.HeaderTemplate>
                        </GroupStyle>
                      </ItemsControl.GroupStyle>
                    </ItemsControl>
                  </ScrollViewer>
                </Grid>
              </Border>
            </Popup>
          </Grid>

          <!--  類型 — ToggleButton + Popup 多選清單（search + clear + checkbox 列表）  -->
          <Grid
                        Width="140"
                        Height="30"
                        Margin="8,0,0,0"
                        VerticalAlignment="Center"
                        DockPanel.Dock="Right">
            <ToggleButton
                            x:Name="TradeTypePopupToggle"
                            Height="30"
                            Padding="10,0,28,0"
                            HorizontalAlignment="Stretch"
                            VerticalAlignment="Center"
                            HorizontalContentAlignment="Left"
                            VerticalContentAlignment="Center"
                            Background="{DynamicResource AppBackground}"
                            BorderBrush="{DynamicResource AppBorder}"
                            BorderThickness="1"
                            Content="{Binding TradeFilter.TradeTypeFiltersDisplay}"
                            Cursor="Hand"
                            FontSize="{StaticResource FontSizeSm}"
                            Foreground="{DynamicResource AppTextPrimary}" />
            <!--  Caret (chevron)  -->
            <ui:SymbolIcon
                            Width="12"
                            Height="12"
                            Margin="0,0,10,0"
                            HorizontalAlignment="Right"
                            VerticalAlignment="Center"
                            FontSize="12"
                            Foreground="{DynamicResource AppTextMuted}"
                            IsHitTestVisible="False"
                            Symbol="ChevronDown24" />
            <!--  Popup  -->
            <Popup
                            AllowsTransparency="True"
                            IsOpen="{Binding IsChecked, ElementName=TradeTypePopupToggle}"
                            Placement="Bottom"
                            PlacementTarget="{Binding ElementName=TradeTypePopupToggle}"
                            StaysOpen="False">
              <Border
                                Width="220"
                                Margin="0,4,0,0"
                                Background="{DynamicResource AppSurface}"
                                BorderBrush="{DynamicResource AppBorder}"
                                BorderThickness="1"
                                CornerRadius="{StaticResource RadiusSm}">
                <Grid Margin="8">
                  <Grid.RowDefinitions>
                    <RowDefinition Height="Auto" />
                    <!--  Search  -->
                    <RowDefinition Height="Auto" />
                    <!--  Clear button  -->
                    <RowDefinition Height="*" />
                    <!--  Checkbox list  -->
                  </Grid.RowDefinitions>

                  <!--  Search  -->
                  <Border
                                        Grid.Row="0"
                                        Height="30"
                                        Margin="0,0,0,8"
                                        Background="{DynamicResource AppBackground}"
                                        BorderBrush="{DynamicResource AppBorder}"
                                        BorderThickness="1"
                                        CornerRadius="{StaticResource RadiusSm}">
                    <Grid>
                      <Grid.ColumnDefinitions>
                        <ColumnDefinition Width="Auto" />
                        <ColumnDefinition Width="*" />
                      </Grid.ColumnDefinitions>
                      <ui:SymbolIcon
                                                Grid.Column="0"
                                                Width="12"
                                                Height="12"
                                                Margin="8,0,4,0"
                                                VerticalAlignment="Center"
                                                FontSize="12"
                                                Foreground="{DynamicResource AppTextMuted}"
                                                Symbol="Search24" />
                      <ui:TextBox
                                                Grid.Column="1"
                                                Margin="4,0,8,0"
                                                VerticalContentAlignment="Center"
                                                Background="Transparent"
                                                BorderThickness="0"
                                                FontSize="{StaticResource FontSizeSm}"
                                                Foreground="{DynamicResource AppTextPrimary}"
                                                Text="{Binding TradeFilter.TradeTypeFiltersSearch, UpdateSourceTrigger=PropertyChanged}" />
                    </Grid>
                  </Border>

                  <!--  Clear filters 按鈕  -->
                  <ui:Button
                                        Grid.Row="1"
                                        Height="30"
                                        Margin="0,0,0,8"
                                        HorizontalContentAlignment="Center"
                                        Command="{Binding TradeFilter.ClearTradeTypeFiltersCommand}"
                                        Content="{DynamicResource Portfolio.Filter.ClearInPopup}"
                                        FontSize="{StaticResource FontSizeSm}"
                                        Appearance="Secondary" />

                  <!--  勾選清單（search text 過濾後的 view）  -->
                  <ScrollViewer
                                        Grid.Row="2"
                                        MaxHeight="260"
                                        VerticalScrollBarVisibility="Auto">
                    <ItemsControl ItemsSource="{Binding TradeFilter.TradeTypeFiltersView}">
                      <ItemsControl.ItemTemplate>
                        <DataTemplate>
                          <CheckBox
                                                        Margin="4,4"
                                                        Content="{Binding Label}"
                                                        FontSize="{StaticResource FontSizeSm}"
                                                        Foreground="{DynamicResource AppTextPrimary}"
                                                        IsChecked="{Binding IsChecked, Mode=TwoWay}" />
                        </DataTemplate>
                      </ItemsControl.ItemTemplate>
                    </ItemsControl>
                  </ScrollViewer>
                </Grid>
              </Border>
            </Popup>
          </Grid>

          <!--  日期範圍 — 使用 DateRangePicker 單一控制項（雙月曆 popup + 範圍高亮）  -->
          <controls:DateRangePicker
                        Width="260"
                        Margin="8,0,0,0"
                        VerticalAlignment="Center"
                        DockPanel.Dock="Right"
                        EndDate="{Binding TradeFilter.TradeDateTo, Mode=TwoWay}"
                        Placeholder="{DynamicResource Portfolio.Filter.DateRangePlaceholder}"
                        StartDate="{Binding TradeFilter.TradeDateFrom, Mode=TwoWay}" />

          <!--  搜尋框（最後 = 吃剩餘空間，響應式填滿）  -->
          <controls:SearchBox
                        VerticalAlignment="Center"
                        IsInline="True"
                        Placeholder="{DynamicResource Portfolio.Filter.SearchTrades}"
                        Text="{Binding TradeFilter.TradeSearchText}" />
        </DockPanel>
      </ScrollViewer>
    </Border>

    <!--  Trade history DataGrid  -->
    <Grid Grid.Row="2">
      <ListBox
                Margin="12"
                Background="Transparent"
                BorderThickness="0"
                ItemContainerStyle="{x:Null}"
                ItemsSource="{Binding TradeFilter.TradesView}"
                ScrollViewer.HorizontalScrollBarVisibility="Disabled"
                ScrollViewer.VerticalScrollBarVisibility="Auto">
        <ListBox.Style>
          <Style TargetType="ListBox">
            <Setter Property="Visibility" Value="Collapsed" />
            <Style.Triggers>
              <DataTrigger Value="True">
                <DataTrigger.Binding>
                  <MultiBinding Converter="{StaticResource WidthScaleThresholdToBooleanConverter}" ConverterParameter="1120">
                    <Binding ElementName="Root" Path="ActualWidth" />
                    <Binding Path="DataContext.Settings.UiScale" RelativeSource="{RelativeSource AncestorType=Window}" />
                  </MultiBinding>
                </DataTrigger.Binding>
                <Setter Property="Visibility" Value="Visible" />
              </DataTrigger>
            </Style.Triggers>
          </Style>
        </ListBox.Style>
        <ListBox.ItemTemplate>
          <DataTemplate>
            <ui:Button
                            Margin="0,0,0,10"
                            Padding="0"
                            HorizontalContentAlignment="Stretch"
                            Background="Transparent"
                            BorderThickness="0"
                            Command="{Binding DataContext.Transaction.EditTradeCommand, RelativeSource={RelativeSource AncestorType=UserControl}}"
                            CommandParameter="{Binding}"
                            Appearance="Secondary">
              <ui:Card
                                Padding="14,12">
                <StackPanel>
                  <DockPanel LastChildFill="True">
                    <TextBlock
                                            DockPanel.Dock="Left"
                                            FontFamily="{StaticResource FontBase}" Typography.NumeralAlignment="Tabular"
                                            FontSize="{StaticResource FontSizeXs}"
                                            Foreground="{DynamicResource AppTextMuted}"
                                            Text="{Binding TradeDateLocal, StringFormat=yyyy/MM/dd HH:mm}" />
                    <Border
                                            Margin="8,0,0,0"
                                            Padding="6,2"
                                            Background="{Binding TypeBadgeColor, Converter={StaticResource HexToBrushConverter}}"
                                            CornerRadius="{StaticResource RadiusSm}"
                                            DockPanel.Dock="Right">
                      <TextBlock
                                                HorizontalAlignment="Center"
                                                FontSize="{StaticResource FontSizeXs}"
                                                FontWeight="SemiBold"
                                                Foreground="{DynamicResource AppTextOnAccent}"
                                                TextAlignment="Center"
                                                Text="{Binding Type, Converter={StaticResource TradeTypeConverter}}" />
                    </Border>
                    <TextBlock
                                            FontSize="{StaticResource FontSizeSm}"
                                            FontWeight="SemiBold"
                                            Foreground="{DynamicResource AppTextPrimary}"
                                            Text="{Binding DisplayAsset}"
                                            TextTrimming="CharacterEllipsis" />
                  </DockPanel>

                  <WrapPanel Margin="0,10,0,0" ItemWidth="150">
                    <StackPanel Margin="0,0,12,8">
                      <TextBlock
                                                FontSize="{StaticResource FontSizeXs}"
                                                Foreground="{DynamicResource AppTextMuted}"
                                                Text="{DynamicResource Portfolio.Shares}" />
                      <TextBlock
                                                FontFamily="{StaticResource FontBase}" Typography.NumeralAlignment="Tabular"
                                                FontSize="{StaticResource FontSizeSm}"
                                                Foreground="{DynamicResource AppTextSecondary}"
                                                Text="{Binding DisplayQuantityText}" />
                    </StackPanel>
                    <StackPanel Margin="0,0,12,8">
                      <TextBlock
                                                FontSize="{StaticResource FontSizeXs}"
                                                Foreground="{DynamicResource AppTextMuted}"
                                                Text="{DynamicResource Portfolio.TradeHistory.UnitPrice}" />
                      <TextBlock
                                                FontFamily="{StaticResource FontBase}" Typography.NumeralAlignment="Tabular"
                                                FontSize="{StaticResource FontSizeSm}"
                                                Foreground="{DynamicResource AppTextPrimary}"
                                                Text="{Binding Price, Converter={StaticResource CurrencyConverter}, ConverterParameter=price-dash}" />
                    </StackPanel>
                    <StackPanel Margin="0,0,12,8">
                      <TextBlock
                                                FontSize="{StaticResource FontSizeXs}"
                                                Foreground="{DynamicResource AppTextMuted}"
                                                Text="{DynamicResource Portfolio.TradeHistory.GrossAmount}" />
                      <TextBlock
                                                FontFamily="{StaticResource FontBase}" Typography.NumeralAlignment="Tabular"
                                                FontSize="{StaticResource FontSizeSm}"
                                                FontWeight="SemiBold"
                                                Text="{Binding TotalAmount, Converter={StaticResource CurrencyConverter}, ConverterParameter=signed-dash}">
                        <TextBlock.Style>
                          <Style TargetType="TextBlock">
                            <Setter Property="Foreground" Value="{DynamicResource AppDown}" />
                            <Style.Triggers>
                              <DataTrigger Binding="{Binding IsAmountPositive}" Value="True">
                                <Setter Property="Foreground" Value="{DynamicResource AppUp}" />
                              </DataTrigger>
                              <DataTrigger Binding="{Binding TotalAmount}" Value="0">
                                <Setter Property="Foreground" Value="{DynamicResource AppTextSecondary}" />
                              </DataTrigger>
                            </Style.Triggers>
                          </Style>
                        </TextBlock.Style>
                      </TextBlock>
                    </StackPanel>
                    <StackPanel Margin="0,0,12,8">
                      <TextBlock
                                                FontSize="{StaticResource FontSizeXs}"
                                                Foreground="{DynamicResource AppTextMuted}"
                                                Text="{DynamicResource Portfolio.TradeHistory.Commission}" />
                      <TextBlock
                                                FontFamily="{StaticResource FontBase}" Typography.NumeralAlignment="Tabular"
                                                FontSize="{StaticResource FontSizeSm}"
                                                Foreground="{DynamicResource AppTextSecondary}"
                                                Text="{Binding CommissionDisplay}" />
                    </StackPanel>
                  </WrapPanel>

                </StackPanel>
              </ui:Card>
            </ui:Button>
          </DataTemplate>
        </ListBox.ItemTemplate>
      </ListBox>

      <ui:DataGrid
                AlternationCount="2"
                AutoGenerateColumns="False"
                Background="{DynamicResource AppBackground}"
                BorderThickness="0"
                CanUserAddRows="False"
                CanUserDeleteRows="False"
                CanUserReorderColumns="False"
                CanUserResizeColumns="False"
                CanUserSortColumns="True"
                ColumnHeaderHeight="{StaticResource DataGridHeaderHeight}"
                EnableRowVirtualization="True"
                FontFamily="{StaticResource FontBase}"
                FontSize="{StaticResource FontSizeSm}"
                Foreground="{DynamicResource AppTextPrimary}"
                GridLinesVisibility="None"
                HeadersVisibility="Column"
                HorizontalScrollBarVisibility="Auto"
                IsReadOnly="True"
                ItemsSource="{Binding TradeFilter.TradesView}"
                RowHeight="{StaticResource DataGridRowHeight}"
                SelectionMode="Single"
                VirtualizingPanel.IsVirtualizing="True"
                VirtualizingPanel.VirtualizationMode="Recycling">
        <DataGrid.Style>
          <Style TargetType="DataGrid">
            <Setter Property="Visibility" Value="Visible" />
            <Style.Triggers>
              <DataTrigger Value="True">
                <DataTrigger.Binding>
                  <MultiBinding Converter="{StaticResource WidthScaleThresholdToBooleanConverter}" ConverterParameter="1120">
                    <Binding ElementName="Root" Path="ActualWidth" />
                    <Binding Path="DataContext.Settings.UiScale" RelativeSource="{RelativeSource AncestorType=Window}" />
                  </MultiBinding>
                </DataTrigger.Binding>
                <Setter Property="Visibility" Value="Collapsed" />
              </DataTrigger>
            </Style.Triggers>
          </Style>
        </DataGrid.Style>
        <DataGrid.ColumnHeaderStyle>
          <Style BasedOn="{StaticResource AppDataGridColHeader}" TargetType="DataGridColumnHeader" />
        </DataGrid.ColumnHeaderStyle>
        <DataGrid.CellStyle>
          <Style BasedOn="{StaticResource AppDataGridCell}" TargetType="DataGridCell" />
        </DataGrid.CellStyle>
        <DataGrid.RowStyle>
          <!--
                        EventSetter on DataGridRow is more reliable than DataGrid.MouseDoubleClick:
                        sender IS the row, so DataContext is always the trade item directly.
                    -->
          <Style BasedOn="{StaticResource AppDataGridRowSelectable}" TargetType="DataGridRow">
            <EventSetter Event="MouseLeftButtonUp" Handler="OnRowClick" />
          </Style>
        </DataGrid.RowStyle>
        <DataGrid.Columns>
          <!--  日期  -->
          <DataGridTemplateColumn
                        Width="175"
                        CanUserSort="True"
                        SortMemberPath="TradeDate">
            <DataGridTemplateColumn.Header>
              <TextBlock Text="{DynamicResource Portfolio.TradeHistory.Date}" />
            </DataGridTemplateColumn.Header>
            <DataGridTemplateColumn.CellTemplate>
              <DataTemplate>
                <TextBlock
                                    VerticalAlignment="Center"
                                    FontFamily="{StaticResource FontBase}" Typography.NumeralAlignment="Tabular"
                                    FontSize="{StaticResource FontSizeSm}"
                                    Foreground="{DynamicResource AppTextSecondary}"
                                    Text="{Binding TradeDateLocal, StringFormat=yyyy/MM/dd HH:mm}" />
              </DataTemplate>
            </DataGridTemplateColumn.CellTemplate>
          </DataGridTemplateColumn>

          <!--  資產（合併代號 + 名稱；股票顯示「名稱 (代號)」、其他類型顯示名稱即可）  -->
          <DataGridTextColumn
                        Width="*"
                        Binding="{Binding DisplayAsset}"
                        SortMemberPath="DisplayAsset">
            <DataGridTextColumn.Header>
              <TextBlock Text="{DynamicResource Common.Asset}" />
            </DataGridTextColumn.Header>
            <DataGridTextColumn.ElementStyle>
              <Style TargetType="TextBlock">
                <Setter Property="FontSize" Value="{StaticResource FontSizeSm}" />
                <Setter Property="Foreground" Value="{DynamicResource AppTextPrimary}" />
                <Setter Property="VerticalAlignment" Value="Center" />
                <Setter Property="TextTrimming" Value="CharacterEllipsis" />
              </Style>
            </DataGridTextColumn.ElementStyle>
          </DataGridTextColumn>

          <!--  買/賣  -->
          <DataGridTemplateColumn
                        Width="112"
                        CanUserSort="True"
                        SortMemberPath="Type">
            <DataGridTemplateColumn.Header>
              <TextBlock Text="{DynamicResource Portfolio.TradeHistory.Type}" />
            </DataGridTemplateColumn.Header>
            <DataGridTemplateColumn.CellTemplate>
              <DataTemplate>
                <Border
                                    Margin="4,4"
                                    MinWidth="64"
                                    Padding="7,1"
                                    HorizontalAlignment="Left"
                                    VerticalAlignment="Center"
                                    Background="{Binding TypeBadgeColor, Converter={StaticResource HexToBrushConverter}}"
                                    CornerRadius="{StaticResource RadiusSm}">
                  <TextBlock
                                        FontFamily="{StaticResource FontBase}"
                                        FontSize="{StaticResource FontSizeXs}"
                                        FontWeight="SemiBold"
                                        Foreground="{DynamicResource AppTextOnAccent}"
                                        HorizontalAlignment="Center"
                                        TextAlignment="Center"
                                        Text="{Binding Type, Converter={StaticResource TradeTypeConverter}}" />
                </Border>
              </DataTemplate>
            </DataGridTemplateColumn.CellTemplate>
          </DataGridTemplateColumn>

          <!--  單價（Buy/Sell/CashDiv = 每股成交價；其他類型 = —）  -->
          <DataGridTemplateColumn
                        Width="120"
                        CanUserSort="True"
                        SortMemberPath="Price">
            <DataGridTemplateColumn.HeaderStyle>
              <Style BasedOn="{StaticResource AppDataGridColHeader}" TargetType="DataGridColumnHeader">
                <Setter Property="HorizontalContentAlignment" Value="Right" />
              </Style>
            </DataGridTemplateColumn.HeaderStyle>
            <DataGridTemplateColumn.Header>
              <TextBlock Text="{DynamicResource Portfolio.TradeHistory.UnitPrice}" />
            </DataGridTemplateColumn.Header>
            <DataGridTemplateColumn.CellTemplate>
              <DataTemplate>
                <TextBlock
                                    HorizontalAlignment="Right"
                                    VerticalAlignment="Center"
                                    FontFamily="{StaticResource FontBase}" Typography.NumeralAlignment="Tabular"
                                    FontSize="{StaticResource FontSizeSm}"
                                    Foreground="{DynamicResource AppTextPrimary}"
                                    Text="{Binding Price, Converter={StaticResource CurrencyConverter}, ConverterParameter=price-dash}" />
              </DataTemplate>
            </DataGridTemplateColumn.CellTemplate>
          </DataGridTemplateColumn>

          <!--  股數（非股票交易顯示 —）  -->
          <DataGridTemplateColumn
                        Width="120"
                        CanUserSort="True"
                        SortMemberPath="Quantity">
            <DataGridTemplateColumn.HeaderStyle>
              <Style BasedOn="{StaticResource AppDataGridColHeader}" TargetType="DataGridColumnHeader">
                <Setter Property="HorizontalContentAlignment" Value="Right" />
              </Style>
            </DataGridTemplateColumn.HeaderStyle>
            <DataGridTemplateColumn.Header>
              <TextBlock Text="{DynamicResource Portfolio.Shares}" />
            </DataGridTemplateColumn.Header>
            <DataGridTemplateColumn.CellTemplate>
              <DataTemplate>
                <TextBlock
                                    HorizontalAlignment="Right"
                                    VerticalAlignment="Center"
                                    FontFamily="{StaticResource FontBase}" Typography.NumeralAlignment="Tabular"
                                    FontSize="{StaticResource FontSizeSm}"
                                    Foreground="{DynamicResource AppTextSecondary}"
                                    Text="{Binding DisplayQuantityText}" />
              </DataTemplate>
            </DataGridTemplateColumn.CellTemplate>
          </DataGridTemplateColumn>

          <!--  總額（實際現金流動；Buy = −(P×Q + 手續費)；Sell = +(P×Q − 手續費)；現金/借還 = ±CashAmount；StockDiv = —）  -->
          <DataGridTemplateColumn
                        Width="200"
                        CanUserSort="True"
                        SortMemberPath="TotalAmount">
            <DataGridTemplateColumn.HeaderStyle>
              <Style BasedOn="{StaticResource AppDataGridColHeader}" TargetType="DataGridColumnHeader">
                <Setter Property="HorizontalContentAlignment" Value="Right" />
              </Style>
            </DataGridTemplateColumn.HeaderStyle>
            <DataGridTemplateColumn.Header>
              <TextBlock Text="{DynamicResource Portfolio.TradeHistory.GrossAmount}" />
            </DataGridTemplateColumn.Header>
            <DataGridTemplateColumn.CellTemplate>
              <DataTemplate>
                <TextBlock
                                    HorizontalAlignment="Right"
                                    VerticalAlignment="Center"
                                    FontFamily="{StaticResource FontBase}" Typography.NumeralAlignment="Tabular"
                                    FontSize="{StaticResource FontSizeSm}"
                                    FontWeight="SemiBold"
                                    Text="{Binding TotalAmount, Converter={StaticResource CurrencyConverter}, ConverterParameter=signed-dash}">
                  <TextBlock.Style>
                    <Style BasedOn="{StaticResource {x:Type TextBlock}}" TargetType="TextBlock">
                      <Setter Property="Foreground" Value="{DynamicResource AppDown}" />
                      <Style.Triggers>
                        <DataTrigger Binding="{Binding IsAmountPositive}" Value="True">
                          <Setter Property="Foreground" Value="{DynamicResource AppUp}" />
                        </DataTrigger>
                        <!--  StockDividend / 零值：中性色，避免綠色 "—"  -->
                        <DataTrigger Binding="{Binding TotalAmount}" Value="0">
                          <Setter Property="Foreground" Value="{DynamicResource AppTextSecondary}" />
                        </DataTrigger>
                      </Style.Triggers>
                    </Style>
                  </TextBlock.Style>
                </TextBlock>
              </DataTemplate>
            </DataGridTemplateColumn.CellTemplate>
          </DataGridTemplateColumn>

          <!--  手續費（Buy/Sell: Commission 欄位；其他類型或 legacy = —）  -->
          <DataGridTemplateColumn
                        Width="150"
                        CanUserSort="True"
                        SortMemberPath="Commission">
            <DataGridTemplateColumn.HeaderStyle>
              <Style BasedOn="{StaticResource AppDataGridColHeader}" TargetType="DataGridColumnHeader">
                <Setter Property="HorizontalContentAlignment" Value="Right" />
              </Style>
            </DataGridTemplateColumn.HeaderStyle>
            <DataGridTemplateColumn.Header>
              <TextBlock Text="{DynamicResource Portfolio.TradeHistory.Commission}" />
            </DataGridTemplateColumn.Header>
            <DataGridTemplateColumn.CellTemplate>
              <DataTemplate>
                <TextBlock
                                    HorizontalAlignment="Right"
                                    VerticalAlignment="Center"
                                    FontFamily="{StaticResource FontBase}" Typography.NumeralAlignment="Tabular"
                                    FontSize="{StaticResource FontSizeSm}"
                                    Foreground="{DynamicResource AppTextSecondary}"
                                    Text="{Binding CommissionDisplay}" />
              </DataTemplate>
            </DataGridTemplateColumn.CellTemplate>
          </DataGridTemplateColumn>

        </DataGrid.Columns>
      </ui:DataGrid>

      <!--  Empty state  -->
      <Border Visibility="{Binding HasNoTrades, Converter={StaticResource BooleanToVisibilityConverter}}">
        <StackPanel
                    HorizontalAlignment="Center"
                    VerticalAlignment="Center"
                    Opacity="0.4">
          <TextBlock
                        Margin="0,0,0,8"
                        HorizontalAlignment="Center"
                        FontSize="{StaticResource FontSize2xl}"
                        Text="&#x1F4CB;" />
          <TextBlock
                        HorizontalAlignment="Center"
                        FontSize="{StaticResource FontSizeSm}"
                        Foreground="{DynamicResource AppTextSecondary}"
                        Text="{DynamicResource Portfolio.TradeHistory.Empty}" />
        </StackPanel>
      </Border>
    </Grid>

    <!--  Pagination bar  -->
    <Border
            Grid.Row="3"
            Padding="12,6"
            Background="{DynamicResource AppSurface}"
            BorderBrush="{DynamicResource AppBorder}"
            BorderThickness="0,1,0,0">
      <Grid>
        <DockPanel LastChildFill="False">
          <DockPanel.Visibility>
            <MultiBinding Converter="{StaticResource InverseWidthScaleThresholdToVisibilityConverter}" ConverterParameter="900">
              <Binding ElementName="Root" Path="ActualWidth" />
              <Binding Path="DataContext.Settings.UiScale" RelativeSource="{RelativeSource AncestorType=Window}" />
            </MultiBinding>
          </DockPanel.Visibility>
          <!--  Page size selector  -->
          <StackPanel
                        VerticalAlignment="Center"
                        DockPanel.Dock="Left"
                        Orientation="Horizontal">
            <ComboBox
                            Width="56"
                            Margin="0,0,8,0"
                            ItemsSource="{Binding TradeFilter.PageSizeOptions}"
                            SelectedItem="{Binding TradeFilter.TradePageSize, Mode=TwoWay}"
                            Style="{StaticResource FormComboBox}">
              <ComboBox.Resources>
                <Style BasedOn="{StaticResource FormComboBoxItem}" TargetType="ComboBoxItem" />
              </ComboBox.Resources>
            </ComboBox>
            <TextBlock
                            VerticalAlignment="Center"
                            FontSize="{StaticResource FontSizeXs}"
                            Foreground="{DynamicResource AppTextMuted}"
                            Text="{Binding TradeFilter.TradePageDisplay}" />
          </StackPanel>

          <!--  Page navigation — 頁碼按鈕清單 + 跳頁輸入  -->
          <StackPanel
                        VerticalAlignment="Center"
                        DockPanel.Dock="Right"
                        Orientation="Horizontal">
            <!--  上一頁 — 用 WPF-UI SymbolIcon (內建 Fluent Icons 字型，不依賴系統字型)  -->
            <ui:Button
                            Width="30"
                            Height="30"
                            Margin="0,0,4,0"
                            Padding="0"
                            Command="{Binding TradeFilter.TradePagePrevCommand}"
                            Appearance="Secondary"
            ToolTip="{DynamicResource Common.Previous}">
              <ui:SymbolIcon
                                Width="14"
                                Height="14"
                                FontSize="14"
                                Foreground="{DynamicResource AppTextSecondary}"
                                Symbol="ChevronLeft24" />
            </ui:Button>

            <!--  頁碼按鈕（動態生成，當前頁高亮；省略號為純顯示）  -->
            <ItemsControl VerticalAlignment="Center" ItemsSource="{Binding TradeFilter.TradePageNumbers}">
              <ItemsControl.ItemsPanel>
                <ItemsPanelTemplate>
                  <StackPanel Orientation="Horizontal" />
                </ItemsPanelTemplate>
              </ItemsControl.ItemsPanel>
              <ItemsControl.ItemTemplate>
                <DataTemplate>
                  <Grid Margin="2,0">
                    <!--  Ellipsis ("…") — 不可點擊  -->
                    <TextBlock
                                            MinWidth="28"
                                            VerticalAlignment="Center"
                                            FontFamily="{StaticResource FontBase}" Typography.NumeralAlignment="Tabular"
                                            FontSize="{StaticResource FontSizeSm}"
                                            Foreground="{DynamicResource AppTextMuted}"
                                            Text="…"
                                            TextAlignment="Center"
                                            Visibility="{Binding IsEllipsis, Converter={StaticResource BooleanToVisibilityConverter}}" />
                    <!--  頁碼按鈕 — 當前頁高亮；Padding=0 避免窄按鈕內容被切  -->
                    <ui:Button
                                            Height="30"
                                            MinWidth="30"
                                            Padding="4,0"
                                            Command="{Binding DataContext.TradeFilter.GoToPageCommand, RelativeSource={RelativeSource AncestorType=UserControl}}"
                                            CommandParameter="{Binding Number}"
                                            Content="{Binding Number}"
                                            FontFamily="{StaticResource FontBase}" Typography.NumeralAlignment="Tabular"
                                            FontSize="{StaticResource FontSizeSm}">
                      <ui:Button.Style>
                        <Style BasedOn="{StaticResource {x:Type ui:Button}}" TargetType="{x:Type ui:Button}">
                          <Setter Property="Appearance" Value="Secondary" />
                          <Setter Property="Visibility" Value="Visible" />
                          <Style.Triggers>
                            <DataTrigger Binding="{Binding IsEllipsis}" Value="True">
                              <Setter Property="Visibility" Value="Collapsed" />
                            </DataTrigger>
                            <DataTrigger Binding="{Binding IsCurrent}" Value="True">
                              <Setter Property="Appearance" Value="Primary" />
                              <Setter Property="FontWeight" Value="SemiBold" />
                            </DataTrigger>
                          </Style.Triggers>
                        </Style>
                      </ui:Button.Style>
                    </ui:Button>
                  </Grid>
                </DataTemplate>
              </ItemsControl.ItemTemplate>
            </ItemsControl>

            <!--  下一頁 — SymbolIcon 同上理由  -->
            <ui:Button
                            Width="30"
                            Height="30"
                            Margin="4,0,0,0"
                            Padding="0"
                            Command="{Binding TradeFilter.TradePageNextCommand}"
                            Appearance="Secondary"
            ToolTip="{DynamicResource Common.Next}">
              <ui:SymbolIcon
                                Width="14"
                                Height="14"
                                FontSize="14"
                                Foreground="{DynamicResource AppTextSecondary}"
                                Symbol="ChevronRight24" />
            </ui:Button>

            <!--  跳頁輸入：頁碼: [input] / total  -->
            <TextBlock
                            Margin="16,0,6,0"
                            VerticalAlignment="Center"
                            FontSize="{StaticResource FontSizeXs}"
                            Foreground="{DynamicResource AppTextMuted}"
                            Text="{DynamicResource Portfolio.Pagination.JumpTo}" />
            <ui:TextBox
                            Width="48"
                            Height="30"
                            Padding="4,0"
                            VerticalContentAlignment="Center"
                            FontFamily="{StaticResource FontBase}" Typography.NumeralAlignment="Tabular"
                            FontSize="{StaticResource FontSizeSm}"

                            Text="{Binding TradeFilter.TradeJumpPageInput, UpdateSourceTrigger=PropertyChanged}"
                            TextAlignment="Center">
              <TextBox.InputBindings>
                <KeyBinding Key="Enter" Command="{Binding TradeFilter.JumpToPageCommand}" />
              </TextBox.InputBindings>
            </ui:TextBox>
            <TextBlock
                            Margin="6,0,0,0"
                            VerticalAlignment="Center"
                            FontFamily="{StaticResource FontBase}" Typography.NumeralAlignment="Tabular"
                            FontSize="{StaticResource FontSizeXs}"
                            Foreground="{DynamicResource AppTextMuted}">
                            <Run Text="/" />
                            <Run Text="{Binding TradeFilter.TradeTotalPages, Mode=OneWay}" />
            </TextBlock>
          </StackPanel>
        </DockPanel>

        <StackPanel>
          <StackPanel.Visibility>
            <MultiBinding Converter="{StaticResource WidthScaleThresholdToVisibilityConverter}" ConverterParameter="900">
              <Binding ElementName="Root" Path="ActualWidth" />
              <Binding Path="DataContext.Settings.UiScale" RelativeSource="{RelativeSource AncestorType=Window}" />
            </MultiBinding>
          </StackPanel.Visibility>
          <StackPanel VerticalAlignment="Center" Orientation="Horizontal">
            <ComboBox
                            Width="56"
                            Margin="0,0,8,0"
                            ItemsSource="{Binding TradeFilter.PageSizeOptions}"
                            SelectedItem="{Binding TradeFilter.TradePageSize, Mode=TwoWay}"
                            Style="{StaticResource FormComboBox}">
              <ComboBox.Resources>
                <Style BasedOn="{StaticResource FormComboBoxItem}" TargetType="ComboBoxItem" />
              </ComboBox.Resources>
            </ComboBox>
            <TextBlock
                            VerticalAlignment="Center"
                            FontSize="{StaticResource FontSizeXs}"
                            Foreground="{DynamicResource AppTextMuted}"
                            Text="{Binding TradeFilter.TradePageDisplay}" />
          </StackPanel>

          <WrapPanel Margin="0,10,0,0" VerticalAlignment="Center">
            <ui:Button
                            Width="30"
                            Height="30"
                            Margin="0,0,4,4"
                            Padding="0"
                            Command="{Binding TradeFilter.TradePagePrevCommand}"
                            Appearance="Secondary"
            ToolTip="{DynamicResource Common.Previous}">
              <ui:SymbolIcon
                                Width="14"
                                Height="14"
                                FontSize="14"
                                Foreground="{DynamicResource AppTextSecondary}"
                                Symbol="ChevronLeft24" />
            </ui:Button>

            <ItemsControl VerticalAlignment="Center" ItemsSource="{Binding TradeFilter.TradePageNumbers}">
              <ItemsControl.ItemsPanel>
                <ItemsPanelTemplate>
                  <WrapPanel />
                </ItemsPanelTemplate>
              </ItemsControl.ItemsPanel>
              <ItemsControl.ItemTemplate>
                <DataTemplate>
                  <Grid Margin="2,0,2,4">
                    <TextBlock
                                            MinWidth="28"
                                            VerticalAlignment="Center"
                                            FontFamily="{StaticResource FontBase}" Typography.NumeralAlignment="Tabular"
                                            FontSize="{StaticResource FontSizeSm}"
                                            Foreground="{DynamicResource AppTextMuted}"
                                            Text="…"
                                            TextAlignment="Center"
                                            Visibility="{Binding IsEllipsis, Converter={StaticResource BooleanToVisibilityConverter}}" />
                    <ui:Button
                                            Height="30"
                                            MinWidth="30"
                                            Padding="4,0"
                                            Command="{Binding DataContext.TradeFilter.GoToPageCommand, RelativeSource={RelativeSource AncestorType=UserControl}}"
                                            CommandParameter="{Binding Number}"
                                            Content="{Binding Number}"
                                            FontFamily="{StaticResource FontBase}" Typography.NumeralAlignment="Tabular"
                                            FontSize="{StaticResource FontSizeSm}">
                      <ui:Button.Style>
                        <Style BasedOn="{StaticResource {x:Type ui:Button}}" TargetType="{x:Type ui:Button}">
                          <Setter Property="Appearance" Value="Secondary" />
                          <Setter Property="Visibility" Value="Visible" />
                          <Style.Triggers>
                            <DataTrigger Binding="{Binding IsEllipsis}" Value="True">
                              <Setter Property="Visibility" Value="Collapsed" />
                            </DataTrigger>
                            <DataTrigger Binding="{Binding IsCurrent}" Value="True">
                              <Setter Property="Appearance" Value="Primary" />
                              <Setter Property="FontWeight" Value="SemiBold" />
                            </DataTrigger>
                          </Style.Triggers>
                        </Style>
                      </ui:Button.Style>
                    </ui:Button>
                  </Grid>
                </DataTemplate>
              </ItemsControl.ItemTemplate>
            </ItemsControl>

            <ui:Button
                            Width="30"
                            Height="30"
                            Margin="4,0,0,4"
                            Padding="0"
                            Command="{Binding TradeFilter.TradePageNextCommand}"
                            Appearance="Secondary"
            ToolTip="{DynamicResource Common.Next}">
              <ui:SymbolIcon
                                Width="14"
                                Height="14"
                                FontSize="14"
                                Foreground="{DynamicResource AppTextSecondary}"
                                Symbol="ChevronRight24" />
            </ui:Button>

            <StackPanel
                            Margin="12,0,0,4"
                            VerticalAlignment="Center"
                            Orientation="Horizontal">
              <TextBlock
                                Margin="0,0,6,0"
                                VerticalAlignment="Center"
                                FontSize="{StaticResource FontSizeXs}"
                                Foreground="{DynamicResource AppTextMuted}"
                                Text="{DynamicResource Portfolio.Pagination.JumpTo}" />
              <ui:TextBox
                                Width="48"
                                Height="30"
                                Padding="4,0"
                                VerticalContentAlignment="Center"
                                FontFamily="{StaticResource FontBase}" Typography.NumeralAlignment="Tabular"
                                FontSize="{StaticResource FontSizeSm}"

                                Text="{Binding TradeFilter.TradeJumpPageInput, UpdateSourceTrigger=PropertyChanged}"
                                TextAlignment="Center">
                <TextBox.InputBindings>
                  <KeyBinding Key="Enter" Command="{Binding TradeFilter.JumpToPageCommand}" />
                </TextBox.InputBindings>
              </ui:TextBox>
              <TextBlock
                                Margin="6,0,0,0"
                                VerticalAlignment="Center"
                                FontFamily="{StaticResource FontBase}" Typography.NumeralAlignment="Tabular"
                                FontSize="{StaticResource FontSizeXs}"
                                Foreground="{DynamicResource AppTextMuted}">
                                <Run Text="/" />
                                <Run Text="{Binding TradeFilter.TradeTotalPages, Mode=OneWay}" />
              </TextBlock>
            </StackPanel>
          </WrapPanel>
        </StackPanel>
      </Grid>
    </Border>
  </Grid>
</UserControl>
