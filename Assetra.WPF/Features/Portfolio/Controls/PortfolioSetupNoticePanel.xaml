<UserControl
    x:Class="Assetra.WPF.Features.Portfolio.Controls.PortfolioSetupNoticePanel"
    xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
    xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
    xmlns:ui="http://schemas.lepo.co/wpfui/2022/xaml">
    <Border
        Padding="20,14"
        Background="{DynamicResource AppSurface}"
        BorderBrush="{DynamicResource AppBorder}"
        BorderThickness="0,0,0,1"
        Visibility="{Binding SetupNotice.HasSetupNotice, Converter={StaticResource BooleanToVisibilityConverter}}">
        <Grid>
            <Grid.ColumnDefinitions>
                <ColumnDefinition Width="*" />
                <ColumnDefinition Width="Auto" />
            </Grid.ColumnDefinitions>
            <StackPanel Grid.Column="0" VerticalAlignment="Center">
                <TextBlock
                    FontSize="{StaticResource FontSizeMd}"
                    FontWeight="SemiBold"
                    Foreground="{DynamicResource AppTextPrimary}"
                    Text="{Binding SetupNotice.Title}" />
                <TextBlock
                    Margin="0,4,0,0"
                    FontSize="{StaticResource FontSizeBase}"
                    Foreground="{DynamicResource AppTextSecondary}"
                    Text="{Binding SetupNotice.Message}"
                    TextWrapping="Wrap" />
            </StackPanel>
            <ui:Button
                Grid.Column="1"
                Margin="12,0,0,0"
                VerticalAlignment="Center"
                Command="{Binding SetupNotice.ExecuteCommand}"
                Content="{Binding SetupNotice.ActionText}"
                Appearance="Secondary" />
        </Grid>
    </Border>
</UserControl>
