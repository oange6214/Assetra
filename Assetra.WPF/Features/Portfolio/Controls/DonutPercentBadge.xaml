<UserControl
    x:Class="Assetra.WPF.Features.Portfolio.Controls.DonutPercentBadge"
    xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
    xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
    xmlns:d="http://schemas.microsoft.com/expression/blend/2008"
    xmlns:mc="http://schemas.openxmlformats.org/markup-compatibility/2006"
    x:Name="Root"
    Width="56"
    Height="56"
    mc:Ignorable="d">

    <!--
        P5.10 — Compact donut indicator: shows percentage as filled arc + text in center.
        P5.15 — Resized 44→56 to give "51.5%" 等 5-char text 足夠呼吸空間。

        Used at the front of Allocation list rows so users read
        「magnitude + asset identity + percent text」in a single glance.

        Implementation: two stroked Ellipses overlay.
          - Background ring = AppBorderLight, full stroke (visible portion + invisible gap)
          - Foreground arc = FillBrush, StrokeDashArray driven by Percent via converter
          - RotateTransform −90° rotates start point from 3 o'clock to 12 o'clock
          - StrokeDashCap=Round makes the arc's leading edge a smooth rounded tip

        P5.15c — User 反映 5-char (e.g. "61.9%") 文字仍貼 ring 邊。修法：
          ① stroke 4→3：環細一點，內部可用空間 +2px 各邊（共 +4px）
          ② 拿掉 TextBlock Margin="10,0"：原本想當 stroke buffer，但 TextBlock 在
             Grid HorizontalAlignment=Center 已自動依文字寬度置中，Margin 反而把
             BBox 強制縮成 36px 跟 35px 寬的文字 conflict。
          ③ ConverterParameter 重算：stroke 3 + 新 radius → 47.1

        Geometry (current 56 / margin=2 / stroke=3):
          - Ring outer diameter = 56 - 2*2 = 52
          - Ring centerline radius = 52/2 - 3/2 = 24.5
          - Circumference = 2π * 24.5 ≈ 153.9 px
          - StrokeDashArray param = 153.9 / 3 ≈ 47.1
          - 中央可放字直徑 = 56 - 2*2 (margin) - 2*3 (stroke) = 46 px
            「61.9%」at Font.Size.Sm (12) SemiBold ≈ 35px wide → ~5.5px 兩邊呼吸
    -->
    <Grid>
        <!--
            Background ring — P5.15d: AppBorderLight 在 dark theme 跟 cell bg 太接近
            幾乎隱形，user 看起來像 donut「分裂」。改用 AppBorder（darker, contrast 較高），
            背景環明顯可見、整個 donut 一眼就是完整圓形。
        -->
        <Ellipse
            Margin="2"
            Stroke="{DynamicResource AppBorder}"
            StrokeThickness="3" />

        <!--  Foreground arc  -->
        <Ellipse
            Margin="2"
            RenderTransformOrigin="0.5,0.5"
            Stroke="{Binding FillBrush, ElementName=Root}"
            StrokeDashArray="{Binding Percent, ElementName=Root, Converter={StaticResource PercentToDashArrayConverter}, ConverterParameter=47.1}"
            StrokeDashCap="Round"
            StrokeThickness="3">
            <Ellipse.RenderTransform>
                <RotateTransform Angle="-90" />
            </Ellipse.RenderTransform>
        </Ellipse>

        <!--  Center text — 無 Margin：TextBlock 在 Grid 內 HorizontalAlignment=Center 已用文字自然寬度置中  -->
        <TextBlock
            HorizontalAlignment="Center"
            VerticalAlignment="Center"
            FontFamily="{StaticResource Font.Family.Base}"
            FontSize="{StaticResource Font.Size.Sm}"
            FontWeight="SemiBold"
            Foreground="{DynamicResource AppTextPrimary}"
            Text="{Binding PercentText, ElementName=Root}"
            Typography.NumeralAlignment="Tabular" />
    </Grid>
</UserControl>
