<UserControl
    x:Class="Assetra.WPF.Features.Portfolio.Controls.AllocationMiniChart"
    xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
    xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
    xmlns:d="http://schemas.microsoft.com/expression/blend/2008"
    xmlns:lvc="clr-namespace:LiveChartsCore.SkiaSharpView.WPF;assembly=LiveChartsCore.SkiaSharpView.WPF"
    xmlns:mc="http://schemas.openxmlformats.org/markup-compatibility/2006"
    xmlns:vm="clr-namespace:Assetra.WPF.Features.Portfolio"
    d:DataContext="{d:DesignInstance Type={x:Type vm:PortfolioViewModel},
                                     IsDesignTimeCreatable=False}"
    mc:Ignorable="d">

    <Border
        Padding="16,8,16,10"
        Background="{DynamicResource AppSurface}"
        BorderBrush="{DynamicResource AppBorder}"
        BorderThickness="0,0,0,1"
        Visibility="{Binding IsMetricCardsExpanded, Converter={StaticResource BooleanToVisibilityConverter}}">

        <Grid MinHeight="100" MaxHeight="160">
            <Grid.ColumnDefinitions>
                <ColumnDefinition Width="Auto" />
                <ColumnDefinition Width="*" />
            </Grid.ColumnDefinitions>

            <!--  Donut chart — 正方形，高度自適應  -->
            <lvc:PieChart
                x:Name="Chart"
                Grid.Column="0"
                Width="{Binding ActualHeight, RelativeSource={RelativeSource Self}}"
                Margin="6"
                Background="Transparent"
                InitialRotation="-90"
                LegendPosition="Hidden"
                Series="{Binding Allocation.PieSeries}"
                TooltipPosition="Center"
                TooltipTextSize="11" />

            <!--  Legend  -->
            <ItemsControl
                Grid.Column="1"
                Margin="16,4,0,0"
                VerticalAlignment="Center"
                ItemsSource="{Binding Allocation.Slices}">
                <ItemsControl.ItemTemplate>
                    <DataTemplate>
                        <Grid Margin="0,2">
                            <Grid.ColumnDefinitions>
                                <ColumnDefinition Width="10" />
                                <ColumnDefinition Width="*" />
                                <ColumnDefinition Width="Auto" />
                                <ColumnDefinition Width="Auto" />
                            </Grid.ColumnDefinitions>

                            <!--  Color dot  -->
                            <Ellipse
                                Grid.Column="0"
                                Width="{StaticResource LegendDotSize}"
                                Height="{StaticResource LegendDotSize}"
                                VerticalAlignment="Center">
                                <Ellipse.Fill>
                                    <SolidColorBrush Color="{Binding ColorHex}" />
                                </Ellipse.Fill>
                            </Ellipse>

                            <!--  Label  -->
                            <TextBlock
                                Grid.Column="1"
                                Margin="8,0,12,0"
                                VerticalAlignment="Center"
                                FontSize="{StaticResource FontSizeSm}"
                                Foreground="{DynamicResource AppTextSecondary}"
                                Text="{Binding Label}" />

                            <!--  Percentage  -->
                            <TextBlock
                                Grid.Column="2"
                                Margin="0,0,8,0"
                                VerticalAlignment="Center"
                                FontFamily="{DynamicResource FontTabular}"
                                FontSize="{StaticResource FontSizeSm}"
                                FontWeight="SemiBold"
                                Foreground="{DynamicResource AppTextPrimary}"
                                Text="{Binding Percent, StringFormat={}{0:F1}%}" />

                            <!--  Market value  -->
                            <TextBlock
                                Grid.Column="3"
                                VerticalAlignment="Center"
                                FontFamily="{DynamicResource FontTabular}"
                                FontSize="{StaticResource FontSizeXs}"
                                Foreground="{DynamicResource AppTextMuted}"
                                Text="{Binding Value, StringFormat='NT\${0:N0}'}" />
                        </Grid>
                    </DataTemplate>
                </ItemsControl.ItemTemplate>
            </ItemsControl>

            <!--  Empty state  -->
            <TextBlock
                Grid.ColumnSpan="2"
                HorizontalAlignment="Center"
                VerticalAlignment="Center"
                FontSize="{StaticResource FontSizeSm}"
                Foreground="{DynamicResource AppTextMuted}"
                Text="{DynamicResource Portfolio.Allocation.Empty}"
                Visibility="{Binding Allocation.HasData, Converter={StaticResource InverseBooleanToVisibilityConverter}}" />
        </Grid>
    </Border>
</UserControl>
