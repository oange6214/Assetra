<UserControl
    x:Class="Assetra.WPF.Features.Portfolio.Controls.DividendCalendarPanel"
    xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
    xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
    xmlns:ui="http://schemas.lepo.co/wpfui/2022/xaml"
    xmlns:d="http://schemas.microsoft.com/expression/blend/2008"
    xmlns:mc="http://schemas.openxmlformats.org/markup-compatibility/2006"
    mc:Ignorable="d">

    <!--  DataContext = PortfolioViewModel, set by parent  -->

    <Border
        x:Name="RootBorder"
        Padding="16,4,16,8"
        Background="Transparent">
        <StackPanel>
            <!--  Title + year total + year navigation  -->
            <Grid Margin="0,0,0,10">
                <Grid.ColumnDefinitions>
                    <ColumnDefinition Width="Auto" />
                    <ColumnDefinition Width="Auto" />
                    <ColumnDefinition Width="Auto" />
                    <ColumnDefinition Width="*" />
                    <ColumnDefinition Width="Auto" />
                </Grid.ColumnDefinitions>

                <TextBlock
                    Grid.Column="0"
                    VerticalAlignment="Center"
                    FontSize="{StaticResource FontSizeSm}"
                    FontWeight="SemiBold"
                    Foreground="{DynamicResource AppTextPrimary}"
                    Text="{DynamicResource Portfolio.DivCalendar.Title}" />
                <TextBlock
                    Grid.Column="1"
                    Margin="10,0,0,0"
                    VerticalAlignment="Center"
                    FontFamily="{DynamicResource FontBase}" Typography.NumeralAlignment="Tabular"
                    FontSize="{StaticResource FontSizeSm}"
                    FontWeight="SemiBold"
                    Foreground="{DynamicResource AppAccent}"
                    Text="{Binding DivCalendar.Year}" />

                <!--  Year total  -->
                <TextBlock
                    x:Name="YearTotalText"
                    Grid.Column="2"
                    Margin="12,0,0,0"
                    VerticalAlignment="Center"
                    FontFamily="{DynamicResource FontBase}" Typography.NumeralAlignment="Tabular"
                    FontSize="{StaticResource FontSizeXs}"
                    Foreground="{DynamicResource AppUp}" />

                <StackPanel Grid.Column="4" Orientation="Horizontal">
                    <ui:Button
                        Width="24"
                        Height="24"
                        Margin="0,0,4,0"
                        Command="{Binding DivCalendar.PrevYearCommand}"
                        Appearance="Secondary">
                        <ui:SymbolIcon Symbol="ChevronLeft24" FontSize="10" Foreground="{DynamicResource AppTextSecondary}" />
                    </ui:Button>
                    <ui:Button
                        Width="24"
                        Height="24"
                        Command="{Binding DivCalendar.NextYearCommand}"
                        Appearance="Secondary">
                        <ui:SymbolIcon Symbol="ChevronRight24" FontSize="10" Foreground="{DynamicResource AppTextSecondary}" />
                    </ui:Button>
                </StackPanel>
            </Grid>

            <!--  4×3 month grid (populated by code-behind)  -->
            <UniformGrid
                x:Name="MonthGrid"
                Columns="4"
                Rows="3" />
        </StackPanel>
    </Border>
</UserControl>
