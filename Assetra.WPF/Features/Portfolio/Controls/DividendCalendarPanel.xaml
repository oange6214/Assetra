<UserControl
    x:Class="Assetra.WPF.Features.Portfolio.Controls.DividendCalendarPanel"
    xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
    xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
    xmlns:d="http://schemas.microsoft.com/expression/blend/2008"
    xmlns:mc="http://schemas.openxmlformats.org/markup-compatibility/2006"
    mc:Ignorable="d">

    <!--  DataContext = PortfolioViewModel, set by parent  -->

    <Border
        x:Name="RootBorder"
        Padding="16,4,16,8"
        Background="Transparent">
        <StackPanel>
            <!--  Title + year total + year navigation  -->
            <Grid Margin="0,0,0,10">
                <Grid.ColumnDefinitions>
                    <ColumnDefinition Width="Auto" />
                    <ColumnDefinition Width="Auto" />
                    <ColumnDefinition Width="Auto" />
                    <ColumnDefinition Width="*" />
                    <ColumnDefinition Width="Auto" />
                </Grid.ColumnDefinitions>

                <TextBlock
                    Grid.Column="0"
                    VerticalAlignment="Center"
                    FontSize="{StaticResource FontSizeSm}"
                    FontWeight="SemiBold"
                    Foreground="{DynamicResource AppTextPrimary}"
                    Text="{DynamicResource Portfolio.DivCalendar.Title}" />
                <TextBlock
                    Grid.Column="1"
                    Margin="10,0,0,0"
                    VerticalAlignment="Center"
                    FontFamily="{DynamicResource FontTabular}"
                    FontSize="{StaticResource FontSizeSm}"
                    FontWeight="SemiBold"
                    Foreground="{DynamicResource AppAccent}"
                    Text="{Binding DivCalendarYear}" />

                <!--  Year total  -->
                <TextBlock
                    x:Name="YearTotalText"
                    Grid.Column="2"
                    Margin="12,0,0,0"
                    VerticalAlignment="Center"
                    FontFamily="{DynamicResource FontTabular}"
                    FontSize="{StaticResource FontSizeXs}"
                    Foreground="{DynamicResource AppUp}" />

                <StackPanel Grid.Column="4" Orientation="Horizontal">
                    <Button
                        Width="24"
                        Height="24"
                        Margin="0,0,4,0"
                        Command="{Binding DivCalendarPrevYearCommand}"
                        Style="{StaticResource BtnGhost}">
                        <TextBlock
                            FontFamily="Segoe MDL2 Assets"
                            FontSize="10"
                            Foreground="{DynamicResource AppTextSecondary}"
                            Text="&#xE76B;" />
                    </Button>
                    <Button
                        Width="24"
                        Height="24"
                        Command="{Binding DivCalendarNextYearCommand}"
                        Style="{StaticResource BtnGhost}">
                        <TextBlock
                            FontFamily="Segoe MDL2 Assets"
                            FontSize="10"
                            Foreground="{DynamicResource AppTextSecondary}"
                            Text="&#xE76C;" />
                    </Button>
                </StackPanel>
            </Grid>

            <!--  4×3 month grid (populated by code-behind)  -->
            <UniformGrid
                x:Name="MonthGrid"
                Columns="4"
                Rows="3" />
        </StackPanel>
    </Border>
</UserControl>
