<UserControl
    x:Class="Assetra.WPF.Features.Portfolio.Controls.AddAssetDialog"
    xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
    xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
    xmlns:d="http://schemas.microsoft.com/expression/blend/2008"
    xmlns:mc="http://schemas.openxmlformats.org/markup-compatibility/2006"
    xmlns:vm="clr-namespace:Assetra.WPF.Features.Portfolio"
    d:DataContext="{d:DesignInstance Type={x:Type vm:PortfolioViewModel},
                                     IsDesignTimeCreatable=False}"
    Visibility="{Binding IsAddDialogOpen, Converter={StaticResource BooleanToVisibilityConverter}}"
    mc:Ignorable="d">

    <Grid>
        <!--  半透明背景幕  -->
        <Border Background="{DynamicResource AppModalOverlay}" />

        <!--  Dialog card  -->
        <Border
            Width="{StaticResource DialogWidth}"
            MaxHeight="{StaticResource DialogMaxHeight}"
            HorizontalAlignment="Center"
            VerticalAlignment="Center"
            Background="{DynamicResource AppSurface}"
            BorderBrush="{DynamicResource AppBorder}"
            BorderThickness="1"
            CornerRadius="{StaticResource RadiusMd}">
            <Grid>
                <Grid.RowDefinitions>
                    <RowDefinition Height="Auto" />
                    <!--  Title  -->
                    <RowDefinition Height="Auto" />
                    <!--  Type selector  -->
                    <RowDefinition Height="*" />
                    <!--  Fields  -->
                    <RowDefinition Height="Auto" />
                    <!--  Error  -->
                    <RowDefinition Height="Auto" />
                    <!--  Buttons  -->
                </Grid.RowDefinitions>

                <!--  Title  -->
                <Border
                    Grid.Row="0"
                    Padding="20,14"
                    BorderBrush="{DynamicResource AppBorder}"
                    BorderThickness="0,0,0,1">
                    <DockPanel>
                        <TextBlock
                            VerticalAlignment="Center"
                            FontSize="{StaticResource FontSizeSm}"
                            FontWeight="SemiBold"
                            Foreground="{DynamicResource AppTextPrimary}"
                            Text="{DynamicResource Portfolio.Account.Title}" />
                        <Button
                            Width="28"
                            Height="28"
                            HorizontalAlignment="Right"
                            Command="{Binding CloseAddDialogCommand}"
                            DockPanel.Dock="Right"
                            Style="{StaticResource BtnIcon}">
                            <TextBlock
                                FontFamily="Segoe MDL2 Assets"
                                FontSize="12"
                                Foreground="{DynamicResource AppTextMuted}"
                                Text="&#xE8BB;" />
                        </Button>
                    </DockPanel>
                </Border>

                <!--  Asset type selector (Cash only)  -->
                <StackPanel
                    Grid.Row="1"
                    Margin="20,14,20,0"
                    Orientation="Horizontal">
                    <RadioButton
                        Content="{DynamicResource Portfolio.Dialog.TypeCash}"
                        GroupName="AddType"
                        IsChecked="{Binding AddTypeIsAccount, Mode=TwoWay}"
                        Style="{StaticResource NavTabBtn}" />
                </StackPanel>

                <!--  Fields area (scrollable)  -->
                <ScrollViewer
                    Grid.Row="2"
                    Padding="20,16"
                    VerticalScrollBarVisibility="Auto">
                    <Grid>

                        <!--  Cash fields — 極簡：只收名稱，餘額由「存入/提款」交易累積  -->
                        <StackPanel Visibility="{Binding AddTypeIsAccount, Converter={StaticResource BooleanToVisibilityConverter}}">
                            <TextBlock
                                Margin="0,0,0,4"
                                FontSize="{StaticResource FontSizeXs}"
                                FontWeight="SemiBold"
                                Foreground="{DynamicResource AppTextSecondary}"
                                Text="{DynamicResource Portfolio.Cash.Name}" />
                            <TextBox
                                Margin="0,0,0,8"
                                Style="{StaticResource FormTextBox}"
                                Text="{Binding AddAccountName, UpdateSourceTrigger=PropertyChanged}" />

                            <TextBlock
                                FontSize="{StaticResource FontSizeXs}"
                                Foreground="{DynamicResource AppTextMuted}"
                                Text="{DynamicResource Portfolio.Cash.AddHint}"
                                TextWrapping="Wrap" />
                        </StackPanel>

                    </Grid>
                </ScrollViewer>

                <!--  Error  -->
                <TextBlock
                    Grid.Row="3"
                    Margin="20,8,20,0"
                    FontSize="{StaticResource FontSizeXs}"
                    Foreground="{DynamicResource AppDown}"
                    Text="{Binding AddError}"
                    Visibility="{Binding AddError, Converter={StaticResource StringToVisibilityConverter}}" />

                <!--  Footer  -->
                <Border
                    Grid.Row="4"
                    Padding="20,12"
                    BorderBrush="{DynamicResource AppBorder}"
                    BorderThickness="0,1,0,0">
                    <StackPanel HorizontalAlignment="Right" Orientation="Horizontal">
                        <Button
                            Height="30"
                            Margin="0,0,8,0"
                            Padding="14,0"
                            Command="{Binding CloseAddDialogCommand}"
                            Style="{StaticResource BtnGhost}">
                            <TextBlock Foreground="{DynamicResource AppTextSecondary}" Text="{DynamicResource Common.Cancel}" />
                        </Button>
                        <Button
                            Height="30"
                            Padding="14,0"
                            Command="{Binding ConfirmAddCommand}"
                            Style="{StaticResource BtnPrimary}">
                            <TextBlock Foreground="{Binding Foreground, RelativeSource={RelativeSource AncestorType=Button}}" Text="{DynamicResource Common.Confirm}" />
                        </Button>
                    </StackPanel>
                </Border>
            </Grid>
        </Border>
    </Grid>
</UserControl>
