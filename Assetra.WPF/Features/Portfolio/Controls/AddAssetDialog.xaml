<UserControl
    x:Name="Root"
    x:Class="Assetra.WPF.Features.Portfolio.Controls.AddAssetDialog"
    xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
    xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
    xmlns:assetSections="clr-namespace:Assetra.WPF.Features.Portfolio.Controls.AssetSections"
    xmlns:d="http://schemas.microsoft.com/expression/blend/2008"
    xmlns:mc="http://schemas.openxmlformats.org/markup-compatibility/2006"
    xmlns:vm="clr-namespace:Assetra.WPF.Features.Portfolio"
    d:DataContext="{d:DesignInstance Type={x:Type vm:PortfolioViewModel},
                                     IsDesignTimeCreatable=False}"
    Visibility="{Binding AddAssetDialog.IsAddDialogOpen, Converter={StaticResource BooleanToVisibilityConverter}}"
    mc:Ignorable="d">

    <Grid>
        <!--  半透明背景幕  -->
        <Border Background="{DynamicResource AppModalOverlay}" />

        <!--  Dialog card  -->
        <Border
            MaxHeight="{StaticResource DialogMaxHeight}"
            HorizontalAlignment="Center"
            VerticalAlignment="Center"
            Background="{DynamicResource AppSurface}"
            BorderBrush="{DynamicResource AppBorder}"
            BorderThickness="1"
            CornerRadius="{StaticResource RadiusMd}">
            <Border.Width>
                <MultiBinding Converter="{StaticResource AdaptivePanelWidthConverter}" ConverterParameter="0.62|400|560">
                    <Binding ElementName="Root" Path="ActualWidth" />
                    <Binding RelativeSource="{RelativeSource AncestorType=Window}" Path="DataContext.Settings.UiScale" />
                </MultiBinding>
            </Border.Width>
            <Grid>
                <Grid.RowDefinitions>
                    <RowDefinition Height="Auto" />
                    <!--  Title  -->
                    <RowDefinition Height="Auto" />
                    <!--  Type selector  -->
                    <RowDefinition Height="*" />
                    <!--  Fields  -->
                    <RowDefinition Height="Auto" />
                    <!--  Error  -->
                    <RowDefinition Height="Auto" />
                    <!--  Buttons  -->
                </Grid.RowDefinitions>

                <!--  Title  -->
                <Border
                    Grid.Row="0"
                    Padding="20,14"
                    BorderBrush="{DynamicResource AppBorder}"
                    BorderThickness="0,0,0,1">
                    <DockPanel>
                        <TextBlock
                            VerticalAlignment="Center"
                            FontSize="{StaticResource FontSizeSm}"
                            FontWeight="SemiBold"
                            Foreground="{DynamicResource AppTextPrimary}"
                            Text="{DynamicResource Portfolio.Account.Title}">
                            <TextBlock.Style>
                                <Style TargetType="TextBlock">
                                    <Setter Property="Text" Value="{DynamicResource Portfolio.Account.Title}" />
                                    <Style.Triggers>
                                        <DataTrigger Binding="{Binding AddAssetDialog.IsLiabilityDialogMode}" Value="True">
                                            <Setter Property="Text" Value="{DynamicResource Portfolio.Liability.Title}" />
                                        </DataTrigger>
                                    </Style.Triggers>
                                </Style>
                            </TextBlock.Style>
                        </TextBlock>
                        <Button
                            Width="28"
                            Height="28"
                            HorizontalAlignment="Right"
                            Command="{Binding AddAssetDialog.CloseAddDialogCommand}"
                            DockPanel.Dock="Right"
                            Style="{StaticResource BtnIcon}">
                            <TextBlock
                                FontFamily="Segoe MDL2 Assets"
                                FontSize="12"
                                Foreground="{DynamicResource AppTextMuted}"
                                Text="&#xE8BB;" />
                        </Button>
                    </DockPanel>
                </Border>

                <!--  Asset type selector (Cash only)  -->
                <StackPanel
                    Grid.Row="1"
                    Margin="20,14,20,0"
                    Orientation="Horizontal"
                    Visibility="{Binding AddAssetDialog.IsLiabilityDialogMode, Converter={StaticResource BooleanToVisibilityConverter}}">
                    <RadioButton
                        Content="{DynamicResource Portfolio.Dialog.TypeLoan}"
                        GroupName="AddType"
                        IsChecked="{Binding AddAssetDialog.AddTypeIsLoan, Mode=TwoWay}"
                        Style="{StaticResource NavTabBtn}" />
                    <RadioButton
                        Margin="8,0,0,0"
                        Content="{DynamicResource Portfolio.Dialog.TypeCreditCard}"
                        GroupName="AddType"
                        IsChecked="{Binding AddAssetDialog.AddTypeIsCreditCard, Mode=TwoWay}"
                        Style="{StaticResource NavTabBtn}" />
                </StackPanel>

                <!--  Fields area (scrollable)  -->
                <ScrollViewer
                    Grid.Row="2"
                    Padding="20,16"
                    VerticalScrollBarVisibility="Auto">
                    <Grid>
                        <assetSections:AccountCreateSection
                            DataContext="{Binding AddAssetDialog}"
                            Visibility="{Binding AddAssetDialog.AddTypeIsAccount, Converter={StaticResource BooleanToVisibilityConverter}}" />

                        <assetSections:LoanCreateSection
                            DataContext="{Binding AddAssetDialog}"
                            Visibility="{Binding AddAssetDialog.AddTypeIsLoan, Converter={StaticResource BooleanToVisibilityConverter}}" />

                        <assetSections:CreditCardCreateSection
                            DataContext="{Binding AddAssetDialog}"
                            Visibility="{Binding AddAssetDialog.AddTypeIsCreditCard, Converter={StaticResource BooleanToVisibilityConverter}}" />
                    </Grid>
                </ScrollViewer>

                <!--  Error  -->
                <TextBlock
                    Grid.Row="3"
                    Margin="20,8,20,0"
                    FontSize="{StaticResource FontSizeXs}"
                    Foreground="{DynamicResource AppDown}"
                    Text="{Binding AddAssetDialog.AddError}"
                    Visibility="{Binding AddAssetDialog.AddError, Converter={StaticResource StringToVisibilityConverter}}" />

                <!--  Footer  -->
                <Border
                    Grid.Row="4"
                    Padding="20,12"
                    BorderBrush="{DynamicResource AppBorder}"
                    BorderThickness="0,1,0,0">
                    <StackPanel HorizontalAlignment="Right" Orientation="Horizontal">
                        <Button
                            Height="30"
                            Margin="0,0,8,0"
                            Padding="14,0"
                            Command="{Binding AddAssetDialog.CloseAddDialogCommand}"
                            Style="{StaticResource BtnGhost}">
                            <TextBlock Foreground="{DynamicResource AppTextSecondary}" Text="{DynamicResource Common.Cancel}" />
                        </Button>
                        <Button
                            Height="30"
                            Padding="14,0"
                            Command="{Binding AddAssetDialog.ConfirmAddCommand}"
                            Style="{StaticResource BtnPrimary}">
                            <TextBlock Foreground="{Binding Foreground, RelativeSource={RelativeSource AncestorType=Button}}" Text="{DynamicResource Common.Confirm}" />
                        </Button>
                    </StackPanel>
                </Border>
            </Grid>
        </Border>
    </Grid>
</UserControl>
