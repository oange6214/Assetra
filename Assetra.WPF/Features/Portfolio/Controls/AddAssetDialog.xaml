<UserControl
    x:Name="Root"
    x:Class="Assetra.WPF.Features.Portfolio.Controls.AddAssetDialog"
    xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
    xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
    xmlns:assetSections="clr-namespace:Assetra.WPF.Features.Portfolio.Controls.AssetSections"
    xmlns:d="http://schemas.microsoft.com/expression/blend/2008"
    xmlns:mc="http://schemas.openxmlformats.org/markup-compatibility/2006"
    xmlns:vm="clr-namespace:Assetra.WPF.Features.Portfolio"
    d:DataContext="{d:DesignInstance Type={x:Type vm:PortfolioViewModel},
                                     IsDesignTimeCreatable=False}"
    Visibility="{Binding AddAssetDialog.IsAddDialogOpen, Converter={StaticResource BooleanToVisibilityConverter}}"
    mc:Ignorable="d">

    <Grid>
        <!--  半透明背景幕  -->
        <Border Background="{DynamicResource AppModalOverlay}" />

        <!--  Dialog card  -->
        <Border
            MaxHeight="{StaticResource DialogMaxHeight}"
            HorizontalAlignment="Center"
            VerticalAlignment="Center"
            Background="{DynamicResource AppSurface}"
            BorderBrush="{DynamicResource AppBorder}"
            BorderThickness="1"
            CornerRadius="{StaticResource RadiusMd}">
            <Border.Width>
                <MultiBinding Converter="{StaticResource AdaptivePanelWidthConverter}" ConverterParameter="0.62|400|560">
                    <Binding ElementName="Root" Path="ActualWidth" />
                    <Binding RelativeSource="{RelativeSource AncestorType=Window}" Path="DataContext.Settings.UiScale" />
                </MultiBinding>
            </Border.Width>
            <Grid>
                <Grid.RowDefinitions>
                    <RowDefinition Height="Auto" />
                    <!--  Title  -->
                    <RowDefinition Height="Auto" />
                    <!--  Type selector  -->
                    <RowDefinition Height="*" />
                    <!--  Fields  -->
                    <RowDefinition Height="Auto" />
                    <!--  Error  -->
                    <RowDefinition Height="Auto" />
                    <!--  Buttons  -->
                </Grid.RowDefinitions>

                <!--  Title  -->
                <Border
                    Grid.Row="0"
                    Padding="20,14"
                    BorderBrush="{DynamicResource AppBorder}"
                    BorderThickness="0,0,0,1">
                    <DockPanel>
                        <Button
                            Width="28"
                            Height="28"
                            Margin="0,0,8,0"
                            VerticalAlignment="Center"
                            Command="{Binding AddAssetDialog.BackToTypePickerCommand}"
                            DockPanel.Dock="Left"
                            Style="{StaticResource BtnIcon}"
                            ToolTip="{DynamicResource Common.Back}"
                            Visibility="{Binding AddAssetDialog.IsLiabilityFormStep, Converter={StaticResource BooleanToVisibilityConverter}}">
                            <TextBlock
                                FontFamily="Segoe MDL2 Assets"
                                FontSize="12"
                                Foreground="{DynamicResource AppTextMuted}"
                                Text="&#xE72B;" />
                        </Button>
                        <Button
                            Width="28"
                            Height="28"
                            HorizontalAlignment="Right"
                            Command="{Binding AddAssetDialog.CloseAddDialogCommand}"
                            DockPanel.Dock="Right"
                            Style="{StaticResource BtnIcon}">
                            <TextBlock
                                FontFamily="Segoe MDL2 Assets"
                                FontSize="12"
                                Foreground="{DynamicResource AppTextMuted}"
                                Text="&#xE8BB;" />
                        </Button>
                        <TextBlock
                            VerticalAlignment="Center"
                            FontSize="{StaticResource FontSizeSm}"
                            FontWeight="SemiBold"
                            Foreground="{DynamicResource AppTextPrimary}"
                            Text="{DynamicResource Portfolio.Account.Title}">
                            <TextBlock.Style>
                                <Style TargetType="TextBlock">
                                    <Setter Property="Text" Value="{DynamicResource Portfolio.Account.Title}" />
                                    <Style.Triggers>
                                        <DataTrigger Binding="{Binding AddAssetDialog.IsLiabilityDialogMode}" Value="True">
                                            <Setter Property="Text" Value="{DynamicResource Portfolio.Liability.Title}" />
                                        </DataTrigger>
                                    </Style.Triggers>
                                </Style>
                            </TextBlock.Style>
                        </TextBlock>
                    </DockPanel>
                </Border>

                <!--  Liability type picker (Step 1 — only shown when IsTypePickerStep)  -->
                <Grid
                    Grid.Row="1"
                    Grid.RowSpan="4"
                    Margin="20,18,20,18"
                    Visibility="{Binding AddAssetDialog.IsTypePickerStep, Converter={StaticResource BooleanToVisibilityConverter}}">
                    <Grid.RowDefinitions>
                        <RowDefinition Height="Auto" />
                        <RowDefinition Height="*" />
                    </Grid.RowDefinitions>
                    <TextBlock
                        Grid.Row="0"
                        Margin="0,0,0,12"
                        FontSize="{StaticResource FontSizeSm}"
                        FontWeight="SemiBold"
                        Foreground="{DynamicResource AppTextSecondary}"
                        Text="{DynamicResource Portfolio.Liability.PickType.Heading}" />
                    <UniformGrid
                        Grid.Row="1"
                        Columns="2"
                        Rows="1">
                        <!--  Card: 借款  -->
                        <Button
                            Margin="0,0,8,0"
                            Padding="16,18"
                            HorizontalContentAlignment="Stretch"
                            VerticalContentAlignment="Stretch"
                            Background="{DynamicResource AppBackground}"
                            BorderBrush="{DynamicResource AppBorder}"
                            BorderThickness="1"
                            Command="{Binding AddAssetDialog.SelectLiabilityTypeCommand}"
                            CommandParameter="loan"
                            Style="{StaticResource BtnGhost}">
                            <StackPanel HorizontalAlignment="Left">
                                <TextBlock
                                    Margin="0,0,0,8"
                                    FontSize="{StaticResource FontSize2xl}"
                                    Text="&#x1F3E6;" />
                                <TextBlock
                                    Margin="0,0,0,4"
                                    FontSize="{StaticResource FontSizeBase}"
                                    FontWeight="SemiBold"
                                    Foreground="{DynamicResource AppTextPrimary}"
                                    Text="{DynamicResource Portfolio.Dialog.TypeLoan}" />
                                <TextBlock
                                    FontSize="{StaticResource FontSizeXs}"
                                    Foreground="{DynamicResource AppTextMuted}"
                                    Text="{DynamicResource Portfolio.Liability.PickType.LoanDesc}"
                                    TextWrapping="Wrap" />
                            </StackPanel>
                        </Button>
                        <!--  Card: 信用卡  -->
                        <Button
                            Margin="8,0,0,0"
                            Padding="16,18"
                            HorizontalContentAlignment="Stretch"
                            VerticalContentAlignment="Stretch"
                            Background="{DynamicResource AppBackground}"
                            BorderBrush="{DynamicResource AppBorder}"
                            BorderThickness="1"
                            Command="{Binding AddAssetDialog.SelectLiabilityTypeCommand}"
                            CommandParameter="creditCard"
                            Style="{StaticResource BtnGhost}">
                            <StackPanel HorizontalAlignment="Left">
                                <TextBlock
                                    Margin="0,0,0,8"
                                    FontSize="{StaticResource FontSize2xl}"
                                    Text="&#x1F4B3;" />
                                <TextBlock
                                    Margin="0,0,0,4"
                                    FontSize="{StaticResource FontSizeBase}"
                                    FontWeight="SemiBold"
                                    Foreground="{DynamicResource AppTextPrimary}"
                                    Text="{DynamicResource Portfolio.Dialog.TypeCreditCard}" />
                                <TextBlock
                                    FontSize="{StaticResource FontSizeXs}"
                                    Foreground="{DynamicResource AppTextMuted}"
                                    Text="{DynamicResource Portfolio.Liability.PickType.CreditCardDesc}"
                                    TextWrapping="Wrap" />
                            </StackPanel>
                        </Button>
                    </UniformGrid>
                </Grid>

                <!--  Fields area (scrollable) — Step 2 / form step  -->
                <ScrollViewer
                    Grid.Row="2"
                    Padding="20,16"
                    VerticalScrollBarVisibility="Auto"
                    Visibility="{Binding AddAssetDialog.IsFormStep, Converter={StaticResource BooleanToVisibilityConverter}}">
                    <Grid>
                        <assetSections:AccountCreateSection
                            DataContext="{Binding AddAssetDialog}">
                            <assetSections:AccountCreateSection.Visibility>
                                <Binding ElementName="Root" Path="DataContext.AddAssetDialog.AddTypeIsAccount" Converter="{StaticResource BooleanToVisibilityConverter}" />
                            </assetSections:AccountCreateSection.Visibility>
                        </assetSections:AccountCreateSection>

                        <assetSections:LoanCreateSection
                            DataContext="{Binding AddAssetDialog}">
                            <assetSections:LoanCreateSection.Visibility>
                                <Binding ElementName="Root" Path="DataContext.AddAssetDialog.AddTypeIsLoan" Converter="{StaticResource BooleanToVisibilityConverter}" />
                            </assetSections:LoanCreateSection.Visibility>
                        </assetSections:LoanCreateSection>

                        <assetSections:CreditCardCreateSection
                            DataContext="{Binding AddAssetDialog}">
                            <assetSections:CreditCardCreateSection.Visibility>
                                <Binding ElementName="Root" Path="DataContext.AddAssetDialog.AddTypeIsCreditCard" Converter="{StaticResource BooleanToVisibilityConverter}" />
                            </assetSections:CreditCardCreateSection.Visibility>
                        </assetSections:CreditCardCreateSection>
                    </Grid>
                </ScrollViewer>

                <!--  Error (form step only)  -->
                <TextBlock
                    Grid.Row="3"
                    Margin="20,8,20,0"
                    FontSize="{StaticResource FontSizeXs}"
                    Foreground="{DynamicResource AppDown}"
                    Text="{Binding AddAssetDialog.AddError}">
                    <TextBlock.Style>
                        <Style TargetType="TextBlock">
                            <Setter Property="Visibility" Value="Collapsed" />
                            <Style.Triggers>
                                <MultiDataTrigger>
                                    <MultiDataTrigger.Conditions>
                                        <Condition Binding="{Binding AddAssetDialog.IsFormStep}" Value="True" />
                                    </MultiDataTrigger.Conditions>
                                    <Setter Property="Visibility" Value="{Binding AddAssetDialog.AddError, Converter={StaticResource StringToVisibilityConverter}}" />
                                </MultiDataTrigger>
                            </Style.Triggers>
                        </Style>
                    </TextBlock.Style>
                </TextBlock>

                <!--  Footer (form step only)  -->
                <Border
                    Grid.Row="4"
                    Padding="20,12"
                    BorderBrush="{DynamicResource AppBorder}"
                    BorderThickness="0,1,0,0"
                    Visibility="{Binding AddAssetDialog.IsFormStep, Converter={StaticResource BooleanToVisibilityConverter}}">
                    <StackPanel HorizontalAlignment="Right" Orientation="Horizontal">
                        <Button
                            Height="30"
                            Margin="0,0,8,0"
                            Padding="14,0"
                            Command="{Binding AddAssetDialog.CloseAddDialogCommand}"
                            Style="{StaticResource BtnGhost}">
                            <TextBlock Foreground="{DynamicResource AppTextSecondary}" Text="{DynamicResource Common.Cancel}" />
                        </Button>
                        <Button
                            Height="30"
                            Padding="14,0"
                            Command="{Binding AddAssetDialog.ConfirmAddCommand}"
                            Style="{StaticResource BtnPrimary}">
                            <TextBlock Foreground="{Binding Foreground, RelativeSource={RelativeSource AncestorType=Button}}" Text="{DynamicResource Common.Confirm}" />
                        </Button>
                    </StackPanel>
                </Border>
            </Grid>
        </Border>
    </Grid>
</UserControl>
