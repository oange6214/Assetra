<UserControl
    x:Class="Assetra.WPF.Features.Portfolio.Controls.AddAssetDialog"
    xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
    xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
    xmlns:assetSections="clr-namespace:Assetra.WPF.Features.Portfolio.Controls.AssetSections"
    xmlns:behaviors="clr-namespace:Assetra.WPF.Infrastructure.Behaviors"
    xmlns:d="http://schemas.microsoft.com/expression/blend/2008"
    xmlns:ds="clr-namespace:Assetra.WPF.DesignSystem.Controls"
    xmlns:mc="http://schemas.openxmlformats.org/markup-compatibility/2006"
    xmlns:vm="clr-namespace:Assetra.WPF.Features.Portfolio"
    x:Name="Root"
    d:DataContext="{d:DesignInstance Type={x:Type vm:PortfolioViewModel}}"
    Visibility="{Binding AddAssetDialog.IsAddDialogOpen, Converter={StaticResource BooleanToVisibilityConverter}}"
    mc:Ignorable="d">

    <Grid>
        <!--  半透明背景幕  -->
        <Grid Style="{StaticResource AppDialogOverlay}" />

        <!--  Dialog card  -->
        <Border
            MaxHeight="{StaticResource DialogMaxHeight}"
            Padding="0"
            HorizontalAlignment="Center"
            VerticalAlignment="Center"
            behaviors:EscapeKeyCommandBehavior.Command="{Binding AddAssetDialog.CloseAddDialogCommand}"
            Style="{StaticResource AppDialogShell}">
            <Border.Width>
                <MultiBinding Converter="{StaticResource AdaptivePanelWidthConverter}" ConverterParameter="0.62|400|560">
                    <Binding ElementName="Root" Path="ActualWidth" />
                    <Binding Path="DataContext.Settings.UiScale" RelativeSource="{RelativeSource AncestorType=Window}" />
                </MultiBinding>
            </Border.Width>
            <Grid>
                <Grid.RowDefinitions>
                    <RowDefinition Height="Auto" />
                    <!--  Title  -->
                    <RowDefinition Height="Auto" />
                    <!--  Type selector  -->
                    <RowDefinition Height="*" />
                    <!--  Fields  -->
                    <RowDefinition Height="Auto" />
                    <!--  Error  -->
                    <RowDefinition Height="Auto" />
                    <!--  Buttons  -->
                </Grid.RowDefinitions>

                <!--  Title  -->
                <Border
                    Grid.Row="0"
                    Padding="20,14"
                    BorderBrush="{DynamicResource AppBorder}"
                    BorderThickness="0,0,0,1">
                    <DockPanel>
                        <Button
                            Width="28"
                            Height="28"
                            Margin="0,0,8,0"
                            Padding="0"
                            VerticalAlignment="Center"
                            Command="{Binding AddAssetDialog.BackToTypePickerCommand}"
                            DockPanel.Dock="Left"
                            Style="{StaticResource AppIconButton}"
                            ToolTip="{DynamicResource Common.Back}"
                            Visibility="{Binding AddAssetDialog.IsLiabilityFormStep, Converter={StaticResource BooleanToVisibilityConverter}}">
                            <ds:AppIcon
                                FontSize="12"
                                Foreground="{DynamicResource AppTextMuted}"
                                Symbol="ChevronUp24" />
                        </Button>
                        <Button
                            Width="28"
                            Height="28"
                            Padding="0"
                            HorizontalAlignment="Right"
                            Command="{Binding AddAssetDialog.CloseAddDialogCommand}"
                            DockPanel.Dock="Right"
                            Style="{StaticResource AppIconButton}"
                            ToolTip="{DynamicResource Common.Close}">
                            <ds:AppIcon
                                FontSize="12"
                                Foreground="{DynamicResource AppTextMuted}"
                                Symbol="Dismiss24" />
                        </Button>
                        <TextBlock
                            VerticalAlignment="Center"
                            FontSize="{StaticResource Font.Size.Sm}"
                            FontWeight="SemiBold"
                            Foreground="{DynamicResource AppTextPrimary}"
                            Text="{DynamicResource Portfolio.Account.Title}">
                            <TextBlock.Style>
                                <Style TargetType="TextBlock">
                                    <Setter Property="Text" Value="{DynamicResource Portfolio.Account.Title}" />
                                    <Style.Triggers>
                                        <DataTrigger Binding="{Binding AddAssetDialog.IsLiabilityDialogMode}" Value="True">
                                            <Setter Property="Text" Value="{DynamicResource Portfolio.Liability.Title}" />
                                        </DataTrigger>
                                    </Style.Triggers>
                                </Style>
                            </TextBlock.Style>
                        </TextBlock>
                    </DockPanel>
                </Border>

                <!--  Type picker (Step 1 — only shown when IsTypePickerStep)  -->
                <Grid
                    Grid.Row="1"
                    Grid.RowSpan="4"
                    Margin="20,18,20,18"
                    Visibility="{Binding AddAssetDialog.IsTypePickerStep, Converter={StaticResource BooleanToVisibilityConverter}}">
                    <Grid.RowDefinitions>
                        <RowDefinition Height="Auto" />
                        <RowDefinition Height="*" />
                    </Grid.RowDefinitions>
                    <TextBlock
                        Grid.Row="0"
                        Margin="0,0,0,12"
                        FontSize="{StaticResource Font.Size.Sm}"
                        FontWeight="SemiBold"
                        Foreground="{DynamicResource AppTextSecondary}"
                        Text="{DynamicResource Portfolio.Liability.PickType.Heading}"
                        Visibility="{Binding AddAssetDialog.IsLiabilityDialogMode, Converter={StaticResource BooleanToVisibilityConverter}}" />
                    <TextBlock
                        Grid.Row="0"
                        Margin="0,0,0,12"
                        FontSize="{StaticResource Font.Size.Sm}"
                        FontWeight="SemiBold"
                        Foreground="{DynamicResource AppTextSecondary}"
                        Text="{DynamicResource Portfolio.Account.PickType.Heading}"
                        Visibility="{Binding AddAssetDialog.IsAccountDialogMode, Converter={StaticResource BooleanToVisibilityConverter}}" />
                    <UniformGrid
                        Grid.Row="1"
                        Columns="3"
                        Visibility="{Binding AddAssetDialog.IsLiabilityDialogMode, Converter={StaticResource BooleanToVisibilityConverter}}">
                        <!--  Card: 信用卡  -->
                        <Button
                            Margin="0,0,4,8"
                            Padding="14,16"
                            HorizontalContentAlignment="Stretch"
                            VerticalContentAlignment="Stretch"
                            Background="{DynamicResource AppBackground}"
                            BorderBrush="{DynamicResource AppBorder}"
                            BorderThickness="1"
                            Command="{Binding AddAssetDialog.SelectLiabilityTypeCommand}"
                            CommandParameter="creditCard:信用卡"
                            Style="{StaticResource AppSecondaryButton}">
                            <StackPanel HorizontalAlignment="Left">
                                <ds:AppIcon
                                    Margin="0,0,0,6"
                                    HorizontalAlignment="Left"
                                    FontSize="24"
                                    Foreground="{DynamicResource AppTextPrimary}"
                                    Symbol="CreditCardPerson24" />
                                <TextBlock
                                    FontSize="{StaticResource Font.Size.Base}"
                                    FontWeight="SemiBold"
                                    Foreground="{DynamicResource AppTextPrimary}"
                                    Text="{DynamicResource Portfolio.Liability.Preset.CreditCard}" />
                            </StackPanel>
                        </Button>
                        <!--  Card: 分期付款  -->
                        <Button
                            Margin="4,0,4,8"
                            Padding="14,16"
                            HorizontalContentAlignment="Stretch"
                            VerticalContentAlignment="Stretch"
                            Background="{DynamicResource AppBackground}"
                            BorderBrush="{DynamicResource AppBorder}"
                            BorderThickness="1"
                            Command="{Binding AddAssetDialog.SelectLiabilityTypeCommand}"
                            CommandParameter="creditCard:0% 分期"
                            Style="{StaticResource AppSecondaryButton}">
                            <StackPanel HorizontalAlignment="Left">
                                <ds:AppIcon
                                    Margin="0,0,0,6"
                                    HorizontalAlignment="Left"
                                    FontSize="24"
                                    Foreground="{DynamicResource AppTextPrimary}"
                                    Symbol="CalendarMonth24" />
                                <TextBlock
                                    FontSize="{StaticResource Font.Size.Base}"
                                    FontWeight="SemiBold"
                                    Foreground="{DynamicResource AppTextPrimary}"
                                    Text="{DynamicResource Portfolio.Liability.Preset.Installment}" />
                            </StackPanel>
                        </Button>
                        <!--  Card: 預借現金  -->
                        <Button
                            Margin="4,0,0,8"
                            Padding="14,16"
                            HorizontalContentAlignment="Stretch"
                            VerticalContentAlignment="Stretch"
                            Background="{DynamicResource AppBackground}"
                            BorderBrush="{DynamicResource AppBorder}"
                            BorderThickness="1"
                            Command="{Binding AddAssetDialog.SelectLiabilityTypeCommand}"
                            CommandParameter="creditCard:預借現金"
                            Style="{StaticResource AppSecondaryButton}">
                            <StackPanel HorizontalAlignment="Left">
                                <ds:AppIcon
                                    Margin="0,0,0,6"
                                    HorizontalAlignment="Left"
                                    FontSize="24"
                                    Foreground="{DynamicResource AppTextPrimary}"
                                    Symbol="MoneyHand24" />
                                <TextBlock
                                    FontSize="{StaticResource Font.Size.Base}"
                                    FontWeight="SemiBold"
                                    Foreground="{DynamicResource AppTextPrimary}"
                                    Text="{DynamicResource Portfolio.Liability.Preset.CashAdvance}" />
                            </StackPanel>
                        </Button>
                        <!--  Card: 房屋貸款  -->
                        <Button
                            Margin="0,0,4,8"
                            Padding="14,16"
                            HorizontalContentAlignment="Stretch"
                            VerticalContentAlignment="Stretch"
                            Background="{DynamicResource AppBackground}"
                            BorderBrush="{DynamicResource AppBorder}"
                            BorderThickness="1"
                            Command="{Binding AddAssetDialog.SelectLiabilityTypeCommand}"
                            CommandParameter="loan:房貸"
                            Style="{StaticResource AppSecondaryButton}">
                            <StackPanel HorizontalAlignment="Left">
                                <ds:AppIcon
                                    Margin="0,0,0,6"
                                    HorizontalAlignment="Left"
                                    FontSize="24"
                                    Foreground="{DynamicResource AppTextPrimary}"
                                    Symbol="Home24" />
                                <TextBlock
                                    FontSize="{StaticResource Font.Size.Base}"
                                    FontWeight="SemiBold"
                                    Foreground="{DynamicResource AppTextPrimary}"
                                    Text="{DynamicResource Portfolio.Liability.Preset.Mortgage}" />
                            </StackPanel>
                        </Button>
                        <!--  Card: 車輛貸款  -->
                        <Button
                            Margin="4,0,4,8"
                            Padding="14,16"
                            HorizontalContentAlignment="Stretch"
                            VerticalContentAlignment="Stretch"
                            Background="{DynamicResource AppBackground}"
                            BorderBrush="{DynamicResource AppBorder}"
                            BorderThickness="1"
                            Command="{Binding AddAssetDialog.SelectLiabilityTypeCommand}"
                            CommandParameter="loan:車貸"
                            Style="{StaticResource AppSecondaryButton}">
                            <StackPanel HorizontalAlignment="Left">
                                <ds:AppIcon
                                    Margin="0,0,0,6"
                                    HorizontalAlignment="Left"
                                    FontSize="24"
                                    Foreground="{DynamicResource AppTextPrimary}"
                                    Symbol="VehicleCar24" />
                                <TextBlock
                                    FontSize="{StaticResource Font.Size.Base}"
                                    FontWeight="SemiBold"
                                    Foreground="{DynamicResource AppTextPrimary}"
                                    Text="{DynamicResource Portfolio.Liability.Preset.CarLoan}" />
                            </StackPanel>
                        </Button>
                        <!--  Card: 助學貸款  -->
                        <Button
                            Margin="4,0,0,8"
                            Padding="14,16"
                            HorizontalContentAlignment="Stretch"
                            VerticalContentAlignment="Stretch"
                            Background="{DynamicResource AppBackground}"
                            BorderBrush="{DynamicResource AppBorder}"
                            BorderThickness="1"
                            Command="{Binding AddAssetDialog.SelectLiabilityTypeCommand}"
                            CommandParameter="loan:學貸"
                            Style="{StaticResource AppSecondaryButton}">
                            <StackPanel HorizontalAlignment="Left">
                                <ds:AppIcon
                                    Margin="0,0,0,6"
                                    HorizontalAlignment="Left"
                                    FontSize="24"
                                    Foreground="{DynamicResource AppTextPrimary}"
                                    Symbol="HatGraduation24" />
                                <TextBlock
                                    FontSize="{StaticResource Font.Size.Base}"
                                    FontWeight="SemiBold"
                                    Foreground="{DynamicResource AppTextPrimary}"
                                    Text="{DynamicResource Portfolio.Liability.Preset.StudentLoan}" />
                            </StackPanel>
                        </Button>
                        <!--  Card: 信用貸款  -->
                        <Button
                            Margin="0,0,4,0"
                            Padding="14,16"
                            HorizontalContentAlignment="Stretch"
                            VerticalContentAlignment="Stretch"
                            Background="{DynamicResource AppBackground}"
                            BorderBrush="{DynamicResource AppBorder}"
                            BorderThickness="1"
                            Command="{Binding AddAssetDialog.SelectLiabilityTypeCommand}"
                            CommandParameter="loan:信貸"
                            Style="{StaticResource AppSecondaryButton}">
                            <StackPanel HorizontalAlignment="Left">
                                <ds:AppIcon
                                    Margin="0,0,0,6"
                                    HorizontalAlignment="Left"
                                    FontSize="24"
                                    Foreground="{DynamicResource AppTextPrimary}"
                                    Symbol="Money24" />
                                <TextBlock
                                    FontSize="{StaticResource Font.Size.Base}"
                                    FontWeight="SemiBold"
                                    Foreground="{DynamicResource AppTextPrimary}"
                                    Text="{DynamicResource Portfolio.Liability.Preset.PersonalLoan}" />
                            </StackPanel>
                        </Button>
                        <!--  Card: 親友借款  -->
                        <Button
                            Margin="4,0,4,0"
                            Padding="14,16"
                            HorizontalContentAlignment="Stretch"
                            VerticalContentAlignment="Stretch"
                            Background="{DynamicResource AppBackground}"
                            BorderBrush="{DynamicResource AppBorder}"
                            BorderThickness="1"
                            Command="{Binding AddAssetDialog.SelectLiabilityTypeCommand}"
                            CommandParameter="loan:親友借款"
                            Style="{StaticResource AppSecondaryButton}">
                            <StackPanel HorizontalAlignment="Left">
                                <ds:AppIcon
                                    Margin="0,0,0,6"
                                    HorizontalAlignment="Left"
                                    FontSize="24"
                                    Foreground="{DynamicResource AppTextPrimary}"
                                    Symbol="People24" />
                                <TextBlock
                                    FontSize="{StaticResource Font.Size.Base}"
                                    FontWeight="SemiBold"
                                    Foreground="{DynamicResource AppTextPrimary}"
                                    Text="{DynamicResource Portfolio.Liability.Preset.FriendLoan}" />
                            </StackPanel>
                        </Button>
                        <!--  Card: 自訂  -->
                        <Button
                            Margin="4,0,0,0"
                            Padding="14,16"
                            HorizontalContentAlignment="Stretch"
                            VerticalContentAlignment="Stretch"
                            Background="{DynamicResource AppBackground}"
                            BorderBrush="{DynamicResource AppBorder}"
                            BorderThickness="1"
                            Command="{Binding AddAssetDialog.SelectLiabilityTypeCommand}"
                            CommandParameter="loan"
                            Style="{StaticResource AppSecondaryButton}">
                            <StackPanel HorizontalAlignment="Left">
                                <ds:AppIcon
                                    Margin="0,0,0,6"
                                    HorizontalAlignment="Left"
                                    FontSize="24"
                                    Foreground="{DynamicResource AppTextPrimary}"
                                    Symbol="Add24" />
                                <TextBlock
                                    FontSize="{StaticResource Font.Size.Base}"
                                    FontWeight="SemiBold"
                                    Foreground="{DynamicResource AppTextPrimary}"
                                    Text="{DynamicResource Portfolio.Liability.Preset.Custom}" />
                            </StackPanel>
                        </Button>
                    </UniformGrid>
                    <!--  Account preset picker (mode=account)  -->
                    <UniformGrid
                        Grid.Row="1"
                        Columns="3"
                        Visibility="{Binding AddAssetDialog.IsAccountDialogMode, Converter={StaticResource BooleanToVisibilityConverter}}">
                        <Button
                            Margin="0,0,4,8"
                            Padding="14,16"
                            HorizontalContentAlignment="Stretch"
                            VerticalContentAlignment="Stretch"
                            Background="{DynamicResource AppBackground}"
                            BorderBrush="{DynamicResource AppBorder}"
                            BorderThickness="1"
                            Command="{Binding AddAssetDialog.SelectLiabilityTypeCommand}"
                            CommandParameter="cash:手邊現金"
                            Style="{StaticResource AppSecondaryButton}">
                            <StackPanel HorizontalAlignment="Left">
                                <ds:AppIcon
                                    Margin="0,0,0,6"
                                    HorizontalAlignment="Left"
                                    FontSize="24"
                                    Foreground="{DynamicResource AppTextPrimary}"
                                    Symbol="Wallet24" />
                                <TextBlock
                                    FontSize="{StaticResource Font.Size.Base}"
                                    FontWeight="SemiBold"
                                    Foreground="{DynamicResource AppTextPrimary}"
                                    Text="{DynamicResource Portfolio.Account.Preset.Cash}" />
                            </StackPanel>
                        </Button>
                        <Button
                            Margin="4,0,4,8"
                            Padding="14,16"
                            HorizontalContentAlignment="Stretch"
                            VerticalContentAlignment="Stretch"
                            Background="{DynamicResource AppBackground}"
                            BorderBrush="{DynamicResource AppBorder}"
                            BorderThickness="1"
                            Command="{Binding AddAssetDialog.SelectLiabilityTypeCommand}"
                            CommandParameter="cash:銀行活存"
                            Style="{StaticResource AppSecondaryButton}">
                            <StackPanel HorizontalAlignment="Left">
                                <ds:AppIcon
                                    Margin="0,0,0,6"
                                    HorizontalAlignment="Left"
                                    FontSize="24"
                                    Foreground="{DynamicResource AppTextPrimary}"
                                    Symbol="BuildingBank24" />
                                <TextBlock
                                    FontSize="{StaticResource Font.Size.Base}"
                                    FontWeight="SemiBold"
                                    Foreground="{DynamicResource AppTextPrimary}"
                                    Text="{DynamicResource Portfolio.Account.Preset.Bank}" />
                            </StackPanel>
                        </Button>
                        <Button
                            Margin="4,0,0,8"
                            Padding="14,16"
                            HorizontalContentAlignment="Stretch"
                            VerticalContentAlignment="Stretch"
                            Background="{DynamicResource AppBackground}"
                            BorderBrush="{DynamicResource AppBorder}"
                            BorderThickness="1"
                            Command="{Binding AddAssetDialog.SelectLiabilityTypeCommand}"
                            CommandParameter="cash:數位活存"
                            Style="{StaticResource AppSecondaryButton}">
                            <StackPanel HorizontalAlignment="Left">
                                <ds:AppIcon
                                    Margin="0,0,0,6"
                                    HorizontalAlignment="Left"
                                    FontSize="24"
                                    Foreground="{DynamicResource AppTextPrimary}"
                                    Symbol="PhoneLaptop24" />
                                <TextBlock
                                    FontSize="{StaticResource Font.Size.Base}"
                                    FontWeight="SemiBold"
                                    Foreground="{DynamicResource AppTextPrimary}"
                                    Text="{DynamicResource Portfolio.Account.Preset.Digital}" />
                            </StackPanel>
                        </Button>
                        <Button
                            Margin="0,0,4,8"
                            Padding="14,16"
                            HorizontalContentAlignment="Stretch"
                            VerticalContentAlignment="Stretch"
                            Background="{DynamicResource AppBackground}"
                            BorderBrush="{DynamicResource AppBorder}"
                            BorderThickness="1"
                            Command="{Binding AddAssetDialog.SelectLiabilityTypeCommand}"
                            CommandParameter="cash:定存"
                            Style="{StaticResource AppSecondaryButton}">
                            <StackPanel HorizontalAlignment="Left">
                                <ds:AppIcon
                                    Margin="0,0,0,6"
                                    HorizontalAlignment="Left"
                                    FontSize="24"
                                    Foreground="{DynamicResource AppTextPrimary}"
                                    Symbol="LockClosed24" />
                                <TextBlock
                                    FontSize="{StaticResource Font.Size.Base}"
                                    FontWeight="SemiBold"
                                    Foreground="{DynamicResource AppTextPrimary}"
                                    Text="{DynamicResource Portfolio.Account.Preset.TimeDeposit}" />
                            </StackPanel>
                        </Button>
                        <Button
                            Margin="4,0,4,8"
                            Padding="14,16"
                            HorizontalContentAlignment="Stretch"
                            VerticalContentAlignment="Stretch"
                            Background="{DynamicResource AppBackground}"
                            BorderBrush="{DynamicResource AppBorder}"
                            BorderThickness="1"
                            Command="{Binding AddAssetDialog.SelectLiabilityTypeCommand}"
                            CommandParameter="cash:外幣活存"
                            Style="{StaticResource AppSecondaryButton}">
                            <StackPanel HorizontalAlignment="Left">
                                <ds:AppIcon
                                    Margin="0,0,0,6"
                                    HorizontalAlignment="Left"
                                    FontSize="24"
                                    Foreground="{DynamicResource AppTextPrimary}"
                                    Symbol="ArrowSwap24" />
                                <TextBlock
                                    FontSize="{StaticResource Font.Size.Base}"
                                    FontWeight="SemiBold"
                                    Foreground="{DynamicResource AppTextPrimary}"
                                    Text="{DynamicResource Portfolio.Account.Preset.Foreign}" />
                            </StackPanel>
                        </Button>
                        <Button
                            Margin="4,0,0,8"
                            Padding="14,16"
                            HorizontalContentAlignment="Stretch"
                            VerticalContentAlignment="Stretch"
                            Background="{DynamicResource AppBackground}"
                            BorderBrush="{DynamicResource AppBorder}"
                            BorderThickness="1"
                            Command="{Binding AddAssetDialog.SelectLiabilityTypeCommand}"
                            CommandParameter="cash:交割戶"
                            Style="{StaticResource AppSecondaryButton}">
                            <StackPanel HorizontalAlignment="Left">
                                <ds:AppIcon
                                    Margin="0,0,0,6"
                                    HorizontalAlignment="Left"
                                    FontSize="24"
                                    Foreground="{DynamicResource AppTextPrimary}"
                                    Symbol="ArrowTrendingLines24" />
                                <TextBlock
                                    FontSize="{StaticResource Font.Size.Base}"
                                    FontWeight="SemiBold"
                                    Foreground="{DynamicResource AppTextPrimary}"
                                    Text="{DynamicResource Portfolio.Account.Preset.Brokerage}" />
                            </StackPanel>
                        </Button>
                        <Button
                            Margin="0,0,4,0"
                            Padding="14,16"
                            HorizontalContentAlignment="Stretch"
                            VerticalContentAlignment="Stretch"
                            Background="{DynamicResource AppBackground}"
                            BorderBrush="{DynamicResource AppBorder}"
                            BorderThickness="1"
                            Command="{Binding AddAssetDialog.SelectLiabilityTypeCommand}"
                            CommandParameter="cash:電子支付"
                            Style="{StaticResource AppSecondaryButton}">
                            <StackPanel HorizontalAlignment="Left">
                                <ds:AppIcon
                                    Margin="0,0,0,6"
                                    HorizontalAlignment="Left"
                                    FontSize="24"
                                    Foreground="{DynamicResource AppTextPrimary}"
                                    Symbol="WalletCreditCard24" />
                                <TextBlock
                                    FontSize="{StaticResource Font.Size.Base}"
                                    FontWeight="SemiBold"
                                    Foreground="{DynamicResource AppTextPrimary}"
                                    Text="{DynamicResource Portfolio.Account.Preset.EWallet}" />
                            </StackPanel>
                        </Button>
                        <Button
                            Margin="4,0,4,0"
                            Padding="14,16"
                            HorizontalContentAlignment="Stretch"
                            VerticalContentAlignment="Stretch"
                            Background="{DynamicResource AppBackground}"
                            BorderBrush="{DynamicResource AppBorder}"
                            BorderThickness="1"
                            Command="{Binding AddAssetDialog.SelectLiabilityTypeCommand}"
                            CommandParameter="cash:儲值卡"
                            Style="{StaticResource AppSecondaryButton}">
                            <StackPanel HorizontalAlignment="Left">
                                <ds:AppIcon
                                    Margin="0,0,0,6"
                                    HorizontalAlignment="Left"
                                    FontSize="24"
                                    Foreground="{DynamicResource AppTextPrimary}"
                                    Symbol="Gift24" />
                                <TextBlock
                                    FontSize="{StaticResource Font.Size.Base}"
                                    FontWeight="SemiBold"
                                    Foreground="{DynamicResource AppTextPrimary}"
                                    Text="{DynamicResource Portfolio.Account.Preset.PrepaidCard}" />
                            </StackPanel>
                        </Button>
                        <Button
                            Margin="4,0,0,0"
                            Padding="14,16"
                            HorizontalContentAlignment="Stretch"
                            VerticalContentAlignment="Stretch"
                            Background="{DynamicResource AppBackground}"
                            BorderBrush="{DynamicResource AppBorder}"
                            BorderThickness="1"
                            Command="{Binding AddAssetDialog.SelectLiabilityTypeCommand}"
                            CommandParameter="cash"
                            Style="{StaticResource AppSecondaryButton}">
                            <StackPanel HorizontalAlignment="Left">
                                <ds:AppIcon
                                    Margin="0,0,0,6"
                                    HorizontalAlignment="Left"
                                    FontSize="24"
                                    Foreground="{DynamicResource AppTextPrimary}"
                                    Symbol="Add24" />
                                <TextBlock
                                    FontSize="{StaticResource Font.Size.Base}"
                                    FontWeight="SemiBold"
                                    Foreground="{DynamicResource AppTextPrimary}"
                                    Text="{DynamicResource Portfolio.Account.Preset.Custom}" />
                            </StackPanel>
                        </Button>
                    </UniformGrid>
                </Grid>

                <!--  Fields area (scrollable) — Step 2 / form step  -->
                <ScrollViewer
                    Grid.Row="2"
                    Padding="20,16"
                    VerticalScrollBarVisibility="Auto"
                    Visibility="{Binding AddAssetDialog.IsFormStep, Converter={StaticResource BooleanToVisibilityConverter}}">
                    <Grid>
                        <assetSections:AccountCreateSection DataContext="{Binding AddAssetDialog}" Visibility="{Binding AddTypeIsAccount, Converter={StaticResource BooleanToVisibilityConverter}}" />

                        <assetSections:LoanCreateSection DataContext="{Binding AddAssetDialog}" Visibility="{Binding AddTypeIsLoan, Converter={StaticResource BooleanToVisibilityConverter}}" />

                        <assetSections:CreditCardCreateSection DataContext="{Binding AddAssetDialog}" Visibility="{Binding AddTypeIsCreditCard, Converter={StaticResource BooleanToVisibilityConverter}}" />
                    </Grid>
                </ScrollViewer>

                <!--  Error (form step only)  -->
                <TextBlock
                    Grid.Row="3"
                    Margin="20,8,20,0"
                    FontSize="{StaticResource Font.Size.Xs}"
                    Foreground="{DynamicResource AppDown}"
                    Text="{Binding AddAssetDialog.AddError}">
                    <TextBlock.Style>
                        <Style TargetType="TextBlock">
                            <Setter Property="Visibility" Value="Collapsed" />
                            <Style.Triggers>
                                <MultiDataTrigger>
                                    <MultiDataTrigger.Conditions>
                                        <Condition Binding="{Binding AddAssetDialog.IsFormStep}" Value="True" />
                                    </MultiDataTrigger.Conditions>
                                    <Setter Property="Visibility" Value="{Binding AddAssetDialog.AddError, Converter={StaticResource StringToVisibilityConverter}}" />
                                </MultiDataTrigger>
                            </Style.Triggers>
                        </Style>
                    </TextBlock.Style>
                </TextBlock>

                <!--  Footer (form step only)  -->
                <Border
                    Grid.Row="4"
                    Padding="20,12"
                    BorderBrush="{DynamicResource AppBorder}"
                    BorderThickness="0,1,0,0"
                    Visibility="{Binding AddAssetDialog.IsFormStep, Converter={StaticResource BooleanToVisibilityConverter}}">
                    <StackPanel HorizontalAlignment="Right" Orientation="Horizontal">
                        <Button
                            Height="30"
                            Margin="0,0,8,0"
                            Padding="14,0"
                            Command="{Binding AddAssetDialog.CloseAddDialogCommand}"
                            Style="{StaticResource AppSecondaryButton}">
                            <TextBlock Foreground="{DynamicResource AppTextSecondary}" Text="{DynamicResource Common.Cancel}" />
                        </Button>
                        <Button
                            Height="30"
                            Padding="14,0"
                            Command="{Binding AddAssetDialog.ConfirmAddCommand}"
                            Style="{StaticResource AppPrimaryButton}">
                            <TextBlock Foreground="{Binding Foreground, RelativeSource={RelativeSource AncestorType=Button}}" Text="{DynamicResource Common.Confirm}" />
                        </Button>
                    </StackPanel>
                </Border>
            </Grid>
        </Border>
    </Grid>
</UserControl>
