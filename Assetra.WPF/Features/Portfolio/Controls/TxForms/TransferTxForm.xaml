<UserControl
    x:Class="Assetra.WPF.Features.Portfolio.Controls.TxForms.TransferTxForm"
    xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
    xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
    xmlns:behaviors="clr-namespace:Assetra.WPF.Infrastructure.Behaviors"
    xmlns:d="http://schemas.microsoft.com/expression/blend/2008"
    xmlns:mc="http://schemas.openxmlformats.org/markup-compatibility/2006"
    xmlns:vm="clr-namespace:Assetra.WPF.Features.Portfolio.SubViewModels"
    d:DataContext="{d:DesignInstance Type={x:Type vm:TransactionDialogViewModel},
                                     IsDesignTimeCreatable=False}"
    mc:Ignorable="d">

    <!--  ======== 轉帳欄位 ========  -->
    <StackPanel Visibility="{Binding TxTypeIsTransfer, Converter={StaticResource BooleanToVisibilityConverter}}">
        <Border
            Margin="0,0,0,12"
            Padding="10,8"
            Background="{DynamicResource AppBackground}"
            BorderBrush="{DynamicResource AppBorder}"
            BorderThickness="1"
            CornerRadius="{StaticResource Radius.Sm}">
            <TextBlock
                FontSize="{StaticResource Font.Size.Xs}"
                Foreground="{DynamicResource AppTextMuted}"
                Text="{Binding TxTransferHint}"
                TextWrapping="Wrap" />
        </Border>

        <TextBlock
            Margin="0,0,0,4"
            FontSize="{StaticResource Font.Size.Xs}"
            FontWeight="SemiBold"
            Foreground="{DynamicResource AppTextSecondary}"
            Text="{DynamicResource Portfolio.Tx.TransferSourceAccount}" />
        <ComboBox
            Margin="0,0,0,4"
            DisplayMemberPath="Name"
            IsEditable="True"
            IsTextSearchEnabled="True"
            ItemsSource="{Binding CashAccounts}"
            SelectedItem="{Binding TxCashAccount, Mode=TwoWay}"
            Style="{StaticResource FormComboBox}"
            Text="{Binding TxCashAccountName, UpdateSourceTrigger=PropertyChanged, Mode=TwoWay}">
            <ComboBox.Resources>
                <Style BasedOn="{StaticResource FormComboBoxItem}" TargetType="ComboBoxItem" />
            </ComboBox.Resources>
        </ComboBox>
        <TextBlock
            Margin="0,2,0,8"
            FontSize="{StaticResource Font.Size.Xs}"
            Foreground="{DynamicResource AppAccent}"
            Text="{DynamicResource Portfolio.Tx.WillCreateNew}"
            Visibility="{Binding IsNewCashAccount, Converter={StaticResource BooleanToVisibilityConverter}}" />

        <TextBlock
            Margin="0,0,0,4"
            FontSize="{StaticResource Font.Size.Xs}"
            FontWeight="SemiBold"
            Foreground="{DynamicResource AppTextSecondary}"
            Text="{DynamicResource Portfolio.Tx.TransferSourceAmount}" />
        <TextBox behaviors:ThousandSeparatorBehavior.IsEnabled="True" Text="{Binding TxAmount, UpdateSourceTrigger=PropertyChanged}" />
        <TextBlock
            Margin="0,0,0,12"
            Style="{StaticResource FormFieldError}"
            Text="{Binding TxAmountError}"
            Visibility="{Binding TxAmountError, Converter={StaticResource StringToVisibilityConverter}}" />

        <TextBlock
            Margin="0,0,0,4"
            FontSize="{StaticResource Font.Size.Xs}"
            FontWeight="SemiBold"
            Foreground="{DynamicResource AppTextSecondary}"
            Text="{DynamicResource Portfolio.Tx.TransferTargetAccount}" />
        <ComboBox
            Margin="0,0,0,4"
            DisplayMemberPath="Name"
            IsEditable="True"
            IsTextSearchEnabled="True"
            ItemsSource="{Binding CashAccounts}"
            SelectedItem="{Binding Transfer.Target, Mode=TwoWay}"
            Style="{StaticResource FormComboBox}"
            Text="{Binding Transfer.TargetName, UpdateSourceTrigger=PropertyChanged, Mode=TwoWay}">
            <ComboBox.Resources>
                <Style BasedOn="{StaticResource FormComboBoxItem}" TargetType="ComboBoxItem" />
            </ComboBox.Resources>
        </ComboBox>
        <TextBlock
            Margin="0,2,0,8"
            FontSize="{StaticResource Font.Size.Xs}"
            Foreground="{DynamicResource AppAccent}"
            Text="{DynamicResource Portfolio.Tx.WillCreateNew}"
            Visibility="{Binding IsNewTransferTarget, Converter={StaticResource BooleanToVisibilityConverter}}" />

        <TextBlock
            Margin="0,0,0,4"
            FontSize="{StaticResource Font.Size.Xs}"
            FontWeight="SemiBold"
            Foreground="{DynamicResource AppTextSecondary}"
            Text="{DynamicResource Portfolio.Tx.TransferTargetAmount}" />
        <TextBox behaviors:ThousandSeparatorBehavior.IsEnabled="True" Text="{Binding Transfer.TargetAmount, UpdateSourceTrigger=PropertyChanged}" />
        <TextBlock
            Style="{StaticResource FormFieldError}"
            Text="{Binding Transfer.TargetAmountError}"
            Visibility="{Binding Transfer.TargetAmountError, Converter={StaticResource StringToVisibilityConverter}}" />
        <TextBlock
            Margin="0,2,0,12"
            FontSize="{StaticResource Font.Size.Xs}"
            Foreground="{DynamicResource AppTextMuted}">
            <Run Text="{DynamicResource Portfolio.Tx.TransferImpliedRate}" />
            <Run Text=": " />
            <Run Text="{Binding Transfer.ImpliedRate, Mode=OneWay}" />
        </TextBlock>

        <TextBlock
            Margin="0,0,0,4"
            FontSize="{StaticResource Font.Size.Xs}"
            FontWeight="SemiBold"
            Foreground="{DynamicResource AppTextSecondary}"
            Text="{DynamicResource Portfolio.Tx.Fee}" />
        <TextBox behaviors:ThousandSeparatorBehavior.IsEnabled="True" Text="{Binding TxFee, UpdateSourceTrigger=PropertyChanged}" />
        <TextBlock
            Margin="0,0,0,12"
            Style="{StaticResource FormFieldError}"
            Text="{Binding TxFeeError}"
            Visibility="{Binding TxFeeError, Converter={StaticResource StringToVisibilityConverter}}" />

        <TextBlock
            Margin="0,0,0,4"
            FontSize="{StaticResource Font.Size.Xs}"
            FontWeight="SemiBold"
            Foreground="{DynamicResource AppTextSecondary}"
            Text="{DynamicResource Portfolio.Tx.Note}" />
        <TextBox Text="{Binding TxNote, UpdateSourceTrigger=PropertyChanged}" />
    </StackPanel>
</UserControl>
