<UserControl
    x:Class="Assetra.WPF.Features.Portfolio.Controls.TxForms.CashDividendTxForm"
    xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
    xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
    xmlns:behaviors="clr-namespace:Assetra.WPF.Infrastructure.Behaviors"
    xmlns:d="http://schemas.microsoft.com/expression/blend/2008"
    xmlns:ds="clr-namespace:Assetra.WPF.DesignSystem.Controls"
    xmlns:mc="http://schemas.openxmlformats.org/markup-compatibility/2006"
    xmlns:shared="clr-namespace:Assetra.WPF.Features.Portfolio.Controls.TxForms.Shared"
    xmlns:vm="clr-namespace:Assetra.WPF.Features.Portfolio.SubViewModels"
    x:Name="Root"
    d:DataContext="{d:DesignInstance Type={x:Type vm:TransactionDialogViewModel}}"
    mc:Ignorable="d">

    <!--  ======== 現金股利欄位 ========  -->
    <StackPanel Visibility="{Binding TxTypeIsCashDiv, Converter={StaticResource BooleanToVisibilityConverter}}">
        <!--  股票已由上方「選擇資產」決定（現金股利只在選到投資持倉時可選，cascade 會把它設成
              Div.Position），故此處不再重複顯示股票選擇器，避免與「選擇資產」重複。  -->

        <!--  輸入模式 toggle: 每股股利 vs 總股息金額  -->
        <TextBlock
            Margin="0,0,0,6"
            FontSize="{StaticResource Font.Size.Xs}"
            FontWeight="SemiBold"
            Foreground="{DynamicResource AppTextSecondary}"
            Text="{DynamicResource Portfolio.Tx.DivInputMode}" />
        <StackPanel Margin="0,0,0,8" Orientation="Horizontal">
            <RadioButton
                Content="{DynamicResource Portfolio.Tx.DivModePerShare}"
                GroupName="Div.InputMode"
                IsChecked="{Binding Div.InputMode, Converter={StaticResource EqualityConverter}, ConverterParameter=perShare, Mode=TwoWay}"
                Style="{StaticResource SegmentBtn}" />
            <RadioButton
                Margin="6,0,0,0"
                Content="{DynamicResource Portfolio.Tx.DivModeTotal}"
                GroupName="Div.InputMode"
                IsChecked="{Binding Div.InputMode, Converter={StaticResource EqualityConverter}, ConverterParameter=total, Mode=TwoWay}"
                Style="{StaticResource SegmentBtn}" />
        </StackPanel>

        <!--  每股股利模式  -->
        <StackPanel Visibility="{Binding Div.IsPerShareMode, Converter={StaticResource BooleanToVisibilityConverter}}">
            <!--  Wave 1 — 標準金額欄位改用 shared:FormField（error 局部 12px 間距以 ErrorMargin 帶入，與原 markup 等價）  -->
            <shared:FormField
                ErrorMargin="0,0,0,12"
                ErrorText="{Binding Div.PerShareError}"
                Label="{DynamicResource Portfolio.Tx.DivPerShare}"
                Placeholder="{DynamicResource Portfolio.Tx.PricePlaceholder}"
                Text="{Binding Div.PerShare, UpdateSourceTrigger=PropertyChanged}"
                ThousandSeparator="True" />
        </StackPanel>

        <!--  總額模式  -->
        <StackPanel Visibility="{Binding Div.IsTotalMode, Converter={StaticResource BooleanToVisibilityConverter}}">
            <shared:FormField
                ErrorMargin="0,0,0,12"
                ErrorText="{Binding Div.TotalInputError}"
                Label="{DynamicResource Portfolio.Tx.DivTotalAmount}"
                Placeholder="{DynamicResource Portfolio.Tx.AmountPlaceholder}"
                Text="{Binding Div.TotalInput, UpdateSourceTrigger=PropertyChanged}"
                ThousandSeparator="True" />
        </StackPanel>

        <!--  持有股數 + 合計（auto-calculated）  -->
        <Border
            Margin="0,0,0,12"
            Padding="10,8"
            Background="{DynamicResource AppBackground}"
            BorderBrush="{DynamicResource AppBorder}"
            BorderThickness="1"
            CornerRadius="{StaticResource Radius.Sm}"
            Visibility="{Binding Div.HasPreview, Converter={StaticResource BooleanToVisibilityConverter}}">
            <Grid>
                <Grid.ColumnDefinitions>
                    <ColumnDefinition Width="*" />
                    <ColumnDefinition Width="Auto" />
                </Grid.ColumnDefinitions>
                <Grid.RowDefinitions>
                    <RowDefinition Height="Auto" />
                    <RowDefinition Height="6" />
                    <RowDefinition Height="Auto" />
                </Grid.RowDefinitions>
                <TextBlock
                    Grid.Row="0"
                    Grid.Column="0"
                    FontSize="{StaticResource Font.Size.Xs}"
                    Foreground="{DynamicResource AppTextMuted}"
                    Text="{DynamicResource Portfolio.Tx.HeldShares}" />
                <TextBlock
                    Grid.Row="0"
                    Grid.Column="1"
                    FontFamily="{StaticResource Font.Family.Base}"
                    FontSize="{StaticResource Font.Size.Xs}"
                    Foreground="{DynamicResource AppTextSecondary}"
                    Text="{Binding Div.Position.Quantity, StringFormat={}{0:N0}}"
                    Typography.NumeralAlignment="Tabular" />
                <Rectangle
                    Grid.Row="1"
                    Grid.Column="0"
                    Grid.ColumnSpan="2"
                    Margin="0,1"
                    Fill="{DynamicResource AppBorder}" />
                <TextBlock
                    Grid.Row="2"
                    Grid.Column="0"
                    FontSize="{StaticResource Font.Size.Xs}"
                    FontWeight="SemiBold"
                    Foreground="{DynamicResource AppTextSecondary}"
                    Text="{DynamicResource Portfolio.Tx.DivTotal}" />
                <TextBlock
                    Grid.Row="2"
                    Grid.Column="1"
                    FontFamily="{StaticResource Font.Family.Base}"
                    FontSize="{StaticResource Font.Size.Xs}"
                    FontWeight="SemiBold"
                    Foreground="{DynamicResource AppUp}"
                    Text="{Binding Div.Total, StringFormat={}{0:N0}}"
                    Typography.NumeralAlignment="Tabular" />
            </Grid>
        </Border>

        <!--  手續費 (e.g. 二代健保補充費 1.91%)  -->
        <TextBlock
            Margin="0,0,0,6"
            FontSize="{StaticResource Font.Size.Xs}"
            FontWeight="SemiBold"
            Foreground="{DynamicResource AppTextSecondary}"
            Text="{DynamicResource Portfolio.Tx.Fee}" />
        <TextBox
            behaviors:ThousandSeparatorBehavior.IsEnabled="True"
            Tag="{DynamicResource Portfolio.Tx.FeePlaceholder}"
            Text="{Binding TxFee, UpdateSourceTrigger=PropertyChanged}" />
        <TextBlock
            Margin="0,0,0,12"
            Style="{StaticResource FormFieldError}"
            Text="{Binding TxFeeError}"
            Visibility="{Binding TxFeeError, Converter={StaticResource StringToVisibilityConverter}}" />

        <!--  存入現金帳戶 — checkbox + dropdown  -->
        <CheckBox
            Margin="0,0,0,4"
            Content="{Binding TxUseCashAccountLabel}"
            FontSize="{StaticResource Font.Size.Xs}"
            Foreground="{DynamicResource AppTextSecondary}"
            IsChecked="{Binding TxUseCashAccount, Mode=TwoWay}" />
        <StackPanel Visibility="{Binding TxUseCashAccount, Converter={StaticResource BooleanToVisibilityConverter}}">
            <TextBlock
                Margin="0,0,0,6"
                FontSize="{StaticResource Font.Size.Xs}"
                FontWeight="SemiBold"
                Foreground="{DynamicResource AppTextSecondary}"
                Text="{Binding TxCashAccountLabel}" />
            <ComboBox
                Margin="0,0,0,4"
                DisplayMemberPath="Name"
                IsEditable="True"
                IsTextSearchEnabled="True"
                ItemsSource="{Binding CashAccounts}"
                SelectedItem="{Binding TxCashAccount, Mode=TwoWay}"
                Style="{StaticResource FormComboBox}"
                Text="{Binding TxCashAccountName, UpdateSourceTrigger=PropertyChanged, Mode=TwoWay}">
                <ComboBox.Resources>
                    <Style BasedOn="{StaticResource FormComboBoxItem}" TargetType="ComboBoxItem" />
                </ComboBox.Resources>
            </ComboBox>
            <TextBlock
                Margin="0,2,0,0"
                FontSize="{StaticResource Font.Size.Xs}"
                Foreground="{DynamicResource AppAccent}"
                Text="{DynamicResource Portfolio.Tx.WillCreateNew}"
                Visibility="{Binding IsNewCashAccount, Converter={StaticResource BooleanToVisibilityConverter}}" />

            <!--
                「帳戶入帳」卡（入帳依據 radios ＋ 實際入帳金額 ＋ 三段說明）已整張移除，
                對齊買入／賣出。現金股利一律走「依匯率估算」：台幣入帳 = 股息 × 當日市場匯率
                － 手續費，匯率由 QueueDividendFxRateRefresh() 在日期／帳戶／幣別變動時靜默
                自動抓，確認前還有一道補抓，使用者不需要碰任何跨幣別欄位。

                只留這一行匯率：①自動抓不到當日匯率時（補記舊股息）否則會卡在確認錯誤、
                無處可修；②台幣入帳完全由它推導出來，使用者有權看見並覆寫。
            -->
            <Grid
                Margin="0,10,0,0"
                Visibility="{Binding Div.IsCrossCurrency, Converter={StaticResource BooleanToVisibilityConverter}}">
                <Grid.ColumnDefinitions>
                    <ColumnDefinition Width="Auto" />
                    <ColumnDefinition Width="*" />
                    <ColumnDefinition Width="Auto" />
                </Grid.ColumnDefinitions>
                <StackPanel
                    Grid.Column="0"
                    VerticalAlignment="Center"
                    Orientation="Horizontal">
                    <TextBlock
                        VerticalAlignment="Center"
                        FontSize="{StaticResource Font.Size.Xs}"
                        FontWeight="SemiBold"
                        Foreground="{DynamicResource AppTextSecondary}"
                        Text="{DynamicResource Portfolio.Tx.FxRate.Short}" />
                    <TextBlock
                        Margin="6,0,0,0"
                        VerticalAlignment="Center"
                        FontSize="{StaticResource Font.Size.Xs}"
                        Foreground="{DynamicResource AppAccent}"
                        Text="{Binding Div.SettlementPairDisplay, Mode=OneWay}" />
                </StackPanel>
                <TextBox
                    Grid.Column="1"
                    MinWidth="90"
                    Margin="10,0,0,0"
                    HorizontalAlignment="Left"
                    VerticalAlignment="Center"
                    IsEnabled="{Binding AreEconomicFieldsEditable}"
                    Text="{Binding Div.FxRate, UpdateSourceTrigger=PropertyChanged}"
                    ToolTip="{DynamicResource Portfolio.Tx.FxRate.Hint}" />
                <Button
                    Grid.Column="2"
                    Padding="0"
                    VerticalAlignment="Center"
                    Background="Transparent"
                    BorderThickness="0"
                    Command="{Binding FetchDividendFxRateCommand}"
                    Cursor="Hand"
                    ToolTip="{DynamicResource Portfolio.Tx.FetchFxRate}">
                    <ds:AppIcon
                        FontSize="12"
                        Foreground="{DynamicResource AppAccent}"
                        Symbol="Flash16" />
                </Button>
            </Grid>
            <!--  抓匯率失敗訊息 — 走設計系統既有的 FormFieldError 樣式（勿直接塗 AppDanger）  -->
            <TextBlock
                Margin="0,4,0,0"
                Style="{StaticResource FormFieldError}"
                Text="{Binding Div.FxFetchError}"
                TextWrapping="Wrap"
                Visibility="{Binding Div.FxFetchError, Converter={StaticResource StringToVisibilityConverter}}" />
        </StackPanel>
    </StackPanel>
</UserControl>
