<UserControl
    x:Class="Assetra.WPF.Features.Portfolio.Controls.TxForms.CashDividendTxForm"
    xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
    xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
    xmlns:behaviors="clr-namespace:Assetra.WPF.Infrastructure.Behaviors"
    xmlns:d="http://schemas.microsoft.com/expression/blend/2008"
    xmlns:mc="http://schemas.openxmlformats.org/markup-compatibility/2006"
    xmlns:vm="clr-namespace:Assetra.WPF.Features.Portfolio"
    d:DataContext="{d:DesignInstance Type={x:Type vm:PortfolioViewModel},
                                     IsDesignTimeCreatable=False}"
    mc:Ignorable="d">

    <!--  ======== 現金股利欄位 ========  -->
    <StackPanel Visibility="{Binding TxTypeIsCashDiv, Converter={StaticResource BooleanToVisibilityConverter}}">
        <TextBlock
            Margin="0,0,0,4"
            FontSize="{StaticResource FontSizeXs}"
            FontWeight="SemiBold"
            Foreground="{DynamicResource AppTextSecondary}"
            Text="{DynamicResource Portfolio.Tx.Stock}" />
        <ComboBox
            Margin="0,0,0,12"
            ItemsSource="{Binding Positions}"
            SelectedItem="{Binding TxDivPosition, Mode=TwoWay}"
            Style="{StaticResource FormComboBox}">
            <ComboBox.ItemTemplate>
                <DataTemplate>
                    <StackPanel Orientation="Horizontal">
                        <TextBlock
                            Margin="0,0,8,0"
                            FontFamily="{StaticResource FontTabular}"
                            FontWeight="SemiBold"
                            Foreground="{DynamicResource AppAccent}"
                            Text="{Binding Symbol}" />
                        <TextBlock Foreground="{DynamicResource AppTextPrimary}" Text="{Binding Name}" />
                    </StackPanel>
                </DataTemplate>
            </ComboBox.ItemTemplate>
        </ComboBox>

        <!--  輸入模式 toggle: 每股股利 vs 總股息金額  -->
        <TextBlock
            Margin="0,0,0,4"
            FontSize="{StaticResource FontSizeXs}"
            FontWeight="SemiBold"
            Foreground="{DynamicResource AppTextSecondary}"
            Text="{DynamicResource Portfolio.Tx.DivInputMode}" />
        <StackPanel Margin="0,0,0,8" Orientation="Horizontal">
            <RadioButton
                Content="{DynamicResource Portfolio.Tx.DivModePerShare}"
                GroupName="TxDivInputMode"
                IsChecked="{Binding TxDivInputMode, Converter={StaticResource EqualityConverter}, ConverterParameter=perShare, Mode=TwoWay}"
                Style="{StaticResource SegmentBtn}" />
            <RadioButton
                Margin="6,0,0,0"
                Content="{DynamicResource Portfolio.Tx.DivModeTotal}"
                GroupName="TxDivInputMode"
                IsChecked="{Binding TxDivInputMode, Converter={StaticResource EqualityConverter}, ConverterParameter=total, Mode=TwoWay}"
                Style="{StaticResource SegmentBtn}" />
        </StackPanel>

        <!--  每股股利模式  -->
        <StackPanel Visibility="{Binding TxDivIsPerShareMode, Converter={StaticResource BooleanToVisibilityConverter}}">
            <TextBlock
                Margin="0,0,0,4"
                FontSize="{StaticResource FontSizeXs}"
                FontWeight="SemiBold"
                Foreground="{DynamicResource AppTextSecondary}"
                Text="{DynamicResource Portfolio.Tx.DivPerShare}" />
            <TextBox
                behaviors:ThousandSeparatorBehavior.IsEnabled="True"
                Style="{StaticResource FormTextBox}"
                Text="{Binding TxDivPerShare, UpdateSourceTrigger=PropertyChanged}" />
            <TextBlock
                Margin="0,0,0,12"
                Style="{StaticResource FormFieldError}"
                Text="{Binding TxDivPerShareError}"
                Visibility="{Binding TxDivPerShareError, Converter={StaticResource StringToVisibilityConverter}}" />
        </StackPanel>

        <!--  總額模式  -->
        <StackPanel Visibility="{Binding TxDivIsTotalMode, Converter={StaticResource BooleanToVisibilityConverter}}">
            <TextBlock
                Margin="0,0,0,4"
                FontSize="{StaticResource FontSizeXs}"
                FontWeight="SemiBold"
                Foreground="{DynamicResource AppTextSecondary}"
                Text="{DynamicResource Portfolio.Tx.DivTotalAmount}" />
            <TextBox
                behaviors:ThousandSeparatorBehavior.IsEnabled="True"
                Style="{StaticResource FormTextBox}"
                Text="{Binding TxDivTotalInput, UpdateSourceTrigger=PropertyChanged}" />
            <TextBlock
                Margin="0,0,0,12"
                Style="{StaticResource FormFieldError}"
                Text="{Binding TxDivTotalInputError}"
                Visibility="{Binding TxDivTotalInputError, Converter={StaticResource StringToVisibilityConverter}}" />
        </StackPanel>

        <!--  持有股數 + 合計（auto-calculated）  -->
        <Border
            Margin="0,0,0,12"
            Padding="10,8"
            Background="{DynamicResource AppBackground}"
            BorderBrush="{DynamicResource AppBorder}"
            BorderThickness="1"
            CornerRadius="{StaticResource RadiusSm}"
            Visibility="{Binding HasDivPreview, Converter={StaticResource BooleanToVisibilityConverter}}">
            <Grid>
                <Grid.ColumnDefinitions>
                    <ColumnDefinition Width="*" />
                    <ColumnDefinition Width="Auto" />
                </Grid.ColumnDefinitions>
                <Grid.RowDefinitions>
                    <RowDefinition Height="Auto" />
                    <RowDefinition Height="6" />
                    <RowDefinition Height="Auto" />
                </Grid.RowDefinitions>
                <TextBlock
                    Grid.Row="0"
                    Grid.Column="0"
                    FontSize="{StaticResource FontSizeXs}"
                    Foreground="{DynamicResource AppTextMuted}"
                    Text="{DynamicResource Portfolio.Tx.HeldShares}" />
                <TextBlock
                    Grid.Row="0"
                    Grid.Column="1"
                    FontFamily="{StaticResource FontTabular}"
                    FontSize="{StaticResource FontSizeXs}"
                    Foreground="{DynamicResource AppTextSecondary}"
                    Text="{Binding TxDivPosition.Quantity, StringFormat={}{0:N0}}" />
                <Rectangle
                    Grid.Row="1"
                    Grid.Column="0"
                    Grid.ColumnSpan="2"
                    Margin="0,1"
                    Fill="{DynamicResource AppBorder}" />
                <TextBlock
                    Grid.Row="2"
                    Grid.Column="0"
                    FontSize="{StaticResource FontSizeXs}"
                    FontWeight="SemiBold"
                    Foreground="{DynamicResource AppTextSecondary}"
                    Text="{DynamicResource Portfolio.Tx.DivTotal}" />
                <TextBlock
                    Grid.Row="2"
                    Grid.Column="1"
                    FontFamily="{StaticResource FontTabular}"
                    FontSize="{StaticResource FontSizeXs}"
                    FontWeight="SemiBold"
                    Foreground="{DynamicResource AppUp}"
                    Text="{Binding TxDivTotal, StringFormat={}{0:N0}}" />
            </Grid>
        </Border>

        <!--  手續費 (e.g. 二代健保補充費 1.91%)  -->
        <TextBlock
            Margin="0,0,0,4"
            FontSize="{StaticResource FontSizeXs}"
            FontWeight="SemiBold"
            Foreground="{DynamicResource AppTextSecondary}"
            Text="{DynamicResource Portfolio.Tx.Fee}" />
        <TextBox
            behaviors:ThousandSeparatorBehavior.IsEnabled="True"
            Style="{StaticResource FormTextBox}"
            Text="{Binding TxFee, UpdateSourceTrigger=PropertyChanged}" />
        <TextBlock
            Margin="0,0,0,12"
            Style="{StaticResource FormFieldError}"
            Text="{Binding TxFeeError}"
            Visibility="{Binding TxFeeError, Converter={StaticResource StringToVisibilityConverter}}" />

        <!--  存入現金帳戶 — checkbox + dropdown  -->
        <CheckBox
            Margin="0,0,0,4"
            Content="{DynamicResource Portfolio.Tx.UseLoanCashAccount}"
            FontSize="{StaticResource FontSizeXs}"
            Foreground="{DynamicResource AppTextSecondary}"
            IsChecked="{Binding TxUseCashAccount, Mode=TwoWay}" />
        <StackPanel Visibility="{Binding TxUseCashAccount, Converter={StaticResource BooleanToVisibilityConverter}}">
            <TextBlock
                Margin="0,0,0,4"
                FontSize="{StaticResource FontSizeXs}"
                FontWeight="SemiBold"
                Foreground="{DynamicResource AppTextSecondary}"
                Text="{DynamicResource Portfolio.Tx.LoanCashAccount}" />
            <ComboBox
                Margin="0,0,0,4"
                DisplayMemberPath="Name"
                IsEditable="True"
                IsTextSearchEnabled="True"
                ItemsSource="{Binding CashAccounts}"
                SelectedItem="{Binding TxCashAccount, Mode=TwoWay}"
                Style="{StaticResource FormComboBox}"
                Text="{Binding TxCashAccountName, UpdateSourceTrigger=PropertyChanged, Mode=TwoWay}">
                <ComboBox.Resources>
                    <Style BasedOn="{StaticResource FormComboBoxItem}" TargetType="ComboBoxItem" />
                </ComboBox.Resources>
            </ComboBox>
            <TextBlock
                Margin="0,2,0,0"
                FontSize="{StaticResource FontSizeXs}"
                Foreground="{DynamicResource AppAccent}"
                Text="{DynamicResource Portfolio.Tx.WillCreateNew}"
                Visibility="{Binding IsNewCashAccount, Converter={StaticResource BooleanToVisibilityConverter}}" />
        </StackPanel>
    </StackPanel>
</UserControl>
