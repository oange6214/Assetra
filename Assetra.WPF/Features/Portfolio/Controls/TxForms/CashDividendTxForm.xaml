<UserControl
    x:Class="Assetra.WPF.Features.Portfolio.Controls.TxForms.CashDividendTxForm"
    xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
    xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
    xmlns:behaviors="clr-namespace:Assetra.WPF.Infrastructure.Behaviors"
    xmlns:d="http://schemas.microsoft.com/expression/blend/2008"
    xmlns:mc="http://schemas.openxmlformats.org/markup-compatibility/2006"
    xmlns:vm="clr-namespace:Assetra.WPF.Features.Portfolio.SubViewModels"
    d:DataContext="{d:DesignInstance Type={x:Type vm:TransactionDialogViewModel}}"
    mc:Ignorable="d">

    <!--  ======== 現金股利欄位 ========  -->
    <StackPanel Visibility="{Binding TxTypeIsCashDiv, Converter={StaticResource BooleanToVisibilityConverter}}">
        <TextBlock
            Margin="0,0,0,6"
            FontSize="{StaticResource Font.Size.Xs}"
            FontWeight="SemiBold"
            Foreground="{DynamicResource AppTextSecondary}"
            Text="{DynamicResource Portfolio.Tx.Stock}" />
        <ComboBox
            Margin="0,0,0,12"
            ItemsSource="{Binding Positions}"
            SelectedItem="{Binding Div.Position, Mode=TwoWay}"
            Style="{StaticResource FormComboBox}">
            <ComboBox.ItemTemplate>
                <DataTemplate>
                    <StackPanel Orientation="Horizontal">
                        <TextBlock
                            Margin="0,0,8,0"
                            FontFamily="{StaticResource Font.Family.Base}"
                            FontWeight="SemiBold"
                            Foreground="{DynamicResource AppAccent}"
                            Text="{Binding Symbol}"
                            Typography.NumeralAlignment="Tabular" />
                        <TextBlock Foreground="{DynamicResource AppTextPrimary}" Text="{Binding Name}" />
                    </StackPanel>
                </DataTemplate>
            </ComboBox.ItemTemplate>
        </ComboBox>

        <!--  輸入模式 toggle: 每股股利 vs 總股息金額  -->
        <TextBlock
            Margin="0,0,0,6"
            FontSize="{StaticResource Font.Size.Xs}"
            FontWeight="SemiBold"
            Foreground="{DynamicResource AppTextSecondary}"
            Text="{DynamicResource Portfolio.Tx.DivInputMode}" />
        <StackPanel Margin="0,0,0,8" Orientation="Horizontal">
            <RadioButton
                Content="{DynamicResource Portfolio.Tx.DivModePerShare}"
                GroupName="Div.InputMode"
                IsChecked="{Binding Div.InputMode, Converter={StaticResource EqualityConverter}, ConverterParameter=perShare, Mode=TwoWay}"
                Style="{StaticResource SegmentBtn}" />
            <RadioButton
                Margin="6,0,0,0"
                Content="{DynamicResource Portfolio.Tx.DivModeTotal}"
                GroupName="Div.InputMode"
                IsChecked="{Binding Div.InputMode, Converter={StaticResource EqualityConverter}, ConverterParameter=total, Mode=TwoWay}"
                Style="{StaticResource SegmentBtn}" />
        </StackPanel>

        <!--  每股股利模式  -->
        <StackPanel Visibility="{Binding Div.IsPerShareMode, Converter={StaticResource BooleanToVisibilityConverter}}">
            <TextBlock
                Margin="0,0,0,6"
                FontSize="{StaticResource Font.Size.Xs}"
                FontWeight="SemiBold"
                Foreground="{DynamicResource AppTextSecondary}"
                Text="{DynamicResource Portfolio.Tx.DivPerShare}" />
            <TextBox
                behaviors:ThousandSeparatorBehavior.IsEnabled="True"
                Tag="{DynamicResource Portfolio.Tx.PricePlaceholder}"
                Text="{Binding Div.PerShare, UpdateSourceTrigger=PropertyChanged}" />
            <TextBlock
                Margin="0,0,0,12"
                Style="{StaticResource FormFieldError}"
                Text="{Binding Div.PerShareError}"
                Visibility="{Binding Div.PerShareError, Converter={StaticResource StringToVisibilityConverter}}" />
        </StackPanel>

        <!--  總額模式  -->
        <StackPanel Visibility="{Binding Div.IsTotalMode, Converter={StaticResource BooleanToVisibilityConverter}}">
            <TextBlock
                Margin="0,0,0,6"
                FontSize="{StaticResource Font.Size.Xs}"
                FontWeight="SemiBold"
                Foreground="{DynamicResource AppTextSecondary}"
                Text="{DynamicResource Portfolio.Tx.DivTotalAmount}" />
            <TextBox
                behaviors:ThousandSeparatorBehavior.IsEnabled="True"
                Tag="{DynamicResource Portfolio.Tx.AmountPlaceholder}"
                Text="{Binding Div.TotalInput, UpdateSourceTrigger=PropertyChanged}" />
            <TextBlock
                Margin="0,0,0,12"
                Style="{StaticResource FormFieldError}"
                Text="{Binding Div.TotalInputError}"
                Visibility="{Binding Div.TotalInputError, Converter={StaticResource StringToVisibilityConverter}}" />
        </StackPanel>

        <!--  持有股數 + 合計（auto-calculated）  -->
        <Border
            Margin="0,0,0,12"
            Padding="10,8"
            Background="{DynamicResource AppBackground}"
            BorderBrush="{DynamicResource AppBorder}"
            BorderThickness="1"
            CornerRadius="{StaticResource Radius.Sm}"
            Visibility="{Binding Div.HasPreview, Converter={StaticResource BooleanToVisibilityConverter}}">
            <Grid>
                <Grid.ColumnDefinitions>
                    <ColumnDefinition Width="*" />
                    <ColumnDefinition Width="Auto" />
                </Grid.ColumnDefinitions>
                <Grid.RowDefinitions>
                    <RowDefinition Height="Auto" />
                    <RowDefinition Height="6" />
                    <RowDefinition Height="Auto" />
                </Grid.RowDefinitions>
                <TextBlock
                    Grid.Row="0"
                    Grid.Column="0"
                    FontSize="{StaticResource Font.Size.Xs}"
                    Foreground="{DynamicResource AppTextMuted}"
                    Text="{DynamicResource Portfolio.Tx.HeldShares}" />
                <TextBlock
                    Grid.Row="0"
                    Grid.Column="1"
                    FontFamily="{StaticResource Font.Family.Base}"
                    FontSize="{StaticResource Font.Size.Xs}"
                    Foreground="{DynamicResource AppTextSecondary}"
                    Text="{Binding Div.Position.Quantity, StringFormat={}{0:N0}}"
                    Typography.NumeralAlignment="Tabular" />
                <Rectangle
                    Grid.Row="1"
                    Grid.Column="0"
                    Grid.ColumnSpan="2"
                    Margin="0,1"
                    Fill="{DynamicResource AppBorder}" />
                <TextBlock
                    Grid.Row="2"
                    Grid.Column="0"
                    FontSize="{StaticResource Font.Size.Xs}"
                    FontWeight="SemiBold"
                    Foreground="{DynamicResource AppTextSecondary}"
                    Text="{DynamicResource Portfolio.Tx.DivTotal}" />
                <TextBlock
                    Grid.Row="2"
                    Grid.Column="1"
                    FontFamily="{StaticResource Font.Family.Base}"
                    FontSize="{StaticResource Font.Size.Xs}"
                    FontWeight="SemiBold"
                    Foreground="{DynamicResource AppUp}"
                    Text="{Binding Div.Total, StringFormat={}{0:N0}}"
                    Typography.NumeralAlignment="Tabular" />
            </Grid>
        </Border>

        <!--  手續費 (e.g. 二代健保補充費 1.91%)  -->
        <TextBlock
            Margin="0,0,0,6"
            FontSize="{StaticResource Font.Size.Xs}"
            FontWeight="SemiBold"
            Foreground="{DynamicResource AppTextSecondary}"
            Text="{DynamicResource Portfolio.Tx.Fee}" />
        <TextBox
            behaviors:ThousandSeparatorBehavior.IsEnabled="True"
            Tag="{DynamicResource Portfolio.Tx.FeePlaceholder}"
            Text="{Binding TxFee, UpdateSourceTrigger=PropertyChanged}" />
        <TextBlock
            Margin="0,0,0,12"
            Style="{StaticResource FormFieldError}"
            Text="{Binding TxFeeError}"
            Visibility="{Binding TxFeeError, Converter={StaticResource StringToVisibilityConverter}}" />

        <!--  存入現金帳戶 — checkbox + dropdown  -->
        <CheckBox
            Margin="0,0,0,4"
            Content="{Binding TxUseCashAccountLabel}"
            FontSize="{StaticResource Font.Size.Xs}"
            Foreground="{DynamicResource AppTextSecondary}"
            IsChecked="{Binding TxUseCashAccount, Mode=TwoWay}" />
        <StackPanel Visibility="{Binding TxUseCashAccount, Converter={StaticResource BooleanToVisibilityConverter}}">
            <TextBlock
                Margin="0,0,0,6"
                FontSize="{StaticResource Font.Size.Xs}"
                FontWeight="SemiBold"
                Foreground="{DynamicResource AppTextSecondary}"
                Text="{Binding TxCashAccountLabel}" />
            <ComboBox
                Margin="0,0,0,4"
                DisplayMemberPath="Name"
                IsEditable="True"
                IsTextSearchEnabled="True"
                ItemsSource="{Binding CashAccounts}"
                SelectedItem="{Binding TxCashAccount, Mode=TwoWay}"
                Style="{StaticResource FormComboBox}"
                Text="{Binding TxCashAccountName, UpdateSourceTrigger=PropertyChanged, Mode=TwoWay}">
                <ComboBox.Resources>
                    <Style BasedOn="{StaticResource FormComboBoxItem}" TargetType="ComboBoxItem" />
                </ComboBox.Resources>
            </ComboBox>
            <TextBlock
                Margin="0,2,0,0"
                FontSize="{StaticResource Font.Size.Xs}"
                Foreground="{DynamicResource AppAccent}"
                Text="{DynamicResource Portfolio.Tx.WillCreateNew}"
                Visibility="{Binding IsNewCashAccount, Converter={StaticResource BooleanToVisibilityConverter}}" />

            <!--
                MultiCurrency-Trade-Refactor P3 — CashDividend mirror of Buy/Sell.
                跨幣別股息（美股配 USD 股息入 TWD 帳戶）顯示 banner + 匯率 + 實際入帳。
            -->
            <!--  P5.8a — Settlement section mirrored from BuyTxForm（取代原 P5.7 banner + Expander）  -->
            <Border
                Margin="0,14,0,0"
                Padding="12"
                Background="{DynamicResource AppSurface}"
                BorderBrush="{DynamicResource AppBorder}"
                BorderThickness="1"
                CornerRadius="{StaticResource Radius.Sm}"
                Visibility="{Binding Div.IsCrossCurrency, Converter={StaticResource BooleanToVisibilityConverter}}">
                <StackPanel>
                    <Grid>
                        <Grid.ColumnDefinitions>
                            <ColumnDefinition Width="*" />
                            <ColumnDefinition Width="Auto" />
                        </Grid.ColumnDefinitions>
                        <TextBlock
                            Grid.Column="0"
                            FontSize="{StaticResource Font.Size.Sm}"
                            FontWeight="SemiBold"
                            Foreground="{DynamicResource AppTextPrimary}"
                            Text="{DynamicResource Portfolio.Tx.SettlementSection}" />
                        <Border
                            Grid.Column="1"
                            Padding="8,3"
                            Background="{DynamicResource AppSurfaceAlt}"
                            BorderBrush="{DynamicResource AppBorder}"
                            BorderThickness="1"
                            CornerRadius="{StaticResource Radius.Sm}">
                            <TextBlock
                                FontSize="{StaticResource Font.Size.Xs}"
                                Foreground="{DynamicResource AppTextSecondary}"
                                Text="{Binding Div.SettlementPairDisplay, Mode=OneWay}" />
                        </Border>
                    </Grid>

                    <TextBlock
                        Margin="0,4,0,12"
                        FontSize="{StaticResource Font.Size.Xs}"
                        Foreground="{DynamicResource AppTextSecondary}"
                        Text="{DynamicResource Portfolio.Tx.CrossCurrency.Hint.Short}"
                        TextWrapping="Wrap" />

                    <TextBlock
                        Margin="0,0,0,6"
                        FontSize="{StaticResource Font.Size.Xs}"
                        FontWeight="SemiBold"
                        Foreground="{DynamicResource AppTextSecondary}"
                        Text="{DynamicResource Portfolio.Tx.SettlementInputMode}" />
                    <Grid Margin="0,0,0,12">
                        <Grid.ColumnDefinitions>
                            <ColumnDefinition Width="*" />
                            <ColumnDefinition Width="6" />
                            <ColumnDefinition Width="*" />
                        </Grid.ColumnDefinitions>
                        <RadioButton
                            Grid.Column="0"
                            HorizontalAlignment="Stretch"
                            HorizontalContentAlignment="Center"
                            Content="{DynamicResource Portfolio.Tx.SettlementMode.Statement}"
                            GroupName="TxDivSettlementInputMode"
                            IsChecked="{Binding Div.SettlementInputMode, Converter={StaticResource EqualityConverter}, ConverterParameter=statement, Mode=TwoWay}"
                            Style="{StaticResource SegmentBtn}" />
                        <RadioButton
                            Grid.Column="2"
                            HorizontalAlignment="Stretch"
                            HorizontalContentAlignment="Center"
                            Content="{DynamicResource Portfolio.Tx.SettlementMode.FxEstimate}"
                            GroupName="TxDivSettlementInputMode"
                            IsChecked="{Binding Div.SettlementInputMode, Converter={StaticResource EqualityConverter}, ConverterParameter=fx, Mode=TwoWay}"
                            Style="{StaticResource SegmentBtn}" />
                    </Grid>

                    <StackPanel Visibility="{Binding Div.IsStatementSettlementMode, Converter={StaticResource BooleanToVisibilityConverter}}">
                        <TextBlock
                            Margin="0,0,0,6"
                            Style="{StaticResource FormFieldLabel}"
                            Text="{DynamicResource Portfolio.Tx.DivActualCashAmount}" />
                        <TextBox
                            behaviors:ThousandSeparatorBehavior.IsEnabled="True"
                            Text="{Binding Div.ActualCashAmount, UpdateSourceTrigger=PropertyChanged}" />
                        <TextBlock
                            Style="{StaticResource FormFieldError}"
                            Text="{Binding Div.ActualCashAmountError}"
                            Visibility="{Binding Div.ActualCashAmountError, Converter={StaticResource StringToVisibilityConverter}}" />
                        <TextBlock
                            Margin="0,2,0,0"
                            FontSize="{StaticResource Font.Size.Xs}"
                            Foreground="{DynamicResource AppTextMuted}"
                            Text="{DynamicResource Portfolio.Tx.DivActualCashAmountHint}"
                            TextWrapping="Wrap" />
                    </StackPanel>

                    <StackPanel Visibility="{Binding Div.IsFxSettlementMode, Converter={StaticResource BooleanToVisibilityConverter}}">
                        <TextBlock
                            Margin="0,0,0,6"
                            Style="{StaticResource FormFieldLabel}"
                            Text="{DynamicResource Portfolio.Tx.FxRate}" />
                        <TextBlock
                            Margin="0,0,0,6"
                            FontSize="{StaticResource Font.Size.Xs}"
                            Foreground="{DynamicResource AppTextMuted}"
                            Text="{DynamicResource Portfolio.Tx.FxMode.Hint}"
                            TextWrapping="Wrap" />
                        <Grid>
                            <Grid.ColumnDefinitions>
                                <ColumnDefinition Width="*" />
                                <ColumnDefinition Width="12" />
                                <ColumnDefinition Width="*" />
                            </Grid.ColumnDefinitions>
                            <TextBox
                                Grid.Column="0"
                                behaviors:ThousandSeparatorBehavior.IsEnabled="True"
                                Text="{Binding Div.FxRate, UpdateSourceTrigger=PropertyChanged}" />
                            <StackPanel Grid.Column="2">
                                <TextBlock Style="{StaticResource FormFieldLabel}" Text="{DynamicResource Portfolio.Tx.FxRateDate}" />
                                <Border
                                    MinHeight="{StaticResource Control.Height.Md}"
                                    Padding="10,0"
                                    Background="{DynamicResource AppSurfaceAlt}"
                                    BorderBrush="{DynamicResource AppBorder}"
                                    BorderThickness="1"
                                    CornerRadius="{StaticResource Radius.Sm}">
                                    <TextBlock
                                        VerticalAlignment="Center"
                                        FontSize="{StaticResource Font.Size.Sm}"
                                        Foreground="{DynamicResource AppTextSecondary}"
                                        Text="{Binding Div.FxRateDateDisplay, Mode=OneWay}" />
                                </Border>
                            </StackPanel>
                        </Grid>
                        <TextBlock
                            Style="{StaticResource FormFieldError}"
                            Text="{Binding Div.FxRateError}"
                            Visibility="{Binding Div.FxRateError, Converter={StaticResource StringToVisibilityConverter}}" />
                        <TextBlock
                            Style="{StaticResource FormFieldError}"
                            Text="{Binding Div.FxFetchError}"
                            Visibility="{Binding Div.FxFetchError, Converter={StaticResource StringToVisibilityConverter}}" />
                        <TextBlock
                            Margin="0,4,0,0"
                            FontSize="{StaticResource Font.Size.Xs}"
                            Foreground="{DynamicResource AppTextMuted}">
                            <Run Text="{DynamicResource Portfolio.Tx.FxSource}" />
                            <Run Text=": " />
                            <Run Text="{Binding Div.FxSourceDisplay, Mode=OneWay}" />
                        </TextBlock>
                    </StackPanel>
                </StackPanel>
            </Border>
        </StackPanel>
    </StackPanel>
</UserControl>
