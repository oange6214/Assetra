<UserControl
    x:Class="Assetra.WPF.Features.Portfolio.Controls.TxForms.CreditCardTxForm"
    xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
    xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
    xmlns:behaviors="clr-namespace:Assetra.WPF.Infrastructure.Behaviors"
    xmlns:controls="clr-namespace:Assetra.WPF.Controls"
    xmlns:d="http://schemas.microsoft.com/expression/blend/2008"
    xmlns:mc="http://schemas.openxmlformats.org/markup-compatibility/2006"
    mc:Ignorable="d">

    <StackPanel Visibility="{Binding TxTypeIsCreditCard, Converter={StaticResource BooleanToVisibilityConverter}}">
        <Border
            Margin="0,0,0,12"
            Padding="10,8"
            Background="{DynamicResource AppBackground}"
            BorderBrush="{DynamicResource AppBorder}"
            BorderThickness="1"
            CornerRadius="{StaticResource Radius.Sm}">
            <TextBlock
                FontSize="{StaticResource Font.Size.Xs}"
                Foreground="{DynamicResource AppTextMuted}"
                Text="{Binding TxCreditCardHint}"
                TextWrapping="Wrap" />
        </Border>

        <!--
            信用卡已由上方「選擇資產」決定（信用卡消費/還款只在選到信用卡負債時可選，cascade 會把它設成
            CreditCard.Card），故此處不再重複顯示信用卡選擇器，避免與「選擇資產」重複。
        -->

        <Grid Margin="0,0,0,12">
            <Grid.ColumnDefinitions>
                <ColumnDefinition Width="*" />
                <ColumnDefinition Width="12" />
                <ColumnDefinition Width="*" />
            </Grid.ColumnDefinitions>

            <StackPanel Grid.Column="0">
                <TextBlock
                    Margin="0,0,0,6"
                    FontSize="{StaticResource Font.Size.Xs}"
                    FontWeight="SemiBold"
                    Foreground="{DynamicResource AppTextSecondary}"
                    Text="{DynamicResource Portfolio.Tx.Amount}" />
                <TextBox
                    Margin="0,0,0,6"
                    behaviors:ThousandSeparatorBehavior.IsEnabled="True"
                    Text="{Binding TxAmount, UpdateSourceTrigger=PropertyChanged}" />
                <TextBlock
                    FontSize="{StaticResource Font.Size.Xs}"
                    Foreground="{DynamicResource AppDown}"
                    Text="{Binding TxAmountError}"
                    Visibility="{Binding TxAmountError, Converter={StaticResource StringToVisibilityConverter}}" />
            </StackPanel>

            <StackPanel Grid.Column="2" Visibility="{Binding TxTypeIsCreditCardPayment, Converter={StaticResource BooleanToVisibilityConverter}}">
                <TextBlock
                    Margin="0,0,0,6"
                    FontSize="{StaticResource Font.Size.Xs}"
                    FontWeight="SemiBold"
                    Foreground="{DynamicResource AppTextSecondary}"
                    Text="{DynamicResource Portfolio.Tx.CreditCardPaymentAccount}" />
                <ComboBox
                    DisplayMemberPath="Name"
                    ItemsSource="{Binding CashAccounts}"
                    SelectedItem="{Binding TxCashAccount, Mode=TwoWay}"
                    Style="{StaticResource FormComboBox}" />
            </StackPanel>
        </Grid>

        <!--  P2.9 — TxNote 已 unified 到 AddRecordDialog dialog level。  -->
    </StackPanel>
</UserControl>
