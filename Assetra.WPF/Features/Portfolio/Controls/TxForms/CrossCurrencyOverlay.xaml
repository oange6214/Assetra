<UserControl
    x:Class="Assetra.WPF.Features.Portfolio.Controls.TxForms.CrossCurrencyOverlay"
    xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
    xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
    xmlns:behaviors="clr-namespace:Assetra.WPF.Infrastructure.Behaviors"
    xmlns:d="http://schemas.microsoft.com/expression/blend/2008"
    xmlns:mc="http://schemas.openxmlformats.org/markup-compatibility/2006"
    x:Name="Root"
    Visibility="{Binding IsCrossCurrency, Converter={StaticResource BooleanToVisibilityConverter}}"
    mc:Ignorable="d">

    <!--
        P5.8b — Cross-currency settlement section 抽出來的共用 UserControl。
        
        前置：P5.8a 把 Buy / Sell / Div 三個 sub-VM 的 settlement 屬性鏡像對齊
        （SettlementInputMode / SettlementCurrency / FxRateDate / FxSourceLabel /
        IsFxManual / FxFetchError），P5.8b-prereq 把 Sell + Div 也接上
        FetchXxxFxRateCommand。3 個 form 結構此時完全對稱 → 可抽 UserControl。
        
        DataContext 期待是 Buy / Sell / Div sub-VM（不是 TransactionDialogViewModel
        本身）— 內層 binding 用未加前綴的屬性名稱（SettlementInputMode 等）。
        
        DPs（由呼叫方 XAML 設定）：
        - GroupName               — RadioButton GroupName，避免跨表單 group 串組
        e.g. "TxBuySettlementInputMode"
        - FetchFxRateCommand      — 父 VM 的一鍵抓匯率 command
        e.g. FetchBuyFxRateCommand
        - ActualCashAmountLabel   — 「實際扣款/入帳金額」label 文字
        Buy: 實際扣款金額 / Sell: 實際入帳金額 / Div: 實際入帳金額
        - ActualCashAmountHint    — label 下方說明文字
        
        Visibility 由內層 Binding 自己讀 sub-VM 的 IsCrossCurrency 控制；
        非跨幣別時整個 UserControl collapse 不占空間。
    -->

    <Border
        Margin="0,14,0,0"
        Padding="12"
        Background="{DynamicResource AppSurface}"
        BorderBrush="{DynamicResource AppBorder}"
        BorderThickness="1"
        CornerRadius="{StaticResource Radius.Sm}">
        <StackPanel>
            <!--  Section header + pair badge  -->
            <Grid>
                <Grid.ColumnDefinitions>
                    <ColumnDefinition Width="*" />
                    <ColumnDefinition Width="Auto" />
                </Grid.ColumnDefinitions>
                <TextBlock
                    Grid.Column="0"
                    FontSize="{StaticResource Font.Size.Sm}"
                    FontWeight="SemiBold"
                    Foreground="{DynamicResource AppTextPrimary}"
                    Text="{DynamicResource Portfolio.Tx.SettlementSection}" />
                <Border
                    Grid.Column="1"
                    Padding="8,3"
                    Background="{DynamicResource AppSurfaceAlt}"
                    BorderBrush="{DynamicResource AppBorder}"
                    BorderThickness="1"
                    CornerRadius="{StaticResource Radius.Sm}">
                    <TextBlock
                        FontSize="{StaticResource Font.Size.Xs}"
                        Foreground="{DynamicResource AppTextSecondary}"
                        Text="{Binding SettlementPairDisplay, Mode=OneWay}" />
                </Border>
            </Grid>

            <!--  Cross-currency short hint  -->
            <TextBlock
                Margin="0,4,0,12"
                FontSize="{StaticResource Font.Size.Xs}"
                Foreground="{DynamicResource AppTextSecondary}"
                Text="{DynamicResource Portfolio.Tx.CrossCurrency.Hint.Short}"
                TextWrapping="Wrap" />

            <!--  Input mode label  -->
            <TextBlock
                Margin="0,0,0,6"
                FontSize="{StaticResource Font.Size.Xs}"
                FontWeight="SemiBold"
                Foreground="{DynamicResource AppTextSecondary}"
                Text="{DynamicResource Portfolio.Tx.SettlementInputMode}" />

            <!--  Mode toggle: 2 borders with RadioButton + hint each  -->
            <Grid Margin="0,0,0,12">
                <Grid.ColumnDefinitions>
                    <ColumnDefinition Width="*" />
                    <ColumnDefinition Width="8" />
                    <ColumnDefinition Width="*" />
                </Grid.ColumnDefinitions>
                <Border
                    Grid.Column="0"
                    Padding="10,9"
                    Background="{DynamicResource AppBackground}"
                    BorderBrush="{DynamicResource AppBorderLight}"
                    BorderThickness="1"
                    CornerRadius="{StaticResource Radius.Sm}">
                    <StackPanel>
                        <RadioButton
                            Content="{DynamicResource Portfolio.Tx.SettlementMode.Statement}"
                            GroupName="{Binding GroupName, ElementName=Root}"
                            IsChecked="{Binding SettlementInputMode, Converter={StaticResource EqualityConverter}, ConverterParameter=statement, Mode=TwoWay}"
                            Style="{StaticResource AppRadioButton}" />
                        <TextBlock
                            Margin="24,4,0,0"
                            FontSize="{StaticResource Font.Size.Xs}"
                            Foreground="{DynamicResource AppTextMuted}"
                            Text="{DynamicResource Portfolio.Tx.SettlementMode.StatementHint}"
                            TextWrapping="Wrap" />
                    </StackPanel>
                </Border>
                <Border
                    Grid.Column="2"
                    Padding="10,9"
                    Background="{DynamicResource AppBackground}"
                    BorderBrush="{DynamicResource AppBorderLight}"
                    BorderThickness="1"
                    CornerRadius="{StaticResource Radius.Sm}">
                    <StackPanel>
                        <RadioButton
                            Content="{DynamicResource Portfolio.Tx.SettlementMode.FxEstimate}"
                            GroupName="{Binding GroupName, ElementName=Root}"
                            IsChecked="{Binding SettlementInputMode, Converter={StaticResource EqualityConverter}, ConverterParameter=fx, Mode=TwoWay}"
                            Style="{StaticResource AppRadioButton}" />
                        <TextBlock
                            Margin="24,4,0,0"
                            FontSize="{StaticResource Font.Size.Xs}"
                            Foreground="{DynamicResource AppTextMuted}"
                            Text="{DynamicResource Portfolio.Tx.SettlementMode.FxEstimateHint}"
                            TextWrapping="Wrap" />
                    </StackPanel>
                </Border>
            </Grid>

            <!--  Statement mode panel: ActualCashAmount input  -->
            <StackPanel Visibility="{Binding IsStatementSettlementMode, Converter={StaticResource BooleanToVisibilityConverter}}">
                <StackPanel Margin="0,0,0,6" Orientation="Horizontal">
                    <TextBlock
                        VerticalAlignment="Center"
                        Style="{StaticResource FormFieldLabel}"
                        Text="{Binding ActualCashAmountLabel, ElementName=Root}" />
                    <Border
                        Margin="6,0,0,0"
                        Padding="6,2"
                        VerticalAlignment="Center"
                        Background="{DynamicResource AppSurfaceAlt}"
                        BorderBrush="{DynamicResource AppBorderLight}"
                        BorderThickness="1"
                        CornerRadius="{StaticResource Radius.Sm}">
                        <TextBlock
                            FontSize="{StaticResource Font.Size.Xs}"
                            Foreground="{DynamicResource AppTextSecondary}"
                            Text="{Binding SettlementCurrencyDisplay, Mode=OneWay}" />
                    </Border>
                </StackPanel>
                <TextBox behaviors:ThousandSeparatorBehavior.IsEnabled="True" Text="{Binding ActualCashAmount, UpdateSourceTrigger=PropertyChanged}" />
                <TextBlock
                    Style="{StaticResource FormFieldError}"
                    Text="{Binding ActualCashAmountError}"
                    Visibility="{Binding ActualCashAmountError, Converter={StaticResource StringToVisibilityConverter}}" />
                <TextBlock
                    Margin="0,2,0,0"
                    FontSize="{StaticResource Font.Size.Xs}"
                    Foreground="{DynamicResource AppTextMuted}"
                    Text="{Binding ActualCashAmountHint, ElementName=Root}"
                    TextWrapping="Wrap" />
            </StackPanel>

            <!--  FX mode panel: FxRate + Fetch button + FxRateDate display + errors + source  -->
            <StackPanel Visibility="{Binding IsFxSettlementMode, Converter={StaticResource BooleanToVisibilityConverter}}">
                <DockPanel Margin="0,0,0,6" LastChildFill="False">
                    <TextBlock
                        VerticalAlignment="Center"
                        DockPanel.Dock="Left"
                        Style="{StaticResource FormFieldLabel}"
                        Text="{DynamicResource Portfolio.Tx.FxRate}" />
                    <Button
                        MinWidth="0"
                        MinHeight="28"
                        Padding="8,0"
                        VerticalAlignment="Center"
                        Command="{Binding FetchFxRateCommand, ElementName=Root}"
                        Content="{DynamicResource Portfolio.Tx.FetchFxRate}"
                        DockPanel.Dock="Right"
                        FontSize="{StaticResource Font.Size.Xs}"
                        Style="{StaticResource AppGhostButton}" />
                </DockPanel>
                <TextBlock
                    Margin="0,0,0,6"
                    FontSize="{StaticResource Font.Size.Xs}"
                    Foreground="{DynamicResource AppTextMuted}"
                    Text="{DynamicResource Portfolio.Tx.FxMode.Hint}"
                    TextWrapping="Wrap" />
                <Grid>
                    <Grid.ColumnDefinitions>
                        <ColumnDefinition Width="*" />
                        <ColumnDefinition Width="12" />
                        <ColumnDefinition Width="*" />
                    </Grid.ColumnDefinitions>
                    <TextBox
                        Grid.Column="0"
                        behaviors:ThousandSeparatorBehavior.IsEnabled="True"
                        Text="{Binding FxRate, UpdateSourceTrigger=PropertyChanged}" />
                    <StackPanel Grid.Column="2">
                        <TextBlock Style="{StaticResource FormFieldLabel}" Text="{DynamicResource Portfolio.Tx.FxRateDate}" />
                        <Border
                            MinHeight="{StaticResource Control.Height.Md}"
                            Padding="10,0"
                            Background="{DynamicResource AppSurfaceAlt}"
                            BorderBrush="{DynamicResource AppBorder}"
                            BorderThickness="1"
                            CornerRadius="{StaticResource Radius.Sm}">
                            <TextBlock
                                VerticalAlignment="Center"
                                FontSize="{StaticResource Font.Size.Sm}"
                                Foreground="{DynamicResource AppTextSecondary}"
                                Text="{Binding FxRateDateDisplay, Mode=OneWay}" />
                        </Border>
                    </StackPanel>
                </Grid>
                <TextBlock
                    Style="{StaticResource FormFieldError}"
                    Text="{Binding FxRateError}"
                    Visibility="{Binding FxRateError, Converter={StaticResource StringToVisibilityConverter}}" />
                <TextBlock
                    Style="{StaticResource FormFieldError}"
                    Text="{Binding FxFetchError}"
                    Visibility="{Binding FxFetchError, Converter={StaticResource StringToVisibilityConverter}}" />
                <TextBlock
                    Margin="0,4,0,0"
                    FontSize="{StaticResource Font.Size.Xs}"
                    Foreground="{DynamicResource AppTextMuted}">
                    <Run Text="{DynamicResource Portfolio.Tx.FxSource}" />
                    <Run Text=": " />
                    <Run Text="{Binding FxSourceDisplay, Mode=OneWay}" />
                </TextBlock>
            </StackPanel>
        </StackPanel>
    </Border>
</UserControl>
