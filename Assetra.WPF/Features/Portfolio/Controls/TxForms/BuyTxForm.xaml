<UserControl
    x:Class="Assetra.WPF.Features.Portfolio.Controls.TxForms.BuyTxForm"
    xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
    xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
    xmlns:behaviors="clr-namespace:Assetra.WPF.Infrastructure.Behaviors"
    xmlns:d="http://schemas.microsoft.com/expression/blend/2008"
    xmlns:mc="http://schemas.openxmlformats.org/markup-compatibility/2006"
    xmlns:vm="clr-namespace:Assetra.WPF.Features.Portfolio.SubViewModels"
    d:DataContext="{d:DesignInstance Type={x:Type vm:TransactionDialogViewModel},
                                     IsDesignTimeCreatable=False}"
    mc:Ignorable="d">

    <!--  ======== 買入欄位 ========  -->
    <StackPanel Visibility="{Binding TxTypeIsBuy, Converter={StaticResource BooleanToVisibilityConverter}}">
        <!--  Asset type selector (ComboBox)  -->
        <TextBlock
            Margin="0,0,0,4"
            FontSize="{StaticResource FontSizeXs}"
            FontWeight="SemiBold"
            Foreground="{DynamicResource AppTextSecondary}"
            Text="{DynamicResource Portfolio.AssetType}" />
        <ComboBox
            Margin="0,0,0,12"
            SelectedValue="{Binding TxBuyAssetType, Mode=TwoWay}"
            SelectedValuePath="Tag"
            Style="{StaticResource FormComboBox}">
            <ComboBox.Resources>
                <Style BasedOn="{StaticResource FormComboBoxItem}" TargetType="ComboBoxItem" />
            </ComboBox.Resources>
            <ComboBoxItem Content="{DynamicResource Portfolio.Dialog.TypeStock}" Tag="stock" />
            <ComboBoxItem Content="{DynamicResource Portfolio.Dialog.TypeFund}" Tag="fund" />
            <ComboBoxItem Content="{DynamicResource Portfolio.Dialog.TypeMetal}" Tag="metal" />
            <ComboBoxItem Content="{DynamicResource Portfolio.Dialog.TypeBond}" Tag="bond" />
            <ComboBoxItem Content="{DynamicResource Portfolio.Dialog.TypeCrypto}" Tag="crypto" />
        </ComboBox>

        <!--  Stock/ETF: Symbol + autocomplete  -->
        <StackPanel d:Visibility="Visible" Visibility="{Binding TxBuyIsStock, Converter={StaticResource BooleanToVisibilityConverter}}">
            <!--  Dual-mode toggle: full Buy trade vs. metadata-only (Task 18 Option B) — Stock only  -->
            <TextBlock
                Margin="0,0,0,4"
                FontSize="{StaticResource FontSizeXs}"
                FontWeight="SemiBold"
                Foreground="{DynamicResource AppTextSecondary}"
                Text="{DynamicResource Portfolio.Tx.BuyMode}" />
            <StackPanel Margin="0,0,0,12" Orientation="Horizontal">
                <RadioButton
                    Content="{DynamicResource Portfolio.Tx.BuyModeFull}"
                    GroupName="TxBuyMode"
                    IsChecked="True"
                    Style="{StaticResource SegmentBtn}" />
                <RadioButton
                    Margin="6,0,0,0"
                    Content="{DynamicResource Portfolio.Tx.BuyModeMetaOnly}"
                    GroupName="TxBuyMode"
                    IsChecked="{Binding TxBuyMetaOnly, Mode=TwoWay}"
                    Style="{StaticResource SegmentBtn}" />
            </StackPanel>

            <TextBlock
                Margin="0,0,0,4"
                FontSize="{StaticResource FontSizeXs}"
                FontWeight="SemiBold"
                Foreground="{DynamicResource AppTextSecondary}"
                Text="{DynamicResource Portfolio.Symbol}" />
            <Grid Margin="0,0,0,12">
                <TextBox
                    x:Name="TxSymbolBox"
                    IsEnabled="{Binding AreEconomicFieldsEditable}"
                    Style="{StaticResource FormTextBox}"
                    Text="{Binding AddAssetDialog.AddSymbol, UpdateSourceTrigger=PropertyChanged}" />
                <Popup
                    Width="{Binding ActualWidth, ElementName=TxSymbolBox}"
                    AllowsTransparency="True"
                    IsOpen="{Binding AddAssetDialog.IsSuggestionsOpen}"
                    Placement="Bottom"
                    PlacementTarget="{Binding ElementName=TxSymbolBox}"
                    StaysOpen="True">
                    <Border
                        Background="{DynamicResource AppSurface}"
                        BorderBrush="{DynamicResource AppBorder}"
                        BorderThickness="1"
                        CornerRadius="{StaticResource RadiusSm}">
                        <ListBox
                            MaxHeight="240"
                            Background="Transparent"
                            BorderThickness="0"
                            ItemsSource="{Binding AddAssetDialog.SymbolSuggestions}"
                            ScrollViewer.HorizontalScrollBarVisibility="Disabled"
                            SelectedItem="{Binding AddAssetDialog.SelectedSuggestion, Mode=TwoWay}">
                            <ListBox.ItemContainerStyle>
                                <Style TargetType="ListBoxItem">
                                    <Setter Property="Padding" Value="10,6" />
                                    <Setter Property="Background" Value="Transparent" />
                                    <Setter Property="BorderThickness" Value="0" />
                                    <Setter Property="HorizontalContentAlignment" Value="Stretch" />
                                    <Setter Property="FocusVisualStyle" Value="{x:Null}" />
                                    <Style.Triggers>
                                        <Trigger Property="IsMouseOver" Value="True">
                                            <Setter Property="Background" Value="{DynamicResource AppHover}" />
                                        </Trigger>
                                    </Style.Triggers>
                                </Style>
                            </ListBox.ItemContainerStyle>
                            <ListBox.ItemTemplate>
                                <DataTemplate>
                                    <Grid>
                                        <Grid.ColumnDefinitions>
                                            <ColumnDefinition Width="56" />
                                            <ColumnDefinition Width="*" />
                                            <ColumnDefinition Width="Auto" />
                                        </Grid.ColumnDefinitions>
                                        <TextBlock
                                            Grid.Column="0"
                                            VerticalAlignment="Center"
                                            FontFamily="{StaticResource FontTabular}"
                                            FontSize="{StaticResource FontSizeSm}"
                                            FontWeight="SemiBold"
                                            Foreground="{DynamicResource AppAccent}"
                                            Text="{Binding Symbol}" />
                                        <TextBlock
                                            Grid.Column="1"
                                            VerticalAlignment="Center"
                                            FontSize="{StaticResource FontSizeSm}"
                                            Foreground="{DynamicResource AppTextPrimary}"
                                            Text="{Binding Name}"
                                            TextTrimming="CharacterEllipsis" />
                                        <Border
                                            Grid.Column="2"
                                            Padding="4,1"
                                            VerticalAlignment="Center"
                                            Background="{DynamicResource AppBackground}"
                                            CornerRadius="{StaticResource RadiusSm}">
                                            <TextBlock
                                                FontSize="{StaticResource FontSizeXs}"
                                                Foreground="{DynamicResource AppTextMuted}"
                                                Text="{Binding Exchange}" />
                                        </Border>
                                    </Grid>
                                </DataTemplate>
                            </ListBox.ItemTemplate>
                        </ListBox>
                    </Border>
                </Popup>
            </Grid>

            <!--  Economic fields — hidden in meta-only mode  -->
            <StackPanel>
                <StackPanel.Style>
                    <Style TargetType="StackPanel">
                        <Setter Property="Visibility" Value="Visible" />
                        <Style.Triggers>
                            <DataTrigger Binding="{Binding TxBuyMetaOnly}" Value="True">
                                <Setter Property="Visibility" Value="Collapsed" />
                            </DataTrigger>
                        </Style.Triggers>
                    </Style>
                </StackPanel.Style>

                <!--  價格輸入模式 toggle: 單價 vs 總額 (AscentPortfolio pattern)  -->
                <TextBlock
                    Margin="0,0,0,4"
                    FontSize="{StaticResource FontSizeXs}"
                    FontWeight="SemiBold"
                    Foreground="{DynamicResource AppTextSecondary}"
                    Text="{DynamicResource Portfolio.Tx.PriceMode}" />
                <StackPanel Margin="0,0,0,8" Orientation="Horizontal">
                    <RadioButton
                        Content="{DynamicResource Portfolio.Tx.PriceModeUnit}"
                        GroupName="TxBuyPriceMode"
                        IsChecked="{Binding TxBuyPriceMode, Converter={StaticResource EqualityConverter}, ConverterParameter=unit, Mode=TwoWay}"
                        IsEnabled="{Binding AreEconomicFieldsEditable}"
                        Style="{StaticResource SegmentBtn}" />
                    <RadioButton
                        Margin="6,0,0,0"
                        Content="{DynamicResource Portfolio.Tx.PriceModeTotal}"
                        GroupName="TxBuyPriceMode"
                        IsChecked="{Binding TxBuyPriceMode, Converter={StaticResource EqualityConverter}, ConverterParameter=total, Mode=TwoWay}"
                        IsEnabled="{Binding AreEconomicFieldsEditable}"
                        Style="{StaticResource SegmentBtn}" />
                </StackPanel>

                <!--  單價輸入 (在 unit mode 顯示)  -->
                <StackPanel d:Visibility="Visible" Visibility="{Binding TxBuyIsUnitMode, Converter={StaticResource BooleanToVisibilityConverter}}">
                    <TextBlock
                        Margin="0,0,0,4"
                        FontSize="{StaticResource FontSizeXs}"
                        FontWeight="SemiBold"
                        Foreground="{DynamicResource AppTextSecondary}"
                        Text="{DynamicResource Portfolio.AddPrice}" />
                    <TextBox
                        behaviors:ThousandSeparatorBehavior.IsEnabled="True"
                        IsEnabled="{Binding AreEconomicFieldsEditable}"
                        Style="{StaticResource FormTextBox}"
                        Text="{Binding AddAssetDialog.AddPrice, UpdateSourceTrigger=PropertyChanged}" />
                    <TextBlock
                        Style="{StaticResource FormFieldError}"
                        Text="{Binding AddAssetDialog.AddPriceError}"
                        Visibility="{Binding AddAssetDialog.AddPriceError, Converter={StaticResource StringToVisibilityConverter}}" />
                    <TextBlock
                        Margin="0,2,0,8"
                        FontSize="{StaticResource FontSizeXs}"
                        Foreground="{DynamicResource AppTextMuted}"
                        Text="{Binding AddAssetDialog.ClosePriceHint}"
                        Visibility="{Binding AddAssetDialog.ClosePriceHint, Converter={StaticResource StringToVisibilityConverter}}" />
                </StackPanel>

                <!--  總額輸入 (在 total mode 顯示)  -->
                <StackPanel d:Visibility="Collapsed" Visibility="{Binding TxBuyIsTotalMode, Converter={StaticResource BooleanToVisibilityConverter}}">
                    <TextBlock
                        Margin="0,0,0,4"
                        FontSize="{StaticResource FontSizeXs}"
                        FontWeight="SemiBold"
                        Foreground="{DynamicResource AppTextSecondary}"
                        Text="{DynamicResource Portfolio.Tx.TotalAmount}" />
                    <TextBox
                        behaviors:ThousandSeparatorBehavior.IsEnabled="True"
                        IsEnabled="{Binding AreEconomicFieldsEditable}"
                        Style="{StaticResource FormTextBox}"
                        Text="{Binding TxBuyTotalCost, UpdateSourceTrigger=PropertyChanged}" />
                    <TextBlock
                        Margin="0,0,0,8"
                        Style="{StaticResource FormFieldError}"
                        Text="{Binding TxBuyTotalCostError}"
                        Visibility="{Binding TxBuyTotalCostError, Converter={StaticResource StringToVisibilityConverter}}" />
                </StackPanel>

                <TextBlock
                    Margin="0,0,0,4"
                    FontSize="{StaticResource FontSizeXs}"
                    FontWeight="SemiBold"
                    Foreground="{DynamicResource AppTextSecondary}"
                    Text="{DynamicResource Portfolio.AddQuantity}" />
                <TextBox
                    behaviors:ThousandSeparatorBehavior.IsEnabled="True"
                    IsEnabled="{Binding AreEconomicFieldsEditable}"
                    Style="{StaticResource FormTextBox}"
                    Text="{Binding AddAssetDialog.AddQuantity, UpdateSourceTrigger=PropertyChanged}" />
                <TextBlock
                    Margin="0,0,0,4"
                    Style="{StaticResource FormFieldError}"
                    Text="{Binding AddAssetDialog.AddQuantityError}"
                    Visibility="{Binding AddAssetDialog.AddQuantityError, Converter={StaticResource StringToVisibilityConverter}}" />

                <TextBlock
                    Margin="0,0,0,4"
                    FontSize="{StaticResource FontSizeXs}"
                    FontWeight="SemiBold"
                    Foreground="{DynamicResource AppTextSecondary}"
                    Text="{DynamicResource Portfolio.Tx.CommissionDiscount}" />
                <Grid>
                    <Grid.ColumnDefinitions>
                        <ColumnDefinition Width="80" />
                        <ColumnDefinition Width="*" />
                    </Grid.ColumnDefinitions>
                    <TextBox
                        Grid.Column="0"
                        Style="{StaticResource FormTextBox}"
                        Text="{Binding TxCommissionDiscount, UpdateSourceTrigger=PropertyChanged}" />
                    <TextBlock
                        Grid.Column="1"
                        Margin="8,0,0,0"
                        VerticalAlignment="Center"
                        FontSize="{StaticResource FontSizeXs}"
                        Foreground="{DynamicResource AppTextMuted}"
                        Text="{DynamicResource Portfolio.Tx.CommissionDiscountHint}" />
                </Grid>
                <TextBlock
                    Margin="0,0,0,12"
                    Style="{StaticResource FormFieldError}"
                    Text="{Binding TxCommissionDiscountError}"
                    Visibility="{Binding TxCommissionDiscountError, Converter={StaticResource StringToVisibilityConverter}}" />

                <!--  Fee preview  -->
                <Border
                    Margin="0,0,0,8"
                    Padding="10,8"
                    Background="{DynamicResource AppBackground}"
                    BorderBrush="{DynamicResource AppBorder}"
                    BorderThickness="1"
                    CornerRadius="{StaticResource RadiusSm}"
                    Visibility="{Binding AddAssetDialog.HasAddPreview, Converter={StaticResource BooleanToVisibilityConverter}}">
                    <Grid>
                        <Grid.ColumnDefinitions>
                            <ColumnDefinition Width="*" />
                            <ColumnDefinition Width="Auto" />
                        </Grid.ColumnDefinitions>
                        <Grid.RowDefinitions>
                            <RowDefinition Height="Auto" />
                            <RowDefinition Height="Auto" />
                            <RowDefinition Height="6" />
                            <RowDefinition Height="Auto" />
                            <RowDefinition Height="Auto" />
                        </Grid.RowDefinitions>
                        <TextBlock
                            Grid.Row="0"
                            Grid.Column="0"
                            FontSize="{StaticResource FontSizeXs}"
                            Foreground="{DynamicResource AppTextMuted}"
                            Text="{DynamicResource Portfolio.Add.GrossAmount}" />
                        <TextBlock
                            Grid.Row="0"
                            Grid.Column="1"
                            FontFamily="{StaticResource FontTabular}"
                            FontSize="{StaticResource FontSizeXs}"
                            Foreground="{DynamicResource AppTextSecondary}"
                            Text="{Binding AddAssetDialog.AddGrossAmount, StringFormat={}{0:N0}}" />
                        <TextBlock
                            Grid.Row="1"
                            Grid.Column="0"
                            FontSize="{StaticResource FontSizeXs}"
                            Foreground="{DynamicResource AppTextMuted}"
                            Text="{DynamicResource Portfolio.Add.Commission}" />
                        <TextBlock
                            Grid.Row="1"
                            Grid.Column="1"
                            FontFamily="{StaticResource FontTabular}"
                            FontSize="{StaticResource FontSizeXs}"
                            Foreground="{DynamicResource AppDown}"
                            Text="{Binding AddAssetDialog.AddCommission, StringFormat=+{0:N0}}" />
                        <Rectangle
                            Grid.Row="2"
                            Grid.Column="0"
                            Grid.ColumnSpan="2"
                            Margin="0,1"
                            Fill="{DynamicResource AppBorder}" />
                        <TextBlock
                            Grid.Row="3"
                            Grid.Column="0"
                            FontSize="{StaticResource FontSizeXs}"
                            FontWeight="SemiBold"
                            Foreground="{DynamicResource AppTextSecondary}"
                            Text="{DynamicResource Portfolio.Add.TotalCost}" />
                        <TextBlock
                            Grid.Row="3"
                            Grid.Column="1"
                            FontFamily="{StaticResource FontTabular}"
                            FontSize="{StaticResource FontSizeXs}"
                            FontWeight="SemiBold"
                            Foreground="{DynamicResource AppTextPrimary}"
                            Text="{Binding AddAssetDialog.AddTotalCost, StringFormat={}{0:N0}}" />
                        <TextBlock
                            Grid.Row="4"
                            Grid.Column="0"
                            Margin="0,2,0,0"
                            FontSize="{StaticResource FontSizeXs}"
                            Foreground="{DynamicResource AppTextMuted}"
                            Text="{DynamicResource Portfolio.Add.CostPerShare}" />
                        <TextBlock
                            Grid.Row="4"
                            Grid.Column="1"
                            Margin="0,2,0,0"
                            FontFamily="{StaticResource FontTabular}"
                            FontSize="{StaticResource FontSizeXs}"
                            Foreground="{DynamicResource AppTextMuted}"
                            Text="{Binding AddAssetDialog.AddCostPerShare, StringFormat={}{0:F4}}" />
                    </Grid>
                </Border>
            </StackPanel>
        </StackPanel>

        <!--  Non-stock (Fund/Metal/Bond): Name + Cost  -->
        <StackPanel Visibility="{Binding TxBuyIsNonStock, Converter={StaticResource BooleanToVisibilityConverter}}">
            <TextBlock
                Margin="0,0,0,4"
                FontSize="{StaticResource FontSizeXs}"
                FontWeight="SemiBold"
                Foreground="{DynamicResource AppTextSecondary}"
                Text="{DynamicResource Portfolio.Dialog.AddName}" />
            <TextBox
                Margin="0,0,0,12"
                Style="{StaticResource FormTextBox}"
                Text="{Binding AddAssetDialog.AddName, UpdateSourceTrigger=PropertyChanged}" />
            <TextBlock
                Margin="0,0,0,4"
                FontSize="{StaticResource FontSizeXs}"
                FontWeight="SemiBold"
                Foreground="{DynamicResource AppTextSecondary}"
                Text="{DynamicResource Portfolio.Dialog.AddCost}" />
            <TextBox
                behaviors:ThousandSeparatorBehavior.IsEnabled="True"
                Style="{StaticResource FormTextBox}"
                Text="{Binding AddAssetDialog.AddCost, UpdateSourceTrigger=PropertyChanged}" />
            <TextBlock
                Style="{StaticResource FormFieldError}"
                Text="{Binding AddAssetDialog.AddCostError}"
                Visibility="{Binding AddAssetDialog.AddCostError, Converter={StaticResource StringToVisibilityConverter}}" />
        </StackPanel>

        <!--  Crypto: Symbol + Qty + Price  -->
        <StackPanel Visibility="{Binding TxBuyIsCrypto, Converter={StaticResource BooleanToVisibilityConverter}}">
            <TextBlock
                Margin="0,0,0,4"
                FontSize="{StaticResource FontSizeXs}"
                FontWeight="SemiBold"
                Foreground="{DynamicResource AppTextSecondary}"
                Text="{DynamicResource Portfolio.Dialog.CryptoSymbol}" />
            <TextBox
                Margin="0,0,0,12"
                Style="{StaticResource FormTextBox}"
                Text="{Binding AddAssetDialog.AddCryptoSymbol, UpdateSourceTrigger=PropertyChanged}" />
            <TextBlock
                Margin="0,0,0,4"
                FontSize="{StaticResource FontSizeXs}"
                FontWeight="SemiBold"
                Foreground="{DynamicResource AppTextSecondary}"
                Text="{DynamicResource Portfolio.Dialog.CryptoQty}" />
            <TextBox
                behaviors:ThousandSeparatorBehavior.IsEnabled="True"
                Style="{StaticResource FormTextBox}"
                Text="{Binding AddAssetDialog.AddCryptoQty, UpdateSourceTrigger=PropertyChanged}" />
            <TextBlock
                Style="{StaticResource FormFieldError}"
                Text="{Binding AddAssetDialog.AddCryptoQtyError}"
                Visibility="{Binding AddAssetDialog.AddCryptoQtyError, Converter={StaticResource StringToVisibilityConverter}}" />
            <TextBlock
                Margin="0,12,0,4"
                FontSize="{StaticResource FontSizeXs}"
                FontWeight="SemiBold"
                Foreground="{DynamicResource AppTextSecondary}"
                Text="{DynamicResource Portfolio.Dialog.CryptoPrice}" />
            <TextBox
                behaviors:ThousandSeparatorBehavior.IsEnabled="True"
                Style="{StaticResource FormTextBox}"
                Text="{Binding AddAssetDialog.AddCryptoPrice, UpdateSourceTrigger=PropertyChanged}" />
            <TextBlock
                Style="{StaticResource FormFieldError}"
                Text="{Binding AddAssetDialog.AddCryptoPriceError}"
                Visibility="{Binding AddAssetDialog.AddCryptoPriceError, Converter={StaticResource StringToVisibilityConverter}}" />
        </StackPanel>

        <!--  Fee + cash-account — hidden in meta-only mode  -->
        <StackPanel>
            <StackPanel.Style>
                <Style TargetType="StackPanel">
                    <Setter Property="Visibility" Value="Visible" />
                    <Style.Triggers>
                        <DataTrigger Binding="{Binding TxBuyMetaOnly}" Value="True">
                            <Setter Property="Visibility" Value="Collapsed" />
                        </DataTrigger>
                    </Style.Triggers>
                </Style>
            </StackPanel.Style>

            <!--  手續費 (manual override; 留空 → 走 TxCommissionDiscount 自動計算)  -->
            <TextBlock
                Margin="0,12,0,4"
                FontSize="{StaticResource FontSizeXs}"
                FontWeight="SemiBold"
                Foreground="{DynamicResource AppTextSecondary}"
                Text="{DynamicResource Portfolio.Tx.Fee}" />
            <TextBox
                behaviors:ThousandSeparatorBehavior.IsEnabled="True"
                Style="{StaticResource FormTextBox}"
                Text="{Binding TxFee, UpdateSourceTrigger=PropertyChanged}" />
            <TextBlock
                Style="{StaticResource FormFieldError}"
                Text="{Binding TxFeeError}"
                Visibility="{Binding TxFeeError, Converter={StaticResource StringToVisibilityConverter}}" />
            <TextBlock
                Margin="0,2,0,12"
                FontSize="{StaticResource FontSizeXs}"
                Foreground="{DynamicResource AppTextMuted}"
                Text="{DynamicResource Portfolio.Tx.FeeOverrideHint}"
                TextWrapping="Wrap" />

            <!--  從現金帳戶扣款 — checkbox + dropdown (一致 with 借款/還款 / Transfer)  -->
            <CheckBox
                Margin="0,0,0,4"
                Content="{DynamicResource Portfolio.Tx.UseLoanCashAccount}"
                FontSize="{StaticResource FontSizeXs}"
                Foreground="{DynamicResource AppTextSecondary}"
                IsChecked="{Binding TxUseCashAccount, Mode=TwoWay}" />
            <StackPanel Visibility="{Binding TxUseCashAccount, Converter={StaticResource BooleanToVisibilityConverter}}">
                <TextBlock
                    Margin="0,0,0,4"
                    FontSize="{StaticResource FontSizeXs}"
                    FontWeight="SemiBold"
                    Foreground="{DynamicResource AppTextSecondary}"
                    Text="{DynamicResource Portfolio.Tx.LoanCashAccount}" />
                <ComboBox
                    Margin="0,0,0,4"
                    DisplayMemberPath="Name"
                    IsEditable="True"
                    IsTextSearchEnabled="True"
                    ItemsSource="{Binding CashAccounts}"
                    SelectedItem="{Binding TxCashAccount, Mode=TwoWay}"
                    Style="{StaticResource FormComboBox}"
                    Text="{Binding TxCashAccountName, UpdateSourceTrigger=PropertyChanged, Mode=TwoWay}">
                    <ComboBox.Resources>
                        <Style BasedOn="{StaticResource FormComboBoxItem}" TargetType="ComboBoxItem" />
                    </ComboBox.Resources>
                </ComboBox>
                <TextBlock
                    Margin="0,2,0,0"
                    FontSize="{StaticResource FontSizeXs}"
                    Foreground="{DynamicResource AppAccent}"
                    Text="{DynamicResource Portfolio.Tx.WillCreateNew}"
                    Visibility="{Binding IsNewCashAccount, Converter={StaticResource BooleanToVisibilityConverter}}" />
            </StackPanel>
        </StackPanel>
    </StackPanel>
</UserControl>
