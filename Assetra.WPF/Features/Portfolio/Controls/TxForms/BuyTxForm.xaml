<UserControl
    x:Class="Assetra.WPF.Features.Portfolio.Controls.TxForms.BuyTxForm"
    xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
    xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
    xmlns:behaviors="clr-namespace:Assetra.WPF.Infrastructure.Behaviors"
    xmlns:d="http://schemas.microsoft.com/expression/blend/2008"
    xmlns:mc="http://schemas.openxmlformats.org/markup-compatibility/2006"
    xmlns:vm="clr-namespace:Assetra.WPF.Features.Portfolio.SubViewModels"
    x:Name="Root"
    d:DataContext="{d:DesignInstance Type={x:Type vm:TransactionDialogViewModel}}"
    mc:Ignorable="d">

    <!--  ======== 買入欄位 ========  -->
    <StackPanel Visibility="{Binding TxTypeIsBuy, Converter={StaticResource BooleanToVisibilityConverter}}">
        <!--  Asset type selector (ComboBox)  -->
        <TextBlock
            Margin="0,0,0,4"
            FontSize="{StaticResource Font.Size.Xs}"
            FontWeight="SemiBold"
            Foreground="{DynamicResource AppTextSecondary}"
            Text="{DynamicResource Portfolio.AssetType}" />
        <ComboBox
            Margin="0,0,0,12"
            SelectedValue="{Binding Buy.AssetType, Mode=TwoWay}"
            SelectedValuePath="Tag"
            Style="{StaticResource FormComboBox}">
            <ComboBox.Resources>
                <Style BasedOn="{StaticResource FormComboBoxItem}" TargetType="ComboBoxItem" />
            </ComboBox.Resources>
            <ComboBoxItem Content="{DynamicResource Portfolio.Dialog.TypeStock}" Tag="stock" />
            <ComboBoxItem Content="{DynamicResource Portfolio.Dialog.TypeFund}" Tag="fund" />
            <ComboBoxItem Content="{DynamicResource Portfolio.Dialog.TypeMetal}" Tag="metal" />
            <ComboBoxItem Content="{DynamicResource Portfolio.Dialog.TypeBond}" Tag="bond" />
            <ComboBoxItem Content="{DynamicResource Portfolio.Dialog.TypeCrypto}" Tag="crypto" />
        </ComboBox>

        <!--  Stock/ETF: Symbol + autocomplete  -->
        <StackPanel d:Visibility="Visible" Visibility="{Binding Buy.IsStock, Converter={StaticResource BooleanToVisibilityConverter}}">
            <!--  Dual-mode toggle: full Buy trade vs. metadata-only (Task 18 Option B) — Stock only  -->
            <TextBlock
                Margin="0,0,0,4"
                FontSize="{StaticResource Font.Size.Xs}"
                FontWeight="SemiBold"
                Foreground="{DynamicResource AppTextSecondary}"
                Text="{DynamicResource Portfolio.Tx.BuyMode}" />
            <Grid Margin="0,0,0,12">
                <Grid.ColumnDefinitions>
                    <ColumnDefinition Width="*" />
                    <ColumnDefinition Width="*" />
                </Grid.ColumnDefinitions>
                <RadioButton
                    Grid.Column="0"
                    Margin="0,0,3,0"
                    HorizontalAlignment="Stretch"
                    HorizontalContentAlignment="Center"
                    Content="{DynamicResource Portfolio.Tx.BuyModeFull}"
                    GroupName="TxBuyMode"
                    IsChecked="True"
                    Style="{StaticResource SegmentBtn}" />
                <RadioButton
                    Grid.Column="1"
                    Margin="3,0,0,0"
                    HorizontalAlignment="Stretch"
                    HorizontalContentAlignment="Center"
                    Content="{DynamicResource Portfolio.Tx.BuyModeMetaOnly}"
                    GroupName="TxBuyMode"
                    IsChecked="{Binding Buy.MetaOnly, Mode=TwoWay}"
                    Style="{StaticResource SegmentBtn}" />
            </Grid>

            <TextBlock
                Margin="0,0,0,4"
                FontSize="{StaticResource Font.Size.Xs}"
                FontWeight="SemiBold"
                Foreground="{DynamicResource AppTextSecondary}"
                Text="{DynamicResource Portfolio.Symbol}" />
            <Grid Margin="0,0,0,12">
                <TextBox
                    x:Name="TxSymbolBox"
                    IsEnabled="{Binding AreEconomicFieldsEditable}"
                    Text="{Binding AddAssetDialog.AddSymbol, UpdateSourceTrigger=PropertyChanged}" />
                <Popup
                    Width="{Binding ActualWidth, ElementName=TxSymbolBox}"
                    AllowsTransparency="True"
                    IsOpen="{Binding AddAssetDialog.IsSuggestionsOpen}"
                    Placement="Bottom"
                    PlacementTarget="{Binding ElementName=TxSymbolBox}"
                    StaysOpen="True">
                    <Border
                        Background="{DynamicResource AppSurface}"
                        BorderBrush="{DynamicResource AppBorder}"
                        BorderThickness="1"
                        CornerRadius="{StaticResource Radius.Sm}">
                        <ListBox
                            MaxHeight="240"
                            Background="Transparent"
                            BorderThickness="0"
                            ItemContainerStyle="{StaticResource StockSuggestionListBoxItemStyle}"
                            ItemTemplate="{StaticResource StockSuggestionItemTemplate}"
                            ItemsSource="{Binding AddAssetDialog.SymbolSuggestions}"
                            ScrollViewer.HorizontalScrollBarVisibility="Disabled"
                            SelectedItem="{Binding AddAssetDialog.SelectedSuggestion, Mode=TwoWay}" />
                    </Border>
                </Popup>
            </Grid>

            <!--  Economic fields — hidden in meta-only mode  -->
            <StackPanel>
                <StackPanel.Style>
                    <Style TargetType="StackPanel">
                        <Setter Property="Visibility" Value="Visible" />
                        <Style.Triggers>
                            <DataTrigger Binding="{Binding Buy.MetaOnly}" Value="True">
                                <Setter Property="Visibility" Value="Collapsed" />
                            </DataTrigger>
                        </Style.Triggers>
                    </Style>
                </StackPanel.Style>

                <!--  價格輸入模式 toggle: 單價 vs 總額 (AscentPortfolio pattern)  -->
                <TextBlock
                    Margin="0,0,0,4"
                    FontSize="{StaticResource Font.Size.Xs}"
                    FontWeight="SemiBold"
                    Foreground="{DynamicResource AppTextSecondary}"
                    Text="{DynamicResource Portfolio.Tx.PriceMode}" />
                <Grid Margin="0,0,0,8">
                    <Grid.ColumnDefinitions>
                        <ColumnDefinition Width="*" />
                        <ColumnDefinition Width="*" />
                    </Grid.ColumnDefinitions>
                    <RadioButton
                        Grid.Column="0"
                        Margin="0,0,3,0"
                        HorizontalAlignment="Stretch"
                        HorizontalContentAlignment="Center"
                        Content="{DynamicResource Portfolio.Tx.PriceModeUnit}"
                        GroupName="TxBuyPriceMode"
                        IsChecked="{Binding Buy.PriceMode, Converter={StaticResource EqualityConverter}, ConverterParameter=unit, Mode=TwoWay}"
                        IsEnabled="{Binding AreEconomicFieldsEditable}"
                        Style="{StaticResource SegmentBtn}" />
                    <RadioButton
                        Grid.Column="1"
                        Margin="3,0,0,0"
                        HorizontalAlignment="Stretch"
                        HorizontalContentAlignment="Center"
                        Content="{DynamicResource Portfolio.Tx.PriceModeTotal}"
                        GroupName="TxBuyPriceMode"
                        IsChecked="{Binding Buy.PriceMode, Converter={StaticResource EqualityConverter}, ConverterParameter=total, Mode=TwoWay}"
                        IsEnabled="{Binding AreEconomicFieldsEditable}"
                        Style="{StaticResource SegmentBtn}" />
                </Grid>

                <!--  單價輸入 (在 unit mode 顯示)  -->
                <StackPanel d:Visibility="Visible" Visibility="{Binding Buy.IsUnitMode, Converter={StaticResource BooleanToVisibilityConverter}}">
                    <!--
                        Label + instrument-currency badge — badge 在標的計價為 USD/JPY/HKD 等
                        非 TWD 時才出現（同幣別不渲染避免干擾）。MultiCurrency-Trade-Refactor P3.
                    -->
                    <StackPanel Margin="0,0,0,4" Orientation="Horizontal">
                        <TextBlock
                            FontSize="{StaticResource Font.Size.Xs}"
                            FontWeight="SemiBold"
                            Foreground="{DynamicResource AppTextSecondary}"
                            Text="{DynamicResource Portfolio.AddPrice}" />
                        <TextBlock
                            Margin="6,0,0,0"
                            FontSize="{StaticResource Font.Size.Xs}"
                            Foreground="{DynamicResource AppAccent}"
                            Text="{Binding Buy.InstrumentCurrencyBadge}"
                            Visibility="{Binding Buy.InstrumentCurrencyBadge, Converter={StaticResource StringToVisibilityConverter}}" />
                    </StackPanel>
                    <TextBox
                        behaviors:ThousandSeparatorBehavior.IsEnabled="True"
                        IsEnabled="{Binding AreEconomicFieldsEditable}"
                        Text="{Binding AddAssetDialog.AddPrice, UpdateSourceTrigger=PropertyChanged}" />
                    <TextBlock
                        Style="{StaticResource FormFieldError}"
                        Text="{Binding AddAssetDialog.AddPriceError}"
                        Visibility="{Binding AddAssetDialog.AddPriceError, Converter={StaticResource StringToVisibilityConverter}}" />
                    <TextBlock
                        Margin="0,2,0,2"
                        FontSize="{StaticResource Font.Size.Xs}"
                        Foreground="{DynamicResource AppTextMuted}"
                        Text="{Binding AddAssetDialog.ClosePriceHint}"
                        Visibility="{Binding AddAssetDialog.ClosePriceHint, Converter={StaticResource StringToVisibilityConverter}}" />
                    <!--
                        Mode C hint — 成交價可留空，由實際扣款 + 股數反推。
                        永遠顯示在 unit-mode 下，提示使用者偷懶選項。
                        MultiCurrency-Trade-Refactor P3.
                    -->
                    <TextBlock
                        Margin="0,2,0,8"
                        FontSize="{StaticResource Font.Size.Xs}"
                        Foreground="{DynamicResource AppTextMuted}"
                        Text="{DynamicResource Portfolio.AddPrice.OptionalHint}"
                        TextWrapping="Wrap" />
                </StackPanel>

                <!--  總額輸入 (在 total mode 顯示)  -->
                <StackPanel d:Visibility="Collapsed" Visibility="{Binding Buy.IsTotalMode, Converter={StaticResource BooleanToVisibilityConverter}}">
                    <TextBlock
                        Margin="0,0,0,4"
                        FontSize="{StaticResource Font.Size.Xs}"
                        FontWeight="SemiBold"
                        Foreground="{DynamicResource AppTextSecondary}"
                        Text="{DynamicResource Portfolio.Tx.TotalAmount}" />
                    <TextBox
                        behaviors:ThousandSeparatorBehavior.IsEnabled="True"
                        IsEnabled="{Binding AreEconomicFieldsEditable}"
                        Text="{Binding Buy.TotalCost, UpdateSourceTrigger=PropertyChanged}" />
                    <TextBlock
                        Margin="0,0,0,4"
                        Style="{StaticResource FormFieldError}"
                        Text="{Binding Buy.TotalCostError}"
                        Visibility="{Binding Buy.TotalCostError, Converter={StaticResource StringToVisibilityConverter}}" />
                    <!--
                        多數券商的成交回報是「含手續費的最終扣款金額」，
                        因此預設勾選。勾選時 record 進 Trade 的 Commission=0，
                        持倉成本就是使用者輸入的總額（不會再加 0.1425% 上去）。
                    -->
                    <CheckBox
                        Margin="0,0,0,8"
                        Content="{DynamicResource Portfolio.Tx.TotalIncludesFee}"
                        IsChecked="{Binding Buy.TotalIncludesFee, Mode=TwoWay}"
                        IsEnabled="{Binding AreEconomicFieldsEditable}"
                        ToolTip="{DynamicResource Portfolio.Tx.TotalIncludesFee.Tooltip}" />
                </StackPanel>

                <TextBlock
                    Margin="0,0,0,4"
                    FontSize="{StaticResource Font.Size.Xs}"
                    FontWeight="SemiBold"
                    Foreground="{DynamicResource AppTextSecondary}"
                    Text="{DynamicResource Portfolio.AddQuantity}" />
                <TextBox
                    behaviors:ThousandSeparatorBehavior.IsEnabled="True"
                    IsEnabled="{Binding AreEconomicFieldsEditable}"
                    Text="{Binding AddAssetDialog.AddQuantity, UpdateSourceTrigger=PropertyChanged}" />
                <TextBlock
                    Margin="0,0,0,4"
                    Style="{StaticResource FormFieldError}"
                    Text="{Binding AddAssetDialog.AddQuantityError}"
                    Visibility="{Binding AddAssetDialog.AddQuantityError, Converter={StaticResource StringToVisibilityConverter}}" />

                <TextBlock
                    Margin="0,0,0,4"
                    FontSize="{StaticResource Font.Size.Xs}"
                    FontWeight="SemiBold"
                    Foreground="{DynamicResource AppTextSecondary}"
                    Text="{DynamicResource Portfolio.Tx.CommissionDiscount}" />
                <Grid>
                    <Grid.Visibility>
                        <MultiBinding Converter="{StaticResource InverseWidthScaleThresholdToVisibilityConverter}" ConverterParameter="940">
                            <Binding ElementName="Root" Path="ActualWidth" />
                            <Binding Path="DataContext.Settings.UiScale" RelativeSource="{RelativeSource AncestorType=Window}" />
                        </MultiBinding>
                    </Grid.Visibility>
                    <Grid.ColumnDefinitions>
                        <ColumnDefinition Width="80" />
                        <ColumnDefinition Width="*" />
                    </Grid.ColumnDefinitions>
                    <TextBox Grid.Column="0" Text="{Binding TxCommissionDiscount, UpdateSourceTrigger=PropertyChanged}" />
                    <TextBlock
                        Grid.Column="1"
                        Margin="8,0,0,0"
                        VerticalAlignment="Center"
                        FontSize="{StaticResource Font.Size.Xs}"
                        Foreground="{DynamicResource AppTextMuted}"
                        Text="{DynamicResource Portfolio.Tx.CommissionDiscountHint}" />
                </Grid>
                <StackPanel>
                    <StackPanel.Visibility>
                        <MultiBinding Converter="{StaticResource WidthScaleThresholdToVisibilityConverter}" ConverterParameter="940">
                            <Binding ElementName="Root" Path="ActualWidth" />
                            <Binding Path="DataContext.Settings.UiScale" RelativeSource="{RelativeSource AncestorType=Window}" />
                        </MultiBinding>
                    </StackPanel.Visibility>
                    <TextBox
                        Width="96"
                        HorizontalAlignment="Left"
                        Text="{Binding TxCommissionDiscount, UpdateSourceTrigger=PropertyChanged}" />
                    <TextBlock
                        Margin="0,6,0,0"
                        FontSize="{StaticResource Font.Size.Xs}"
                        Foreground="{DynamicResource AppTextMuted}"
                        Text="{DynamicResource Portfolio.Tx.CommissionDiscountHint}"
                        TextWrapping="Wrap" />
                </StackPanel>
                <TextBlock
                    Margin="0,0,0,12"
                    Style="{StaticResource FormFieldError}"
                    Text="{Binding TxCommissionDiscountError}"
                    Visibility="{Binding TxCommissionDiscountError, Converter={StaticResource StringToVisibilityConverter}}" />

                <!--  Fee preview  -->
                <Border
                    Margin="0,0,0,8"
                    Padding="10,8"
                    Background="{DynamicResource AppBackground}"
                    BorderBrush="{DynamicResource AppBorder}"
                    BorderThickness="1"
                    CornerRadius="{StaticResource Radius.Sm}"
                    Visibility="{Binding AddAssetDialog.HasAddPreview, Converter={StaticResource BooleanToVisibilityConverter}}">
                    <Grid>
                        <Grid.ColumnDefinitions>
                            <ColumnDefinition Width="*" />
                            <ColumnDefinition Width="Auto" />
                        </Grid.ColumnDefinitions>
                        <Grid.RowDefinitions>
                            <RowDefinition Height="Auto" />
                            <RowDefinition Height="Auto" />
                            <RowDefinition Height="6" />
                            <RowDefinition Height="Auto" />
                            <RowDefinition Height="Auto" />
                        </Grid.RowDefinitions>
                        <TextBlock
                            Grid.Row="0"
                            Grid.Column="0"
                            FontSize="{StaticResource Font.Size.Xs}"
                            Foreground="{DynamicResource AppTextMuted}"
                            Text="{DynamicResource Portfolio.Add.GrossAmount}" />
                        <TextBlock
                            Grid.Row="0"
                            Grid.Column="1"
                            FontFamily="{StaticResource Font.Family.Base}"
                            FontSize="{StaticResource Font.Size.Xs}"
                            Foreground="{DynamicResource AppTextSecondary}"
                            Text="{Binding AddAssetDialog.AddGrossAmount, StringFormat={}{0:N0}}"
                            Typography.NumeralAlignment="Tabular" />
                        <TextBlock
                            Grid.Row="1"
                            Grid.Column="0"
                            FontSize="{StaticResource Font.Size.Xs}"
                            Foreground="{DynamicResource AppTextMuted}"
                            Text="{DynamicResource Portfolio.Add.Commission}" />
                        <TextBlock
                            Grid.Row="1"
                            Grid.Column="1"
                            FontFamily="{StaticResource Font.Family.Base}"
                            FontSize="{StaticResource Font.Size.Xs}"
                            Foreground="{DynamicResource AppDown}"
                            Text="{Binding AddAssetDialog.AddCommission, StringFormat=+{0:N0}}"
                            Typography.NumeralAlignment="Tabular" />
                        <Rectangle
                            Grid.Row="2"
                            Grid.Column="0"
                            Grid.ColumnSpan="2"
                            Margin="0,1"
                            Fill="{DynamicResource AppBorder}" />
                        <TextBlock
                            Grid.Row="3"
                            Grid.Column="0"
                            FontSize="{StaticResource Font.Size.Xs}"
                            FontWeight="SemiBold"
                            Foreground="{DynamicResource AppTextSecondary}"
                            Text="{DynamicResource Portfolio.Add.TotalCost}" />
                        <TextBlock
                            Grid.Row="3"
                            Grid.Column="1"
                            FontFamily="{StaticResource Font.Family.Base}"
                            FontSize="{StaticResource Font.Size.Xs}"
                            FontWeight="SemiBold"
                            Foreground="{DynamicResource AppTextPrimary}"
                            Text="{Binding AddAssetDialog.AddTotalCost, StringFormat={}{0:N0}}"
                            Typography.NumeralAlignment="Tabular" />
                        <TextBlock
                            Grid.Row="4"
                            Grid.Column="0"
                            Margin="0,2,0,0"
                            FontSize="{StaticResource Font.Size.Xs}"
                            Foreground="{DynamicResource AppTextMuted}"
                            Text="{DynamicResource Portfolio.Add.CostPerShare}" />
                        <TextBlock
                            Grid.Row="4"
                            Grid.Column="1"
                            Margin="0,2,0,0"
                            FontFamily="{StaticResource Font.Family.Base}"
                            FontSize="{StaticResource Font.Size.Xs}"
                            Foreground="{DynamicResource AppTextMuted}"
                            Text="{Binding AddAssetDialog.AddCostPerShare, StringFormat={}{0:F4}}"
                            Typography.NumeralAlignment="Tabular" />
                    </Grid>
                </Border>
            </StackPanel>
        </StackPanel>

        <!--  Non-stock (Fund/Metal/Bond): Name + Cost  -->
        <StackPanel Visibility="{Binding Buy.IsNonStock, Converter={StaticResource BooleanToVisibilityConverter}}">
            <TextBlock
                Margin="0,0,0,4"
                FontSize="{StaticResource Font.Size.Xs}"
                FontWeight="SemiBold"
                Foreground="{DynamicResource AppTextSecondary}"
                Text="{DynamicResource Portfolio.Dialog.AddName}" />
            <TextBox Margin="0,0,0,12" Text="{Binding AddAssetDialog.AddName, UpdateSourceTrigger=PropertyChanged}" />
            <TextBlock
                Margin="0,0,0,4"
                FontSize="{StaticResource Font.Size.Xs}"
                FontWeight="SemiBold"
                Foreground="{DynamicResource AppTextSecondary}"
                Text="{DynamicResource Portfolio.Dialog.AddCost}" />
            <TextBox behaviors:ThousandSeparatorBehavior.IsEnabled="True" Text="{Binding AddAssetDialog.AddCost, UpdateSourceTrigger=PropertyChanged}" />
            <TextBlock
                Style="{StaticResource FormFieldError}"
                Text="{Binding AddAssetDialog.AddCostError}"
                Visibility="{Binding AddAssetDialog.AddCostError, Converter={StaticResource StringToVisibilityConverter}}" />
        </StackPanel>

        <!--  Crypto: Symbol + Qty + Price  -->
        <StackPanel Visibility="{Binding Buy.IsCrypto, Converter={StaticResource BooleanToVisibilityConverter}}">
            <TextBlock
                Margin="0,0,0,4"
                FontSize="{StaticResource Font.Size.Xs}"
                FontWeight="SemiBold"
                Foreground="{DynamicResource AppTextSecondary}"
                Text="{DynamicResource Portfolio.Dialog.CryptoSymbol}" />
            <TextBox Margin="0,0,0,12" Text="{Binding AddAssetDialog.AddCryptoSymbol, UpdateSourceTrigger=PropertyChanged}" />
            <TextBlock
                Margin="0,0,0,4"
                FontSize="{StaticResource Font.Size.Xs}"
                FontWeight="SemiBold"
                Foreground="{DynamicResource AppTextSecondary}"
                Text="{DynamicResource Portfolio.Dialog.CryptoQty}" />
            <TextBox behaviors:ThousandSeparatorBehavior.IsEnabled="True" Text="{Binding AddAssetDialog.AddCryptoQty, UpdateSourceTrigger=PropertyChanged}" />
            <TextBlock
                Style="{StaticResource FormFieldError}"
                Text="{Binding AddAssetDialog.AddCryptoQtyError}"
                Visibility="{Binding AddAssetDialog.AddCryptoQtyError, Converter={StaticResource StringToVisibilityConverter}}" />
            <TextBlock
                Margin="0,12,0,4"
                FontSize="{StaticResource Font.Size.Xs}"
                FontWeight="SemiBold"
                Foreground="{DynamicResource AppTextSecondary}"
                Text="{DynamicResource Portfolio.Dialog.CryptoPrice}" />
            <TextBox behaviors:ThousandSeparatorBehavior.IsEnabled="True" Text="{Binding AddAssetDialog.AddCryptoPrice, UpdateSourceTrigger=PropertyChanged}" />
            <TextBlock
                Style="{StaticResource FormFieldError}"
                Text="{Binding AddAssetDialog.AddCryptoPriceError}"
                Visibility="{Binding AddAssetDialog.AddCryptoPriceError, Converter={StaticResource StringToVisibilityConverter}}" />
        </StackPanel>

        <!--  Fee + cash-account — hidden in meta-only mode  -->
        <StackPanel>
            <StackPanel.Style>
                <Style TargetType="StackPanel">
                    <Setter Property="Visibility" Value="Visible" />
                    <Style.Triggers>
                        <DataTrigger Binding="{Binding Buy.MetaOnly}" Value="True">
                            <Setter Property="Visibility" Value="Collapsed" />
                        </DataTrigger>
                    </Style.Triggers>
                </Style>
            </StackPanel.Style>

            <!--  手續費 (manual override; 留空 → 走 TxCommissionDiscount 自動計算)  -->
            <TextBlock
                Margin="0,12,0,4"
                FontSize="{StaticResource Font.Size.Xs}"
                FontWeight="SemiBold"
                Foreground="{DynamicResource AppTextSecondary}"
                Text="{DynamicResource Portfolio.Tx.Fee}" />
            <TextBox behaviors:ThousandSeparatorBehavior.IsEnabled="True" Text="{Binding TxFee, UpdateSourceTrigger=PropertyChanged}" />
            <TextBlock
                Style="{StaticResource FormFieldError}"
                Text="{Binding TxFeeError}"
                Visibility="{Binding TxFeeError, Converter={StaticResource StringToVisibilityConverter}}" />
            <TextBlock
                Margin="0,2,0,12"
                FontSize="{StaticResource Font.Size.Xs}"
                Foreground="{DynamicResource AppTextMuted}"
                Text="{DynamicResource Portfolio.Tx.FeeOverrideHint}"
                TextWrapping="Wrap" />

            <!--  從現金帳戶扣款 — checkbox + dropdown (一致 with 借款/還款 / Transfer)  -->
            <CheckBox
                Margin="0,0,0,4"
                Content="{Binding TxUseCashAccountLabel}"
                FontSize="{StaticResource Font.Size.Xs}"
                Foreground="{DynamicResource AppTextSecondary}"
                IsChecked="{Binding TxUseCashAccount, Mode=TwoWay}" />
            <StackPanel Visibility="{Binding TxUseCashAccount, Converter={StaticResource BooleanToVisibilityConverter}}">
                <TextBlock
                    Margin="0,0,0,4"
                    FontSize="{StaticResource Font.Size.Xs}"
                    FontWeight="SemiBold"
                    Foreground="{DynamicResource AppTextSecondary}"
                    Text="{Binding TxCashAccountLabel}" />
                <ComboBox
                    Margin="0,0,0,4"
                    DisplayMemberPath="Name"
                    IsEditable="True"
                    IsTextSearchEnabled="True"
                    ItemsSource="{Binding CashAccounts}"
                    SelectedItem="{Binding TxCashAccount, Mode=TwoWay}"
                    Style="{StaticResource FormComboBox}"
                    Text="{Binding TxCashAccountName, UpdateSourceTrigger=PropertyChanged, Mode=TwoWay}">
                    <ComboBox.Resources>
                        <Style BasedOn="{StaticResource FormComboBoxItem}" TargetType="ComboBoxItem" />
                    </ComboBox.Resources>
                </ComboBox>
                <TextBlock
                    Margin="0,2,0,0"
                    FontSize="{StaticResource Font.Size.Xs}"
                    Foreground="{DynamicResource AppAccent}"
                    Text="{DynamicResource Portfolio.Tx.WillCreateNew}"
                    Visibility="{Binding IsNewCashAccount, Converter={StaticResource BooleanToVisibilityConverter}}" />

                <!--
                    跨幣別 banner — Buy.IsCrossCurrency=true (標的幣別 ≠ 帳戶幣別) 時顯示，
                    白話告訴使用者「為什麼底下兩個額外欄位變必填」。
                    MultiCurrency-Trade-Refactor P3。
                -->
                <Border
                    Margin="0,12,0,0"
                    Padding="10,8"
                    Background="{DynamicResource AppAccentSubtle}"
                    BorderBrush="{DynamicResource AppAccent}"
                    BorderThickness="1"
                    CornerRadius="{StaticResource Radius.Sm}"
                    Visibility="{Binding Buy.IsCrossCurrency, Converter={StaticResource BooleanToVisibilityConverter}}">
                    <StackPanel>
                        <TextBlock
                            FontSize="{StaticResource Font.Size.Xs}"
                            FontWeight="SemiBold"
                            Foreground="{DynamicResource AppTextPrimary}"
                            Text="{DynamicResource Portfolio.Tx.CrossCurrency.Banner}" />
                        <TextBlock
                            Margin="0,4,0,0"
                            FontSize="{StaticResource Font.Size.Xs}"
                            Foreground="{DynamicResource AppTextSecondary}"
                            Text="{DynamicResource Portfolio.Tx.CrossCurrency.Hint}"
                            TextWrapping="Wrap" />
                    </StackPanel>
                </Border>

                <!--
                    FX rate (跨幣別模式才顯示)。同幣別時隱藏 → Trade.FxRate = null = implicit 1.0。
                -->
                <StackPanel Visibility="{Binding Buy.IsCrossCurrency, Converter={StaticResource BooleanToVisibilityConverter}}">
                    <TextBlock
                        Margin="0,12,0,4"
                        FontSize="{StaticResource Font.Size.Xs}"
                        FontWeight="SemiBold"
                        Foreground="{DynamicResource AppTextSecondary}"
                        Text="{DynamicResource Portfolio.Tx.FxRate}" />
                    <TextBox
                        behaviors:ThousandSeparatorBehavior.IsEnabled="True"
                        Text="{Binding Buy.FxRate, UpdateSourceTrigger=PropertyChanged}" />
                    <TextBlock
                        Style="{StaticResource FormFieldError}"
                        Text="{Binding Buy.FxRateError}"
                        Visibility="{Binding Buy.FxRateError, Converter={StaticResource StringToVisibilityConverter}}" />
                    <TextBlock
                        Margin="0,2,0,0"
                        FontSize="{StaticResource Font.Size.Xs}"
                        Foreground="{DynamicResource AppTextMuted}"
                        Text="{DynamicResource Portfolio.Tx.FxRate.Hint}"
                        TextWrapping="Wrap" />
                </StackPanel>

                <TextBlock
                    Margin="0,12,0,4"
                    FontSize="{StaticResource Font.Size.Xs}"
                    FontWeight="SemiBold"
                    Foreground="{DynamicResource AppTextSecondary}"
                    Text="{DynamicResource Portfolio.Tx.ActualCashAmount}" />
                <TextBox
                    behaviors:ThousandSeparatorBehavior.IsEnabled="True"
                    Text="{Binding Buy.ActualCashAmount, UpdateSourceTrigger=PropertyChanged}" />
                <TextBlock
                    Style="{StaticResource FormFieldError}"
                    Text="{Binding Buy.ActualCashAmountError}"
                    Visibility="{Binding Buy.ActualCashAmountError, Converter={StaticResource StringToVisibilityConverter}}" />
                <TextBlock
                    Margin="0,2,0,0"
                    FontSize="{StaticResource Font.Size.Xs}"
                    Foreground="{DynamicResource AppTextMuted}"
                    Text="{DynamicResource Portfolio.Tx.ActualCashAmountHint}"
                    TextWrapping="Wrap" />
            </StackPanel>
        </StackPanel>
    </StackPanel>
</UserControl>
