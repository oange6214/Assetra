<UserControl
    x:Class="Assetra.WPF.Features.Portfolio.Controls.TxForms.BuyTxForm"
    xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
    xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
    xmlns:behaviors="clr-namespace:Assetra.WPF.Infrastructure.Behaviors"
    xmlns:d="http://schemas.microsoft.com/expression/blend/2008"
    xmlns:ds="clr-namespace:Assetra.WPF.DesignSystem.Controls"
    xmlns:mc="http://schemas.openxmlformats.org/markup-compatibility/2006"
    xmlns:shared="clr-namespace:Assetra.WPF.Features.Portfolio.Controls.TxForms.Shared"
    xmlns:vm="clr-namespace:Assetra.WPF.Features.Portfolio.SubViewModels"
    x:Name="Root"
    d:DataContext="{d:DesignInstance Type={x:Type vm:TransactionDialogViewModel}}"
    mc:Ignorable="d">

    <!--  ======== 買入欄位 ========  -->
    <StackPanel Visibility="{Binding TxTypeIsBuy, Converter={StaticResource BooleanToVisibilityConverter}}">
        <!--
            P2.5 — 移除「資產類別 (Stock/Fund/Metal/Bond/Crypto)」ComboBox。
            類別現在由統一資產選擇器決定（SelectedAsset.Kind → Buy.AssetType，
            由 SyncSelectedAssetIntoBuyState() 同步）。使用者選 NVDA 即 Stock，
            選 Vanguard Total World Stock 即 Fund — 不必再 dropdown 選一次。

            同樣地，「代號」輸入框也拿掉 — Symbol 由 SelectedAsset.Symbol 帶。
            非 Stock 子表單（Non-stock / Crypto）下面仍保留自己的 Name / Symbol
            輸入欄位作為過渡，直到 + 新增資產 CTA 完整接上前不動。
        -->

        <!--  Stock/ETF：直接走到經濟欄位（單價/總額 toggle、數量等），代號 + 自動補全已拔  -->
        <StackPanel d:Visibility="Visible" Visibility="{Binding Buy.IsStock, Converter={StaticResource BooleanToVisibilityConverter}}">

            <!--  Economic fields — hidden in meta-only mode  -->
            <StackPanel>
                <StackPanel.Style>
                    <Style TargetType="StackPanel">
                        <Setter Property="Visibility" Value="Visible" />
                        <Style.Triggers>
                            <DataTrigger Binding="{Binding Buy.MetaOnly}" Value="True">
                                <Setter Property="Visibility" Value="Collapsed" />
                            </DataTrigger>
                        </Style.Triggers>
                    </Style>
                </StackPanel.Style>

                <!--
                    P2.4 reorganization — 對齊使用者提供的參考設計：
                    Row 1: 數量（全寬，價格模式 toggle 移至進階區）
                    Row 2: 單位價格 label，右上 inline 「⚡ 取得市價」link
                    Row 3: 單位價格 TextBox（預設只顯示 unit-mode input）
                    Row 4: 即時計算 mirror — 單價模式顯示「總計: X」、總額模式顯示「單位價格: X」
                    Bindings 仍走 Buy.PriceMode / AddAssetDialog.AddPrice / Buy.TotalCost
                    （沒有 lift 到 parent VM 的 facade，因為 sub-VM 已是同一個 dialog DataContext 可訪問），
                    所以下游 ConfirmBuyAsync 邏輯不受影響。
                -->
                <!--
                    Section header + ⓘ（說明收進 tooltip，文案 key 不變）＋ 右側「取得市價」。
                    取得市價原本貼在「每股價格」label 右邊，但成交明細改三欄後那欄只剩約 1/3 寬，
                    塞不下 label＋幣別 badge＋連結；它本來就是整個成交明細的動作，移到區塊標題列。
                -->
                <Grid Margin="0,0,0,12">
                    <Grid.ColumnDefinitions>
                        <ColumnDefinition Width="*" />
                        <ColumnDefinition Width="Auto" />
                    </Grid.ColumnDefinitions>
                    <StackPanel
                        Grid.Column="0"
                        VerticalAlignment="Center"
                        Orientation="Horizontal">
                        <TextBlock
                            VerticalAlignment="Center"
                            FontSize="{StaticResource Font.Size.Sm}"
                            FontWeight="SemiBold"
                            Foreground="{DynamicResource AppTextPrimary}"
                            Text="{DynamicResource Portfolio.Tx.TradeDetailsSection}" />
                        <ds:AppIcon
                            Margin="6,0,0,0"
                            VerticalAlignment="Center"
                            AutomationProperties.Name="{DynamicResource Portfolio.Tx.TradeDetailsHint}"
                            FontSize="12"
                            Foreground="{DynamicResource AppTextMuted}"
                            Symbol="Info24"
                            ToolTipService.InitialShowDelay="250"
                            ToolTipService.ShowDuration="20000">
                            <ds:AppIcon.ToolTip>
                                <ToolTip>
                                    <TextBlock
                                        FontSize="{StaticResource Font.Size.Xs}"
                                        Foreground="{DynamicResource AppTextSecondary}"
                                        Text="{DynamicResource Portfolio.Tx.TradeDetailsHint}"
                                        TextWrapping="Wrap" />
                                </ToolTip>
                            </ds:AppIcon.ToolTip>
                        </ds:AppIcon>
                    </StackPanel>
                    <Button
                        Grid.Column="1"
                        Padding="0"
                        HorizontalAlignment="Right"
                        VerticalAlignment="Center"
                        Background="Transparent"
                        BorderThickness="0"
                        Command="{Binding AddAssetDialog.FetchMarketPriceCommand}"
                        Cursor="Hand"
                        ToolTip="{DynamicResource Portfolio.Tx.FetchMarketPrice.Hint}">
                        <StackPanel Orientation="Horizontal">
                            <ds:AppIcon
                                Margin="0,0,4,0"
                                VerticalAlignment="Center"
                                FontSize="12"
                                Foreground="{DynamicResource AppAccent}"
                                Symbol="Flash16" />
                            <TextBlock
                                VerticalAlignment="Center"
                                FontSize="{StaticResource Font.Size.Xs}"
                                Foreground="{DynamicResource AppAccent}"
                                Text="{DynamicResource Portfolio.Tx.FetchMarketPrice}" />
                        </StackPanel>
                    </Button>
                </Grid>

                <!--
                    成交明細三欄：數量 ｜ 每股價格 ｜ 成交總額。
                    填任兩欄，第三欄自動補算 —— 券商明細給單價就打單價；定期定額／多筆成交
                    只知道總額就打總額（此時單價＝總額÷數量的均價，反而更準）。兩種輸入都直接
                    支援，所以原本那顆藏在進階、卻會改上方欄位的「單價/總額」切換整個拿掉。
                    PriceMode 降級為內部旗標，由使用者最後輸入哪個金額欄自動決定，
                    確認層的 GROSS 語意不變（Wave 0 特徵測試守著）。
                    三欄 Top 對齊，任一欄出現錯誤字不會推歪其他欄。
                -->
                <Grid Margin="0,0,0,14">
                    <Grid.ColumnDefinitions>
                        <ColumnDefinition Width="*" />
                        <ColumnDefinition Width="10" />
                        <ColumnDefinition Width="*" />
                        <ColumnDefinition Width="10" />
                        <ColumnDefinition Width="*" />
                        <ColumnDefinition Width="10" />
                        <ColumnDefinition Width="*" />
                    </Grid.ColumnDefinitions>

                    <!--  數量  -->
                    <shared:FormField
                        Grid.Column="0"
                        VerticalAlignment="Top"
                        ErrorText="{Binding AddAssetDialog.AddQuantityError}"
                        InputEnabled="{Binding AreEconomicFieldsEditable}"
                        Label="{DynamicResource Portfolio.AddQuantity}"
                        Placeholder="{DynamicResource Portfolio.Tx.QuantityPlaceholder}"
                        Text="{Binding AddAssetDialog.AddQuantity, UpdateSourceTrigger=PropertyChanged}"
                        ThousandSeparator="True" />

                    <!--  每股價格 — label 帶幣別 badge，故不用 FormField（它的 label 是純文字）  -->
                    <StackPanel Grid.Column="2" VerticalAlignment="Top">
                        <StackPanel Margin="0,0,0,6" Orientation="Horizontal">
                            <TextBlock
                                VerticalAlignment="Center"
                                FontSize="{StaticResource Font.Size.Xs}"
                                FontWeight="SemiBold"
                                Foreground="{DynamicResource AppTextSecondary}"
                                Text="{DynamicResource Portfolio.Tx.UnitPriceLabel}" />
                            <TextBlock
                                Margin="6,0,0,0"
                                VerticalAlignment="Center"
                                FontSize="{StaticResource Font.Size.Xs}"
                                Foreground="{DynamicResource AppAccent}"
                                Text="{Binding Buy.InstrumentCurrencyBadge}"
                                Visibility="{Binding Buy.InstrumentCurrencyBadge, Converter={StaticResource StringToVisibilityConverter}}" />
                        </StackPanel>
                        <TextBox
                            behaviors:ThousandSeparatorBehavior.IsEnabled="True"
                            IsEnabled="{Binding AreEconomicFieldsEditable}"
                            Tag="{DynamicResource Portfolio.Tx.PricePlaceholder}"
                            Text="{Binding AddAssetDialog.AddPrice, UpdateSourceTrigger=PropertyChanged}" />
                        <TextBlock
                            Style="{StaticResource FormFieldError}"
                            Text="{Binding AddAssetDialog.AddPriceError}"
                            Visibility="{Binding AddAssetDialog.AddPriceError, Converter={StaticResource StringToVisibilityConverter}}" />
                    </StackPanel>

                    <!--  成交總額 — 原本是唯讀鏡像，現在可編輯；打這欄則單價由 總額÷數量 反推  -->
                    <shared:FormField
                        Grid.Column="4"
                        VerticalAlignment="Top"
                        ErrorText="{Binding Buy.TotalCostError}"
                        InputEnabled="{Binding AreEconomicFieldsEditable}"
                        Label="{DynamicResource Portfolio.Tx.TotalAmountLabel}"
                        Placeholder="{DynamicResource Portfolio.Tx.AmountPlaceholder}"
                        Text="{Binding Buy.TotalCost, UpdateSourceTrigger=PropertyChanged}"
                        ThousandSeparator="True" />

                    <!--
                        手續費 — 從進階搬上來並排。留空即走「折扣 × 標準費率」自動計算，
                        說明在 label 旁的 ⓘ。原本為了這一個選填欄位包一整張 Expander 卡片，
                        純屬多餘的包裝，已整個移除。
                    -->
                    <shared:TxFeeField Grid.Column="6" VerticalAlignment="Top" />
                </Grid>

                <!--
                    「金額已含手續費」— 不是模式而是寫入語意（已含＝手續費視為 0、總成本即此值；
                    未含＝手續費另計加上去），僅在「總額為權威」時才有意義，故沿用 IsTotalMode。
                    原本住在進階裡，進階移除後改掛在成交明細下方。
                -->
                <CheckBox
                    Margin="0,0,0,14"
                    Content="{DynamicResource Portfolio.Tx.TotalIncludesFee}"
                    IsChecked="{Binding Buy.TotalIncludesFee, Mode=TwoWay}"
                    IsEnabled="{Binding AreEconomicFieldsEditable}"
                    ToolTip="{DynamicResource Portfolio.Tx.TotalIncludesFee.Tooltip}"
                    Visibility="{Binding Buy.IsTotalMode, Converter={StaticResource BooleanToVisibilityConverter}}" />

                <!--  ClosePrice 自動抓取後的 hint（只在 unit mode 才相關）  -->
                <TextBlock
                    Margin="0,4,0,0"
                    FontSize="{StaticResource Font.Size.Xs}"
                    Foreground="{DynamicResource AppTextMuted}"
                    Text="{Binding AddAssetDialog.ClosePriceHint}">
                    <TextBlock.Style>
                        <Style TargetType="TextBlock">
                            <Setter Property="Visibility" Value="Collapsed" />
                            <Style.Triggers>
                                <MultiDataTrigger>
                                    <MultiDataTrigger.Conditions>
                                        <Condition Binding="{Binding Buy.IsUnitMode}" Value="True" />
                                    </MultiDataTrigger.Conditions>
                                    <Setter Property="Visibility" Value="{Binding AddAssetDialog.ClosePriceHint, Converter={StaticResource StringToVisibilityConverter}}" />
                                </MultiDataTrigger>
                            </Style.Triggers>
                        </Style>
                    </TextBlock.Style>
                </TextBlock>

                <!--
                    「手續費折扣」欄位已搬到「設定 → 預設手續費折扣」(AppSettings.DefaultCommissionDiscount)。
                    Dialog 開啟時自動由 SeedCommissionDiscountFromSettings() 帶入；
                    使用者鮮少每筆交易改券商折扣，移除減少 dialog 噪音。下方「手續費（選填）」
                    手動覆寫欄位仍保留作 per-trade override（移至進階區）。
                -->

                <!--  Fee preview  -->
                <Border
                    Margin="0,0,0,8"
                    Padding="10,8"
                    Background="{DynamicResource AppBackground}"
                    BorderBrush="{DynamicResource AppBorder}"
                    BorderThickness="1"
                    CornerRadius="{StaticResource Radius.Sm}"
                    Visibility="{Binding AddAssetDialog.HasAddPreview, Converter={StaticResource BooleanToVisibilityConverter}}">
                    <Grid>
                        <Grid.ColumnDefinitions>
                            <ColumnDefinition Width="*" />
                            <ColumnDefinition Width="Auto" />
                        </Grid.ColumnDefinitions>
                        <Grid.RowDefinitions>
                            <RowDefinition Height="Auto" />
                            <RowDefinition Height="Auto" />
                            <RowDefinition Height="6" />
                            <RowDefinition Height="Auto" />
                            <RowDefinition Height="Auto" />
                        </Grid.RowDefinitions>
                        <TextBlock
                            Grid.Row="0"
                            Grid.Column="0"
                            FontSize="{StaticResource Font.Size.Xs}"
                            Foreground="{DynamicResource AppTextMuted}"
                            Text="{DynamicResource Portfolio.Add.GrossAmount}" />
                        <TextBlock
                            Grid.Row="0"
                            Grid.Column="1"
                            FontFamily="{StaticResource Font.Family.Base}"
                            FontSize="{StaticResource Font.Size.Xs}"
                            Foreground="{DynamicResource AppTextSecondary}"
                            Text="{Binding AddAssetDialog.AddGrossAmount, StringFormat={}{0:N0}}"
                            Typography.NumeralAlignment="Tabular" />
                        <TextBlock
                            Grid.Row="1"
                            Grid.Column="0"
                            FontSize="{StaticResource Font.Size.Xs}"
                            Foreground="{DynamicResource AppTextMuted}"
                            Text="{DynamicResource Portfolio.Add.Commission}" />
                        <TextBlock
                            Grid.Row="1"
                            Grid.Column="1"
                            FontFamily="{StaticResource Font.Family.Base}"
                            FontSize="{StaticResource Font.Size.Xs}"
                            Foreground="{DynamicResource AppDown}"
                            Text="{Binding AddAssetDialog.AddCommission, StringFormat=+{0:N0}}"
                            Typography.NumeralAlignment="Tabular" />
                        <Rectangle
                            Grid.Row="2"
                            Grid.Column="0"
                            Grid.ColumnSpan="2"
                            Margin="0,1"
                            Fill="{DynamicResource AppBorder}" />
                        <TextBlock
                            Grid.Row="3"
                            Grid.Column="0"
                            FontSize="{StaticResource Font.Size.Xs}"
                            FontWeight="SemiBold"
                            Foreground="{DynamicResource AppTextSecondary}"
                            Text="{DynamicResource Portfolio.Add.TotalCost}" />
                        <TextBlock
                            Grid.Row="3"
                            Grid.Column="1"
                            FontFamily="{StaticResource Font.Family.Base}"
                            FontSize="{StaticResource Font.Size.Xs}"
                            FontWeight="SemiBold"
                            Foreground="{DynamicResource AppTextPrimary}"
                            Text="{Binding AddAssetDialog.AddTotalCost, StringFormat={}{0:N0}}"
                            Typography.NumeralAlignment="Tabular" />
                        <TextBlock
                            Grid.Row="4"
                            Grid.Column="0"
                            Margin="0,2,0,0"
                            FontSize="{StaticResource Font.Size.Xs}"
                            Foreground="{DynamicResource AppTextMuted}"
                            Text="{DynamicResource Portfolio.Add.CostPerShare}" />
                        <TextBlock
                            Grid.Row="4"
                            Grid.Column="1"
                            Margin="0,2,0,0"
                            FontFamily="{StaticResource Font.Family.Base}"
                            FontSize="{StaticResource Font.Size.Xs}"
                            Foreground="{DynamicResource AppTextMuted}"
                            Text="{Binding AddAssetDialog.AddCostPerShare, StringFormat={}{0:F4}}"
                            Typography.NumeralAlignment="Tabular" />
                    </Grid>
                </Border>
            </StackPanel>
        </StackPanel>

        <!--  Non-stock (Fund/Metal/Bond): Name + Cost  -->
        <StackPanel Visibility="{Binding Buy.IsNonStock, Converter={StaticResource BooleanToVisibilityConverter}}">
            <!--  Wave 1 — 標準文字欄位改用 shared:FormField（label/TextBox/error 三段與原 inline markup 等價）  -->
            <shared:FormField
                Margin="0,0,0,14"
                Label="{DynamicResource Portfolio.Dialog.AddName}"
                Text="{Binding AddAssetDialog.AddName, UpdateSourceTrigger=PropertyChanged}" />
            <shared:FormField
                ErrorText="{Binding AddAssetDialog.AddCostError}"
                Label="{DynamicResource Portfolio.Dialog.AddCost}"
                Text="{Binding AddAssetDialog.AddCost, UpdateSourceTrigger=PropertyChanged}"
                ThousandSeparator="True" />
        </StackPanel>

        <!--  Crypto: Symbol + Qty + Price  -->
        <StackPanel Visibility="{Binding Buy.IsCrypto, Converter={StaticResource BooleanToVisibilityConverter}}">
            <!--  Wave 1 — 標準文字欄位改用 shared:FormField（label/TextBox/error 三段與原 inline markup 等價）  -->
            <shared:FormField
                Margin="0,0,0,14"
                Label="{DynamicResource Portfolio.Dialog.CryptoSymbol}"
                Text="{Binding AddAssetDialog.AddCryptoSymbol, UpdateSourceTrigger=PropertyChanged}" />
            <shared:FormField
                ErrorText="{Binding AddAssetDialog.AddCryptoQtyError}"
                Label="{DynamicResource Portfolio.Dialog.CryptoQty}"
                Text="{Binding AddAssetDialog.AddCryptoQty, UpdateSourceTrigger=PropertyChanged}"
                ThousandSeparator="True" />
            <shared:FormField
                Margin="0,14,0,0"
                ErrorText="{Binding AddAssetDialog.AddCryptoPriceError}"
                Label="{DynamicResource Portfolio.Dialog.CryptoPrice}"
                Text="{Binding AddAssetDialog.AddCryptoPrice, UpdateSourceTrigger=PropertyChanged}"
                ThousandSeparator="True" />
        </StackPanel>

        <!--
            扣款帳戶 + 跨幣別匯率 — 主流程（非進階）。
            跨幣別（成交幣別 ≠ 扣款帳戶幣別，如複委託 USD 交易由 TWD 帳戶扣款）的
            匯率攸關成本正確性，不可收在進階裡；下方匯率列以 Buy.IsCrossCurrency
            自我 gating，同幣別（台股 TWD→TWD、IB USD→USD）不顯示。
            外層 StackPanel 保留 MetaOnly 收合（原本在進階內由同樣的 trigger 包住）。
        -->
        <StackPanel Margin="0,12,0,0">
            <StackPanel.Style>
                <Style TargetType="StackPanel">
                    <Setter Property="Visibility" Value="Visible" />
                    <Style.Triggers>
                        <DataTrigger Binding="{Binding Buy.MetaOnly}" Value="True">
                            <Setter Property="Visibility" Value="Collapsed" />
                        </DataTrigger>
                    </Style.Triggers>
                </Style>
            </StackPanel.Style>

            <!--
                從現金帳戶扣款 — checkbox + 帳戶下拉並排一行（原本 checkbox／扣款帳戶 label／
                下拉共佔三行）。獨立的「扣款帳戶」label 拿掉：checkbox 文字本身已說明用途，
                語系 key（TxCashAccountLabel）保留未動。下拉仍由 TxUseCashAccount gating。
            -->
            <Grid Margin="0,0,0,6">
                <Grid.ColumnDefinitions>
                    <ColumnDefinition Width="Auto" />
                    <ColumnDefinition Width="*" />
                </Grid.ColumnDefinitions>
                <CheckBox
                    Grid.Column="0"
                    VerticalAlignment="Center"
                    Content="{Binding TxUseCashAccountLabel}"
                    FontSize="{StaticResource Font.Size.Xs}"
                    Foreground="{DynamicResource AppTextSecondary}"
                    IsChecked="{Binding TxUseCashAccount, Mode=TwoWay}" />
                <StackPanel
                    Grid.Column="1"
                    Margin="10,0,0,0"
                    VerticalAlignment="Center"
                    Visibility="{Binding TxUseCashAccount, Converter={StaticResource BooleanToVisibilityConverter}}">
                    <ComboBox
                        MinWidth="180"
                        DisplayMemberPath="Name"
                        IsEditable="True"
                        IsTextSearchEnabled="True"
                        ItemsSource="{Binding CashAccounts}"
                        SelectedItem="{Binding TxCashAccount, Mode=TwoWay}"
                        Style="{StaticResource FormComboBox}"
                        Text="{Binding TxCashAccountName, UpdateSourceTrigger=PropertyChanged, Mode=TwoWay}">
                        <ComboBox.Resources>
                            <Style BasedOn="{StaticResource FormComboBoxItem}" TargetType="ComboBoxItem" />
                        </ComboBox.Resources>
                    </ComboBox>
                </StackPanel>
            </Grid>
            <StackPanel Visibility="{Binding TxUseCashAccount, Converter={StaticResource BooleanToVisibilityConverter}}">
                <TextBlock
                    Margin="0,2,0,0"
                    FontSize="{StaticResource Font.Size.Xs}"
                    Foreground="{DynamicResource AppAccent}"
                    Text="{DynamicResource Portfolio.Tx.WillCreateNew}"
                    Visibility="{Binding IsNewCashAccount, Converter={StaticResource BooleanToVisibilityConverter}}" />

                <!--
                    「帳戶扣款」卡（扣款依據 radios ＋ 帳戶扣款金額 ＋ 三段說明）已整張移除。
                    新增交易時一律走「依匯率估算」：台幣扣款 = 價金 × 當日市場匯率 ＋ 手續費，
                    匯率由 QueueBuyFxRateRefresh() 在日期／帳戶／幣別變動時靜默自動抓，
                    確認前還有一道補抓，使用者不需要碰任何跨幣別欄位。

                    只留這一行匯率：①自動抓不到當日匯率時（補記舊交易）否則會卡在確認錯誤、
                    無處可修；②台幣扣款完全由它推導出來，使用者有權看見並覆寫。
                    代價：實際扣款金額無法在此輸入，故餘額為估算值 — 靠帳戶設定的券商換匯價差
                    收斂、並以既有的「對帳」功能定期校正。
                -->
                <Grid
                    Margin="0,10,0,0"
                    Visibility="{Binding Buy.IsCrossCurrency, Converter={StaticResource BooleanToVisibilityConverter}}">
                    <Grid.ColumnDefinitions>
                        <ColumnDefinition Width="Auto" />
                        <ColumnDefinition Width="*" />
                        <ColumnDefinition Width="Auto" />
                    </Grid.ColumnDefinitions>
                    <StackPanel
                        Grid.Column="0"
                        VerticalAlignment="Center"
                        Orientation="Horizontal">
                        <TextBlock
                            VerticalAlignment="Center"
                            FontSize="{StaticResource Font.Size.Xs}"
                            FontWeight="SemiBold"
                            Foreground="{DynamicResource AppTextSecondary}"
                            Text="{DynamicResource Portfolio.Tx.FxRate.Short}" />
                        <TextBlock
                            Margin="6,0,0,0"
                            VerticalAlignment="Center"
                            FontSize="{StaticResource Font.Size.Xs}"
                            Foreground="{DynamicResource AppAccent}"
                            Text="{Binding Buy.SettlementPairDisplay, Mode=OneWay}" />
                    </StackPanel>
                    <TextBox
                        Grid.Column="1"
                        MinWidth="90"
                        Margin="10,0,0,0"
                        HorizontalAlignment="Left"
                        VerticalAlignment="Center"
                        IsEnabled="{Binding AreEconomicFieldsEditable}"
                        Text="{Binding Buy.FxRate, UpdateSourceTrigger=PropertyChanged}"
                        ToolTip="{DynamicResource Portfolio.Tx.FxRate.Hint}" />
                    <Button
                        Grid.Column="2"
                        Padding="0"
                        VerticalAlignment="Center"
                        Background="Transparent"
                        BorderThickness="0"
                        Command="{Binding FetchBuyFxRateCommand}"
                        Cursor="Hand"
                        ToolTip="{DynamicResource Portfolio.Tx.FetchFxRate}">
                        <ds:AppIcon
                            FontSize="12"
                            Foreground="{DynamicResource AppAccent}"
                            Symbol="Flash16" />
                    </Button>
                </Grid>
                <!--  抓匯率失敗訊息 — 走設計系統既有的 FormFieldError 樣式（勿直接塗 AppDanger）  -->
                <TextBlock
                    Margin="0,4,0,0"
                    Style="{StaticResource FormFieldError}"
                    Text="{Binding Buy.FxFetchError}"
                    TextWrapping="Wrap"
                    Visibility="{Binding Buy.FxFetchError, Converter={StaticResource StringToVisibilityConverter}}" />

                <!--
                    溢價合理性檢查整組已移除：它的原理是「實際扣款 vs 價金 × 市場匯率」對照，
                    而「實際扣款」的輸入隨帳戶扣款卡一起拿掉了，新增交易一律走匯率估算
                    （現金由匯率推得 ⇒ 對照必然為 0、沒有資訊量），此列永遠不會顯示。
                    連同 Buy 的 Premium/GrossNative 等 VM 屬性一併刪除——那是純樣板管線，
                    真要接「匯入券商明細／事後校正」時會照當時的設計重寫，留著只是死碼。
                    純函式 SettlementPremiumCalculator（Application 層＋已測試）保留備用。
                -->

            </StackPanel>
        </StackPanel>

        <!--
            進階 Expander 已整個移除：它到最後只剩「手續費」一個選填欄位還要包一張卡片，
            純屬多餘包裝。手續費已並排到上方成交明細列（股票路徑）；「金額已含手續費」
            改掛在成交明細下方。此處只補「非股票 / 加密貨幣」兩條路徑的手續費——
            它們沒有成交明細那個四欄格，原本是靠根層級的 Expander 才拿到這個欄位。
        -->
        <StackPanel Visibility="{Binding Buy.IsNonStock, Converter={StaticResource BooleanToVisibilityConverter}}">
            <shared:TxFeeField Margin="0,14,0,0" />
        </StackPanel>
        <StackPanel Visibility="{Binding Buy.IsCrypto, Converter={StaticResource BooleanToVisibilityConverter}}">
            <shared:TxFeeField Margin="0,14,0,0" />
        </StackPanel>

    </StackPanel>
</UserControl>
