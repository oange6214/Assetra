<UserControl
    x:Class="Assetra.WPF.Features.Portfolio.Controls.TxForms.SellTxForm"
    xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
    xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
    xmlns:behaviors="clr-namespace:Assetra.WPF.Infrastructure.Behaviors"
    xmlns:d="http://schemas.microsoft.com/expression/blend/2008"
    xmlns:mc="http://schemas.openxmlformats.org/markup-compatibility/2006"
    xmlns:vm="clr-namespace:Assetra.WPF.Features.Portfolio.SubViewModels"
    d:DataContext="{d:DesignInstance Type={x:Type vm:TransactionDialogViewModel},
                                     IsDesignTimeCreatable=False}"
    mc:Ignorable="d">

    <!--  ======== 賣出欄位 ========  -->
    <StackPanel Visibility="{Binding TxTypeIsSell, Converter={StaticResource BooleanToVisibilityConverter}}">
        <TextBlock
            Margin="0,0,0,4"
            FontSize="{StaticResource FontSizeXs}"
            FontWeight="SemiBold"
            Foreground="{DynamicResource AppTextSecondary}"
            Text="{DynamicResource Portfolio.Tx.SellPosition}" />
        <ComboBox
            Margin="0,0,0,12"
            IsEnabled="{Binding AreEconomicFieldsEditable}"
            ItemsSource="{Binding Positions}"
            SelectedItem="{Binding TxSellPosition, Mode=TwoWay}"
            Style="{StaticResource FormComboBox}">
            <ComboBox.ItemTemplate>
                <DataTemplate>
                    <StackPanel Orientation="Horizontal">
                        <TextBlock
                            Margin="0,0,8,0"
                            FontFamily="{StaticResource FontTabular}"
                            FontWeight="SemiBold"
                            Foreground="{DynamicResource AppAccent}"
                            Text="{Binding Symbol}" />
                        <TextBlock Foreground="{DynamicResource AppTextPrimary}" Text="{Binding Name}" />
                    </StackPanel>
                </DataTemplate>
            </ComboBox.ItemTemplate>
        </ComboBox>

        <TextBlock
            Margin="0,0,0,4"
            FontSize="{StaticResource FontSizeXs}"
            FontWeight="SemiBold"
            Foreground="{DynamicResource AppTextSecondary}"
            Text="{DynamicResource Portfolio.Tx.SellQuantity}" />
        <TextBox
            Margin="0,0,0,0"
            IsEnabled="{Binding AreEconomicFieldsEditable}"
            Style="{StaticResource FormTextBox}"
            Text="{Binding TxSellQuantity, UpdateSourceTrigger=PropertyChanged}" />
        <TextBlock
            Margin="0,0,0,12"
            Style="{StaticResource FormFieldError}"
            Text="{Binding TxSellQuantityError}"
            Visibility="{Binding TxSellQuantityError, Converter={StaticResource StringToVisibilityConverter}}" />

        <TextBlock
            Margin="0,0,0,4"
            FontSize="{StaticResource FontSizeXs}"
            FontWeight="SemiBold"
            Foreground="{DynamicResource AppTextSecondary}"
            Text="{DynamicResource Portfolio.Tx.SellPrice}" />
        <TextBox
            behaviors:ThousandSeparatorBehavior.IsEnabled="True"
            IsEnabled="{Binding AreEconomicFieldsEditable}"
            Style="{StaticResource FormTextBox}"
            Text="{Binding TxAmount, UpdateSourceTrigger=PropertyChanged}" />
        <TextBlock
            Margin="0,0,0,12"
            Style="{StaticResource FormFieldError}"
            Text="{Binding TxAmountError}"
            Visibility="{Binding TxAmountError, Converter={StaticResource StringToVisibilityConverter}}" />

        <!--  手續費折扣 (和買入對稱)  -->
        <TextBlock
            Margin="0,0,0,4"
            FontSize="{StaticResource FontSizeXs}"
            FontWeight="SemiBold"
            Foreground="{DynamicResource AppTextSecondary}"
            Text="{DynamicResource Portfolio.Tx.CommissionDiscount}" />
        <Grid>
            <Grid.ColumnDefinitions>
                <ColumnDefinition Width="80" />
                <ColumnDefinition Width="*" />
            </Grid.ColumnDefinitions>
            <TextBox
                Grid.Column="0"
                IsEnabled="{Binding AreEconomicFieldsEditable}"
                Style="{StaticResource FormTextBox}"
                Text="{Binding TxCommissionDiscount, UpdateSourceTrigger=PropertyChanged}" />
            <TextBlock
                Grid.Column="1"
                Margin="8,0,0,0"
                VerticalAlignment="Center"
                FontSize="{StaticResource FontSizeXs}"
                Foreground="{DynamicResource AppTextMuted}"
                Text="{DynamicResource Portfolio.Tx.CommissionDiscountHint}" />
        </Grid>
        <TextBlock
            Margin="0,0,0,12"
            Style="{StaticResource FormFieldError}"
            Text="{Binding TxCommissionDiscountError}"
            Visibility="{Binding TxCommissionDiscountError, Converter={StaticResource StringToVisibilityConverter}}" />

        <!--  賣出費用預覽 (對稱於買入的 fee preview)  -->
        <Border
            Margin="0,0,0,12"
            Padding="10,8"
            Background="{DynamicResource AppBackground}"
            BorderBrush="{DynamicResource AppBorder}"
            BorderThickness="1"
            CornerRadius="{StaticResource RadiusSm}"
            Visibility="{Binding HasTxSellPreview, Converter={StaticResource BooleanToVisibilityConverter}}">
            <Grid>
                <Grid.ColumnDefinitions>
                    <ColumnDefinition Width="*" />
                    <ColumnDefinition Width="Auto" />
                </Grid.ColumnDefinitions>
                <Grid.RowDefinitions>
                    <RowDefinition Height="Auto" />
                    <RowDefinition Height="Auto" />
                    <RowDefinition Height="Auto" />
                    <RowDefinition Height="6" />
                    <RowDefinition Height="Auto" />
                </Grid.RowDefinitions>
                <TextBlock
                    Grid.Row="0"
                    Grid.Column="0"
                    FontSize="{StaticResource FontSizeXs}"
                    Foreground="{DynamicResource AppTextMuted}"
                    Text="{DynamicResource Portfolio.Sell.GrossAmount}" />
                <TextBlock
                    Grid.Row="0"
                    Grid.Column="1"
                    FontFamily="{StaticResource FontTabular}"
                    FontSize="{StaticResource FontSizeXs}"
                    Foreground="{DynamicResource AppTextSecondary}"
                    Text="{Binding TxSellGrossAmount, StringFormat={}{0:N0}}" />
                <TextBlock
                    Grid.Row="1"
                    Grid.Column="0"
                    FontSize="{StaticResource FontSizeXs}"
                    Foreground="{DynamicResource AppTextMuted}"
                    Text="{DynamicResource Portfolio.Sell.Commission}" />
                <TextBlock
                    Grid.Row="1"
                    Grid.Column="1"
                    FontFamily="{StaticResource FontTabular}"
                    FontSize="{StaticResource FontSizeXs}"
                    Foreground="{DynamicResource AppDown}"
                    Text="{Binding TxSellCommission, StringFormat=-{0:N0}}" />
                <TextBlock
                    Grid.Row="2"
                    Grid.Column="0"
                    FontSize="{StaticResource FontSizeXs}"
                    Foreground="{DynamicResource AppTextMuted}">
                    <Run Text="{DynamicResource Portfolio.Sell.TransactionTax}" />
                    <Run Foreground="{DynamicResource AppTextMuted}" Text=" " />
                    <Run Foreground="{DynamicResource AppTextMuted}">
                        <Run.Style>
                            <Style TargetType="Run">
                                <Setter Property="Text" Value="(0.3%)" />
                                <Style.Triggers>
                                    <DataTrigger Binding="{Binding TxSellIsEtf}" Value="True">
                                        <Setter Property="Text" Value="(ETF 0.1%)" />
                                    </DataTrigger>
                                    <DataTrigger Binding="{Binding TxSellIsBondEtf}" Value="True">
                                        <Setter Property="Text" Value="(債券 ETF 免徵)" />
                                    </DataTrigger>
                                </Style.Triggers>
                            </Style>
                        </Run.Style>
                    </Run>
                </TextBlock>
                <TextBlock
                    Grid.Row="2"
                    Grid.Column="1"
                    FontFamily="{StaticResource FontTabular}"
                    FontSize="{StaticResource FontSizeXs}"
                    Foreground="{DynamicResource AppDown}"
                    Text="{Binding TxSellTransactionTax, StringFormat=-{0:N0}}" />
                <Rectangle
                    Grid.Row="3"
                    Grid.Column="0"
                    Grid.ColumnSpan="2"
                    Margin="0,1"
                    Fill="{DynamicResource AppBorder}" />
                <TextBlock
                    Grid.Row="4"
                    Grid.Column="0"
                    FontSize="{StaticResource FontSizeXs}"
                    FontWeight="SemiBold"
                    Foreground="{DynamicResource AppTextSecondary}"
                    Text="{DynamicResource Portfolio.Sell.NetAmount}" />
                <TextBlock
                    Grid.Row="4"
                    Grid.Column="1"
                    FontFamily="{StaticResource FontTabular}"
                    FontSize="{StaticResource FontSizeXs}"
                    FontWeight="SemiBold"
                    Foreground="{DynamicResource AppTextPrimary}"
                    Text="{Binding TxSellNetAmount, StringFormat={}{0:N0}}" />
            </Grid>
        </Border>

        <!--  手續費 (override; 留空 → 自動計算)  -->
        <TextBlock
            Margin="0,0,0,4"
            FontSize="{StaticResource FontSizeXs}"
            FontWeight="SemiBold"
            Foreground="{DynamicResource AppTextSecondary}"
            Text="{DynamicResource Portfolio.Tx.Fee}" />
        <TextBox
            behaviors:ThousandSeparatorBehavior.IsEnabled="True"
            Style="{StaticResource FormTextBox}"
            Text="{Binding TxFee, UpdateSourceTrigger=PropertyChanged}" />
        <TextBlock
            Style="{StaticResource FormFieldError}"
            Text="{Binding TxFeeError}"
            Visibility="{Binding TxFeeError, Converter={StaticResource StringToVisibilityConverter}}" />
        <TextBlock
            Margin="0,2,0,12"
            FontSize="{StaticResource FontSizeXs}"
            Foreground="{DynamicResource AppTextMuted}"
            Text="{DynamicResource Portfolio.Tx.FeeOverrideHint}"
            TextWrapping="Wrap" />

        <!--  存入現金帳戶 — checkbox + dropdown  -->
        <CheckBox
            Margin="0,0,0,4"
            Content="{DynamicResource Portfolio.Tx.UseLoanCashAccount}"
            FontSize="{StaticResource FontSizeXs}"
            Foreground="{DynamicResource AppTextSecondary}"
            IsChecked="{Binding TxUseCashAccount, Mode=TwoWay}" />
        <StackPanel Visibility="{Binding TxUseCashAccount, Converter={StaticResource BooleanToVisibilityConverter}}">
            <TextBlock
                Margin="0,0,0,4"
                FontSize="{StaticResource FontSizeXs}"
                FontWeight="SemiBold"
                Foreground="{DynamicResource AppTextSecondary}"
                Text="{DynamicResource Portfolio.Tx.LoanCashAccount}" />
            <ComboBox
                DisplayMemberPath="Name"
                IsEditable="True"
                IsTextSearchEnabled="True"
                ItemsSource="{Binding CashAccounts}"
                SelectedItem="{Binding TxCashAccount, Mode=TwoWay}"
                Style="{StaticResource FormComboBox}"
                Text="{Binding TxCashAccountName, UpdateSourceTrigger=PropertyChanged, Mode=TwoWay}">
                <ComboBox.Resources>
                    <Style BasedOn="{StaticResource FormComboBoxItem}" TargetType="ComboBoxItem" />
                </ComboBox.Resources>
            </ComboBox>
            <TextBlock
                Margin="0,2,0,0"
                FontSize="{StaticResource FontSizeXs}"
                Foreground="{DynamicResource AppAccent}"
                Text="{DynamicResource Portfolio.Tx.WillCreateNew}"
                Visibility="{Binding IsNewCashAccount, Converter={StaticResource BooleanToVisibilityConverter}}" />
        </StackPanel>
    </StackPanel>
</UserControl>
