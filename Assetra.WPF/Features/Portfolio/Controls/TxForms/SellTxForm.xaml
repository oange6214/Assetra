<UserControl
    x:Class="Assetra.WPF.Features.Portfolio.Controls.TxForms.SellTxForm"
    xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
    xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
    xmlns:behaviors="clr-namespace:Assetra.WPF.Infrastructure.Behaviors"
    xmlns:d="http://schemas.microsoft.com/expression/blend/2008"
    xmlns:mc="http://schemas.openxmlformats.org/markup-compatibility/2006"
    xmlns:shared="clr-namespace:Assetra.WPF.Features.Portfolio.Controls.TxForms.Shared"
    xmlns:txforms="clr-namespace:Assetra.WPF.Features.Portfolio.Controls.TxForms"
    xmlns:vm="clr-namespace:Assetra.WPF.Features.Portfolio.SubViewModels"
    x:Name="Root"
    d:DataContext="{d:DesignInstance Type={x:Type vm:TransactionDialogViewModel}}"
    mc:Ignorable="d">

    <!--  ======== 賣出欄位 ========  -->
    <StackPanel Visibility="{Binding TxTypeIsSell, Converter={StaticResource BooleanToVisibilityConverter}}">
        <!--  股票已由上方「選擇資產」決定（賣出只在選到投資持倉時可選，cascade 會把它設成
              Sell.Position），故此處不再重複顯示持倉選擇器，避免與「選擇資產」重複。  -->

        <!--  Wave 1 — 標準金額欄位改用 shared:FormField（error 局部 12px 間距以 ErrorMargin 帶入，與原 markup 等價）  -->
        <shared:FormField
            ErrorMargin="0,0,0,12"
            ErrorText="{Binding Sell.QuantityError}"
            InputEnabled="{Binding AreEconomicFieldsEditable}"
            Label="{DynamicResource Portfolio.Tx.SellQuantity}"
            Placeholder="{DynamicResource Portfolio.Tx.QuantityPlaceholder}"
            Text="{Binding Sell.Quantity, UpdateSourceTrigger=PropertyChanged}" />

        <!--  成交明細輸入模式：單價 / 成交總額（對齊買入）。總額採 GROSS：股數×單價。  -->
        <TextBlock
            Margin="0,0,0,6"
            FontSize="{StaticResource Font.Size.Xs}"
            FontWeight="SemiBold"
            Foreground="{DynamicResource AppTextSecondary}"
            Text="{DynamicResource Portfolio.Tx.PriceMode}" />
        <Grid Margin="0,0,0,12">
            <Grid.ColumnDefinitions>
                <ColumnDefinition Width="*" />
                <ColumnDefinition Width="*" />
            </Grid.ColumnDefinitions>
            <RadioButton
                Grid.Column="0"
                Margin="0,0,3,0"
                HorizontalAlignment="Stretch"
                HorizontalContentAlignment="Center"
                Content="{DynamicResource Portfolio.Tx.PriceModeUnit}"
                GroupName="TxSellPriceMode"
                IsChecked="{Binding Sell.PriceMode, Converter={StaticResource EqualityConverter}, ConverterParameter=unit, Mode=TwoWay}"
                IsEnabled="{Binding AreEconomicFieldsEditable}"
                Style="{StaticResource SegmentBtn}" />
            <RadioButton
                Grid.Column="1"
                Margin="3,0,0,0"
                HorizontalAlignment="Stretch"
                HorizontalContentAlignment="Center"
                Content="{DynamicResource Portfolio.Tx.PriceModeTotal}"
                GroupName="TxSellPriceMode"
                IsChecked="{Binding Sell.PriceMode, Converter={StaticResource EqualityConverter}, ConverterParameter=total, Mode=TwoWay}"
                IsEnabled="{Binding AreEconomicFieldsEditable}"
                Style="{StaticResource SegmentBtn}" />
        </Grid>

        <!--  單價模式：賣出價（每股）＋ 幣別 badge。  -->
        <StackPanel Visibility="{Binding Sell.IsUnitMode, Converter={StaticResource BooleanToVisibilityConverter}}">
            <StackPanel Margin="0,0,0,6" Orientation="Horizontal">
                <TextBlock
                    FontSize="{StaticResource Font.Size.Xs}"
                    FontWeight="SemiBold"
                    Foreground="{DynamicResource AppTextSecondary}"
                    Text="{DynamicResource Portfolio.Tx.SellPrice}" />
                <TextBlock
                    Margin="6,0,0,0"
                    FontSize="{StaticResource Font.Size.Xs}"
                    Foreground="{DynamicResource AppAccent}"
                    Text="{Binding Sell.InstrumentCurrencyBadge}"
                    Visibility="{Binding Sell.InstrumentCurrencyBadge, Converter={StaticResource StringToVisibilityConverter}}" />
            </StackPanel>
            <TextBox
                behaviors:ThousandSeparatorBehavior.IsEnabled="True"
                IsEnabled="{Binding AreEconomicFieldsEditable}"
                Tag="{DynamicResource Portfolio.Tx.PricePlaceholder}"
                Text="{Binding TxAmount, UpdateSourceTrigger=PropertyChanged}" />
            <TextBlock
                Margin="0,0,0,12"
                Style="{StaticResource FormFieldError}"
                Text="{Binding TxAmountError}"
                Visibility="{Binding TxAmountError, Converter={StaticResource StringToVisibilityConverter}}" />
        </StackPanel>

        <!--  總額模式：成交總額（gross＝股數×單價），確認時反推單價。  -->
        <StackPanel Visibility="{Binding Sell.IsTotalMode, Converter={StaticResource BooleanToVisibilityConverter}}">
            <shared:FormField
                ErrorMargin="0,0,0,12"
                ErrorText="{Binding Sell.TotalProceedsError}"
                InputEnabled="{Binding AreEconomicFieldsEditable}"
                Label="{DynamicResource Portfolio.Tx.TotalAmountLabel}"
                Placeholder="{DynamicResource Portfolio.Tx.AmountPlaceholder}"
                Text="{Binding Sell.TotalProceeds, UpdateSourceTrigger=PropertyChanged}"
                ThousandSeparator="True" />
        </StackPanel>

        <!--
            存入帳戶 + 跨幣別結算 — 主流程（非進階），對齊買入。
            跨幣別（成交幣別 ≠ 存入帳戶幣別）的結算金額/匯率攸關損益正確性，不可收在
            進階裡；CrossCurrencyOverlay 自身以 IsCrossCurrency 自我 gating，同幣別不顯示。
        -->
        <StackPanel Margin="0,4,0,0">
            <!--
                存入現金帳戶 — checkbox + 帳戶下拉並排一行（對齊買入）。獨立的「存入帳戶」
                label 拿掉：checkbox 文字本身已說明用途，語系 key（TxCashAccountLabel）保留未動。
            -->
            <Grid Margin="0,0,0,4">
                <Grid.ColumnDefinitions>
                    <ColumnDefinition Width="Auto" />
                    <ColumnDefinition Width="*" />
                </Grid.ColumnDefinitions>
                <CheckBox
                    Grid.Column="0"
                    VerticalAlignment="Center"
                    Content="{Binding TxUseCashAccountLabel}"
                    FontSize="{StaticResource Font.Size.Xs}"
                    Foreground="{DynamicResource AppTextSecondary}"
                    IsChecked="{Binding TxUseCashAccount, Mode=TwoWay}" />
                <StackPanel
                    Grid.Column="1"
                    Margin="10,0,0,0"
                    VerticalAlignment="Center"
                    Visibility="{Binding TxUseCashAccount, Converter={StaticResource BooleanToVisibilityConverter}}">
                    <ComboBox
                        MinWidth="180"
                        DisplayMemberPath="Name"
                        IsEditable="True"
                        IsTextSearchEnabled="True"
                        ItemsSource="{Binding CashAccounts}"
                        SelectedItem="{Binding TxCashAccount, Mode=TwoWay}"
                        Style="{StaticResource FormComboBox}"
                        Text="{Binding TxCashAccountName, UpdateSourceTrigger=PropertyChanged, Mode=TwoWay}">
                        <ComboBox.Resources>
                            <Style BasedOn="{StaticResource FormComboBoxItem}" TargetType="ComboBoxItem" />
                        </ComboBox.Resources>
                    </ComboBox>
                </StackPanel>
            </Grid>
            <StackPanel Visibility="{Binding TxUseCashAccount, Converter={StaticResource BooleanToVisibilityConverter}}">
                <TextBlock
                    Margin="0,2,0,0"
                    FontSize="{StaticResource Font.Size.Xs}"
                    Foreground="{DynamicResource AppAccent}"
                    Text="{DynamicResource Portfolio.Tx.WillCreateNew}"
                    Visibility="{Binding IsNewCashAccount, Converter={StaticResource BooleanToVisibilityConverter}}" />

                <!--
                    P5.8b — Cross-currency settlement section 抽到 CrossCurrencyOverlay 共用
                    UserControl，三個 form (Buy / Sell / CashDividend) 都用同一份 markup。
                    這裡只負責設定 4 個 DP 把 Sell 專屬的差異塞進去（GroupName /
                    FetchCommand / Label / Hint），其餘 binding 透過 DataContext=Sell
                    自動解到 sub-VM 屬性。
                -->
                <txforms:CrossCurrencyOverlay
                    ActualCashAmountHint="{DynamicResource Portfolio.Tx.SellActualCashAmountHint}"
                    ActualCashAmountLabel="{DynamicResource Portfolio.Tx.SellActualCashAmount}"
                    DataContext="{Binding Sell}"
                    FetchFxRateCommand="{Binding DataContext.FetchSellFxRateCommand, ElementName=Root}"
                    GroupName="TxSellSettlementInputMode" />
            </StackPanel>
        </StackPanel>

        <!--  進階（手續費折扣 / 費用預覽 / 手續費）— 對齊買入收合。  -->
        <Expander
            Margin="0,14,0,0"
            Header="{DynamicResource Portfolio.Tx.AdvancedSection}"
            IsExpanded="{Binding Sell.IsAdvancedExpanded, Mode=TwoWay}"
            Style="{StaticResource AppExpander}">
        <StackPanel>

        <!--  手續費折扣 (和買入對稱)  -->
        <TextBlock
            Margin="0,0,0,6"
            FontSize="{StaticResource Font.Size.Xs}"
            FontWeight="SemiBold"
            Foreground="{DynamicResource AppTextSecondary}"
            Text="{DynamicResource Portfolio.Tx.CommissionDiscount}" />
        <Grid>
            <Grid.Visibility>
                <MultiBinding Converter="{StaticResource InverseWidthScaleThresholdToVisibilityConverter}" ConverterParameter="940">
                    <Binding ElementName="Root" Path="ActualWidth" />
                    <Binding Path="DataContext.Settings.UiScale" RelativeSource="{RelativeSource AncestorType=Window}" />
                </MultiBinding>
            </Grid.Visibility>
            <Grid.ColumnDefinitions>
                <ColumnDefinition Width="80" />
                <ColumnDefinition Width="*" />
            </Grid.ColumnDefinitions>
            <TextBox
                Grid.Column="0"
                IsEnabled="{Binding AreEconomicFieldsEditable}"
                Text="{Binding TxCommissionDiscount, UpdateSourceTrigger=PropertyChanged}" />
            <TextBlock
                Grid.Column="1"
                Margin="8,0,0,0"
                VerticalAlignment="Center"
                FontSize="{StaticResource Font.Size.Xs}"
                Foreground="{DynamicResource AppTextMuted}"
                Text="{DynamicResource Portfolio.Tx.CommissionDiscountHint}" />
        </Grid>
        <StackPanel>
            <StackPanel.Visibility>
                <MultiBinding Converter="{StaticResource WidthScaleThresholdToVisibilityConverter}" ConverterParameter="940">
                    <Binding ElementName="Root" Path="ActualWidth" />
                    <Binding Path="DataContext.Settings.UiScale" RelativeSource="{RelativeSource AncestorType=Window}" />
                </MultiBinding>
            </StackPanel.Visibility>
            <TextBox
                Width="96"
                HorizontalAlignment="Left"
                IsEnabled="{Binding AreEconomicFieldsEditable}"
                Text="{Binding TxCommissionDiscount, UpdateSourceTrigger=PropertyChanged}" />
            <TextBlock
                Margin="0,6,0,0"
                FontSize="{StaticResource Font.Size.Xs}"
                Foreground="{DynamicResource AppTextMuted}"
                Text="{DynamicResource Portfolio.Tx.CommissionDiscountHint}"
                TextWrapping="Wrap" />
        </StackPanel>
        <TextBlock
            Margin="0,0,0,12"
            Style="{StaticResource FormFieldError}"
            Text="{Binding TxCommissionDiscountError}"
            Visibility="{Binding TxCommissionDiscountError, Converter={StaticResource StringToVisibilityConverter}}" />

        <!--  賣出費用預覽 (對稱於買入的 fee preview)  -->
        <Border
            Margin="0,0,0,12"
            Padding="10,8"
            Background="{DynamicResource AppBackground}"
            BorderBrush="{DynamicResource AppBorder}"
            BorderThickness="1"
            CornerRadius="{StaticResource Radius.Sm}"
            Visibility="{Binding Sell.HasPreview, Converter={StaticResource BooleanToVisibilityConverter}}">
            <Grid>
                <Grid.ColumnDefinitions>
                    <ColumnDefinition Width="*" />
                    <ColumnDefinition Width="Auto" />
                </Grid.ColumnDefinitions>
                <Grid.RowDefinitions>
                    <RowDefinition Height="Auto" />
                    <RowDefinition Height="Auto" />
                    <RowDefinition Height="Auto" />
                    <RowDefinition Height="6" />
                    <RowDefinition Height="Auto" />
                </Grid.RowDefinitions>
                <TextBlock
                    Grid.Row="0"
                    Grid.Column="0"
                    FontSize="{StaticResource Font.Size.Xs}"
                    Foreground="{DynamicResource AppTextMuted}"
                    Text="{DynamicResource Portfolio.Sell.GrossAmount}" />
                <TextBlock
                    Grid.Row="0"
                    Grid.Column="1"
                    FontFamily="{StaticResource Font.Family.Base}"
                    FontSize="{StaticResource Font.Size.Xs}"
                    Foreground="{DynamicResource AppTextSecondary}"
                    Text="{Binding Sell.GrossAmount, StringFormat={}{0:N0}}"
                    Typography.NumeralAlignment="Tabular" />
                <TextBlock
                    Grid.Row="1"
                    Grid.Column="0"
                    FontSize="{StaticResource Font.Size.Xs}"
                    Foreground="{DynamicResource AppTextMuted}"
                    Text="{DynamicResource Portfolio.Sell.Commission}" />
                <TextBlock
                    Grid.Row="1"
                    Grid.Column="1"
                    FontFamily="{StaticResource Font.Family.Base}"
                    FontSize="{StaticResource Font.Size.Xs}"
                    Foreground="{DynamicResource AppDown}"
                    Text="{Binding Sell.Commission, StringFormat=-{0:N0}}"
                    Typography.NumeralAlignment="Tabular" />
                <TextBlock
                    Grid.Row="2"
                    Grid.Column="0"
                    FontSize="{StaticResource Font.Size.Xs}"
                    Foreground="{DynamicResource AppTextMuted}">
                    <Run Text="{DynamicResource Portfolio.Sell.TransactionTax}" />
                    <Run Foreground="{DynamicResource AppTextMuted}" Text=" " />
                    <Run Foreground="{DynamicResource AppTextMuted}">
                        <Run.Style>
                            <Style TargetType="Run">
                                <Setter Property="Text" Value="(0.3%)" />
                                <Style.Triggers>
                                    <DataTrigger Binding="{Binding Sell.IsEtf}" Value="True">
                                        <Setter Property="Text" Value="(ETF 0.1%)" />
                                    </DataTrigger>
                                    <DataTrigger Binding="{Binding Sell.IsBondEtf}" Value="True">
                                        <Setter Property="Text" Value="(債券 ETF 免徵)" />
                                    </DataTrigger>
                                </Style.Triggers>
                            </Style>
                        </Run.Style>
                    </Run>
                </TextBlock>
                <TextBlock
                    Grid.Row="2"
                    Grid.Column="1"
                    FontFamily="{StaticResource Font.Family.Base}"
                    FontSize="{StaticResource Font.Size.Xs}"
                    Foreground="{DynamicResource AppDown}"
                    Text="{Binding Sell.TransactionTax, StringFormat=-{0:N0}}"
                    Typography.NumeralAlignment="Tabular" />
                <Rectangle
                    Grid.Row="3"
                    Grid.Column="0"
                    Grid.ColumnSpan="2"
                    Margin="0,1"
                    Fill="{DynamicResource AppBorder}" />
                <TextBlock
                    Grid.Row="4"
                    Grid.Column="0"
                    FontSize="{StaticResource Font.Size.Xs}"
                    FontWeight="SemiBold"
                    Foreground="{DynamicResource AppTextSecondary}"
                    Text="{DynamicResource Portfolio.Sell.NetAmount}" />
                <TextBlock
                    Grid.Row="4"
                    Grid.Column="1"
                    FontFamily="{StaticResource Font.Family.Base}"
                    FontSize="{StaticResource Font.Size.Xs}"
                    FontWeight="SemiBold"
                    Foreground="{DynamicResource AppTextPrimary}"
                    Text="{Binding Sell.NetAmount, StringFormat={}{0:N0}}"
                    Typography.NumeralAlignment="Tabular" />
            </Grid>
        </Border>

        <!--  手續費 (override; 留空 → 自動計算) — Wave 1：抽出 shared:TxFeeField（byte-identical）  -->
        <shared:TxFeeField />
        </StackPanel>
        </Expander>
    </StackPanel>
</UserControl>
