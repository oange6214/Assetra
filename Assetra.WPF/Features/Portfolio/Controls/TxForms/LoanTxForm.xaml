<UserControl
    x:Class="Assetra.WPF.Features.Portfolio.Controls.TxForms.LoanTxForm"
    xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
    xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
    xmlns:behaviors="clr-namespace:Assetra.WPF.Infrastructure.Behaviors"
    xmlns:d="http://schemas.microsoft.com/expression/blend/2008"
    xmlns:mc="http://schemas.openxmlformats.org/markup-compatibility/2006"
    xmlns:vm="clr-namespace:Assetra.WPF.Features.Portfolio"
    d:DataContext="{d:DesignInstance Type={x:Type vm:PortfolioViewModel},
                                     IsDesignTimeCreatable=False}"
    mc:Ignorable="d">

    <!--  ======== 借款/還款欄位 ========  -->
    <StackPanel Visibility="{Binding TxTypeIsLoan, Converter={StaticResource BooleanToVisibilityConverter}}">

        <!--  借款：金額 + 選填攤還欄位  -->
        <StackPanel Visibility="{Binding TxTypeIsLoanBorrow, Converter={StaticResource BooleanToVisibilityConverter}}">
            <TextBlock
                Margin="0,0,0,4"
                FontSize="{StaticResource FontSizeXs}"
                FontWeight="SemiBold"
                Foreground="{DynamicResource AppTextSecondary}"
                Text="{DynamicResource Portfolio.Tx.Amount}" />
            <TextBox
                behaviors:ThousandSeparatorBehavior.IsEnabled="True"
                Style="{StaticResource FormTextBox}"
                Text="{Binding TxAmount, UpdateSourceTrigger=PropertyChanged}" />
            <TextBlock
                Margin="0,0,0,12"
                Style="{StaticResource FormFieldError}"
                Text="{Binding TxAmountError}"
                Visibility="{Binding TxAmountError, Converter={StaticResource StringToVisibilityConverter}}" />

            <!--  年利率（選填）  -->
            <TextBlock
                Margin="0,0,0,4"
                FontSize="{StaticResource FontSizeXs}"
                FontWeight="SemiBold"
                Foreground="{DynamicResource AppTextSecondary}"
                Text="{DynamicResource Portfolio.Loan.AnnualRate}" />
            <TextBox
                Style="{StaticResource FormTextBox}"
                Text="{Binding TxLoanRate, UpdateSourceTrigger=PropertyChanged}" />
            <TextBlock
                Margin="0,0,0,12"
                Style="{StaticResource FormFieldError}"
                Text="{Binding TxLoanRateError}"
                Visibility="{Binding TxLoanRateError, Converter={StaticResource StringToVisibilityConverter}}" />

            <!--  還款期數（選填）  -->
            <TextBlock
                Margin="0,0,0,4"
                FontSize="{StaticResource FontSizeXs}"
                FontWeight="SemiBold"
                Foreground="{DynamicResource AppTextSecondary}"
                Text="{DynamicResource Portfolio.Loan.TermMonths}" />
            <TextBox
                Style="{StaticResource FormTextBox}"
                Text="{Binding TxLoanTermMonths, UpdateSourceTrigger=PropertyChanged}" />
            <TextBlock
                Margin="0,0,0,12"
                Style="{StaticResource FormFieldError}"
                Text="{Binding TxLoanTermMonthsError}"
                Visibility="{Binding TxLoanTermMonthsError, Converter={StaticResource StringToVisibilityConverter}}" />

            <!--  首期還款日（選填）  -->
            <TextBlock
                Margin="0,0,0,4"
                FontSize="{StaticResource FontSizeXs}"
                FontWeight="SemiBold"
                Foreground="{DynamicResource AppTextSecondary}"
                Text="{DynamicResource Portfolio.Loan.StartDate}" />
            <DatePicker
                FontSize="{StaticResource FontSizeSm}"
                Foreground="{DynamicResource AppTextPrimary}"
                SelectedDate="{Binding TxLoanStartDate}" />
            <TextBlock
                Margin="0,4,0,12"
                FontSize="{StaticResource FontSizeXs}"
                Foreground="{DynamicResource AppTextMuted}"
                Text="填寫年利率與期數可自動產生攤還表"
                TextWrapping="Wrap" />
        </StackPanel>

        <!--  還款：本金 + 利息拆分  -->
        <StackPanel Visibility="{Binding TxTypeIsLoanRepay, Converter={StaticResource BooleanToVisibilityConverter}}">
            <TextBlock
                Margin="0,0,0,4"
                FontSize="{StaticResource FontSizeXs}"
                FontWeight="SemiBold"
                Foreground="{DynamicResource AppTextSecondary}"
                Text="{DynamicResource Portfolio.Tx.Principal}" />
            <TextBox
                behaviors:ThousandSeparatorBehavior.IsEnabled="True"
                Style="{StaticResource FormTextBox}"
                Text="{Binding TxPrincipal, UpdateSourceTrigger=PropertyChanged}" />
            <TextBlock
                Margin="0,0,0,12"
                Style="{StaticResource FormFieldError}"
                Text="{Binding TxPrincipalError}"
                Visibility="{Binding TxPrincipalError, Converter={StaticResource StringToVisibilityConverter}}" />

            <TextBlock
                Margin="0,0,0,4"
                FontSize="{StaticResource FontSizeXs}"
                FontWeight="SemiBold"
                Foreground="{DynamicResource AppTextSecondary}"
                Text="{DynamicResource Portfolio.Tx.InterestPaid}" />
            <TextBox
                behaviors:ThousandSeparatorBehavior.IsEnabled="True"
                Style="{StaticResource FormTextBox}"
                Text="{Binding TxInterestPaid, UpdateSourceTrigger=PropertyChanged}" />
            <TextBlock
                Style="{StaticResource FormFieldError}"
                Text="{Binding TxInterestPaidError}"
                Visibility="{Binding TxInterestPaidError, Converter={StaticResource StringToVisibilityConverter}}" />
            <TextBlock
                Margin="0,2,0,12"
                FontSize="{StaticResource FontSizeXs}"
                Foreground="{DynamicResource AppTextMuted}"
                Text="{DynamicResource Portfolio.Tx.LoanRepayTotalHint}"
                TextWrapping="Wrap" />
        </StackPanel>

        <TextBlock
            Margin="0,0,0,4"
            FontSize="{StaticResource FontSizeXs}"
            FontWeight="SemiBold"
            Foreground="{DynamicResource AppTextSecondary}"
            Text="{DynamicResource Portfolio.Tx.LoanLabel}" />
        <ComboBox
            Margin="0,0,0,12"
            IsEditable="True"
            ItemsSource="{Binding LoanLabelSuggestions}"
            Style="{StaticResource FormComboBox}"
            Text="{Binding TxLoanLabel, Mode=TwoWay, UpdateSourceTrigger=PropertyChanged}">
            <ComboBox.Resources>
                <Style BasedOn="{StaticResource FormComboBoxItem}" TargetType="ComboBoxItem" />
            </ComboBox.Resources>
        </ComboBox>

        <!--  手續費（選填）— 借款：撥款時扣繳；還款：處理費  -->
        <TextBlock
            Margin="0,0,0,4"
            FontSize="{StaticResource FontSizeXs}"
            FontWeight="SemiBold"
            Foreground="{DynamicResource AppTextSecondary}"
            Text="{DynamicResource Portfolio.Tx.Fee}" />
        <TextBox
            behaviors:ThousandSeparatorBehavior.IsEnabled="True"
            Style="{StaticResource FormTextBox}"
            Text="{Binding TxFee, UpdateSourceTrigger=PropertyChanged}" />
        <TextBlock
            Margin="0,0,0,12"
            Style="{StaticResource FormFieldError}"
            Text="{Binding TxFeeError}"
            Visibility="{Binding TxFeeError, Converter={StaticResource StringToVisibilityConverter}}" />

        <!--  勾選框：連動現金帳戶（預設 on）  -->
        <CheckBox
            Margin="0,0,0,4"
            Content="{DynamicResource Portfolio.Tx.UseLoanCashAccount}"
            FontSize="{StaticResource FontSizeXs}"
            Foreground="{DynamicResource AppTextSecondary}"
            IsChecked="{Binding TxUseCashAccount, Mode=TwoWay}" />

        <!--  只在勾選時顯示現金帳戶下拉  -->
        <StackPanel Visibility="{Binding TxUseCashAccount, Converter={StaticResource BooleanToVisibilityConverter}}">
            <TextBlock
                Margin="0,0,0,4"
                FontSize="{StaticResource FontSizeXs}"
                FontWeight="SemiBold"
                Foreground="{DynamicResource AppTextSecondary}"
                Text="{DynamicResource Portfolio.Tx.LoanCashAccount}" />
            <ComboBox
                Margin="0,0,0,4"
                DisplayMemberPath="Name"
                ItemsSource="{Binding CashAccounts}"
                SelectedItem="{Binding TxCashAccount, Mode=TwoWay}"
                Style="{StaticResource FormComboBox}">
                <ComboBox.Resources>
                    <Style BasedOn="{StaticResource FormComboBoxItem}" TargetType="ComboBoxItem" />
                </ComboBox.Resources>
            </ComboBox>
            <TextBlock
                Margin="0,0,0,12"
                FontSize="{StaticResource FontSizeXs}"
                Foreground="{DynamicResource AppTextMuted}"
                Text="{DynamicResource Portfolio.Tx.LoanCashAccountHint}"
                TextWrapping="Wrap" />
        </StackPanel>

        <TextBlock
            Margin="0,8,0,4"
            FontSize="{StaticResource FontSizeXs}"
            FontWeight="SemiBold"
            Foreground="{DynamicResource AppTextSecondary}"
            Text="{DynamicResource Portfolio.Tx.Note}" />
        <TextBox Style="{StaticResource FormTextBox}" Text="{Binding TxNote, UpdateSourceTrigger=PropertyChanged}" />
    </StackPanel>
</UserControl>
