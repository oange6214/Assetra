<UserControl
    x:Class="Assetra.WPF.Features.Portfolio.Controls.TxForms.LoanTxForm"
    xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
    xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
    xmlns:behaviors="clr-namespace:Assetra.WPF.Infrastructure.Behaviors"
    xmlns:d="http://schemas.microsoft.com/expression/blend/2008"
    xmlns:mc="http://schemas.openxmlformats.org/markup-compatibility/2006"
    xmlns:vm="clr-namespace:Assetra.WPF.Features.Portfolio.SubViewModels"
    x:Name="Root"
    d:DataContext="{d:DesignInstance Type={x:Type vm:TransactionDialogViewModel}}"
    mc:Ignorable="d">

    <!--  ======== 借款/還款欄位 ========  -->
    <StackPanel Visibility="{Binding TxTypeIsLoan, Converter={StaticResource BooleanToVisibilityConverter}}">

        <!--  貸款名稱（共用，先填）  -->
        <TextBlock
            Margin="0,0,0,4"
            FontSize="{StaticResource Font.Size.Xs}"
            FontWeight="SemiBold"
            Foreground="{DynamicResource AppTextSecondary}"
            Text="{DynamicResource Portfolio.Tx.LoanLabel}" />
        <ComboBox
            Margin="0,0,0,12"
            IsEditable="True"
            ItemsSource="{Binding LoanLabelSuggestions}"
            Style="{StaticResource FormComboBox}"
            Text="{Binding Loan.Label, Mode=TwoWay, UpdateSourceTrigger=PropertyChanged}">
            <ComboBox.Resources>
                <Style BasedOn="{StaticResource FormComboBoxItem}" TargetType="ComboBoxItem" />
            </ComboBox.Resources>
        </ComboBox>

        <!--  借款：金額 + 選填攤還欄位  -->
        <StackPanel Visibility="{Binding TxTypeIsLoanBorrow, Converter={StaticResource BooleanToVisibilityConverter}}">
            <TextBlock
                Margin="0,0,0,4"
                FontSize="{StaticResource Font.Size.Xs}"
                FontWeight="SemiBold"
                Foreground="{DynamicResource AppTextSecondary}"
                Text="{DynamicResource Portfolio.Tx.Amount}" />
            <TextBox behaviors:ThousandSeparatorBehavior.IsEnabled="True" Text="{Binding TxAmount, UpdateSourceTrigger=PropertyChanged}" />
            <TextBlock
                Margin="0,0,0,12"
                Style="{StaticResource FormFieldError}"
                Text="{Binding TxAmountError}"
                Visibility="{Binding TxAmountError, Converter={StaticResource StringToVisibilityConverter}}" />

            <Grid Margin="0,0,0,12">
                <Grid.Visibility>
                    <MultiBinding Converter="{StaticResource InverseWidthScaleThresholdToVisibilityConverter}" ConverterParameter="900">
                        <Binding ElementName="Root" Path="ActualWidth" />
                        <Binding Path="DataContext.Settings.UiScale" RelativeSource="{RelativeSource AncestorType=Window}" />
                    </MultiBinding>
                </Grid.Visibility>
                <Grid.ColumnDefinitions>
                    <ColumnDefinition Width="*" />
                    <ColumnDefinition Width="12" />
                    <ColumnDefinition Width="*" />
                </Grid.ColumnDefinitions>
                <StackPanel Grid.Column="0">
                    <TextBlock
                        Margin="0,0,0,4"
                        FontSize="{StaticResource Font.Size.Xs}"
                        FontWeight="SemiBold"
                        Foreground="{DynamicResource AppTextSecondary}"
                        Text="{DynamicResource Portfolio.Loan.AnnualRate}" />
                    <TextBox Text="{Binding Loan.Rate, UpdateSourceTrigger=PropertyChanged}" />
                    <TextBlock
                        Margin="0,0,0,12"
                        Style="{StaticResource FormFieldError}"
                        Text="{Binding Loan.RateError}"
                        Visibility="{Binding Loan.RateError, Converter={StaticResource StringToVisibilityConverter}}" />

                    <TextBlock
                        Margin="0,0,0,4"
                        FontSize="{StaticResource Font.Size.Xs}"
                        FontWeight="SemiBold"
                        Foreground="{DynamicResource AppTextSecondary}"
                        Text="{DynamicResource Portfolio.Loan.StartDate}" />
                    <DatePicker
                        MinWidth="132"
                        HorizontalContentAlignment="Left"
                        SelectedDate="{Binding Loan.StartDate, Mode=TwoWay, UpdateSourceTrigger=PropertyChanged}"
                        Style="{StaticResource AppDatePicker}" />
                </StackPanel>
                <StackPanel Grid.Column="2">
                    <TextBlock
                        Margin="0,0,0,4"
                        FontSize="{StaticResource Font.Size.Xs}"
                        FontWeight="SemiBold"
                        Foreground="{DynamicResource AppTextSecondary}"
                        Text="{DynamicResource Portfolio.Loan.TermMonths}" />
                    <TextBox Text="{Binding Loan.TermMonths, UpdateSourceTrigger=PropertyChanged}" />
                    <TextBlock
                        Margin="0,0,0,12"
                        Style="{StaticResource FormFieldError}"
                        Text="{Binding Loan.TermMonthsError}"
                        Visibility="{Binding Loan.TermMonthsError, Converter={StaticResource StringToVisibilityConverter}}" />

                    <Border
                        Padding="12,10"
                        Background="{DynamicResource AppBackground}"
                        BorderBrush="{DynamicResource AppBorder}"
                        BorderThickness="1"
                        CornerRadius="{StaticResource Radius.Sm}">
                        <TextBlock
                            FontSize="{StaticResource Font.Size.Xs}"
                            Foreground="{DynamicResource AppTextMuted}"
                            Text="{DynamicResource Portfolio.Loan.RateHint}"
                            TextWrapping="Wrap" />
                    </Border>
                </StackPanel>
            </Grid>
            <StackPanel Margin="0,0,0,12">
                <StackPanel.Visibility>
                    <MultiBinding Converter="{StaticResource WidthScaleThresholdToVisibilityConverter}" ConverterParameter="900">
                        <Binding ElementName="Root" Path="ActualWidth" />
                        <Binding Path="DataContext.Settings.UiScale" RelativeSource="{RelativeSource AncestorType=Window}" />
                    </MultiBinding>
                </StackPanel.Visibility>
                <TextBlock
                    Margin="0,0,0,4"
                    FontSize="{StaticResource Font.Size.Xs}"
                    FontWeight="SemiBold"
                    Foreground="{DynamicResource AppTextSecondary}"
                    Text="{DynamicResource Portfolio.Loan.AnnualRate}" />
                <TextBox Text="{Binding Loan.Rate, UpdateSourceTrigger=PropertyChanged}" />
                <TextBlock
                    Margin="0,0,0,12"
                    Style="{StaticResource FormFieldError}"
                    Text="{Binding Loan.RateError}"
                    Visibility="{Binding Loan.RateError, Converter={StaticResource StringToVisibilityConverter}}" />

                <TextBlock
                    Margin="0,0,0,4"
                    FontSize="{StaticResource Font.Size.Xs}"
                    FontWeight="SemiBold"
                    Foreground="{DynamicResource AppTextSecondary}"
                    Text="{DynamicResource Portfolio.Loan.TermMonths}" />
                <TextBox Text="{Binding Loan.TermMonths, UpdateSourceTrigger=PropertyChanged}" />
                <TextBlock
                    Margin="0,0,0,12"
                    Style="{StaticResource FormFieldError}"
                    Text="{Binding Loan.TermMonthsError}"
                    Visibility="{Binding Loan.TermMonthsError, Converter={StaticResource StringToVisibilityConverter}}" />

                <TextBlock
                    Margin="0,0,0,4"
                    FontSize="{StaticResource Font.Size.Xs}"
                    FontWeight="SemiBold"
                    Foreground="{DynamicResource AppTextSecondary}"
                    Text="{DynamicResource Portfolio.Loan.StartDate}" />
                <DatePicker
                    MinWidth="132"
                    HorizontalContentAlignment="Left"
                    SelectedDate="{Binding Loan.StartDate, Mode=TwoWay, UpdateSourceTrigger=PropertyChanged}"
                    Style="{StaticResource AppDatePicker}" />
                <TextBlock
                    Margin="0,4,0,0"
                    FontSize="{StaticResource Font.Size.Xs}"
                    Foreground="{DynamicResource AppTextMuted}"
                    Text="填寫年利率與期數可自動產生攤還表"
                    TextWrapping="Wrap" />
            </StackPanel>
        </StackPanel>

        <!--  還款：本金 + 利息拆分  -->
        <StackPanel Visibility="{Binding TxTypeIsLoanRepay, Converter={StaticResource BooleanToVisibilityConverter}}">
            <Grid Margin="0,0,0,12">
                <Grid.Visibility>
                    <MultiBinding Converter="{StaticResource InverseWidthScaleThresholdToVisibilityConverter}" ConverterParameter="860">
                        <Binding ElementName="Root" Path="ActualWidth" />
                        <Binding Path="DataContext.Settings.UiScale" RelativeSource="{RelativeSource AncestorType=Window}" />
                    </MultiBinding>
                </Grid.Visibility>
                <Grid.ColumnDefinitions>
                    <ColumnDefinition Width="*" />
                    <ColumnDefinition Width="12" />
                    <ColumnDefinition Width="*" />
                </Grid.ColumnDefinitions>
                <StackPanel Grid.Column="0">
                    <TextBlock
                        Margin="0,0,0,4"
                        FontSize="{StaticResource Font.Size.Xs}"
                        FontWeight="SemiBold"
                        Foreground="{DynamicResource AppTextSecondary}"
                        Text="{DynamicResource Portfolio.Tx.Principal}" />
                    <TextBox behaviors:ThousandSeparatorBehavior.IsEnabled="True" Text="{Binding Loan.Principal, UpdateSourceTrigger=PropertyChanged}" />
                    <TextBlock
                        Margin="0,0,0,0"
                        Style="{StaticResource FormFieldError}"
                        Text="{Binding Loan.PrincipalError}"
                        Visibility="{Binding Loan.PrincipalError, Converter={StaticResource StringToVisibilityConverter}}" />
                </StackPanel>
                <StackPanel Grid.Column="2">
                    <TextBlock
                        Margin="0,0,0,4"
                        FontSize="{StaticResource Font.Size.Xs}"
                        FontWeight="SemiBold"
                        Foreground="{DynamicResource AppTextSecondary}"
                        Text="{DynamicResource Portfolio.Tx.InterestPaid}" />
                    <TextBox behaviors:ThousandSeparatorBehavior.IsEnabled="True" Text="{Binding Loan.InterestPaid, UpdateSourceTrigger=PropertyChanged}" />
                    <TextBlock
                        Style="{StaticResource FormFieldError}"
                        Text="{Binding Loan.InterestPaidError}"
                        Visibility="{Binding Loan.InterestPaidError, Converter={StaticResource StringToVisibilityConverter}}" />
                </StackPanel>
            </Grid>
            <StackPanel Margin="0,0,0,12">
                <StackPanel.Visibility>
                    <MultiBinding Converter="{StaticResource WidthScaleThresholdToVisibilityConverter}" ConverterParameter="860">
                        <Binding ElementName="Root" Path="ActualWidth" />
                        <Binding Path="DataContext.Settings.UiScale" RelativeSource="{RelativeSource AncestorType=Window}" />
                    </MultiBinding>
                </StackPanel.Visibility>
                <TextBlock
                    Margin="0,0,0,4"
                    FontSize="{StaticResource Font.Size.Xs}"
                    FontWeight="SemiBold"
                    Foreground="{DynamicResource AppTextSecondary}"
                    Text="{DynamicResource Portfolio.Tx.Principal}" />
                <TextBox behaviors:ThousandSeparatorBehavior.IsEnabled="True" Text="{Binding Loan.Principal, UpdateSourceTrigger=PropertyChanged}" />
                <TextBlock
                    Margin="0,0,0,12"
                    Style="{StaticResource FormFieldError}"
                    Text="{Binding Loan.PrincipalError}"
                    Visibility="{Binding Loan.PrincipalError, Converter={StaticResource StringToVisibilityConverter}}" />

                <TextBlock
                    Margin="0,0,0,4"
                    FontSize="{StaticResource Font.Size.Xs}"
                    FontWeight="SemiBold"
                    Foreground="{DynamicResource AppTextSecondary}"
                    Text="{DynamicResource Portfolio.Tx.InterestPaid}" />
                <TextBox behaviors:ThousandSeparatorBehavior.IsEnabled="True" Text="{Binding Loan.InterestPaid, UpdateSourceTrigger=PropertyChanged}" />
                <TextBlock
                    Style="{StaticResource FormFieldError}"
                    Text="{Binding Loan.InterestPaidError}"
                    Visibility="{Binding Loan.InterestPaidError, Converter={StaticResource StringToVisibilityConverter}}" />
            </StackPanel>
            <TextBlock
                Margin="0,2,0,12"
                FontSize="{StaticResource Font.Size.Xs}"
                Foreground="{DynamicResource AppTextMuted}"
                Text="{DynamicResource Portfolio.Tx.LoanRepayTotalHint}"
                TextWrapping="Wrap" />
        </StackPanel>

        <!--  手續費（選填）  -->
        <TextBlock
            Margin="0,0,0,4"
            FontSize="{StaticResource Font.Size.Xs}"
            FontWeight="SemiBold"
            Foreground="{DynamicResource AppTextSecondary}"
            Text="{DynamicResource Portfolio.Tx.Fee}" />
        <TextBox behaviors:ThousandSeparatorBehavior.IsEnabled="True" Text="{Binding TxFee, UpdateSourceTrigger=PropertyChanged}" />
        <TextBlock
            Margin="0,0,0,12"
            Style="{StaticResource FormFieldError}"
            Text="{Binding TxFeeError}"
            Visibility="{Binding TxFeeError, Converter={StaticResource StringToVisibilityConverter}}" />

        <!--  連動現金帳戶  -->
        <CheckBox
            Margin="0,0,0,4"
            Content="{Binding TxUseCashAccountLabel}"
            FontSize="{StaticResource Font.Size.Xs}"
            Foreground="{DynamicResource AppTextSecondary}"
            IsChecked="{Binding TxUseCashAccount, Mode=TwoWay}" />

        <StackPanel Visibility="{Binding TxUseCashAccount, Converter={StaticResource BooleanToVisibilityConverter}}">
            <TextBlock
                Margin="0,0,0,4"
                FontSize="{StaticResource Font.Size.Xs}"
                FontWeight="SemiBold"
                Foreground="{DynamicResource AppTextSecondary}"
                Text="{Binding TxCashAccountLabel}" />
            <ComboBox
                Margin="0,0,0,4"
                DisplayMemberPath="Name"
                ItemsSource="{Binding CashAccounts}"
                SelectedItem="{Binding TxCashAccount, Mode=TwoWay}"
                Style="{StaticResource FormComboBox}">
                <ComboBox.Resources>
                    <Style BasedOn="{StaticResource FormComboBoxItem}" TargetType="ComboBoxItem" />
                </ComboBox.Resources>
            </ComboBox>
            <TextBlock
                Margin="0,0,0,12"
                FontSize="{StaticResource Font.Size.Xs}"
                Foreground="{DynamicResource AppTextMuted}"
                Text="{DynamicResource Portfolio.Tx.LoanCashAccountHint}"
                TextWrapping="Wrap" />
        </StackPanel>

        <!--  P2.9 — TxNote 已 unified 到 AddRecordDialog dialog level。  -->
    </StackPanel>
</UserControl>
