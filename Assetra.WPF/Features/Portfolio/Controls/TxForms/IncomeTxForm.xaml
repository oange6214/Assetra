<UserControl
    x:Class="Assetra.WPF.Features.Portfolio.Controls.TxForms.IncomeTxForm"
    xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
    xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
    xmlns:behaviors="clr-namespace:Assetra.WPF.Infrastructure.Behaviors"
    xmlns:d="http://schemas.microsoft.com/expression/blend/2008"
    xmlns:mc="http://schemas.openxmlformats.org/markup-compatibility/2006"
    xmlns:vm="clr-namespace:Assetra.WPF.Features.Portfolio.SubViewModels"
    d:DataContext="{d:DesignInstance Type={x:Type vm:TransactionDialogViewModel}}"
    mc:Ignorable="d">

    <!--  ======== 收入欄位 ========  -->
    <StackPanel Visibility="{Binding TxTypeIsIncome, Converter={StaticResource BooleanToVisibilityConverter}}">

        <!--  金額  -->
        <TextBlock
            Margin="0,0,0,4"
            FontSize="{StaticResource Font.Size.Xs}"
            FontWeight="SemiBold"
            Foreground="{DynamicResource AppTextSecondary}"
            Text="{DynamicResource Portfolio.Tx.Amount}" />
        <TextBox behaviors:ThousandSeparatorBehavior.IsEnabled="True" Text="{Binding TxAmount, UpdateSourceTrigger=PropertyChanged}" />
        <TextBlock
            Margin="0,0,0,12"
            Style="{StaticResource FormFieldError}"
            Text="{Binding TxAmountError}"
            Visibility="{Binding TxAmountError, Converter={StaticResource StringToVisibilityConverter}}" />

        <!--  帳戶  -->
        <TextBlock
            Margin="0,0,0,4"
            FontSize="{StaticResource Font.Size.Xs}"
            FontWeight="SemiBold"
            Foreground="{DynamicResource AppTextSecondary}"
            Text="{Binding TxCashAccountLabel}" />
        <ComboBox
            Margin="0,0,0,4"
            DisplayMemberPath="Name"
            IsEditable="True"
            IsTextSearchEnabled="True"
            ItemsSource="{Binding CashAccounts}"
            SelectedItem="{Binding TxCashAccount, Mode=TwoWay}"
            Style="{StaticResource FormComboBox}"
            Text="{Binding TxCashAccountName, UpdateSourceTrigger=PropertyChanged, Mode=TwoWay}">
            <ComboBox.Resources>
                <Style BasedOn="{StaticResource FormComboBoxItem}" TargetType="ComboBoxItem" />
            </ComboBox.Resources>
        </ComboBox>
        <TextBlock
            Margin="0,2,0,4"
            FontSize="{StaticResource Font.Size.Xs}"
            Foreground="{DynamicResource AppAccent}"
            Text="{DynamicResource Portfolio.Tx.WillCreateNew}"
            Visibility="{Binding IsNewCashAccount, Converter={StaticResource BooleanToVisibilityConverter}}" />
        <TextBlock
            Margin="0,2,0,12"
            FontSize="{StaticResource Font.Size.Xs}"
            Foreground="{DynamicResource AppTextMuted}"
            Text="{DynamicResource Portfolio.Tx.NoCashLink}" />

        <!--  手續費  -->
        <TextBlock
            Margin="0,0,0,4"
            FontSize="{StaticResource Font.Size.Xs}"
            FontWeight="SemiBold"
            Foreground="{DynamicResource AppTextSecondary}"
            Text="{DynamicResource Portfolio.Tx.Fee}" />
        <TextBox behaviors:ThousandSeparatorBehavior.IsEnabled="True" Text="{Binding TxFee, UpdateSourceTrigger=PropertyChanged}" />
        <TextBlock
            Margin="0,0,0,12"
            Style="{StaticResource FormFieldError}"
            Text="{Binding TxFeeError}"
            Visibility="{Binding TxFeeError, Converter={StaticResource StringToVisibilityConverter}}" />

        <!--
            分類（P1 收支管理）— 主要分類選擇，先於備註出現以反映其重要性。
            原本上方的「說明」ComboBox 已移除：它跟分類使用同一份 preset 清單
            （薪資/獎金/分紅/...）造成 UX 混淆，且因 Trade.Name 同步寫入該值，
            讓交易列表「資產」欄顯示「薪資」這種非帳戶資料。重構後分類獨佔
            該語義，Trade.Name 改寫帳戶名（見 RecordIncomeAsync）。
        -->
        <TextBlock
            Margin="0,0,0,4"
            FontSize="{StaticResource Font.Size.Xs}"
            FontWeight="SemiBold"
            Foreground="{DynamicResource AppTextSecondary}"
            Text="{DynamicResource Categories.Rule.CategoryHint}" />
        <ComboBox
            DisplayMemberPath="Name"
            ItemsSource="{Binding IncomeCategories}"
            SelectedValue="{Binding TxCategoryId, Mode=TwoWay}"
            SelectedValuePath="Id"
            Style="{StaticResource FormComboBox}" />

        <!--
            備註 — 自由文字輸入（曾為 ComboBox + IncomeNotes preset list）。
            與其他 TxForm 一致：寫入 Trade.Note，不再參與分類運算（分類由
            上面的 ComboBox 直接決定，AutoCategorizationEngine 仍會在使用者
            未指定時嘗試從 Note 文字猜分類）。
        -->
        <TextBlock
            Margin="0,12,0,4"
            FontSize="{StaticResource Font.Size.Xs}"
            FontWeight="SemiBold"
            Foreground="{DynamicResource AppTextSecondary}"
            Text="{DynamicResource Portfolio.Tx.Note}" />
        <TextBox Text="{Binding TxNote, UpdateSourceTrigger=PropertyChanged}" />
    </StackPanel>
</UserControl>
