<UserControl
    x:Class="Assetra.WPF.Features.Portfolio.Controls.TxForms.Shared.FormField"
    xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
    xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
    xmlns:behaviors="clr-namespace:Assetra.WPF.Infrastructure.Behaviors"
    xmlns:d="http://schemas.microsoft.com/expression/blend/2008"
    xmlns:ds="clr-namespace:Assetra.WPF.DesignSystem.Controls"
    xmlns:mc="http://schemas.openxmlformats.org/markup-compatibility/2006"
    x:Name="Root"
    mc:Ignorable="d">

    <!--
        Wave 1 — 「semibold label → TextBox → FormFieldError」三件組共用控制項。
        Label / TextBox / error 三段 markup 逐字沿用 BuyTxForm 數量欄位原本的
        inline 樣式（label 用 Font.Size.Xs + SemiBold + AppTextSecondary + margin
        0,0,0,6；TextBox 走隱式樣式 + Tag placeholder；error 走 FormFieldError）。
        內層綁定用 ElementName=Root 讀本控制項的 DP（唯 ToolTip 內例外，見下方說明）。
    -->
    <StackPanel>
        <!--  label（＋選填 ⓘ：說明只在 hover 顯示，不常駐佔行）  -->
        <StackPanel Margin="0,0,0,6" Orientation="Horizontal">
            <TextBlock
                VerticalAlignment="Center"
                FontSize="{StaticResource Font.Size.Xs}"
                FontWeight="SemiBold"
                Foreground="{DynamicResource AppTextSecondary}"
                Text="{Binding Label, ElementName=Root}" />
            <ds:AppIcon
                Margin="6,0,0,0"
                VerticalAlignment="Center"
                AutomationProperties.Name="{Binding InfoTooltip, ElementName=Root}"
                FontSize="12"
                Foreground="{DynamicResource AppTextMuted}"
                Symbol="Info24"
                ToolTipService.InitialShowDelay="250"
                ToolTipService.ShowDuration="20000"
                Visibility="{Binding InfoTooltip, ElementName=Root, Converter={StaticResource StringToVisibilityConverter}}">
                <ds:AppIcon.ToolTip>
                    <ToolTip>
                        <!--
                            ToolTip 由 Popup 承載，活在獨立 namescope，看不到外層的 x:Name="Root"，
                            所以此處不能用 ElementName=Root（會噴 Cannot find source）。改走
                            ToolTip.PlacementTarget（＝上面那顆 AppIcon）→ 它的 AutomationProperties.Name
                            已綁同一個 InfoTooltip 字串，直接借來當顯示文字。
                        -->
                        <TextBlock
                            MaxWidth="280"
                            FontSize="{StaticResource Font.Size.Xs}"
                            Foreground="{DynamicResource AppTextSecondary}"
                            Text="{Binding PlacementTarget.(AutomationProperties.Name), RelativeSource={RelativeSource AncestorType=ToolTip}}"
                            TextWrapping="Wrap" />
                    </ToolTip>
                </ds:AppIcon.ToolTip>
            </ds:AppIcon>
        </StackPanel>
        <TextBox
            behaviors:ThousandSeparatorBehavior.IsEnabled="{Binding ThousandSeparator, ElementName=Root}"
            IsEnabled="{Binding InputEnabled, ElementName=Root}"
            Tag="{Binding Placeholder, ElementName=Root}"
            Text="{Binding Text, ElementName=Root, UpdateSourceTrigger=PropertyChanged}" />
        <TextBlock
            Margin="{Binding ErrorMargin, ElementName=Root}"
            Style="{StaticResource FormFieldError}"
            Text="{Binding ErrorText, ElementName=Root}"
            Visibility="{Binding ErrorText, ElementName=Root, Converter={StaticResource StringToVisibilityConverter}}" />
    </StackPanel>
</UserControl>
