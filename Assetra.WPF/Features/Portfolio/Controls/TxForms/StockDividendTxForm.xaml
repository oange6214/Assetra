<UserControl
    x:Class="Assetra.WPF.Features.Portfolio.Controls.TxForms.StockDividendTxForm"
    xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
    xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
    xmlns:behaviors="clr-namespace:Assetra.WPF.Infrastructure.Behaviors"
    xmlns:d="http://schemas.microsoft.com/expression/blend/2008"
    xmlns:mc="http://schemas.openxmlformats.org/markup-compatibility/2006"
    xmlns:vm="clr-namespace:Assetra.WPF.Features.Portfolio.SubViewModels"
    d:DataContext="{d:DesignInstance Type={x:Type vm:TransactionDialogViewModel},
                                     IsDesignTimeCreatable=False}"
    mc:Ignorable="d">

    <!--  ======== 股票股利欄位 ========  -->
    <StackPanel Visibility="{Binding TxTypeIsStockDiv, Converter={StaticResource BooleanToVisibilityConverter}}">
        <!--  股票已由上方「選擇資產」決定（股票股利只在選到投資持倉時可選，cascade 會把它設成
              Div.StockPosition），故此處不再重複顯示股票選擇器，避免與「選擇資產」重複。  -->

        <TextBlock
            Margin="0,0,0,6"
            FontSize="{StaticResource Font.Size.Xs}"
            FontWeight="SemiBold"
            Foreground="{DynamicResource AppTextSecondary}"
            Text="{DynamicResource Portfolio.Tx.NewShares}" />
        <TextBox
            behaviors:ThousandSeparatorBehavior.IsEnabled="True"
            IsEnabled="{Binding AreEconomicFieldsEditable}"
            Tag="{DynamicResource Portfolio.Tx.QuantityPlaceholder}"
            Text="{Binding Div.StockNewShares, UpdateSourceTrigger=PropertyChanged}" />
        <TextBlock
            Style="{StaticResource FormFieldError}"
            Text="{Binding Div.StockNewSharesError}"
            Visibility="{Binding Div.StockNewSharesError, Converter={StaticResource StringToVisibilityConverter}}" />
    </StackPanel>
</UserControl>
