<UserControl
    x:Class="Assetra.WPF.Features.Reports.ReportsView"
    xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
    xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
    xmlns:d="http://schemas.microsoft.com/expression/blend/2008"
    xmlns:mc="http://schemas.openxmlformats.org/markup-compatibility/2006"
    xmlns:ui="http://schemas.lepo.co/wpfui/2022/xaml"
    xmlns:vm="clr-namespace:Assetra.WPF.Features.Reports"
    d:DataContext="{d:DesignInstance Type={x:Type vm:ReportsViewModel},
                                     IsDesignTimeCreatable=False}"
    d:DesignHeight="776"
    d:DesignWidth="1100"
    Background="{DynamicResource AppBackground}"
    mc:Ignorable="d">

    <Grid Margin="24">
        <Grid.RowDefinitions>
            <RowDefinition Height="Auto" />
            <!--  header  -->
            <RowDefinition Height="Auto" />
            <!--  metric cards  -->
            <RowDefinition Height="*" />
            <!--  detail lists  -->
            <RowDefinition Height="Auto" />
            <!--  statements  -->
            <RowDefinition Height="Auto" />
            <!--  export status  -->
        </Grid.RowDefinitions>

        <!--  ── Header: month picker ──  -->
        <DockPanel Grid.Row="0" Margin="0,0,0,16">
            <TextBlock
                VerticalAlignment="Center"
                FontFamily="{StaticResource FontTabular}"
                FontSize="{DynamicResource FontSizeXl}"
                FontWeight="SemiBold"
                Foreground="{DynamicResource AppTextPrimary}"
                Text="{DynamicResource Reports.Title}" />

            <StackPanel
                Margin="24,0,0,0"
                VerticalAlignment="Center"
                Orientation="Horizontal">
                <Button
                    Width="32"
                    Height="32"
                    Padding="0"
                    Command="{Binding PrevMonthCommand}"
                    Style="{StaticResource BtnGhost}"
                    ToolTip="{DynamicResource Reports.PrevMonth}">
                    <ui:SymbolIcon FontSize="16" Symbol="ChevronLeft24" />
                </Button>
                <TextBlock
                    Margin="12,0"
                    VerticalAlignment="Center"
                    FontFamily="{StaticResource FontTabular}"
                    FontSize="{DynamicResource FontSizeLg}"
                    FontWeight="SemiBold"
                    Foreground="{DynamicResource AppTextPrimary}"
                    Text="{Binding MonthHeader}" />
                <Button
                    Width="32"
                    Height="32"
                    Padding="0"
                    Command="{Binding NextMonthCommand}"
                    Style="{StaticResource BtnGhost}"
                    ToolTip="{DynamicResource Reports.NextMonth}">
                    <ui:SymbolIcon FontSize="16" Symbol="ChevronRight24" />
                </Button>
                <Button
                    Margin="16,0,0,0"
                    Command="{Binding LoadCommand}"
                    Content="{DynamicResource Reports.Reload}"
                    Style="{StaticResource BtnGhost}" />
            </StackPanel>

            <TextBlock
                Margin="16,0,0,0"
                VerticalAlignment="Center"
                FontStyle="Italic"
                Foreground="{DynamicResource AppTextSecondary}"
                Text="{DynamicResource Reports.Loading}"
                Visibility="{Binding IsLoading, Converter={StaticResource BooleanToVisibilityConverter}}" />
        </DockPanel>

        <!--  ── Metric cards: Income / Expense / Net + Savings rate ──  -->
        <UniformGrid
            Grid.Row="1"
            Margin="0,0,0,24"
            Columns="4"
            Rows="1">

            <Border
                Margin="0,0,8,0"
                Padding="16"
                Background="{DynamicResource AppSurface}"
                BorderBrush="{DynamicResource AppBorder}"
                BorderThickness="1"
                CornerRadius="8">
                <StackPanel>
                    <TextBlock
                        FontSize="{DynamicResource FontSizeXs}"
                        Foreground="{DynamicResource AppTextSecondary}"
                        Text="{DynamicResource Reports.Income}" />
                    <TextBlock
                        Margin="0,8,0,4"
                        FontFamily="{StaticResource FontTabular}"
                        FontSize="{DynamicResource FontSizeXl}"
                        FontWeight="SemiBold"
                        Foreground="{DynamicResource AppUp}"
                        Text="{Binding IncomeDisplay}" />
                    <TextBlock
                        FontFamily="{StaticResource FontTabular}"
                        FontSize="{DynamicResource FontSizeXs}"
                        Foreground="{DynamicResource AppTextSecondary}"
                        Text="{Binding IncomeDeltaDisplay}"
                        ToolTip="{DynamicResource Reports.DeltaTooltip}" />
                </StackPanel>
            </Border>

            <Border
                Margin="8,0"
                Padding="16"
                Background="{DynamicResource AppSurface}"
                BorderBrush="{DynamicResource AppBorder}"
                BorderThickness="1"
                CornerRadius="8">
                <StackPanel>
                    <TextBlock
                        FontSize="{DynamicResource FontSizeXs}"
                        Foreground="{DynamicResource AppTextSecondary}"
                        Text="{DynamicResource Reports.Expense}" />
                    <TextBlock
                        Margin="0,8,0,4"
                        FontFamily="{StaticResource FontTabular}"
                        FontSize="{DynamicResource FontSizeXl}"
                        FontWeight="SemiBold"
                        Foreground="{DynamicResource AppDown}"
                        Text="{Binding ExpenseDisplay}" />
                    <TextBlock
                        FontFamily="{StaticResource FontTabular}"
                        FontSize="{DynamicResource FontSizeXs}"
                        Foreground="{DynamicResource AppTextSecondary}"
                        Text="{Binding ExpenseDeltaDisplay}"
                        ToolTip="{DynamicResource Reports.DeltaTooltip}" />
                </StackPanel>
            </Border>

            <Border
                Margin="8,0"
                Padding="16"
                Background="{DynamicResource AppSurface}"
                BorderBrush="{DynamicResource AppBorder}"
                BorderThickness="1"
                CornerRadius="8">
                <StackPanel>
                    <TextBlock
                        FontSize="{DynamicResource FontSizeXs}"
                        Foreground="{DynamicResource AppTextSecondary}"
                        Text="{DynamicResource Reports.Net}" />
                    <TextBlock
                        Margin="0,8,0,4"
                        FontFamily="{StaticResource FontTabular}"
                        FontSize="{DynamicResource FontSizeXl}"
                        FontWeight="SemiBold"
                        Foreground="{DynamicResource AppTextPrimary}"
                        Text="{Binding NetDisplay}" />
                    <TextBlock
                        FontFamily="{StaticResource FontTabular}"
                        FontSize="{DynamicResource FontSizeXs}"
                        Foreground="{DynamicResource AppTextSecondary}"
                        Text="{Binding NetDeltaDisplay}"
                        ToolTip="{DynamicResource Reports.DeltaTooltip}" />
                </StackPanel>
            </Border>

            <Border
                Margin="8,0,0,0"
                Padding="16"
                Background="{DynamicResource AppSurface}"
                BorderBrush="{DynamicResource AppBorder}"
                BorderThickness="1"
                CornerRadius="8">
                <StackPanel>
                    <TextBlock
                        FontSize="{DynamicResource FontSizeXs}"
                        Foreground="{DynamicResource AppTextSecondary}"
                        Text="{DynamicResource Reports.SavingsRate}" />
                    <TextBlock
                        Margin="0,8,0,4"
                        FontFamily="{StaticResource FontTabular}"
                        FontSize="{DynamicResource FontSizeXl}"
                        FontWeight="SemiBold"
                        Foreground="{DynamicResource AppAccent}"
                        Text="{Binding SavingsRateDisplay}" />
                </StackPanel>
            </Border>
        </UniformGrid>

        <!--  ── Detail lists: over-budget + upcoming ──  -->
        <Grid Grid.Row="2">
            <Grid.ColumnDefinitions>
                <ColumnDefinition Width="*" />
                <ColumnDefinition Width="*" />
            </Grid.ColumnDefinitions>

            <!--  Over-budget categories  -->
            <Border
                Grid.Column="0"
                Margin="0,0,8,0"
                Padding="16"
                Background="{DynamicResource AppSurface}"
                BorderBrush="{DynamicResource AppBorder}"
                BorderThickness="1"
                CornerRadius="8">
                <DockPanel>
                    <TextBlock
                        DockPanel.Dock="Top"
                        Margin="0,0,0,12"
                        FontSize="{DynamicResource FontSizeMd}"
                        FontWeight="SemiBold"
                        Foreground="{DynamicResource AppTextPrimary}"
                        Text="{DynamicResource Reports.OverBudget.Title}" />

                    <TextBlock
                        DockPanel.Dock="Top"
                        FontStyle="Italic"
                        Foreground="{DynamicResource AppTextSecondary}"
                        Text="{DynamicResource Reports.OverBudget.Empty}"
                        Visibility="{Binding HasOverBudget, Converter={StaticResource InverseBooleanToVisibilityConverter}}" />

                    <ItemsControl
                        ItemsSource="{Binding OverBudgetRows}"
                        Visibility="{Binding HasOverBudget, Converter={StaticResource BooleanToVisibilityConverter}}">
                        <ItemsControl.ItemTemplate>
                            <DataTemplate>
                                <Grid Margin="0,6">
                                    <Grid.RowDefinitions>
                                        <RowDefinition Height="Auto" />
                                        <RowDefinition Height="Auto" />
                                    </Grid.RowDefinitions>
                                    <Grid.ColumnDefinitions>
                                        <ColumnDefinition Width="*" />
                                        <ColumnDefinition Width="Auto" />
                                        <ColumnDefinition Width="Auto" />
                                        <ColumnDefinition Width="Auto" />
                                    </Grid.ColumnDefinitions>
                                    <TextBlock
                                        Grid.Row="0"
                                        Grid.Column="0"
                                        Foreground="{DynamicResource AppTextPrimary}"
                                        Text="{Binding CategoryName}" />
                                    <TextBlock
                                        Grid.Row="0"
                                        Grid.Column="1"
                                        Margin="12,0,0,0"
                                        FontFamily="{StaticResource FontTabular}"
                                        Foreground="{DynamicResource AppDown}"
                                        Text="{Binding SpentDisplay}" />
                                    <TextBlock
                                        Grid.Row="0"
                                        Grid.Column="2"
                                        Margin="6,0,12,0"
                                        FontFamily="{StaticResource FontTabular}"
                                        Foreground="{DynamicResource AppTextSecondary}"
                                        Text="{Binding BudgetDisplay}" />
                                    <TextBlock
                                        Grid.Row="0"
                                        Grid.Column="3"
                                        FontFamily="{StaticResource FontTabular}"
                                        FontWeight="SemiBold"
                                        Foreground="{DynamicResource AppDown}"
                                        Text="{Binding OveragePercent, StringFormat=+{0:F0}%}" />

                                    <Border
                                        Grid.Row="1"
                                        Grid.Column="0"
                                        Grid.ColumnSpan="4"
                                        Height="4"
                                        Margin="0,4,0,0"
                                        Background="{DynamicResource AppBorder}"
                                        CornerRadius="2">
                                        <Border
                                            HorizontalAlignment="Left"
                                            Background="{DynamicResource AppDown}"
                                            CornerRadius="2">
                                            <Border.Width>
                                                <MultiBinding Converter="{StaticResource PercentToWidthConverter}">
                                                    <Binding Path="OveragePercent" />
                                                    <Binding Path="ActualWidth" RelativeSource="{RelativeSource AncestorType=ItemsControl}" />
                                                </MultiBinding>
                                            </Border.Width>
                                        </Border>
                                    </Border>
                                </Grid>
                            </DataTemplate>
                        </ItemsControl.ItemTemplate>
                    </ItemsControl>
                </DockPanel>
            </Border>

            <!--  Upcoming recurring  -->
            <Border
                Grid.Column="1"
                Margin="8,0,0,0"
                Padding="16"
                Background="{DynamicResource AppSurface}"
                BorderBrush="{DynamicResource AppBorder}"
                BorderThickness="1"
                CornerRadius="8">
                <DockPanel>
                    <TextBlock
                        DockPanel.Dock="Top"
                        Margin="0,0,0,12"
                        FontSize="{DynamicResource FontSizeMd}"
                        FontWeight="SemiBold"
                        Foreground="{DynamicResource AppTextPrimary}"
                        Text="{DynamicResource Reports.Upcoming.Title}" />

                    <TextBlock
                        DockPanel.Dock="Top"
                        FontStyle="Italic"
                        Foreground="{DynamicResource AppTextSecondary}"
                        Text="{DynamicResource Reports.Upcoming.Empty}"
                        Visibility="{Binding HasUpcoming, Converter={StaticResource InverseBooleanToVisibilityConverter}}" />

                    <ItemsControl
                        ItemsSource="{Binding UpcomingRows}"
                        Visibility="{Binding HasUpcoming, Converter={StaticResource BooleanToVisibilityConverter}}">
                        <ItemsControl.ItemTemplate>
                            <DataTemplate>
                                <Grid Margin="0,4">
                                    <Grid.ColumnDefinitions>
                                        <ColumnDefinition Width="Auto" />
                                        <ColumnDefinition Width="*" />
                                        <ColumnDefinition Width="Auto" />
                                    </Grid.ColumnDefinitions>
                                    <TextBlock
                                        Grid.Column="0"
                                        Width="80"
                                        FontFamily="{StaticResource FontTabular}"
                                        Foreground="{DynamicResource AppTextSecondary}"
                                        Text="{Binding DueDate, StringFormat=MM/dd}" />
                                    <TextBlock
                                        Grid.Column="1"
                                        Margin="12,0"
                                        Foreground="{DynamicResource AppTextPrimary}"
                                        Text="{Binding Name}" />
                                    <TextBlock
                                        Grid.Column="2"
                                        FontFamily="{StaticResource FontTabular}"
                                        Foreground="{DynamicResource AppTextPrimary}"
                                        Text="{Binding AmountDisplay}" />
                                </Grid>
                            </DataTemplate>
                        </ItemsControl.ItemTemplate>
                    </ItemsControl>
                </DockPanel>
            </Border>
        </Grid>

        <!--  ── Statements (Income / Balance / CashFlow) ──  -->
        <StackPanel Grid.Row="3" Margin="0,16,0,0">
            <Expander Header="{DynamicResource Reports.IncomeStatement.Title}" IsExpanded="False" Margin="0,0,0,8">
                <Grid Margin="12">
                    <Grid.RowDefinitions>
                        <RowDefinition Height="Auto" />
                        <RowDefinition Height="Auto" />
                    </Grid.RowDefinitions>
                    <StackPanel Grid.Row="0" Orientation="Horizontal" HorizontalAlignment="Right" Margin="0,0,0,8">
                        <ui:Button Margin="0,0,8,0" Command="{Binding ExportIncomePdfCommand}" Content="{DynamicResource Reports.Export.Pdf}" />
                        <ui:Button Command="{Binding ExportIncomeCsvCommand}" Content="{DynamicResource Reports.Export.Csv}" />
                    </StackPanel>
                    <StackPanel Grid.Row="1" DataContext="{Binding IncomeStatement}">
                        <TextBlock FontFamily="{StaticResource FontTabular}" Text="{Binding Income.Total, StringFormat='Income Total: {0:N2}'}" />
                        <TextBlock FontFamily="{StaticResource FontTabular}" Text="{Binding Expense.Total, StringFormat='Expense Total: {0:N2}'}" />
                        <TextBlock FontFamily="{StaticResource FontTabular}" FontWeight="SemiBold" Text="{Binding Net, StringFormat='Net: {0:N2}'}" />
                    </StackPanel>
                </Grid>
            </Expander>

            <Expander Header="{DynamicResource Reports.BalanceSheet.Title}" IsExpanded="False" Margin="0,0,0,8">
                <Grid Margin="12">
                    <Grid.RowDefinitions>
                        <RowDefinition Height="Auto" />
                        <RowDefinition Height="Auto" />
                    </Grid.RowDefinitions>
                    <StackPanel Grid.Row="0" Orientation="Horizontal" HorizontalAlignment="Right" Margin="0,0,0,8">
                        <ui:Button Margin="0,0,8,0" Command="{Binding ExportBalancePdfCommand}" Content="{DynamicResource Reports.Export.Pdf}" />
                        <ui:Button Command="{Binding ExportBalanceCsvCommand}" Content="{DynamicResource Reports.Export.Csv}" />
                    </StackPanel>
                    <StackPanel Grid.Row="1" DataContext="{Binding BalanceSheet}">
                        <TextBlock FontFamily="{StaticResource FontTabular}" Text="{Binding AsOf, StringFormat='As Of: {0}'}" />
                        <TextBlock FontFamily="{StaticResource FontTabular}" Text="{Binding Assets.Total, StringFormat='Assets: {0:N2}'}" />
                        <TextBlock FontFamily="{StaticResource FontTabular}" Text="{Binding Liabilities.Total, StringFormat='Liabilities: {0:N2}'}" />
                        <TextBlock FontFamily="{StaticResource FontTabular}" FontWeight="SemiBold" Text="{Binding NetWorth, StringFormat='Net Worth: {0:N2}'}" />
                    </StackPanel>
                </Grid>
            </Expander>

            <Expander Header="{DynamicResource Reports.CashFlow.Title}" IsExpanded="False">
                <Grid Margin="12">
                    <Grid.RowDefinitions>
                        <RowDefinition Height="Auto" />
                        <RowDefinition Height="Auto" />
                    </Grid.RowDefinitions>
                    <StackPanel Grid.Row="0" Orientation="Horizontal" HorizontalAlignment="Right" Margin="0,0,0,8">
                        <ui:Button Margin="0,0,8,0" Command="{Binding ExportCashFlowPdfCommand}" Content="{DynamicResource Reports.Export.Pdf}" />
                        <ui:Button Command="{Binding ExportCashFlowCsvCommand}" Content="{DynamicResource Reports.Export.Csv}" />
                    </StackPanel>
                    <StackPanel Grid.Row="1" DataContext="{Binding CashFlowStatement}">
                        <TextBlock FontFamily="{StaticResource FontTabular}" Text="{Binding Operating.Total, StringFormat='Operating: {0:N2}'}" />
                        <TextBlock FontFamily="{StaticResource FontTabular}" Text="{Binding Investing.Total, StringFormat='Investing: {0:N2}'}" />
                        <TextBlock FontFamily="{StaticResource FontTabular}" Text="{Binding Financing.Total, StringFormat='Financing: {0:N2}'}" />
                        <TextBlock FontFamily="{StaticResource FontTabular}" FontWeight="SemiBold" Text="{Binding NetChange, StringFormat='Net Change: {0:N2}'}" />
                        <TextBlock FontFamily="{StaticResource FontTabular}" Foreground="{DynamicResource AppTextSecondary}" Text="{Binding OpeningCash, StringFormat='Opening Cash: {0:N2}'}" />
                        <TextBlock FontFamily="{StaticResource FontTabular}" Foreground="{DynamicResource AppTextSecondary}" Text="{Binding ClosingCash, StringFormat='Closing Cash: {0:N2}'}" />
                    </StackPanel>
                </Grid>
            </Expander>
        </StackPanel>

        <TextBlock
            Grid.Row="4"
            Margin="0,8,0,0"
            Foreground="{DynamicResource AppTextSecondary}"
            Text="{Binding ExportStatus}" />
    </Grid>
</UserControl>
