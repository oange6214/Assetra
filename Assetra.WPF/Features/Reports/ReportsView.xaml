<UserControl
    x:Class="Assetra.WPF.Features.Reports.ReportsView"
    xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
    xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
    xmlns:d="http://schemas.microsoft.com/expression/blend/2008"
    xmlns:mc="http://schemas.openxmlformats.org/markup-compatibility/2006"
    xmlns:ui="http://schemas.lepo.co/wpfui/2022/xaml"
    xmlns:vm="clr-namespace:Assetra.WPF.Features.Reports"
    d:DataContext="{d:DesignInstance Type={x:Type vm:ReportsViewModel},
                                     IsDesignTimeCreatable=False}"
    d:DesignHeight="776"
    d:DesignWidth="1100"
    Background="{DynamicResource AppBackground}"
    mc:Ignorable="d">

    <ScrollViewer
        Margin="24"
        VerticalScrollBarVisibility="Auto"
        HorizontalScrollBarVisibility="Disabled"
        CanContentScroll="False">
        <Grid>
            <Grid.RowDefinitions>
                <RowDefinition Height="Auto" />
                <!--  header  -->
                <RowDefinition Height="Auto" />
                <!--  metric cards  -->
                <RowDefinition Height="Auto" />
                <!--  detail lists  -->
                <RowDefinition Height="Auto" />
                <!--  statements  -->
                <RowDefinition Height="Auto" />
                <!--  export status  -->
            </Grid.RowDefinitions>

        <!--  ── Header: month picker ──  -->
        <DockPanel Grid.Row="0" Margin="0,0,0,16">

            <StackPanel
                Margin="24,0,0,0"
                VerticalAlignment="Center"
                Orientation="Horizontal">
                <ui:Button
                    Width="32"
                    Height="32"
                    Padding="0"
                    Command="{Binding PrevMonthCommand}"
                    Appearance="Secondary"
                    ToolTip="{DynamicResource Reports.PrevMonth}">
                    <ui:SymbolIcon FontSize="16" Symbol="ChevronLeft24" />
                </ui:Button>
                <TextBlock
                    Margin="12,0"
                    VerticalAlignment="Center"
                    FontFamily="{StaticResource FontBase}" Typography.NumeralAlignment="Tabular"
                    FontSize="{DynamicResource FontSizeLg}"
                    FontWeight="SemiBold"
                    Foreground="{DynamicResource AppTextPrimary}"
                    Text="{Binding MonthHeader}" />
                <ui:Button
                    Width="32"
                    Height="32"
                    Padding="0"
                    Command="{Binding NextMonthCommand}"
                    Appearance="Secondary"
                    ToolTip="{DynamicResource Reports.NextMonth}">
                    <ui:SymbolIcon FontSize="16" Symbol="ChevronRight24" />
                </ui:Button>
                <ui:Button
                    Margin="16,0,0,0"
                    Command="{Binding LoadCommand}"
                    Content="{DynamicResource Reports.Reload}"
                    Appearance="Secondary" />
            </StackPanel>

            <TextBlock
                Margin="16,0,0,0"
                VerticalAlignment="Center"
                FontStyle="Italic"
                Foreground="{DynamicResource AppTextSecondary}"
                Text="{DynamicResource Reports.Loading}"
                Visibility="{Binding IsLoading, Converter={StaticResource BooleanToVisibilityConverter}}" />
            <TextBlock
                Margin="16,0,0,0"
                VerticalAlignment="Center"
                Foreground="{DynamicResource AppDanger}"
                Text="{Binding ErrorMessage}"
                TextTrimming="CharacterEllipsis"
                Visibility="{Binding ErrorMessage, Converter={StaticResource StringToVisibilityConverter}}" />
        </DockPanel>

        <!--  ── Metric cards: Income / Expense / Net + Savings rate ──  -->
        <UniformGrid
            Grid.Row="1"
            Margin="0,0,0,24"
            Columns="4"
            Rows="1">

            <ui:Card
                Margin="0,0,8,0"
                Padding="16">
                <StackPanel>
                    <TextBlock
                        FontSize="{DynamicResource FontSizeXs}"
                        Foreground="{DynamicResource AppTextSecondary}"
                        Text="{DynamicResource Reports.Income}" />
                    <TextBlock
                        Margin="0,8,0,4"
                        FontFamily="{StaticResource FontBase}" Typography.NumeralAlignment="Tabular"
                        FontSize="{DynamicResource FontSizeXl}"
                        FontWeight="SemiBold"
                        Foreground="{DynamicResource AppUp}"
                        Text="{Binding IncomeDisplay}" />
                    <TextBlock
                        FontFamily="{StaticResource FontBase}" Typography.NumeralAlignment="Tabular"
                        FontSize="{DynamicResource FontSizeXs}"
                        Foreground="{DynamicResource AppTextSecondary}"
                        Text="{Binding IncomeDeltaDisplay}"
                        ToolTip="{DynamicResource Reports.DeltaTooltip}" />
                </StackPanel>
            </ui:Card>

            <ui:Card
                Margin="8,0"
                Padding="16">
                <StackPanel>
                    <TextBlock
                        FontSize="{DynamicResource FontSizeXs}"
                        Foreground="{DynamicResource AppTextSecondary}"
                        Text="{DynamicResource Reports.Expense}" />
                    <TextBlock
                        Margin="0,8,0,4"
                        FontFamily="{StaticResource FontBase}" Typography.NumeralAlignment="Tabular"
                        FontSize="{DynamicResource FontSizeXl}"
                        FontWeight="SemiBold"
                        Foreground="{DynamicResource AppDown}"
                        Text="{Binding ExpenseDisplay}" />
                    <TextBlock
                        FontFamily="{StaticResource FontBase}" Typography.NumeralAlignment="Tabular"
                        FontSize="{DynamicResource FontSizeXs}"
                        Foreground="{DynamicResource AppTextSecondary}"
                        Text="{Binding ExpenseDeltaDisplay}"
                        ToolTip="{DynamicResource Reports.DeltaTooltip}" />
                </StackPanel>
            </ui:Card>

            <ui:Card
                Margin="8,0"
                Padding="16">
                <StackPanel>
                    <TextBlock
                        FontSize="{DynamicResource FontSizeXs}"
                        Foreground="{DynamicResource AppTextSecondary}"
                        Text="{DynamicResource Reports.Net}" />
                    <TextBlock
                        Margin="0,8,0,4"
                        FontFamily="{StaticResource FontBase}" Typography.NumeralAlignment="Tabular"
                        FontSize="{DynamicResource FontSizeXl}"
                        FontWeight="SemiBold"
                        Foreground="{DynamicResource AppTextPrimary}"
                        Text="{Binding NetDisplay}" />
                    <TextBlock
                        FontFamily="{StaticResource FontBase}" Typography.NumeralAlignment="Tabular"
                        FontSize="{DynamicResource FontSizeXs}"
                        Foreground="{DynamicResource AppTextSecondary}"
                        Text="{Binding NetDeltaDisplay}"
                        ToolTip="{DynamicResource Reports.DeltaTooltip}" />
                </StackPanel>
            </ui:Card>

            <ui:Card
                Margin="8,0,0,0"
                Padding="16">
                <StackPanel>
                    <TextBlock
                        FontSize="{DynamicResource FontSizeXs}"
                        Foreground="{DynamicResource AppTextSecondary}"
                        Text="{DynamicResource Reports.SavingsRate}" />
                    <TextBlock
                        Margin="0,8,0,4"
                        FontFamily="{StaticResource FontBase}" Typography.NumeralAlignment="Tabular"
                        FontSize="{DynamicResource FontSizeXl}"
                        FontWeight="SemiBold"
                        Foreground="{DynamicResource AppAccent}"
                        Text="{Binding SavingsRateDisplay}" />
                </StackPanel>
            </ui:Card>
        </UniformGrid>

        <!--  ── Detail lists: over-budget + upcoming ──  -->
        <Grid Grid.Row="2">
            <Grid.ColumnDefinitions>
                <ColumnDefinition Width="*" />
                <ColumnDefinition Width="*" />
            </Grid.ColumnDefinitions>

            <!--  Over-budget categories  -->
            <ui:Card
                Grid.Column="0"
                Margin="0,0,8,0"
                Padding="16">
                <DockPanel>
                    <TextBlock
                        DockPanel.Dock="Top"
                        Margin="0,0,0,12"
                        FontSize="{DynamicResource FontSizeMd}"
                        FontWeight="SemiBold"
                        Foreground="{DynamicResource AppTextPrimary}"
                        Text="{DynamicResource Reports.OverBudget.Title}" />

                    <TextBlock
                        DockPanel.Dock="Top"
                        FontStyle="Italic"
                        Foreground="{DynamicResource AppTextSecondary}"
                        Text="{DynamicResource Reports.OverBudget.Empty}"
                        Visibility="{Binding HasOverBudget, Converter={StaticResource InverseBooleanToVisibilityConverter}}" />

                    <ItemsControl
                        ItemsSource="{Binding OverBudgetRows}"
                        Visibility="{Binding HasOverBudget, Converter={StaticResource BooleanToVisibilityConverter}}">
                        <ItemsControl.ItemTemplate>
                            <DataTemplate>
                                <Grid Margin="0,6">
                                    <Grid.RowDefinitions>
                                        <RowDefinition Height="Auto" />
                                        <RowDefinition Height="Auto" />
                                    </Grid.RowDefinitions>
                                    <Grid.ColumnDefinitions>
                                        <ColumnDefinition Width="*" />
                                        <ColumnDefinition Width="Auto" />
                                        <ColumnDefinition Width="Auto" />
                                        <ColumnDefinition Width="Auto" />
                                    </Grid.ColumnDefinitions>
                                    <TextBlock
                                        Grid.Row="0"
                                        Grid.Column="0"
                                        Foreground="{DynamicResource AppTextPrimary}"
                                        Text="{Binding CategoryName}" />
                                    <TextBlock
                                        Grid.Row="0"
                                        Grid.Column="1"
                                        Margin="12,0,0,0"
                                        FontFamily="{StaticResource FontBase}" Typography.NumeralAlignment="Tabular"
                                        Foreground="{DynamicResource AppDown}"
                                        Text="{Binding SpentDisplay}" />
                                    <TextBlock
                                        Grid.Row="0"
                                        Grid.Column="2"
                                        Margin="6,0,12,0"
                                        FontFamily="{StaticResource FontBase}" Typography.NumeralAlignment="Tabular"
                                        Foreground="{DynamicResource AppTextSecondary}"
                                        Text="{Binding BudgetDisplay}" />
                                    <TextBlock
                                        Grid.Row="0"
                                        Grid.Column="3"
                                        FontFamily="{StaticResource FontBase}" Typography.NumeralAlignment="Tabular"
                                        FontWeight="SemiBold"
                                        Foreground="{DynamicResource AppDown}"
                                        Text="{Binding OveragePercent, StringFormat=+{0:F0}%}" />

                                    <Border
                                        Grid.Row="1"
                                        Grid.Column="0"
                                        Grid.ColumnSpan="4"
                                        Height="4"
                                        Margin="0,4,0,0"
                                        Background="{DynamicResource AppBorder}"
                                        CornerRadius="{StaticResource RadiusXs}">
                                        <Border
                                            HorizontalAlignment="Left"
                                            Background="{DynamicResource AppDown}"
                                            CornerRadius="{StaticResource RadiusXs}">
                                            <Border.Width>
                                                <MultiBinding Converter="{StaticResource PercentToWidthConverter}">
                                                    <Binding Path="OveragePercent" />
                                                    <Binding Path="ActualWidth" RelativeSource="{RelativeSource AncestorType=ItemsControl}" />
                                                </MultiBinding>
                                            </Border.Width>
                                        </Border>
                                    </Border>
                                </Grid>
                            </DataTemplate>
                        </ItemsControl.ItemTemplate>
                    </ItemsControl>
                </DockPanel>
            </ui:Card>

            <!--  Upcoming recurring  -->
            <ui:Card
                Grid.Column="1"
                Margin="8,0,0,0"
                Padding="16">
                <DockPanel>
                    <TextBlock
                        DockPanel.Dock="Top"
                        Margin="0,0,0,12"
                        FontSize="{DynamicResource FontSizeMd}"
                        FontWeight="SemiBold"
                        Foreground="{DynamicResource AppTextPrimary}"
                        Text="{DynamicResource Reports.Upcoming.Title}" />

                    <TextBlock
                        DockPanel.Dock="Top"
                        FontStyle="Italic"
                        Foreground="{DynamicResource AppTextSecondary}"
                        Text="{DynamicResource Reports.Upcoming.Empty}"
                        Visibility="{Binding HasUpcoming, Converter={StaticResource InverseBooleanToVisibilityConverter}}" />

                    <ItemsControl
                        ItemsSource="{Binding UpcomingRows}"
                        Visibility="{Binding HasUpcoming, Converter={StaticResource BooleanToVisibilityConverter}}">
                        <ItemsControl.ItemTemplate>
                            <DataTemplate>
                                <Grid Margin="0,4">
                                    <Grid.ColumnDefinitions>
                                        <ColumnDefinition Width="Auto" />
                                        <ColumnDefinition Width="*" />
                                        <ColumnDefinition Width="Auto" />
                                    </Grid.ColumnDefinitions>
                                    <TextBlock
                                        Grid.Column="0"
                                        Width="80"
                                        FontFamily="{StaticResource FontBase}" Typography.NumeralAlignment="Tabular"
                                        Foreground="{DynamicResource AppTextSecondary}"
                                        Text="{Binding DueDate, StringFormat=MM/dd}" />
                                    <TextBlock
                                        Grid.Column="1"
                                        Margin="12,0"
                                        Foreground="{DynamicResource AppTextPrimary}"
                                        Text="{Binding Name}" />
                                    <TextBlock
                                        Grid.Column="2"
                                        FontFamily="{StaticResource FontBase}" Typography.NumeralAlignment="Tabular"
                                        Foreground="{DynamicResource AppTextPrimary}"
                                        Text="{Binding AmountDisplay}" />
                                </Grid>
                            </DataTemplate>
                        </ItemsControl.ItemTemplate>
                    </ItemsControl>
                </DockPanel>
            </ui:Card>
        </Grid>

        <!--  ── Statements (Income / Balance / CashFlow) ──  -->
        <StackPanel Grid.Row="3" Margin="0,16,0,0">
            <ui:CardExpander Header="{DynamicResource Reports.IncomeStatement.Title}" IsExpanded="False" Margin="0,0,0,8">
                <Grid Margin="12">
                    <Grid.RowDefinitions>
                        <RowDefinition Height="Auto" />
                        <RowDefinition Height="Auto" />
                    </Grid.RowDefinitions>
                    <StackPanel
                        Grid.Row="0"
                        Margin="0,0,0,12"
                        HorizontalAlignment="Right"
                        Orientation="Horizontal"
                        Visibility="{Binding HasIncomeStatement, Converter={StaticResource BooleanToVisibilityConverter}}">
                        <ui:Button Margin="0,0,8,0" Command="{Binding ExportIncomePdfCommand}" Content="{DynamicResource Reports.Export.Pdf}" />
                        <ui:Button Command="{Binding ExportIncomeCsvCommand}" Content="{DynamicResource Reports.Export.Csv}" />
                    </StackPanel>
                    <TextBlock
                        Grid.Row="1"
                        FontStyle="Italic"
                        Foreground="{DynamicResource AppTextSecondary}"
                        Text="{DynamicResource Reports.Statement.Empty}"
                        Visibility="{Binding HasIncomeStatement, Converter={StaticResource InverseBooleanToVisibilityConverter}}" />
                    <StackPanel Grid.Row="1" Visibility="{Binding HasIncomeStatement, Converter={StaticResource BooleanToVisibilityConverter}}">
                        <Grid>
                            <Grid.ColumnDefinitions>
                                <ColumnDefinition Width="*" />
                                <ColumnDefinition Width="16" />
                                <ColumnDefinition Width="*" />
                            </Grid.ColumnDefinitions>
                            <StackPanel Grid.Column="0">
                                <TextBlock
                                    FontWeight="SemiBold"
                                    Foreground="{DynamicResource AppTextPrimary}"
                                    Text="{DynamicResource Reports.Income.Total}" />
                                <TextBlock
                                    Margin="0,4,0,8"
                                    FontFamily="{StaticResource FontBase}"
                                    FontSize="{DynamicResource FontSizeLg}"
                                    FontWeight="SemiBold"
                                    Foreground="{DynamicResource AppUp}"
                                    Text="{Binding IncomeStatement.Income.Total, StringFormat={}{0:N2}}" />
                                <ItemsControl ItemsSource="{Binding IncomeStatement.Income.Rows}">
                                    <ItemsControl.ItemTemplate>
                                        <DataTemplate>
                                            <Grid Margin="0,3,0,0">
                                                <Grid.ColumnDefinitions>
                                                    <ColumnDefinition Width="*" />
                                                    <ColumnDefinition Width="Auto" />
                                                </Grid.ColumnDefinitions>
                                                <TextBlock
                                                    Grid.Column="0"
                                                    Foreground="{DynamicResource AppTextSecondary}"
                                                    Text="{Binding Label}" />
                                                <TextBlock
                                                    Grid.Column="1"
                                                    FontFamily="{StaticResource FontBase}"
                                                    Typography.NumeralAlignment="Tabular"
                                                    Foreground="{DynamicResource AppTextPrimary}"
                                                    Text="{Binding Amount, StringFormat={}{0:N2}}" />
                                            </Grid>
                                        </DataTemplate>
                                    </ItemsControl.ItemTemplate>
                                </ItemsControl>
                            </StackPanel>
                            <StackPanel Grid.Column="2">
                                <TextBlock
                                    FontWeight="SemiBold"
                                    Foreground="{DynamicResource AppTextPrimary}"
                                    Text="{DynamicResource Reports.Expense.Total}" />
                                <TextBlock
                                    Margin="0,4,0,8"
                                    FontFamily="{StaticResource FontBase}"
                                    FontSize="{DynamicResource FontSizeLg}"
                                    FontWeight="SemiBold"
                                    Foreground="{DynamicResource AppDown}"
                                    Text="{Binding IncomeStatement.Expense.Total, StringFormat={}{0:N2}}" />
                                <ItemsControl ItemsSource="{Binding IncomeStatement.Expense.Rows}">
                                    <ItemsControl.ItemTemplate>
                                        <DataTemplate>
                                            <Grid Margin="0,3,0,0">
                                                <Grid.ColumnDefinitions>
                                                    <ColumnDefinition Width="*" />
                                                    <ColumnDefinition Width="Auto" />
                                                </Grid.ColumnDefinitions>
                                                <TextBlock
                                                    Grid.Column="0"
                                                    Foreground="{DynamicResource AppTextSecondary}"
                                                    Text="{Binding Label}" />
                                                <TextBlock
                                                    Grid.Column="1"
                                                    FontFamily="{StaticResource FontBase}"
                                                    Typography.NumeralAlignment="Tabular"
                                                    Foreground="{DynamicResource AppTextPrimary}"
                                                    Text="{Binding Amount, StringFormat={}{0:N2}}" />
                                            </Grid>
                                        </DataTemplate>
                                    </ItemsControl.ItemTemplate>
                                </ItemsControl>
                            </StackPanel>
                        </Grid>
                        <Border Height="1" Margin="0,12,0,12" Background="{DynamicResource AppBorder}" />
                        <Grid>
                            <Grid.ColumnDefinitions>
                                <ColumnDefinition Width="*" />
                                <ColumnDefinition Width="Auto" />
                            </Grid.ColumnDefinitions>
                            <TextBlock
                                FontWeight="SemiBold"
                                Foreground="{DynamicResource AppTextPrimary}"
                                Text="{DynamicResource Reports.Net.Total}" />
                            <TextBlock
                                Grid.Column="1"
                                FontFamily="{StaticResource FontBase}"
                                Typography.NumeralAlignment="Tabular"
                                FontWeight="SemiBold"
                                Foreground="{DynamicResource AppTextPrimary}"
                                Text="{Binding IncomeStatement.Net, StringFormat={}{0:N2}}" />
                        </Grid>
                    </StackPanel>
                </Grid>
            </ui:CardExpander>

            <ui:CardExpander Header="{DynamicResource Reports.BalanceSheet.Title}" IsExpanded="False" Margin="0,0,0,8">
                <Grid Margin="12">
                    <Grid.RowDefinitions>
                        <RowDefinition Height="Auto" />
                        <RowDefinition Height="Auto" />
                    </Grid.RowDefinitions>
                    <StackPanel
                        Grid.Row="0"
                        Margin="0,0,0,12"
                        HorizontalAlignment="Right"
                        Orientation="Horizontal"
                        Visibility="{Binding HasBalanceSheet, Converter={StaticResource BooleanToVisibilityConverter}}">
                        <ui:Button Margin="0,0,8,0" Command="{Binding ExportBalancePdfCommand}" Content="{DynamicResource Reports.Export.Pdf}" />
                        <ui:Button Command="{Binding ExportBalanceCsvCommand}" Content="{DynamicResource Reports.Export.Csv}" />
                    </StackPanel>
                    <TextBlock
                        Grid.Row="1"
                        FontStyle="Italic"
                        Foreground="{DynamicResource AppTextSecondary}"
                        Text="{DynamicResource Reports.Statement.Empty}"
                        Visibility="{Binding HasBalanceSheet, Converter={StaticResource InverseBooleanToVisibilityConverter}}" />
                    <StackPanel Grid.Row="1" Visibility="{Binding HasBalanceSheet, Converter={StaticResource BooleanToVisibilityConverter}}">
                        <StackPanel Margin="0,0,0,12" Orientation="Horizontal">
                            <TextBlock Foreground="{DynamicResource AppTextSecondary}" Text="{DynamicResource Reports.Balance.AsOf}" />
                            <TextBlock
                                Margin="8,0,0,0"
                                FontFamily="{StaticResource FontBase}"
                                Typography.NumeralAlignment="Tabular"
                                Foreground="{DynamicResource AppTextPrimary}"
                                Text="{Binding BalanceSheet.AsOf, StringFormat={}{0:yyyy-MM-dd}}" />
                        </StackPanel>
                        <Grid>
                            <Grid.ColumnDefinitions>
                                <ColumnDefinition Width="*" />
                                <ColumnDefinition Width="16" />
                                <ColumnDefinition Width="*" />
                            </Grid.ColumnDefinitions>
                            <StackPanel Grid.Column="0">
                                <TextBlock
                                    FontWeight="SemiBold"
                                    Foreground="{DynamicResource AppTextPrimary}"
                                    Text="{DynamicResource Reports.Balance.Assets}" />
                                <TextBlock
                                    Margin="0,4,0,8"
                                    FontFamily="{StaticResource FontBase}"
                                    FontSize="{DynamicResource FontSizeLg}"
                                    FontWeight="SemiBold"
                                    Foreground="{DynamicResource AppTextPrimary}"
                                    Text="{Binding BalanceSheet.Assets.Total, StringFormat={}{0:N2}}" />
                                <ItemsControl ItemsSource="{Binding BalanceSheet.Assets.Rows}">
                                    <ItemsControl.ItemTemplate>
                                        <DataTemplate>
                                            <Grid Margin="0,3,0,0">
                                                <Grid.ColumnDefinitions>
                                                    <ColumnDefinition Width="*" />
                                                    <ColumnDefinition Width="Auto" />
                                                </Grid.ColumnDefinitions>
                                                <TextBlock
                                                    Grid.Column="0"
                                                    Foreground="{DynamicResource AppTextSecondary}"
                                                    Text="{Binding Label}" />
                                                <TextBlock
                                                    Grid.Column="1"
                                                    FontFamily="{StaticResource FontBase}"
                                                    Typography.NumeralAlignment="Tabular"
                                                    Foreground="{DynamicResource AppTextPrimary}"
                                                    Text="{Binding Amount, StringFormat={}{0:N2}}" />
                                            </Grid>
                                        </DataTemplate>
                                    </ItemsControl.ItemTemplate>
                                </ItemsControl>
                            </StackPanel>
                            <StackPanel Grid.Column="2">
                                <TextBlock
                                    FontWeight="SemiBold"
                                    Foreground="{DynamicResource AppTextPrimary}"
                                    Text="{DynamicResource Reports.Balance.Liabilities}" />
                                <TextBlock
                                    Margin="0,4,0,8"
                                    FontFamily="{StaticResource FontBase}"
                                    FontSize="{DynamicResource FontSizeLg}"
                                    FontWeight="SemiBold"
                                    Foreground="{DynamicResource AppTextPrimary}"
                                    Text="{Binding BalanceSheet.Liabilities.Total, StringFormat={}{0:N2}}" />
                                <ItemsControl ItemsSource="{Binding BalanceSheet.Liabilities.Rows}">
                                    <ItemsControl.ItemTemplate>
                                        <DataTemplate>
                                            <Grid Margin="0,3,0,0">
                                                <Grid.ColumnDefinitions>
                                                    <ColumnDefinition Width="*" />
                                                    <ColumnDefinition Width="Auto" />
                                                </Grid.ColumnDefinitions>
                                                <TextBlock
                                                    Grid.Column="0"
                                                    Foreground="{DynamicResource AppTextSecondary}"
                                                    Text="{Binding Label}" />
                                                <TextBlock
                                                    Grid.Column="1"
                                                    FontFamily="{StaticResource FontBase}"
                                                    Typography.NumeralAlignment="Tabular"
                                                    Foreground="{DynamicResource AppTextPrimary}"
                                                    Text="{Binding Amount, StringFormat={}{0:N2}}" />
                                            </Grid>
                                        </DataTemplate>
                                    </ItemsControl.ItemTemplate>
                                </ItemsControl>
                            </StackPanel>
                        </Grid>
                        <Border Height="1" Margin="0,12,0,12" Background="{DynamicResource AppBorder}" />
                        <Grid>
                            <Grid.ColumnDefinitions>
                                <ColumnDefinition Width="*" />
                                <ColumnDefinition Width="Auto" />
                            </Grid.ColumnDefinitions>
                            <TextBlock
                                FontWeight="SemiBold"
                                Foreground="{DynamicResource AppTextPrimary}"
                                Text="{DynamicResource Reports.Balance.NetWorth}" />
                            <TextBlock
                                Grid.Column="1"
                                FontFamily="{StaticResource FontBase}"
                                Typography.NumeralAlignment="Tabular"
                                FontWeight="SemiBold"
                                Foreground="{DynamicResource AppTextPrimary}"
                                Text="{Binding BalanceSheet.NetWorth, StringFormat={}{0:N2}}" />
                        </Grid>
                    </StackPanel>
                </Grid>
            </ui:CardExpander>

            <ui:CardExpander Header="{DynamicResource Reports.CashFlow.Title}" IsExpanded="False">
                <Grid Margin="12">
                    <Grid.RowDefinitions>
                        <RowDefinition Height="Auto" />
                        <RowDefinition Height="Auto" />
                    </Grid.RowDefinitions>
                    <StackPanel
                        Grid.Row="0"
                        Margin="0,0,0,12"
                        HorizontalAlignment="Right"
                        Orientation="Horizontal"
                        Visibility="{Binding HasCashFlowStatement, Converter={StaticResource BooleanToVisibilityConverter}}">
                        <ui:Button Margin="0,0,8,0" Command="{Binding ExportCashFlowPdfCommand}" Content="{DynamicResource Reports.Export.Pdf}" />
                        <ui:Button Command="{Binding ExportCashFlowCsvCommand}" Content="{DynamicResource Reports.Export.Csv}" />
                    </StackPanel>
                    <TextBlock
                        Grid.Row="1"
                        FontStyle="Italic"
                        Foreground="{DynamicResource AppTextSecondary}"
                        Text="{DynamicResource Reports.Statement.Empty}"
                        Visibility="{Binding HasCashFlowStatement, Converter={StaticResource InverseBooleanToVisibilityConverter}}" />
                    <StackPanel Grid.Row="1" Visibility="{Binding HasCashFlowStatement, Converter={StaticResource BooleanToVisibilityConverter}}">
                        <Grid>
                            <Grid.ColumnDefinitions>
                                <ColumnDefinition Width="*" />
                                <ColumnDefinition Width="16" />
                                <ColumnDefinition Width="*" />
                                <ColumnDefinition Width="16" />
                                <ColumnDefinition Width="*" />
                            </Grid.ColumnDefinitions>
                            <StackPanel Grid.Column="0">
                                <TextBlock FontWeight="SemiBold" Foreground="{DynamicResource AppTextPrimary}" Text="{DynamicResource Reports.CashFlow.Operating}" />
                                <TextBlock Margin="0,4,0,8" FontFamily="{StaticResource FontBase}" FontSize="{DynamicResource FontSizeLg}" FontWeight="SemiBold" Text="{Binding CashFlowStatement.Operating.Total, StringFormat={}{0:N2}}" />
                                <ItemsControl ItemsSource="{Binding CashFlowStatement.Operating.Rows}">
                                    <ItemsControl.ItemTemplate>
                                        <DataTemplate>
                                            <Grid Margin="0,3,0,0">
                                                <Grid.ColumnDefinitions>
                                                    <ColumnDefinition Width="*" />
                                                    <ColumnDefinition Width="Auto" />
                                                </Grid.ColumnDefinitions>
                                                <TextBlock Grid.Column="0" Foreground="{DynamicResource AppTextSecondary}" Text="{Binding Label}" />
                                                <TextBlock Grid.Column="1" FontFamily="{StaticResource FontBase}" Typography.NumeralAlignment="Tabular" Text="{Binding Amount, StringFormat={}{0:N2}}" />
                                            </Grid>
                                        </DataTemplate>
                                    </ItemsControl.ItemTemplate>
                                </ItemsControl>
                            </StackPanel>
                            <StackPanel Grid.Column="2">
                                <TextBlock FontWeight="SemiBold" Foreground="{DynamicResource AppTextPrimary}" Text="{DynamicResource Reports.CashFlow.Investing}" />
                                <TextBlock Margin="0,4,0,8" FontFamily="{StaticResource FontBase}" FontSize="{DynamicResource FontSizeLg}" FontWeight="SemiBold" Text="{Binding CashFlowStatement.Investing.Total, StringFormat={}{0:N2}}" />
                                <ItemsControl ItemsSource="{Binding CashFlowStatement.Investing.Rows}">
                                    <ItemsControl.ItemTemplate>
                                        <DataTemplate>
                                            <Grid Margin="0,3,0,0">
                                                <Grid.ColumnDefinitions>
                                                    <ColumnDefinition Width="*" />
                                                    <ColumnDefinition Width="Auto" />
                                                </Grid.ColumnDefinitions>
                                                <TextBlock Grid.Column="0" Foreground="{DynamicResource AppTextSecondary}" Text="{Binding Label}" />
                                                <TextBlock Grid.Column="1" FontFamily="{StaticResource FontBase}" Typography.NumeralAlignment="Tabular" Text="{Binding Amount, StringFormat={}{0:N2}}" />
                                            </Grid>
                                        </DataTemplate>
                                    </ItemsControl.ItemTemplate>
                                </ItemsControl>
                            </StackPanel>
                            <StackPanel Grid.Column="4">
                                <TextBlock FontWeight="SemiBold" Foreground="{DynamicResource AppTextPrimary}" Text="{DynamicResource Reports.CashFlow.Financing}" />
                                <TextBlock Margin="0,4,0,8" FontFamily="{StaticResource FontBase}" FontSize="{DynamicResource FontSizeLg}" FontWeight="SemiBold" Text="{Binding CashFlowStatement.Financing.Total, StringFormat={}{0:N2}}" />
                                <ItemsControl ItemsSource="{Binding CashFlowStatement.Financing.Rows}">
                                    <ItemsControl.ItemTemplate>
                                        <DataTemplate>
                                            <Grid Margin="0,3,0,0">
                                                <Grid.ColumnDefinitions>
                                                    <ColumnDefinition Width="*" />
                                                    <ColumnDefinition Width="Auto" />
                                                </Grid.ColumnDefinitions>
                                                <TextBlock Grid.Column="0" Foreground="{DynamicResource AppTextSecondary}" Text="{Binding Label}" />
                                                <TextBlock Grid.Column="1" FontFamily="{StaticResource FontBase}" Typography.NumeralAlignment="Tabular" Text="{Binding Amount, StringFormat={}{0:N2}}" />
                                            </Grid>
                                        </DataTemplate>
                                    </ItemsControl.ItemTemplate>
                                </ItemsControl>
                            </StackPanel>
                        </Grid>
                        <Border Height="1" Margin="0,12,0,12" Background="{DynamicResource AppBorder}" />
                        <UniformGrid Columns="3">
                            <StackPanel Margin="0,0,12,0">
                                <TextBlock Foreground="{DynamicResource AppTextSecondary}" Text="{DynamicResource Reports.CashFlow.Opening}" />
                                <TextBlock FontFamily="{StaticResource FontBase}" Typography.NumeralAlignment="Tabular" FontWeight="SemiBold" Text="{Binding CashFlowStatement.OpeningCash, StringFormat={}{0:N2}}" />
                            </StackPanel>
                            <StackPanel Margin="12,0">
                                <TextBlock Foreground="{DynamicResource AppTextSecondary}" Text="{DynamicResource Reports.CashFlow.Closing}" />
                                <TextBlock FontFamily="{StaticResource FontBase}" Typography.NumeralAlignment="Tabular" FontWeight="SemiBold" Text="{Binding CashFlowStatement.ClosingCash, StringFormat={}{0:N2}}" />
                            </StackPanel>
                            <StackPanel Margin="12,0,0,0">
                                <TextBlock Foreground="{DynamicResource AppTextSecondary}" Text="{DynamicResource Reports.CashFlow.NetChange}" />
                                <TextBlock FontFamily="{StaticResource FontBase}" Typography.NumeralAlignment="Tabular" FontWeight="SemiBold" Text="{Binding CashFlowStatement.NetChange, StringFormat={}{0:N2}}" />
                            </StackPanel>
                        </UniformGrid>
                    </StackPanel>
                </Grid>
            </ui:CardExpander>

            <ui:CardExpander Header="{DynamicResource Reports.Performance.Title}" IsExpanded="False" Margin="0,8,0,0">
                <Grid>
                    <TextBlock
                        Margin="12"
                        FontStyle="Italic"
                        Foreground="{DynamicResource AppTextSecondary}"
                        Text="{DynamicResource Reports.Statement.Empty}"
                        Visibility="{Binding HasPerformance, Converter={StaticResource InverseBooleanToVisibilityConverter}}" />
                    <StackPanel Margin="12" Visibility="{Binding HasPerformance, Converter={StaticResource BooleanToVisibilityConverter}}">
                        <StackPanel Orientation="Horizontal">
                            <TextBlock FontFamily="{StaticResource FontBase}" Typography.NumeralAlignment="Tabular" Text="{DynamicResource Reports.Performance.Xirr}" />
                            <TextBlock FontFamily="{StaticResource FontBase}" Typography.NumeralAlignment="Tabular" Text="{Binding Performance.Xirr, StringFormat=': {0:P2}', TargetNullValue=': —'}" />
                        </StackPanel>
                        <StackPanel Orientation="Horizontal">
                            <TextBlock FontFamily="{StaticResource FontBase}" Typography.NumeralAlignment="Tabular" Text="{DynamicResource Reports.Performance.Twr}" />
                            <TextBlock FontFamily="{StaticResource FontBase}" Typography.NumeralAlignment="Tabular" Text="{Binding Performance.Twr, StringFormat=': {0:P2}', TargetNullValue=': —'}" />
                        </StackPanel>
                        <StackPanel Orientation="Horizontal">
                            <TextBlock FontFamily="{StaticResource FontBase}" Typography.NumeralAlignment="Tabular" Text="{DynamicResource Reports.Performance.Mwr}" />
                            <TextBlock FontFamily="{StaticResource FontBase}" Typography.NumeralAlignment="Tabular" Text="{Binding Performance.Mwr, StringFormat=': {0:P2}', TargetNullValue=': —'}" />
                        </StackPanel>
                        <StackPanel Orientation="Horizontal">
                            <TextBlock FontFamily="{StaticResource FontBase}" Typography.NumeralAlignment="Tabular" Text="{DynamicResource Reports.Performance.Benchmark}" />
                            <TextBlock FontFamily="{StaticResource FontBase}" Typography.NumeralAlignment="Tabular" Text="{Binding Performance.BenchmarkTwr, StringFormat=': {0:P2}', TargetNullValue=': —'}" />
                        </StackPanel>
                        <StackPanel Orientation="Horizontal">
                            <TextBlock FontFamily="{StaticResource FontBase}" Typography.NumeralAlignment="Tabular" FontWeight="SemiBold" Text="{DynamicResource Reports.Performance.Alpha}" />
                            <TextBlock FontFamily="{StaticResource FontBase}" Typography.NumeralAlignment="Tabular" FontWeight="SemiBold" Text="{Binding Performance.AlphaOverBenchmark, StringFormat=': {0:P2}', TargetNullValue=': —'}" />
                        </StackPanel>
                        <ItemsControl Margin="0,8,0,0" ItemsSource="{Binding Performance.Attribution}">
                            <ItemsControl.ItemTemplate>
                                <DataTemplate>
                                    <Grid Margin="0,2,0,0">
                                        <Grid.ColumnDefinitions>
                                            <ColumnDefinition Width="160" />
                                            <ColumnDefinition Width="*" />
                                        </Grid.ColumnDefinitions>
                                        <TextBlock Grid.Column="0" FontFamily="{StaticResource FontBase}" Typography.NumeralAlignment="Tabular" Text="{Binding Label}" />
                                        <TextBlock Grid.Column="1" FontFamily="{StaticResource FontBase}" Typography.NumeralAlignment="Tabular" HorizontalAlignment="Right" Text="{Binding Amount, StringFormat='{}{0:N2}'}" />
                                    </Grid>
                                </DataTemplate>
                            </ItemsControl.ItemTemplate>
                        </ItemsControl>
                    </StackPanel>
                </Grid>
            </ui:CardExpander>

            <ui:CardExpander Header="{DynamicResource Reports.Risk.Title}" IsExpanded="False" Margin="0,8,0,0">
                <Grid>
                    <TextBlock
                        Margin="12"
                        FontStyle="Italic"
                        Foreground="{DynamicResource AppTextSecondary}"
                        Text="{DynamicResource Reports.Statement.Empty}"
                        Visibility="{Binding HasRisk, Converter={StaticResource InverseBooleanToVisibilityConverter}}" />
                    <StackPanel Margin="12" Visibility="{Binding HasRisk, Converter={StaticResource BooleanToVisibilityConverter}}">
                        <StackPanel Orientation="Horizontal">
                            <TextBlock FontFamily="{StaticResource FontBase}" Typography.NumeralAlignment="Tabular" Text="{DynamicResource Reports.Risk.AnnualizedVolatility}" />
                            <TextBlock FontFamily="{StaticResource FontBase}" Typography.NumeralAlignment="Tabular" Text="{Binding Risk.AnnualizedVolatility, StringFormat=': {0:P2}', TargetNullValue=': —'}" />
                        </StackPanel>
                        <StackPanel Orientation="Horizontal">
                            <TextBlock FontFamily="{StaticResource FontBase}" Typography.NumeralAlignment="Tabular" Text="{DynamicResource Reports.Risk.MaxDrawdown}" />
                            <TextBlock FontFamily="{StaticResource FontBase}" Typography.NumeralAlignment="Tabular" Text="{Binding Risk.MaxDrawdown, StringFormat=': {0:P2}', TargetNullValue=': —'}" />
                        </StackPanel>
                        <StackPanel Orientation="Horizontal">
                            <TextBlock FontFamily="{StaticResource FontBase}" Typography.NumeralAlignment="Tabular" Text="{DynamicResource Reports.Risk.SharpeRatio}" />
                            <TextBlock FontFamily="{StaticResource FontBase}" Typography.NumeralAlignment="Tabular" Text="{Binding Risk.SharpeRatio, StringFormat=': {0:F2}', TargetNullValue=': —'}" />
                        </StackPanel>
                        <StackPanel Orientation="Horizontal">
                            <TextBlock FontFamily="{StaticResource FontBase}" Typography.NumeralAlignment="Tabular" Text="{DynamicResource Reports.Risk.Hhi}" />
                            <TextBlock FontFamily="{StaticResource FontBase}" Typography.NumeralAlignment="Tabular" Text="{Binding Risk.Hhi, StringFormat=': {0:F3}', TargetNullValue=': —'}" />
                        </StackPanel>
                        <TextBlock Margin="0,4,0,0" FontWeight="SemiBold" Foreground="{DynamicResource AppDanger}" Text="{DynamicResource Reports.Risk.ConcentrationWarning}" Visibility="{Binding Risk.HasConcentrationWarning, Converter={StaticResource BooleanToVisibilityConverter}}" />
                        <TextBlock Margin="0,8,0,4" FontWeight="SemiBold" Text="{DynamicResource Reports.Risk.TopHoldings}" />
                        <ItemsControl ItemsSource="{Binding Risk.TopHoldings}">
                            <ItemsControl.ItemTemplate>
                                <DataTemplate>
                                    <Grid Margin="0,2,0,0">
                                        <Grid.ColumnDefinitions>
                                            <ColumnDefinition Width="200" />
                                            <ColumnDefinition Width="*" />
                                        </Grid.ColumnDefinitions>
                                        <TextBlock Grid.Column="0" FontFamily="{StaticResource FontBase}" Typography.NumeralAlignment="Tabular" Text="{Binding Label}" />
                                        <TextBlock Grid.Column="1" FontFamily="{StaticResource FontBase}" Typography.NumeralAlignment="Tabular" HorizontalAlignment="Right" Text="{Binding Weight, StringFormat='{}{0:P2}'}" />
                                    </Grid>
                                </DataTemplate>
                            </ItemsControl.ItemTemplate>
                        </ItemsControl>
                    </StackPanel>
                </Grid>
            </ui:CardExpander>
        </StackPanel>

            <TextBlock
                Grid.Row="4"
                Margin="0,8,0,0"
                Foreground="{DynamicResource AppTextSecondary}"
                Text="{Binding ExportStatus}" />
        </Grid>
    </ScrollViewer>
</UserControl>
