<UserControl
    x:Class="Assetra.WPF.Features.Reports.ReportsView"
    xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
    xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
    xmlns:d="http://schemas.microsoft.com/expression/blend/2008"
    xmlns:mc="http://schemas.openxmlformats.org/markup-compatibility/2006"
    xmlns:ds="clr-namespace:Assetra.WPF.DesignSystem.Controls"
    xmlns:vm="clr-namespace:Assetra.WPF.Features.Reports"
    d:DataContext="{d:DesignInstance Type={x:Type vm:ReportsViewModel},
                                     IsDesignTimeCreatable=False}"
    d:DesignHeight="776"
    d:DesignWidth="1100"
    Background="{DynamicResource AppBackground}"
    mc:Ignorable="d">

    <ScrollViewer
        Margin="24"
        VerticalScrollBarVisibility="Auto"
        HorizontalScrollBarVisibility="Disabled"
        CanContentScroll="False">
        <Grid>
            <Grid.RowDefinitions>
                <RowDefinition Height="Auto" />
                <!--  header  -->
                <RowDefinition Height="Auto" />
                <!--  metric cards  -->
                <RowDefinition Height="Auto" />
                <!--  detail lists  -->
                <RowDefinition Height="Auto" />
                <!--  statements  -->
                <RowDefinition Height="Auto" />
                <!--  export status  -->
            </Grid.RowDefinitions>

        <!--  ── Header: month picker ──  -->
        <DockPanel Grid.Row="0" Margin="0,0,0,16">

            <StackPanel
                Margin="24,0,0,0"
                VerticalAlignment="Center"
                Orientation="Horizontal">
                <Button
                    Width="32"
                    Height="32"
                    Padding="0"
                    Command="{Binding PrevMonthCommand}"
                    Style="{StaticResource AppIconButton}"
                    ToolTip="{DynamicResource Reports.PrevMonth}">
                    <ds:AppIcon FontSize="16" Symbol="ChevronLeft24" />
                </Button>

                <!--
                    Direct year/month selection — replaces the prev/next-only
                    pattern that made jumping across years tedious.
                    Auto-loads on selection via ReportsViewModel.OnYearChanged
                    / OnMonthChanged.
                -->
                <ComboBox
                    Margin="12,0,4,0"
                    Width="84"
                    VerticalAlignment="Center"
                    ItemsSource="{Binding YearOptions}"
                    SelectedItem="{Binding Year}"
                    Style="{StaticResource AppComboBox}" />
                <ComboBox
                    Margin="0,0,12,0"
                    Width="60"
                    VerticalAlignment="Center"
                    ItemsSource="{Binding MonthOptions}"
                    SelectedItem="{Binding Month}"
                    Style="{StaticResource AppComboBox}">
                    <ComboBox.ItemTemplate>
                        <DataTemplate>
                            <TextBlock Text="{Binding StringFormat={}{0:D2}}" />
                        </DataTemplate>
                    </ComboBox.ItemTemplate>
                </ComboBox>

                <Button
                    Width="32"
                    Height="32"
                    Padding="0"
                    Command="{Binding NextMonthCommand}"
                    Style="{StaticResource AppIconButton}"
                    ToolTip="{DynamicResource Reports.NextMonth}">
                    <ds:AppIcon FontSize="16" Symbol="ChevronRight24" />
                </Button>
                <Button
                    Margin="16,0,0,0"
                    Command="{Binding LoadCommand}"
                    Content="{DynamicResource Reports.Reload}"
                    Style="{StaticResource AppSecondaryButton}" />
            </StackPanel>

            <TextBlock
                Margin="16,0,0,0"
                VerticalAlignment="Center"
                FontStyle="Italic"
                Foreground="{DynamicResource AppTextSecondary}"
                Text="{DynamicResource Reports.Loading}"
                Visibility="{Binding IsLoading, Converter={StaticResource BooleanToVisibilityConverter}}" />
            <TextBlock
                Margin="16,0,0,0"
                VerticalAlignment="Center"
                Foreground="{DynamicResource AppDanger}"
                Text="{Binding ErrorMessage}"
                TextTrimming="CharacterEllipsis"
                Visibility="{Binding ErrorMessage, Converter={StaticResource StringToVisibilityConverter}}" />
        </DockPanel>

        <!--  ── Metric cards: Income / Expense / Net + Savings rate ──  -->
        <UniformGrid
            Grid.Row="1"
            Margin="0,0,0,24"
            Columns="4"
            Rows="1">

            <Border
                Margin="0,0,8,0"
                Padding="16"
                Style="{StaticResource FormCard}">
                <StackPanel>
                    <TextBlock
                        FontSize="{DynamicResource Font.Size.Xs}"
                        Foreground="{DynamicResource AppTextSecondary}"
                        Text="{DynamicResource Reports.Income}" />
                    <TextBlock
                        Margin="0,8,0,4"
                        FontFamily="{StaticResource Font.Family.Base}" Typography.NumeralAlignment="Tabular"
                        FontSize="{DynamicResource Font.Size.Xl}"
                        FontWeight="SemiBold"
                        Foreground="{DynamicResource AppUp}"
                        Text="{Binding IncomeDisplay}" />
                    <TextBlock
                        FontFamily="{StaticResource Font.Family.Base}" Typography.NumeralAlignment="Tabular"
                        FontSize="{DynamicResource Font.Size.Xs}"
                        Foreground="{DynamicResource AppTextSecondary}"
                        Text="{Binding IncomeDeltaDisplay}"
                        ToolTip="{DynamicResource Reports.DeltaTooltip}" />
                </StackPanel>
            </Border>

            <Border
                Margin="8,0"
                Padding="16"
                Style="{StaticResource FormCard}">
                <StackPanel>
                    <TextBlock
                        FontSize="{DynamicResource Font.Size.Xs}"
                        Foreground="{DynamicResource AppTextSecondary}"
                        Text="{DynamicResource Reports.Expense}" />
                    <TextBlock
                        Margin="0,8,0,4"
                        FontFamily="{StaticResource Font.Family.Base}" Typography.NumeralAlignment="Tabular"
                        FontSize="{DynamicResource Font.Size.Xl}"
                        FontWeight="SemiBold"
                        Foreground="{DynamicResource AppDown}"
                        Text="{Binding ExpenseDisplay}" />
                    <TextBlock
                        FontFamily="{StaticResource Font.Family.Base}" Typography.NumeralAlignment="Tabular"
                        FontSize="{DynamicResource Font.Size.Xs}"
                        Foreground="{DynamicResource AppTextSecondary}"
                        Text="{Binding ExpenseDeltaDisplay}"
                        ToolTip="{DynamicResource Reports.DeltaTooltip}" />
                </StackPanel>
            </Border>

            <Border
                Margin="8,0"
                Padding="16"
                Style="{StaticResource FormCard}">
                <StackPanel>
                    <TextBlock
                        FontSize="{DynamicResource Font.Size.Xs}"
                        Foreground="{DynamicResource AppTextSecondary}"
                        Text="{DynamicResource Reports.Net}" />
                    <TextBlock
                        Margin="0,8,0,4"
                        FontFamily="{StaticResource Font.Family.Base}" Typography.NumeralAlignment="Tabular"
                        FontSize="{DynamicResource Font.Size.Xl}"
                        FontWeight="SemiBold"
                        Foreground="{DynamicResource AppTextPrimary}"
                        Text="{Binding NetDisplay}" />
                    <TextBlock
                        FontFamily="{StaticResource Font.Family.Base}" Typography.NumeralAlignment="Tabular"
                        FontSize="{DynamicResource Font.Size.Xs}"
                        Foreground="{DynamicResource AppTextSecondary}"
                        Text="{Binding NetDeltaDisplay}"
                        ToolTip="{DynamicResource Reports.DeltaTooltip}" />
                </StackPanel>
            </Border>

            <Border
                Margin="8,0,0,0"
                Padding="16"
                Style="{StaticResource FormCard}">
                <StackPanel>
                    <TextBlock
                        FontSize="{DynamicResource Font.Size.Xs}"
                        Foreground="{DynamicResource AppTextSecondary}"
                        Text="{DynamicResource Reports.SavingsRate}" />
                    <TextBlock
                        Margin="0,8,0,4"
                        FontFamily="{StaticResource Font.Family.Base}" Typography.NumeralAlignment="Tabular"
                        FontSize="{DynamicResource Font.Size.Xl}"
                        FontWeight="SemiBold"
                        Foreground="{DynamicResource AppAccent}"
                        Text="{Binding SavingsRateDisplay}" />
                </StackPanel>
            </Border>
        </UniformGrid>

        <!--  ── Detail lists: over-budget + upcoming ──  -->
        <Grid Grid.Row="2">
            <Grid.ColumnDefinitions>
                <ColumnDefinition Width="*" />
                <ColumnDefinition Width="*" />
            </Grid.ColumnDefinitions>

            <!--  Over-budget categories  -->
            <Border
                Grid.Column="0"
                Margin="0,0,8,0"
                Padding="16"
                Style="{StaticResource FormCard}">
                <DockPanel>
                    <TextBlock
                        DockPanel.Dock="Top"
                        Margin="0,0,0,12"
                        FontSize="{DynamicResource Font.Size.Md}"
                        FontWeight="SemiBold"
                        Foreground="{DynamicResource AppTextPrimary}"
                        Text="{DynamicResource Reports.OverBudget.Title}" />

                    <TextBlock
                        DockPanel.Dock="Top"
                        FontStyle="Italic"
                        Foreground="{DynamicResource AppTextSecondary}"
                        Text="{DynamicResource Reports.OverBudget.Empty}"
                        Visibility="{Binding HasOverBudget, Converter={StaticResource InverseBooleanToVisibilityConverter}}" />

                    <ItemsControl
                        ItemsSource="{Binding OverBudgetRows}"
                        Visibility="{Binding HasOverBudget, Converter={StaticResource BooleanToVisibilityConverter}}">
                        <ItemsControl.ItemTemplate>
                            <DataTemplate>
                                <Grid Margin="0,6">
                                    <Grid.RowDefinitions>
                                        <RowDefinition Height="Auto" />
                                        <RowDefinition Height="Auto" />
                                    </Grid.RowDefinitions>
                                    <Grid.ColumnDefinitions>
                                        <ColumnDefinition Width="*" />
                                        <ColumnDefinition Width="Auto" />
                                        <ColumnDefinition Width="Auto" />
                                        <ColumnDefinition Width="Auto" />
                                    </Grid.ColumnDefinitions>
                                    <TextBlock
                                        Grid.Row="0"
                                        Grid.Column="0"
                                        Foreground="{DynamicResource AppTextPrimary}"
                                        Text="{Binding CategoryName}" />
                                    <TextBlock
                                        Grid.Row="0"
                                        Grid.Column="1"
                                        Margin="12,0,0,0"
                                        FontFamily="{StaticResource Font.Family.Base}" Typography.NumeralAlignment="Tabular"
                                        Foreground="{DynamicResource AppDown}"
                                        Text="{Binding SpentDisplay}" />
                                    <TextBlock
                                        Grid.Row="0"
                                        Grid.Column="2"
                                        Margin="6,0,12,0"
                                        FontFamily="{StaticResource Font.Family.Base}" Typography.NumeralAlignment="Tabular"
                                        Foreground="{DynamicResource AppTextSecondary}"
                                        Text="{Binding BudgetDisplay}" />
                                    <TextBlock
                                        Grid.Row="0"
                                        Grid.Column="3"
                                        FontFamily="{StaticResource Font.Family.Base}" Typography.NumeralAlignment="Tabular"
                                        FontWeight="SemiBold"
                                        Foreground="{DynamicResource AppDown}"
                                        Text="{Binding OveragePercent, StringFormat=+{0:F0}%}" />

                                    <Border
                                        Grid.Row="1"
                                        Grid.Column="0"
                                        Grid.ColumnSpan="4"
                                        Height="4"
                                        Margin="0,4,0,0"
                                        Background="{DynamicResource AppBorder}"
                                        CornerRadius="{StaticResource Radius.Xs}">
                                        <Border
                                            HorizontalAlignment="Left"
                                            Background="{DynamicResource AppDown}"
                                            CornerRadius="{StaticResource Radius.Xs}">
                                            <Border.Width>
                                                <MultiBinding Converter="{StaticResource PercentToWidthConverter}">
                                                    <Binding Path="OveragePercent" />
                                                    <Binding Path="ActualWidth" RelativeSource="{RelativeSource AncestorType=ItemsControl}" />
                                                </MultiBinding>
                                            </Border.Width>
                                        </Border>
                                    </Border>
                                </Grid>
                            </DataTemplate>
                        </ItemsControl.ItemTemplate>
                    </ItemsControl>
                </DockPanel>
            </Border>

            <!--  Upcoming recurring  -->
            <Border
                Grid.Column="1"
                Margin="8,0,0,0"
                Padding="16"
                Style="{StaticResource FormCard}">
                <DockPanel>
                    <TextBlock
                        DockPanel.Dock="Top"
                        Margin="0,0,0,12"
                        FontSize="{DynamicResource Font.Size.Md}"
                        FontWeight="SemiBold"
                        Foreground="{DynamicResource AppTextPrimary}"
                        Text="{DynamicResource Reports.Upcoming.Title}" />

                    <TextBlock
                        DockPanel.Dock="Top"
                        FontStyle="Italic"
                        Foreground="{DynamicResource AppTextSecondary}"
                        Text="{DynamicResource Reports.Upcoming.Empty}"
                        Visibility="{Binding HasUpcoming, Converter={StaticResource InverseBooleanToVisibilityConverter}}" />

                    <ItemsControl
                        ItemsSource="{Binding UpcomingRows}"
                        Visibility="{Binding HasUpcoming, Converter={StaticResource BooleanToVisibilityConverter}}">
                        <ItemsControl.ItemTemplate>
                            <DataTemplate>
                                <Grid Margin="0,4">
                                    <Grid.ColumnDefinitions>
                                        <ColumnDefinition Width="Auto" />
                                        <ColumnDefinition Width="*" />
                                        <ColumnDefinition Width="Auto" />
                                    </Grid.ColumnDefinitions>
                                    <TextBlock
                                        Grid.Column="0"
                                        Width="80"
                                        FontFamily="{StaticResource Font.Family.Base}" Typography.NumeralAlignment="Tabular"
                                        Foreground="{DynamicResource AppTextSecondary}"
                                        Text="{Binding DueDate, StringFormat=MM/dd}" />
                                    <TextBlock
                                        Grid.Column="1"
                                        Margin="12,0"
                                        Foreground="{DynamicResource AppTextPrimary}"
                                        Text="{Binding Name}" />
                                    <TextBlock
                                        Grid.Column="2"
                                        FontFamily="{StaticResource Font.Family.Base}" Typography.NumeralAlignment="Tabular"
                                        Foreground="{DynamicResource AppTextPrimary}"
                                        Text="{Binding AmountDisplay}" />
                                </Grid>
                            </DataTemplate>
                        </ItemsControl.ItemTemplate>
                    </ItemsControl>
                </DockPanel>
            </Border>
        </Grid>

        <!--  ── Statements (Income / Balance / CashFlow) ──  -->
        <StackPanel Grid.Row="3" Margin="0,16,0,0">
            <Expander Style="{StaticResource AppExpander}" Header="{DynamicResource Reports.IncomeStatement.Title}" IsExpanded="False" Margin="0,0,0,16">
                <Grid Margin="12">
                    <Grid.RowDefinitions>
                        <RowDefinition Height="Auto" />
                        <RowDefinition Height="Auto" />
                    </Grid.RowDefinitions>
                    <StackPanel
                        Grid.Row="0"
                        Margin="0,0,0,12"
                        HorizontalAlignment="Right"
                        Orientation="Horizontal"
                        Visibility="{Binding HasIncomeStatement, Converter={StaticResource BooleanToVisibilityConverter}}">
                        <Button Margin="0,0,8,0" Command="{Binding ExportIncomePdfCommand}" Content="{DynamicResource Reports.Export.Pdf}" Style="{StaticResource AppSecondaryButton}" />
                        <Button Command="{Binding ExportIncomeCsvCommand}" Content="{DynamicResource Reports.Export.Csv}" Style="{StaticResource AppSecondaryButton}" />
                    </StackPanel>
                    <TextBlock
                        Grid.Row="1"
                        FontStyle="Italic"
                        Foreground="{DynamicResource AppTextSecondary}"
                        Text="{DynamicResource Reports.Statement.Empty}"
                        Visibility="{Binding HasIncomeStatement, Converter={StaticResource InverseBooleanToVisibilityConverter}}" />
                    <StackPanel Grid.Row="1" Visibility="{Binding HasIncomeStatement, Converter={StaticResource BooleanToVisibilityConverter}}">
                        <Grid>
                            <Grid.ColumnDefinitions>
                                <ColumnDefinition Width="*" />
                                <ColumnDefinition Width="16" />
                                <ColumnDefinition Width="*" />
                            </Grid.ColumnDefinitions>
                            <StackPanel Grid.Column="0">
                                <TextBlock
                                    FontWeight="SemiBold"
                                    Foreground="{DynamicResource AppTextPrimary}"
                                    Text="{DynamicResource Reports.Income.Total}" />
                                <TextBlock
                                    Margin="0,4,0,8"
                                    FontFamily="{StaticResource Font.Family.Base}"
                                    FontSize="{DynamicResource Font.Size.Lg}"
                                    FontWeight="SemiBold"
                                    Foreground="{DynamicResource AppUp}"
                                    Text="{Binding IncomeStatement.Income.Total, StringFormat={}{0:N2}}" />
                                <ItemsControl ItemsSource="{Binding IncomeStatement.Income.Rows}">
                                    <ItemsControl.ItemTemplate>
                                        <DataTemplate>
                                            <Grid Margin="0,3,0,0">
                                                <Grid.ColumnDefinitions>
                                                    <ColumnDefinition Width="*" />
                                                    <ColumnDefinition Width="Auto" />
                                                </Grid.ColumnDefinitions>
                                                <TextBlock
                                                    Grid.Column="0"
                                                    Foreground="{DynamicResource AppTextSecondary}"
                                                    Text="{Binding Label}" />
                                                <TextBlock
                                                    Grid.Column="1"
                                                    FontFamily="{StaticResource Font.Family.Base}"
                                                    Typography.NumeralAlignment="Tabular"
                                                    Foreground="{DynamicResource AppTextPrimary}"
                                                    Text="{Binding Amount, StringFormat={}{0:N2}}" />
                                            </Grid>
                                        </DataTemplate>
                                    </ItemsControl.ItemTemplate>
                                </ItemsControl>
                            </StackPanel>
                            <StackPanel Grid.Column="2">
                                <TextBlock
                                    FontWeight="SemiBold"
                                    Foreground="{DynamicResource AppTextPrimary}"
                                    Text="{DynamicResource Reports.Expense.Total}" />
                                <TextBlock
                                    Margin="0,4,0,8"
                                    FontFamily="{StaticResource Font.Family.Base}"
                                    FontSize="{DynamicResource Font.Size.Lg}"
                                    FontWeight="SemiBold"
                                    Foreground="{DynamicResource AppDown}"
                                    Text="{Binding IncomeStatement.Expense.Total, StringFormat={}{0:N2}}" />
                                <ItemsControl ItemsSource="{Binding IncomeStatement.Expense.Rows}">
                                    <ItemsControl.ItemTemplate>
                                        <DataTemplate>
                                            <Grid Margin="0,3,0,0">
                                                <Grid.ColumnDefinitions>
                                                    <ColumnDefinition Width="*" />
                                                    <ColumnDefinition Width="Auto" />
                                                </Grid.ColumnDefinitions>
                                                <TextBlock
                                                    Grid.Column="0"
                                                    Foreground="{DynamicResource AppTextSecondary}"
                                                    Text="{Binding Label}" />
                                                <TextBlock
                                                    Grid.Column="1"
                                                    FontFamily="{StaticResource Font.Family.Base}"
                                                    Typography.NumeralAlignment="Tabular"
                                                    Foreground="{DynamicResource AppTextPrimary}"
                                                    Text="{Binding Amount, StringFormat={}{0:N2}}" />
                                            </Grid>
                                        </DataTemplate>
                                    </ItemsControl.ItemTemplate>
                                </ItemsControl>
                            </StackPanel>
                        </Grid>
                        <Border Height="1" Margin="0,12,0,12" Background="{DynamicResource AppBorder}" />
                        <Grid>
                            <Grid.ColumnDefinitions>
                                <ColumnDefinition Width="*" />
                                <ColumnDefinition Width="Auto" />
                            </Grid.ColumnDefinitions>
                            <TextBlock
                                FontWeight="SemiBold"
                                Foreground="{DynamicResource AppTextPrimary}"
                                Text="{DynamicResource Reports.Net.Total}" />
                            <TextBlock
                                Grid.Column="1"
                                FontFamily="{StaticResource Font.Family.Base}"
                                Typography.NumeralAlignment="Tabular"
                                FontWeight="SemiBold"
                                Foreground="{DynamicResource AppTextPrimary}"
                                Text="{Binding IncomeStatement.Net, StringFormat={}{0:N2}}" />
                        </Grid>
                    </StackPanel>
                </Grid>
            </Expander>

            <Expander Style="{StaticResource AppExpander}" Header="{DynamicResource Reports.BalanceSheet.Title}" IsExpanded="False" Margin="0,0,0,16">
                <Grid Margin="12">
                    <Grid.RowDefinitions>
                        <RowDefinition Height="Auto" />
                        <RowDefinition Height="Auto" />
                    </Grid.RowDefinitions>
                    <StackPanel
                        Grid.Row="0"
                        Margin="0,0,0,12"
                        HorizontalAlignment="Right"
                        Orientation="Horizontal"
                        Visibility="{Binding HasBalanceSheet, Converter={StaticResource BooleanToVisibilityConverter}}">
                        <Button Margin="0,0,8,0" Command="{Binding ExportBalancePdfCommand}" Content="{DynamicResource Reports.Export.Pdf}" Style="{StaticResource AppSecondaryButton}" />
                        <Button Command="{Binding ExportBalanceCsvCommand}" Content="{DynamicResource Reports.Export.Csv}" Style="{StaticResource AppSecondaryButton}" />
                    </StackPanel>
                    <TextBlock
                        Grid.Row="1"
                        FontStyle="Italic"
                        Foreground="{DynamicResource AppTextSecondary}"
                        Text="{DynamicResource Reports.Statement.Empty}"
                        Visibility="{Binding HasBalanceSheet, Converter={StaticResource InverseBooleanToVisibilityConverter}}" />
                    <StackPanel Grid.Row="1" Visibility="{Binding HasBalanceSheet, Converter={StaticResource BooleanToVisibilityConverter}}">
                        <StackPanel Margin="0,0,0,12" Orientation="Horizontal">
                            <TextBlock Foreground="{DynamicResource AppTextSecondary}" Text="{DynamicResource Reports.Balance.AsOf}" />
                            <TextBlock
                                Margin="8,0,0,0"
                                FontFamily="{StaticResource Font.Family.Base}"
                                Typography.NumeralAlignment="Tabular"
                                Foreground="{DynamicResource AppTextPrimary}"
                                Text="{Binding BalanceSheet.AsOf, StringFormat={}{0:yyyy-MM-dd}}" />
                        </StackPanel>
                        <Grid>
                            <Grid.ColumnDefinitions>
                                <ColumnDefinition Width="*" />
                                <ColumnDefinition Width="16" />
                                <ColumnDefinition Width="*" />
                            </Grid.ColumnDefinitions>
                            <StackPanel Grid.Column="0">
                                <TextBlock
                                    FontWeight="SemiBold"
                                    Foreground="{DynamicResource AppTextPrimary}"
                                    Text="{DynamicResource Reports.Balance.Assets}" />
                                <TextBlock
                                    Margin="0,4,0,8"
                                    FontFamily="{StaticResource Font.Family.Base}"
                                    FontSize="{DynamicResource Font.Size.Lg}"
                                    FontWeight="SemiBold"
                                    Foreground="{DynamicResource AppTextPrimary}"
                                    Text="{Binding BalanceSheet.Assets.Total, StringFormat={}{0:N2}}" />
                                <ItemsControl ItemsSource="{Binding BalanceSheet.Assets.Rows}">
                                    <ItemsControl.ItemTemplate>
                                        <DataTemplate>
                                            <Grid Margin="0,3,0,0">
                                                <Grid.ColumnDefinitions>
                                                    <ColumnDefinition Width="*" />
                                                    <ColumnDefinition Width="Auto" />
                                                </Grid.ColumnDefinitions>
                                                <TextBlock
                                                    Grid.Column="0"
                                                    Foreground="{DynamicResource AppTextSecondary}"
                                                    Text="{Binding Label}" />
                                                <TextBlock
                                                    Grid.Column="1"
                                                    FontFamily="{StaticResource Font.Family.Base}"
                                                    Typography.NumeralAlignment="Tabular"
                                                    Foreground="{DynamicResource AppTextPrimary}"
                                                    Text="{Binding Amount, StringFormat={}{0:N2}}" />
                                            </Grid>
                                        </DataTemplate>
                                    </ItemsControl.ItemTemplate>
                                </ItemsControl>
                            </StackPanel>
                            <StackPanel Grid.Column="2">
                                <TextBlock
                                    FontWeight="SemiBold"
                                    Foreground="{DynamicResource AppTextPrimary}"
                                    Text="{DynamicResource Reports.Balance.Liabilities}" />
                                <TextBlock
                                    Margin="0,4,0,8"
                                    FontFamily="{StaticResource Font.Family.Base}"
                                    FontSize="{DynamicResource Font.Size.Lg}"
                                    FontWeight="SemiBold"
                                    Foreground="{DynamicResource AppTextPrimary}"
                                    Text="{Binding BalanceSheet.Liabilities.Total, StringFormat={}{0:N2}}" />
                                <ItemsControl ItemsSource="{Binding BalanceSheet.Liabilities.Rows}">
                                    <ItemsControl.ItemTemplate>
                                        <DataTemplate>
                                            <Grid Margin="0,3,0,0">
                                                <Grid.ColumnDefinitions>
                                                    <ColumnDefinition Width="*" />
                                                    <ColumnDefinition Width="Auto" />
                                                </Grid.ColumnDefinitions>
                                                <TextBlock
                                                    Grid.Column="0"
                                                    Foreground="{DynamicResource AppTextSecondary}"
                                                    Text="{Binding Label}" />
                                                <TextBlock
                                                    Grid.Column="1"
                                                    FontFamily="{StaticResource Font.Family.Base}"
                                                    Typography.NumeralAlignment="Tabular"
                                                    Foreground="{DynamicResource AppTextPrimary}"
                                                    Text="{Binding Amount, StringFormat={}{0:N2}}" />
                                            </Grid>
                                        </DataTemplate>
                                    </ItemsControl.ItemTemplate>
                                </ItemsControl>
                            </StackPanel>
                        </Grid>
                        <Border Height="1" Margin="0,12,0,12" Background="{DynamicResource AppBorder}" />
                        <Grid>
                            <Grid.ColumnDefinitions>
                                <ColumnDefinition Width="*" />
                                <ColumnDefinition Width="Auto" />
                            </Grid.ColumnDefinitions>
                            <TextBlock
                                FontWeight="SemiBold"
                                Foreground="{DynamicResource AppTextPrimary}"
                                Text="{DynamicResource Reports.Balance.NetWorth}" />
                            <TextBlock
                                Grid.Column="1"
                                FontFamily="{StaticResource Font.Family.Base}"
                                Typography.NumeralAlignment="Tabular"
                                FontWeight="SemiBold"
                                Foreground="{DynamicResource AppTextPrimary}"
                                Text="{Binding BalanceSheet.NetWorth, StringFormat={}{0:N2}}" />
                        </Grid>
                    </StackPanel>
                </Grid>
            </Expander>

            <Expander Style="{StaticResource AppExpander}" Header="{DynamicResource Reports.CashFlow.Title}" IsExpanded="False" Margin="0,0,0,16">
                <Grid Margin="12">
                    <Grid.RowDefinitions>
                        <RowDefinition Height="Auto" />
                        <RowDefinition Height="Auto" />
                    </Grid.RowDefinitions>
                    <StackPanel
                        Grid.Row="0"
                        Margin="0,0,0,12"
                        HorizontalAlignment="Right"
                        Orientation="Horizontal"
                        Visibility="{Binding HasCashFlowStatement, Converter={StaticResource BooleanToVisibilityConverter}}">
                        <Button Margin="0,0,8,0" Command="{Binding ExportCashFlowPdfCommand}" Content="{DynamicResource Reports.Export.Pdf}" Style="{StaticResource AppSecondaryButton}" />
                        <Button Command="{Binding ExportCashFlowCsvCommand}" Content="{DynamicResource Reports.Export.Csv}" Style="{StaticResource AppSecondaryButton}" />
                    </StackPanel>
                    <TextBlock
                        Grid.Row="1"
                        FontStyle="Italic"
                        Foreground="{DynamicResource AppTextSecondary}"
                        Text="{DynamicResource Reports.Statement.Empty}"
                        Visibility="{Binding HasCashFlowStatement, Converter={StaticResource InverseBooleanToVisibilityConverter}}" />
                    <StackPanel Grid.Row="1" Visibility="{Binding HasCashFlowStatement, Converter={StaticResource BooleanToVisibilityConverter}}">
                        <Grid>
                            <Grid.ColumnDefinitions>
                                <ColumnDefinition Width="*" />
                                <ColumnDefinition Width="16" />
                                <ColumnDefinition Width="*" />
                                <ColumnDefinition Width="16" />
                                <ColumnDefinition Width="*" />
                            </Grid.ColumnDefinitions>
                            <StackPanel Grid.Column="0">
                                <TextBlock FontWeight="SemiBold" Foreground="{DynamicResource AppTextPrimary}" Text="{DynamicResource Reports.CashFlow.Operating}" />
                                <TextBlock Margin="0,4,0,8" FontFamily="{StaticResource Font.Family.Base}" FontSize="{DynamicResource Font.Size.Lg}" FontWeight="SemiBold" Text="{Binding CashFlowStatement.Operating.Total, StringFormat={}{0:N2}}" />
                                <ItemsControl ItemsSource="{Binding CashFlowStatement.Operating.Rows}">
                                    <ItemsControl.ItemTemplate>
                                        <DataTemplate>
                                            <Grid Margin="0,3,0,0">
                                                <Grid.ColumnDefinitions>
                                                    <ColumnDefinition Width="*" />
                                                    <ColumnDefinition Width="Auto" />
                                                </Grid.ColumnDefinitions>
                                                <TextBlock Grid.Column="0" Foreground="{DynamicResource AppTextSecondary}" Text="{Binding Label}" />
                                                <TextBlock Grid.Column="1" FontFamily="{StaticResource Font.Family.Base}" Typography.NumeralAlignment="Tabular" Text="{Binding Amount, StringFormat={}{0:N2}}" />
                                            </Grid>
                                        </DataTemplate>
                                    </ItemsControl.ItemTemplate>
                                </ItemsControl>
                            </StackPanel>
                            <StackPanel Grid.Column="2">
                                <TextBlock FontWeight="SemiBold" Foreground="{DynamicResource AppTextPrimary}" Text="{DynamicResource Reports.CashFlow.Investing}" />
                                <TextBlock Margin="0,4,0,8" FontFamily="{StaticResource Font.Family.Base}" FontSize="{DynamicResource Font.Size.Lg}" FontWeight="SemiBold" Text="{Binding CashFlowStatement.Investing.Total, StringFormat={}{0:N2}}" />
                                <ItemsControl ItemsSource="{Binding CashFlowStatement.Investing.Rows}">
                                    <ItemsControl.ItemTemplate>
                                        <DataTemplate>
                                            <Grid Margin="0,3,0,0">
                                                <Grid.ColumnDefinitions>
                                                    <ColumnDefinition Width="*" />
                                                    <ColumnDefinition Width="Auto" />
                                                </Grid.ColumnDefinitions>
                                                <TextBlock Grid.Column="0" Foreground="{DynamicResource AppTextSecondary}" Text="{Binding Label}" />
                                                <TextBlock Grid.Column="1" FontFamily="{StaticResource Font.Family.Base}" Typography.NumeralAlignment="Tabular" Text="{Binding Amount, StringFormat={}{0:N2}}" />
                                            </Grid>
                                        </DataTemplate>
                                    </ItemsControl.ItemTemplate>
                                </ItemsControl>
                            </StackPanel>
                            <StackPanel Grid.Column="4">
                                <TextBlock FontWeight="SemiBold" Foreground="{DynamicResource AppTextPrimary}" Text="{DynamicResource Reports.CashFlow.Financing}" />
                                <TextBlock Margin="0,4,0,8" FontFamily="{StaticResource Font.Family.Base}" FontSize="{DynamicResource Font.Size.Lg}" FontWeight="SemiBold" Text="{Binding CashFlowStatement.Financing.Total, StringFormat={}{0:N2}}" />
                                <ItemsControl ItemsSource="{Binding CashFlowStatement.Financing.Rows}">
                                    <ItemsControl.ItemTemplate>
                                        <DataTemplate>
                                            <Grid Margin="0,3,0,0">
                                                <Grid.ColumnDefinitions>
                                                    <ColumnDefinition Width="*" />
                                                    <ColumnDefinition Width="Auto" />
                                                </Grid.ColumnDefinitions>
                                                <TextBlock Grid.Column="0" Foreground="{DynamicResource AppTextSecondary}" Text="{Binding Label}" />
                                                <TextBlock Grid.Column="1" FontFamily="{StaticResource Font.Family.Base}" Typography.NumeralAlignment="Tabular" Text="{Binding Amount, StringFormat={}{0:N2}}" />
                                            </Grid>
                                        </DataTemplate>
                                    </ItemsControl.ItemTemplate>
                                </ItemsControl>
                            </StackPanel>
                        </Grid>
                        <Border Height="1" Margin="0,12,0,12" Background="{DynamicResource AppBorder}" />
                        <UniformGrid Columns="3">
                            <StackPanel Margin="0,0,12,0">
                                <TextBlock Foreground="{DynamicResource AppTextSecondary}" Text="{DynamicResource Reports.CashFlow.Opening}" />
                                <TextBlock FontFamily="{StaticResource Font.Family.Base}" Typography.NumeralAlignment="Tabular" FontWeight="SemiBold" Text="{Binding CashFlowStatement.OpeningCash, StringFormat={}{0:N2}}" />
                            </StackPanel>
                            <StackPanel Margin="12,0">
                                <TextBlock Foreground="{DynamicResource AppTextSecondary}" Text="{DynamicResource Reports.CashFlow.Closing}" />
                                <TextBlock FontFamily="{StaticResource Font.Family.Base}" Typography.NumeralAlignment="Tabular" FontWeight="SemiBold" Text="{Binding CashFlowStatement.ClosingCash, StringFormat={}{0:N2}}" />
                            </StackPanel>
                            <StackPanel Margin="12,0,0,0">
                                <TextBlock Foreground="{DynamicResource AppTextSecondary}" Text="{DynamicResource Reports.CashFlow.NetChange}" />
                                <TextBlock FontFamily="{StaticResource Font.Family.Base}" Typography.NumeralAlignment="Tabular" FontWeight="SemiBold" Text="{Binding CashFlowStatement.NetChange, StringFormat={}{0:N2}}" />
                            </StackPanel>
                        </UniformGrid>
                    </StackPanel>
                </Grid>
            </Expander>

            <!--
                Annual tax summary — aggregates the Year's CashDividend +
                Sell-with-RealizedPnl trades into 4 buckets (domestic /
                overseas × dividend / capital-gain) plus an AMT trigger flag.
                Driven by TaxCalculationService (pure function over trade
                journal); export to PDF / CSV via IReportExportService.
            -->
            <Expander Style="{StaticResource AppExpander}" Header="{DynamicResource Reports.Tax.Title}" IsExpanded="False" Margin="0,0,0,16">
                <Grid Margin="12">
                    <Grid.RowDefinitions>
                        <RowDefinition Height="Auto" />
                        <RowDefinition Height="Auto" />
                    </Grid.RowDefinitions>

                    <!--  Header: export buttons (only when there is data)  -->
                    <StackPanel
                        Grid.Row="0"
                        Margin="0,0,0,12"
                        HorizontalAlignment="Right"
                        Orientation="Horizontal"
                        Visibility="{Binding HasTaxSummary, Converter={StaticResource BooleanToVisibilityConverter}}">
                        <Button Margin="0,0,8,0" Command="{Binding ExportTaxPdfCommand}" Content="{DynamicResource Reports.Export.Pdf}" Style="{StaticResource AppSecondaryButton}" />
                        <Button Command="{Binding ExportTaxCsvCommand}" Content="{DynamicResource Reports.Export.Csv}" Style="{StaticResource AppSecondaryButton}" />
                    </StackPanel>

                    <!--  Empty state  -->
                    <TextBlock
                        Grid.Row="1"
                        FontStyle="Italic"
                        Foreground="{DynamicResource AppTextSecondary}"
                        Text="{DynamicResource Reports.Tax.Empty}"
                        Visibility="{Binding HasTaxSummary, Converter={StaticResource InverseBooleanToVisibilityConverter}}" />

                    <!--  Data view  -->
                    <StackPanel Grid.Row="1" Visibility="{Binding HasTaxSummary, Converter={StaticResource BooleanToVisibilityConverter}}">
                        <!--  4 KPI cards: domestic / overseas × dividend / capital-gain  -->
                        <Grid Margin="0,0,0,12">
                            <Grid.ColumnDefinitions>
                                <ColumnDefinition Width="*" />
                                <ColumnDefinition Width="12" />
                                <ColumnDefinition Width="*" />
                                <ColumnDefinition Width="12" />
                                <ColumnDefinition Width="*" />
                                <ColumnDefinition Width="12" />
                                <ColumnDefinition Width="*" />
                            </Grid.ColumnDefinitions>
                            <StackPanel Grid.Column="0">
                                <TextBlock FontSize="{StaticResource Font.Size.Xs}" Foreground="{DynamicResource AppTextMuted}" Text="{DynamicResource Reports.Tax.DomesticDividend}" />
                                <TextBlock Margin="0,4,0,0" FontFamily="{StaticResource Font.Family.Base}" FontSize="{StaticResource Font.Size.Lg}" FontWeight="SemiBold" Foreground="{DynamicResource AppTextPrimary}" Text="{Binding TaxSummary.DomesticDividendTotal, StringFormat={}{0:N0}}" Typography.NumeralAlignment="Tabular" />
                            </StackPanel>
                            <StackPanel Grid.Column="2">
                                <TextBlock FontSize="{StaticResource Font.Size.Xs}" Foreground="{DynamicResource AppTextMuted}" Text="{DynamicResource Reports.Tax.OverseasDividend}" />
                                <TextBlock Margin="0,4,0,0" FontFamily="{StaticResource Font.Family.Base}" FontSize="{StaticResource Font.Size.Lg}" FontWeight="SemiBold" Foreground="{DynamicResource AppTextPrimary}" Text="{Binding TaxSummary.OverseasDividendTotal, StringFormat={}{0:N0}}" Typography.NumeralAlignment="Tabular" />
                            </StackPanel>
                            <StackPanel Grid.Column="4">
                                <TextBlock FontSize="{StaticResource Font.Size.Xs}" Foreground="{DynamicResource AppTextMuted}" Text="{DynamicResource Reports.Tax.DomesticCapitalGain}" />
                                <TextBlock Margin="0,4,0,0" FontFamily="{StaticResource Font.Family.Base}" FontSize="{StaticResource Font.Size.Lg}" FontWeight="SemiBold" Foreground="{DynamicResource AppTextPrimary}" Text="{Binding TaxSummary.DomesticCapitalGainTotal, StringFormat={}{0:N0}}" Typography.NumeralAlignment="Tabular" />
                            </StackPanel>
                            <StackPanel Grid.Column="6">
                                <TextBlock FontSize="{StaticResource Font.Size.Xs}" Foreground="{DynamicResource AppTextMuted}" Text="{DynamicResource Reports.Tax.OverseasCapitalGain}" />
                                <TextBlock Margin="0,4,0,0" FontFamily="{StaticResource Font.Family.Base}" FontSize="{StaticResource Font.Size.Lg}" FontWeight="SemiBold" Foreground="{DynamicResource AppTextPrimary}" Text="{Binding TaxSummary.OverseasCapitalGainTotal, StringFormat={}{0:N0}}" Typography.NumeralAlignment="Tabular" />
                            </StackPanel>
                        </Grid>

                        <!--  Overseas income + AMT trigger banner  -->
                        <Border
                            Margin="0,0,0,12"
                            Padding="12,10"
                            Background="{DynamicResource AppSurfaceAlt}"
                            BorderBrush="{DynamicResource AppBorder}"
                            BorderThickness="1"
                            CornerRadius="{StaticResource Radius.Sm}">
                            <Grid>
                                <Grid.ColumnDefinitions>
                                    <ColumnDefinition Width="*" />
                                    <ColumnDefinition Width="Auto" />
                                </Grid.ColumnDefinitions>
                                <StackPanel Grid.Column="0">
                                    <TextBlock FontSize="{StaticResource Font.Size.Xs}" Foreground="{DynamicResource AppTextSecondary}" Text="{DynamicResource Reports.Tax.OverseasIncome}" />
                                    <TextBlock Margin="0,2,0,0" FontFamily="{StaticResource Font.Family.Base}" FontSize="{StaticResource Font.Size.Md}" FontWeight="SemiBold" Foreground="{DynamicResource AppTextPrimary}" Text="{Binding TaxSummary.OverseasIncomeTotal, StringFormat={}{0:N0}}" Typography.NumeralAlignment="Tabular" />
                                </StackPanel>
                                <Border
                                    Grid.Column="1"
                                    Padding="8,3"
                                    VerticalAlignment="Center"
                                    Background="{DynamicResource AppDanger}"
                                    CornerRadius="{StaticResource Radius.Sm}"
                                    Visibility="{Binding TaxSummary.TriggersAmtDeclaration, Converter={StaticResource BooleanToVisibilityConverter}}">
                                    <TextBlock FontSize="{StaticResource Font.Size.Xs}" FontWeight="SemiBold" Foreground="{DynamicResource AppTextOnAccent}" Text="{DynamicResource Reports.Tax.AmtTriggered}" />
                                </Border>
                            </Grid>
                        </Border>

                        <!--  Records: dividends  -->
                        <TextBlock Margin="0,8,0,4" FontWeight="SemiBold" Foreground="{DynamicResource AppTextPrimary}" Text="{DynamicResource Reports.Tax.DividendRecords}" />
                        <ItemsControl ItemsSource="{Binding TaxSummary.Dividends}">
                            <ItemsControl.ItemTemplate>
                                <DataTemplate>
                                    <Grid Margin="0,3,0,0">
                                        <Grid.ColumnDefinitions>
                                            <ColumnDefinition Width="100" />
                                            <ColumnDefinition Width="*" />
                                            <ColumnDefinition Width="50" />
                                            <ColumnDefinition Width="Auto" />
                                        </Grid.ColumnDefinitions>
                                        <TextBlock Grid.Column="0" Foreground="{DynamicResource AppTextSecondary}" Text="{Binding Date}" Typography.NumeralAlignment="Tabular" />
                                        <TextBlock Grid.Column="1" Foreground="{DynamicResource AppTextPrimary}" Text="{Binding Symbol}" />
                                        <TextBlock Grid.Column="2" Foreground="{DynamicResource AppTextMuted}" Text="{Binding Country}" />
                                        <TextBlock Grid.Column="3" FontFamily="{StaticResource Font.Family.Base}" Typography.NumeralAlignment="Tabular" Text="{Binding Amount, StringFormat={}{0:N2}}" />
                                    </Grid>
                                </DataTemplate>
                            </ItemsControl.ItemTemplate>
                        </ItemsControl>

                        <!--  Records: capital gains  -->
                        <TextBlock Margin="0,16,0,4" FontWeight="SemiBold" Foreground="{DynamicResource AppTextPrimary}" Text="{DynamicResource Reports.Tax.CapitalGainRecords}" />
                        <ItemsControl ItemsSource="{Binding TaxSummary.CapitalGains}">
                            <ItemsControl.ItemTemplate>
                                <DataTemplate>
                                    <Grid Margin="0,3,0,0">
                                        <Grid.ColumnDefinitions>
                                            <ColumnDefinition Width="100" />
                                            <ColumnDefinition Width="*" />
                                            <ColumnDefinition Width="50" />
                                            <ColumnDefinition Width="Auto" />
                                        </Grid.ColumnDefinitions>
                                        <TextBlock Grid.Column="0" Foreground="{DynamicResource AppTextSecondary}" Text="{Binding Date}" Typography.NumeralAlignment="Tabular" />
                                        <TextBlock Grid.Column="1" Foreground="{DynamicResource AppTextPrimary}" Text="{Binding Symbol}" />
                                        <TextBlock Grid.Column="2" Foreground="{DynamicResource AppTextMuted}" Text="{Binding Country}" />
                                        <TextBlock Grid.Column="3" FontFamily="{StaticResource Font.Family.Base}" Typography.NumeralAlignment="Tabular" Text="{Binding RealizedPnl, StringFormat={}{0:N2}}" />
                                    </Grid>
                                </DataTemplate>
                            </ItemsControl.ItemTemplate>
                        </ItemsControl>
                    </StackPanel>
                </Grid>
            </Expander>

            <!--
                Multi-year tax comparison — only renders when ≥ 2 tax-bearing
                years exist in the trade journal. Single-year users get the
                regular TaxSummary card above; this avoids showing a 1-row
                table that adds no insight.
            -->
            <Expander
                Margin="0,0,0,16"
                Header="{DynamicResource Reports.Tax.MultiYear.Title}"
                IsExpanded="False"
                Style="{StaticResource AppExpander}"
                Visibility="{Binding HasMultiYearTax, Converter={StaticResource BooleanToVisibilityConverter}}">
                <Grid Margin="12">
                    <ItemsControl ItemsSource="{Binding MultiYearTaxRows}">
                        <ItemsControl.ItemTemplate>
                            <DataTemplate>
                                <Border
                                    Margin="0,0,0,4"
                                    Padding="10,8"
                                    Background="{DynamicResource AppSurfaceAlt}"
                                    BorderBrush="{DynamicResource AppBorder}"
                                    BorderThickness="1"
                                    CornerRadius="{StaticResource Radius.Sm}">
                                    <StackPanel>
                                        <!-- Row 1: 年度 + 各類所得 + AMT 觸發徽章 -->
                                        <Grid>
                                            <Grid.ColumnDefinitions>
                                                <ColumnDefinition Width="60" />
                                                <ColumnDefinition Width="*" />
                                                <ColumnDefinition Width="*" />
                                                <ColumnDefinition Width="*" />
                                                <ColumnDefinition Width="*" />
                                                <ColumnDefinition Width="80" />
                                                <ColumnDefinition Width="Auto" />
                                            </Grid.ColumnDefinitions>
                                            <StackPanel Grid.Column="0" VerticalAlignment="Center" Orientation="Horizontal">
                                                <TextBlock FontWeight="SemiBold" Foreground="{DynamicResource AppTextPrimary}" Text="{Binding Year}" Typography.NumeralAlignment="Tabular" />
                                                <!-- 推估資料警示徽章 -->
                                                <TextBlock Margin="4,0,0,0" FontSize="{StaticResource Font.Size.Xs}" Foreground="{DynamicResource AppTextMuted}" Text="*" ToolTip="{DynamicResource Reports.Tax.MultiYear.Extrapolated}" Visibility="{Binding ProfileExtrapolated, Converter={StaticResource BooleanToVisibilityConverter}}" />
                                            </StackPanel>
                                            <StackPanel Grid.Column="1">
                                                <TextBlock FontSize="{StaticResource Font.Size.Xs}" Foreground="{DynamicResource AppTextMuted}" Text="{DynamicResource Reports.Tax.DomesticDividend}" />
                                                <TextBlock FontFamily="{StaticResource Font.Family.Base}" Text="{Binding DomesticDividendTotal, StringFormat={}{0:N0}}" Typography.NumeralAlignment="Tabular" />
                                            </StackPanel>
                                            <StackPanel Grid.Column="2">
                                                <TextBlock FontSize="{StaticResource Font.Size.Xs}" Foreground="{DynamicResource AppTextMuted}" Text="{DynamicResource Reports.Tax.OverseasDividend}" />
                                                <TextBlock FontFamily="{StaticResource Font.Family.Base}" Text="{Binding OverseasDividendTotal, StringFormat={}{0:N0}}" Typography.NumeralAlignment="Tabular" />
                                            </StackPanel>
                                            <StackPanel Grid.Column="3">
                                                <TextBlock FontSize="{StaticResource Font.Size.Xs}" Foreground="{DynamicResource AppTextMuted}" Text="{DynamicResource Reports.Tax.DomesticCapitalGain}" />
                                                <TextBlock FontFamily="{StaticResource Font.Family.Base}" Text="{Binding DomesticCapitalGainTotal, StringFormat={}{0:N0}}" Typography.NumeralAlignment="Tabular" />
                                            </StackPanel>
                                            <StackPanel Grid.Column="4">
                                                <TextBlock FontSize="{StaticResource Font.Size.Xs}" Foreground="{DynamicResource AppTextMuted}" Text="{DynamicResource Reports.Tax.OverseasCapitalGain}" />
                                                <TextBlock FontFamily="{StaticResource Font.Family.Base}" Text="{Binding OverseasCapitalGainTotal, StringFormat={}{0:N0}}" Typography.NumeralAlignment="Tabular" />
                                            </StackPanel>
                                            <StackPanel Grid.Column="5">
                                                <TextBlock FontSize="{StaticResource Font.Size.Xs}" Foreground="{DynamicResource AppTextMuted}" Text="{DynamicResource Reports.Tax.RecordCount}" />
                                                <TextBlock FontFamily="{StaticResource Font.Family.Base}" Text="{Binding RecordCount}" Typography.NumeralAlignment="Tabular" />
                                            </StackPanel>
                                            <Border
                                                Grid.Column="6"
                                                Margin="8,0,0,0"
                                                Padding="6,1"
                                                VerticalAlignment="Center"
                                                Background="{DynamicResource AppDanger}"
                                                CornerRadius="{StaticResource Radius.Sm}"
                                                Visibility="{Binding TriggersAmtDeclaration, Converter={StaticResource BooleanToVisibilityConverter}}">
                                                <TextBlock FontSize="{StaticResource Font.Size.Xs}" FontWeight="SemiBold" Foreground="{DynamicResource AppTextOnAccent}" Text="{DynamicResource Reports.Tax.AmtTriggered}" />
                                            </Border>
                                        </Grid>

                                        <!-- Row 2: 應納稅額三欄（綜所稅 / AMT / 總稅負）+ AMT 免稅額 -->
                                        <Grid Margin="0,6,0,0">
                                            <Grid.ColumnDefinitions>
                                                <ColumnDefinition Width="60" />
                                                <ColumnDefinition Width="*" />
                                                <ColumnDefinition Width="*" />
                                                <ColumnDefinition Width="*" />
                                                <ColumnDefinition Width="*" />
                                            </Grid.ColumnDefinitions>
                                            <StackPanel Grid.Column="1">
                                                <TextBlock FontSize="{StaticResource Font.Size.Xs}" Foreground="{DynamicResource AppTextMuted}" Text="{DynamicResource Reports.Tax.MultiYear.IncomeTax}" />
                                                <TextBlock FontFamily="{StaticResource Font.Family.Base}" Foreground="{DynamicResource AppTextSecondary}" Text="{Binding IncomeTaxLiability, StringFormat={}{0:N0}}" Typography.NumeralAlignment="Tabular" />
                                            </StackPanel>
                                            <StackPanel Grid.Column="2">
                                                <TextBlock FontSize="{StaticResource Font.Size.Xs}" Foreground="{DynamicResource AppTextMuted}" Text="{DynamicResource Reports.Tax.MultiYear.AmtLiability}" />
                                                <TextBlock FontFamily="{StaticResource Font.Family.Base}" Foreground="{DynamicResource AppTextSecondary}" Text="{Binding AmtLiability, StringFormat={}{0:N0}}" Typography.NumeralAlignment="Tabular" />
                                            </StackPanel>
                                            <StackPanel Grid.Column="3">
                                                <TextBlock FontSize="{StaticResource Font.Size.Xs}" Foreground="{DynamicResource AppTextMuted}" Text="{DynamicResource Reports.Tax.MultiYear.AmtExemption}" />
                                                <TextBlock FontFamily="{StaticResource Font.Family.Base}" Foreground="{DynamicResource AppTextMuted}" Text="{Binding AmtExemption, StringFormat={}{0:N0}}" Typography.NumeralAlignment="Tabular" />
                                            </StackPanel>
                                            <StackPanel Grid.Column="4">
                                                <TextBlock FontSize="{StaticResource Font.Size.Xs}" FontWeight="SemiBold" Foreground="{DynamicResource AppAccent}" Text="{DynamicResource Reports.Tax.MultiYear.TotalLiability}" />
                                                <TextBlock FontFamily="{StaticResource Font.Family.Base}" FontWeight="SemiBold" Foreground="{DynamicResource AppAccent}" Text="{Binding TotalTaxLiability, StringFormat={}{0:N0}}" Typography.NumeralAlignment="Tabular" />
                                            </StackPanel>
                                        </Grid>
                                    </StackPanel>
                                </Border>
                            </DataTemplate>
                        </ItemsControl.ItemTemplate>
                    </ItemsControl>
                </Grid>
            </Expander>

            <!--
                AMT 完整稅額計算 — 使用 Settings.Amt.* 參數實算當年度應補繳。
                只在 HasAmtResult（有 TaxSummary 且已算出 AmtResult）時顯示。
            -->
            <Expander
                Margin="0,0,0,16"
                Header="{DynamicResource Reports.Tax.Amt.Title}"
                IsExpanded="False"
                Style="{StaticResource AppExpander}"
                Visibility="{Binding HasAmtResult, Converter={StaticResource BooleanToVisibilityConverter}}">
                <StackPanel Margin="12">
                    <TextBlock
                        Margin="0,0,0,12"
                        FontSize="{StaticResource Font.Size.Xs}"
                        Foreground="{DynamicResource AppTextMuted}"
                        Text="{DynamicResource Reports.Tax.Amt.Hint}"
                        TextWrapping="Wrap" />

                    <!-- Not-applicable banner (海外所得未達門檻 或 未填一般所得) -->
                    <Border
                        Margin="0,0,0,12"
                        Padding="10,8"
                        Background="{DynamicResource AppSurfaceAlt}"
                        BorderBrush="{DynamicResource AppBorder}"
                        BorderThickness="1"
                        CornerRadius="{StaticResource Radius.Sm}"
                        Visibility="{Binding AmtResult.IsApplicable, Converter={StaticResource InverseBooleanToVisibilityConverter}}">
                        <TextBlock
                            FontStyle="Italic"
                            Foreground="{DynamicResource AppTextSecondary}"
                            Text="{DynamicResource Reports.Tax.Amt.NotApplicable}"
                            TextWrapping="Wrap" />
                    </Border>

                    <!-- Formula breakdown — 含 5 項加項（僅顯示 > 0 的列）+ 海外抵稅 -->
                    <Border
                        Padding="14,12"
                        Background="{DynamicResource AppSurfaceAlt}"
                        BorderBrush="{DynamicResource AppBorder}"
                        BorderThickness="1"
                        CornerRadius="{StaticResource Radius.Md}">
                        <StackPanel>
                            <!-- 5 項加項：僅 > 0 顯示 -->
                            <Grid Visibility="{Binding AmtResult.OverseasIncomeIncluded, Converter={StaticResource NonZeroDecimalToVisibilityConverter}}">
                                <Grid.ColumnDefinitions><ColumnDefinition Width="*" /><ColumnDefinition Width="Auto" /></Grid.ColumnDefinitions>
                                <TextBlock Grid.Column="0" Foreground="{DynamicResource AppTextSecondary}" Text="{DynamicResource Reports.Tax.Amt.OverseasIncluded}" />
                                <TextBlock Grid.Column="1" FontFamily="{StaticResource Font.Family.Base}" FontWeight="SemiBold" Foreground="{DynamicResource AppTextPrimary}" Text="{Binding AmtResult.OverseasIncomeIncluded, StringFormat={}{0:N0}}" Typography.NumeralAlignment="Tabular" />
                            </Grid>
                            <Grid Margin="0,6,0,0" Visibility="{Binding AmtResult.InsuranceDeathIncluded, Converter={StaticResource NonZeroDecimalToVisibilityConverter}}">
                                <Grid.ColumnDefinitions><ColumnDefinition Width="*" /><ColumnDefinition Width="Auto" /></Grid.ColumnDefinitions>
                                <TextBlock Grid.Column="0" Foreground="{DynamicResource AppTextSecondary}" Text="{DynamicResource Reports.Tax.Amt.InsuranceDeathIncluded}" />
                                <TextBlock Grid.Column="1" FontFamily="{StaticResource Font.Family.Base}" FontWeight="SemiBold" Foreground="{DynamicResource AppTextPrimary}" Text="{Binding AmtResult.InsuranceDeathIncluded, StringFormat={}{0:N0}}" Typography.NumeralAlignment="Tabular" />
                            </Grid>
                            <Grid Margin="0,6,0,0" Visibility="{Binding AmtResult.InsuranceNonDeathIncluded, Converter={StaticResource NonZeroDecimalToVisibilityConverter}}">
                                <Grid.ColumnDefinitions><ColumnDefinition Width="*" /><ColumnDefinition Width="Auto" /></Grid.ColumnDefinitions>
                                <TextBlock Grid.Column="0" Foreground="{DynamicResource AppTextSecondary}" Text="{DynamicResource Reports.Tax.Amt.InsuranceNonDeathIncluded}" />
                                <TextBlock Grid.Column="1" FontFamily="{StaticResource Font.Family.Base}" FontWeight="SemiBold" Foreground="{DynamicResource AppTextPrimary}" Text="{Binding AmtResult.InsuranceNonDeathIncluded, StringFormat={}{0:N0}}" Typography.NumeralAlignment="Tabular" />
                            </Grid>
                            <Grid Margin="0,6,0,0" Visibility="{Binding AmtResult.UnlistedIncluded, Converter={StaticResource NonZeroDecimalToVisibilityConverter}}">
                                <Grid.ColumnDefinitions><ColumnDefinition Width="*" /><ColumnDefinition Width="Auto" /></Grid.ColumnDefinitions>
                                <TextBlock Grid.Column="0" Foreground="{DynamicResource AppTextSecondary}" Text="{DynamicResource Reports.Tax.Amt.UnlistedIncluded}" />
                                <TextBlock Grid.Column="1" FontFamily="{StaticResource Font.Family.Base}" FontWeight="SemiBold" Foreground="{DynamicResource AppTextPrimary}" Text="{Binding AmtResult.UnlistedIncluded, StringFormat={}{0:N0}}" Typography.NumeralAlignment="Tabular" />
                            </Grid>
                            <Grid Margin="0,6,0,0" Visibility="{Binding AmtResult.PrivateFundIncluded, Converter={StaticResource NonZeroDecimalToVisibilityConverter}}">
                                <Grid.ColumnDefinitions><ColumnDefinition Width="*" /><ColumnDefinition Width="Auto" /></Grid.ColumnDefinitions>
                                <TextBlock Grid.Column="0" Foreground="{DynamicResource AppTextSecondary}" Text="{DynamicResource Reports.Tax.Amt.PrivateFundIncluded}" />
                                <TextBlock Grid.Column="1" FontFamily="{StaticResource Font.Family.Base}" FontWeight="SemiBold" Foreground="{DynamicResource AppTextPrimary}" Text="{Binding AmtResult.PrivateFundIncluded, StringFormat={}{0:N0}}" Typography.NumeralAlignment="Tabular" />
                            </Grid>
                            <Grid Margin="0,6,0,0" Visibility="{Binding AmtResult.NonCashDonationAdded, Converter={StaticResource NonZeroDecimalToVisibilityConverter}}">
                                <Grid.ColumnDefinitions><ColumnDefinition Width="*" /><ColumnDefinition Width="Auto" /></Grid.ColumnDefinitions>
                                <TextBlock Grid.Column="0" Foreground="{DynamicResource AppTextSecondary}" Text="{DynamicResource Reports.Tax.Amt.NonCashDonationAdded}" />
                                <TextBlock Grid.Column="1" FontFamily="{StaticResource Font.Family.Base}" FontWeight="SemiBold" Foreground="{DynamicResource AppTextPrimary}" Text="{Binding AmtResult.NonCashDonationAdded, StringFormat={}{0:N0}}" Typography.NumeralAlignment="Tabular" />
                            </Grid>
                            <Grid Margin="0,6,0,0" Visibility="{Binding AmtResult.DividendSeparateAdded, Converter={StaticResource NonZeroDecimalToVisibilityConverter}}">
                                <Grid.ColumnDefinitions><ColumnDefinition Width="*" /><ColumnDefinition Width="Auto" /></Grid.ColumnDefinitions>
                                <TextBlock Grid.Column="0" Foreground="{DynamicResource AppTextSecondary}" Text="{DynamicResource Reports.Tax.Amt.DividendSeparateAdded}" />
                                <TextBlock Grid.Column="1" FontFamily="{StaticResource Font.Family.Base}" FontWeight="SemiBold" Foreground="{DynamicResource AppTextPrimary}" Text="{Binding AmtResult.DividendSeparateAdded, StringFormat={}{0:N0}}" Typography.NumeralAlignment="Tabular" />
                            </Grid>

                            <!-- 基本所得 / 基本稅額 / 一般稅額（恆顯示） -->
                            <Grid Margin="0,8,0,0">
                                <Grid.ColumnDefinitions><ColumnDefinition Width="*" /><ColumnDefinition Width="Auto" /></Grid.ColumnDefinitions>
                                <TextBlock Grid.Column="0" Foreground="{DynamicResource AppTextSecondary}" Text="{DynamicResource Reports.Tax.Amt.BaseTaxableIncome}" />
                                <TextBlock Grid.Column="1" FontFamily="{StaticResource Font.Family.Base}" FontWeight="SemiBold" Foreground="{DynamicResource AppTextPrimary}" Text="{Binding AmtResult.BaseTaxableIncome, StringFormat={}{0:N0}}" Typography.NumeralAlignment="Tabular" />
                            </Grid>
                            <Grid Margin="0,6,0,0">
                                <Grid.ColumnDefinitions><ColumnDefinition Width="*" /><ColumnDefinition Width="Auto" /></Grid.ColumnDefinitions>
                                <TextBlock Grid.Column="0" Foreground="{DynamicResource AppTextSecondary}" Text="{DynamicResource Reports.Tax.Amt.AmtBaseTax}" />
                                <TextBlock Grid.Column="1" FontFamily="{StaticResource Font.Family.Base}" FontWeight="SemiBold" Foreground="{DynamicResource AppTextPrimary}" Text="{Binding AmtResult.AmtBaseTax, StringFormat={}{0:N0}}" Typography.NumeralAlignment="Tabular" />
                            </Grid>
                            <Grid Margin="0,6,0,0">
                                <Grid.ColumnDefinitions><ColumnDefinition Width="*" /><ColumnDefinition Width="Auto" /></Grid.ColumnDefinitions>
                                <TextBlock Grid.Column="0" Foreground="{DynamicResource AppTextSecondary}" Text="{DynamicResource Reports.Tax.Amt.RegularIncomeTax}" />
                                <TextBlock Grid.Column="1" FontFamily="{StaticResource Font.Family.Base}" FontWeight="SemiBold" Foreground="{DynamicResource AppTextPrimary}" Text="{Binding AmtResult.RegularIncomeTax, StringFormat={}{0:N0}}" Typography.NumeralAlignment="Tabular" />
                            </Grid>
                            <Grid Margin="0,6,0,0" Visibility="{Binding AmtResult.OverseasTaxCreditApplied, Converter={StaticResource NonZeroDecimalToVisibilityConverter}}">
                                <Grid.ColumnDefinitions><ColumnDefinition Width="*" /><ColumnDefinition Width="Auto" /></Grid.ColumnDefinitions>
                                <TextBlock Grid.Column="0" Foreground="{DynamicResource AppTextSecondary}" Text="{DynamicResource Reports.Tax.Amt.OverseasTaxCreditApplied}" />
                                <TextBlock Grid.Column="1" FontFamily="{StaticResource Font.Family.Base}" FontWeight="SemiBold" Foreground="{DynamicResource AppTextPrimary}" Text="{Binding AmtResult.OverseasTaxCreditApplied, StringFormat={}-{0:N0}}" Typography.NumeralAlignment="Tabular" />
                            </Grid>

                            <!-- 應補繳 banner -->
                            <Border Margin="0,10,0,0" Padding="10,8" Background="{DynamicResource AppAccent}" CornerRadius="{StaticResource Radius.Sm}">
                                <Grid>
                                    <Grid.ColumnDefinitions><ColumnDefinition Width="*" /><ColumnDefinition Width="Auto" /></Grid.ColumnDefinitions>
                                    <TextBlock Grid.Column="0" FontWeight="SemiBold" Foreground="{DynamicResource AppTextOnAccent}" Text="{DynamicResource Reports.Tax.Amt.Liability}" />
                                    <TextBlock Grid.Column="1" FontFamily="{StaticResource Font.Family.Base}" FontSize="{StaticResource Font.Size.Lg}" FontWeight="SemiBold" Foreground="{DynamicResource AppTextOnAccent}" Text="{Binding AmtResult.AmtLiability, StringFormat={}{0:N0}}" Typography.NumeralAlignment="Tabular" />
                                </Grid>
                            </Border>

                            <!-- Profile extrapolated 警示 -->
                            <TextBlock Margin="0,8,0,0" FontSize="{StaticResource Font.Size.Xs}" FontStyle="Italic" Foreground="{DynamicResource AppTextMuted}" Text="{DynamicResource Reports.Tax.Amt.ProfileExtrapolated}" TextWrapping="Wrap" Visibility="{Binding AmtResult.ProfileExtrapolated, Converter={StaticResource BooleanToVisibilityConverter}}" />
                        </StackPanel>
                    </Border>
                </StackPanel>
            </Expander>

            <!--
                Stage 3 (Dashboard consolidation)：Performance / Risk 兩個 Expander
                已搬到「財務儀表板 → 資產趨勢」tab，作為「動態觀察」語意更合適的家。
                這裡保留為 Collapsed 以兼容既有 ReportsViewModel 計算（避免破壞測試），
                未來真要移除 service 注入可以等下一輪 cleanup。
            -->
            <Expander Style="{StaticResource AppExpander}" Header="{DynamicResource Reports.Performance.Title}" IsExpanded="False" Margin="0,0,0,16"
                      Visibility="Collapsed">
                <Grid>
                    <TextBlock
                        Margin="12"
                        FontStyle="Italic"
                        Foreground="{DynamicResource AppTextSecondary}"
                        Text="{DynamicResource Reports.Statement.Empty}"
                        Visibility="{Binding HasPerformance, Converter={StaticResource InverseBooleanToVisibilityConverter}}" />
                    <StackPanel Margin="12" Visibility="{Binding HasPerformance, Converter={StaticResource BooleanToVisibilityConverter}}">
                        <UniformGrid Columns="5" Rows="1">
                            <Border Margin="0,0,8,0" Padding="12" Background="{DynamicResource AppSurfaceAlt}" BorderBrush="{DynamicResource AppBorderLight}" BorderThickness="1" CornerRadius="{StaticResource Radius.Md}">
                                <StackPanel>
                                    <TextBlock FontSize="{StaticResource Font.Size.Xs}" Foreground="{DynamicResource AppTextSecondary}" Text="{DynamicResource Reports.Performance.Xirr}" />
                                    <TextBlock Margin="0,6,0,0" FontFamily="{StaticResource Font.Family.Base}" Typography.NumeralAlignment="Tabular" FontSize="{StaticResource Font.Size.Lg}" FontWeight="SemiBold" Foreground="{DynamicResource AppTextPrimary}" Text="{Binding Performance.Xirr, StringFormat={}{0:P2}, TargetNullValue=—}" />
                                </StackPanel>
                            </Border>
                            <Border Margin="8,0" Padding="12" Background="{DynamicResource AppSurfaceAlt}" BorderBrush="{DynamicResource AppBorderLight}" BorderThickness="1" CornerRadius="{StaticResource Radius.Md}">
                                <StackPanel>
                                    <TextBlock FontSize="{StaticResource Font.Size.Xs}" Foreground="{DynamicResource AppTextSecondary}" Text="{DynamicResource Reports.Performance.Twr}" />
                                    <TextBlock Margin="0,6,0,0" FontFamily="{StaticResource Font.Family.Base}" Typography.NumeralAlignment="Tabular" FontSize="{StaticResource Font.Size.Lg}" FontWeight="SemiBold" Foreground="{DynamicResource AppTextPrimary}" Text="{Binding Performance.Twr, StringFormat={}{0:P2}, TargetNullValue=—}" />
                                </StackPanel>
                            </Border>
                            <Border Margin="8,0" Padding="12" Background="{DynamicResource AppSurfaceAlt}" BorderBrush="{DynamicResource AppBorderLight}" BorderThickness="1" CornerRadius="{StaticResource Radius.Md}">
                                <StackPanel>
                                    <TextBlock FontSize="{StaticResource Font.Size.Xs}" Foreground="{DynamicResource AppTextSecondary}" Text="{DynamicResource Reports.Performance.Mwr}" />
                                    <TextBlock Margin="0,6,0,0" FontFamily="{StaticResource Font.Family.Base}" Typography.NumeralAlignment="Tabular" FontSize="{StaticResource Font.Size.Lg}" FontWeight="SemiBold" Foreground="{DynamicResource AppTextPrimary}" Text="{Binding Performance.Mwr, StringFormat={}{0:P2}, TargetNullValue=—}" />
                                </StackPanel>
                            </Border>
                            <Border Margin="8,0" Padding="12" Background="{DynamicResource AppSurfaceAlt}" BorderBrush="{DynamicResource AppBorderLight}" BorderThickness="1" CornerRadius="{StaticResource Radius.Md}">
                                <StackPanel>
                                    <TextBlock FontSize="{StaticResource Font.Size.Xs}" Foreground="{DynamicResource AppTextSecondary}" Text="{DynamicResource Reports.Performance.Benchmark}" />
                                    <TextBlock Margin="0,6,0,0" FontFamily="{StaticResource Font.Family.Base}" Typography.NumeralAlignment="Tabular" FontSize="{StaticResource Font.Size.Lg}" FontWeight="SemiBold" Foreground="{DynamicResource AppTextPrimary}" Text="{Binding Performance.BenchmarkTwr, StringFormat={}{0:P2}, TargetNullValue=—}" />
                                </StackPanel>
                            </Border>
                            <Border Margin="8,0,0,0" Padding="12" Background="{DynamicResource AppAccentSubtle}" BorderBrush="{DynamicResource AppBorderLight}" BorderThickness="1" CornerRadius="{StaticResource Radius.Md}">
                                <StackPanel>
                                    <TextBlock FontSize="{StaticResource Font.Size.Xs}" Foreground="{DynamicResource AppAccentText}" Text="{DynamicResource Reports.Performance.Alpha}" />
                                    <TextBlock Margin="0,6,0,0" FontFamily="{StaticResource Font.Family.Base}" Typography.NumeralAlignment="Tabular" FontSize="{StaticResource Font.Size.Lg}" FontWeight="SemiBold" Foreground="{DynamicResource AppAccentText}" Text="{Binding Performance.AlphaOverBenchmark, StringFormat={}{0:P2}, TargetNullValue=—}" />
                                </StackPanel>
                            </Border>
                        </UniformGrid>

                        <Border Margin="0,16,0,0" Padding="12" BorderBrush="{DynamicResource AppBorderLight}" BorderThickness="1" CornerRadius="{StaticResource Radius.Md}">
                            <StackPanel>
                                <TextBlock Margin="0,0,0,8" FontWeight="SemiBold" Foreground="{DynamicResource AppTextPrimary}" Text="{DynamicResource Reports.Performance.Attribution}" />
                                <TextBlock
                                    Foreground="{DynamicResource AppTextSecondary}"
                                    Text="{DynamicResource Reports.Performance.Attribution.Empty}"
                                    Visibility="{Binding HasPerformanceAttribution, Converter={StaticResource InverseBooleanToVisibilityConverter}}" />
                                <ItemsControl
                                    ItemsSource="{Binding PerformanceAttributionRows}"
                                    Visibility="{Binding HasPerformanceAttribution, Converter={StaticResource BooleanToVisibilityConverter}}">
                                    <ItemsControl.ItemTemplate>
                                        <DataTemplate>
                                            <Grid Margin="0,6,0,0">
                                                <Grid.ColumnDefinitions>
                                                    <ColumnDefinition Width="*" />
                                                    <ColumnDefinition Width="Auto" />
                                                </Grid.ColumnDefinitions>
                                                <TextBlock Grid.Column="0" Foreground="{DynamicResource AppTextSecondary}" Text="{Binding Label}" />
                                                <TextBlock
                                                    Grid.Column="1"
                                                    FontFamily="{StaticResource Font.Family.Base}"
                                                    Typography.NumeralAlignment="Tabular"
                                                    FontWeight="SemiBold"
                                                    Text="{Binding AmountDisplay}">
                                                    <TextBlock.Style>
                                                        <Style TargetType="TextBlock">
                                                            <Setter Property="Foreground" Value="{DynamicResource AppDown}" />
                                                            <Style.Triggers>
                                                                <DataTrigger Binding="{Binding IsPositive}" Value="True">
                                                                    <Setter Property="Foreground" Value="{DynamicResource AppUp}" />
                                                                </DataTrigger>
                                                            </Style.Triggers>
                                                        </Style>
                                                    </TextBlock.Style>
                                                </TextBlock>
                                            </Grid>
                                        </DataTemplate>
                                    </ItemsControl.ItemTemplate>
                                </ItemsControl>
                            </StackPanel>
                        </Border>
                    </StackPanel>
                </Grid>
            </Expander>

            <Expander Style="{StaticResource AppExpander}" Header="{DynamicResource Reports.Risk.Title}" IsExpanded="False" Margin="0,0,0,16">
                <!--
                    Stage 3 (Dashboard consolidation)：Risk Expander 暫留 Reports，
                    因為 HHI / Top Holdings 等內容尚未整合到 Trends 頁。下一輪
                    把 Volatility / Sharpe / HHI 接到 PortfolioHistoryViewModel
                    後再搬遷。
                -->
                <Grid>
                    <TextBlock
                        Margin="12"
                        FontStyle="Italic"
                        Foreground="{DynamicResource AppTextSecondary}"
                        Text="{DynamicResource Reports.Statement.Empty}"
                        Visibility="{Binding HasRisk, Converter={StaticResource InverseBooleanToVisibilityConverter}}" />
                    <StackPanel Margin="12" Visibility="{Binding HasRisk, Converter={StaticResource BooleanToVisibilityConverter}}">
                        <UniformGrid Columns="4" Rows="1">
                            <Border Margin="0,0,8,0" Padding="12" Background="{DynamicResource AppSurfaceAlt}" BorderBrush="{DynamicResource AppBorderLight}" BorderThickness="1" CornerRadius="{StaticResource Radius.Md}">
                                <StackPanel>
                                    <TextBlock FontSize="{StaticResource Font.Size.Xs}" Foreground="{DynamicResource AppTextSecondary}" Text="{DynamicResource Reports.Risk.AnnualizedVolatility}" />
                                    <TextBlock Margin="0,6,0,0" FontFamily="{StaticResource Font.Family.Base}" Typography.NumeralAlignment="Tabular" FontSize="{StaticResource Font.Size.Lg}" FontWeight="SemiBold" Foreground="{DynamicResource AppTextPrimary}" Text="{Binding Risk.AnnualizedVolatility, StringFormat={}{0:P2}, TargetNullValue=—}" />
                                </StackPanel>
                            </Border>
                            <Border Margin="8,0" Padding="12" Background="{DynamicResource AppSurfaceAlt}" BorderBrush="{DynamicResource AppBorderLight}" BorderThickness="1" CornerRadius="{StaticResource Radius.Md}">
                                <StackPanel>
                                    <TextBlock FontSize="{StaticResource Font.Size.Xs}" Foreground="{DynamicResource AppTextSecondary}" Text="{DynamicResource Reports.Risk.MaxDrawdown}" />
                                    <TextBlock Margin="0,6,0,0" FontFamily="{StaticResource Font.Family.Base}" Typography.NumeralAlignment="Tabular" FontSize="{StaticResource Font.Size.Lg}" FontWeight="SemiBold" Foreground="{DynamicResource AppTextPrimary}" Text="{Binding Risk.MaxDrawdown, StringFormat={}{0:P2}, TargetNullValue=—}" />
                                </StackPanel>
                            </Border>
                            <Border Margin="8,0" Padding="12" Background="{DynamicResource AppSurfaceAlt}" BorderBrush="{DynamicResource AppBorderLight}" BorderThickness="1" CornerRadius="{StaticResource Radius.Md}">
                                <StackPanel>
                                    <TextBlock FontSize="{StaticResource Font.Size.Xs}" Foreground="{DynamicResource AppTextSecondary}" Text="{DynamicResource Reports.Risk.SharpeRatio}" />
                                    <TextBlock Margin="0,6,0,0" FontFamily="{StaticResource Font.Family.Base}" Typography.NumeralAlignment="Tabular" FontSize="{StaticResource Font.Size.Lg}" FontWeight="SemiBold" Foreground="{DynamicResource AppTextPrimary}" Text="{Binding Risk.SharpeRatio, StringFormat={}{0:F2}, TargetNullValue=—}" />
                                </StackPanel>
                            </Border>
                            <Border Margin="8,0,0,0" Padding="12" Background="{DynamicResource AppSurfaceAlt}" BorderBrush="{DynamicResource AppBorderLight}" BorderThickness="1" CornerRadius="{StaticResource Radius.Md}">
                                <StackPanel>
                                    <TextBlock FontSize="{StaticResource Font.Size.Xs}" Foreground="{DynamicResource AppTextSecondary}" Text="{DynamicResource Reports.Risk.Hhi}" />
                                    <TextBlock Margin="0,6,0,0" FontFamily="{StaticResource Font.Family.Base}" Typography.NumeralAlignment="Tabular" FontSize="{StaticResource Font.Size.Lg}" FontWeight="SemiBold" Foreground="{DynamicResource AppTextPrimary}" Text="{Binding Risk.Hhi, StringFormat={}{0:F3}, TargetNullValue=—}" />
                                </StackPanel>
                            </Border>
                        </UniformGrid>

                        <Border Margin="0,12,0,0" Padding="10" Background="{DynamicResource AppAccentSubtle}" BorderBrush="{DynamicResource AppBorderLight}" BorderThickness="1" CornerRadius="{StaticResource Radius.Md}" Visibility="{Binding Risk.HasConcentrationWarning, Converter={StaticResource BooleanToVisibilityConverter}}">
                            <TextBlock FontWeight="SemiBold" Foreground="{DynamicResource AppDanger}" Text="{DynamicResource Reports.Risk.ConcentrationWarning}" TextWrapping="Wrap" />
                        </Border>

                        <Border Margin="0,16,0,0" Padding="12" BorderBrush="{DynamicResource AppBorderLight}" BorderThickness="1" CornerRadius="{StaticResource Radius.Md}">
                            <StackPanel>
                                <TextBlock Margin="0,0,0,8" FontWeight="SemiBold" Foreground="{DynamicResource AppTextPrimary}" Text="{DynamicResource Reports.Risk.TopHoldings}" />
                                <TextBlock
                                    Foreground="{DynamicResource AppTextSecondary}"
                                    Text="{DynamicResource Reports.Risk.TopHoldings.Empty}"
                                    Visibility="{Binding HasRiskTopHoldings, Converter={StaticResource InverseBooleanToVisibilityConverter}}" />
                                <ItemsControl
                                    ItemsSource="{Binding RiskTopHoldingRows}"
                                    Visibility="{Binding HasRiskTopHoldings, Converter={StaticResource BooleanToVisibilityConverter}}">
                                    <ItemsControl.ItemTemplate>
                                        <DataTemplate>
                                            <Grid Margin="0,8,0,0">
                                                <Grid.RowDefinitions>
                                                    <RowDefinition Height="Auto" />
                                                    <RowDefinition Height="Auto" />
                                                </Grid.RowDefinitions>
                                                <Grid.ColumnDefinitions>
                                                    <ColumnDefinition Width="*" />
                                                    <ColumnDefinition Width="Auto" />
                                                    <ColumnDefinition Width="Auto" />
                                                </Grid.ColumnDefinitions>
                                                <TextBlock Grid.Column="0" Foreground="{DynamicResource AppTextPrimary}" Text="{Binding Label}" />
                                                <TextBlock
                                                    Grid.Column="1"
                                                    Margin="16,0,0,0"
                                                    FontFamily="{StaticResource Font.Family.Base}"
                                                    Typography.NumeralAlignment="Tabular"
                                                    Foreground="{DynamicResource AppTextSecondary}"
                                                    Text="{Binding MarketValueDisplay}" />
                                                <TextBlock
                                                    Grid.Column="2"
                                                    Margin="16,0,0,0"
                                                    FontFamily="{StaticResource Font.Family.Base}"
                                                    Typography.NumeralAlignment="Tabular"
                                                    FontWeight="SemiBold"
                                                    Foreground="{DynamicResource AppTextPrimary}"
                                                    Text="{Binding WeightDisplay}" />
                                                <Border
                                                    Grid.Row="1"
                                                    Grid.Column="0"
                                                    Grid.ColumnSpan="3"
                                                    Height="4"
                                                    Margin="0,5,0,0"
                                                    Background="{DynamicResource AppBorder}"
                                                    CornerRadius="{StaticResource Radius.Xs}">
                                                    <Border
                                                        HorizontalAlignment="Left"
                                                        Background="{DynamicResource AppAccent}"
                                                        CornerRadius="{StaticResource Radius.Xs}">
                                                        <Border.Width>
                                                            <MultiBinding Converter="{StaticResource PercentToWidthConverter}">
                                                                <Binding Path="WeightPercent" />
                                                                <Binding Path="ActualWidth" RelativeSource="{RelativeSource AncestorType=ItemsControl}" />
                                                            </MultiBinding>
                                                        </Border.Width>
                                                    </Border>
                                                </Border>
                                            </Grid>
                                        </DataTemplate>
                                    </ItemsControl.ItemTemplate>
                                </ItemsControl>
                            </StackPanel>
                        </Border>
                    </StackPanel>
                </Grid>
            </Expander>
        </StackPanel>

            <TextBlock
                Grid.Row="4"
                Margin="0,8,0,0"
                Foreground="{DynamicResource AppTextSecondary}"
                Text="{Binding ExportStatus}" />
        </Grid>
    </ScrollViewer>
</UserControl>
