<UserControl
    x:Class="Assetra.WPF.Features.Import.ImportView"
    xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
    xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
    xmlns:d="http://schemas.microsoft.com/expression/blend/2008"
    xmlns:mc="http://schemas.openxmlformats.org/markup-compatibility/2006"
    xmlns:ui="http://schemas.lepo.co/wpfui/2022/xaml"
    xmlns:vm="clr-namespace:Assetra.WPF.Features.Import"
    xmlns:imp="clr-namespace:Assetra.Core.Models.Import;assembly=Assetra.Core"
    xmlns:sys="clr-namespace:System;assembly=mscorlib"
    d:DataContext="{d:DesignInstance Type={x:Type vm:ImportViewModel},
                                     IsDesignTimeCreatable=False}"
    d:DesignHeight="776"
    d:DesignWidth="1100"
    AllowDrop="True"
    Background="{DynamicResource AppBackground}"
    DragOver="OnDragOver"
    Drop="OnDrop"
    mc:Ignorable="d">

    <UserControl.Resources>
        <ObjectDataProvider
            x:Key="ResolutionValues"
            MethodName="GetValues"
            ObjectType="{x:Type sys:Enum}">
            <ObjectDataProvider.MethodParameters>
                <x:Type TypeName="imp:ImportConflictResolution" />
            </ObjectDataProvider.MethodParameters>
        </ObjectDataProvider>
    </UserControl.Resources>

    <Grid Margin="24">
        <Grid.RowDefinitions>
            <RowDefinition Height="Auto" />
            <RowDefinition Height="Auto" />
            <RowDefinition Height="Auto" />
            <RowDefinition Height="*" />
            <RowDefinition Height="Auto" />
        </Grid.RowDefinitions>

        <!--  ── Header ──  -->
        <StackPanel Grid.Row="0" Margin="0,0,0,16">
            <TextBlock
                FontFamily="{StaticResource FontTabular}"
                FontSize="{DynamicResource FontSizeXl}"
                FontWeight="SemiBold"
                Foreground="{DynamicResource AppTextPrimary}"
                Text="{DynamicResource Import.Title}" />
            <TextBlock
                Margin="0,4,0,0"
                Foreground="{DynamicResource AppTextSecondary}"
                Text="{DynamicResource Import.Subtitle}" />
        </StackPanel>

        <!--  ── Drop zone ──  -->
        <Border
            Grid.Row="1"
            Margin="0,0,0,16"
            Padding="32,28"
            Background="{DynamicResource AppSurface}"
            BorderBrush="{DynamicResource AppBorder}"
            BorderThickness="1.5"
            CornerRadius="12">
            <Grid>
                <Grid.ColumnDefinitions>
                    <ColumnDefinition Width="*" />
                    <ColumnDefinition Width="Auto" />
                </Grid.ColumnDefinitions>

                <StackPanel Grid.Column="0">
                    <TextBlock
                        FontFamily="{StaticResource FontTabular}"
                        FontSize="{DynamicResource FontSizeLg}"
                        FontWeight="SemiBold"
                        Foreground="{DynamicResource AppTextPrimary}"
                        Text="{DynamicResource Import.DropZone.Title}" />
                    <TextBlock
                        Margin="0,4,0,0"
                        Foreground="{DynamicResource AppTextSecondary}"
                        Text="{DynamicResource Import.DropZone.Hint}" />
                    <TextBlock
                        Margin="0,12,0,0"
                        FontWeight="SemiBold"
                        Foreground="{DynamicResource AppTextPrimary}"
                        Text="{Binding SelectedFileName}"
                        Visibility="{Binding HasFile, Converter={StaticResource BooleanToVisibilityConverter}}" />
                </StackPanel>

                <StackPanel Grid.Column="1" Orientation="Horizontal" VerticalAlignment="Center">
                    <ui:Button
                        Appearance="Primary"
                        Command="{Binding BrowseCommand}"
                        Content="{DynamicResource Import.Button.Browse}" />
                    <ui:Button
                        Margin="8,0,0,0"
                        Command="{Binding ClearCommand}"
                        Content="{DynamicResource Import.Button.Clear}"
                        Visibility="{Binding HasFile, Converter={StaticResource BooleanToVisibilityConverter}}" />
                </StackPanel>
            </Grid>
        </Border>

        <!--  ── Detection chip + cash account ──  -->
        <Grid Grid.Row="2" Margin="0,0,0,12">
            <Grid.ColumnDefinitions>
                <ColumnDefinition Width="Auto" />
                <ColumnDefinition Width="*" />
                <ColumnDefinition Width="Auto" />
            </Grid.ColumnDefinitions>

            <Border
                Grid.Column="0"
                Padding="12,6"
                VerticalAlignment="Center"
                Background="{DynamicResource AppAccentSubtle}"
                CornerRadius="999"
                Visibility="{Binding HasDetectedFormat, Converter={StaticResource BooleanToVisibilityConverter}}">
                <StackPanel Orientation="Horizontal">
                    <TextBlock
                        Foreground="{DynamicResource AppTextSecondary}"
                        Text="{DynamicResource Import.Detected.Prefix}" />
                    <TextBlock
                        Margin="6,0,0,0"
                        FontWeight="SemiBold"
                        Foreground="{DynamicResource AppTextPrimary}"
                        Text="{Binding DetectedFormatLabel}" />
                </StackPanel>
            </Border>

            <StackPanel
                Grid.Column="2"
                Orientation="Horizontal"
                VerticalAlignment="Center">
                <TextBlock
                    Margin="0,0,8,0"
                    VerticalAlignment="Center"
                    Foreground="{DynamicResource AppTextSecondary}"
                    Text="{DynamicResource Import.CashAccount.Label}" />
                <ComboBox
                    MinWidth="200"
                    DisplayMemberPath="DisplayName"
                    ItemsSource="{Binding CashAccountOptions}"
                    SelectedItem="{Binding SelectedCashAccount, Mode=TwoWay}" />
            </StackPanel>
        </Grid>

        <!--  ── Preview area ──  -->
        <Border
            Grid.Row="3"
            Background="{DynamicResource AppSurface}"
            BorderBrush="{DynamicResource AppBorder}"
            BorderThickness="1"
            CornerRadius="8">
            <Grid>
                <!--  Empty state  -->
                <StackPanel
                    HorizontalAlignment="Center"
                    VerticalAlignment="Center"
                    Visibility="{Binding HasNoRows, Converter={StaticResource BooleanToVisibilityConverter}}">
                    <TextBlock
                        FontStyle="Italic"
                        Foreground="{DynamicResource AppTextSecondary}"
                        Text="{DynamicResource Import.Empty}" />
                </StackPanel>

                <!--  Loading  -->
                <ui:ProgressRing
                    Width="48"
                    Height="48"
                    HorizontalAlignment="Center"
                    VerticalAlignment="Center"
                    IsIndeterminate="True"
                    Visibility="{Binding IsBusy, Converter={StaticResource BooleanToVisibilityConverter}}" />

                <!--  Preview grid  -->
                <DataGrid
                    AutoGenerateColumns="False"
                    Background="Transparent"
                    BorderThickness="0"
                    CanUserAddRows="False"
                    CanUserDeleteRows="False"
                    CanUserReorderColumns="False"
                    GridLinesVisibility="Horizontal"
                    HeadersVisibility="Column"
                    IsReadOnly="False"
                    ItemsSource="{Binding Rows}"
                    SelectionMode="Single"
                    Visibility="{Binding HasRows, Converter={StaticResource BooleanToVisibilityConverter}}">
                    <DataGrid.Columns>
                        <DataGridTextColumn
                            Width="40"
                            Binding="{Binding RowIndex}"
                            IsReadOnly="True">
                            <DataGridTextColumn.Header>
                                <TextBlock Text="#" />
                            </DataGridTextColumn.Header>
                        </DataGridTextColumn>
                        <DataGridTextColumn
                            Width="120"
                            Binding="{Binding DateDisplay}"
                            IsReadOnly="True">
                            <DataGridTextColumn.Header>
                                <TextBlock Text="{DynamicResource Import.Col.Date}" />
                            </DataGridTextColumn.Header>
                        </DataGridTextColumn>
                        <DataGridTextColumn
                            Width="140"
                            Binding="{Binding AmountDisplay}"
                            IsReadOnly="True">
                            <DataGridTextColumn.Header>
                                <TextBlock Text="{DynamicResource Import.Col.Amount}" />
                            </DataGridTextColumn.Header>
                        </DataGridTextColumn>
                        <DataGridTextColumn
                            Width="100"
                            Binding="{Binding Symbol}"
                            IsReadOnly="True">
                            <DataGridTextColumn.Header>
                                <TextBlock Text="{DynamicResource Import.Col.Symbol}" />
                            </DataGridTextColumn.Header>
                        </DataGridTextColumn>
                        <DataGridTextColumn
                            Width="*"
                            Binding="{Binding Counterparty}"
                            IsReadOnly="True">
                            <DataGridTextColumn.Header>
                                <TextBlock Text="{DynamicResource Import.Col.Counterparty}" />
                            </DataGridTextColumn.Header>
                        </DataGridTextColumn>
                        <DataGridTextColumn
                            Width="*"
                            Binding="{Binding Memo}"
                            IsReadOnly="True">
                            <DataGridTextColumn.Header>
                                <TextBlock Text="{DynamicResource Import.Col.Memo}" />
                            </DataGridTextColumn.Header>
                        </DataGridTextColumn>
                        <DataGridTemplateColumn Width="160">
                            <DataGridTemplateColumn.Header>
                                <TextBlock Text="{DynamicResource Import.Col.Resolution}" />
                            </DataGridTemplateColumn.Header>
                            <DataGridTemplateColumn.CellTemplate>
                                <DataTemplate DataType="{x:Type vm:ImportRowViewModel}">
                                    <Grid>
                                        <ComboBox
                                            ItemsSource="{Binding Source={StaticResource ResolutionValues}}"
                                            SelectedItem="{Binding Resolution, Mode=TwoWay}"
                                            Visibility="{Binding HasConflict, Converter={StaticResource BooleanToVisibilityConverter}}" />
                                        <TextBlock
                                            VerticalAlignment="Center"
                                            Foreground="{DynamicResource AppTextSecondary}"
                                            Text="{DynamicResource Import.Resolution.New}">
                                            <TextBlock.Style>
                                                <Style TargetType="TextBlock">
                                                    <Setter Property="Visibility" Value="Collapsed" />
                                                    <Style.Triggers>
                                                        <DataTrigger Binding="{Binding HasConflict}" Value="False">
                                                            <Setter Property="Visibility" Value="Visible" />
                                                        </DataTrigger>
                                                    </Style.Triggers>
                                                </Style>
                                            </TextBlock.Style>
                                        </TextBlock>
                                    </Grid>
                                </DataTemplate>
                            </DataGridTemplateColumn.CellTemplate>
                        </DataGridTemplateColumn>
                    </DataGrid.Columns>
                </DataGrid>
            </Grid>
        </Border>

        <!--  ── Footer ──  -->
        <Grid Grid.Row="4" Margin="0,16,0,0">
            <Grid.ColumnDefinitions>
                <ColumnDefinition Width="*" />
                <ColumnDefinition Width="Auto" />
            </Grid.ColumnDefinitions>

            <StackPanel Grid.Column="0" VerticalAlignment="Center">
                <TextBlock
                    Foreground="{DynamicResource AppTextSecondary}"
                    Text="{Binding StatusMessage}"
                    Visibility="{Binding StatusMessage, Converter={StaticResource StringToVisibilityConverter}}" />
                <TextBlock
                    Foreground="{DynamicResource AppDown}"
                    Text="{Binding ErrorMessage}"
                    Visibility="{Binding ErrorMessage, Converter={StaticResource StringToVisibilityConverter}}" />
                <TextBlock
                    Foreground="{DynamicResource AppUp}"
                    Text="{Binding ApplySummary}"
                    Visibility="{Binding ApplySummary, Converter={StaticResource StringToVisibilityConverter}}" />
            </StackPanel>

            <ui:Button
                Grid.Column="1"
                Appearance="Primary"
                Command="{Binding ApplyCommand}"
                Content="{DynamicResource Import.Button.Apply}"
                ToolTip="{DynamicResource Import.Apply.Tooltip}" />
        </Grid>
    </Grid>
</UserControl>
