<UserControl
    x:Class="Assetra.WPF.Features.PhysicalAsset.PhysicalAssetView"
    xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
    xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
    xmlns:d="http://schemas.microsoft.com/expression/blend/2008"
    xmlns:mc="http://schemas.openxmlformats.org/markup-compatibility/2006"
    xmlns:ui="http://schemas.lepo.co/wpfui/2022/xaml"
    xmlns:vm="clr-namespace:Assetra.WPF.Features.PhysicalAsset"
    d:DataContext="{d:DesignInstance Type={x:Type vm:PhysicalAssetViewModel}}"
    d:DesignHeight="800"
    d:DesignWidth="1200"
    Background="{DynamicResource AppBackground}"
    mc:Ignorable="d">

    <UserControl.Resources>
        <Style BasedOn="{StaticResource FormComboBox}" TargetType="ComboBox" />
    </UserControl.Resources>

    <Grid Margin="20">
        <Grid.RowDefinitions>
            <RowDefinition Height="Auto" />
            <RowDefinition Height="Auto" />
            <RowDefinition Height="Auto" />
            <RowDefinition Height="Auto" />
        </Grid.RowDefinitions>

        <StackPanel
            Grid.Row="0"
            Margin="0,0,0,16"
            Orientation="Horizontal">
            <TextBlock
                Margin="16,0,0,0"
                VerticalAlignment="Bottom"
                Foreground="{DynamicResource AppTextSecondary}">
                <Run Text="{DynamicResource PhysicalAsset.TotalValue}" />
                <Run Text="{Binding TotalCurrentValue, StringFormat=N0}" />
            </TextBlock>
            <TextBlock
                Margin="16,0,0,0"
                VerticalAlignment="Bottom"
                Foreground="{DynamicResource AppTextSecondary}">
                <Run Text="{DynamicResource PhysicalAsset.TotalGain}" />
                <Run Text="{Binding TotalUnrealizedGain, StringFormat=N0}" />
            </TextBlock>
        </StackPanel>

        <TextBlock
            Grid.Row="1"
            Margin="0,0,0,8"
            Foreground="{DynamicResource AppDanger}"
            Text="{Binding ErrorMessage}"
            Visibility="{Binding ErrorMessage, Converter={StaticResource NullToVisibilityConverter}}" />

        <Border
            Grid.Row="2"
            Background="{DynamicResource AppSurface}"
            BorderBrush="{DynamicResource AppBorder}"
            BorderThickness="1"
            CornerRadius="{StaticResource Card.Radius}">
            <ui:DataGrid
                MaxHeight="500"
                AutoGenerateColumns="False"
                CanUserAddRows="False"
                CanUserDeleteRows="False"
                GridLinesVisibility="Horizontal"
                HeadersVisibility="Column"
                IsReadOnly="True"
                ItemsSource="{Binding Assets}"
                RowBackground="Transparent"
                SelectionMode="Single">
                <DataGrid.Columns>
                    <DataGridTextColumn
                        Width="*"
                        Binding="{Binding Name}"
                        Header="{DynamicResource PhysicalAsset.Column.Name}" />
                    <DataGridTextColumn
                        Width="120"
                        Binding="{Binding Category}"
                        Header="{DynamicResource PhysicalAsset.Column.Category}" />
                    <DataGridTextColumn
                        Width="120"
                        Binding="{Binding AcquisitionCost, StringFormat=N0}"
                        Header="{DynamicResource PhysicalAsset.Column.Cost}" />
                    <DataGridTextColumn
                        Width="120"
                        Binding="{Binding CurrentValue, StringFormat=N0}"
                        Header="{DynamicResource PhysicalAsset.Column.CurrentValue}" />
                    <DataGridTextColumn
                        Width="120"
                        Binding="{Binding UnrealizedGain, StringFormat=N0}"
                        Header="{DynamicResource PhysicalAsset.Column.Gain}" />
                    <DataGridTextColumn
                        Width="100"
                        Binding="{Binding UnrealizedGainRate, StringFormat=P2}"
                        Header="{DynamicResource PhysicalAsset.Column.GainRate}" />
                    <DataGridTextColumn
                        Width="80"
                        Binding="{Binding Currency}"
                        Header="{DynamicResource PhysicalAsset.Column.Currency}" />
                    <DataGridTemplateColumn Width="120" Header="{DynamicResource Common.Actions}">
                        <DataGridTemplateColumn.CellTemplate>
                            <DataTemplate>
                                <StackPanel Orientation="Horizontal">
                                    <ui:Button
                                        Margin="0,0,4,0"
                                        Padding="6"
                                        Appearance="Transparent"
                                        Command="{Binding DataContext.EditCommand, RelativeSource={RelativeSource AncestorType=DataGrid}}"
                                        CommandParameter="{Binding}"
                                        ToolTip="{DynamicResource Common.Edit}">
                    <ui:SymbolIcon Symbol="Edit24" />
                  </ui:Button>
                                    <ui:Button
                                        Padding="6"
                                        Appearance="Transparent"
                                        Command="{Binding DataContext.DeleteCommand, RelativeSource={RelativeSource AncestorType=DataGrid}}"
                                        CommandParameter="{Binding}"
                                        ToolTip="{DynamicResource Common.Delete}">
                    <ui:SymbolIcon Foreground="{DynamicResource AppDanger}" Symbol="Delete24" />
                  </ui:Button>
                                </StackPanel>
                            </DataTemplate>
                        </DataGridTemplateColumn.CellTemplate>
                    </DataGridTemplateColumn>
                </DataGrid.Columns>
            </ui:DataGrid>
        </Border>

        <Border
            Grid.Row="3"
            Margin="0,16,0,0"
            Style="{StaticResource FormCard}">
            <StackPanel>
                <TextBlock Style="{StaticResource FormSectionTitle}" Text="{DynamicResource PhysicalAsset.Form.Title}" />
                <UniformGrid Columns="4" Rows="2">
                    <StackPanel Margin="0,0,8,8">
                        <TextBlock Foreground="{DynamicResource AppTextSecondary}" Text="{DynamicResource PhysicalAsset.Form.Name}" />
                        <ui:TextBox Text="{Binding FormName, UpdateSourceTrigger=PropertyChanged}" />
                    </StackPanel>
                    <StackPanel Margin="0,0,8,8">
                        <TextBlock Foreground="{DynamicResource AppTextSecondary}" Text="{DynamicResource PhysicalAsset.Form.Category}" />
                        <ComboBox ItemsSource="{Binding Categories}" SelectedItem="{Binding FormCategory}" />
                    </StackPanel>
                    <StackPanel Margin="0,0,8,8">
                        <TextBlock Foreground="{DynamicResource AppTextSecondary}" Text="{DynamicResource PhysicalAsset.Form.Description}" />
                        <ui:TextBox Text="{Binding FormDescription, UpdateSourceTrigger=PropertyChanged}" />
                    </StackPanel>
                    <StackPanel Margin="0,0,0,8">
                        <TextBlock Foreground="{DynamicResource AppTextSecondary}" Text="{DynamicResource PhysicalAsset.Form.Cost}" />
                        <ui:TextBox Text="{Binding FormAcquisitionCost, UpdateSourceTrigger=PropertyChanged}" />
                    </StackPanel>
                    <StackPanel Margin="0,0,8,0">
                        <TextBlock Foreground="{DynamicResource AppTextSecondary}" Text="{DynamicResource PhysicalAsset.Form.AcquisitionDate}" />
                        <ui:CalendarDatePicker Date="{Binding FormAcquisitionDate, Mode=TwoWay}" />
                    </StackPanel>
                    <StackPanel Margin="0,0,8,0">
                        <TextBlock Foreground="{DynamicResource AppTextSecondary}" Text="{DynamicResource PhysicalAsset.Form.CurrentValue}" />
                        <ui:TextBox Text="{Binding FormCurrentValue, UpdateSourceTrigger=PropertyChanged}" />
                    </StackPanel>
                    <StackPanel Margin="0,0,8,0">
                        <TextBlock Foreground="{DynamicResource AppTextSecondary}" Text="{DynamicResource PhysicalAsset.Form.ValuationMethod}" />
                        <ui:TextBox Text="{Binding FormValuationMethod, UpdateSourceTrigger=PropertyChanged}" />
                    </StackPanel>
                    <StackPanel>
                        <TextBlock Foreground="{DynamicResource AppTextSecondary}" Text="{DynamicResource PhysicalAsset.Form.Currency}" />
                        <ui:TextBox Text="{Binding FormCurrency, UpdateSourceTrigger=PropertyChanged}" />
                    </StackPanel>
                </UniformGrid>
                <StackPanel Margin="0,8,0,0">
                    <TextBlock Foreground="{DynamicResource AppTextSecondary}" Text="{DynamicResource PhysicalAsset.Form.Notes}" />
                    <ui:TextBox Text="{Binding FormNotes, UpdateSourceTrigger=PropertyChanged}" />
                </StackPanel>

                <TextBlock
                    Margin="0,8,0,0"
                    Foreground="{DynamicResource AppDanger}"
                    Text="{Binding FormError}"
                    Visibility="{Binding FormError, Converter={StaticResource NullToVisibilityConverter}}" />

                <StackPanel
                    Margin="0,12,0,0"
                    HorizontalAlignment="Right"
                    Orientation="Horizontal">
                    <ui:Button
                        Margin="0,0,8,0"
                        Command="{Binding CancelEditCommand}"
                        Content="{DynamicResource Common.Cancel}"
                        Appearance="Secondary"
                        Visibility="{Binding IsEditing, Converter={StaticResource BoolToVisibilityConverter}}" />
                    <ui:Button Command="{Binding SaveCommand}" Content="{DynamicResource Common.Save}" />
                </StackPanel>
            </StackPanel>
        </Border>
    </Grid>
</UserControl>
